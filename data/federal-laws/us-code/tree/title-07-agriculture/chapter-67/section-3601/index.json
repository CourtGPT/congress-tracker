{"type":"section","nativeType":"section","number":"3601","heading":"Definitions","label":"3601 Definitions","identifier":"/us/usc/t7/s3601","parentIdentifier":"/us/usc/t7/ch67","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3601","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s3601/1","parentIdentifier":"/us/usc/t7/s3601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3601%2F1","sourceRelease":"119-100","text":"The term “Agreement” means the International Sugar Agreement, 1977, signed at New York City on .December 9, 1977","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s3601/2","parentIdentifier":"/us/usc/t7/s3601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3601%2F2","sourceRelease":"119-100","text":"The term “sugar” has the same meaning as is given to such term in paragraph (12) of Article 2 of the Agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s3601/3","parentIdentifier":"/us/usc/t7/s3601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3601%2F3","sourceRelease":"119-100","text":"The term “entry” means entry, or withdrawal from warehouse, for consumption in the customs territory of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
