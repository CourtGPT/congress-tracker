{"type":"section","nativeType":"section","number":"9709","heading":"National Weather Service hydrologic research fellowship program","label":"9709 National Weather Service hydrologic research fellowship program","identifier":"/us/usc/t15/s9709","parentIdentifier":"/us/usc/t15/ch121","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t15/s9709/a","parentIdentifier":"/us/usc/t15/s9709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Assistant Administrator","label":"1 Assistant Administrator","identifier":"/us/usc/t15/s9709/a/1","parentIdentifier":"/us/usc/t15/s9709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fa%2F1","sourceRelease":"119-100","text":"The term “Assistant Administrator” means the Assistant Administrator for Weather Services of the National Oceanic and Atmospheric Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Decision support services","label":"2 Decision support services","identifier":"/us/usc/t15/s9709/a/2","parentIdentifier":"/us/usc/t15/s9709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fa%2F2","sourceRelease":"119-100","text":"The term “decision support services” means information, including data and refined products, that supports water resources-related decision-making processes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Institution of higher education","label":"3 Institution of higher education","identifier":"/us/usc/t15/s9709/a/3","parentIdentifier":"/us/usc/t15/s9709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fa%2F3","sourceRelease":"119-100","text":"The term “institution of higher education” has the meaning given that term in .section 1001 of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"NOAA line offices","label":"4 NOAA line offices","identifier":"/us/usc/t15/s9709/a/4","parentIdentifier":"/us/usc/t15/s9709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9709/a/4/A","parentIdentifier":"/us/usc/t15/s9709/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fa%2F4%2FA","sourceRelease":"119-100","text":"The National Ocean Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9709/a/4/B","parentIdentifier":"/us/usc/t15/s9709/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fa%2F4%2FB","sourceRelease":"119-100","text":"The National Environmental Satellite, Data, and Information Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9709/a/4/C","parentIdentifier":"/us/usc/t15/s9709/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fa%2F4%2FC","sourceRelease":"119-100","text":"The National Marine Fisheries Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s9709/a/4/D","parentIdentifier":"/us/usc/t15/s9709/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fa%2F4%2FD","sourceRelease":"119-100","text":"The Office of Oceanic and Atmospheric Research.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s9709/a/4/E","parentIdentifier":"/us/usc/t15/s9709/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fa%2F4%2FE","sourceRelease":"119-100","text":"The Office of Marine and Aviation Operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Hydrologic research fellowship program","label":"b Hydrologic research fellowship program","identifier":"/us/usc/t15/s9709/b","parentIdentifier":"/us/usc/t15/s9709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t15/s9709/b/1","parentIdentifier":"/us/usc/t15/s9709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F1","sourceRelease":"119-100","text":"The Administrator shall establish a hydrologic research fellowship program (in this section referred to as the “program”) for qualified individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Qualified individual","label":"2 Qualified individual","identifier":"/us/usc/t15/s9709/b/2","parentIdentifier":"/us/usc/t15/s9709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9709/b/2/A","parentIdentifier":"/us/usc/t15/s9709/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F2%2FA","sourceRelease":"119-100","text":"a citizen of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9709/b/2/B","parentIdentifier":"/us/usc/t15/s9709/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9709/b/2/B/i","parentIdentifier":"/us/usc/t15/s9709/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"hydrology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9709/b/2/B/ii","parentIdentifier":"/us/usc/t15/s9709/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"earth sciences;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s9709/b/2/B/iii","parentIdentifier":"/us/usc/t15/s9709/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"atmospheric sciences;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t15/s9709/b/2/B/iv","parentIdentifier":"/us/usc/t15/s9709/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"computer sciences;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t15/s9709/b/2/B/v","parentIdentifier":"/us/usc/t15/s9709/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F2%2FB%2Fv","sourceRelease":"119-100","text":"engineering;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t15/s9709/b/2/B/vi","parentIdentifier":"/us/usc/t15/s9709/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F2%2FB%2Fvi","sourceRelease":"119-100","text":"environmental sciences;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t15/s9709/b/2/B/vii","parentIdentifier":"/us/usc/t15/s9709/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F2%2FB%2Fvii","sourceRelease":"119-100","text":"geosciences;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t15/s9709/b/2/B/viii","parentIdentifier":"/us/usc/t15/s9709/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F2%2FB%2Fviii","sourceRelease":"119-100","text":"urban planning; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ix","heading":null,"label":"ix","identifier":"/us/usc/t15/s9709/b/2/B/ix","parentIdentifier":"/us/usc/t15/s9709/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F2%2FB%2Fix","sourceRelease":"119-100","text":"related social sciences.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Award guidelines","label":"3 Award guidelines","identifier":"/us/usc/t15/s9709/b/3","parentIdentifier":"/us/usc/t15/s9709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F3","sourceRelease":"119-100","text":"Fellowships under the program shall be awarded pursuant to guidelines established by the Assistant Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Selection preference","label":"4 Selection preference","identifier":"/us/usc/t15/s9709/b/4","parentIdentifier":"/us/usc/t15/s9709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F4","sourceRelease":"119-100","text":"In selecting qualified individuals for participation in the program, the Assistant Administrator shall give preference to applicants from historically Black colleges and universities and minority-serving institutions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Placement","label":"5 Placement","identifier":"/us/usc/t15/s9709/b/5","parentIdentifier":"/us/usc/t15/s9709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F5","sourceRelease":"119-100","text":"The program shall support the placement of qualified individuals in positions within the executive branch of the Federal Government where such individuals can address and advance the research priorities developed by the Assistant Administrator under paragraph (7).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Fellowship term","label":"6 Fellowship term","identifier":"/us/usc/t15/s9709/b/6","parentIdentifier":"/us/usc/t15/s9709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F6","sourceRelease":"119-100","text":"A fellowship under the program shall be for a period of up to 2 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Fellowship research priorities","label":"7 Fellowship research priorities","identifier":"/us/usc/t15/s9709/b/7","parentIdentifier":"/us/usc/t15/s9709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9709/b/7/A","parentIdentifier":"/us/usc/t15/s9709/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F7%2FA","sourceRelease":"119-100","text":"Advance the collaborative development of a flexible community-based water resources modeling system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9709/b/7/B","parentIdentifier":"/us/usc/t15/s9709/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F7%2FB","sourceRelease":"119-100","text":"Apply artificial intelligence and machine learning capabilities to advance existing hydrologic modeling capabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9709/b/7/C","parentIdentifier":"/us/usc/t15/s9709/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F7%2FC","sourceRelease":"119-100","text":"Support the evolution and integration of hydrologic modeling within an Earth Systems Modeling Framework.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s9709/b/7/D","parentIdentifier":"/us/usc/t15/s9709/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F7%2FD","sourceRelease":"119-100","text":"Improve visualizations of hydrologic model outputs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s9709/b/7/E","parentIdentifier":"/us/usc/t15/s9709/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F7%2FE","sourceRelease":"119-100","text":"Advance the state of coupled freshwater and salt water modeling and forecasting capabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t15/s9709/b/7/F","parentIdentifier":"/us/usc/t15/s9709/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F7%2FF","sourceRelease":"119-100","text":"Advance understanding and process representation of water quality parameters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t15/s9709/b/7/G","parentIdentifier":"/us/usc/t15/s9709/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F7%2FG","sourceRelease":"119-100","text":"Advance the assimilation of in-situ and remotely sensed observations and data.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t15/s9709/b/7/H","parentIdentifier":"/us/usc/t15/s9709/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F7%2FH","sourceRelease":"119-100","text":"Support the integration of social science to advance decision support services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s9709/b/7/I","parentIdentifier":"/us/usc/t15/s9709/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fb%2F7%2FI","sourceRelease":"119-100","text":"Develop methods to study groundwater sustainability and estimate the efficiency of recharge management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Direct hiring","label":"c Direct hiring","identifier":"/us/usc/t15/s9709/c","parentIdentifier":"/us/usc/t15/s9709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Authority","label":"1 Authority","identifier":"/us/usc/t15/s9709/c/1","parentIdentifier":"/us/usc/t15/s9709/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9709/c/1/A","parentIdentifier":"/us/usc/t15/s9709/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fc%2F1%2FA","sourceRelease":"119-100","text":"earned a degree from a program described in subsection (b)(2)(B);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9709/c/1/B","parentIdentifier":"/us/usc/t15/s9709/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fc%2F1%2FB","sourceRelease":"119-100","text":"successfully fulfilled the requirements of the fellowship within the executive branch of the Federal Government; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9709/c/1/C","parentIdentifier":"/us/usc/t15/s9709/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fc%2F1%2FC","sourceRelease":"119-100","text":"meets qualification standards established by the Office of Personnel Management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Exercise of authority","label":"2 Exercise of authority","identifier":"/us/usc/t15/s9709/c/2","parentIdentifier":"/us/usc/t15/s9709/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9709%2Fc%2F2","sourceRelease":"119-100","text":"The direct hire authority provided by this subsection shall be exercised with respect to an individual described in paragraph (1) not later than 2 years after the date on which the individual completed the fellowship under the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
