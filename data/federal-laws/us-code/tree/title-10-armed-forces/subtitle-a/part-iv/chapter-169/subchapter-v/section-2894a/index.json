{"type":"section","nativeType":"section","number":"2894a","heading":"Complaint database","label":"2894a Complaint database","identifier":"/us/usc/t10/s2894a","parentIdentifier":"/us/usc/t10/stA/ptIV/ch169/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2024—Subsec. (a). , substituted “by a tenant regarding covered dwelling units” for “regarding housing units”.Pub. L. 118–159, § 2825(a)(1)Subsecs. (c), (d). , substituted “covered dwelling unit” for “housing unit” in two places.Pub. L. 118–159, § 2825(a)(2)Subsec. (f). , added subsec. (f).Pub. L. 118–159, § 2825(a)(3)"],"amendments":["Amendments2024—Subsec. (a). , substituted “by a tenant regarding covered dwelling units” for “regarding housing units”.Pub. L. 118–159, § 2825(a)(1)Subsecs. (c), (d). , substituted “covered dwelling unit” for “housing unit” in two places.Pub. L. 118–159, § 2825(a)(2)Subsec. (f). , added subsec. (f).Pub. L. 118–159, § 2825(a)(3)"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Database Required","label":"a .—Database Required","identifier":"/us/usc/t10/s2894a/a","parentIdentifier":"/us/usc/t10/s2894a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Fa","sourceRelease":"119-100","text":"The Secretary of Defense shall establish a database of complaints made by a tenant regarding covered dwelling units.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Public Availability","label":"b .—Public Availability","identifier":"/us/usc/t10/s2894a/b","parentIdentifier":"/us/usc/t10/s2894a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Fb","sourceRelease":"119-100","text":"The database shall be available to the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Inclusion of Tenant Complaints","label":"c .—Inclusion of Tenant Complaints","identifier":"/us/usc/t10/s2894a/c","parentIdentifier":"/us/usc/t10/s2894a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Fc","sourceRelease":"119-100","text":"The Secretary of Defense shall permit a tenant of a covered dwelling unit to file a complaint regarding the covered dwelling unit for inclusion in the database.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Inclusion of Certain Information","label":"d .—Inclusion of Certain Information","identifier":"/us/usc/t10/s2894a/d","parentIdentifier":"/us/usc/t10/s2894a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2894a/d/1","parentIdentifier":"/us/usc/t10/s2894a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2894a/d/1/A","parentIdentifier":"/us/usc/t10/s2894a/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Fd%2F1%2FA","sourceRelease":"119-100","text":"The name of the installation for which the covered dwelling unit is provided.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2894a/d/1/B","parentIdentifier":"/us/usc/t10/s2894a/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Fd%2F1%2FB","sourceRelease":"119-100","text":"The name of the landlord responsible for the covered dwelling unit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s2894a/d/1/C","parentIdentifier":"/us/usc/t10/s2894a/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Fd%2F1%2FC","sourceRelease":"119-100","text":"A description of the nature of the complaint.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2894a/d/2","parentIdentifier":"/us/usc/t10/s2894a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Fd%2F2","sourceRelease":"119-100","text":"The Secretary of Defense may not disclose personally identifiable information through the database.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Response by Landlords","label":"e .—Response by Landlords","identifier":"/us/usc/t10/s2894a/e","parentIdentifier":"/us/usc/t10/s2894a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2894a/e/1","parentIdentifier":"/us/usc/t10/s2894a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Fe%2F1","sourceRelease":"119-100","text":"The Secretary of Defense shall include in any contract with a landlord responsible for a housing unit a requirement that the landlord respond in a timely manner to any complaints included in the database that relate to the housing unit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2894a/e/2","parentIdentifier":"/us/usc/t10/s2894a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Fe%2F2","sourceRelease":"119-100","text":"The Secretary shall include landlord responses in the database.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Definitions","label":"f .—Definitions","identifier":"/us/usc/t10/s2894a/f","parentIdentifier":"/us/usc/t10/s2894a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2894a/f/1","parentIdentifier":"/us/usc/t10/s2894a/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Ff%2F1","sourceRelease":"119-100","text":"The term “covered armed force” means the Army, Navy, Marine Corps, Air Force, or Space Force.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2894a/f/2","parentIdentifier":"/us/usc/t10/s2894a/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2894a/f/2/A","parentIdentifier":"/us/usc/t10/s2894a/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Ff%2F2%2FA","sourceRelease":"119-100","text":"that is acquired or constructed pursuant to subchapter IV of chapter 169 of this title;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2894a/f/2/B","parentIdentifier":"/us/usc/t10/s2894a/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Ff%2F2%2FB","sourceRelease":"119-100","text":"in which a member of a covered armed force resides; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s2894a/f/2/C","parentIdentifier":"/us/usc/t10/s2894a/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Ff%2F2%2FC","sourceRelease":"119-100","text":"that such member does not own.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2894a/f/3","parentIdentifier":"/us/usc/t10/s2894a/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Ff%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2894a/f/3/A","parentIdentifier":"/us/usc/t10/s2894a/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Ff%2F3%2FA","sourceRelease":"119-100","text":"A member of a covered armed force who resides in a covered dwelling unit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2894a/f/3/B","parentIdentifier":"/us/usc/t10/s2894a/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2894a%2Ff%2F3%2FB","sourceRelease":"119-100","text":"A dependent of a member described in subparagraph (A) who resides in a covered dwelling unit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
