{"type":"section","nativeType":"section","number":"6002","heading":"Purposes for grants","label":"6002 Purposes for grants","identifier":"/us/usc/t15/s6002","parentIdentifier":"/us/usc/t15/ch86","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6002","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s6002/1","parentIdentifier":"/us/usc/t15/s6002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6002%2F1","sourceRelease":"119-100","text":"enforce a law that requires individuals under the age of 16 to wear approved bicycle helmets on their heads while riding on bicycles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s6002/2","parentIdentifier":"/us/usc/t15/s6002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6002%2F2","sourceRelease":"119-100","text":"provide assistance, to individuals under the age of 16 who may not be able to afford approved bicycle helmets, to enable such individuals to acquire such helmets;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s6002/3","parentIdentifier":"/us/usc/t15/s6002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6002%2F3","sourceRelease":"119-100","text":"develop and administer a program to educate individuals under the age of 16 and their families on the importance of wearing such helmets in order to improve bicycle safety; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s6002/4","parentIdentifier":"/us/usc/t15/s6002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6002%2F4","sourceRelease":"119-100","text":"carry out any combination of the activities described in paragraphs (1), (2), and (3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
