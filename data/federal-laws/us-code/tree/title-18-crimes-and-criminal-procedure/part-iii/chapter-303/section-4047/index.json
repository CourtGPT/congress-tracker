{"type":"section","nativeType":"section","number":"4047","heading":"Prison impact assessments","label":"4047 Prison impact assessments","identifier":"/us/usc/t18/s4047","parentIdentifier":"/us/usc/t18/ptIII/ch303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4047","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t18/s4047/a","parentIdentifier":"/us/usc/t18/s4047","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4047%2Fa","sourceRelease":"119-100","text":"Any submission of legislation by the Judicial or Executive branch which could increase or decrease the number of persons incarcerated in Federal penal institutions shall be accompanied by a prison impact statement (as defined in subsection (b)).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t18/s4047/b","parentIdentifier":"/us/usc/t18/s4047","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4047%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s4047/b/1","parentIdentifier":"/us/usc/t18/s4047/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4047%2Fb%2F1","sourceRelease":"119-100","text":"projections of the impact on prison, probation, and post prison supervision populations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s4047/b/2","parentIdentifier":"/us/usc/t18/s4047/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4047%2Fb%2F2","sourceRelease":"119-100","text":"an estimate of the fiscal impact of such population changes on Federal expenditures, including those for construction and operation of correctional facilities for the current fiscal year and 5 succeeding fiscal years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s4047/b/3","parentIdentifier":"/us/usc/t18/s4047/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4047%2Fb%2F3","sourceRelease":"119-100","text":"an analysis of any other significant factor affecting the cost of the measure and its impact on the operations of components of the criminal justice system; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t18/s4047/b/4","parentIdentifier":"/us/usc/t18/s4047/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4047%2Fb%2F4","sourceRelease":"119-100","text":"a statement of the methodologies and assumptions utilized in preparing the assessment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t18/s4047/c","parentIdentifier":"/us/usc/t18/s4047","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4047%2Fc","sourceRelease":"119-100","text":"The Attorney General shall prepare and transmit to the Congress, by March 1 of each year, a prison impact assessment reflecting the cumulative effect of all relevant changes in the law taking effect during the preceding calendar year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
