{"type":"section","nativeType":"section","number":"1161z","heading":"Henry Kuualoha Giugni Kupuna Memorial Archives","label":"1161z Henry Kuualoha Giugni Kupuna Memorial Archives","identifier":"/us/usc/t20/s1161z","parentIdentifier":"/us/usc/t20/ch28/schIX/ptZ","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Grants authorized","label":"a Grants authorized","identifier":"/us/usc/t20/s1161z/a","parentIdentifier":"/us/usc/t20/s1161z","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fa","sourceRelease":"119-100","text":"From the amounts appropriated under subsection (c), the Secretary is authorized to award a grant to the University of Hawaii Academy for Creative Media for the establishment, maintenance, and periodic modernization of the Henry Kuualoha Giugni Kupuna Memorial Archives at the University of Hawaii.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Use of funds","label":"b Use of funds","identifier":"/us/usc/t20/s1161z/b","parentIdentifier":"/us/usc/t20/s1161z","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1161z/b/1","parentIdentifier":"/us/usc/t20/s1161z/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fb%2F1","sourceRelease":"119-100","text":"to facilitate the acquisition of a secure web-accessible repository of Native Hawaiian historical data rich in ethnic and cultural significance to the United States for preservation and access by future generations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1161z/b/2","parentIdentifier":"/us/usc/t20/s1161z/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fb%2F2","sourceRelease":"119-100","text":"to award scholarships to facilitate access to postsecondary education for students who cannot afford such education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s1161z/b/3","parentIdentifier":"/us/usc/t20/s1161z/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fb%2F3","sourceRelease":"119-100","text":"to support programmatic efforts associated with the web-based media projects of the archives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s1161z/b/4","parentIdentifier":"/us/usc/t20/s1161z/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fb%2F4","sourceRelease":"119-100","text":"to create educational materials, from the contents of the archives, that are applicable to a broad range of indigenous students, such as Native Hawaiians, Alaskan Natives, and Native American Indians;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t20/s1161z/b/5","parentIdentifier":"/us/usc/t20/s1161z/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fb%2F5","sourceRelease":"119-100","text":"to develop outreach initiatives that introduce the archival collections to elementary schools and secondary schools;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t20/s1161z/b/6","parentIdentifier":"/us/usc/t20/s1161z/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fb%2F6","sourceRelease":"119-100","text":"to develop supplemental web-based resources that define terms and cultural practices innate to Native Hawaiians;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t20/s1161z/b/7","parentIdentifier":"/us/usc/t20/s1161z/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fb%2F7","sourceRelease":"119-100","text":"to rent, lease, purchase, maintain, or repair educational facilities to house the archival collections;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t20/s1161z/b/8","parentIdentifier":"/us/usc/t20/s1161z/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fb%2F8","sourceRelease":"119-100","text":"to rent, lease, purchase, maintain, or repair computer equipment for use by elementary schools and secondary schools in accessing the archival collections;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t20/s1161z/b/9","parentIdentifier":"/us/usc/t20/s1161z/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fb%2F9","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161z/b/9/A","parentIdentifier":"/us/usc/t20/s1161z/b/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fb%2F9%2FA","sourceRelease":"119-100","text":"facilitate greater understanding by teachers of the unique background of indigenous students; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161z/b/9/B","parentIdentifier":"/us/usc/t20/s1161z/b/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fb%2F9%2FB","sourceRelease":"119-100","text":"improve student achievement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t20/s1161z/b/10","parentIdentifier":"/us/usc/t20/s1161z/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fb%2F10","sourceRelease":"119-100","text":"to increase the economic and financial literacy of postsecondary education students through the dissemination of best practices used at other institutions of higher education regarding debt and credit management and economic decisionmaking.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t20/s1161z/c","parentIdentifier":"/us/usc/t20/s1161z","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161z%2Fc","sourceRelease":"119-100","text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
