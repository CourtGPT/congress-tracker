{"type":"section","nativeType":"section","number":"11502","heading":"Entry of offenses in logbook","label":"11502 Entry of offenses in logbook","identifier":"/us/usc/t46/s11502","parentIdentifier":"/us/usc/t46/stII/ptG/ch115","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevised sectionSource section (U.S. Code)1150246:702Section 11502 describes the manner in which offenses must be recorded in the official logbook, and the use of the records by the court."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t46/s11502/a","parentIdentifier":"/us/usc/t46/s11502","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s11502/a/1","parentIdentifier":"/us/usc/t46/s11502/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fa%2F1","sourceRelease":"119-100","text":"on the day of the offense;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s11502/a/2","parentIdentifier":"/us/usc/t46/s11502/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fa%2F2","sourceRelease":"119-100","text":"stating the details;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s11502/a/3","parentIdentifier":"/us/usc/t46/s11502/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fa%2F3","sourceRelease":"119-100","text":"signed by the master; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t46/s11502/a/4","parentIdentifier":"/us/usc/t46/s11502/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fa%2F4","sourceRelease":"119-100","text":"signed by the chief mate or another seaman.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t46/s11502/b","parentIdentifier":"/us/usc/t46/s11502","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s11502/b/1","parentIdentifier":"/us/usc/t46/s11502/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fb%2F1","sourceRelease":"119-100","text":"the entry shall be read to the offender;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s11502/b/2","parentIdentifier":"/us/usc/t46/s11502/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fb%2F2","sourceRelease":"119-100","text":"the offender shall be given a copy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s11502/b/3","parentIdentifier":"/us/usc/t46/s11502/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fb%2F3","sourceRelease":"119-100","text":"the offender shall be given the opportunity to reply.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t46/s11502/c","parentIdentifier":"/us/usc/t46/s11502","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s11502/c/1","parentIdentifier":"/us/usc/t46/s11502/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fc%2F1","sourceRelease":"119-100","text":"stating that the entry about the offense was read and a copy provided to the offender;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s11502/c/2","parentIdentifier":"/us/usc/t46/s11502/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fc%2F2","sourceRelease":"119-100","text":"stating the offender’s reply;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s11502/c/3","parentIdentifier":"/us/usc/t46/s11502/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fc%2F3","sourceRelease":"119-100","text":"signed by the master; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t46/s11502/c/4","parentIdentifier":"/us/usc/t46/s11502/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fc%2F4","sourceRelease":"119-100","text":"signed by the chief mate or another seaman.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t46/s11502/d","parentIdentifier":"/us/usc/t46/s11502","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11502%2Fd","sourceRelease":"119-100","text":"In a subsequent legal proceeding, if the entries required by this section are not produced or proved, the court may refuse to receive evidence of the offense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
