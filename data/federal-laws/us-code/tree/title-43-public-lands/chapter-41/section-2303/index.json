{"type":"section","nativeType":"section","number":"2303","heading":"Identification of inholdings","label":"2303 Identification of inholdings","identifier":"/us/usc/t43/s2303","parentIdentifier":"/us/usc/t43/ch41","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2303","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t43/s2303/a","parentIdentifier":"/us/usc/t43/s2303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2303%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2303/a/1","parentIdentifier":"/us/usc/t43/s2303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2303%2Fa%2F1","sourceRelease":"119-100","text":"identify, by State, inholdings for which the landowner has indicated a desire to sell the land or interest therein to the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2303/a/2","parentIdentifier":"/us/usc/t43/s2303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2303%2Fa%2F2","sourceRelease":"119-100","text":"prioritize the acquisition of inholdings in accordance with .section 2305(c)(3) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Public notice","label":"b Public notice","identifier":"/us/usc/t43/s2303/b","parentIdentifier":"/us/usc/t43/s2303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2303%2Fb","sourceRelease":"119-100","text":"As soon as practicable after , and periodically thereafter, the Secretary and the Secretary of Agriculture shall provide public notice of the procedures referred to in subsection (a), including any information necessary for the consideration of an inholding under . Such notice shall include publication in the Federal Register and by such other means as the Secretary and the Secretary of Agriculture determine to be appropriate.July 25, 2000section 2305 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Identification","label":"c Identification","identifier":"/us/usc/t43/s2303/c","parentIdentifier":"/us/usc/t43/s2303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2303%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2303/c/1","parentIdentifier":"/us/usc/t43/s2303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2303%2Fc%2F1","sourceRelease":"119-100","text":"shall be considered for identification under this section only if the Secretary or the Secretary of Agriculture receive notification of a desire to sell from the landowner in response to public notice given under subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2303/c/2","parentIdentifier":"/us/usc/t43/s2303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2303%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2303/c/2/A","parentIdentifier":"/us/usc/t43/s2303/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2303%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s2303/c/2/A/i","parentIdentifier":"/us/usc/t43/s2303/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2303%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the date on which the land was withdrawn from the public domain; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s2303/c/2/A/ii","parentIdentifier":"/us/usc/t43/s2303/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2303%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the date on which the land was established or designated for special management; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2303/c/2/B","parentIdentifier":"/us/usc/t43/s2303/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2303%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the date on which the inholding was acquired by the current owner.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"No obligation to convey or acquire","label":"d No obligation to convey or acquire","identifier":"/us/usc/t43/s2303/d","parentIdentifier":"/us/usc/t43/s2303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2303%2Fd","sourceRelease":"119-100","text":"The identification of an inholding under this section creates no obligation on the part of a landowner to convey the inholding or any obligation on the part of the United States to acquire the inholding.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
