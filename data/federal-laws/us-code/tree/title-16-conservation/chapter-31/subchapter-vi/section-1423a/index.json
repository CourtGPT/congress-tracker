{"type":"section","nativeType":"section","number":"1423a","heading":"Prohibitions","label":"1423a Prohibitions","identifier":"/us/usc/t16/s1423a","parentIdentifier":"/us/usc/t16/ch31/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s1423a/a","parentIdentifier":"/us/usc/t16/s1423a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s1423a/a/1","parentIdentifier":"/us/usc/t16/s1423a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423a%2Fa%2F1","sourceRelease":"119-100","text":"to take any polar bear in violation of the Agreement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s1423a/a/2","parentIdentifier":"/us/usc/t16/s1423a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423a%2Fa%2F2","sourceRelease":"119-100","text":"to take any polar bear in violation of the Agreement or any annual taking limit or other restriction on the taking of polar bears that is adopted by the Commission pursuant to the Agreement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s1423a/a/3","parentIdentifier":"/us/usc/t16/s1423a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423a%2Fa%2F3","sourceRelease":"119-100","text":"to import, export, possess, transport, sell, receive, acquire, or purchase, exchange, barter, or offer to sell, purchase, exchange, or barter any polar bear, or any part or product of a polar bear, that is taken in violation of paragraph (2);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s1423a/a/4","parentIdentifier":"/us/usc/t16/s1423a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423a%2Fa%2F4","sourceRelease":"119-100","text":"to import, export, sell, purchase, exchange, barter, or offer to sell, purchase, exchange, or barter, any polar bear gall bile or polar bear gall bladder;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s1423a/a/5","parentIdentifier":"/us/usc/t16/s1423a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423a%2Fa%2F5","sourceRelease":"119-100","text":"to attempt to commit, solicit another person to commit, or cause to be committed, any offense under this subsection; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s1423a/a/6","parentIdentifier":"/us/usc/t16/s1423a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423a%2Fa%2F6","sourceRelease":"119-100","text":"to violate any regulation promulgated by the Secretary to implement any of the prohibitions established in this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Exceptions","label":"b Exceptions","identifier":"/us/usc/t16/s1423a/b","parentIdentifier":"/us/usc/t16/s1423a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423a%2Fb","sourceRelease":"119-100","text":"For the purpose of forensic testing or any other law enforcement purpose, the Secretary, and Federal law enforcement officials, and any State or local law enforcement official authorized by the Secretary, may import a polar bear or any part or product of a polar bear.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
