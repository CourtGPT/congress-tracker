":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s6323/b/5","parentIdentifier":"/us/usc/t22/s6323/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6323%2Fb%2F5","sourceRelease":"119-100","text":"any recommendations of the President on additional measures to enhance the effectiveness of IAEA safeguards; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s6323/b/6","parentIdentifier":"/us/usc/t22/s6323/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6323%2Fb%2F6","sourceRelease":"119-100","text":"any initiatives that the President plans to take in support of each of the objectives set forth in sections 6321 and 6322 of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
