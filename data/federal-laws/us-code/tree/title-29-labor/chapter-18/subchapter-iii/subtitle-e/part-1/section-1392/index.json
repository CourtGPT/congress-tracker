{"type":"section","nativeType":"section","number":"1392","heading":"Obligation to contribute","label":"1392 Obligation to contribute","identifier":"/us/usc/t29/s1392","parentIdentifier":"/us/usc/t29/ch18/schIII/stE/pt1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1392","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"“Obligation to contribute” defined","label":"a “Obligation to contribute” defined","identifier":"/us/usc/t29/s1392/a","parentIdentifier":"/us/usc/t29/s1392","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1392%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s1392/a/1","parentIdentifier":"/us/usc/t29/s1392/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1392%2Fa%2F1","sourceRelease":"119-100","text":"under one or more collective bargaining (or related) agreements, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s1392/a/2","parentIdentifier":"/us/usc/t29/s1392/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1392%2Fa%2F2","sourceRelease":"119-100","text":"as a result of a duty under applicable labor-management relations law, but","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Payments of withdrawal liability not considered contributions","label":"b Payments of withdrawal liability not considered contributions","identifier":"/us/usc/t29/s1392/b","parentIdentifier":"/us/usc/t29/s1392","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1392%2Fb","sourceRelease":"119-100","text":"Payments of withdrawal liability under this part shall not be considered contributions for purposes of this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Transactions to evade or avoid liability","label":"c Transactions to evade or avoid liability","identifier":"/us/usc/t29/s1392/c","parentIdentifier":"/us/usc/t29/s1392","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1392%2Fc","sourceRelease":"119-100","text":"If a principal purpose of any transaction is to evade or avoid liability under this part, this part shall be applied (and liability shall be determined and collected) without regard to such transaction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
