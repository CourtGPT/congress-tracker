{"type":"section","nativeType":"section","number":"5903","heading":"Establishment of Realty Ombudsman position","label":"5903 Establishment of Realty Ombudsman position","identifier":"/us/usc/t25/s5903","parentIdentifier":"/us/usc/t25/ch51","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5903","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t25/s5903/a","parentIdentifier":"/us/usc/t25/s5903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5903%2Fa","sourceRelease":"119-100","text":"The Director shall establish within the Division of Real Estate Services of the Bureau the position of Realty Ombudsman, who shall report directly to the Secretary of the Interior.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Functions","label":"b Functions","identifier":"/us/usc/t25/s5903/b","parentIdentifier":"/us/usc/t25/s5903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5903%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s5903/b/1","parentIdentifier":"/us/usc/t25/s5903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5903%2Fb%2F1","sourceRelease":"119-100","text":"ensure that the applicable Bureau offices are meeting the mortgage review and processing deadlines established by ;section 5902(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s5903/b/2","parentIdentifier":"/us/usc/t25/s5903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5903%2Fb%2F2","sourceRelease":"119-100","text":"ensure that the applicable Bureau offices comply with the notices required under subsections (a) and (b) of ;section 5902 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s5903/b/3","parentIdentifier":"/us/usc/t25/s5903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5903%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s5903/b/3/A","parentIdentifier":"/us/usc/t25/s5903/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5903%2Fb%2F3%2FA","sourceRelease":"119-100","text":"ensuring the Bureau is responsive to all of the inquiries from the relevant Federal agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s5903/b/3/B","parentIdentifier":"/us/usc/t25/s5903/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5903%2Fb%2F3%2FB","sourceRelease":"119-100","text":"helping to facilitate communications between the relevant Federal agencies and the Bureau on matters relating to mortgages on Indian land;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s5903/b/4","parentIdentifier":"/us/usc/t25/s5903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5903%2Fb%2F4","sourceRelease":"119-100","text":"receive inquiries, questions, and complaints directly from Indian Tribes, members of Indian Tribes, and lenders in regard to executed residential leasehold mortgages, business leasehold mortgages, land mortgages, or right-of-way documents; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s5903/b/5","parentIdentifier":"/us/usc/t25/s5903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5903%2Fb%2F5","sourceRelease":"119-100","text":"serve as the intermediary between the Indian Tribes, members of Indian Tribes, and lenders and the Bureau in responding to inquiries and questions and resolving complaints.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
