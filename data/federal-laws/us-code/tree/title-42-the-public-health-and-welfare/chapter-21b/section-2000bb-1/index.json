{"type":"section","nativeType":"section","number":"2000bb–1","heading":"Free exercise of religion protected","label":"2000bb–1 Free exercise of religion protected","identifier":"/us/usc/t42/s2000bb–1","parentIdentifier":"/us/usc/t42/ch21B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs2000bb%E2%80%931","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s2000bb–1/a","parentIdentifier":"/us/usc/t42/s2000bb–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs2000bb%E2%80%931%2Fa","sourceRelease":"119-100","text":"Government shall not substantially burden a person’s exercise of religion even if the burden results from a rule of general applicability, except as provided in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Exception","label":"b Exception","identifier":"/us/usc/t42/s2000bb–1/b","parentIdentifier":"/us/usc/t42/s2000bb–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs2000bb%E2%80%931%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s2000bb–1/b/1","parentIdentifier":"/us/usc/t42/s2000bb–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs2000bb%E2%80%931%2Fb%2F1","sourceRelease":"119-100","text":"is in furtherance of a compelling governmental interest; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s2000bb–1/b/2","parentIdentifier":"/us/usc/t42/s2000bb–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs2000bb%E2%80%931%2Fb%2F2","sourceRelease":"119-100","text":"is the least restrictive means of furthering that compelling governmental interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Judicial relief","label":"c Judicial relief","identifier":"/us/usc/t42/s2000bb–1/c","parentIdentifier":"/us/usc/t42/s2000bb–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs2000bb%E2%80%931%2Fc","sourceRelease":"119-100","text":"A person whose religious exercise has been burdened in violation of this section may assert that violation as a claim or defense in a judicial proceeding and obtain appropriate relief against a government. Standing to assert a claim or defense under this section shall be governed by the general rules of standing under article III of the Constitution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
