{"type":"section","nativeType":"section","number":"8501","heading":"Promotion of outdoor recreation for military servicemembers and veterans","label":"8501 Promotion of outdoor recreation for military servicemembers and veterans","identifier":"/us/usc/t16/s8501","parentIdentifier":"/us/usc/t16/ch103/schII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8501","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s8501/1","parentIdentifier":"/us/usc/t16/s8501","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8501%2F1","sourceRelease":"119-100","text":"opportunities for members of the Armed Forces and veterans to access Federal recreational lands and waters free of charge under ;section 6804 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s8501/2","parentIdentifier":"/us/usc/t16/s8501","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8501%2F2","sourceRelease":"119-100","text":"the availability and location of accessible trails, including new accessible trails developed and completed under ;section 8484 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s8501/3","parentIdentifier":"/us/usc/t16/s8501","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8501%2F3","sourceRelease":"119-100","text":"the availability and location of accessible recreation opportunities, including new accessible recreation opportunities developed and completed under ;section 8485 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"pa