","sourceRelease":"119-100","text":"a plant disease; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s8914/a/4/A/ii","parentIdentifier":"/us/usc/t7/s8914/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F4%2FA%2Fii","sourceRelease":"119-100","text":"a plant pest; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s8914/a/4/B","parentIdentifier":"/us/usc/t7/s8914/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F4%2FB","sourceRelease":"119-100","text":"of high consequence, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Pest","label":"5 Pest","identifier":"/us/usc/t7/s8914/a/5","parentIdentifier":"/us/usc/t7/s8914/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s8914/a/5/A","parentIdentifier":"/us/usc/t7/s8914/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F5%2FA","sourceRelease":"119-100","text":"with respect to a plant, has the meaning given the term “plant pest” in ; andsection 7702 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s8914/a/5/B","parentIdentifier":"/us/usc/t7/s8914/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F5%2FB","sourceRelease":"119-100","text":"with respect to an animal, has the meaning given the term in .section 8302 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Plant","label":"6 Plant","identifier":"/us/usc/t7/s8914/a/6","parentIdentifier":"/us/usc/t7/s8914/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F6","sourceRelease":"119-100","text":"The term “plant” has the meaning given the term in .section 7702 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Plant health management strategy","label":"7 Plant health management strategy","identifier":"/us/usc/t7/s8914/a/7","parentIdentifier":"/us/usc/t7/s8914/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F7","sourceRelease":"119-100","text":"The term “plant health management strategy” means a strategy to timely control and eradicate a plant disease or plant pest outbreak, including through mitigation (such as chemical control), surveillance, the use of diagnostic products and procedures, and the use of existing resistant seed stock.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Transboundary disease","label":"8 Transboundary disease","identifier":"/us/usc/t7/s8914/a/8","parentIdentifier":"/us/usc/t7/s8914/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s8914/a/8/A","parentIdentifier":"/us/usc/t7/s8914/a/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F8%2FA","sourceRelease":"119-100","text":"The term “transboundary disease” means a plant or animal disease or pest that is within 1 or more countries outside of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Inclusion","label":"B Inclusion","identifier":"/us/usc/t7/s8914/a/8/B","parentIdentifier":"/us/usc/t7/s8914/a/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F8%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s8914/a/8/B/i","parentIdentifier":"/us/usc/t7/s8914/a/8/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F8%2FB%2Fi","sourceRelease":"119-100","text":"has emerged within the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s8914/a/8/B/ii","parentIdentifier":"/us/usc/t7/s8914/a/8/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F8%2FB%2Fii","sourceRelease":"119-100","text":"has been introduced within the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":"Veterinary countermeasure","label":"9 Veterinary countermeasure","identifier":"/us/usc/t7/s8914/a/9","parentIdentifier":"/us/usc/t7/s8914/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F9","sourceRelease":"119-100","text":"The term “veterinary countermeasure” has the meaning given such term in .section 8302 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Disease or Pest of Concern Response Planning","label":"b Disease or Pest of Concern Response Planning","identifier":"/us/usc/t7/s8914/b","parentIdentifier":"/us/usc/t7/s8914","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s8914/b/1","parentIdentifier":"/us/usc/t7/s8914/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s8914/b/1/A","parentIdentifier":"/us/usc/t7/s8914/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s8914/b/1/A/i","parentIdentifier":"/us/usc/t7/s8914/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"developing a process to solicit and receive expert opinion and evidence relating to the diseases or pests of concern entered on the list; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s8914/b/1/A/ii","parentIdentifier":"/us/usc/t7/s8914/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"reviewing all available evidence relating to the diseases or pests of concern entered on the list, including classified information; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s8914/b/1/B","parentIdentifier":"/us/usc/t7/s8914/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F1%2FB","sourceRelease":"119-100","text":"periodically update the list established under subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Response plans","label":"2 Response plans","identifier":"/us/usc/t7/s8914/b/2","parentIdentifier":"/us/usc/t7/s8914/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Comprehensive strategic response plan or plans","label":"A Comprehensive strategic response plan or plans","identifier":"/us/usc/t7/s8914/b/2/A","parentIdentifier":"/us/usc/t7/s8914/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The Secretary shall develop, in collaboration with appropriate Federal, State, regional, and local officials, a comprehensive strategic response plan or plans, as appropriate, for the diseases or pests of concern that are entered on the list established under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"State or region response plan or plans","label":"B State or region response plan or plans","identifier":"/us/usc/t7/s8914/b/2/B","parentIdentifier":"/us/usc/t7/s8914/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate"