{"type":"section","nativeType":"section","number":"2013","heading":"NMIC requirements and review","label":"2013 NMIC requirements and review","identifier":"/us/usc/t21/s2013","parentIdentifier":"/us/usc/t21/ch25/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t21/s2013/a","parentIdentifier":"/us/usc/t21/s2013","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fa","sourceRelease":"119-100","text":"The NMIC shall promote sharing information regarding successful law enforcement, treatment, environmental, prevention, social services, and other programs related to the production, use, or effects of methamphetamine and grants available for such programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Components","label":"b Components","identifier":"/us/usc/t21/s2013/b","parentIdentifier":"/us/usc/t21/s2013","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s2013/b/1","parentIdentifier":"/us/usc/t21/s2013/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fb%2F1","sourceRelease":"119-100","text":"a toll-free number; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s2013/b/2","parentIdentifier":"/us/usc/t21/s2013/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s2013/b/2/A","parentIdentifier":"/us/usc/t21/s2013/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fb%2F2%2FA","sourceRelease":"119-100","text":"provides information on the short-term and long-term effects of methamphetamine use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s2013/b/2/B","parentIdentifier":"/us/usc/t21/s2013/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fb%2F2%2FB","sourceRelease":"119-100","text":"provides information regarding methamphetamine treatment and prevention programs and strategies and programs for drug endangered children, including descriptions of successful programs and strategies and contact information for such programs and strategies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t21/s2013/b/2/C","parentIdentifier":"/us/usc/t21/s2013/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fb%2F2%2FC","sourceRelease":"119-100","text":"provides information regarding grants for methamphetamine-related programs, including contact information and links to websites;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t21/s2013/b/2/D","parentIdentifier":"/us/usc/t21/s2013/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fb%2F2%2FD","sourceRelease":"119-100","text":"allows a qualified entity to submit items to be posted on the website regarding successful public or private programs or other useful information related to the production, use, or effects of methamphetamine;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t21/s2013/b/2/E","parentIdentifier":"/us/usc/t21/s2013/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fb%2F2%2FE","sourceRelease":"119-100","text":"includes a restricted section that may only be accessed by a law enforcement organization that contains successful strategies, training techniques, and other information that the Council determines helpful to law enforcement agency efforts to identify or combat the production, use, or effects of methamphetamine;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t21/s2013/b/2/F","parentIdentifier":"/us/usc/t21/s2013/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fb%2F2%2FF","sourceRelease":"119-100","text":"allows public access to all information not in a restricted section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t21/s2013/b/2/G","parentIdentifier":"/us/usc/t21/s2013/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fb%2F2%2FG","sourceRelease":"119-100","text":"contains any additional information the Council determines may be useful in identifying or combating the production, use, or effects of methamphetamine.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Review of posted information","label":"c Review of posted information","identifier":"/us/usc/t21/s2013/c","parentIdentifier":"/us/usc/t21/s2013","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t21/s2013/c/1","parentIdentifier":"/us/usc/t21/s2013/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s2013/c/1/A","parentIdentifier":"/us/usc/t21/s2013/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fc%2F1%2FA","sourceRelease":"119-100","text":"to evaluate and determine whether the item, as submitted or as modified, meets the requirements for posting; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s2013/c/1/B","parentIdentifier":"/us/usc/t21/s2013/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fc%2F1%2FB","sourceRelease":"119-100","text":"in consultation with the Attorney General, to determine whether the item should be posted in a restricted section of the website.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Determination","label":"2 Determination","identifier":"/us/usc/t21/s2013/c/2","parentIdentifier":"/us/usc/t21/s2013/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s2013/c/2/A","parentIdentifier":"/us/usc/t21/s2013/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fc%2F2%2FA","sourceRelease":"119-100","text":"post the item on the website described in subsection (b)(2); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s2013/c/2/B","parentIdentifier":"/us/usc/t21/s2013/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2013%2Fc%2F2%2FB","sourceRelease":"119-100","text":"notify the qualified entity that submitted the item regarding the reason such item shall not be posted and modifications, if any, that the qualified entity may make to allow the item to be posted.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
