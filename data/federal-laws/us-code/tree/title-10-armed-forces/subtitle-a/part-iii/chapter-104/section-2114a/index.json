{"type":"section","nativeType":"section","number":"2114a","heading":"Eligibility of members of foreign militaries to enroll in the University","label":"2114a Eligibility of members of foreign militaries to enroll in the University","identifier":"/us/usc/t10/s2114a","parentIdentifier":"/us/usc/t10/stA/ptIII/ch104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Authority","label":"a .—Authority","identifier":"/us/usc/t10/s2114a/a","parentIdentifier":"/us/usc/t10/s2114a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2114a/a/1","parentIdentifier":"/us/usc/t10/s2114a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2114a/a/1/A","parentIdentifier":"/us/usc/t10/s2114a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s2114a/a/1/A/i","parentIdentifier":"/us/usc/t10/s2114a/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"as a medical student of the University; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s2114a/a/1/A/ii","parentIdentifier":"/us/usc/t10/s2114a/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"in a postdoctoral, postgraduate, or certificate program of the University; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2114a/a/1/B","parentIdentifier":"/us/usc/t10/s2114a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F1%2FB","sourceRelease":"119-100","text":"to participate in training exercises of the University.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2114a/a/2","parentIdentifier":"/us/usc/t10/s2114a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2114a/a/2/A","parentIdentifier":"/us/usc/t10/s2114a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s2114a/a/2/A/i","parentIdentifier":"/us/usc/t10/s2114a/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the academic capacity of the University described in ; andsection 2112(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s2114a/a/2/A/ii","parentIdentifier":"/us/usc/t10/s2114a/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"an international agreement or qualifying non-binding instrument (as such terms are defined in ); andsection 112b of title 1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2114a/a/2/B","parentIdentifier":"/us/usc/t10/s2114a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F2%2FB","sourceRelease":"119-100","text":"may not decrease the number of members of the uniformed services enrolled in the University; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s2114a/a/2/C","parentIdentifier":"/us/usc/t10/s2114a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F2%2FC","sourceRelease":"119-100","text":"may not be given priority over the enrollment of a member of the uniformed services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2114a/a/3","parentIdentifier":"/us/usc/t10/s2114a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2114a/a/3/A","parentIdentifier":"/us/usc/t10/s2114a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F3%2FA","sourceRelease":"119-100","text":"10, in the case of medical students of the University; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2114a/a/3/B","parentIdentifier":"/us/usc/t10/s2114a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fa%2F3%2FB","sourceRelease":"119-100","text":"40, with regards to all postdoctoral, postgraduate, and certificate programs of the University.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Qualifications; Selection","label":"b .—Qualifications; Selection","identifier":"/us/usc/t10/s2114a/b","parentIdentifier":"/us/usc/t10/s2114a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2114a/b/1","parentIdentifier":"/us/usc/t10/s2114a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fb%2F1","sourceRelease":"119-100","text":"who was nominated for such enrollment by the medical command of the military of a foreign country; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2114a/b/2","parentIdentifier":"/us/usc/t10/s2114a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2114a/b/2/A","parentIdentifier":"/us/usc/t10/s2114a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fb%2F2%2FA","sourceRelease":"119-100","text":"qualifications for such enrollment that are comparable to the qualifications required of a United States citizen; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2114a/b/2/B","parentIdentifier":"/us/usc/t10/s2114a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fb%2F2%2FB","sourceRelease":"119-100","text":"procedures for such selection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Reimbursement","label":"c .—Reimbursement","identifier":"/us/usc/t10/s2114a/c","parentIdentifier":"/us/usc/t10/s2114a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2114a/c/1","parentIdentifier":"/us/usc/t10/s2114a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary shall require the foreign country of an individual enrolled under this section to reimburse the United States for the cost of providing instruction to such individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2114a/c/2","parentIdentifier":"/us/usc/t10/s2114a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fc%2F2","sourceRelease":"119-100","text":"The Secretary shall prescribe rates for such reimbursement that equal or exceed the cost to the United States of providing such instruction to a member of the uniformed services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2114a/c/3","parentIdentifier":"/us/usc/t10/s2114a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fc%2F3","sourceRelease":"119-100","text":"The Secretary may waive, in whole or in part, reimbursement with regards to an individual enrolled under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s2114a/c/4","parentIdentifier":"/us/usc/t10/s2114a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2114a/c/4/A","parentIdentifier":"/us/usc/t10/s2114a/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fc%2F4%2FA","sourceRelease":"119-100","text":"be used to defray the costs of providing instruction to an individual enrolled under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2114a/c/4/B","parentIdentifier":"/us/usc/t10/s2114a/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fc%2F4%2FB","sourceRelease":"119-100","text":"be credited to appropriations available for the maintenance and operation of the University; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s2114a/c/4/C","parentIdentifier":"/us/usc/t10/s2114a/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fc%2F4%2FC","sourceRelease":"119-100","text":"remain available for until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s2114a/c/5","parentIdentifier":"/us/usc/t10/s2114a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fc%2F5","sourceRelease":"119-100","text":"The source and the disposition of such amounts shall be specifically identified in records of the University.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Applicability of Regulations and Policies","label":"d .—Applicability of Regulations and Policies","identifier":"/us/usc/t10/s2114a/d","parentIdentifier":"/us/usc/t10/s2114a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2114a/d/1","parentIdentifier":"/us/usc/t10/s2114a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fd%2F1","sourceRelease":"119-100","text":"Subject to paragraphs (2) through (4), and to the determination of the Secretary, an individual enrolled under this section shall be subject to the same regulations and policies that apply to a member of the uniformed services enrolled in the University.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2114a/d/2","parentIdentifier":"/us/usc/t10/s2114a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fd%2F2","sourceRelease":"119-100","text":"The Secretary may prescribe regulations regarding access to classified information by an individual enrolled under this section that differ from the regulations that apply to a member of the uniformed services enrolled in the University.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2114a/d/3","parentIdentifier":"/us/usc/t10/s2114a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fd%2F3","sourceRelease":"119-100","text":"An individual enrolled under this section shall not be entitled to an appointment in a uniformed service by reason of completing of a program of the University.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s2114a/d/4","parentIdentifier":"/us/usc/t10/s2114a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2114a%2Fd%2F4","sourceRelease":"119-100","text":"shall not apply to an individual enrolled under this section.Section 2114 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
