{"type":"section","nativeType":"section","number":"16103","heading":"Conserve by Bicycling Program","label":"16103 Conserve by Bicycling Program","identifier":"/us/usc/t42/s16103","parentIdentifier":"/us/usc/t42/ch149/schVII/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s16103/a","parentIdentifier":"/us/usc/t42/s16103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Program","label":"1 Program","identifier":"/us/usc/t42/s16103/a/1","parentIdentifier":"/us/usc/t42/s16103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fa%2F1","sourceRelease":"119-100","text":"The term “program” means the Conserve by Bicycling Program established by subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Secretary","label":"2 Secretary","identifier":"/us/usc/t42/s16103/a/2","parentIdentifier":"/us/usc/t42/s16103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fa%2F2","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Transportation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t42/s16103/b","parentIdentifier":"/us/usc/t42/s16103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fb","sourceRelease":"119-100","text":"There is established within the Department of Transportation a program to be known as the “Conserve by Bicycling Program”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Projects","label":"c Projects","identifier":"/us/usc/t42/s16103/c","parentIdentifier":"/us/usc/t42/s16103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16103/c/1","parentIdentifier":"/us/usc/t42/s16103/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16103/c/1/A","parentIdentifier":"/us/usc/t42/s16103/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F1%2FA","sourceRelease":"119-100","text":"dispersed geographically throughout the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16103/c/1/B","parentIdentifier":"/us/usc/t42/s16103/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F1%2FB","sourceRelease":"119-100","text":"designed to conserve energy resources by encouraging the use of bicycles in place of motor vehicles.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t42/s16103/c/2","parentIdentifier":"/us/usc/t42/s16103/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16103/c/2/A","parentIdentifier":"/us/usc/t42/s16103/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F2%2FA","sourceRelease":"119-100","text":"use education and marketing to convert motor vehicle trips to bicycle trips;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16103/c/2/B","parentIdentifier":"/us/usc/t42/s16103/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F2%2FB","sourceRelease":"119-100","text":"document project results and energy savings (in estimated units of energy conserved);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16103/c/2/C","parentIdentifier":"/us/usc/t42/s16103/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16103/c/2/C/i","parentIdentifier":"/us/usc/t42/s16103/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F2%2FC%2Fi","sourceRelease":"119-100","text":"transportation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16103/c/2/C/ii","parentIdentifier":"/us/usc/t42/s16103/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F2%2FC%2Fii","sourceRelease":"119-100","text":"law enforcement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16103/c/2/C/iii","parentIdentifier":"/us/usc/t42/s16103/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F2%2FC%2Fiii","sourceRelease":"119-100","text":"education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s16103/c/2/C/iv","parentIdentifier":"/us/usc/t42/s16103/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F2%2FC%2Fiv","sourceRelease":"119-100","text":"public health;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s16103/c/2/C/v","parentIdentifier":"/us/usc/t42/s16103/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F2%2FC%2Fv","sourceRelease":"119-100","text":"environment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s16103/c/2/C/vi","parentIdentifier":"/us/usc/t42/s16103/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F2%2FC%2Fvi","sourceRelease":"119-100","text":"energy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16103/c/2/D","parentIdentifier":"/us/usc/t42/s16103/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F2%2FD","sourceRelease":"119-100","text":"maximize bicycle facility investments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16103/c/2/E","parentIdentifier":"/us/usc/t42/s16103/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F2%2FE","sourceRelease":"119-100","text":"demonstrate methods that may be used in other regions of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s16103/c/2/F","parentIdentifier":"/us/usc/t42/s16103/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F2%2FF","sourceRelease":"119-100","text":"facilitate the continuation of ongoing programs that are sustained by local resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Cost sharing","label":"3 Cost sharing","identifier":"/us/usc/t42/s16103/c/3","parentIdentifier":"/us/usc/t42/s16103/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fc%2F3","sourceRelease":"119-100","text":"At least 20 percent of the cost of each pilot project described in paragraph (1) shall be provided from non-Federal sources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Energy and bicycling research study","label":"d Energy and bicycling research study","identifier":"/us/usc/t42/s16103/d","parentIdentifier":"/us/usc/t42/s16103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16103/d/1","parentIdentifier":"/us/usc/t42/s16103/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fd%2F1","sourceRelease":"119-100","text":"Not later than 2 years after , the Secretary shall enter into a contract with the National Academy of Sciences for, and the National Academy of Sciences shall conduct and submit to Congress a report on, a study on the feasibility of converting motor vehicle trips to bicycle trips.August 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Components","label":"2 Components","identifier":"/us/usc/t42/s16103/d/2","parentIdentifier":"/us/usc/t42/s16103/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16103/d/2/A","parentIdentifier":"/us/usc/t42/s16103/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fd%2F2%2FA","sourceRelease":"119-100","text":"document the results or progress of the pilot projects under subsection (c);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16103/d/2/B","parentIdentifier":"/us/usc/t42/s16103/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fd%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16103/d/2/B/i","parentIdentifier":"/us/usc/t42/s16103/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fd%2F2%2FB%2Fi","sourceRelease":"119-100","text":"weather;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16103/d/2/B/ii","parentIdentifier":"/us/usc/t42/s16103/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fd%2F2%2FB%2Fii","sourceRelease":"119-100","text":"land use and traffic patterns;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16103/d/2/B/iii","parentIdentifier":"/us/usc/t42/s16103/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fd%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"the carrying capacity of bicycles; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s16103/d/2/B/iv","parentIdentifier":"/us/usc/t42/s16103/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fd%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"bicycle infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16103/d/2/C","parentIdentifier":"/us/usc/t42/s16103/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fd%2F2%2FC","sourceRelease":"119-100","text":"determine any energy savings that would result from the conversion of motor vehicle trips to bicycle trips;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16103/d/2/D","parentIdentifier":"/us/usc/t42/s16103/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fd%2F2%2FD","sourceRelease":"119-100","text":"include a cost-benefit analysis of bicycle infrastructure investments; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16103/d/2/E","parentIdentifier":"/us/usc/t42/s16103/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fd%2F2%2FE","sourceRelease":"119-100","text":"include a description of any factors that would encourage more motor vehicle trips to be replaced with bicycle trips.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s16103/e","parentIdentifier":"/us/usc/t42/s16103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16103/e/1","parentIdentifier":"/us/usc/t42/s16103/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fe%2F1","sourceRelease":"119-100","text":"$5,150,000 shall be used to carry out pilot projects described in subsection (c);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16103/e/2","parentIdentifier":"/us/usc/t42/s16103/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fe%2F2","sourceRelease":"119-100","text":"$300,000 shall be used by the Secretary to coordinate, publicize, and disseminate the results of the program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16103/e/3","parentIdentifier":"/us/usc/t42/s16103/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16103%2Fe%2F3","sourceRelease":"119-100","text":"$750,000 shall be used to carry out subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
