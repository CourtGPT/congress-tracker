{"type":"section","nativeType":"section","number":"290ee–5a","heading":"Sobriety treatment and recovery teams","label":"290ee–5a Sobriety treatment and recovery teams","identifier":"/us/usc/t42/s290ee–5a","parentIdentifier":"/us/usc/t42/ch6A/schIII–A/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%935a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to prior to renumbering by .section 290ee–10 of this titlePub. L. 117–328"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s290ee–5a/a","parentIdentifier":"/us/usc/t42/s290ee–5a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%935a%2Fa","sourceRelease":"119-100","text":"The Secretary may make grants to States, units of local government, or tribal governments to establish or expand Sobriety Treatment And Recovery Team (referred to in this section as “START”) or other similar programs to determine the effectiveness of pairing social workers or mentors with families that are struggling with a substance use disorder and child abuse or neglect in order to help provide peer support, intensive treatment, and child welfare services to such families.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Allowable uses","label":"b Allowable uses","identifier":"/us/usc/t42/s290ee–5a/b","parentIdentifier":"/us/usc/t42/s290ee–5a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%935a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s290ee–5a/b/1","parentIdentifier":"/us/usc/t42/s290ee–5a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%935a%2Fb%2F1","sourceRelease":"119-100","text":"Training eligible staff, including social workers, social services coordinators, child welfare specialists, substance use disorder treatment professionals, and mentors.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s290ee–5a/b/2","parentIdentifier":"/us/usc/t42/s290ee–5a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%935a%2Fb%2F2","sourceRelease":"119-100","text":"Expanding access to substance use disorder treatment services and drug testing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s290ee–5a/b/3","parentIdentifier":"/us/usc/t42/s290ee–5a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%935a%2Fb%2F3","sourceRelease":"119-100","text":"Enhancing data sharing with law enforcement agencies, child welfare agencies, substance use disorder treatment providers, judges, and court personnel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s290ee–5a/b/4","parentIdentifier":"/us/usc/t42/s290ee–5a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%935a%2Fb%2F4","sourceRelease":"119-100","text":"Program evaluation and technical assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Program requirements","label":"c Program requirements","identifier":"/us/usc/t42/s290ee–5a/c","parentIdentifier":"/us/usc/t42/s290ee–5a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%935a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s290ee–5a/c/1","parentIdentifier":"/us/usc/t42/s290ee–5a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%935a%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s290ee–5a/c/1/A","parentIdentifier":"/us/usc/t42/s290ee–5a/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%935a%2Fc%2F1%2FA","sourceRelease":"119-100","text":"there is an open record with the child welfare agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s290ee–5a/c/1/B","parentIdentifier":"/us/usc/t42/s290ee–5a/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%935a%2Fc%2F1%2FB","sourceRelease":"119-100","text":"substance use disorder was a reason for the record or finding described in paragraph (1); and1So in original. Probably should be “subparagraph (A)”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s290ee–5a/c/2","parentIdentifier":"/us/usc/t42/s290ee–5a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%935a%2Fc%2F2","sourceRelease":"119-100","text":"coordinate any grants awarded under this section with any grant awarded under focused on improving outcomes for children affected by substance abuse.section 629g(f) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Technical assistance","label":"d Technical assistance","identifier":"/us/usc/t42/s290ee–5a/d","parentIdentifier":"/us/usc/t42/s290ee–5a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%935a%2Fd","sourceRelease":"119-100","text":"The Secretary may reserve not more than 5 percent of funds provided under this section to provide technical assistance on the establishment or expansion of programs funded under this section from the National Center on Substance Abuse and Child Welfare.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
