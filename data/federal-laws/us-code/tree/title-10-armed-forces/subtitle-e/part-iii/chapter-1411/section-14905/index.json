{"type":"section","nativeType":"section","number":"14905","heading":"Officer considered for removal: retirement or discharge","label":"14905 Officer considered for removal: retirement or discharge","identifier":"/us/usc/t10/s14905","parentIdentifier":"/us/usc/t10/stE/ptIII/ch1411","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14905","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , see , set out as a note under .Oct. 1, 1996section 1691(b)(1) of Pub. L. 103–337section 10001 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Voluntary Retirement or Discharge","label":"a .—Voluntary Retirement or Discharge","identifier":"/us/usc/t10/s14905/a","parentIdentifier":"/us/usc/t10/s14905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14905%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s14905/a/1","parentIdentifier":"/us/usc/t10/s14905/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14905%2Fa%2F1","sourceRelease":"119-100","text":"for voluntary retirement, if the officer is qualified for retirement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s14905/a/2","parentIdentifier":"/us/usc/t10/s14905/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14905%2Fa%2F2","sourceRelease":"119-100","text":"for transfer to the Retired Reserve if the officer has completed the years of service required for eligibility for retired pay under chapter 1223 of this title and is otherwise eligible for transfer to the Retired Reserve; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s14905/a/3","parentIdentifier":"/us/usc/t10/s14905/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14905%2Fa%2F3","sourceRelease":"119-100","text":"for discharge in accordance with subsection (b)(3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Required Retirement or Discharge","label":"b .—Required Retirement or Discharge","identifier":"/us/usc/t10/s14905/b","parentIdentifier":"/us/usc/t10/s14905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14905%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s14905/b/1","parentIdentifier":"/us/usc/t10/s14905/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14905%2Fb%2F1","sourceRelease":"119-100","text":"if eligible for voluntary retirement under any provision of law on the date of such removal, be retired in the grade and with the retired pay for which he would be eligible if retired under that provision;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s14905/b/2","parentIdentifier":"/us/usc/t10/s14905/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14905%2Fb%2F2","sourceRelease":"119-100","text":"if eligible for transfer to the Retired Reserve and has completed the years of service required for retired pay under chapter 1223 of this title, be transferred to the Retired Reserve; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s14905/b/3","parentIdentifier":"/us/usc/t10/s14905/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14905%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s14905/b/3/A","parentIdentifier":"/us/usc/t10/s14905/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14905%2Fb%2F3%2FA","sourceRelease":"119-100","text":"be honorably discharged in the grade then held, in the case of an officer whose case was brought under subsection (a) of ; orsection 14902 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s14905/b/3/B","parentIdentifier":"/us/usc/t10/s14905/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14905%2Fb%2F3%2FB","sourceRelease":"119-100","text":"be discharged in the grade then held, in the case of an officer whose case was brought under subsection (b) of .section 14902 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Separation Pay","label":"c .—Separation Pay","identifier":"/us/usc/t10/s14905/c","parentIdentifier":"/us/usc/t10/s14905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14905%2Fc","sourceRelease":"119-100","text":"An officer who is discharged under subsection (b)(3) is entitled, if eligible therefor, to separation pay under .section 1174(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
