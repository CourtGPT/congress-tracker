{"type":"section","nativeType":"section","number":"8259a","heading":"Energy and water savings measures in congressional buildings","label":"8259a Energy and water savings measures in congressional buildings","identifier":"/us/usc/t42/s8259a","parentIdentifier":"/us/usc/t42/ch91/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s8259a/a","parentIdentifier":"/us/usc/t42/s8259a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s8259a/a/1","parentIdentifier":"/us/usc/t42/s8259a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a%2Fa%2F1","sourceRelease":"119-100","text":"shall develop, update, and implement a cost-effective energy conservation and management plan (referred to in this section as the “plan”) for all facilities administered by Congress (referred to in this section as “congressional buildings”) to meet the energy performance requirements for Federal buildings established under ; andsection 8253(a)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s8259a/a/2","parentIdentifier":"/us/usc/t42/s8259a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a%2Fa%2F2","sourceRelease":"119-100","text":"shall submit the plan to Congress, not later than 180 days after .August 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Plan requirements","label":"b Plan requirements","identifier":"/us/usc/t42/s8259a/b","parentIdentifier":"/us/usc/t42/s8259a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s8259a/b/1","parentIdentifier":"/us/usc/t42/s8259a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a%2Fb%2F1","sourceRelease":"119-100","text":"a description of the life cycle cost analysis used to determine the cost-effectiveness of proposed energy efficiency projects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s8259a/b/2","parentIdentifier":"/us/usc/t42/s8259a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a%2Fb%2F2","sourceRelease":"119-100","text":"a schedule of energy surveys to ensure complete surveys of all congressional buildings every 5 years to determine the cost and payback period of energy and water conservation measures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s8259a/b/3","parentIdentifier":"/us/usc/t42/s8259a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a%2Fb%2F3","sourceRelease":"119-100","text":"a strategy for installation of life cycle cost-effective energy and water conservation measures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s8259a/b/4","parentIdentifier":"/us/usc/t42/s8259a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a%2Fb%2F4","sourceRelease":"119-100","text":"the results of a study of the costs and benefits of installation of submetering in congressional buildings; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s8259a/b/5","parentIdentifier":"/us/usc/t42/s8259a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a%2Fb%2F5","sourceRelease":"119-100","text":"information packages and “how-to” guides for each Member and employing authority of Congress that detail simple, cost-effective methods to save energy and taxpayer dollars in the workplace.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Annual report","label":"c Annual report","identifier":"/us/usc/t42/s8259a/c","parentIdentifier":"/us/usc/t42/s8259a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s8259a/c/1","parentIdentifier":"/us/usc/t42/s8259a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a%2Fc%2F1","sourceRelease":"119-100","text":"energy expenditures and savings estimates for each facility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s8259a/c/2","parentIdentifier":"/us/usc/t42/s8259a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a%2Fc%2F2","sourceRelease":"119-100","text":"energy management and conservation projects; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s8259a/c/3","parentIdentifier":"/us/usc/t42/s8259a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8259a%2Fc%2F3","sourceRelease":"119-100","text":"future priorities to ensure compliance with this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
