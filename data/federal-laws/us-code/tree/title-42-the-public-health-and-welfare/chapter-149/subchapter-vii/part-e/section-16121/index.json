{"type":"section","nativeType":"section","number":"16121","heading":"Definitions","label":"16121 Definitions","identifier":"/us/usc/t42/s16121","parentIdentifier":"/us/usc/t42/ch149/schVII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16121","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Fuel cell","label":"1 Fuel cell","identifier":"/us/usc/t42/s16121/1","parentIdentifier":"/us/usc/t42/s16121","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16121%2F1","sourceRelease":"119-100","text":"The term “fuel cell” means a device that directly converts the chemical energy of a fuel and an oxidant into electricity by electrochemical processes occurring at separate electrodes in the device.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Light-duty or heavy-duty vehicle fleet","label":"2 Light-duty or heavy-duty vehicle fleet","identifier":"/us/usc/t42/s16121/2","parentIdentifier":"/us/usc/t42/s16121","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16121%2F2","sourceRelease":"119-100","text":"The term “light-duty or heavy-duty vehicle fleet” does not include any vehicle designed or procured for combat or combat-related missions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Stationary; portable","label":"3 Stationary; portable","identifier":"/us/usc/t42/s16121/3","parentIdentifier":"/us/usc/t42/s16121","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16121%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16121/3/A","parentIdentifier":"/us/usc/t42/s16121/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16121%2F3%2FA","sourceRelease":"119-100","text":"continuous electric power; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16121/3/B","parentIdentifier":"/us/usc/t42/s16121/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16121%2F3%2FB","sourceRelease":"119-100","text":"backup electric power.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Task Force","label":"4 Task Force","identifier":"/us/usc/t42/s16121/4","parentIdentifier":"/us/usc/t42/s16121","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16121%2F4","sourceRelease":"119-100","text":"The term “Task Force” means the Hydrogen and Fuel Cell Technical Task Force established under .section 16155 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Technical Advisory Committee","label":"5 Technical Advisory Committee","identifier":"/us/usc/t42/s16121/5","parentIdentifier":"/us/usc/t42/s16121","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16121%2F5","sourceRelease":"119-100","text":"The term “Technical Advisory Committee” means the independent Technical Advisory Committee selected under .section 16156 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
