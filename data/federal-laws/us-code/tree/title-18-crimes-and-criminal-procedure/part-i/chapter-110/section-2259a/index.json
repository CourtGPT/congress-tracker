{"type":"section","nativeType":"section","number":"2259A","heading":"Assessments in child pornography cases","label":"2259A Assessments in child pornography cases","identifier":"/us/usc/t18/s2259A","parentIdentifier":"/us/usc/t18/ptI/ch110","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t18/s2259A/a","parentIdentifier":"/us/usc/t18/s2259A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2259A/a/1","parentIdentifier":"/us/usc/t18/s2259A/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fa%2F1","sourceRelease":"119-100","text":"not more than $17,000 on any person convicted of an offense under section 2252(a)(4) or 2252A(a)(5);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2259A/a/2","parentIdentifier":"/us/usc/t18/s2259A/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fa%2F2","sourceRelease":"119-100","text":"not more than $35,000 on any person convicted of any other offense for trafficking in child pornography; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s2259A/a/3","parentIdentifier":"/us/usc/t18/s2259A/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fa%2F3","sourceRelease":"119-100","text":"not more than $50,000 on any person convicted of a child pornography production offense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Annual Adjustment","label":"b .—Annual Adjustment","identifier":"/us/usc/t18/s2259A/b","parentIdentifier":"/us/usc/t18/s2259A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fb","sourceRelease":"119-100","text":"The dollar amounts in subsection (a) shall be adjusted annually in conformity with the Consumer Price Index.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Factors Considered","label":"c .—Factors Considered","identifier":"/us/usc/t18/s2259A/c","parentIdentifier":"/us/usc/t18/s2259A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fc","sourceRelease":"119-100","text":"In determining the amount of the assessment under subsection (a), the court shall consider the factors set forth in sections 3553(a) and 3572.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Imposition and Implementation.—","label":"d Imposition and Implementation.—","identifier":"/us/usc/t18/s2259A/d","parentIdentifier":"/us/usc/t18/s2259A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t18/s2259A/d/1","parentIdentifier":"/us/usc/t18/s2259A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fd%2F1","sourceRelease":"119-100","text":"The provisions of subchapter C of chapter 227 (other than section 3571) and subchapter B of chapter 229 (relating to fines) apply to assessments under this section, except that paragraph (2) applies in lieu of any contrary provisions of law relating to fines or disbursement of money received from a defendant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Effect on other penalties","label":"2 .—Effect on other penalties","identifier":"/us/usc/t18/s2259A/d/2","parentIdentifier":"/us/usc/t18/s2259A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s2259A/d/2/A","parentIdentifier":"/us/usc/t18/s2259A/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fd%2F2%2FA","sourceRelease":"119-100","text":"A special assessment under section 3013.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s2259A/d/2/B","parentIdentifier":"/us/usc/t18/s2259A/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fd%2F2%2FB","sourceRelease":"119-100","text":"Restitution to victims of any child pornography production or trafficking offense that the defendant committed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t18/s2259A/d/2/C","parentIdentifier":"/us/usc/t18/s2259A/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fd%2F2%2FC","sourceRelease":"119-100","text":"An assessment under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t18/s2259A/d/2/D","parentIdentifier":"/us/usc/t18/s2259A/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fd%2F2%2FD","sourceRelease":"119-100","text":"Other orders under any other section of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t18/s2259A/d/2/E","parentIdentifier":"/us/usc/t18/s2259A/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2259A%2Fd%2F2%2FE","sourceRelease":"119-100","text":"All other fines, penalties, costs, and other payments required under the sentence.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
