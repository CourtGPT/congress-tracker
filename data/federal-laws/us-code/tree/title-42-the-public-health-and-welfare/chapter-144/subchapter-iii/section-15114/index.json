{"type":"section","nativeType":"section","number":"15114","heading":"Staff development curriculum authorization","label":"15114 Staff development curriculum authorization","identifier":"/us/usc/t42/s15114","parentIdentifier":"/us/usc/t42/ch144/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe Individuals with Disabilities Education Act, referred to in subsec. (b)(3)(C)(i), is title VI of , , . Part D of the Act is classified generally to subchapter IV (§ 1450 et seq.) of chapter 33 of Title 20, Education. For complete classification of this Act to the Code, see and Tables.Pub. L. 91–23084 Stat. 175section 1400 of Title 20Apr. 13, 1970"],"amendments":["References in TextThe Individuals with Disabilities Education Act, referred to in subsec. (b)(3)(C)(i), is title VI of , , . Part D of the Act is classified generally to subchapter IV (§ 1450 et seq.) of chapter 33 of Title 20, Education. For complete classification of this Act to the Code, see and Tables.Pub. L. 91–23084 Stat. 175section 1400 of Title 20Apr. 13, 1970"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Funding","label":"a Funding","identifier":"/us/usc/t42/s15114/a","parentIdentifier":"/us/usc/t42/s15114","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s15114/a/1","parentIdentifier":"/us/usc/t42/s15114/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary shall award funding, on a competitive basis, through a grant, cooperative agreement, or contract, to a public or private entity or a combination of such entities, for the development, evaluation, and dissemination of a staff development curriculum, and related guidelines, for computer-assisted, competency-based, multimedia, interactive instruction, relating to service as a direct support worker.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Participants","label":"2 Participants","identifier":"/us/usc/t42/s15114/a/2","parentIdentifier":"/us/usc/t42/s15114/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15114/a/2/A","parentIdentifier":"/us/usc/t42/s15114/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fa%2F2%2FA","sourceRelease":"119-100","text":"seek to become direct support workers who assist individuals with developmental disabilities or are such direct support workers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15114/a/2/B","parentIdentifier":"/us/usc/t42/s15114/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fa%2F2%2FB","sourceRelease":"119-100","text":"seek to upgrade their skills and competencies related to being a direct support worker.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Application requirements","label":"b Application requirements","identifier":"/us/usc/t42/s15114/b","parentIdentifier":"/us/usc/t42/s15114","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15114/b/1","parentIdentifier":"/us/usc/t42/s15114/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F1","sourceRelease":"119-100","text":"a comprehensive analysis of the content of direct support roles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15114/b/2","parentIdentifier":"/us/usc/t42/s15114/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15114/b/2/A","parentIdentifier":"/us/usc/t42/s15114/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F2%2FA","sourceRelease":"119-100","text":"is comprised of individuals with experience and expertise with regard to the support provided by direct support workers, and effective ways to provide the support, for individuals with developmental disabilities in diverse settings; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15114/b/2/B","parentIdentifier":"/us/usc/t42/s15114/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F2%2FB","sourceRelease":"119-100","text":"will advise the entity throughout the development, evaluation, and dissemination of the staff development curriculum and guidelines;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s15114/b/3","parentIdentifier":"/us/usc/t42/s15114/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15114/b/3/A","parentIdentifier":"/us/usc/t42/s15114/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s15114/b/3/A/i","parentIdentifier":"/us/usc/t42/s15114/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FA%2Fi","sourceRelease":"119-100","text":"relates to the appropriate reading level for direct service workers who assist individuals with disabilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s15114/b/3/A/ii","parentIdentifier":"/us/usc/t42/s15114/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FA%2Fii","sourceRelease":"119-100","text":"allows for multiple levels of instruction;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s15114/b/3/A/iii","parentIdentifier":"/us/usc/t42/s15114/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"provides instruction appropriate for direct support workers who work in diverse settings; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s15114/b/3/A/iv","parentIdentifier":"/us/usc/t42/s15114/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FA%2Fiv","sourceRelease":"119-100","text":"is consistent with subsections (b) and (c) of and ;section 15001 of this titlesection 15009 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15114/b/3/B","parentIdentifier":"/us/usc/t42/s15114/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s15114/b/3/B/i","parentIdentifier":"/us/usc/t42/s15114/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"providing necessary technical and instructional support to trainers and mentors for the participants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s15114/b/3/B/ii","parentIdentifier":"/us/usc/t42/s15114/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"ensuring easy access to and use of such curriculum by workers that choose to participate in using, and agencies that choose to use, the curriculum;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s15114/b/3/B/iii","parentIdentifier":"/us/usc/t42/s15114/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"evaluating the proficiency of the participants with respect to the content of the curriculum;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s15114/b/3/B/iv","parentIdentifier":"/us/usc/t42/s15114/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FB%2Fiv","sourceRelease":"119-100","text":"providing necessary support to the participants to assure that the participants have access to, and proficiency in using, a computer in order to participate in the development, testing, and validation process;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s15114/b/3/B/v","parentIdentifier":"/us/usc/t42/s15114/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FB%2Fv","sourceRelease":"119-100","text":"providing necessary technical and instructional support to trainers and mentors for the participants in conjunction with the development, testing, and validation process;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s15114/b/3/B/vi","parentIdentifier":"/us/usc/t42/s15114/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FB%2Fvi","sourceRelease":"119-100","text":"addressing the satisfaction of participants, individuals with developmental disabilities and their families, providers of services for such individuals and families, and other relevant entities with the curriculum; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t42/s15114/b/3/B/vii","parentIdentifier":"/us/usc/t42/s15114/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FB%2Fvii","sourceRelease":"119-100","text":"developing methods to maintain a record of the instruction completed, and the content mastered, by each participant under the curriculum; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s15114/b/3/C","parentIdentifier":"/us/usc/t42/s15114/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s15114/b/3/C/i","parentIdentifier":"/us/usc/t42/s15114/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FC%2Fi","sourceRelease":"119-100","text":"parent training and information centers funded under part D of the Individuals with Disabilities Education Act ( et seq.);20 U.S.C. 1451","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s15114/b/3/C/ii","parentIdentifier":"/us/usc/t42/s15114/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FC%2Fii","sourceRelease":"119-100","text":"community-based organizations of and for individuals with developmental disabilities and their families;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s15114/b/3/C/iii","parentIdentifier":"/us/usc/t42/s15114/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FC%2Fiii","sourceRelease":"119-100","text":"entities funded under subchapter I;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s15114/b/3/C/iv","parentIdentifier":"/us/usc/t42/s15114/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FC%2Fiv","sourceRelease":"119-100","text":"centers for independent living;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s15114/b/3/C/v","parentIdentifier":"/us/usc/t42/s15114/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FC%2Fv","sourceRelease":"119-100","text":"State educational agencies and local educational agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s15114/b/3/C/vi","parentIdentifier":"/us/usc/t42/s15114/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FC%2Fvi","sourceRelease":"119-100","text":"entities operating appropriate medical facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t42/s15114/b/3/C/vii","parentIdentifier":"/us/usc/t42/s15114/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FC%2Fvii","sourceRelease":"119-100","text":"postsecondary education entities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t42/s15114/b/3/C/viii","parentIdentifier":"/us/usc/t42/s15114/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F3%2FC%2Fviii","sourceRelease":"119-100","text":"other appropriate entities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s15114/b/4","parentIdentifier":"/us/usc/t42/s15114/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15114%2Fb%2F4","sourceRelease":"119-100","text":"such other information as the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
