{"type":"section","nativeType":"section","number":"2466","heading":"Use of funds for the purchase of options to purchase real property","label":"2466 Use of funds for the purchase of options to purchase real property","identifier":"/us/usc/t50/s2466","parentIdentifier":"/us/usc/t50/ch41/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2466","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authority","label":"a Authority","identifier":"/us/usc/t50/s2466/a","parentIdentifier":"/us/usc/t50/s2466","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2466%2Fa","sourceRelease":"119-100","text":"Subject to the limitation in subsection (b), funds authorized to be appropriated for the Administration for the purchase of real property may be expended to purchase options for the purchase of real property.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitation on price of options","label":"b Limitation on price of options","identifier":"/us/usc/t50/s2466/b","parentIdentifier":"/us/usc/t50/s2466","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2466%2Fb","sourceRelease":"119-100","text":"The price of any option purchased pursuant to subsection (a) may not exceed the minor construction threshold (as defined in ).section 2741 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Notice","label":"c Notice","identifier":"/us/usc/t50/s2466/c","parentIdentifier":"/us/usc/t50/s2466","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2466%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","numb