{"type":"section","nativeType":"section","number":"9543","heading":"Educational development relating to management and entrepreneurship","label":"9543 Educational development relating to management and entrepreneurship","identifier":"/us/usc/t15/s9543","parentIdentifier":"/us/usc/t15/ch120/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9543","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Duties","label":"a Duties","identifier":"/us/usc/t15/s9543/a","parentIdentifier":"/us/usc/t15/s9543","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9543%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9543/a/1","parentIdentifier":"/us/usc/t15/s9543/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9543%2Fa%2F1","sourceRelease":"119-100","text":"promote the education and training of socially or economically disadvantaged individuals in subjects directly relating to business administration and management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9543/a/2","parentIdentifier":"/us/usc/t15/s9543/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9543%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9543/a/2/A","parentIdentifier":"/us/usc/t15/s9543/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9543%2Fa%2F2%2FA","sourceRelease":"119-100","text":"develop programs to offer scholarships and fellowships, apprenticeships, and internships relating to business to socially or economically disadvantaged individuals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9543/a/2/B","parentIdentifier":"/us/usc/t15/s9543/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9543%2Fa%2F2%2FB","sourceRelease":"119-100","text":"sponsor seminars, conferences, and similar activities relating to business for the benefit of socially or economically disadvantaged individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s9543/a/3","parentIdentifier":"/us/usc/t15/s9543/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9543%2Fa%2F3","sourceRelease":"119-100","text":"stimulate and accelerate curriculum design and improvement in support of development of minority business enterprises; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s9543/a/4","parentIdentifier":"/us/usc/t15/s9543/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9543%2Fa%2F4","sourceRelease":"119-100","text":"encourage and assist private institutions and organizations and public sector entities to undertake activities similar to the activities described in paragraphs (1), (2), and (3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Parren J. Mitchell Entrepreneurship Education Grants","label":"b Parren J. Mitchell Entrepreneurship Education Grants","identifier":"/us/usc/t15/s9543/b","parentIdentifier":"/us/usc/t15/s9543",