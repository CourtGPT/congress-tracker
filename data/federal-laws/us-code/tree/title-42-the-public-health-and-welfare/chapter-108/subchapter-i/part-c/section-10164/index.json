{"type":"section","nativeType":"section","number":"10164","heading":"Survey","label":"10164 Survey","identifier":"/us/usc/t42/s10164","parentIdentifier":"/us/usc/t42/ch108/schI/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10164","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Codificationand added identical sections.Pub. L. 100–202Pub. L. 100–203"],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s10164/1","parentIdentifier":"/us/usc/t42/s10164","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10164%2F1","sourceRelease":"119-100","text":"enhance the reliability and flexibility of the system for the disposal of spent nuclear fuel and high-level radioactive waste established under this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s10164/2","parentIdentifier":"/us/usc/t42/s10164","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10164%2F2","sourceRelease":"119-100","text":"minimize the impacts of transportation and handling of such fuel and waste;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s10164/3","parentIdentifier":"/us/usc/t42/s10164","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10164%2F3","sourceRelease":"119-100","text":"provide for public confidence in the ability of such system to safely dispose of the fuel and waste;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s10164/4","parentIdentifier":"/us/usc/t42/s10164","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10164%2F4","sourceRelease":"119-100","text":"impose minimal adverse effects on the local community and the local environment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s10164/5","parentIdentifier":"/us/usc/t42/s10164","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10164%2F5","sourceRelease":"119-100","text":"provide a high probability that the facility will meet applicable environmental, health, and safety requirements in a timely fashion;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s10164/6","parentIdentifier":"/us/usc/t42/s10164","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10164%2F6","sourceRelease":"119-100","text":"provide such other benefits to the system for the disposal of spent nuclear fuel and high-level radioactive waste as the Secretary deems appropriate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s10164/7","parentIdentifier":"/us/usc/t42/s10164","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10164%2F7","sourceRelease":"119-100","text":"unduly burden a State in which significant volumes of high-level radioactive waste resulting from atomic energy defense activities are stored.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
