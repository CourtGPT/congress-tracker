{"type":"section","nativeType":"section","number":"1302c","heading":"Small publicly owned treatment works efficiency grant program","label":"1302c Small publicly owned treatment works efficiency grant program","identifier":"/us/usc/t33/s1302c","parentIdentifier":"/us/usc/t33/ch26/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t33/s1302c/a","parentIdentifier":"/us/usc/t33/s1302c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302c%2Fa","sourceRelease":"119-100","text":"Subject to the availability of appropriations, not later than 180 days after , the Administrator shall establish an efficiency grant program (referred to in this section as the “efficiency grant program”) under which the Administrator shall award grants to eligible entities for the replacement or repair of equipment that improves water or energy efficiency of small publicly owned treatment works, as identified in an efficiency audit.November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Eligible entities","label":"b Eligible entities","identifier":"/us/usc/t33/s1302c/b","parentIdentifier":"/us/usc/t33/s1302c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1302c/b/1","parentIdentifier":"/us/usc/t33/s1302c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302c%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1302c/b/1/A","parentIdentifier":"/us/usc/t33/s1302c/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302c%2Fb%2F1%2FA","sourceRelease":"119-100","text":"a population of not more than 10,000 people; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1302c/b/1/B","parentIdentifier":"/us/usc/t33/s1302c/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302c%2Fb%2F1%2FB","sourceRelease":"119-100","text":"a disadvantaged community; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1302c/b/2","parentIdentifier":"/us/usc/t33/s1302c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302c%2Fb%2F2","sourceRelease":"119-100","text":"a nonprofit organization that seeks to assist a small publicly owned treatment works described in paragraph (1) to carry out the activities described in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Report","label":"c Report","identifier":"/us/usc/t33/s1302c/c","parentIdentifier":"/us/usc/t33/s1302c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302c%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1302c/c/1","parentIdentifier":"/us/usc/t33/s1302c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302c%2Fc%2F1","sourceRelease":"119-100","text":"each recipient of a grant under the efficiency grant program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1302c/c/2","parentIdentifier":"/us/usc/t33/s1302c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302c%2Fc%2F2","sourceRelease":"119-100","text":"a summary of the activities carried out under the efficiency grant program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Use of funds","label":"d Use of funds","identifier":"/us/usc/t33/s1302c/d","parentIdentifier":"/us/usc/t33/s1302c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302c%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Small systems","label":"1 Small systems","identifier":"/us/usc/t33/s1302c/d/1","parentIdentifier":"/us/usc/t33/s1302c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302c%2Fd%2F1","sourceRelease":"119-100","text":"Of the amounts made available for grants under this section, to the extent that there are sufficient applications, not less than 15 percent shall be used for grants to publicly owned treatment works that serve fewer than 3,300 people.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitation on use of funds","label":"2 Limitation on use of funds","identifier":"/us/usc/t33/s1302c/d/2","parentIdentifier":"/us/usc/t33/s1302c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302c%2Fd%2F2","sourceRelease":"119-100","text":"Of the amounts made available for grants under this section, not more than 2 percent may be used to pay the administrative costs of the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
