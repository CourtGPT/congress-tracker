e.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fa%2F3","sourceRelease":"119-100","text":"bioenergy with carbon capture and sequestration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16298e/a/4","parentIdentifier":"/us/usc/t42/s16298e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fa%2F4","sourceRelease":"119-100","text":"forest restoration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16298e/a/5","parentIdentifier":"/us/usc/t42/s16298e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fa%2F5","sourceRelease":"119-100","text":"soil carbon management; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s16298e/a/6","parentIdentifier":"/us/usc/t42/s16298e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fa%2F6","sourceRelease":"119-100","text":"direct ocean capture.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report","label":"b Report","identifier":"/us/usc/t42/s16298e/b","parentIdentifier":"/us/usc/t42/s16298e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16298e/b/1","parentIdentifier":"/us/usc/t42/s16298e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fb%2F1","sourceRelease":"119-100","text":"estimates the magnitude of excess carbon dioxide in the atmosphere that will need to be removed by 2050 to achieve net-zero emissions and stabilize the climate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16298e/b/2","parentIdentifier":"/us/usc/t42/s16298e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fb%2F2","sourceRelease":"119-100","text":"inventories current and emerging approaches of carbon dioxide removal and evaluates the advantages and disadvantages of each of the approaches; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16298e/b/3","parentIdentifier":"/us/usc/t42/s16298e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16298e/b/3/A","parentIdentifier":"/us/usc/t42/s16298e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fb%2F3%2FA","sourceRelease":"119-100","text":"grants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16298e/b/3/B","parentIdentifier":"/us/usc/t42/s16298e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fb%2F3%2FB","sourceRelease":"119-100","text":"loans or loan guarantees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16298e/b/3/C","parentIdentifier":"/us/usc/t42/s16298e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fb%2F3%2FC","sourceRelease":"119-100","text":"public-private partnerships;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16298e/b/3/D","parentIdentifier":"/us/usc/t42/s16298e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fb%2F3%2FD","sourceRelease":"119-100","text":"direct procurement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16298e/b/3/E","parentIdentifier":"/us/usc/t42/s16298e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fb%2F3%2FE","sourceRelease":"119-100","text":"incentives, including subsidized Federal financing mechanisms available to project developers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s16298e/b/3/F","parentIdentifier":"/us/usc/t42/s16298e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fb%2F3%2FF","sourceRelease":"119-100","text":"advance market commitments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s16298e/b/3/G","parentIdentifier":"/us/usc/t42/s16298e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fb%2F3%2FG","sourceRelease":"119-100","text":"regulations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t42/s16298e/b/3/H","parentIdentifier":"/us/usc/t42/s16298e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fb%2F3%2FH","sourceRelease":"119-100","text":"any other policy mechanism determined by the Secretary to be beneficial for advancing carbon dioxide removal methods and the deployment of carbon dioxide removal projects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Submission; publication","label":"c Submission; publication","identifier":"/us/usc/t42/s16298e/c","parentIdentifier":"/us/usc/t42/s16298e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16298e/c/1","parentIdentifier":"/us/usc/t42/s16298e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fc%2F1","sourceRelease":"119-100","text":"submit the report prepared under subsection (b) to the Committee on Energy and Natural Resources of the Senate and the Committees on Energy and Commerce and Science, Space, and Technology of the House of Representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16298e/c/2","parentIdentifier":"/us/usc/t42/s16298e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fc%2F2","sourceRelease":"119-100","text":"as soon as practicable after completion of the report, make the report publicly available.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Evaluation; revision","label":"d Evaluation; revision","identifier":"/us/usc/t42/s16298e/d","parentIdentifier":"/us/usc/t42/s16298e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16298e/d/1","parentIdentifier":"/us/usc/t42/s16298e/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fd%2F1","sourceRelease":"119-100","text":"Not later than 2 years after the date on which the Secretary publishes the report under subsection (c)(2), and every 2 years thereafter, the Secretary shall evaluate the findings and recommendations of the report, or the most recent updated report submitted under paragraph (2)(B), as applicable, taking into consideration any issues and recommendations identified by the task force established under subsection (e)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Revision","label":"2 Revision","identifier":"/us/usc/t42/s16298e/d/2","parentIdentifier":"/us/usc/t42/s16298e/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16298e/d/2/A","parentIdentifier":"/us/usc/t42/s16298e/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fd%2F2%2FA","sourceRelease":"119-100","text":"revise the report as necessary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16298e/d/2/B","parentIdentifier":"/us/usc/t42/s16298e/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fd%2F2%2FB","sourceRelease":"119-100","text":"if the Secretary revises the report under subparagraph (A), submit and publish the updated report in accordance with subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Task force","label":"e Task force","identifier":"/us/usc/t42/s16298e/e","parentIdentifier":"/us/usc/t42/s16298e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment and duties","label":"1 Establishment and duties","identifier":"/us/usc/t42/s16298e/e/1","parentIdentifier":"/us/usc/t42/s16298e/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16298e/e/1/A","parentIdentifier":"/us/usc/t42/s16298e/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fe%2F1%2FA","sourceRelease":"119-100","text":"to identify barriers to advancement of carbon dioxide removal methods and the deployment of carbon dioxide removal projects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16298e/e/1/B","parentIdentifier":"/us/usc/t42/s16298e/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fe%2F1%2FB","sourceRelease":"119-100","text":"to inventory existing or potential Federal legislation, rules, revisions to rules, financing mechanisms, or other policy tools that are capable of advancing carbon dioxide removal methods and the deployment of carbon dioxide removal projects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16298e/e/1/C","parentIdentifier":"/us/usc/t42/s16298e/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fe%2F1%2FC","sourceRelease":"119-100","text":"to assist in preparing the report described in subsection (b) and any updates to the report under subsection (d); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16298e/e/1/D","parentIdentifier":"/us/usc/t42/s16298e/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fe%2F1%2FD","sourceRelease":"119-100","text":"to advise the Secretary on matters pertaining to carbon dioxide removal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Members and selection","label":"2 Members and selection","identifier":"/us/usc/t42/s16298e/e/2","parentIdentifier":"/us/usc/t42/s16298e/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16298e/e/2/A","parentIdentifier":"/us/usc/t42/s16298e/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fe%2F2%2FA","sourceRelease":"119-100","text":"develop criteria for the selection of members to the task force established under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16298e/e/2/B","parentIdentifier":"/us/usc/t42/s16298e/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fe%2F2%2FB","sourceRelease":"119-100","text":"select members for the task force in accordance with the criteria developed under subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Meetings","label":"3 Meetings","identifier":"/us/usc/t42/s16298e/e/3","parentIdentifier":"/us/usc/t42/s16298e/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fe%2F3","sourceRelease":"119-100","text":"The task force shall meet not less frequently than once each year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Evaluation","label":"4 Evaluation","identifier":"/us/usc/t42/s16298e/e/4","parentIdentifier":"/us/usc/t42/s16298e/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fe%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16298e/e/4/A","parentIdentifier":"/us/usc/t42/s16298e/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fe%2F4%2FA","sourceRelease":"119-100","text":"reevaluate the need for the task force established under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16298e/e/4/B","parentIdentifier":"/us/usc/t42/s16298e/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298e%2Fe%2F4%2FB","sourceRelease":"119-100","text":"submit to Congress a recommendation as to whether the task force should continue.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
