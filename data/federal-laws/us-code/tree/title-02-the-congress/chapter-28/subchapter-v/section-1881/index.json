{"type":"section","nativeType":"section","number":"1881","heading":"Definitions","label":"1881 Definitions","identifier":"/us/usc/t2/s1881","parentIdentifier":"/us/usc/t2/ch28/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1881","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s1881/1","parentIdentifier":"/us/usc/t2/s1881","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1881%2F1","sourceRelease":"119-100","text":"the term “Capitol-flown flag” means a flag of the United States flown over the Capitol in honor of the deceased individual for whom the flag is requested;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s1881/2","parentIdentifier":"/us/usc/t2/s1881","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1881%2F2","sourceRelease":"119-100","text":"the terms “chaplain”, “firefighter”, “law enforcement officer”, “member of a rescue squad or ambulance crew”, and “public agency” have the meanings given such terms in ;section 10284 of title 34","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t2/s1881/3","parentIdentifier":"/us/usc/t2/s1881","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1881%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t2/s1881/3/A","parentIdentifier":"/us/usc/t2/s1881/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1881%2F3%2FA","sourceRelease":"119-100","text":"the spouse, parent, brother, sister, or child of the individual or a person to whom the individual stands in loco parentis; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t2/s1881/3/B","parentIdentifier":"/us/usc/t2/s1881/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1881%2F3%2FB","sourceRelease":"119-100","text":"any other person related to the individual by blood or marriage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t2/s1881/4","parentIdentifier":"/us/usc/t2/s1881","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1881%2F4","sourceRelease":"119-100","text":"the term “public safety officer” means an individual serving a public agency in an official capacity, with or without compensation, as a law enforcement officer, as a firefighter, or as a chaplain; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t2/s1881/5","parentIdentifier":"/us/usc/t2/s1881","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1881%2F5","sourceRelease":"119-100","text":"the term “Representative” includes a Delegate or Resident Commissioner to the Congress.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
