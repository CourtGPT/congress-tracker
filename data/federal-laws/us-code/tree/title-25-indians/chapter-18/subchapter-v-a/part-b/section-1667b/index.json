{"type":"section","nativeType":"section","number":"1667b","heading":"Indian youth telemental health demonstration project","label":"1667b Indian youth telemental health demonstration project","identifier":"/us/usc/t25/s1667b","parentIdentifier":"/us/usc/t25/ch18/schV–A/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Codificationis based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by .Section 723 of Pub. L. 94–437section 10221(a) of Pub. L. 111–148"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authorization","label":"a Authorization","identifier":"/us/usc/t25/s1667b/a","parentIdentifier":"/us/usc/t25/s1667b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s1667b/a/1","parentIdentifier":"/us/usc/t25/s1667b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1667b/a/1/A","parentIdentifier":"/us/usc/t25/s1667b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F1%2FA","sourceRelease":"119-100","text":"have expressed suicidal ideas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1667b/a/1/B","parentIdentifier":"/us/usc/t25/s1667b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F1%2FB","sourceRelease":"119-100","text":"have attempted suicide; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1667b/a/1/C","parentIdentifier":"/us/usc/t25/s1667b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F1%2FC","sourceRelease":"119-100","text":"have behavioral health conditions that increase or could increase the risk of suicide.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligibility for grants","label":"2 Eligibility for grants","identifier":"/us/usc/t25/s1667b/a/2","parentIdentifier":"/us/usc/t25/s1667b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1667b/a/2/A","parentIdentifier":"/us/usc/t25/s1667b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F2%2FA","sourceRelease":"119-100","text":"located in an area with documented disproportionately high rates of suicide;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1667b/a/2/B","parentIdentifier":"/us/usc/t25/s1667b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F2%2FB","sourceRelease":"119-100","text":"reporting active clinical telehealth capabilities; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1667b/a/2/C","parentIdentifier":"/us/usc/t25/s1667b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F2%2FC","sourceRelease":"119-100","text":"offering school-based telemental health services to Indian youth.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Grant period","label":"3 Grant period","identifier":"/us/usc/t25/s1667b/a/3","parentIdentifier":"/us/usc/t25/s1667b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F3","sourceRelease":"119-100","text":"The Secretary shall award grants under this section for a period of up to 4 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Maximum number of grants","label":"4 Maximum number of grants","identifier":"/us/usc/t25/s1667b/a/4","parentIdentifier":"/us/usc/t25/s1667b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1667b/a/4/A","parentIdentifier":"/us/usc/t25/s1667b/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F4%2FA","sourceRelease":"119-100","text":"serve a particular community or geographic area in which there is a demonstrated need to address Indian youth suicide;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1667b/a/4/B","parentIdentifier":"/us/usc/t25/s1667b/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F4%2FB","sourceRelease":"119-100","text":"enter into collaborative partnerships with Service or other tribal health programs or facilities to provide services under this demonstration project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1667b/a/4/C","parentIdentifier":"/us/usc/t25/s1667b/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F4%2FC","sourceRelease":"119-100","text":"serve an isolated community or geographic area that has limited or no access to behavioral health services; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s1667b/a/4/D","parentIdentifier":"/us/usc/t25/s1667b/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F4%2FD","sourceRelease":"119-100","text":"operate a detention facility at which Indian youth are detained.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Consultation with Administration","label":"5 Consultation with Administration","identifier":"/us/usc/t25/s1667b/a/5","parentIdentifier":"/us/usc/t25/s1667b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fa%2F5","sourceRelease":"119-100","text":"In developing and carrying out the demonstration project under this subsection, the Secretary shall consult with the Administration as the Federal agency focused on mental health issues, including suicide.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Use of funds","label":"b Use of funds","identifier":"/us/usc/t25/s1667b/b","parentIdentifier":"/us/usc/t25/s1667b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s1667b/b/1","parentIdentifier":"/us/usc/t25/s1667b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1667b/b/1/A","parentIdentifier":"/us/usc/t25/s1667b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s1667b/b/1/A/i","parentIdentifier":"/us/usc/t25/s1667b/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"psychotherapy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s1667b/b/1/A/ii","parentIdentifier":"/us/usc/t25/s1667b/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"psychiatric assessments and diagnostic interviews, therapies for mental health conditions predisposing to suicide, and treatment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t25/s1667b/b/1/A/iii","parentIdentifier":"/us/usc/t25/s1667b/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"alcohol and substance abuse treatment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1667b/b/1/B","parentIdentifier":"/us/usc/t25/s1667b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1%2FB","sourceRelease":"119-100","text":"To provide clinician-interactive medical advice, guidance and training, assistance in diagnosis and interpretation, crisis counseling and intervention, and related assistance to Service or tribal clinicians and health services providers working with youth being served under the demonstration project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1667b/b/1/C","parentIdentifier":"/us/usc/t25/s1667b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1%2FC","sourceRelease":"119-100","text":"To assist, educate, and train community leaders, health education professionals and paraprofessionals, tribal outreach workers, and family members who work with the youth receiving telemental health services under the demonstration project, including with identification of suicidal tendencies, crisis intervention and suicide prevention, emergency skill development, and building and expanding networks among those individuals and with State and local health services providers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s1667b/b/1/D","parentIdentifier":"/us/usc/t25/s1667b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s1667b/b/1/D/i","parentIdentifier":"/us/usc/t25/s1667b/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1%2FD%2Fi","sourceRelease":"119-100","text":"suicide prevention;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s1667b/b/1/D/ii","parentIdentifier":"/us/usc/t25/s1667b/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1%2FD%2Fii","sourceRelease":"119-100","text":"suicide education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t25/s1667b/b/1/D/iii","parentIdentifier":"/us/usc/t25/s1667b/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1%2FD%2Fiii","sourceRelease":"119-100","text":"suicide screening;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t25/s1667b/b/1/D/iv","parentIdentifier":"/us/usc/t25/s1667b/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1%2FD%2Fiv","sourceRelease":"119-100","text":"suicide intervention; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t25/s1667b/b/1/D/v","parentIdentifier":"/us/usc/t25/s1667b/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1%2FD%2Fv","sourceRelease":"119-100","text":"ways to mobilize communities with respect to the identification of risk factors for suicide.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t25/s1667b/b/1/E","parentIdentifier":"/us/usc/t25/s1667b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F1%2FE","sourceRelease":"119-100","text":"To conduct data collection and reporting relating to Indian youth suicide prevention efforts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Traditional health care practices","label":"2 Traditional health care practices","identifier":"/us/usc/t25/s1667b/b/2","parentIdentifier":"/us/usc/t25/s1667b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fb%2F2","sourceRelease":"119-100","text":"In carrying out the purposes described in paragraph (1), an Indian tribe or tribal organization may use and promote the traditional health care practices of the Indian tribes of the youth to be served.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Applications","label":"c Applications","identifier":"/us/usc/t25/s1667b/c","parentIdentifier":"/us/usc/t25/s1667b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s1667b/c/1","parentIdentifier":"/us/usc/t25/s1667b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1667b/c/1/A","parentIdentifier":"/us/usc/t25/s1667b/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fc%2F1%2FA","sourceRelease":"119-100","text":"a description of the project that the Indian tribe or tribal organization will carry out using the funds provided under the grant;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1667b/c/1/B","parentIdentifier":"/us/usc/t25/s1667b/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s1667b/c/1/B/i","parentIdentifier":"/us/usc/t25/s1667b/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"meet the telemental health care needs of the Indian youth population to be served by the project; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s1667b/c/1/B/ii","parentIdentifier":"/us/usc/t25/s1667b/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"improve the access of the Indian youth population to be served to suicide prevention and treatment services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1667b/c/1/C","parentIdentifier":"/us/usc/t25/s1667b/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fc%2F1%2FC","sourceRelease":"119-100","text":"evidence of support for the project from the local community to be served by the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s1667b/c/1/D","parentIdentifier":"/us/usc/t25/s1667b/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fc%2F1%2FD","sourceRelease":"119-100","text":"a description of how the families and leadership of the communities or populations to be served by the project would be involved in the development and ongoing operations of the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t25/s1667b/c/1/E","parentIdentifier":"/us/usc/t25/s1667b/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fc%2F1%2FE","sourceRelease":"119-100","text":"a plan to involve the tribal community of the youth who are provided services by the project in planning and evaluating the behavioral health care and suicide prevention efforts provided, in order to ensure the integration of community, clinical, environmental, and cultural components of the treatment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t25/s1667b/c/1/F","parentIdentifier":"/us/usc/t25/s1667b/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fc%2F1%2FF","sourceRelease":"119-100","text":"a plan for sustaining the project after Federal assistance for the demonstration project has terminated.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Efficiency of grant application process","label":"2 Efficiency of grant application process","identifier":"/us/usc/t25/s1667b/c/2","parentIdentifier":"/us/usc/t25/s1667b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fc%2F2","sourceRelease":"119-100","text":"The Secretary shall carry out such measures as the Secretary determines to be necessary to maximize the time and workload efficiency of the process by which Indian tribes and tribal organizations apply for grants under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Collaboration","label":"d Collaboration","identifier":"/us/usc/t25/s1667b/d","parentIdentifier":"/us/usc/t25/s1667b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fd","sourceRelease":"119-100","text":"The Secretary, acting through the Service, shall encourage Indian tribes and tribal organizations receiving grants under this section to collaborate to enable comparisons regarding best practices across projects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Annual report","label":"e Annual report","identifier":"/us/usc/t25/s1667b/e","parentIdentifier":"/us/usc/t25/s1667b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s1667b/e/1","parentIdentifier":"/us/usc/t25/s1667b/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fe%2F1","sourceRelease":"119-100","text":"describes the number of telemental health services provided; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s1667b/e/2","parentIdentifier":"/us/usc/t25/s1667b/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fe%2F2","sourceRelease":"119-100","text":"includes any other information that the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Reports to Congress","label":"f Reports to Congress","identifier":"/us/usc/t25/s1667b/f","parentIdentifier":"/us/usc/t25/s1667b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Initial report","label":"1 Initial report","identifier":"/us/usc/t25/s1667b/f/1","parentIdentifier":"/us/usc/t25/s1667b/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t25/s1667b/f/1/A","parentIdentifier":"/us/usc/t25/s1667b/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Ff%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s1667b/f/1/A/i","parentIdentifier":"/us/usc/t25/s1667b/f/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Ff%2F1%2FA%2Fi","sourceRelease":"119-100","text":"describes each project funded by a grant under this section during the preceding 2-year period, including a description of the level of success achieved by the project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s1667b/f/1/A/ii","parentIdentifier":"/us/usc/t25/s1667b/f/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Ff%2F1%2FA%2Fii","sourceRelease":"119-100","text":"evaluates whether the demonstration project should be continued during the period beginning on the date of termination of funding for the demonstration project under subsection (g) and ending on the date on which the final report is submitted under paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Continuation of demonstration project","label":"B Continuation of demonstration project","identifier":"/us/usc/t25/s1667b/f/1/B","parentIdentifier":"/us/usc/t25/s1667b/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Ff%2F1%2FB","sourceRelease":"119-100","text":"On a determination by the Secretary under clause (ii) of subparagraph (A) that the demonstration project should be continued, the Secretary may carry out the demonstration project during the period described in that clause using such sums otherwise made available to the Secretary as the Secretary determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Final report","label":"2 Final report","identifier":"/us/usc/t25/s1667b/f/2","parentIdentifier":"/us/usc/t25/s1667b/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1667b/f/2/A","parentIdentifier":"/us/usc/t25/s1667b/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Ff%2F2%2FA","sourceRelease":"119-100","text":"describes the results of the projects funded by grants awarded under this section, including any data available that indicate the number of attempted suicides;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1667b/f/2/B","parentIdentifier":"/us/usc/t25/s1667b/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Ff%2F2%2FB","sourceRelease":"119-100","text":"evaluates the impact of the telemental health services funded by the grants in reducing the number of completed suicides among Indian youth;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1667b/f/2/C","parentIdentifier":"/us/usc/t25/s1667b/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Ff%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s1667b/f/2/C/i","parentIdentifier":"/us/usc/t25/s1667b/f/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Ff%2F2%2FC%2Fi","sourceRelease":"119-100","text":"expanded to provide more than 5 grants; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s1667b/f/2/C/ii","parentIdentifier":"/us/usc/t25/s1667b/f/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Ff%2F2%2FC%2Fii","sourceRelease":"119-100","text":"designated as a permanent program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s1667b/f/2/D","parentIdentifier":"/us/usc/t25/s1667b/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Ff%2F2%2FD","sourceRelease":"119-100","text":"evaluates the benefits of expanding the demonstration project to include urban Indian organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Authorization of appropriations","label":"g Authorization of appropriations","identifier":"/us/usc/t25/s1667b/g","parentIdentifier":"/us/usc/t25/s1667b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667b%2Fg","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $1,500,000 for each of fiscal years 2010 through 2013.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
