{"type":"section","nativeType":"section","number":"16123","heading":"Federal procurement of stationary, portable, and micro fuel cells","label":"16123 Federal procurement of stationary, portable, and micro fuel cells","identifier":"/us/usc/t42/s16123","parentIdentifier":"/us/usc/t42/ch149/schVII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purposes","label":"a Purposes","identifier":"/us/usc/t42/s16123/a","parentIdentifier":"/us/usc/t42/s16123","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16123/a/1","parentIdentifier":"/us/usc/t42/s16123/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fa%2F1","sourceRelease":"119-100","text":"to stimulate acceptance by the market of stationary, portable, and micro fuel cells; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16123/a/2","parentIdentifier":"/us/usc/t42/s16123/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fa%2F2","sourceRelease":"119-100","text":"to support development of technologies relating to stationary, portable, and micro fuel cells.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Federal leases and purchases","label":"b Federal leases and purchases","identifier":"/us/usc/t42/s16123/b","parentIdentifier":"/us/usc/t42/s16123","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16123/b/1","parentIdentifier":"/us/usc/t42/s16123/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb%2F1","sourceRelease":"119-100","text":"Not later than , the head of any Federal agency that uses electrical power from stationary, portable, or microportable devices shall lease or purchase a stationary, portable, or micro fuel cell to meet any applicable energy savings goal described in subsection (c).January 1, 2006","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Costs of leases and purchases","label":"2 Costs of leases and purchases","identifier":"/us/usc/t42/s16123/b/2","parentIdentifier":"/us/usc/t42/s16123/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16123/b/2/A","parentIdentifier":"/us/usc/t42/s16123/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The Secretary, in cooperation with the Task Force and the Technical Advisory Committee, shall pay the cost to Federal agencies (or share the cost under interagency agreements) of leasing or purchasing stationary, portable, and micro fuel cells under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Competitive costs and management structures","label":"B Competitive costs and management structures","identifier":"/us/usc/t42/s16123/b/2/B","parentIdentifier":"/us/usc/t42/s16123/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16123/b/2/B/i","parentIdentifier":"/us/usc/t42/s16123/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"a cost-effective purchase of a stationary, portable, or micro fuel cell; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16123/b/2/B/ii","parentIdentifier":"/us/usc/t42/s16123/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"a cost-effective management structure of the lease of a stationary, portable, or micro fuel cell.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Exception","label":"3 Exception","identifier":"/us/usc/t42/s16123/b/3","parentIdentifier":"/us/usc/t42/s16123/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16123/b/3/A","parentIdentifier":"/us/usc/t42/s16123/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb%2F3%2FA","sourceRelease":"119-100","text":"If the Secretary determines that the head of an agency described in paragraph (1) cannot find an appropriately efficient and reliable stationary, portable, or micro fuel cell in accordance with paragraph (1), that agency shall be excepted from compliance with paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Consideration","label":"B Consideration","identifier":"/us/usc/t42/s16123/b/3/B","parentIdentifier":"/us/usc/t42/s16123/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16123/b/3/B/i","parentIdentifier":"/us/usc/t42/s16123/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"the needs of the agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16123/b/3/B/ii","parentIdentifier":"/us/usc/t42/s16123/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s16123/b/3/B/ii/I","parentIdentifier":"/us/usc/t42/s16123/b/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb%2F3%2FB%2Fii%2FI","sourceRelease":"119-100","text":"the Task Force; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s16123/b/3/B/ii/II","parentIdentifier":"/us/usc/t42/s16123/b/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fb%2F3%2FB%2Fii%2FII","sourceRelease":"119-100","text":"the Technical Advisory Committee of the Task Force.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Energy savings goals","label":"c Energy savings goals","identifier":"/us/usc/t42/s16123/c","parentIdentifier":"/us/usc/t42/s16123","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fc","sourceRelease":"119-100","text":"An agency that leases or purchases a stationary, portable, or micro fuel cell in accordance with subsection (b)(1) may use that lease or purchase to count toward an energy savings goal described in that is applicable to the agency.section 16157 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s16123/d","parentIdentifier":"/us/usc/t42/s16123","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16123/d/1","parentIdentifier":"/us/usc/t42/s16123/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fd%2F1","sourceRelease":"119-100","text":"$20,000,000 for fiscal year 2006;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16123/d/2","parentIdentifier":"/us/usc/t42/s16123/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fd%2F2","sourceRelease":"119-100","text":"$50,000,000 for fiscal year 2007;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16123/d/3","parentIdentifier":"/us/usc/t42/s16123/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fd%2F3","sourceRelease":"119-100","text":"$75,000,000 for fiscal year 2008;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16123/d/4","parentIdentifier":"/us/usc/t42/s16123/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fd%2F4","sourceRelease":"119-100","text":"$100,000,000 for fiscal year 2009;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16123/d/5","parentIdentifier":"/us/usc/t42/s16123/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fd%2F5","sourceRelease":"119-100","text":"$100,000,000 for fiscal year 2010; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s16123/d/6","parentIdentifier":"/us/usc/t42/s16123/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16123%2Fd%2F6","sourceRelease":"119-100","text":"such sums as are necessary for each of fiscal years 2011 through 2015.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
