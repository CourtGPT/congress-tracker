{"type":"section","nativeType":"section","number":"1508","heading":"National plan for unlicensed spectrum","label":"1508 National plan for unlicensed spectrum","identifier":"/us/usc/t47/s1508","parentIdentifier":"/us/usc/t47/ch14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t47/s1508/a","parentIdentifier":"/us/usc/t47/s1508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Spectrum Relocation Fund","label":"1 Spectrum Relocation Fund","identifier":"/us/usc/t47/s1508/a/1","parentIdentifier":"/us/usc/t47/s1508/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fa%2F1","sourceRelease":"119-100","text":"The term “Spectrum Relocation Fund” means the Fund established under .section 928 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Unlicensed or licensed by rule operations","label":"2 Unlicensed or licensed by rule operations","identifier":"/us/usc/t47/s1508/a/2","parentIdentifier":"/us/usc/t47/s1508/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1508/a/2/A","parentIdentifier":"/us/usc/t47/s1508/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fa%2F2%2FA","sourceRelease":"119-100","text":"part 15 of title 47, Code of Federal Regulations; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1508/a/2/B","parentIdentifier":"/us/usc/t47/s1508/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fa%2F2%2FB","sourceRelease":"119-100","text":"licensing by rule under part 96 of title 47, Code of Federal Regulations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"National plan","label":"b National plan","identifier":"/us/usc/t47/s1508/b","parentIdentifier":"/us/usc/t47/s1508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fb","sourceRelease":"119-100","text":"Not later than 18 months after , the Commission, in consultation with the NTIA, shall develop a national plan for making additional radio frequency bands available for unlicensed or licensed by rule operations.March 23, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Requirements","label":"c Requirements","identifier":"/us/usc/t47/s1508/c","parentIdentifier":"/us/usc/t47/s1508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s1508/c/1","parentIdentifier":"/us/usc/t47/s1508/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fc%2F1","sourceRelease":"119-100","text":"identify an approach that ensures that consumers have access to additional spectrum to conduct unlicensed or licensed by rule operations in a range of radio frequencies to meet consumer demand;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s1508/c/2","parentIdentifier":"/us/usc/t47/s1508/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1508/c/2/A","parentIdentifier":"/us/usc/t47/s1508/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fc%2F2%2FA","sourceRelease":"119-100","text":"are consistent with the statement of policy under ;section 1507(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1508/c/2/B","parentIdentifier":"/us/usc/t47/s1508/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1508/c/2/B/i","parentIdentifier":"/us/usc/t47/s1508/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"expand opportunities for unlicensed or licensed by rule operations in a spectrum band; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1508/c/2/B/ii","parentIdentifier":"/us/usc/t47/s1508/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"otherwise improve spectrum utilization and intensity of use of bands where unlicensed or licensed by rule operations are already permitted;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t47/s1508/c/2/C","parentIdentifier":"/us/usc/t47/s1508/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fc%2F2%2FC","sourceRelease":"119-100","text":"will not cause harmful interference to Federal or non-Federal users of such bands; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t47/s1508/c/2/D","parentIdentifier":"/us/usc/t47/s1508/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fc%2F2%2FD","sourceRelease":"119-100","text":"will not significantly impact homeland security or national security communications systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t47/s1508/c/3","parentIdentifier":"/us/usc/t47/s1508/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1508/c/3/A","parentIdentifier":"/us/usc/t47/s1508/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fc%2F3%2FA","sourceRelease":"119-100","text":"to improve accuracy and efficacy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1508/c/3/B","parentIdentifier":"/us/usc/t47/s1508/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fc%2F3%2FB","sourceRelease":"119-100","text":"to reduce burdens on consumers, manufacturers, and service providers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t47/s1508/c/3/C","parentIdentifier":"/us/usc/t47/s1508/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fc%2F3%2FC","sourceRelease":"119-100","text":"to protect sensitive Government information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Spectrum Relocation Fund","label":"d Spectrum Relocation Fund","identifier":"/us/usc/t47/s1508/d","parentIdentifier":"/us/usc/t47/s1508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s1508/d/1","parentIdentifier":"/us/usc/t47/s1508/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fd%2F1","sourceRelease":"119-100","text":"to address costs incurred by Federal entities related to sharing radio frequency bands with radio technologies conducting unlicensed or licensed by rule operations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s1508/d/2","parentIdentifier":"/us/usc/t47/s1508/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1508/d/2/A","parentIdentifier":"/us/usc/t47/s1508/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fd%2F2%2FA","sourceRelease":"119-100","text":"the costs described in paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1508/d/2/B","parentIdentifier":"/us/usc/t47/s1508/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fd%2F2%2FB","sourceRelease":"119-100","text":"other expenditures allowed of the Spectrum Relocation Fund under .section 928 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Report required","label":"e Report required","identifier":"/us/usc/t47/s1508/e","parentIdentifier":"/us/usc/t47/s1508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t47/s1508/e/1","parentIdentifier":"/us/usc/t47/s1508/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fe%2F1","sourceRelease":"119-100","text":"Not later than 18 months after , the Commission shall submit to the appropriate committees of Congress a report that describes the plan developed under this section, including any recommendations for legislative change.March 23, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Publication on commission website","label":"2 Publication on commission website","identifier":"/us/usc/t47/s1508/e/2","parentIdentifier":"/us/usc/t47/s1508/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Fe%2F2","sourceRelease":"119-100","text":"Not later than the date on which the Commission submits the report under paragraph (1), the Commission shall make the report publicly available on the website of the Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Rule of construction","label":"f Rule of construction","identifier":"/us/usc/t47/s1508/f","parentIdentifier":"/us/usc/t47/s1508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1508%2Ff","sourceRelease":"119-100","text":"Nothing in this section confers any additional rights on unlicensed users or users licensed by rule under part 96 of title 47, Code of Federal Regulations, to protection from harmful interference.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
