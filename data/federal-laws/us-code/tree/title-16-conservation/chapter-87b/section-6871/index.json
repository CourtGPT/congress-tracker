{"type":"section","nativeType":"section","number":"6871","heading":"Definitions","label":"6871 Definitions","identifier":"/us/usc/t16/s6871","parentIdentifier":"/us/usc/t16/ch87B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Short Title, , , provided that:Pub. L. 119–62, § 1139 Stat. 1979Dec. 26, 2025“This Act [enacting this chapter] may be cited as the ‘Modernizing Access to our Public Waters Act of 2025’ or the ‘MAPWaters Act of 2025’.”"],"amendments":["Short Title, , , provided that:Pub. L. 119–62, § 1139 Stat. 1979Dec. 26, 2025“This Act [enacting this chapter] may be cited as the ‘Modernizing Access to our Public Waters Act of 2025’ or the ‘MAPWaters Act of 2025’.”"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Federal fishing restriction","label":"1 Federal fishing restriction","identifier":"/us/usc/t16/s6871/1","parentIdentifier":"/us/usc/t16/s6871","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871%2F1","sourceRelease":"119-100","text":"The term “Federal fishing restriction” means a defined area in which all or certain fishing activities are temporarily or permanently prohibited or restricted by a Federal land or water management agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Federal land or water management agency","label":"2 Federal land or water management agency","identifier":"/us/usc/t16/s6871/2","parentIdentifier":"/us/usc/t16/s6871","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6871/2/A","parentIdentifier":"/us/usc/t16/s6871/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871%2F2%2FA","sourceRelease":"119-100","text":"the Bureau of Reclamation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6871/2/B","parentIdentifier":"/us/usc/t16/s6871/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871%2F2%2FB","sourceRelease":"119-100","text":"the National Park Service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6871/2/C","parentIdentifier":"/us/usc/t16/s6871/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871%2F2%2FC","sourceRelease":"119-100","text":"the Bureau of Land Management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s6871/2/D","parentIdentifier":"/us/usc/t16/s6871/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871%2F2%2FD","sourceRelease":"119-100","text":"the United States Fish and Wildlife Service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s6871/2/E","parentIdentifier":"/us/usc/t16/s6871/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871%2F2%2FE","sourceRelease":"119-100","text":"the Forest Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Federal waterway","label":"3 Federal waterway","identifier":"/us/usc/t16/s6871/3","parentIdentifier":"/us/usc/t16/s6871","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871%2F3","sourceRelease":"119-100","text":"The term “Federal waterway” means waters managed by 1 or more of the relevant Secretaries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Federal waterway restriction","label":"4 Federal waterway restriction","identifier":"/us/usc/t16/s6871/4","parentIdentifier":"/us/usc/t16/s6871","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871%2F4","sourceRelease":"119-100","text":"The term “Federal waterway restriction” means a restriction on the access or use of a Federal waterway applied under applicable law by 1 or more of the Secretaries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Secretaries","label":"5 Secretaries","identifier":"/us/usc/t16/s6871/5","parentIdentifier":"/us/usc/t16/s6871","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6871/5/A","parentIdentifier":"/us/usc/t16/s6871/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871%2F5%2FA","sourceRelease":"119-100","text":"the Secretary of Agriculture, acting through the Chief of the Forest Service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6871/5/B","parentIdentifier":"/us/usc/t16/s6871/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871%2F5%2FB","sourceRelease":"119-100","text":"the Secretary of the Interior.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"State","label":"6 State","identifier":"/us/usc/t16/s6871/6","parentIdentifier":"/us/usc/t16/s6871","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6871%2F6","sourceRelease":"119-100","text":"The term “State” means each of the several States, the District of Columbia, and each territory of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
