parentIdentifier":"/us/usc/t15/s78c–4/d/14/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FB%2Fiv","sourceRelease":"119-100","text":"be responsible for establishing and administering the policies and procedures required to be established pursuant to this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t15/s78c–4/d/14/B/v","parentIdentifier":"/us/usc/t15/s78c–4/d/14/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FB%2Fv","sourceRelease":"119-100","text":"ensure compliance with this chapter and the rules and regulations issued under this chapter, including rules prescribed by the Commission pursuant to this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t15/s78c–4/d/14/B/vi","parentIdentifier":"/us/usc/t15/s78c–4/d/14/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FB%2Fvi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s78c–4/d/14/B/vi/I","parentIdentifier":"/us/usc/t15/s78c–4/d/14/B/vi","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FB%2Fvi%2FI","sourceRelease":"119-100","text":"compliance office reviews;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t15/s78c–4/d/14/B/vi/II","parentIdentifier":"/us/usc/t15/s78c–4/d/14/B/vi","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FB%2Fvi%2FII","sourceRelease":"119-100","text":"look backs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t15/s78c–4/d/14/B/vi/III","parentIdentifier":"/us/usc/t15/s78c–4/d/14/B/vi","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FB%2Fvi%2FIII","sourceRelease":"119-100","text":"internal or external audit findings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t15/s78c–4/d/14/B/vi/IV","parentIdentifier":"/us/usc/t15/s78c–4/d/14/B/vi","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FB%2Fvi%2FIV","sourceRelease":"119-100","text":"self-reported errors; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t15/s78c–4/d/14/B/vi/V","parentIdentifier":"/us/usc/t15/s78c–4/d/14/B/vi","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FB%2Fvi%2FV","sourceRelease":"119-100","text":"through validated complaints; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t15/s78c–4/d/14/B/vii","parentIdentifier":"/us/usc/t15/s78c–4/d/14/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FB%2Fvii","sourceRelease":"119-100","text":"establish and follow appropriate procedures for the handling, management response, remediation, retesting, and closing of noncompliance issues.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Annual reports","label":"C Annual reports","identifier":"/us/usc/t15/s78c–4/d/14/C","parentIdentifier":"/us/usc/t15/s78c–4/d/14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t15/s78c–4/d/14/C/i","parentIdentifier":"/us/usc/t15/s78c–4/d/14/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FC%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s78c–4/d/14/C/i/I","parentIdentifier":"/us/usc/t15/s78c–4/d/14/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FC%2Fi%2FI","sourceRelease":"119-100","text":"the compliance of the security-based swap execution facility with this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t15/s78c–4/d/14/C/i/II","parentIdentifier":"/us/usc/t15/s78c–4/d/14/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FC%2Fi%2FII","sourceRelease":"119-100","text":"the policies and procedures, including the code of ethics and conflict of interest policies, of the security-based security-based swap execution facility.2So in original.2","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Requirements","label":"ii Requirements","identifier":"/us/usc/t15/s78c–4/d/14/C/ii","parentIdentifier":"/us/usc/t15/s78c–4/d/14/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FC%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s78c–4/d/14/C/ii/I","parentIdentifier":"/us/usc/t15/s78c–4/d/14/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FC%2Fii%2FI","sourceRelease":"119-100","text":"submit each report described in clause (i) with the appropriate financial report of the security-based swap execution facility that is required to be submitted to the Commission pursuant to this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t15/s78c–4/d/14/C/ii/II","parentIdentifier":"/us/usc/t15/s78c–4/d/14/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fd%2F14%2FC%2Fii%2FII","sourceRelease":"119-100","text":"include in the report a certification that, under penalty of law, the report is accurate and complete.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Exemptions","label":"e Exemptions","identifier":"/us/usc/t15/s78c–4/e","parentIdentifier":"/us/usc/t15/s78c–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Fe","sourceRelease":"119-100","text":"The Commission may exempt, conditionally or unconditionally, a security-based swap execution facility from registration under this section if the Commission finds that the facility is subject to comparable, comprehensive supervision and regulation on a consolidated basis by the Commodity Futures Trading Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Rules","label":"f Rules","identifier":"/us/usc/t15/s78c–4/f","parentIdentifier":"/us/usc/t15/s78c–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78c%E2%80%934%2Ff","sourceRelease":"119-100","text":"The Commission shall prescribe rules governing the regulation of security-based swap execution facilities under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
