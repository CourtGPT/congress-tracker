{"type":"section","nativeType":"section","number":"16494","heading":"Oxygen-fuel","label":"16494 Oxygen-fuel","identifier":"/us/usc/t42/s16494","parentIdentifier":"/us/usc/t42/ch149/schXIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16494","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Program","label":"a Program","identifier":"/us/usc/t42/s16494/a","parentIdentifier":"/us/usc/t42/s16494","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16494%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish a program on oxygen-fuel systems. If feasible, the program shall include renovation of at least one existing large unit and one existing small unit, and construction of one new large unit and one new small unit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Authorization of appropriations","label":"b Authorization of appropriations","identifier":"/us/usc/t42/s16494/b","parentIdentifier":"/us/usc/t42/s16494","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16494%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16494/b/1","parentIdentifier":"/us/usc/t42/s16494/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16494%2Fb%2F1","sourceRelease":"119-100","text":"$100,000,000 for fiscal year 2006;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16494/b/2","parentIdentifier":"/us/usc/t42/s16494/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16494%2Fb%2F2","sourceRelease":"119-100","text":"$100,000,000 for fiscal year 2007; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16494/b/3","parentIdentifier":"/us/usc/t42/s16494/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16494%2Fb%2F3","sourceRelease":"119-100","text":"$100,000,000 for fiscal year 2008.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Definitions","label":"c Definitions","identifier":"/us/usc/t42/s16494/c","parentIdentifier":"/us/usc/t42/s16494","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16494%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16494/c/1","parentIdentifier":"/us/usc/t42/s16494/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16494%2Fc%2F1","sourceRelease":"119-100","text":"the term “large unit” means a unit with a generating capacity of 100 megawatts or more;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16494/c/2","parentIdentifier":"/us/usc/t42/s16494/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16494%2Fc%2F2","sourceRelease":"119-100","text":"the term “oxygen-fuel systems” means systems that utilize fuel efficiency benefits of oil, gas, coal, and biomass combustion using substantially pure oxygen, with high flame temperatures and the exclusion of air from the boiler, in industrial or electric utility steam generating units; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16494/c/3","parentIdentifier":"/us/usc/t42/s16494/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16494%2Fc%2F3","sourceRelease":"119-100","text":"the term “small unit” means a unit with a generating capacity in the 10–50 megawatt range.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
