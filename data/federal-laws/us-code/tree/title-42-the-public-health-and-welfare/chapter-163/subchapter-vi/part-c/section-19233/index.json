{"type":"section","nativeType":"section","number":"19233","heading":"Review of contracts and agreements","label":"19233 Review of contracts and agreements","identifier":"/us/usc/t42/s19233","parentIdentifier":"/us/usc/t42/ch163/schVI/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19233","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s19233/a","parentIdentifier":"/us/usc/t42/s19233","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19233%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19233/a/1","parentIdentifier":"/us/usc/t42/s19233/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19233%2Fa%2F1","sourceRelease":"119-100","text":"require, upon request, the submission to such agency, by an institution of higher education or other organization applying for a research and development award, of supporting documentation, including copies of contracts, grants, or any other agreement specific to foreign appointments, employment with a foreign institution, participation in a foreign talent recruitment program and other information reported as current and pending support for all covered individuals in a research and development award application;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19233/a/2","parentIdentifier":"/us/usc/t42/s19233/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19233%2Fa%2F2","sourceRelease":"119-100","text":"require such institution of higher education or other organization to review any documents requested under paragraph (1) for compliance with the Federal research agency’s award terms and conditions, including guidance on conflicts of interest and conflicts of commitment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19233/a/3","parentIdentifier":"/us/usc/t42/s19233/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19233%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19233/a/3/A","parentIdentifier":"/us/usc/t42/s19233/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19233%2Fa%2F3%2FA","sourceRelease":"119-100","text":"interfere with the capacity for agency-supported activities to be carried out; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19233/a/3/B","parentIdentifier":"/us/usc/t42/s19233/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19233%2Fa%2F3%2FB","sourceRelease":"119-100","text":"create duplication with agency-supported activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitations","label":"b Limitations","identifier":"/us/usc/t42/s19233/b","parentIdentifier":"/us/usc/t42/s19233","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19233%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19233/b/1","parentIdentifier":"/us/usc/t42/s19233/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19233%2Fb%2F1","sourceRelease":"119-100","text":"take necessary steps, as practicable, to protect the privacy of all covered individuals and other parties specified in the documentation submitted under paragraph (1) of such subsection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19233/b/2","parentIdentifier":"/us/usc/t42/s19233/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19233%2Fb%2F2","sourceRelease":"119-100","text":"endeavor to provide justification for requests for supporting documentation made under such paragraph;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19233/b/3","parentIdentifier":"/us/usc/t42/s19233/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19233%2Fb%2F3","sourceRelease":"119-100","text":"require that allegations be proven by a preponderance of evidence; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s19233/b/4","parentIdentifier":"/us/usc/t42/s19233/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19233%2Fb%2F4","sourceRelease":"119-100","text":"as practicable, afford subjects an opportunity to provide comments and rebuttal and an opportunity to appeal before final administrative action is taken.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
