{"type":"section","nativeType":"section","number":"13506","heading":"Definitions","label":"13506 Definitions","identifier":"/us/usc/t42/s13506","parentIdentifier":"/us/usc/t42/ch134/schX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13506","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13506/1","parentIdentifier":"/us/usc/t42/s13506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13506%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13506/1/A","parentIdentifier":"/us/usc/t42/s13506/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13506%2F1%2FA","sourceRelease":"119-100","text":"improving the productivity, quality, or energy efficiency of the design, development, testing, or manufacture of a product; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13506/1/B","parentIdentifier":"/us/usc/t42/s13506/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13506%2F1%2FB","sourceRelease":"119-100","text":"expanding the technical capability to design, develop, test, or manufacture a product that is fundamentally different in character from existing products and that will result in improved energy efficiency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13506/2","parentIdentifier":"/us/usc/t42/s13506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13506%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13506/2/A","parentIdentifier":"/us/usc/t42/s13506/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13506%2F2%2FA","sourceRelease":"119-100","text":"advanced monolithic materials such as metals, ceramics, and polymers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13506/2/B","parentIdentifier":"/us/usc/t42/s13506/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13506%2F2%2FB","sourceRelease":"119-100","text":"advanced composite materials such as metal matrix (including intermetallics), polymer matrix, ceramic matrix, continuous fiber ceramic composite, and carbon matrix composites; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s13506/2/C","parentIdentifier":"/us/usc/t42/s13506/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13506%2F2%2FC","sourceRelease":"119-100","text":"advanced electronic, magnetic, and photonic materials, including superconducting, semiconductor, electrooptic, magnetooptic, thin-film, and special purpose coating materials used in technologies for energy efficiency, renewable energy, or electric power applications; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13506/3","parentIdentifier":"/us/usc/t42/s13506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13506%2F3","sourceRelease":"119-100","text":"the term “United States” means the 50 States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, the Northern Mariana Islands, and any other territory or possession of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
