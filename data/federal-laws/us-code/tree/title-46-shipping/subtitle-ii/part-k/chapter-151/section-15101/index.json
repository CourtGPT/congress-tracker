{"type":"section","nativeType":"section","number":"15101","heading":"National Chemical Transportation Safety Advisory Committee","label":"15101 National Chemical Transportation Safety Advisory Committee","identifier":"/us/usc/t46/s15101","parentIdentifier":"/us/usc/t46/stII/ptK/ch151","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15101","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t46/s15101/a","parentIdentifier":"/us/usc/t46/s15101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15101%2Fa","sourceRelease":"119-100","text":"There is established a National Chemical Transportation Safety Advisory Committee (in this section referred to as the “Committee”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Function","label":"b .—Function","identifier":"/us/usc/t46/s15101/b","parentIdentifier":"/us/usc/t46/s15101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15101%2Fb","sourceRelease":"119-100","text":"The Committee shall advise the Secretary on matters relating to the safe and secure marine transportation of hazardous materials.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Membership.—","label":"c Membership.—","identifier":"/us/usc/t46/s15101/c","parentIdentifier":"/us/usc/t46/s15101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15101%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t46/s15101/c/1","parentIdentifier":"/us/usc/t46/s15101/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15101%2Fc%2F1","sourceRelease":"119-100","text":"The Committee shall consist of not more than 25 members appointed by the Secretary in accordance with this section and section 15109 of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Expertise","label":"2 .—Expertise","identifier":"/us/usc/t46/s15101/c/2","parentIdentifier":"/us/usc/t46/s15101/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15101%2Fc%2F2","sourceRelease":"119-100","text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Representation","label":"3 .—Representation","identifier":"/us/usc/t46/s15101/c/3","parentIdentifier":"/us/usc/t46/s15101/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15101%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s15101/c/3/A","parentIdentifier":"/us/usc/t46/s15101/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15101%2Fc%2F3%2FA","sourceRelease":"119-100","text":"Chemical manufacturing entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s15101/c/3/B","parentIdentifier":"/us/usc/t46/s15101/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15101%2Fc%2F3%2FB","sourceRelease":"119-100","text":"Entities related to marine handling or transportation of chemicals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t46/s15101/c/3/C","parentIdentifier":"/us/usc/t46/s15101/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15101%2Fc%2F3%2FC","sourceRelease":"119-100","text":"Vessel design and construction entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t46/s15101/c/3/D","parentIdentifier":"/us/usc/t46/s15101/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15101%2Fc%2F3%2FD","sourceRelease":"119-100","text":"Marine safety or security entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t46/s15101/c/3/E","parentIdentifier":"/us/usc/t46/s15101/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15101%2Fc%2F3%2FE","sourceRelease":"119-100","text":"Marine environmental protection entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Distribution","label":"4 .—Distribution","identifier":"/us/usc/t46/s15101/c/4","parentIdentifier":"/us/usc/t46/s15101/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15101%2Fc%2F4","sourceRelease":"119-100","text":"The Secretary shall, based on the needs of the Coast Guard, determine the number of members of the Committee who represent each entity specified in paragraph (3). Neither this paragraph nor any other provision of law shall be construed to require an equal distribution of members representing each entity specified in paragraph (3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
