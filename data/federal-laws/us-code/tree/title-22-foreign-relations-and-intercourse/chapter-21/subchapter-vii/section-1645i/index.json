{"type":"section","nativeType":"section","number":"1645i","heading":"Award payment procedures","label":"1645i Award payment procedures","identifier":"/us/usc/t22/s1645i","parentIdentifier":"/us/usc/t22/ch21/schVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645i","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Certification of amounts","label":"a Certification of amounts","identifier":"/us/usc/t22/s1645i/a","parentIdentifier":"/us/usc/t22/s1645i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645i%2Fa","sourceRelease":"119-100","text":"The Commission shall certify to the Secretary of the Treasury, in terms of United States currency, each award made pursuant to .section 1645b of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Priority of payments","label":"b Priority of payments","identifier":"/us/usc/t22/s1645i/b","parentIdentifier":"/us/usc/t22/s1645i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645i%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s1645i/b/1","parentIdentifier":"/us/usc/t22/s1645i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645i%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s1645i/b/1/A","parentIdentifier":"/us/usc/t22/s1645i/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645i%2Fb%2F1%2FA","sourceRelease":"119-100","text":"Payment in the amount of $2,500 or the principal amount of the award, whichever is less.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s1645i/b/1/B","parentIdentifier":"/us/usc/t22/s1645i/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645i%2Fb%2F1%2FB","sourceRelease":"119-100","text":"Thereafter, payments from time to time, in ratable proportions, on account of the unpaid balance of the principal amounts of all awards according to the proportions which the unpaid balance of such awards bear to the total amount in the Claims Fund available for distribution at the time such payments are made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s1645i/b/2","parentIdentifier":"/us/usc/t22/s1645i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645i%2Fb%2F2","sourceRelease":"119-100","text":"After payment has been made in full of the principal amounts of all awards pursuant to paragraph (1), pro rata payments may be made on account of any interest that may be allowed on such awards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Regulations","label":"c Regulations","identifier":"/us/usc/t22/s1645i/c","parentIdentifier":"/us/usc/t22/s1645i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645i%2Fc","sourceRelease":"119-100","text":"Payments or applications for payments under subsection (b) shall be made in accordance with such regulations as the Secretary of the Treasury may prescribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
