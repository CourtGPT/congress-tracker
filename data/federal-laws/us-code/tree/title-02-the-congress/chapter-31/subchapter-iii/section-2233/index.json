{"type":"section","nativeType":"section","number":"2233","heading":"Use of monies","label":"2233 Use of monies","identifier":"/us/usc/t2/s2233","parentIdentifier":"/us/usc/t2/ch31/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2233","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Gift Shop Account","label":"a Gift Shop Account","identifier":"/us/usc/t2/s2233/a","parentIdentifier":"/us/usc/t2/s2233","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2233%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t2/s2233/a/1","parentIdentifier":"/us/usc/t2/s2233/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2233%2Fa%2F1","sourceRelease":"119-100","text":"All monies in the Gift Shop Account shall be available without fiscal year limitation for disbursement by the Architect of the Capitol, upon recommendation of the Chief Executive Officer, in connection with the operation of the gift shop under , including supplies, inventories, equipment, and other expenses. In addition, such monies may be used by the Architect of the Capitol, upon recommendation of the Chief Executive Officer, to reimburse any applicable appropriations account for amounts used from such appropriations account to pay the salaries of employees of the gift shops.section 2215 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Use of remaining funds","label":"2 Use of remaining funds","identifier":"/us/usc/t2/s2233/a/2","parentIdentifier":"/us/usc/t2/s2233/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2233%2Fa%