{"type":"section","nativeType":"section","number":"2935","heading":"Budget coordination","label":"2935 Budget coordination","identifier":"/us/usc/t15/s2935","parentIdentifier":"/us/usc/t15/ch56A/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2935","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Committee guidance","label":"a Committee guidance","identifier":"/us/usc/t15/s2935/a","parentIdentifier":"/us/usc/t15/s2935","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2935%2Fa","sourceRelease":"119-100","text":"The Committee shall each year provide general guidance to each Federal agency or department participating in the Program with respect to the preparation of requests for appropriations for activities related to the Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Submission of reports with agency appropriations requests","label":"b Submission of reports with agency appropriations requests","identifier":"/us/usc/t15/s2935/b","parentIdentifier":"/us/usc/t15/s2935","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2935%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2935/b/1","parentIdentifier":"/us/usc/t15/s2935/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2935%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s2935/b/1/A","parentIdentifier":"/us/usc/t15/s2935/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2935%2Fb%2F1%2FA","sourceRelease":"119-100","text":"identifies each element of the proposed global change research activities of the agency or department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s2935/b/1/B","parentIdentifier":"/us/usc/t15/s2935/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2935%2Fb%2F1%2FB","sourceRelease":"119-100","text":"specifies whether each element (i) contributes directly to the Program or (ii) contributes indirectly but in important ways to the Program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s2935/b/1/C","parentIdentifier":"/us/usc/t15/s2935/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2935%2Fb%2F1%2FC","sourceRelease":"119-100","text":"states the portion of its request for appropriations allocated to each element of the Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2935/b/2","parentIdentifier":"/us/usc/t15/s2935/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2935%2Fb%2F2","sourceRelease":"119-100","text":"Each agency or department that submits a report under paragraph (1) shall submit such report simultaneously to the Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Consideration in President’s budget","label":"c Consideration in President’s budget","identifier":"/us/usc/t15/s2935/c","parentIdentifier":"/us/usc/t15/s2935","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2935%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2935/c/1","parentIdentifier":"/us/usc/t15/s2935/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2935%2Fc%2F1","sourceRelease":"119-100","text":"The President shall, in a timely fashion, provide the Committee with an opportunity to review and comment on the budget estimate of each agency and department involved in global change research in the context of the Plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2935/c/2","parentIdentifier":"/us/usc/t15/s2935/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2935%2Fc%2F2","sourceRelease":"119-100","text":"The President shall identify in each annual budget submitted to the Congress under those items in each agency’s or department’s annual budget which are elements of the Program.section 1105 of title 31","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
