clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8203/a/2/H/ii","parentIdentifier":"/us/usc/t16/s8203/a/2/H","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FH%2Fii","sourceRelease":"119-100","text":"the Marine Fisheries Commissions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s8203/a/2/I","parentIdentifier":"/us/usc/t16/s8203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FI","sourceRelease":"119-100","text":"1 shall be a representative of the Sport Fishing and Boating Partnership Council;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t16/s8203/a/2/J","parentIdentifier":"/us/usc/t16/s8203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FJ","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8203/a/2/J/i","parentIdentifier":"/us/usc/t16/s8203/a/2/J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FJ%2Fi","sourceRelease":"119-100","text":"the recreational sportfishing industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8203/a/2/J/ii","parentIdentifier":"/us/usc/t16/s8203/a/2/J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FJ%2Fii","sourceRelease":"119-100","text":"the commercial fishing industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type"