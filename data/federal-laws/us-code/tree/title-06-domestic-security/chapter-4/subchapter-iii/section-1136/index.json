{"type":"section","nativeType":"section","number":"1136","heading":"Security exercises","label":"1136 Security exercises","identifier":"/us/usc/t6/s1136","parentIdentifier":"/us/usc/t6/ch4/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t6/s1136/a","parentIdentifier":"/us/usc/t6/s1136","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish a program for conducting security exercises for public transportation agencies for the purpose of assessing and improving the capabilities of entities described in subsection (b) to prevent, prepare for, mitigate against, respond to, and recover from acts of terrorism.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Covered entities","label":"b Covered entities","identifier":"/us/usc/t6/s1136/b","parentIdentifier":"/us/usc/t6/s1136","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s1136/b/1","parentIdentifier":"/us/usc/t6/s1136/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fb%2F1","sourceRelease":"119-100","text":"Federal, State, and local agencies and tribal governments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s1136/b/2","parentIdentifier":"/us/usc/t6/s1136/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fb%2F2","sourceRelease":"119-100","text":"public transportation agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s1136/b/3","parentIdentifier":"/us/usc/t6/s1136/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fb%2F3","sourceRelease":"119-100","text":"governmental and nongovernmental emergency response providers and law enforcement personnel, including transit police; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s1136/b/4","parentIdentifier":"/us/usc/t6/s1136/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fb%2F4","sourceRelease":"119-100","text":"any other organization or entity that the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Requirements","label":"c Requirements","identifier":"/us/usc/t6/s1136/c","parentIdentifier":"/us/usc/t6/s1136","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s1136/c/1","parentIdentifier":"/us/usc/t6/s1136/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s1136/c/1/A","parentIdentifier":"/us/usc/t6/s1136/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc%2F1%2FA","sourceRelease":"119-100","text":"scaled and tailored to the needs of specific public transportation systems, and include taking into account the needs of the elderly and individuals with disabilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s1136/c/1/B","parentIdentifier":"/us/usc/t6/s1136/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc%2F1%2FB","sourceRelease":"119-100","text":"live;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s1136/c/1/C","parentIdentifier":"/us/usc/t6/s1136/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc%2F1%2FC","sourceRelease":"119-100","text":"coordinated with appropriate officials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s1136/c/1/D","parentIdentifier":"/us/usc/t6/s1136/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc%2F1%2FD","sourceRelease":"119-100","text":"as realistic as practicable and based on current risk assessments, including credible threats, vulnerabilities, and consequences;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t6/s1136/c/1/E","parentIdentifier":"/us/usc/t6/s1136/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc%2F1%2FE","sourceRelease":"119-100","text":"inclusive, as appropriate, of frontline employees and managers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t6/s1136/c/1/F","parentIdentifier":"/us/usc/t6/s1136/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc%2F1%2FF","sourceRelease":"119-100","text":"consistent with the National Incident Management System, the National Response Plan, the National Infrastructure Protection Plan, the National Preparedness Guidance, the National Preparedness Goal, and other such national initiatives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s1136/c/2","parentIdentifier":"/us/usc/t6/s1136/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s1136/c/2/A","parentIdentifier":"/us/usc/t6/s1136/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc%2F2%2FA","sourceRelease":"119-100","text":"evaluated by the Secretary against clear and consistent performance measures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s1136/c/2/B","parentIdentifier":"/us/usc/t6/s1136/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc%2F2%2FB","sourceRelease":"119-100","text":"assessed by the Secretary to learn best practices, which shall be shared with appropriate Federal, State, local, and tribal officials, governmental and nongovernmental emergency response providers, law enforcement personnel, including railroad and transit police, and appropriate stakeholders; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s1136/c/2/C","parentIdentifier":"/us/usc/t6/s1136/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc%2F2%2FC","sourceRelease":"119-100","text":"followed by remedial action by covered entities in response to lessons learned;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s1136/c/3","parentIdentifier":"/us/usc/t6/s1136/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc%2F3","sourceRelease":"119-100","text":"involves individuals in neighborhoods around the infrastructure of a public transportation system; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s1136/c/4","parentIdentifier":"/us/usc/t6/s1136/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fc%2F4","sourceRelease":"119-100","text":"assists State, local, and tribal governments and public transportation agencies in designing, implementing, and evaluating exercises that conform to the requirements of paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"National Exercise Program","label":"d National Exercise Program","identifier":"/us/usc/t6/s1136/d","parentIdentifier":"/us/usc/t6/s1136","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fd","sourceRelease":"119-100","text":"The Secretary shall ensure that the exercise program developed under subsection (a) is a component of the National Exercise Program established under .section 748 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Ferry system exemption","label":"e Ferry system exemption","identifier":"/us/usc/t6/s1136/e","parentIdentifier":"/us/usc/t6/s1136","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1136%2Fe","sourceRelease":"119-100","text":"This section does not apply to any ferry system for which drills are required to be conducted pursuant to .section 70103 of title 46","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
