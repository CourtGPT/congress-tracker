{"type":"section","nativeType":"section","number":"32701","heading":"Findings and purposes","label":"32701 Findings and purposes","identifier":"/us/usc/t49/s32701","parentIdentifier":"/us/usc/t49/stVI/ptC/ch327","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32701","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevisedSectionSource (U.S. Code)Source (Statutes at Large)32701(a)15:1981 (1st sentence)., , .Oct. 20, 1972Pub. L. 92–513, § 40186 Stat. 96132701(b)15:1981 (last sentence)."],"amendments":["Historical and Revision NotesRevisedSectionSource (U.S. Code)Source (Statutes at Large)32701(a)15:1981 (1st sentence)., , .Oct. 20, 1972Pub. L. 92–513, § 40186 Stat. 96132701(b)15:1981 (last sentence)."],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Findings","label":"a .—Findings","identifier":"/us/usc/t49/s32701/a","parentIdentifier":"/us/usc/t49/s32701","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32701%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s32701/a/1","parentIdentifier":"/us/usc/t49/s32701/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32701%2Fa%2F1","sourceRelease":"119-100","text":"buyers of motor vehicles rely heavily on the odometer reading as an index of the condition and value of a vehicle;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s32701/a/2","parentIdentifier":"/us/usc/t49/s32701/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32701%2Fa%2F2","sourceRelease":"119-100","text":"buyers are entitled to rely on the odometer reading as an accurate indication of the mileage of the vehicle;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s32701/a/3","parentIdentifier":"/us/usc/t49/s32701/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32701%2Fa%2F3","sourceRelease":"119-100","text":"an accurate indication of the mileage assists a buyer in deciding on the safety and reliability of the vehicle; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s32701/a/4","parentIdentifier":"/us/usc/t49/s32701/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32701%2Fa%2F4","sourceRelease":"119-100","text":"motor vehicles move in, or affect, interstate and foreign commerce.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Purposes","label":"b .—Purposes","identifier":"/us/usc/t49/s32701/b","parentIdentifier":"/us/usc/t49/s32701","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32701%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s32701/b/1","parentIdentifier":"/us/usc/t49/s32701/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32701%2Fb%2F1","sourceRelease":"119-100","text":"to prohibit tampering with motor vehicle odometers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s32701/b/2","parentIdentifier":"/us/usc/t49/s32701/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32701%2Fb%2F2","sourceRelease":"119-100","text":"to provide safeguards to protect purchasers in the sale of motor vehicles with altered or reset odometers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
