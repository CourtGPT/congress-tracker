{"type":"section","nativeType":"section","number":"7106","heading":"Petition and review","label":"7106 Petition and review","identifier":"/us/usc/t7/s7106","parentIdentifier":"/us/usc/t7/ch99","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7106","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Petition","label":"a Petition","identifier":"/us/usc/t7/s7106/a","parentIdentifier":"/us/usc/t7/s7106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7106%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s7106/a/1","parentIdentifier":"/us/usc/t7/s7106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7106%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7106/a/1/A","parentIdentifier":"/us/usc/t7/s7106/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7106%2Fa%2F1%2FA","sourceRelease":"119-100","text":"stating that the order, any provision of the order, or any obligation imposed in connection with the order is not established in accordance with law; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7106/a/1/B","parentIdentifier":"/us/usc/t7/s7106/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7106%2Fa%2F1%2FB","sourceRelease":"119-100","text":"requesting a modification of the order or an exemption from the order.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Hearings","label":"2 Hearings","identifier":"/us/usc/t7/s7106/a/2","parentIdentifier":"/us/usc/t7/s7106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7106%2Fa%2F2","sourceRelease":"119-100","text":"The petitioner shall be given an opportunity for a hearing on the petition, in accordance with regulations issued by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Ruling","label":"3 Ruling","identifier":"/us/usc/t7/s7106/a/3","parentIdentifier":"/us/usc/t7/s7106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7106%2Fa%2F3","sourceRelease":"119-100","text":"After the hearing, the Secretary shall make a ruling on the petition. The ruling shall be final if the ruling is in accordance with law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Review","label":"b Review","identifier":"/us/usc/t7/s7106/b","parentIdentifier":"/us/usc/t7/s7106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7106%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Commencement of action","label":"1 Commencement of action","identifier":"/us/usc/t7/s7106/b/1","parentIdentifier":"/us/usc/t7/s7106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7106%2Fb%2F1","sourceRelease":"119-100","text":"The district court of the United States for any district in which a person who is a petitioner under subsection (a) resides or carries on business shall have jurisdiction to review the ruling on the petition of the person, if a complaint for that purpose is filed not later than 20 days after the date of the entry of the ruling by the Secretary under subsection (a)(3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Process","label":"2 Process","identifier":"/us/usc/t7/s7106/b/2","parentIdentifier":"/us/usc/t7/s7106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7106%2Fb%2F2","sourceRelease":"119-100","text":"Service of process in a proceeding may be conducted on the Secretary by delivering a copy of the complaint to the Secretary, under such rules or regulations as are considered necessary by the Secretary to facilitate the service of process.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Remands","label":"3 Remands","identifier":"/us/usc/t7/s7106/b/3","parentIdentifier":"/us/usc/t7/s7106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7106%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7106/b/3/A","parentIdentifier":"/us/usc/t7/s7106/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7106%2Fb%2F3%2FA","sourceRelease":"119-100","text":"to make such ruling as the court shall determine to be in accordance with law; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7106/b/3/B","parentIdentifier":"/us/usc/t7/s7106/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7106%2Fb%2F3%2FB","sourceRelease":"119-100","text":"to take such further action as, in the opinion of the court, the law requires.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
