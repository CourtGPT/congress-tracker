{"type":"section","nativeType":"section","number":"3509","heading":"Medical standards","label":"3509 Medical standards","identifier":"/us/usc/t46/s3509","parentIdentifier":"/us/usc/t46/stII/ptB/ch35","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3509","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Exemptions for Certain Passenger VesselsFor provisions exempting certain passenger vessels from the requirements authorized under this section, see , set out as a note under .section 11510 of Pub. L. 117–263section 3508 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s3509/1","parentIdentifier":"/us/usc/t46/s3509","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3509%2F1","sourceRelease":"119-100","text":"a physician is always present and available to treat any passengers who may be on board the vessel in the event of an emergency situation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s3509/2","parentIdentifier":"/us/usc/t46/s3509","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3509%2F2","sourceRelease":"119-100","text":"the vessel is in compliance with the Health Care Guidelines for Cruise Ship Medical Facilities established by the American College of Emergency Physicians; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s3509/3","parentIdentifier":"/us/usc/t46/s3509","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3509%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph"