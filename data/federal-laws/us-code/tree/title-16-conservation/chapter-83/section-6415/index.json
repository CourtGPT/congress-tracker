{"type":"section","nativeType":"section","number":"6415","heading":"Definitions","label":"6415 Definitions","identifier":"/us/usc/t16/s6415","parentIdentifier":"/us/usc/t16/ch83","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Administrator","label":"1 Administrator","identifier":"/us/usc/t16/s6415/1","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F1","sourceRelease":"119-100","text":"The term “Administrator” means the Administrator of the National Oceanic and Atmospheric Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Alaska Native Corporation","label":"2 Alaska Native Corporation","identifier":"/us/usc/t16/s6415/2","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F2","sourceRelease":"119-100","text":"The term “Alaska Native Corporation” has the meaning given the term “Native Corporation” in .section 1602 of title 43","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Appropriate congressional committees","label":"3 Appropriate congressional committees","identifier":"/us/usc/t16/s6415/3","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F3","sourceRelease":"119-100","text":"The term “appropriate congressional committees” means the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Natural Resources of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Conservation","label":"4 Conservation","identifier":"/us/usc/t16/s6415/4","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6415/4/A","parentIdentifier":"/us/usc/t16/s6415/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F4%2FA","sourceRelease":"119-100","text":"all activities associated with resource management, such as monitoring, assessment, protection, restoration, sustainable use, management of habitat, and maintenance or augmentation of genetic diversity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6415/4/B","parentIdentifier":"/us/usc/t16/s6415/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F4%2FB","sourceRelease":"119-100","text":"mapping;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6415/4/C","parentIdentifier":"/us/usc/t16/s6415/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F4%2FC","sourceRelease":"119-100","text":"scientific expertise and technical assistance in the development and implementation of management strategies for marine protected areas and marine resources required by Federal law;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s6415/4/D","parentIdentifier":"/us/usc/t16/s6415/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F4%2FD","sourceRelease":"119-100","text":"law enforcement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s6415/4/E","parentIdentifier":"/us/usc/t16/s6415/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F4%2FE","sourceRelease":"119-100","text":"conflict resolution initiatives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t16/s6415/4/F","parentIdentifier":"/us/usc/t16/s6415/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F4%2FF","sourceRelease":"119-100","text":"community outreach and education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t16/s6415/4/G","parentIdentifier":"/us/usc/t16/s6415/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F4%2FG","sourceRelease":"119-100","text":"promotion of safe and ecologically sound navigation and anchoring.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Coral","label":"5 Coral","identifier":"/us/usc/t16/s6415/5","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6415/5/A","parentIdentifier":"/us/usc/t16/s6415/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F5%2FA","sourceRelease":"119-100","text":"all species of the orders Antipatharia (black corals), Scleractinia (stony corals), Alcyonacea (soft corals, organ pipe corals, gorgonians), and Helioporacea (blue coral), of the class Anthozoa; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6415/5/B","parentIdentifier":"/us/usc/t16/s6415/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F5%2FB","sourceRelease":"119-100","text":"all species of the order Anthoathecata (fire corals and other hydrocorals) of the class Hydrozoa.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Coral products","label":"6 Coral products","identifier":"/us/usc/t16/s6415/6","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F6","sourceRelease":"119-100","text":"The term “coral products” means any living or dead specimens, parts, or derivatives, or any product containing specimens, parts, or derivatives, of any species of coral.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Coral reef","label":"7 Coral reef","identifier":"/us/usc/t16/s6415/7","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F7","sourceRelease":"119-100","text":"The term “coral reef” means calcium carbonate structures in the form of a reef or shoal, composed in whole or in part by living coral, skeletal remains of coral, crustose coralline algae, and other associated sessile marine plants and animals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Coral reef ecosystem","label":"8 Coral reef ecosystem","identifier":"/us/usc/t16/s6415/8","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6415/8/A","parentIdentifier":"/us/usc/t16/s6415/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F8%2FA","sourceRelease":"119-100","text":"corals and other geographically and ecologically associated marine communities of other reef organisms (including reef plants and animals) associated with coral reef habitat; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6415/8/B","parentIdentifier":"/us/usc/t16/s6415/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F8%2FB","sourceRelease":"119-100","text":"the biotic and abiotic factors and processes that control or significantly affect coral calcification rates, tissue growth, reproduction, recruitment, abundance, coral-algal symbiosis, and biodiversity in such habitat.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":"Coral reef ecosystem services","label":"9 Coral reef ecosystem services","identifier":"/us/usc/t16/s6415/9","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F9","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6415/9/A","parentIdentifier":"/us/usc/t16/s6415/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F9%2FA","sourceRelease":"119-100","text":"protection of coastal beaches, structures, and infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6415/9/B","parentIdentifier":"/us/usc/t16/s6415/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F9%2FB","sourceRelease":"119-100","text":"habitat for organisms of economic, ecological, biomedical, medicinal, and cultural value;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6415/9/C","parentIdentifier":"/us/usc/t16/s6415/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F9%2FC","sourceRelease":"119-100","text":"serving as centers for the promulgation, performance, and training of cultural practices representative of traditional ecological knowledge; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s6415/9/D","parentIdentifier":"/us/usc/t16/s6415/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F9%2FD","sourceRelease":"119-100","text":"aesthetic value.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":"Covered Native entity","label":"10 Covered Native entity","identifier":"/us/usc/t16/s6415/10","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F10","sourceRelease":"119-100","text":"The term “covered Native entity” means a Native entity with interests in a coral reef ecosystem.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":"Covered reef manager","label":"11 Covered reef manager","identifier":"/us/usc/t16/s6415/11","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F11","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6415/11/A","parentIdentifier":"/us/usc/t16/s6415/11","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F11%2FA","sourceRelease":"119-100","text":"a management unit of a covered State with jurisdiction over a coral reef ecosystem;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6415/11/B","parentIdentifier":"/us/usc/t16/s6415/11","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F11%2FB","sourceRelease":"119-100","text":"a covered State; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6415/11/C","parentIdentifier":"/us/usc/t16/s6415/11","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F11%2FC","sourceRelease":"119-100","text":"a coral reef stewardship partnership under .section 6405 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":"Covered State","label":"12 Covered State","identifier":"/us/usc/t16/s6415/12","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F12","sourceRelease":"119-100","text":"The term “covered State” means Florida, Hawaii, and the territories of American Samoa, the Commonwealth of the Northern Mariana Islands, Guam, Puerto Rico, and the United States Virgin Islands.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"13","heading":"Federal reef manager","label":"13 Federal reef manager","identifier":"/us/usc/t16/s6415/13","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F13","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s6415/13/A","parentIdentifier":"/us/usc/t16/s6415/13","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F13%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s6415/13/A/i","parentIdentifier":"/us/usc/t16/s6415/13/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F13%2FA%2Fi","sourceRelease":"119-100","text":"a management unit of a Federal agency specified in subparagraph (B) with lead management jurisdiction over a coral reef ecosystem; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s6415/13/A/ii","parentIdentifier":"/us/usc/t16/s6415/13/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F13%2FA%2Fii","sourceRelease":"119-100","text":"a coral reef stewardship partnership under .section 6405(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Federal agencies specified","label":"B Federal agencies specified","identifier":"/us/usc/t16/s6415/13/B","parentIdentifier":"/us/usc/t16/s6415/13","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F13%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s6415/13/B/i","parentIdentifier":"/us/usc/t16/s6415/13/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F13%2FB%2Fi","sourceRelease":"119-100","text":"The National Oceanic and Atmospheric Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s6415/13/B/ii","parentIdentifier":"/us/usc/t16/s6415/13/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F13%2FB%2Fii","sourceRelease":"119-100","text":"The National Park Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s6415/13/B/iii","parentIdentifier":"/us/usc/t16/s6415/13/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F13%2FB%2Fiii","sourceRelease":"119-100","text":"The United States Fish and Wildlife Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s6415/13/B/iv","parentIdentifier":"/us/usc/t16/s6415/13/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F13%2FB%2Fiv","sourceRelease":"119-100","text":"The Office of Insular Affairs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"14","heading":"Institution of higher education","label":"14 Institution of higher education","identifier":"/us/usc/t16/s6415/14","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F14","sourceRelease":"119-100","text":"The term “institution of higher education” has the meaning given that term in .section 1001 of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"15","heading":"Interested stakeholder groups","label":"15 Interested stakeholder groups","identifier":"/us/usc/t16/s6415/15","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F15","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6415/15/A","parentIdentifier":"/us/usc/t16/s6415/15","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F15%2FA","sourceRelease":"119-100","text":"A business.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6415/15/B","parentIdentifier":"/us/usc/t16/s6415/15","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F15%2FB","sourceRelease":"119-100","text":"A commercial or recreational fisherman.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6415/15/C","parentIdentifier":"/us/usc/t16/s6415/15","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F15%2FC","sourceRelease":"119-100","text":"A recreationalist.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s6415/15/D","parentIdentifier":"/us/usc/t16/s6415/15","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F15%2FD","sourceRelease":"119-100","text":"A Federal, State, Tribal, or local government unit with related jurisdiction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s6415/15/E","parentIdentifier":"/us/usc/t16/s6415/15","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F15%2FE","sourceRelease":"119-100","text":"An institution of higher education (as such term is defined in .section 1001(a) of title 201So in original. A closing parenthesis probably should precede the period.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t16/s6415/15/F","parentIdentifier":"/us/usc/t16/s6415/15","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F15%2FF","sourceRelease":"119-100","text":"A nongovernmental organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"16","heading":"National Coral Reef Resilience Strategy","label":"16 National Coral Reef Resilience Strategy","identifier":"/us/usc/t16/s6415/16","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F16","sourceRelease":"119-100","text":"The term “National Coral Reef Resilience Strategy” means the National Coral Reef Resilience Strategy in effect under .section 6403 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"17","heading":"Native entity","label":"17 Native entity","identifier":"/us/usc/t16/s6415/17","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F17","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6415/17/A","parentIdentifier":"/us/usc/t16/s6415/17","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F17%2FA","sourceRelease":"119-100","text":"An Indian Tribe (as defined in ).section 5304 of title 25","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6415/17/B","parentIdentifier":"/us/usc/t16/s6415/17","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F17%2FB","sourceRelease":"119-100","text":"An Alaska Native Corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6415/17/C","parentIdentifier":"/us/usc/t16/s6415/17","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F17%2FC","sourceRelease":"119-100","text":"The Department of Hawaiian Home Lands.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s6415/17/D","parentIdentifier":"/us/usc/t16/s6415/17","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F17%2FD","sourceRelease":"119-100","text":"The Office of Hawaiian Affairs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s6415/17/E","parentIdentifier":"/us/usc/t16/s6415/17","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F17%2FE","sourceRelease":"119-100","text":"A Native Hawaiian organization (as defined in ).section 7517 of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"18","heading":"Nonprofit organization","label":"18 Nonprofit organization","identifier":"/us/usc/t16/s6415/18","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F18","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6415/18/A","parentIdentifier":"/us/usc/t16/s6415/18","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F18%2FA","sourceRelease":"119-100","text":"is operated primarily for scientific, educational, service, charitable, or similar purposes in the public interest;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6415/18/B","parentIdentifier":"/us/usc/t16/s6415/18","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F18%2FB","sourceRelease":"119-100","text":"is not organized primarily for profit; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6415/18/C","parentIdentifier":"/us/usc/t16/s6415/18","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F18%2FC","sourceRelease":"119-100","text":"uses net proceeds to maintain, improve, or expand the operations of the organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"19","heading":"Restoration","label":"19 Restoration","identifier":"/us/usc/t16/s6415/19","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F19","sourceRelease":"119-100","text":"The term “restoration” means the use of methods and procedures necessary to enhance, rehabilitate, recreate, or create a functioning coral reef or coral reef ecosystem, in whole or in part, within suitable waters of the historical geographic range of such ecosystems, to provide ecological, economic, cultural, or coastal resiliency services associated with healthy coral reefs and benefit native populations of coral reef organisms.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"20","heading":"Resilience","label":"20 Resilience","identifier":"/us/usc/t16/s6415/20","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F20","sourceRelease":"119-100","text":"The term “resilience” means the capacity for corals within their native range, coral reefs, or coral reef ecosystems to resist and recover from natural and human disturbances, and maintain structure and function to provide coral reef ecosystem services, as determined by clearly identifiable, measurable, and science-based standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"21","heading":"Secretary","label":"21 Secretary","identifier":"/us/usc/t16/s6415/21","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F21","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Commerce.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"22","heading":"State","label":"22 State","identifier":"/us/usc/t16/s6415/22","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F22","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6415/22/A","parentIdentifier":"/us/usc/t16/s6415/22","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F22%2FA","sourceRelease":"119-100","text":"any State of the United States that contains a coral reef ecosystem within its seaward boundaries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6415/22/B","parentIdentifier":"/us/usc/t16/s6415/22","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F22%2FB","sourceRelease":"119-100","text":"American Samoa, the Commonwealth of the Northern Mariana Islands, Guam, Puerto Rico, or the United States Virgin Islands; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6415/22/C","parentIdentifier":"/us/usc/t16/s6415/22","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F22%2FC","sourceRelease":"119-100","text":"any other territory or possession of the United States or separate sovereign in free association with the United States that contains a coral reef ecosystem within its seaward boundaries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"23","heading":"Stewardship","label":"23 Stewardship","identifier":"/us/usc/t16/s6415/23","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F23","sourceRelease":"119-100","text":"The term “stewardship”, with respect to a coral reef, includes conservation, restoration, and public outreach and education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"24","heading":"Task Force","label":"24 Task Force","identifier":"/us/usc/t16/s6415/24","parentIdentifier":"/us/usc/t16/s6415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6415%2F24","sourceRelease":"119-100","text":"The term “Task Force” means the United States Coral Reef Task Force established under .section 6451 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
