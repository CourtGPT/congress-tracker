{"type":"section","nativeType":"section","number":"1506","heading":"Rulemaking related to partitioning or disaggregating licenses","label":"1506 Rulemaking related to partitioning or disaggregating licenses","identifier":"/us/usc/t47/s1506","parentIdentifier":"/us/usc/t47/ch14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t47/s1506/a","parentIdentifier":"/us/usc/t47/s1506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Covered small carrier","label":"1 Covered small carrier","identifier":"/us/usc/t47/s1506/a/1","parentIdentifier":"/us/usc/t47/s1506/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1506/a/1/A","parentIdentifier":"/us/usc/t47/s1506/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fa%2F1%2FA","sourceRelease":"119-100","text":"has not more than 1,500 employees (as determined under section 121.106 of title 13, Code of Federal Regulations, or any successor thereto); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1506/a/1/B","parentIdentifier":"/us/usc/t47/s1506/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fa%2F1%2FB","sourceRelease":"119-100","text":"offers services using the facilities of the carrier.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Rural area","label":"2 Rural area","identifier":"/us/usc/t47/s1506/a/2","parentIdentifier":"/us/usc/t47/s1506/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1506/a/2/A","parentIdentifier":"/us/usc/t47/s1506/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fa%2F2%2FA","sourceRelease":"119-100","text":"a city, town, or incorporated area that has a population of more than 20,000 inhabitants; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1506/a/2/B","parentIdentifier":"/us/usc/t47/s1506/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fa%2F2%2FB","sourceRelease":"119-100","text":"an urbanized area contiguous and adjacent to a city or town that has a population of more than 50,000 inhabitants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Rulemaking","label":"b Rulemaking","identifier":"/us/usc/t47/s1506/b","parentIdentifier":"/us/usc/t47/s1506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t47/s1506/b/1","parentIdentifier":"/us/usc/t47/s1506/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1506/b/1/A","parentIdentifier":"/us/usc/t47/s1506/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1506/b/1/A/i","parentIdentifier":"/us/usc/t47/s1506/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"provide services consistent with the license; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1506/b/1/A/ii","parentIdentifier":"/us/usc/t47/s1506/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t47/s1506/b/1/A/ii/I","parentIdentifier":"/us/usc/t47/s1506/b/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F1%2FA%2Fii%2FI","sourceRelease":"119-100","text":"an unaffiliated covered small carrier; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t47/s1506/b/1/A/ii/II","parentIdentifier":"/us/usc/t47/s1506/b/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F1%2FA%2Fii%2FII","sourceRelease":"119-100","text":"an unaffiliated carrier to serve a rural area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1506/b/1/B","parentIdentifier":"/us/usc/t47/s1506/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1506/b/1/B/i","parentIdentifier":"/us/usc/t47/s1506/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the availability of advanced telecommunications services in rural areas; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1506/b/1/B/ii","parentIdentifier":"/us/usc/t47/s1506/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"spectrum availability for covered small carriers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Considerations","label":"2 Considerations","identifier":"/us/usc/t47/s1506/b/2","parentIdentifier":"/us/usc/t47/s1506/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1506/b/2/A","parentIdentifier":"/us/usc/t47/s1506/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F2%2FA","sourceRelease":"119-100","text":"whether reduced performance requirements with respect to spectrum obtained through the program would facilitate deployment of advanced telecommunications services in the areas covered by the program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1506/b/2/B","parentIdentifier":"/us/usc/t47/s1506/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F2%2FB","sourceRelease":"119-100","text":"what conditions may be needed on transfers of spectrum under the program to allow covered small carriers that obtain spectrum under the program to build out the spectrum in a reasonable period of time;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t47/s1506/b/2/C","parentIdentifier":"/us/usc/t47/s1506/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1506/b/2/C/i","parentIdentifier":"/us/usc/t47/s1506/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F2%2FC%2Fi","sourceRelease":"119-100","text":"extending the term of a license granted under ; orsection 301 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1506/b/2/C/ii","parentIdentifier":"/us/usc/t47/s1506/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F2%2FC%2Fii","sourceRelease":"119-100","text":"modifying performance requirements of the license relating to the leased or sold spectrum; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t47/s1506/b/2/D","parentIdentifier":"/us/usc/t47/s1506/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1506/b/2/D/i","parentIdentifier":"/us/usc/t47/s1506/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F2%2FD%2Fi","sourceRelease":"119-100","text":"the incentives described in subparagraph (C); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1506/b/2/D/ii","parentIdentifier":"/us/usc/t47/s1506/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F2%2FD%2Fii","sourceRelease":"119-100","text":"other incentives considered by the Commission that further the goals of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Forfeiture of spectrum","label":"3 Forfeiture of spectrum","identifier":"/us/usc/t47/s1506/b/3","parentIdentifier":"/us/usc/t47/s1506/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F3","sourceRelease":"119-100","text":"If a party fails to meet any build out requirements set by the Commission for any spectrum sold or leased under this section, the right to the spectrum shall be forfeited to the Commission unless the Commission finds that there is good cause for the failure of the party.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Requirement","label":"4 Requirement","identifier":"/us/usc/t47/s1506/b/4","parentIdentifier":"/us/usc/t47/s1506/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1506%2Fb%2F4","sourceRelease":"119-100","text":"The Commission may offer a licensee incentives or reduced performance requirements under this section only if the Commission finds that doing so would likely result in increased availability of advanced telecommunications services in a rural area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
