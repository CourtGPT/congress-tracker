{"type":"section","nativeType":"section","number":"13216","heading":"Recognition and incentive awards program","label":"13216 Recognition and incentive awards program","identifier":"/us/usc/t42/s13216","parentIdentifier":"/us/usc/t42/ch134/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13216","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Awards program","label":"a Awards program","identifier":"/us/usc/t42/s13216/a","parentIdentifier":"/us/usc/t42/s13216","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13216%2Fa","sourceRelease":"119-100","text":"The Administrator of General Services shall establish annual awards program to recognize those Federal employees who demonstrate the strongest commitment to the use of alternative fuels and fuel conservation in Federal motor vehicles.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Criteria","label":"b Criteria","identifier":"/us/usc/t42/s13216/b","parentIdentifier":"/us/usc/t42/s13216","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13216%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13216/b/1","parentIdentifier":"/us/usc/t42/s13216/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13216%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13216/b/1/A","parentIdentifier":"/us/usc/t42/s13216/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13216%2Fb%2F1%2FA","sourceRelease":"119-100","text":"exemplary promotion of alternative fueled vehicle use within Federal agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13216/b/1/B","parentIdentifier":"/us/usc/t42/s13216/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13216%2Fb%2F1%2FB","sourceRelease":"119-100","text":"proper alternative fueled vehicle care and maintenance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s13216/b/1/C","parentIdentifier":"/us/usc/t42/s13216/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13216%2Fb%2F1%2FC","sourceRelease":"119-100","text":"coordination with Federal, State, and local efforts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s13216/b/1/D","parentIdentifier":"/us/usc/t42/s13216/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13216%2Fb%2F1%2FD","sourceRelease":"119-100","text":"innovative alternative fueled vehicle procurement, refueling, and maintenance arrangements with commercial entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s13216/b/1/E","parentIdentifier":"/us/usc/t42/s13216/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13216%2Fb%2F1%2FE","sourceRelease":"119-100","text":"making regular requests for alternative fueled vehicles for agency use; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s13216/b/1/F","parentIdentifier":"/us/usc/t42/s13216/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13216%2Fb%2F1%2FF","sourceRelease":"119-100","text":"maintaining a high number of alternative fueled vehicles used relative to comparable conventionally fueled motor vehicles used; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13216/b/2","parentIdentifier":"/us/usc/t42/s13216/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13216%2Fb%2F2","sourceRelease":"119-100","text":"to fuel efficiency in Federal motor vehicle use through the promotion of such measures as increased use of fuel-efficient vehicles, carpooling, ride-sharing, regular maintenance, and other conservation and awareness measures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t42/s13216/c","parentIdentifier":"/us/usc/t42/s13216","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13216%2Fc","sourceRelease":"119-100","text":"There are authorized to be appropriated for the purpose of carrying out this section not more than $35,000 for fiscal year 1994 and such sums as may be necessary for each of the fiscal years 1995 and 1996.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
