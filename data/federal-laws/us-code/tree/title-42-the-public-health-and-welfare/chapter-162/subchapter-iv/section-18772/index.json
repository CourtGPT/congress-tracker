a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fa%2F1%2FA","sourceRelease":"119-100","text":"Not later than 90 days after , the Administrator shall establish an online database to track the operation of the bulk power system in the contiguous 48 States (referred to in this section as the “Dashboard”).November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Improvement of existing dashboard","label":"B Improvement of existing dashboard","identifier":"/us/usc/t42/s18772/a/1/B","parentIdentifier":"/us/usc/t42/s18772/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18772/a/1/B/i","parentIdentifier":"/us/usc/t42/s18772/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the U.S. Electric System Operating Data dashboard; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18772/a/1/B/ii","parentIdentifier":"/us/usc/t42/s18772/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the Hourly Electric Grid Monitor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Expansion","label":"2 Expansion","identifier":"/us/usc/t42/s18772/a/2","parentIdentifier":"/us/usc/t42/s18772/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amend