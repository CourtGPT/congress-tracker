{"type":"section","nativeType":"section","number":"6122","heading":"Manufacturing infrastructure for refabrication and certification of nuclear weapons stockpile","label":"6122 Manufacturing infrastructure for refabrication and certification of nuclear weapons stockpile","identifier":"/us/usc/t10/s6122","parentIdentifier":"/us/usc/t10/stA/ptVI/sptB/ch602/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsProvisions similar to those in this section were contained in , War and National Defense, prior to repeal by .section 2532 of Title 50Pub. L. 119–60, § 3111(b)(1)","Amendments2025—, realigned margins.Pub. L. 119–60, § 3111(d)(2)(B)"],"amendments":["Amendments2025—, realigned margins.Pub. L. 119–60, § 3111(d)(2)(B)"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Manufacturing Program","label":"a .—Manufacturing Program","identifier":"/us/usc/t10/s6122/a","parentIdentifier":"/us/usc/t10/s6122","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6122/a/1","parentIdentifier":"/us/usc/t10/s6122/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s6122/a/1/A","parentIdentifier":"/us/usc/t10/s6122/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fa%2F1%2FA","sourceRelease":"119-100","text":"To provide a stockpile surveillance engineering base.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s6122/a/1/B","parentIdentifier":"/us/usc/t10/s6122/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fa%2F1%2FB","sourceRelease":"119-100","text":"To refabricate and certify weapon components and types in the enduring nuclear weapons stockpile, as necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s6122/a/1/C","parentIdentifier":"/us/usc/t10/s6122/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fa%2F1%2FC","sourceRelease":"119-100","text":"To fabricate and certify new nuclear warheads, as necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s6122/a/1/D","parentIdentifier":"/us/usc/t10/s6122/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fa%2F1%2FD","sourceRelease":"119-100","text":"To support nuclear weapons.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t10/s6122/a/1/E","parentIdentifier":"/us/usc/t10/s6122/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fa%2F1%2FE","sourceRelease":"119-100","text":"To supply sufficient tritium in support of nuclear weapons to ensure an upload hedge in the event circumstances require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6122/a/2","parentIdentifier":"/us/usc/t10/s6122/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fa%2F2","sourceRelease":"119-100","text":"The purpose of the program carried out under paragraph (1) shall also be to develop manufacturing capabilities and capacities necessary to meet the requirements specified in the annual Nuclear Weapons Stockpile Memorandum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Required Capabilities","label":"b .—Required Capabilities","identifier":"/us/usc/t10/s6122/b","parentIdentifier":"/us/usc/t10/s6122","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6122/b/1","parentIdentifier":"/us/usc/t10/s6122/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fb%2F1","sourceRelease":"119-100","text":"The weapons assembly and high explosives manufacturing capabilities of the Pantex Plant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6122/b/2","parentIdentifier":"/us/usc/t10/s6122/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fb%2F2","sourceRelease":"119-100","text":"The weapon secondary fabrication capabilities of the Y–12 National Security Complex, Oak Ridge, Tennessee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s6122/b/3","parentIdentifier":"/us/usc/t10/s6122/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fb%2F3","sourceRelease":"119-100","text":"The capabilities of the Savannah River Site relating to tritium recycling and processing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s6122/b/4","parentIdentifier":"/us/usc/t10/s6122/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fb%2F4","sourceRelease":"119-100","text":"The fissile material component processing and fabrication capabilities of the Savannah River Plutonium Processing Facility and the Los Alamos National Laboratory.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s6122/b/5","parentIdentifier":"/us/usc/t10/s6122/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6122%2Fb%2F5","sourceRelease":"119-100","text":"The non-nuclear component capabilities of the Kansas City National Security Campus, Kansas City, Missouri.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
