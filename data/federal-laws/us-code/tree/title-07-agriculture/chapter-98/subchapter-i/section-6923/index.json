{"type":"section","nativeType":"section","number":"6923","heading":"Office of Urban Agriculture and Innovative Production","label":"6923 Office of Urban Agriculture and Innovative Production","identifier":"/us/usc/t7/s6923","parentIdentifier":"/us/usc/t7/ch98/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Office","label":"a Office","identifier":"/us/usc/t7/s6923/a","parentIdentifier":"/us/usc/t7/s6923","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s6923/a/1","parentIdentifier":"/us/usc/t7/s6923/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary shall establish in the Department an Office of Urban Agriculture and Innovative Production.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Director","label":"2 Director","identifier":"/us/usc/t7/s6923/a/2","parentIdentifier":"/us/usc/t7/s6923/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F2","sourceRelease":"119-100","text":"The Secretary shall appoint a senior official to serve as the Director of the Office of Urban Agriculture and Innovative Production (referred to in this section as the “Director”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Mission","label":"3 Mission","identifier":"/us/usc/t7/s6923/a/3","parentIdentifier":"/us/usc/t7/s6923/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6923/a/3/A","parentIdentifier":"/us/usc/t7/s6923/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F3%2FA","sourceRelease":"119-100","text":"community gardens and farms located in urban areas, suburbs, and urban clusters;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6923/a/3/B","parentIdentifier":"/us/usc/t7/s6923/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F3%2FB","sourceRelease":"119-100","text":"rooftop farms, outdoor vertical production, and green walls;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s6923/a/3/C","parentIdentifier":"/us/usc/t7/s6923/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F3%2FC","sourceRelease":"119-100","text":"indoor farms, greenhouses, and high-tech vertical technology farms;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s6923/a/3/D","parentIdentifier":"/us/usc/t7/s6923/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F3%2FD","sourceRelease":"119-100","text":"hydroponic, aeroponic, and aquaponic farm facilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s6923/a/3/E","parentIdentifier":"/us/usc/t7/s6923/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F3%2FE","sourceRelease":"119-100","text":"other innovations in agricultural production, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Responsibilities","label":"4 Responsibilities","identifier":"/us/usc/t7/s6923/a/4","parentIdentifier":"/us/usc/t7/s6923/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6923/a/4/A","parentIdentifier":"/us/usc/t7/s6923/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F4%2FA","sourceRelease":"119-100","text":"managing programs, including for community gardens, urban farms, rooftop agriculture, and indoor vertical production;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6923/a/4/B","parentIdentifier":"/us/usc/t7/s6923/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F4%2FB","sourceRelease":"119-100","text":"advising the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s6923/a/4/C","parentIdentifier":"/us/usc/t7/s6923/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F4%2FC","sourceRelease":"119-100","text":"coordinating with the agencies and officials of the Department to update relevant programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s6923/a/4/D","parentIdentifier":"/us/usc/t7/s6923/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F4%2FD","sourceRelease":"119-100","text":"engaging in stakeholder relations and developing external partnerships;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s6923/a/4/E","parentIdentifier":"/us/usc/t7/s6923/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F4%2FE","sourceRelease":"119-100","text":"identifying common State and municipal best practices for navigating local policies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t7/s6923/a/4/F","parentIdentifier":"/us/usc/t7/s6923/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F4%2FF","sourceRelease":"119-100","text":"coordinating networks of community gardens and facilitating connections to local food banks, in partnership with the Food and Nutrition Service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t7/s6923/a/4/G","parentIdentifier":"/us/usc/t7/s6923/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fa%2F4%2FG","sourceRelease":"119-100","text":"collaborating with other Federal agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Urban Agriculture and Innovative Production Advisory Committee","label":"b Urban Agriculture and Innovative Production Advisory Committee","identifier":"/us/usc/t7/s6923/b","parentIdentifier":"/us/usc/t7/s6923","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s6923/b/1","parentIdentifier":"/us/usc/t7/s6923/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6923/b/1/A","parentIdentifier":"/us/usc/t7/s6923/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the development of policies and outreach relating to urban, indoor, and other emerging agricultural production practices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6923/b/1/B","parentIdentifier":"/us/usc/t7/s6923/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F1%2FB","sourceRelease":"119-100","text":"any other aspects of the implementation of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Membership","label":"2 Membership","identifier":"/us/usc/t7/s6923/b/2","parentIdentifier":"/us/usc/t7/s6923/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s6923/b/2/A","parentIdentifier":"/us/usc/t7/s6923/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6923/b/2/A/i","parentIdentifier":"/us/usc/t7/s6923/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s6923/b/2/A/i/I","parentIdentifier":"/us/usc/t7/s6923/b/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F2%2FA%2Fi%2FI","sourceRelease":"119-100","text":"2 individuals shall be agricultural producers located in an urban area or urban cluster; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s6923/b/2/A/i/II","parentIdentifier":"/us/usc/t7/s6923/b/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F2%2FA%2Fi%2FII","sourceRelease":"119-100","text":"2 individuals shall be farmers that use innovative technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6923/b/2/A/ii","parentIdentifier":"/us/usc/t7/s6923/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"2 shall be representatives from an institution of higher education or extension program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s6923/b/2/A/iii","parentIdentifier":"/us/usc/t7/s6923/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"1 shall be an individual who represents a nonprofit organization, which may include a public health, environmental, or community organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s6923/b/2/A/iv","parentIdentifier":"/us/usc/t7/s6923/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"1 shall be an individual who represents business and economic development, which may include a business development entity, a chamber of commerce, a city government, or a planning organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t7/s6923/b/2/A/v","parentIdentifier":"/us/usc/t7/s6923/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F2%2FA%2Fv","sourceRelease":"119-100","text":"1 shall be an individual with supply chain experience, which may include a food aggregator, wholesale food distributor, food hub, or an individual who has direct-to-consumer market experience;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t7/s6923/b/2/A/vi","parentIdentifier":"/us/usc/t7/s6923/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F2%2FA%2Fvi","sourceRelease":"119-100","text":"1 shall be an individual from a financing entity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t7/s6923/b/2/A/vii","parentIdentifier":"/us/usc/t7/s6923/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F2%2FA%2Fvii","sourceRelease":"119-100","text":"2 shall be individuals with related experience or expertise in urban, indoor, and other emerging agriculture production practices, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Initial appointments","label":"B Initial appointments","identifier":"/us/usc/t7/s6923/b/2/B","parentIdentifier":"/us/usc/t7/s6923/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F2%2FB","sourceRelease":"119-100","text":"The Secretary shall appoint the members of the Committee not later than 180 days after .December 20, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Period of appointment; vacancies","label":"3 Period of appointment; vacancies","identifier":"/us/usc/t7/s6923/b/3","parentIdentifier":"/us/usc/t7/s6923/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s6923/b/3/A","parentIdentifier":"/us/usc/t7/s6923/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F3%2FA","sourceRelease":"119-100","text":"Except as provided in subparagraph (B), a member of the Committee shall be appointed for a term of 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Initial appointments","label":"B Initial appointments","identifier":"/us/usc/t7/s6923/b/3/B","parentIdentifier":"/us/usc/t7/s6923/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6923/b/3/B/i","parentIdentifier":"/us/usc/t7/s6923/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"4 of the members, as determined by the Secretary, shall be appointed for a term of 3 years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6923/b/3/B/ii","parentIdentifier":"/us/usc/t7/s6923/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"4 of the members, as determined by the Secretary, shall be appointed for a term of 2 years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s6923/b/3/B/iii","parentIdentifier":"/us/usc/t7/s6923/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"4 of the members, as determined by the Secretary, shall be appointed for a term of 1 year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Vacancies","label":"C Vacancies","identifier":"/us/usc/t7/s6923/b/3/C","parentIdentifier":"/us/usc/t7/s6923/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6923/b/3/C/i","parentIdentifier":"/us/usc/t7/s6923/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F3%2FC%2Fi","sourceRelease":"119-100","text":"shall not affect the powers of the Committee; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6923/b/3/C/ii","parentIdentifier":"/us/usc/t7/s6923/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F3%2FC%2Fii","sourceRelease":"119-100","text":"shall be filled as soon as practicable in the same manner as the original appointment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Consecutive terms","label":"D Consecutive terms","identifier":"/us/usc/t7/s6923/b/3/D","parentIdentifier":"/us/usc/t7/s6923/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F3%2FD","sourceRelease":"119-100","text":"An initial appointee of the committee may serve an additional consecutive term if the member is reappointed by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Meetings","label":"4 Meetings","identifier":"/us/usc/t7/s6923/b/4","parentIdentifier":"/us/usc/t7/s6923/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Frequency","label":"A Frequency","identifier":"/us/usc/t7/s6923/b/4/A","parentIdentifier":"/us/usc/t7/s6923/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F4%2FA","sourceRelease":"119-100","text":"The Committee shall meet not fewer than 3 times per year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Initial meeting","label":"B Initial meeting","identifier":"/us/usc/t7/s6923/b/4/B","parentIdentifier":"/us/usc/t7/s6923/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F4%2FB","sourceRelease":"119-100","text":"Not later than 180 days after the date on which the members are appointed under paragraph (2)(B), the Committee shall hold the first meeting of the Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Duties","label":"5 Duties","identifier":"/us/usc/t7/s6923/b/5","parentIdentifier":"/us/usc/t7/s6923/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s6923/b/5/A","parentIdentifier":"/us/usc/t7/s6923/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F5%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6923/b/5/A/i","parentIdentifier":"/us/usc/t7/s6923/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F5%2FA%2Fi","sourceRelease":"119-100","text":"develop recommendations and advise the Director on policies, initiatives, and outreach administered by the Office of Urban Agriculture and Innovative Production;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6923/b/5/A/ii","parentIdentifier":"/us/usc/t7/s6923/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F5%2FA%2Fii","sourceRelease":"119-100","text":"evaluate and review ongoing research and extension activities relating to urban, indoor, and other innovative agricultural practices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s6923/b/5/A/iii","parentIdentifier":"/us/usc/t7/s6923/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F5%2FA%2Fiii","sourceRelease":"119-100","text":"identify new and existing barriers to successful urban, indoor, and other emerging agricultural production practices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s6923/b/5/A/iv","parentIdentifier":"/us/usc/t7/s6923/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F5%2FA%2Fiv","sourceRelease":"119-100","text":"provide additional assistance and advice to the Director as appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Reports","label":"B Reports","identifier":"/us/usc/t7/s6923/b/5/B","parentIdentifier":"/us/usc/t7/s6923/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F5%2FB","sourceRelease":"119-100","text":"Not later than 1 year after the date on which the Committee is established, and every 2 years through 2023, the Committee shall submit to the Secretary, the Committee on Agriculture of the House of Representatives, and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing the recommendations developed under subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Personnel matters","label":"6 Personnel matters","identifier":"/us/usc/t7/s6923/b/6","parentIdentifier":"/us/usc/t7/s6923/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Compensation","label":"A Compensation","identifier":"/us/usc/t7/s6923/b/6/A","parentIdentifier":"/us/usc/t7/s6923/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F6%2FA","sourceRelease":"119-100","text":"A member of the Committee shall serve without compensation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Travel expenses","label":"B Travel expenses","identifier":"/us/usc/t7/s6923/b/6/B","parentIdentifier":"/us/usc/t7/s6923/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F6%2FB","sourceRelease":"119-100","text":"A member of the Committee shall be allowed travel expenses, including per diem in lieu of subsistence, in accordance with .section 5703 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Termination","label":"7 Termination","identifier":"/us/usc/t7/s6923/b/7","parentIdentifier":"/us/usc/t7/s6923/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s6923/b/7/A","parentIdentifier":"/us/usc/t7/s6923/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F7%2FA","sourceRelease":"119-100","text":"Subject to subparagraph (B), the Committee shall terminate on the date that is 5 years after the date on which the members are appointed under paragraph (2)(B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Extensions","label":"B Extensions","identifier":"/us/usc/t7/s6923/b/7/B","parentIdentifier":"/us/usc/t7/s6923/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fb%2F7%2FB","sourceRelease":"119-100","text":"Before the date on which the Committee terminates, the Secretary may renew the Committee for 1 or more 2-year periods.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Grants","label":"c Grants","identifier":"/us/usc/t7/s6923/c","parentIdentifier":"/us/usc/t7/s6923","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s6923/c/1","parentIdentifier":"/us/usc/t7/s6923/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fc%2F1","sourceRelease":"119-100","text":"A nonprofit organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s6923/c/2","parentIdentifier":"/us/usc/t7/s6923/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fc%2F2","sourceRelease":"119-100","text":"A unit of local government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s6923/c/3","parentIdentifier":"/us/usc/t7/s6923/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fc%2F3","sourceRelease":"119-100","text":"A Tribal government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s6923/c/4","parentIdentifier":"/us/usc/t7/s6923/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fc%2F4","sourceRelease":"119-100","text":"Any school that serves any of grades kindergarten through grade 12.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Pilot projects","label":"d Pilot projects","identifier":"/us/usc/t7/s6923/d","parentIdentifier":"/us/usc/t7/s6923","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Urban and suburban county committees","label":"1 Urban and suburban county committees","identifier":"/us/usc/t7/s6923/d/1","parentIdentifier":"/us/usc/t7/s6923/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s6923/d/1/A","parentIdentifier":"/us/usc/t7/s6923/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F1%2FA","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary shall establish a pilot program for not fewer than 5 years that establishes 10 county committees in accordance with to operate in counties located in urban or suburban areas with a high concentration of urban or suburban farms.December 20, 2018section 590h(b)(5)(B)(ii)(II) of title 16","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Effect","label":"B Effect","identifier":"/us/usc/t7/s6923/d/1/B","parentIdentifier":"/us/usc/t7/s6923/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F1%2FB","sourceRelease":"119-100","text":"Nothing in this paragraph requires or precludes the establishment of a Farm Service Agency office in a county in which a county committee is established under subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Report","label":"C Report","identifier":"/us/usc/t7/s6923/d/1/C","parentIdentifier":"/us/usc/t7/s6923/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6923/d/1/C/i","parentIdentifier":"/us/usc/t7/s6923/d/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F1%2FC%2Fi","sourceRelease":"119-100","text":"the status of the pilot program under subparagraph (A);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6923/d/1/C/ii","parentIdentifier":"/us/usc/t7/s6923/d/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F1%2FC%2Fii","sourceRelease":"119-100","text":"meetings and other activities of the committees established under that subparagraph; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s6923/d/1/C/iii","parentIdentifier":"/us/usc/t7/s6923/d/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"the types and volume of assistance and services provided to farmers in counties in which county committees are established under that subparagraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Increasing community compost and reducing food waste","label":"2 Increasing community compost and reducing food waste","identifier":"/us/usc/t7/s6923/d/2","parentIdentifier":"/us/usc/t7/s6923/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s6923/d/2/A","parentIdentifier":"/us/usc/t7/s6923/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FA","sourceRelease":"119-100","text":"The Secretary, acting through the Director, shall carry out pilot projects under which the Secretary shall offer to enter into cooperative agreements with local or municipal governments in not fewer than 10 States to develop and test strategies for planning and implementing municipal compost plans and food waste reduction plans.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Eligible entities and purposes of pilot projects","label":"B Eligible entities and purposes of pilot projects","identifier":"/us/usc/t7/s6923/d/2/B","parentIdentifier":"/us/usc/t7/s6923/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6923/d/2/B/i","parentIdentifier":"/us/usc/t7/s6923/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FB%2Fi","sourceRelease":"119-100","text":"generate compost;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6923/d/2/B/ii","parentIdentifier":"/us/usc/t7/s6923/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FB%2Fii","sourceRelease":"119-100","text":"increase access to compost for agricultural producers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s6923/d/2/B/iii","parentIdentifier":"/us/usc/t7/s6923/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"reduce reliance on, and limit the use of, fertilizer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s6923/d/2/B/iv","parentIdentifier":"/us/usc/t7/s6923/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"improve soil quality;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t7/s6923/d/2/B/v","parentIdentifier":"/us/usc/t7/s6923/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FB%2Fv","sourceRelease":"119-100","text":"encourage waste management and permaculture business development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t7/s6923/d/2/B/vi","parentIdentifier":"/us/usc/t7/s6923/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FB%2Fvi","sourceRelease":"119-100","text":"increase rainwater absorption;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t7/s6923/d/2/B/vii","parentIdentifier":"/us/usc/t7/s6923/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FB%2Fvii","sourceRelease":"119-100","text":"reduce municipal food waste; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t7/s6923/d/2/B/viii","parentIdentifier":"/us/usc/t7/s6923/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FB%2Fviii","sourceRelease":"119-100","text":"divert food waste from landfills.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Evaluation and ranking of applications","label":"C Evaluation and ranking of applications","identifier":"/us/usc/t7/s6923/d/2/C","parentIdentifier":"/us/usc/t7/s6923/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"Criteria","label":"i Criteria","identifier":"/us/usc/t7/s6923/d/2/C/i","parentIdentifier":"/us/usc/t7/s6923/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FC%2Fi","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary shall establish criteria for the selection of pilot projects under this paragraph.December 20, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Consideration","label":"ii Consideration","identifier":"/us/usc/t7/s6923/d/2/C/ii","parentIdentifier":"/us/usc/t7/s6923/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FC%2Fii","sourceRelease":"119-100","text":"In selecting, undertaking, or funding pilot projects under this paragraph, the Secretary shall consider any commonly known significant impact on existing food waste recovery and disposal by commercial, marketing, or business relationships.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":"Priority","label":"iii Priority","identifier":"/us/usc/t7/s6923/d/2/C/iii","parentIdentifier":"/us/usc/t7/s6923/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FC%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s6923/d/2/C/iii/I","parentIdentifier":"/us/usc/t7/s6923/d/2/C/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FC%2Fiii%2FI","sourceRelease":"119-100","text":"anticipates or demonstrates economic benefits;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s6923/d/2/C/iii/II","parentIdentifier":"/us/usc/t7/s6923/d/2/C/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FC%2Fiii%2FII","sourceRelease":"119-100","text":"incorporates plans to make compost easily accessible to agricultural producers, including community gardeners;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t7/s6923/d/2/C/iii/III","parentIdentifier":"/us/usc/t7/s6923/d/2/C/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FC%2Fiii%2FIII","sourceRelease":"119-100","text":"integrates other food waste strategies, including food recovery efforts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t7/s6923/d/2/C/iii/IV","parentIdentifier":"/us/usc/t7/s6923/d/2/C/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FC%2Fiii%2FIV","sourceRelease":"119-100","text":"provides for collaboration with multiple partners.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Matching requirement","label":"D Matching requirement","identifier":"/us/usc/t7/s6923/d/2/D","parentIdentifier":"/us/usc/t7/s6923/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FD","sourceRelease":"119-100","text":"The recipient of assistance for a pilot project under this paragraph shall provide funds, in-kind contributions, or a combination of both from sources other than funds provided through the grant in an amount equal to not less than 25 percent of the amount of the grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":"Evaluation","label":"E Evaluation","identifier":"/us/usc/t7/s6923/d/2/E","parentIdentifier":"/us/usc/t7/s6923/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6923/d/2/E/i","parentIdentifier":"/us/usc/t7/s6923/d/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FE%2Fi","sourceRelease":"119-100","text":"the amount of Federal funds used for each project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6923/d/2/E/ii","parentIdentifier":"/us/usc/t7/s6923/d/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fd%2F2%2FE%2Fii","sourceRelease":"119-100","text":"a measurement of the outcomes of each project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t7/s6923/e","parentIdentifier":"/us/usc/t7/s6923","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6923%2Fe","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section and the amendments made by this section $25,000,000 for each of fiscal years 2019 through 2023.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
