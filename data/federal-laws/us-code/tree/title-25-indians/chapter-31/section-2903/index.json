{"type":"section","nativeType":"section","number":"2903","heading":"Declaration of policy","label":"2903 Declaration of policy","identifier":"/us/usc/t25/s2903","parentIdentifier":"/us/usc/t25/ch31","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s2903/1","parentIdentifier":"/us/usc/t25/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903%2F1","sourceRelease":"119-100","text":"preserve, protect, and promote the rights and freedom of Native Americans to use, practice, and develop Native American languages;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s2903/2","parentIdentifier":"/us/usc/t25/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903%2F2","sourceRelease":"119-100","text":"allow exceptions to teacher certification requirements for Federal programs, and programs funded in whole or in part by the Federal Government, for instruction in Native American languages when such teacher certification requirements hinder the employment of qualified teachers who teach in Native American languages, and to encourage State and territorial governments to make similar exceptions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s2903/3","parentIdentifier":"/us/usc/t25/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s2903/3/A","parentIdentifier":"/us/usc/t25/s2903/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903%2F3%2FA","sourceRelease":"119-100","text":"Native American language survival,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s2903/3/B","parentIdentifier":"/us/usc/t25/s2903/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903%2F3%2FB","sourceRelease":"119-100","text":"educational opportunity,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s2903/3/C","parentIdentifier":"/us/usc/t25/s2903/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903%2F3%2FC","sourceRelease":"119-100","text":"increased student success and performance,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s2903/3/D","parentIdentifier":"/us/usc/t25/s2903/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903%2F3%2FD","sourceRelease":"119-100","text":"increased student awareness and knowledge of their culture and history, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t25/s2903/3/E","parentIdentifier":"/us/usc/t25/s2903/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903%2F3%2FE","sourceRelease":"119-100","text":"increased student and community pride;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s2903/4","parentIdentifier":"/us/usc/t25/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903%2F4","sourceRelease":"119-100","text":"encourage State and local education programs to work with Native American parents, educators, Indian tribes, and other Native American governing bodies in the implementation of programs to put this policy into effect;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s2903/5","parentIdentifier":"/us/usc/t25/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903%2F5","sourceRelease":"119-100","text":"recognize the right of Indian tribes and other Native American governing bodies to use the Native American languages as a medium of instruction in all schools funded by the Secretary of the Interior;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t25/s2903/6","parentIdentifier":"/us/usc/t25/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903%2F6","sourceRelease":"119-100","text":"fully recognize the inherent right of Indian tribes and other Native American governing bodies, States, territories, and possessions of the United States to take action on, and give official status to, their Native American languages for the purpose of conducting their own business;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t25/s2903/7","parentIdentifier":"/us/usc/t25/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903%2F7","sourceRelease":"119-100","text":"support the granting of comparable proficiency achieved through course work in a Native American language the same academic credit as comparable proficiency achieved through course work in a foreign language, with recognition of such Native American language proficiency by institutions of higher education as fulfilling foreign language entrance or degree requirements; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t25/s2903/8","parentIdentifier":"/us/usc/t25/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2903%2F8","sourceRelease":"119-100","text":"encourage all institutions of elementary, secondary and higher education, where appropriate, to include Native American languages in the curriculum in the same manner as foreign languages and to grant proficiency in Native American languages the same full academic credit as proficiency in foreign languages.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
