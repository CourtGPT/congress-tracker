{"type":"section","nativeType":"section","number":"16298b","heading":"High efficiency turbines","label":"16298b High efficiency turbines","identifier":"/us/usc/t42/s16298b","parentIdentifier":"/us/usc/t42/ch149/schIX/ptF","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s16298b/a","parentIdentifier":"/us/usc/t42/s16298b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fa","sourceRelease":"119-100","text":"The Secretary, acting through the Assistant Secretary for Fossil Energy (referred to in this section as the “Secretary”), shall establish a multiyear, multiphase program (referred to in this section as the “program”) of research, development, and technology demonstration to improve the efficiency of gas turbines used in power generation systems and aviation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Program elements","label":"b Program elements","identifier":"/us/usc/t42/s16298b/b","parentIdentifier":"/us/usc/t42/s16298b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16298b/b/1","parentIdentifier":"/us/usc/t42/s16298b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16298b/b/1/A","parentIdentifier":"/us/usc/t42/s16298b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F1%2FA","sourceRelease":"119-100","text":"high temperature materials, including superalloys, coatings, and ceramics;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16298b/b/1/B","parentIdentifier":"/us/usc/t42/s16298b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F1%2FB","sourceRelease":"119-100","text":"improved heat transfer capability;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16298b/b/1/C","parentIdentifier":"/us/usc/t42/s16298b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F1%2FC","sourceRelease":"119-100","text":"manufacturing technology required to construct complex 3-dimensional geometry parts with improved aerodynamic capability;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16298b/b/1/D","parentIdentifier":"/us/usc/t42/s16298b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F1%2FD","sourceRelease":"119-100","text":"combustion technology to produce higher firing temperature while lowering nitrogen oxide and carbon monoxide emissions per unit of output;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16298b/b/1/E","parentIdentifier":"/us/usc/t42/s16298b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F1%2FE","sourceRelease":"119-100","text":"advanced controls and systems integration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s16298b/b/1/F","parentIdentifier":"/us/usc/t42/s16298b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F1%2FF","sourceRelease":"119-100","text":"advanced high performance compressor technology; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s16298b/b/1/G","parentIdentifier":"/us/usc/t42/s16298b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F1%2FG","sourceRelease":"119-100","text":"validation facilities for the testing of components and subsystems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16298b/b/2","parentIdentifier":"/us/usc/t42/s16298b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F2","sourceRelease":"119-100","text":"include technology demonstration through component testing, subscale testing, and full-scale testing in existing fleets;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16298b/b/3","parentIdentifier":"/us/usc/t42/s16298b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F3","sourceRelease":"119-100","text":"include field demonstrations of the developed technology elements to demonstrate technical and economic feasibility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16298b/b/4","parentIdentifier":"/us/usc/t42/s16298b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F4","sourceRelease":"119-100","text":"assess overall combined cycle and simple cycle system performance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16298b/b/5","parentIdentifier":"/us/usc/t42/s16298b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F5","sourceRelease":"119-100","text":"increase fuel flexibility by enabling gas turbines to operate with high proportions of, or pure, hydrogen or other renewable gas fuels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s16298b/b/6","parentIdentifier":"/us/usc/t42/s16298b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F6","sourceRelease":"119-100","text":"enhance foundational knowledge needed for low-emission combustion systems that can work in high-pressure, high-temperature environments required for high-efficiency cycles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s16298b/b/7","parentIdentifier":"/us/usc/t42/s16298b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F7","sourceRelease":"119-100","text":"increase operational flexibility by reducing turbine start-up times and improving the ability to accommodate flexible power demand; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s16298b/b/8","parentIdentifier":"/us/usc/t42/s16298b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fb%2F8","sourceRelease":"119-100","text":"include any other elements necessary to achieve the goals described in subsection (c), as determined by the Secretary, in consultation with private industry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Program goals","label":"c Program goals","identifier":"/us/usc/t42/s16298b/c","parentIdentifier":"/us/usc/t42/s16298b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16298b/c/1","parentIdentifier":"/us/usc/t42/s16298b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16298b/c/1/A","parentIdentifier":"/us/usc/t42/s16298b/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16298b/c/1/A/i","parentIdentifier":"/us/usc/t42/s16298b/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s16298b/c/1/A/i/I","parentIdentifier":"/us/usc/t42/s16298b/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fc%2F1%2FA%2Fi%2FI","sourceRelease":"119-100","text":"a combined cycle efficiency of not less than 65 percent; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s16298b/c/1/A/i/II","parentIdentifier":"/us/usc/t42/s16298b/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fc%2F1%2FA%2Fi%2FII","sourceRelease":"119-100","text":"a simple cycle efficiency of not less than 47 percent; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16298b/c/1/A/ii","parentIdentifier":"/us/usc/t42/s16298b/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"aviation gas turbines to achieve a 25 percent reduction in fuel burn by improving fuel efficiency to existing best-in-class turbo-fan engines; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16298b/c/1/B","parentIdentifier":"/us/usc/t42/s16298b/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16298b/c/1/B/i","parentIdentifier":"/us/usc/t42/s16298b/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"a combined cycle efficiency of not less than 67 percent; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16298b/c/1/B/ii","parentIdentifier":"/us/usc/t42/s16298b/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"a simple cycle efficiency of not less than 50 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Additional goals","label":"2 Additional goals","identifier":"/us/usc/t42/s16298b/c/2","parentIdentifier":"/us/usc/t42/s16298b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fc%2F2","sourceRelease":"119-100","text":"If a goal described in paragraph (1) has been achieved, the Secretary, in consultation with private industry and the National Academy of Sciences, may develop additional goals or phases for advanced gas turbine research and development.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Financial assistance","label":"d Financial assistance","identifier":"/us/usc/t42/s16298b/d","parentIdentifier":"/us/usc/t42/s16298b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16298b/d/1","parentIdentifier":"/us/usc/t42/s16298b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary may provide financial assistance, including grants, to carry out the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Proposals","label":"2 Proposals","identifier":"/us/usc/t42/s16298b/d/2","parentIdentifier":"/us/usc/t42/s16298b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fd%2F2","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary shall solicit proposals from industry, small businesses, universities, and other appropriate parties for conducting activities under this section.December 27, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Considerations","label":"3 Considerations","identifier":"/us/usc/t42/s16298b/d/3","parentIdentifier":"/us/usc/t42/s16298b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16298b/d/3/A","parentIdentifier":"/us/usc/t42/s16298b/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fd%2F3%2FA","sourceRelease":"119-100","text":"stimulate the creation or increased retention of jobs in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16298b/d/3/B","parentIdentifier":"/us/usc/t42/s16298b/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fd%2F3%2FB","sourceRelease":"119-100","text":"promote and enhance technology leadership in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Competitive awards","label":"4 Competitive awards","identifier":"/us/usc/t42/s16298b/d/4","parentIdentifier":"/us/usc/t42/s16298b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fd%2F4","sourceRelease":"119-100","text":"The Secretary shall provide financial assistance under this subsection on a competitive basis, with an emphasis on technical merit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Cost sharing","label":"5 Cost sharing","identifier":"/us/usc/t42/s16298b/d/5","parentIdentifier":"/us/usc/t42/s16298b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fd%2F5","sourceRelease":"119-100","text":"Financial assistance provided under this subsection shall be subject to the cost sharing requirements of .section 16352 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s16298b/e","parentIdentifier":"/us/usc/t42/s16298b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298b%2Fe","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $50,000,000 for each of fiscal years 2021 through 2025.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
