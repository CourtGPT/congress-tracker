ildren":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Day care center facilities","label":"b Day care center facilities","identifier":"/us/usc/t20/s3477/b","parentIdentifier":"/us/usc/t20/s3477","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3477%2Fb","sourceRelease":"119-100","text":"The authority available to the Secretary of Health, Education, and Welfare under , shall also be available to the Secretary.section 2564 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Special purpose facilities","label":"c Special purpose facilities","identifier":"/us/usc/t20/s3477/c","parentIdentifier":"/us/usc/t20/s3477","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3477%2Fc","sourceRelease":"119-100","text":"The authority granted by subsection (a) of this section shall be available only with respect to facilities of a special purpose nature that cannot readily be reassigned from similar Federal activities and are not otherwise available for assignment to the Department by the Administrator of General Services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
