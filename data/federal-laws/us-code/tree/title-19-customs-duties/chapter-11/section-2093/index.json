{"type":"section","nativeType":"section","number":"2093","heading":"Forfeiture of unlawful imports","label":"2093 Forfeiture of unlawful imports","identifier":"/us/usc/t19/s2093","parentIdentifier":"/us/usc/t19/ch11","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2093","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Seizure","label":"a Seizure","identifier":"/us/usc/t19/s2093/a","parentIdentifier":"/us/usc/t19/s2093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2093%2Fa","sourceRelease":"119-100","text":"Any pre-Columbian monumental or architectural sculpture or mural imported into the United States in violation of this chapter shall be seized and subject to forfeiture under the customs laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Disposition of articles","label":"b Disposition of articles","identifier":"/us/usc/t19/s2093/b","parentIdentifier":"/us/usc/t19/s2093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2093%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s2093/b/1","parentIdentifier":"/us/usc/t19/s2093/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2093%2Fb%2F1","sourceRelease":"119-100","text":"first be offered for return to the country of origin and shall be returned if that country bears all expenses incurred incident to such return and complies with such other requirements relating to the return as the Secretary shall prescribe; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s2093/b/2","parentIdentifier":"/us/usc/t19/s2093/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2093%2Fb%2F2","sourceRelease":"119-100","text":"if not returned to the country of origin, be disposed of in the manner prescribed by law for articles forfeited for violation of the customs laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
