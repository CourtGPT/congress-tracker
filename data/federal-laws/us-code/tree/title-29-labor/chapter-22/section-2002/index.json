{"type":"section","nativeType":"section","number":"2002","heading":"Prohibitions on lie detector use","label":"2002 Prohibitions on lie detector use","identifier":"/us/usc/t29/s2002","parentIdentifier":"/us/usc/t29/ch22","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2002","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective 6 months after , except that rules and regulations shall be issued not later than 90 days after , see , set out as a note under .June 27, 1988June 27, 1988section 11 of Pub. L. 100–347section 2001 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s2002/1","parentIdentifier":"/us/usc/t29/s2002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2002%2F1","sourceRelease":"119-100","text":"directly or indirectly, to require, request, suggest, or cause any employee or prospective employee to take or submit to any lie detector test;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s2002/2","parentIdentifier":"/us/usc/t29/s2002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2002%2F2","sourceRelease":"119-100","text":"to use, accept, refer to, or inquire concerning the results of any lie detector test of any employee or prospective employee;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t29/s2002/3","parentIdentifier":"/us/usc/t29/s2002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2002%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s2002/3/A","parentIdentifier":"/us/usc/t29/s2002/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2002%2F3%2FA","sourceRelease":"119-100","text":"any employee or prospective employee who refuses, declines, or fails to take or submit to any lie detector test, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s2002/3/B","parentIdentifier":"/us/usc/t29/s2002/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2002%2F3%2FB","sourceRelease":"119-100","text":"any employee or prospective employee on the basis of the results of any lie detector test; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t29/s2002/4","parentIdentifier":"/us/usc/t29/s2002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2002%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s2002/4/A","parentIdentifier":"/us/usc/t29/s2002/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2002%2F4%2FA","sourceRelease":"119-100","text":"such employee or prospective employee has filed any complaint or instituted or caused to be instituted any proceeding under or related to this chapter,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s2002/4/B","parentIdentifier":"/us/usc/t29/s2002/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2002%2F4%2FB","sourceRelease":"119-100","text":"such employee or prospective employee has testified or is about to testify in any such proceeding, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t29/s2002/4/C","parentIdentifier":"/us/usc/t29/s2002/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2002%2F4%2FC","sourceRelease":"119-100","text":"of the exercise by such employee or prospective employee, on behalf of such employee or another person, of any right afforded by this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
