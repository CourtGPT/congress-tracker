{"type":"section","nativeType":"section","number":"80q–1","heading":"National Museum of the American Indian","label":"80q–1 National Museum of the American Indian","identifier":"/us/usc/t20/s80q–1","parentIdentifier":"/us/usc/t20/ch3/schXIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%931","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t20/s80q–1/a","parentIdentifier":"/us/usc/t20/s80q–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%931%2Fa","sourceRelease":"119-100","text":"There is established, within the Smithsonian Institution, a living memorial to Native Americans and their traditions which shall be known as the “National Museum of the American Indian”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purposes","label":"b Purposes","identifier":"/us/usc/t20/s80q–1/b","parentIdentifier":"/us/usc/t20/s80q–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%931%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s80q–1/b/1","parentIdentifier":"/us/usc/t20/s80q–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%931%2Fb%2F1","sourceRelease":"119-100","text":"advance the study of Native Americans, including the study of language, literature, history, art, anthropology, and life;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s80q–1/b/2","parentIdentifier":"/us/usc/t20/s80q–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%931%2Fb%2F2","sourceRelease":"119-100","text":"collect, preserve, and exhibit Native American objects of artistic, historical, literary, anthropological, and scientific interest;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s80q–1/b/3","parentIdentifier":"/us/usc/t20/s80q–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%931%2Fb%2F3","sourceRelease":"119-100","text":"provide for Native American research and study programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s80q–1/b/4","parentIdentifier":"/us/usc/t20/s80q–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%931%2Fb%2F4","sourceRelease":"119-100","text":"provide for the means of carrying out paragraphs (1), (2), and (3) in the District of Columbia, the State of New York, and other appropriate locations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
