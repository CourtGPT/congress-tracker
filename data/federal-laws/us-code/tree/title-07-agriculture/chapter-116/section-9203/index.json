{"type":"section","nativeType":"section","number":"9203","heading":"Evaluation and research plan","label":"9203 Evaluation and research plan","identifier":"/us/usc/t7/s9203","parentIdentifier":"/us/usc/t7/ch116","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t7/s9203/a","parentIdentifier":"/us/usc/t7/s9203","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s9203/a/1","parentIdentifier":"/us/usc/t7/s9203/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203%2Fa%2F1","sourceRelease":"119-100","text":"evaluate the work of the National Bio and Agro-Defense Facility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s9203/a/2","parentIdentifier":"/us/usc/t7/s9203/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s9203/a/2/A","parentIdentifier":"/us/usc/t7/s9203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203%2Fa%2F2%2FA","sourceRelease":"119-100","text":"develop veterinary countermeasures for emerging foreign animal diseases and animal transboundary diseases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s9203/a/2/B","parentIdentifier":"/us/usc/t7/s9203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203%2Fa%2F2%2FB","sourceRelease":"119-100","text":"provide advanced testing, diagnostic, and evaluation capabilities for threat detection, vulnerability assessments of animal and zoonotic diseases, and veterinary countermeasures for animal and zoonotic diseases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s9203/a/2/C","parentIdentifier":"/us/usc/t7/s9203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203%2Fa%2F2%2FC","sourceRelease":"119-100","text":"assist, as appropriate, with the development, and address vulnerability assessments, of the agriculture and food sectors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s9203/a/2/D","parentIdentifier":"/us/usc/t7/s9203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203%2Fa%2F2%2FD","sourceRelease":"119-100","text":"address gaps in the ongoing animal and zoonotic disease research efforts across the Federal Government, ensuring not to duplicate those ongoing efforts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s9203/a/2/E","parentIdentifier":"/us/usc/t7/s9203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203%2Fa%2F2%2FE","sourceRelease":"119-100","text":"be used for such other purposes as the Secretary of Agriculture, in consultation with the Secretary of Homeland Security and the heads of other appropriate Federal departments and agencies, determines to be appropriate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s9203/a/3","parentIdentifier":"/us/usc/t7/s9203/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203%2Fa%2F3","sourceRelease":"119-100","text":"submit to the Committee on Agriculture, Nutrition, and Forestry of the Senate, the Committee on Homeland Security and Governmental Affairs of the Senate, the Committee on Agriculture of the House of Representatives, and the Committee on Homeland Security of the House of Representatives, the strategic plan for research described in paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Classified information","label":"b Classified information","identifier":"/us/usc/t7/s9203/b","parentIdentifier":"/us/usc/t7/s9203","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s9203/b/1","parentIdentifier":"/us/usc/t7/s9203/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203%2Fb%2F1","sourceRelease":"119-100","text":"shall be published in an unclassified format that is publicly available;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s9203/b/2","parentIdentifier":"/us/usc/t7/s9203/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203%2Fb%2F2","sourceRelease":"119-100","text":"shall be submitted under subsection (a)(3) in unclassified form; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s9203/b/3","parentIdentifier":"/us/usc/t7/s9203/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9203%2Fb%2F3","sourceRelease":"119-100","text":"may include in the submission under subsection (a)(3) a classified annex for any sensitive or classified information, as necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
