{"type":"section","nativeType":"section","number":"2261B","heading":"Enhanced penalty for stalkers of children","label":"2261B Enhanced penalty for stalkers of children","identifier":"/us/usc/t18/s2261B","parentIdentifier":"/us/usc/t18/ptI/ch110A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2261B","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t18/s2261B/a","parentIdentifier":"/us/usc/t18/s2261B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2261B%2Fa","sourceRelease":"119-100","text":"Except as provided in subsection (b), if the victim of an offense under section 2261A is under the age of 18 years, the maximum imprisonment for the offense is 5 years greater than the maximum term of imprisonment otherwise provided for that offense in section 2261.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Limitation","label":"b .—Limitation","identifier":"/us/usc/t18/s2261B/b","parentIdentifier":"/us/usc/t18/s2261B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2261B%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2261B/b/1","parentIdentifier":"/us/usc/t18/s2261B/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2261B%2Fb%2F1","sourceRelease":"119-100","text":"the person is subject to a sentence under section 2261(b)(5); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2261B/b/2","parentIdentifier":"/us/usc/t18/s2261B/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2261B%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s2261B/b/2/A","parentIdentifier":"/us/usc/t18/s2261B/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2261B%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the person is under the age of 18 at the time the offense occurred; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s2261B/b/2/B","parentIdentifier":"/us/usc/t18/s2261B/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2261B%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the victim of the offense is not less than 15 nor more than 17 years of age and not more than 3 years younger than the person who committed the offense at the time the offense occurred.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
