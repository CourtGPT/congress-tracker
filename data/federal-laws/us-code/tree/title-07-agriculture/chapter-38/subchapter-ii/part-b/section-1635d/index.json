{"type":"section","nativeType":"section","number":"1635d","heading":"Definitions","label":"1635d Definitions","identifier":"/us/usc/t7/s1635d","parentIdentifier":"/us/usc/t7/ch38/schII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Cattle committed","label":"1 Cattle committed","identifier":"/us/usc/t7/s1635d/1","parentIdentifier":"/us/usc/t7/s1635d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F1","sourceRelease":"119-100","text":"The term “cattle committed” means cattle that are scheduled to be delivered to a packer within the 7-day period beginning on the date of an agreement to sell the cattle.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Cattle type","label":"2 Cattle type","identifier":"/us/usc/t7/s1635d/2","parentIdentifier":"/us/usc/t7/s1635d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1635d/2/A","parentIdentifier":"/us/usc/t7/s1635d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F2%2FA","sourceRelease":"119-100","text":"Fed steers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1635d/2/B","parentIdentifier":"/us/usc/t7/s1635d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F2%2FB","sourceRelease":"119-100","text":"Fed heifers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s1635d/2/C","parentIdentifier":"/us/usc/t7/s1635d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F2%2FC","sourceRelease":"119-100","text":"Fed Holsteins and other fed dairy steers and heifers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s1635d/2/D","parentIdentifier":"/us/usc/t7/s1635d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F2%2FD","sourceRelease":"119-100","text":"Cows.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s1635d/2/E","parentIdentifier":"/us/usc/t7/s1635d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F2%2FE","sourceRelease":"119-100","text":"Bulls.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Formula marketing arrangement","label":"3 Formula marketing arrangement","identifier":"/us/usc/t7/s1635d/3","parentIdentifier":"/us/usc/t7/s1635d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F3","sourceRelease":"119-100","text":"The term “formula marketing arrangement” means the advance commitment of cattle for slaughter by any means other than through a negotiated purchase or a forward contract, using a method for calculating price in which the price is determined at a future date.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Forward contract","label":"4 Forward contract","identifier":"/us/usc/t7/s1635d/4","parentIdentifier":"/us/usc/t7/s1635d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1635d/4/A","parentIdentifier":"/us/usc/t7/s1635d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1635d/4/A/i","parentIdentifier":"/us/usc/t7/s1635d/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F4%2FA%2Fi","sourceRelease":"119-100","text":"prices quoted on the Chicago Mercantile Exchange; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1635d/4/A/ii","parentIdentifier":"/us/usc/t7/s1635d/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F4%2FA%2Fii","sourceRelease":"119-100","text":"other comparable publicly available prices; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1635d/4/B","parentIdentifier":"/us/usc/t7/s1635d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F4%2FB","sourceRelease":"119-100","text":"such other forward contract as the Secretary determines to be applicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Packer","label":"5 Packer","identifier":"/us/usc/t7/s1635d/5","parentIdentifier":"/us/usc/t7/s1635d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1635d/5/A","parentIdentifier":"/us/usc/t7/s1635d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F5%2FA","sourceRelease":"119-100","text":"the term includes only a cattle processing plant that is federally inspected;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1635d/5/B","parentIdentifier":"/us/usc/t7/s1635d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F5%2FB","sourceRelease":"119-100","text":"for any calendar year, the term includes only a cattle processing plant that slaughtered an average of at least 125,000 head of cattle per year during the immediately preceding 5 calendar years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s1635d/5/C","parentIdentifier":"/us/usc/t7/s1635d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F5%2FC","sourceRelease":"119-100","text":"in the case of a cattle processing plant that did not slaughter cattle during the immediately preceding 5 calendar years, the Secretary shall consider the plant capacity of the processing plant in determining whether the processing plant should be considered a packer under this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Packer-owned cattle","label":"6 Packer-owned cattle","identifier":"/us/usc/t7/s1635d/6","parentIdentifier":"/us/usc/t7/s1635d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F6","sourceRelease":"119-100","text":"The term “packer-owned cattle” means cattle that a packer owns for at least 14 days immediately before slaughter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Terms of trade","label":"7 Terms of trade","identifier":"/us/usc/t7/s1635d/7","parentIdentifier":"/us/usc/t7/s1635d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1635d/7/A","parentIdentifier":"/us/usc/t7/s1635d/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F7%2FA","sourceRelease":"119-100","text":"whether a packer provided any financing agreement or arrangement with regard to the cattle;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1635d/7/B","parentIdentifier":"/us/usc/t7/s1635d/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F7%2FB","sourceRelease":"119-100","text":"whether the delivery terms specified the location of the producer or the location of the packer’s plant;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s1635d/7/C","parentIdentifier":"/us/usc/t7/s1635d/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F7%2FC","sourceRelease":"119-100","text":"whether the producer is able to unilaterally specify the date and time during the business day of the packer that the cattle are to be delivered for slaughter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s1635d/7/D","parentIdentifier":"/us/usc/t7/s1635d/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F7%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1635d/7/D/i","parentIdentifier":"/us/usc/t7/s1635d/7/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F7%2FD%2Fi","sourceRelease":"119-100","text":"the date on which the cattle were committed to the packer; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1635d/7/D/ii","parentIdentifier":"/us/usc/t7/s1635d/7/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F7%2FD%2Fii","sourceRelease":"119-100","text":"the date on which the cattle were purchased by the packer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Type of purchase","label":"8 Type of purchase","identifier":"/us/usc/t7/s1635d/8","parentIdentifier":"/us/usc/t7/s1635d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1635d/8/A","parentIdentifier":"/us/usc/t7/s1635d/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F8%2FA","sourceRelease":"119-100","text":"a negotiated purchase;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1635d/8/B","parentIdentifier":"/us/usc/t7/s1635d/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F8%2FB","sourceRelease":"119-100","text":"a formula market arrangement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s1635d/8/C","parentIdentifier":"/us/usc/t7/s1635d/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635d%2F8%2FC","sourceRelease":"119-100","text":"a forward contract.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
