{"type":"section","nativeType":"section","number":"4332","heading":"Joint import safety rapid response plan","label":"4332 Joint import safety rapid response plan","identifier":"/us/usc/t19/s4332","parentIdentifier":"/us/usc/t19/ch28/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t19/s4332/a","parentIdentifier":"/us/usc/t19/s4332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4332/a/1","parentIdentifier":"/us/usc/t19/s4332/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fa%2F1","sourceRelease":"119-100","text":"in taking action in response to, and coordinating Federal responses to, an incident in which cargo destined for or merchandise entering the United States has been identified as posing a threat to the health or safety of consumers in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4332/a/2","parentIdentifier":"/us/usc/t19/s4332/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fa%2F2","sourceRelease":"119-100","text":"in recovering from or mitigating the effects of actions and responses to an incident described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Contents","label":"b Contents","identifier":"/us/usc/t19/s4332/b","parentIdentifier":"/us/usc/t19/s4332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4332/b/1","parentIdentifier":"/us/usc/t19/s4332/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fb%2F1","sourceRelease":"119-100","text":"the statutory and regulatory authorities and responsibilities of U.S. Customs and Border Protection and other Federal agencies in responding to an incident described in subsection (a)(1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4332/b/2","parentIdentifier":"/us/usc/t19/s4332/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fb%2F2","sourceRelease":"119-100","text":"the protocols and practices to be used by U.S. Customs and Border Protection when taking action in response to, and coordinating Federal responses to, such an incident;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s4332/b/3","parentIdentifier":"/us/usc/t19/s4332/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fb%2F3","sourceRelease":"119-100","text":"the measures to be taken by U.S. Customs and Border Protection and other Federal agencies in recovering from or mitigating the effects of actions taken in response to such an incident after the incident to ensure the resumption of the entry of merchandise into the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t19/s4332/b/4","parentIdentifier":"/us/usc/t19/s4332/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fb%2F4","sourceRelease":"119-100","text":"exercises that U.S. Customs and Border Protection may conduct in conjunction with Federal, State, and local agencies, and private sector entities, to simulate responses to such an incident.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Updates of plan","label":"c Updates of plan","identifier":"/us/usc/t19/s4332/c","parentIdentifier":"/us/usc/t19/s4332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fc","sourceRelease":"119-100","text":"The Secretary of Homeland Security shall review and update the joint import safety rapid response plan, as appropriate, after conducting exercises under subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Import health and safety exercises","label":"d Import health and safety exercises","identifier":"/us/usc/t19/s4332/d","parentIdentifier":"/us/usc/t19/s4332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t19/s4332/d/1","parentIdentifier":"/us/usc/t19/s4332/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary of Homeland Security and the Commissioner shall periodically engage in the exercises referred to in subsection (b)(4), in conjunction with Federal, State, and local agencies and private sector entities, as appropriate, to test and evaluate the protocols and practices identified in the joint import safety rapid response plan at United States ports of entry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements for exercises","label":"2 Requirements for exercises","identifier":"/us/usc/t19/s4332/d/2","parentIdentifier":"/us/usc/t19/s4332/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s4332/d/2/A","parentIdentifier":"/us/usc/t19/s4332/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F2%2FA","sourceRelease":"119-100","text":"make allowance for the resources, needs, and constraints of United States ports of entry of different sizes in representative geographic locations across the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s4332/d/2/B","parentIdentifier":"/us/usc/t19/s4332/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F2%2FB","sourceRelease":"119-100","text":"base evaluations on current risk assessments of merchandise entering the United States at representative United States ports of entry located across the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t19/s4332/d/2/C","parentIdentifier":"/us/usc/t19/s4332/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F2%2FC","sourceRelease":"119-100","text":"ensure that such exercises are conducted in a manner consistent with the National Incident Management System, the National Response Plan, the National Infrastructure Protection Plan, the National Preparedness Guidelines, the Maritime Transportation System Security Plan, and other such national initiatives of the Department of Homeland Security, as appropriate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t19/s4332/d/2/D","parentIdentifier":"/us/usc/t19/s4332/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F2%2FD","sourceRelease":"119-100","text":"develop metrics with respect to the resumption of the entry of merchandise into the United States after an incident described in subsection (a)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Requirements for testing and evaluation","label":"3 Requirements for testing and evaluation","identifier":"/us/usc/t19/s4332/d/3","parentIdentifier":"/us/usc/t19/s4332/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s4332/d/3/A","parentIdentifier":"/us/usc/t19/s4332/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F3%2FA","sourceRelease":"119-100","text":"are performed using clear and objective performance measures; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s4332/d/3/B","parentIdentifier":"/us/usc/t19/s4332/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F3%2FB","sourceRelease":"119-100","text":"result in the identification of specific recommendations or best practices for responding to an incident described in subsection (a)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Dissemination of recommendations and best practices","label":"4 Dissemination of recommendations and best practices","identifier":"/us/usc/t19/s4332/d/4","parentIdentifier":"/us/usc/t19/s4332/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s4332/d/4/A","parentIdentifier":"/us/usc/t19/s4332/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s4332/d/4/A/i","parentIdentifier":"/us/usc/t19/s4332/d/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F4%2FA%2Fi","sourceRelease":"119-100","text":"State, local, and tribal governments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s4332/d/4/A/ii","parentIdentifier":"/us/usc/t19/s4332/d/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F4%2FA%2Fii","sourceRelease":"119-100","text":"foreign governments; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t19/s4332/d/4/A/iii","parentIdentifier":"/us/usc/t19/s4332/d/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F4%2FA%2Fiii","sourceRelease":"119-100","text":"private sector entities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s4332/d/4/B","parentIdentifier":"/us/usc/t19/s4332/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4332%2Fd%2F4%2FB","sourceRelease":"119-100","text":"use such recommendations and best practices to update the joint import safety rapid response plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
