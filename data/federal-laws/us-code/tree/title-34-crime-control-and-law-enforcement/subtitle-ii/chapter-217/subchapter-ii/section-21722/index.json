{"type":"section","nativeType":"section","number":"21722","heading":"Effective interagency coordination and Federal data collection","label":"21722 Effective interagency coordination and Federal data collection","identifier":"/us/usc/t34/s21722","parentIdentifier":"/us/usc/t34/stII/ch217/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t34/s21722/a","parentIdentifier":"/us/usc/t34/s21722","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s21722/a/1","parentIdentifier":"/us/usc/t34/s21722/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fa%2F1","sourceRelease":"119-100","text":"collect from Federal law enforcement agencies, other agencies as appropriate, and Federal prosecutors’ offices statistical data related to elder abuse cases, including cases or investigations where one or more victims were elders, or the case or investigation involved a financial scheme or scam that was either targeted directly toward or largely affected elders; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s21722/a/2","parentIdentifier":"/us/usc/t34/s21722/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s21722/a/2/A","parentIdentifier":"/us/usc/t34/s21722/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fa%2F2%2FA","sourceRelease":"119-100","text":"a summary of the data collected under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s21722/a/2/B","parentIdentifier":"/us/usc/t34/s21722/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fa%2F2%2FB","sourceRelease":"119-100","text":"recommendations for collecting additional data relating to elder abuse, including recommendations for ways to improve data reporting across Federal, State, and local agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirement","label":"b Requirement","identifier":"/us/usc/t34/s21722/b","parentIdentifier":"/us/usc/t34/s21722","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s21722/b/1","parentIdentifier":"/us/usc/t34/s21722/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fb%2F1","sourceRelease":"119-100","text":"the total number of investigations initiated by Federal law enforcement agencies, other agencies as appropriate, and Federal prosecutors’ offices related to elder abuse;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s21722/b/2","parentIdentifier":"/us/usc/t34/s21722/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fb%2F2","sourceRelease":"119-100","text":"the total number and types of elder abuse cases filed in Federal courts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s21722/b/3","parentIdentifier":"/us/usc/t34/s21722/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s21722/b/3/A","parentIdentifier":"/us/usc/t34/s21722/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the name of the district where the case originated;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s21722/b/3/B","parentIdentifier":"/us/usc/t34/s21722/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fb%2F3%2FB","sourceRelease":"119-100","text":"the style of the case, including the case name and number;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s21722/b/3/C","parentIdentifier":"/us/usc/t34/s21722/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fb%2F3%2FC","sourceRelease":"119-100","text":"a description of the act or acts giving rise to the elder abuse;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s21722/b/3/D","parentIdentifier":"/us/usc/t34/s21722/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fb%2F3%2FD","sourceRelease":"119-100","text":"in the case of a scheme or scam, a description of such scheme or scam giving rise to the elder abuse;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t34/s21722/b/3/E","parentIdentifier":"/us/usc/t34/s21722/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fb%2F3%2FE","sourceRelease":"119-100","text":"information about each alleged perpetrator of the elder abuse; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t34/s21722/b/3/F","parentIdentifier":"/us/usc/t34/s21722/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fb%2F3%2FF","sourceRelease":"119-100","text":"the outcome of the case.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"HHS requirement","label":"c HHS requirement","identifier":"/us/usc/t34/s21722/c","parentIdentifier":"/us/usc/t34/s21722","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fc","sourceRelease":"119-100","text":"The Secretary of Health and Human Services shall, on an annual basis, provide to the Attorney General statistical data collected by the Secretary relating to elder abuse cases investigated by adult protective services, which shall be included in the summary published under subsection (a)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Prohibition on individual data","label":"d Prohibition on individual data","identifier":"/us/usc/t34/s21722/d","parentIdentifier":"/us/usc/t34/s21722","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21722%2Fd","sourceRelease":"119-100","text":"None of the information reported under this section shall include specific individually identifiable data.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
