{"type":"section","nativeType":"section","number":"15108","heading":"National Towing Safety Advisory Committee","label":"15108 National Towing Safety Advisory Committee","identifier":"/us/usc/t46/s15108","parentIdentifier":"/us/usc/t46/stII/ptK/ch151","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t46/s15108/a","parentIdentifier":"/us/usc/t46/s15108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fa","sourceRelease":"119-100","text":"There is established a National Towing Safety Advisory Committee (in this section referred to as the “Committee”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Function","label":"b .—Function","identifier":"/us/usc/t46/s15108/b","parentIdentifier":"/us/usc/t46/s15108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fb","sourceRelease":"119-100","text":"The Committee shall advise the Secretary on matters relating to shallow-draft inland navigation, coastal waterway navigation, and towing safety.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Membership.—","label":"c Membership.—","identifier":"/us/usc/t46/s15108/c","parentIdentifier":"/us/usc/t46/s15108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t46/s15108/c/1","parentIdentifier":"/us/usc/t46/s15108/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fc%2F1","sourceRelease":"119-100","text":"The Committee shall consist of 18 members appointed by the Secretary in accordance with this section and section 15109 of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Expertise","label":"2 .—Expertise","identifier":"/us/usc/t46/s15108/c/2","parentIdentifier":"/us/usc/t46/s15108/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fc%2F2","sourceRelease":"119-100","text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Representation","label":"3 .—Representation","identifier":"/us/usc/t46/s15108/c/3","parentIdentifier":"/us/usc/t46/s15108/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s15108/c/3/A","parentIdentifier":"/us/usc/t46/s15108/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fc%2F3%2FA","sourceRelease":"119-100","text":"7 members shall represent the barge and towing industry, reflecting a regional geographic balance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s15108/c/3/B","parentIdentifier":"/us/usc/t46/s15108/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fc%2F3%2FB","sourceRelease":"119-100","text":"1 member shall represent the offshore mineral and oil supply vessel industry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t46/s15108/c/3/C","parentIdentifier":"/us/usc/t46/s15108/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fc%2F3%2FC","sourceRelease":"119-100","text":"1 member shall represent masters and pilots of towing vessels who hold active licenses and have experience on the Western Rivers and the Gulf Intracoastal Waterway.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t46/s15108/c/3/D","parentIdentifier":"/us/usc/t46/s15108/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fc%2F3%2FD","sourceRelease":"119-100","text":"1 member shall represent masters of towing vessels in offshore service who hold active licenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t46/s15108/c/3/E","parentIdentifier":"/us/usc/t46/s15108/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fc%2F3%2FE","sourceRelease":"119-100","text":"1 member shall represent masters of active ship-docking or harbor towing vessels.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t46/s15108/c/3/F","parentIdentifier":"/us/usc/t46/s15108/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fc%2F3%2FF","sourceRelease":"119-100","text":"1 member shall represent licensed and unlicensed towing vessel engineers with formal training and experience.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t46/s15108/c/3/G","parentIdentifier":"/us/usc/t46/s15108/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fc%2F3%2FG","sourceRelease":"119-100","text":"2 members shall represent port districts, authorities, or terminal operators.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t46/s15108/c/3/H","parentIdentifier":"/us/usc/t46/s15108/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fc%2F3%2FH","sourceRelease":"119-100","text":"2 members shall represent shippers and, of the 2, 1 shall be engaged in the shipment of oil or hazardous materials by barge.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t46/s15108/c/3/I","parentIdentifier":"/us/usc/t46/s15108/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15108%2Fc%2F3%2FI","sourceRelease":"119-100","text":"2 members shall represent the general public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
