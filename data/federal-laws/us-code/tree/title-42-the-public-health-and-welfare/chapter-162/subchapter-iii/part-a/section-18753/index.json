{"type":"section","nativeType":"section","number":"18753","heading":"Civil nuclear credit program","label":"18753 Civil nuclear credit program","identifier":"/us/usc/t42/s18753","parentIdentifier":"/us/usc/t42/ch162/schIII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Wage Rate RequirementsFor provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of , including authority of Secretary of Labor, see .Pub. L. 117–58section 18851 of this title"],"amendments":["Wage Rate RequirementsFor provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of , including authority of Secretary of Labor, see .Pub. L. 117–58section 18851 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s18753/a","parentIdentifier":"/us/usc/t42/s18753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Certified nuclear reactor","label":"1 Certified nuclear reactor","identifier":"/us/usc/t42/s18753/a/1","parentIdentifier":"/us/usc/t42/s18753/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18753/a/1/A","parentIdentifier":"/us/usc/t42/s18753/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fa%2F1%2FA","sourceRelease":"119-100","text":"competes in a competitive electricity market; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18753/a/1/B","parentIdentifier":"/us/usc/t42/s18753/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fa%2F1%2FB","sourceRelease":"119-100","text":"is certified under subsection (c)(2)(A)(i) to submit a sealed bid in accordance with subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Credit","label":"2 Credit","identifier":"/us/usc/t42/s18753/a/2","parentIdentifier":"/us/usc/t42/s18753/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fa%2F2","sourceRelease":"119-100","text":"The term “credit” means a credit allocated to a certified nuclear reactor under subsection (e)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment of program","label":"b Establishment of program","identifier":"/us/usc/t42/s18753/b","parentIdentifier":"/us/usc/t42/s18753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18753/b/1","parentIdentifier":"/us/usc/t42/s18753/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fb%2F1","sourceRelease":"119-100","text":"to evaluate nuclear reactors that are projected to cease operations due to economic factors; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18753/b/2","parentIdentifier":"/us/usc/t42/s18753/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fb%2F2","sourceRelease":"119-100","text":"to allocate credits to certified nuclear reactors that are selected under paragraph (1)(B) of subsection (e) to receive credits under paragraph (2) of that subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Certification","label":"c Certification","identifier":"/us/usc/t42/s18753/c","parentIdentifier":"/us/usc/t42/s18753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Application","label":"1 Application","identifier":"/us/usc/t42/s18753/c/1","parentIdentifier":"/us/usc/t42/s18753/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s18753/c/1/A","parentIdentifier":"/us/usc/t42/s18753/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18753/c/1/A/i","parentIdentifier":"/us/usc/t42/s18753/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s18753/c/1/A/i/I","parentIdentifier":"/us/usc/t42/s18753/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FA%2Fi%2FI","sourceRelease":"119-100","text":"the average projected annual operating loss in dollars per megawatt-hour, inclusive of the cost of operational and market risks, expected to be incurred by the nuclear reactor over the 4-year period for which credits would be allocated;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s18753/c/1/A/i/II","parentIdentifier":"/us/usc/t42/s18753/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FA%2Fi%2FII","sourceRelease":"119-100","text":"any private or publicly available data with respect to current or projected bulk power market prices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t42/s18753/c/1/A/i/III","parentIdentifier":"/us/usc/t42/s18753/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FA%2Fi%2FIII","sourceRelease":"119-100","text":"out-of-market revenue streams;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t42/s18753/c/1/A/i/IV","parentIdentifier":"/us/usc/t42/s18753/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FA%2Fi%2FIV","sourceRelease":"119-100","text":"operations and maintenance costs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t42/s18753/c/1/A/i/V","parentIdentifier":"/us/usc/t42/s18753/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FA%2Fi%2FV","sourceRelease":"119-100","text":"capital costs, including fuel; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VI","heading":null,"label":"VI","identifier":"/us/usc/t42/s18753/c/1/A/i/VI","parentIdentifier":"/us/usc/t42/s18753/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FA%2Fi%2FVI","sourceRelease":"119-100","text":"operational and market risks;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18753/c/1/A/ii","parentIdentifier":"/us/usc/t42/s18753/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"an estimate of the potential incremental air pollutants that would result if the nuclear reactor were to cease operations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s18753/c/1/A/iii","parentIdentifier":"/us/usc/t42/s18753/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"known information on the source of produced uranium and the location where the uranium is converted, enriched, and fabricated into fuel assemblies for the nuclear reactor for the 4-year period for which credits would be allocated; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s18753/c/1/A/iv","parentIdentifier":"/us/usc/t42/s18753/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FA%2Fiv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s18753/c/1/A/iv/I","parentIdentifier":"/us/usc/t42/s18753/c/1/A/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FA%2Fiv%2FI","sourceRelease":"119-100","text":"without receiving additional credits; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s18753/c/1/A/iv/II","parentIdentifier":"/us/usc/t42/s18753/c/1/A/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FA%2Fiv%2FII","sourceRelease":"119-100","text":"with the receipt of additional credits of a lower amount than the credits allocated during that 4-year credit period.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Timeline","label":"B Timeline","identifier":"/us/usc/t42/s18753/c/1/B","parentIdentifier":"/us/usc/t42/s18753/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18753/c/1/B/i","parentIdentifier":"/us/usc/t42/s18753/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"until the date that is 120 days after ; andNovember 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18753/c/1/B/ii","parentIdentifier":"/us/usc/t42/s18753/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"not less frequently than every year thereafter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Payments from State programs","label":"C Payments from State programs","identifier":"/us/usc/t42/s18753/c/1/C","parentIdentifier":"/us/usc/t42/s18753/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t42/s18753/c/1/C/i","parentIdentifier":"/us/usc/t42/s18753/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FC%2Fi","sourceRelease":"119-100","text":"The owner or operator of a nuclear reactor that receives a payment from a State zero-emission credit, a State clean energy contract, or any other State program with respect to that nuclear reactor shall be eligible to submit an application under subparagraph (A) with respect to that nuclear reactor during any application period beginning after the 120-day period beginning on .November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Requirement","label":"ii Requirement","identifier":"/us/usc/t42/s18753/c/1/C/ii","parentIdentifier":"/us/usc/t42/s18753/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F1%2FC%2Fii","sourceRelease":"119-100","text":"An application submitted by an owner or operator described in clause (i) with respect to a nuclear reactor described in that clause shall include all projected payments from State programs in determining the average projected annual operating loss described in subparagraph (A)(i)(I), unless the credits allocated to the nuclear reactor pursuant to that application will be used to reduce those payments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Determination to certify","label":"2 Determination to certify","identifier":"/us/usc/t42/s18753/c/2","parentIdentifier":"/us/usc/t42/s18753/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Determination","label":"A Determination","identifier":"/us/usc/t42/s18753/c/2/A","parentIdentifier":"/us/usc/t42/s18753/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t42/s18753/c/2/A/i","parentIdentifier":"/us/usc/t42/s18753/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"Not later than 60 days after the applicable date under subparagraph (B) of paragraph (1), the Secretary shall determine whether to certify, in accordance with clauses (ii) and (iii), each nuclear reactor for which an application is submitted under subparagraph (A) of that paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Minimum requirements","label":"ii Minimum requirements","identifier":"/us/usc/t42/s18753/c/2/A/ii","parentIdentifier":"/us/usc/t42/s18753/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s18753/c/2/A/ii/I","parentIdentifier":"/us/usc/t42/s18753/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F2%2FA%2Fii%2FI","sourceRelease":"119-100","text":"after considering the information submitted under paragraph (1)(A)(i), the Secretary determines that the nuclear reactor is projected to cease operations due to economic factors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s18753/c/2/A/ii/II","parentIdentifier":"/us/usc/t42/s18753/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F2%2FA%2Fii%2FII","sourceRelease":"119-100","text":"after considering the estimate submitted under paragraph (1)(A)(ii), the Secretary determines that pollutants would increase if the nuclear reactor were to cease operations and be replaced with other types of power generation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t42/s18753/c/2/A/ii/III","parentIdentifier":"/us/usc/t42/s18753/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F2%2FA%2Fii%2FIII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t42/s18753/c/2/A/ii/III/aa","parentIdentifier":"/us/usc/t42/s18753/c/2/A/ii/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F2%2FA%2Fii%2FIII%2Faa","sourceRelease":"119-100","text":"will continue to be operated in accordance with the current licensing basis (as defined in section 54.3 of title 10, Code of Federal Regulations (or successor regulations) of the nuclear reactor; and1So in original. Probably should be followed by a second closing parenthesis.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t42/s18753/c/2/A/ii/III/bb","parentIdentifier":"/us/usc/t42/s18753/c/2/A/ii/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F2%2FA%2Fii%2FIII%2Fbb","sourceRelease":"119-100","text":"poses no significant safety hazards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":"Priority","label":"iii Priority","identifier":"/us/usc/t42/s18753/c/2/A/iii","parentIdentifier":"/us/usc/t42/s18753/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"In determining whether to certify a nuclear reactor under clause (i), the Secretary shall give priority to a nuclear reactor that uses, to the maximum extent available, uranium that is produced, converted, enriched, and fabricated into fuel assemblies in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Notice","label":"B Notice","identifier":"/us/usc/t42/s18753/c/2/B","parentIdentifier":"/us/usc/t42/s18753/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18753/c/2/B/i","parentIdentifier":"/us/usc/t42/s18753/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"a notice of the certification of the applicable nuclear reactor; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18753/c/2/B/ii","parentIdentifier":"/us/usc/t42/s18753/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"a notice that describes the reasons why the certification of the applicable nuclear reactor was denied.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Bidding process","label":"d Bidding process","identifier":"/us/usc/t42/s18753/d","parentIdentifier":"/us/usc/t42/s18753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18753/d/1","parentIdentifier":"/us/usc/t42/s18753/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18753/d/1/A","parentIdentifier":"/us/usc/t42/s18753/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fd%2F1%2FA","sourceRelease":"119-100","text":"describes the price per megawatt-hour of the credits desired by the certified nuclear reactor, which shall not exceed the average projected annual operating loss described in subsection (c)(1)(A)(i)(I); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18753/d/1/B","parentIdentifier":"/us/usc/t42/s18753/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fd%2F1%2FB","sourceRelease":"119-100","text":"includes a commitment, subject to the receipt of credits, to provide a specific number of megawatt-hours of generation during the 4-year period for which credits would be allocated.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirement","label":"2 Requirement","identifier":"/us/usc/t42/s18753/d/2","parentIdentifier":"/us/usc/t42/s18753/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fd%2F2","sourceRelease":"119-100","text":"The deadline established under paragraph (1) shall be not later than 30 days after the first date on which the Secretary has made the determination described in paragraph (2)(A)(i) of subsection (c) with respect to each application submitted under paragraph (1)(A) of that subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Allocation","label":"e Allocation","identifier":"/us/usc/t42/s18753/e","parentIdentifier":"/us/usc/t42/s18753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Auction","label":"1 Auction","identifier":"/us/usc/t42/s18753/e/1","parentIdentifier":"/us/usc/t42/s18753/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18753/e/1/A","parentIdentifier":"/us/usc/t42/s18753/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fe%2F1%2FA","sourceRelease":"119-100","text":"in consultation with the heads of applicable Federal agencies, establish a process for evaluating bids submitted under subsection (d)(1) through an auction process; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18753/e/1/B","parentIdentifier":"/us/usc/t42/s18753/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fe%2F1%2FB","sourceRelease":"119-100","text":"select certified nuclear reactors to be allocated credits.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Credits","label":"2 Credits","identifier":"/us/usc/t42/s18753/e/2","parentIdentifier":"/us/usc/t42/s18753/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fe%2F2","sourceRelease":"119-100","text":"Subject to subsection (f)(2), on selection under paragraph (1), a certified nuclear reactor shall be allocated credits for a 4-year period beginning on the date of the selection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Requirement","label":"3 Requirement","identifier":"/us/usc/t42/s18753/e/3","parentIdentifier":"/us/usc/t42/s18753/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fe%2F3","sourceRelease":"119-100","text":"To the maximum extent practicable, the Secretary shall use the amounts made available for credits under this section to allocate credits to as many certified nuclear reactors as possible.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Renewal","label":"f Renewal","identifier":"/us/usc/t42/s18753/f","parentIdentifier":"/us/usc/t42/s18753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18753/f/1","parentIdentifier":"/us/usc/t42/s18753/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Ff%2F1","sourceRelease":"119-100","text":"The owner or operator of a certified nuclear reactor may seek to recertify the nuclear reactor in accordance with this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitation","label":"2 Limitation","identifier":"/us/usc/t42/s18753/f/2","parentIdentifier":"/us/usc/t42/s18753/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Ff%2F2","sourceRelease":"119-100","text":"Notwithstanding any other provision of this section, the Secretary may not allocate any credits after .September 30, 2031","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Additional requirements","label":"g Additional requirements","identifier":"/us/usc/t42/s18753/g","parentIdentifier":"/us/usc/t42/s18753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Audit","label":"1 Audit","identifier":"/us/usc/t42/s18753/g/1","parentIdentifier":"/us/usc/t42/s18753/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fg%2F1","sourceRelease":"119-100","text":"During the 4-year period beginning on the date on which a certified nuclear reactor first receives a credit, the Secretary shall periodically audit the certified nuclear reactor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Recapture","label":"2 Recapture","identifier":"/us/usc/t42/s18753/g/2","parentIdentifier":"/us/usc/t42/s18753/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fg%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18753/g/2/A","parentIdentifier":"/us/usc/t42/s18753/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fg%2F2%2FA","sourceRelease":"119-100","text":"terminates operations; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18753/g/2/B","parentIdentifier":"/us/usc/t42/s18753/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fg%2F2%2FB","sourceRelease":"119-100","text":"does not operate at an annual loss in the absence of an allocation of credits to the certified nuclear reactor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Confidentiality","label":"3 Confidentiality","identifier":"/us/usc/t42/s18753/g/3","parentIdentifier":"/us/usc/t42/s18753/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fg%2F3","sourceRelease":"119-100","text":"The Secretary shall establish procedures to ensure that any confidential, private, proprietary, or privileged information that is included in a sealed bid submitted under this section is not publicly disclosed or otherwise improperly used.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Report","label":"h Report","identifier":"/us/usc/t42/s18753/h","parentIdentifier":"/us/usc/t42/s18753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18753/h/1","parentIdentifier":"/us/usc/t42/s18753/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fh%2F1","sourceRelease":"119-100","text":"an evaluation of the effectiveness of the credits in avoiding air pollutants while ensuring grid reliability;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18753/h/2","parentIdentifier":"/us/usc/t42/s18753/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fh%2F2","sourceRelease":"119-100","text":"a quantification of the ratepayer savings achieved under this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18753/h/3","parentIdentifier":"/us/usc/t42/s18753/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fh%2F3","sourceRelease":"119-100","text":"any recommendations to renew or expand the credits.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Authorization of appropriations","label":"i Authorization of appropriations","identifier":"/us/usc/t42/s18753/i","parentIdentifier":"/us/usc/t42/s18753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18753%2Fi","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary to carry out this section $6,000,000,000 for the period of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
