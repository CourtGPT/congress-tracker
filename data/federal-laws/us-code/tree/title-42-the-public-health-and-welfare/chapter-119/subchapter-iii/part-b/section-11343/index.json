{"type":"section","nativeType":"section","number":"11343","heading":"Purposes of grants","label":"11343 Purposes of grants","identifier":"/us/usc/t42/s11343","parentIdentifier":"/us/usc/t42/ch119/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11343","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Eligible activities","label":"a Eligible activities","identifier":"/us/usc/t42/s11343/a","parentIdentifier":"/us/usc/t42/s11343","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11343%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s11343/a/1","parentIdentifier":"/us/usc/t42/s11343/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11343%2Fa%2F1","sourceRelease":"119-100","text":"to supplement and expand ongoing efforts to provide shelter, food, and supportive services for homeless individuals with sensitivity to the transition from temporary shelter to permanent homes, and attention to the special needs of homeless individuals with mental and physical disabilities and illnesses, and to facilitate access for homeless individuals to other sources of services and benefits;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s11343/a/2","parentIdentifier":"/us/usc/t42/s11343/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11343%2Fa%2F2","sourceRelease":"119-100","text":"to strengthen efforts to create more effective and innovative local programs by providing funding for them; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s11343/a/3","parentIdentifier":"/us/usc/t42/s11343/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11343%2Fa%2F3","sourceRelease":"119-100","text":"to conduct minimum rehabilitation of existing mass shelter or mass feeding facilities, but only to the extent necessary to make facilities safe, sanitary, and bring them into compliance with local building codes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitations on activities","label":"b Limitations on activities","identifier":"/us/usc/t42/s11343/b","parentIdentifier":"/us/usc/t42/s11343","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11343%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s11343/b/1","parentIdentifier":"/us/usc/t42/s11343/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11343%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s11343/b/1/A","parentIdentifier":"/us/usc/t42/s11343/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11343%2Fb%2F1%2FA","sourceRelease":"119-100","text":"programs undertaken by private nonprofit organizations and local governments; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s11343/b/1/B","parentIdentifier":"/us/usc/t42/s11343/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11343%2Fb%2F1%2FB","sourceRelease":"119-100","text":"programs that are consistent with the purposes of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s11343/b/2","parentIdentifier":"/us/usc/t42/s11343/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11343%2Fb%2F2","sourceRelease":"119-100","text":"The National Board may not carry out programs directly.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
