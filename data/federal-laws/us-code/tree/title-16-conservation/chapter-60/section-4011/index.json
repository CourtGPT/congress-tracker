{"type":"section","nativeType":"section","number":"4011","heading":"Functions and powers of Secretary","label":"4011 Functions and powers of Secretary","identifier":"/us/usc/t16/s4011","parentIdentifier":"/us/usc/t16/ch60","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4011","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Duties of the Secretary","label":"a Duties of the Secretary","identifier":"/us/usc/t16/s4011/a","parentIdentifier":"/us/usc/t16/s4011","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4011%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s4011/a/1","parentIdentifier":"/us/usc/t16/s4011/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4011%2Fa%2F1","sourceRelease":"119-100","text":"review, for consistency with the provisions of this chapter and other applicable law, and approve or disapprove, marketing and promotion plans and budgets within sixty days after their submission by a council;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s4011/a/2","parentIdentifier":"/us/usc/t16/s4011/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4011%2Fa%2F2","sourceRelease":"119-100","text":"immediately notify a council in writing of the disapproval of a marketing and promotion plan or budget, together with reasons for such disapproval;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s4011/a/3","parentIdentifier":"/us/usc/t16/s4011/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4011%2Fa%2F3","sourceRelease":"119-100","text":"issue orders and amendments to such orders that are necessary to implement quality standards under ;section 4010(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s4011/a/4","parentIdentifier":"/us/usc/t16/s4011/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4011%2Fa%2F4","sourceRelease":"119-100","text":"promulgate regulations necessary to carry out the purposes of this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s4011/a/5","parentIdentifier":"/us/usc/t16/s4011/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4011%2Fa%2F5","sourceRelease":"119-100","text":"enforce the provisions of this chapter, as provided under ; andsection 4016 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s4011/a/6","parentIdentifier":"/us/usc/t16/s4011/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4011%2Fa%2F6","sourceRelease":"119-100","text":"make all appointments to councils in accordance with .section 4009(f) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Assistance","label":"b Assistance","identifier":"/us/usc/t16/s4011/b","parentIdentifier":"/us/usc/t16/s4011","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4011%2Fb","sourceRelease":"119-100","text":"The Secretary may provide, on a reimbursable or other basis, such administrative or technical assistance as a council may request for purposes of the initial organization and subsequent operation of the council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
