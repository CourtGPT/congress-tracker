led” for “is not otherwise eligible to enroll”.Pub. L. 115–251"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t38/s1720I/a","parentIdentifier":"/us/usc/t38/s1720I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1720I/a/1","parentIdentifier":"/us/usc/t38/s1720I/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fa%2F1","sourceRelease":"119-100","text":"an initial mental health assessment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1720I/a/2","parentIdentifier":"/us/usc/t38/s1720I/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fa%2F2","sourceRelease":"119-100","text":"the mental healthcare or behavioral healthcare services authorized under this chapter that are required to treat the mental or behavioral health care needs of the former service members, including risk of suicide or harming others.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Eligible Individuals","label":"b .—Eligible Individuals","identifier":"/us/usc/t38/s1720I/b","parentIdentifier":"/us/usc/t38/s1720I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1720I/b/1","parentIdentifier":"/us/usc/t38/s1720I/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fb%2F1","sourceRelease":"119-100","text":"is a former member of the Armed Forces, including the reserve components;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1720I/b/2","parentIdentifier":"/us/usc/t38/s1720I/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1720I/b/2/A","parentIdentifier":"/us/usc/t38/s1720I/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fb%2F2%2FA","sourceRelease":"119-100","text":"a dishonorable discharge; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1720I/b/2/B","parentIdentifier":"/us/usc/t38/s1720I/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fb%2F2%2FB","sourceRelease":"119-100","text":"a discharge by court-martial;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1720I/b/3","parentIdentifier":"/us/usc/t38/s1720I/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fb%2F3","sourceRelease":"119-100","text":"is not enrolled in the health care system established by ; andsection 1705 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s1720I/b/4","parentIdentifier":"/us/usc/t38/s1720I/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1720I/b/4/A","parentIdentifier":"/us/usc/t38/s1720I/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fb%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t38/s1720I/b/4/A/i","parentIdentifier":"/us/usc/t38/s1720I/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fb%2F4%2FA%2Fi","sourceRelease":"119-100","text":"served in the Armed Forces for a period of more than 100 cumulative days; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t38/s1720I/b/4/A/ii","parentIdentifier":"/us/usc/t38/s1720I/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fb%2F4%2FA%2Fii","sourceRelease":"119-100","text":"was deployed in a theater of combat operations, in support of a contingency operation, or in an area at a time during which hostilities are occurring in that area during such service, including by controlling an unmanned aerial vehicle from a location other than such theater or area; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1720I/b/4/B","parentIdentifier":"/us/usc/t38/s1720I/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fb%2F4%2FB","sourceRelease":"119-100","text":"while serving in the Armed Forces, was the victim of a physical assault of a sexual nature, a battery of a sexual nature, or sexual harassment (as defined in ).section 1720D(f) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Non-Department Care","label":"c .—Non-Department Care","identifier":"/us/usc/t38/s1720I/c","parentIdentifier":"/us/usc/t38/s1720I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1720I/c/1","parentIdentifier":"/us/usc/t38/s1720I/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1720I/c/1/A","parentIdentifier":"/us/usc/t38/s1720I/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fc%2F1%2FA","sourceRelease":"119-100","text":"in the judgment of a mental health professional employed by the Department, the receipt of mental or behavioral health care services by that individual in facilities of the Department would be clinically inadvisable; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1720I/c/1/B","parentIdentifier":"/us/usc/t38/s1720I/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fc%2F1%2FB","sourceRelease":"119-100","text":"facilities of the Department are not capable of furnishing such mental or behavioral health care services to that individual economically because of geographical inaccessibility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1720I/c/2","parentIdentifier":"/us/usc/t38/s1720I/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fc%2F2","sourceRelease":"119-100","text":"The Secretary shall carry out paragraph (1) pursuant to or any other provision of law authorizing the Secretary to enter into contracts or agreements to furnish hospital care and medical services to veterans at non-Department facilities.section 1703 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Setting and Referrals","label":"d .—Setting and Referrals","identifier":"/us/usc/t38/s1720I/d","parentIdentifier":"/us/usc/t38/s1720I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1720I/d/1","parentIdentifier":"/us/usc/t38/s1720I/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fd%2F1","sourceRelease":"119-100","text":"seek to ensure that such services are furnished in settings that are therapeutically appropriate, taking into account the circumstances that resulted in the need for such services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1720I/d/2","parentIdentifier":"/us/usc/t38/s1720I/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fd%2F2","sourceRelease":"119-100","text":"provide referral services to assist former members who are not eligible for services under this chapter to obtain services from sources outside the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Information","label":"e .—Information","identifier":"/us/usc/t38/s1720I/e","parentIdentifier":"/us/usc/t38/s1720I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1720I/e/1","parentIdentifier":"/us/usc/t38/s1720I/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1720I/e/1/A","parentIdentifier":"/us/usc/t38/s1720I/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fe%2F1%2FA","sourceRelease":"119-100","text":"180 days after the date of the enactment of the Military Construction, Veterans Affairs, and Related Agencies Appropriations Act, 2018; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1720I/e/1/B","parentIdentifier":"/us/usc/t38/s1720I/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fe%2F1%2FB","sourceRelease":"119-100","text":"180 days after the date on which the individual was discharged or released from the active military, naval, air, or space service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1720I/e/2","parentIdentifier":"/us/usc/t38/s1720I/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fe%2F2","sourceRelease":"119-100","text":"shall include availability of a toll-free telephone number (commonly referred to as an 800 number);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1720I/e/3","parentIdentifier":"/us/usc/t38/s1720I/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fe%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1720I/e/3/A","parentIdentifier":"/us/usc/t38/s1720I/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fe%2F3%2FA","sourceRelease":"119-100","text":"is revised and updated as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1720I/e/3/B","parentIdentifier":"/us/usc/t38/s1720I/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fe%2F3%2FB","sourceRelease":"119-100","text":"is made available and visibly posted at appropriate facilities of the Department; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s1720I/e/3/C","parentIdentifier":"/us/usc/t38/s1720I/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fe%2F3%2FC","sourceRelease":"119-100","text":"is made available to State veteran agencies and through appropriate public information services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s1720I/e/4","parentIdentifier":"/us/usc/t38/s1720I/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Fe%2F4","sourceRelease":"119-100","text":"shall include coordination with the Secretary of Defense seeking to ensure that members of the Armed Forces and individuals who are being separated from active military, naval, air, or space service are provided appropriate information about programs, requirements, and procedures for applying for mental health care services under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Annual Reports","label":"f .—Annual Reports","identifier":"/us/usc/t38/s1720I/f","parentIdentifier":"/us/usc/t38/s1720I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1720I/f/1","parentIdentifier":"/us/usc/t38/s1720I/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Ff%2F1","sourceRelease":"119-100","text":"Not later than February 15 each year, the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report on the mental and behavioral health care services provided under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1720I/f/2","parentIdentifier":"/us/usc/t38/s1720I/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720I%2Ff%2F2","sourceRelease":"119-100","tex