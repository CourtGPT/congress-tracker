{"type":"section","nativeType":"section","number":"8694","heading":"Annual report on ship maintenance","label":"8694 Annual report on ship maintenance","identifier":"/us/usc/t10/s8694","parentIdentifier":"/us/usc/t10/stC/ptIV/ch863","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8694","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Report Required","label":"a .—Report Required","identifier":"/us/usc/t10/s8694/a","parentIdentifier":"/us/usc/t10/s8694","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8694%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s8694/a/1","parentIdentifier":"/us/usc/t10/s8694/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8694%2Fa%2F1","sourceRelease":"119-100","text":"A description of all ship maintenance planned for the fiscal year during which the report is submitted, by hull.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s8694/a/2","parentIdentifier":"/us/usc/t10/s8694/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8694%2Fa%2F2","sourceRelease":"119-100","text":"The estimated cost of the maintenance described pursuant to paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s8694/a/3","parentIdentifier":"/us/usc/t10/s8694/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8694%2Fa%2F3","sourceRelease":"119-100","text":"A summary of all ship maintenance conducted by the Secretary during the previous fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s8694/a/4","parentIdentifier":"/us/usc/t10/s8694/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8694%2Fa%2F4","sourceRelease":"119-100","text":"A detailed description of any ship maintenance that was deferred during the previous fiscal year, including specific reasons for the delay or cancellation of any availability.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s8694/a/5","parentIdentifier":"/us/usc/t10/s8694/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8694%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8694/a/5/A","parentIdentifier":"/us/usc/t10/s8694/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8694%2Fa%2F5%2FA","sourceRelease":"119-100","text":"a summary of the effects on the costs and schedule for each delay or cancellation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8694/a/5/B","parentIdentifier":"/us/usc/t10/s8694/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8694%2Fa%2F5%2FB","sourceRelease":"119-100","text":"the accrued operational and fiscal cost of all the deferments over the fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Form of Report","label":"b .—Form of Report","identifier":"/us/usc/t10/s8694/b","parentIdentifier":"/us/usc/t10/s8694","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8694%2Fb","sourceRelease":"119-100","text":"Each report submitted under subsection (a) shall be submitted in unclassified form and made publicly available on an appropriate internet website in a searchable format, but may contain a classified annex.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
