{"type":"section","nativeType":"section","number":"2502","heading":"Definitions","label":"2502 Definitions","identifier":"/us/usc/t12/s2502","parentIdentifier":"/us/usc/t12/ch26","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2502","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s2502/1","parentIdentifier":"/us/usc/t12/s2502","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2502%2F1","sourceRelease":"119-100","text":"“banking organization” means any bank, trust company, savings bank, safe deposit company, or a private banker engaged in business in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s2502/2","parentIdentifier":"/us/usc/t12/s2502","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2502%2F2","sourceRelease":"119-100","text":"“business association” means any corporation (other than a public corporation), joint stock company, business trust, partnership, or any association for business purposes of two or more individuals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t12/s2502/3","parentIdentifier":"/us/usc/t12/s2502","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2502%2F3","sourceRelease":"119-100","text":"“financial organization” means any savings and loan association, building and loan association, credit union, or investment company engaged in business in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
