{"type":"section","nativeType":"section","number":"50902","heading":"Best practices and support","label":"50902 Best practices and support","identifier":"/us/usc/t34/s50902","parentIdentifier":"/us/usc/t34/stV/ch509","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t34/s50902/a","parentIdentifier":"/us/usc/t34/s50902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"First responder","label":"1 First responder","identifier":"/us/usc/t34/s50902/a/1","parentIdentifier":"/us/usc/t34/s50902/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fa%2F1","sourceRelease":"119-100","text":"The term “first responder” has the meaning given the term “public safety officer” in .section 10284 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"First responder agency","label":"2 First responder agency","identifier":"/us/usc/t34/s50902/a/2","parentIdentifier":"/us/usc/t34/s50902/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fa%2F2","sourceRelease":"119-100","text":"The term “first responder agency” means a Federal, State, local, or Tribal agency that employs or otherwise engages the services of a first responder.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Peer support counseling program","label":"3 Peer support counseling program","identifier":"/us/usc/t34/s50902/a/3","parentIdentifier":"/us/usc/t34/s50902/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fa%2F3","sourceRelease":"119-100","text":"The term “peer support counseling program” means a program provided by a first responder agency that provides counseling services from a peer support specialist to a first responder of the first responder agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Peer support participant","label":"4 Peer support participant","identifier":"/us/usc/t34/s50902/a/4","parentIdentifier":"/us/usc/t34/s50902/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fa%2F4","sourceRelease":"119-100","text":"The term “peer support participant” means a first responder who receives counseling services from a peer support specialist.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Peer support specialist","label":"5 Peer support specialist","identifier":"/us/usc/t34/s50902/a/5","parentIdentifier":"/us/usc/t34/s50902/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50902/a/5/A","parentIdentifier":"/us/usc/t34/s50902/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fa%2F5%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s50902/a/5/A/i","parentIdentifier":"/us/usc/t34/s50902/a/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fa%2F5%2FA%2Fi","sourceRelease":"119-100","text":"peer support counseling; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s50902/a/5/A/ii","parentIdentifier":"/us/usc/t34/s50902/a/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fa%2F5%2FA%2Fii","sourceRelease":"119-100","text":"providing emotional and moral support to first responders who have been involved in or exposed to an emotionally traumatic experience in the course of the duties of those first responders; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50902/a/5/B","parentIdentifier":"/us/usc/t34/s50902/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fa%2F5%2FB","sourceRelease":"119-100","text":"is designated by a first responder agency to provide the services described in subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report on best practices","label":"b Report on best practices","identifier":"/us/usc/t34/s50902/b","parentIdentifier":"/us/usc/t34/s50902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s50902/b/1","parentIdentifier":"/us/usc/t34/s50902/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50902/b/1/A","parentIdentifier":"/us/usc/t34/s50902/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fb%2F1%2FA","sourceRelease":"119-100","text":"establishing and operating peer support counseling programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50902/b/1/B","parentIdentifier":"/us/usc/t34/s50902/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fb%2F1%2FB","sourceRelease":"119-100","text":"training and certifying peer support specialists;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s50902/b/2","parentIdentifier":"/us/usc/t34/s50902/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fb%2F2","sourceRelease":"119-100","text":"a code of ethics for peer support specialists;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s50902/b/3","parentIdentifier":"/us/usc/t34/s50902/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fb%2F3","sourceRelease":"119-100","text":"recommendations for continuing education for peer support specialists;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t34/s50902/b/4","parentIdentifier":"/us/usc/t34/s50902/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fb%2F4","sourceRelease":"119-100","text":"advice on disclosing to first responders any confidentiality rights of peer support participants; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t34/s50902/b/5","parentIdentifier":"/us/usc/t34/s50902/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50902/b/5/A","parentIdentifier":"/us/usc/t34/s50902/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fb%2F5%2FA","sourceRelease":"119-100","text":"the different types of peer support counseling programs in use by first responder agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50902/b/5/B","parentIdentifier":"/us/usc/t34/s50902/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fb%2F5%2FB","sourceRelease":"119-100","text":"any differences in peer support counseling programs offered across categories of first responders; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s50902/b/5/C","parentIdentifier":"/us/usc/t34/s50902/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fb%2F5%2FC","sourceRelease":"119-100","text":"the important role senior first responders play in supporting access to mental health resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Implementation","label":"c Implementation","identifier":"/us/usc/t34/s50902/c","parentIdentifier":"/us/usc/t34/s50902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s50902/c/1","parentIdentifier":"/us/usc/t34/s50902/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fc%2F1","sourceRelease":"119-100","text":"making the report developed under subsection (b) publicly available on the website of the Department of Justice; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s50902/c/2","parentIdentifier":"/us/usc/t34/s50902/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50902%2Fc%2F2","sourceRelease":"119-100","text":"providing a list of peer support specialist training programs on the website of the Department of Justice.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
