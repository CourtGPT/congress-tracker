{"type":"section","nativeType":"section","number":"13251","heading":"Mandate for alternative fuel providers","label":"13251 Mandate for alternative fuel providers","identifier":"/us/usc/t42/s13251","parentIdentifier":"/us/usc/t42/ch134/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s13251/a","parentIdentifier":"/us/usc/t42/s13251","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13251/a/1","parentIdentifier":"/us/usc/t42/s13251/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13251/a/1/A","parentIdentifier":"/us/usc/t42/s13251/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F1%2FA","sourceRelease":"119-100","text":"30 percent for model year 1996.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13251/a/1/B","parentIdentifier":"/us/usc/t42/s13251/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F1%2FB","sourceRelease":"119-100","text":"50 percent for model year 1997.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s13251/a/1/C","parentIdentifier":"/us/usc/t42/s13251/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F1%2FC","sourceRelease":"119-100","text":"70 percent for model year 1998.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s13251/a/1/D","parentIdentifier":"/us/usc/t42/s13251/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F1%2FD","sourceRelease":"119-100","text":"90 percent for model year 1999 and thereafter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13251/a/2","parentIdentifier":"/us/usc/t42/s13251/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13251/a/2/A","parentIdentifier":"/us/usc/t42/s13251/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F2%2FA","sourceRelease":"119-100","text":"a covered person whose principal business is producing, storing, refining, processing, transporting, distributing, importing, or selling at wholesale or retail any alternative fuel other than electricity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13251/a/2/B","parentIdentifier":"/us/usc/t42/s13251/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F2%2FB","sourceRelease":"119-100","text":"a non-Federal covered person whose principal business is generating, transmitting, importing, or selling at wholesale or retail electricity; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s13251/a/2/C","parentIdentifier":"/us/usc/t42/s13251/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s13251/a/2/C/i","parentIdentifier":"/us/usc/t42/s13251/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F2%2FC%2Fi","sourceRelease":"119-100","text":"who produces, imports, or produces and imports in combination, an average of 50,000 barrels per day or more of petroleum; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s13251/a/2/C/ii","parentIdentifier":"/us/usc/t42/s13251/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F2%2FC%2Fii","sourceRelease":"119-100","text":"a substantial portion of whose business is producing alternative fuels.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13251/a/3","parentIdentifier":"/us/usc/t42/s13251/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13251/a/3/A","parentIdentifier":"/us/usc/t42/s13251/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F3%2FA","sourceRelease":"119-100","text":"In the case of a covered person described in paragraph (2) with more than one affiliate, division, or other business unit, only an affiliate, division, or business unit which is substantially engaged in the alternative fuels business (as determined by the Secretary by rule) shall be subject to this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13251/a/3/B","parentIdentifier":"/us/usc/t42/s13251/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s13251/a/3/B/i","parentIdentifier":"/us/usc/t42/s13251/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F3%2FB%2Fi","sourceRelease":"119-100","text":"transforming alternative fuels into a product that is not an alternative fuel; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s13251/a/3/B/ii","parentIdentifier":"/us/usc/t42/s13251/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F3%2FB%2Fii","sourceRelease":"119-100","text":"consuming alternative fuels as a feedstock or fuel in the manufacture of a product that is not an alternative fuel,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s13251/a/4","parentIdentifier":"/us/usc/t42/s13251/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F4","sourceRelease":"119-100","text":"The vehicles purchased pursuant to this section shall be operated solely on alternative fuels except when operating in an area where the appropriate alternative fuel is unavailable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s13251/a/5","parentIdentifier":"/us/usc/t42/s13251/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13251/a/5/A","parentIdentifier":"/us/usc/t42/s13251/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F5%2FA","sourceRelease":"119-100","text":"alternative fueled vehicles that meet the normal requirements and practices of the principal business of that person are not reasonably available for acquisition; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13251/a/5/B","parentIdentifier":"/us/usc/t42/s13251/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fa%2F5%2FB","sourceRelease":"119-100","text":"alternative fuels that meet the normal requirements and practices of the principal business of that person are not available in the area in which the vehicles are to be operated.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Revisions and extensions","label":"b Revisions and extensions","identifier":"/us/usc/t42/s13251/b","parentIdentifier":"/us/usc/t42/s13251","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13251/b/1","parentIdentifier":"/us/usc/t42/s13251/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fb%2F1","sourceRelease":"119-100","text":"revise the percentage requirements under subsection (a)(1) downward, except that under no circumstances shall the percentage requirement for a model year be less than 20 percent; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13251/b/2","parentIdentifier":"/us/usc/t42/s13251/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fb%2F2","sourceRelease":"119-100","text":"extend the time under subsection (a)(1) for up to 2 model years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Option for electric utilities","label":"c Option for electric utilities","identifier":"/us/usc/t42/s13251/c","parentIdentifier":"/us/usc/t42/s13251","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fc","sourceRelease":"119-100","text":"The Secretary shall, within 1 year after , issue regulations requiring that, in the case of a covered person whose principal business is generating, transmitting, importing, or selling at wholesale or retail electricity, the requirements of subsection (a)(1) shall not apply until after , with respect to electric motor vehicles. Any covered person described in this subsection which plans to acquire electric motor vehicles to comply with the requirements of this section shall so notify the Secretary before .October 24, 1992December 31, 1997January 1, 1996","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Report to Congress","label":"d Report to Congress","identifier":"/us/usc/t42/s13251/d","parentIdentifier":"/us/usc/t42/s13251","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13251%2Fd","sourceRelease":"119-100","text":"The Secretary shall, before , submit a report to the Congress providing detailed information on actions taken to carry out this section, and the progress made and problems encountered thereunder.January 1, 1998","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
