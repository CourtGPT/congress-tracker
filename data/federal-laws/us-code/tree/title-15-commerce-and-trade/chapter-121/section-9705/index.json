{"type":"section","nativeType":"section","number":"9705","heading":"Improving National Oceanic and Atmospheric Administration communication of future flood risks and hazardous flash flood events","label":"9705 Improving National Oceanic and Atmospheric Administration communication of future flood risks and hazardous flash flood events","identifier":"/us/usc/t15/s9705","parentIdentifier":"/us/usc/t15/ch121","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Assessment of flash flood watches and warnings","label":"a Assessment of flash flood watches and warnings","identifier":"/us/usc/t15/s9705/a","parentIdentifier":"/us/usc/t15/s9705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s9705/a/1","parentIdentifier":"/us/usc/t15/s9705/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9705/a/1/A","parentIdentifier":"/us/usc/t15/s9705/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9705/a/1/A/i","parentIdentifier":"/us/usc/t15/s9705/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the flash flood watches and warnings of the National Weather Service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9705/a/1/A/ii","parentIdentifier":"/us/usc/t15/s9705/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the information delivery to support preparation and responses to floods; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9705/a/1/B","parentIdentifier":"/us/usc/t15/s9705/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F1%2FB","sourceRelease":"119-100","text":"submit to Congress a report on the findings of the Administrator with respect to the assessment required by subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Elements","label":"2 Elements","identifier":"/us/usc/t15/s9705/a/2","parentIdentifier":"/us/usc/t15/s9705/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9705/a/2/A","parentIdentifier":"/us/usc/t15/s9705/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9705/a/2/A/i","parentIdentifier":"/us/usc/t15/s9705/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"communicate risk to the general public;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9705/a/2/A/ii","parentIdentifier":"/us/usc/t15/s9705/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"inform action to prevent loss of life and property;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s9705/a/2/A/iii","parentIdentifier":"/us/usc/t15/s9705/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"inform action to support flood preparation and response; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t15/s9705/a/2/A/iv","parentIdentifier":"/us/usc/t15/s9705/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"deliver information in a manner designed to lead to appropriate action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9705/a/2/B","parentIdentifier":"/us/usc/t15/s9705/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9705/a/2/B/i","parentIdentifier":"/us/usc/t15/s9705/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"legislative and administrative action to improve the watches and warnings described in paragraph (1)(A)(i); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9705/a/2/B/ii","parentIdentifier":"/us/usc/t15/s9705/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"such research as the Administrator considers necessary to address the focus areas described in paragraph (3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Focus areas","label":"3 Focus areas","identifier":"/us/usc/t15/s9705/a/3","parentIdentifier":"/us/usc/t15/s9705/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9705/a/3/A","parentIdentifier":"/us/usc/t15/s9705/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F3%2FA","sourceRelease":"119-100","text":"Ways to communicate the risks posed by hazardous flash flood events to the public that are most likely to result in informed decision making regarding the mitigation of those risks.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9705/a/3/B","parentIdentifier":"/us/usc/t15/s9705/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F3%2FB","sourceRelease":"119-100","text":"Ways to provide actionable geographic information to the recipient of a watch or warning for a flash flood, including partnering with emergency response agencies, as appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9705/a/3/C","parentIdentifier":"/us/usc/t15/s9705/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F3%2FC","sourceRelease":"119-100","text":"Evaluation of information delivery to support the preparation for and response to floods.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Consultation","label":"4 Consultation","identifier":"/us/usc/t15/s9705/a/4","parentIdentifier":"/us/usc/t15/s9705/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9705/a/4/A","parentIdentifier":"/us/usc/t15/s9705/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F4%2FA","sourceRelease":"119-100","text":"individuals in the academic sector, including individuals in the field of social and behavioral sciences;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9705/a/4/B","parentIdentifier":"/us/usc/t15/s9705/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F4%2FB","sourceRelease":"119-100","text":"other weather services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9705/a/4/C","parentIdentifier":"/us/usc/t15/s9705/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F4%2FC","sourceRelease":"119-100","text":"media outlets and other entities that distribute the watches and warnings described in paragraph (1)(A)(i);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s9705/a/4/D","parentIdentifier":"/us/usc/t15/s9705/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F4%2FD","sourceRelease":"119-100","text":"floodplain managers and emergency planners and responders, including State, local, and Tribal emergency management agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s9705/a/4/E","parentIdentifier":"/us/usc/t15/s9705/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F4%2FE","sourceRelease":"119-100","text":"other government users of the watches and warnings described in paragraph (1)(A)(i), including the Federal Highway Administration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t15/s9705/a/4/F","parentIdentifier":"/us/usc/t15/s9705/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F4%2FF","sourceRelease":"119-100","text":"such other Federal agencies as the Administrator determines rely on watches and warnings regarding flash floods for operational decisions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"National Academy of Sciences","label":"5 National Academy of Sciences","identifier":"/us/usc/t15/s9705/a/5","parentIdentifier":"/us/usc/t15/s9705/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F5","sourceRelease":"119-100","text":"The Administrator shall engage with the National Academy of Sciences, as the Administrator considers necessary and practicable, including by contracting with the National Research Council to review the scientific and technical soundness of the assessment required by paragraph (1)(A), including the recommendations under paragraph (2)(B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Methodologies","label":"6 Methodologies","identifier":"/us/usc/t15/s9705/a/6","parentIdentifier":"/us/usc/t15/s9705/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fa%2F6","sourceRelease":"119-100","text":"In conducting the assessment required by paragraph (1)(A), the Administrator shall use such methodologies as the Administrator considers are generally accepted by the weather enterprise, including social and behavioral sciences.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Improvements to flash flood watches and warnings","label":"b Improvements to flash flood watches and warnings","identifier":"/us/usc/t15/s9705/b","parentIdentifier":"/us/usc/t15/s9705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s9705/b/1","parentIdentifier":"/us/usc/t15/s9705/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9705/b/1/A","parentIdentifier":"/us/usc/t15/s9705/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fb%2F1%2FA","sourceRelease":"119-100","text":"to improve the communication of the risks posed by hazardous flash flood events; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9705/b/1/B","parentIdentifier":"/us/usc/t15/s9705/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fb%2F1%2FB","sourceRelease":"119-100","text":"to provide actionable geographic information to the recipient of a watch or warning for a flash flood.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements regarding recommendations","label":"2 Requirements regarding recommendations","identifier":"/us/usc/t15/s9705/b/2","parentIdentifier":"/us/usc/t15/s9705/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9705/b/2/A","parentIdentifier":"/us/usc/t15/s9705/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fb%2F2%2FA","sourceRelease":"119-100","text":"is validated by social and behavioral science using a generalizable sample;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9705/b/2/B","parentIdentifier":"/us/usc/t15/s9705/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fb%2F2%2FB","sourceRelease":"119-100","text":"accounts for the needs of various demographics, vulnerable populations, and geographic regions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9705/b/2/C","parentIdentifier":"/us/usc/t15/s9705/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fb%2F2%2FC","sourceRelease":"119-100","text":"responds to the needs of Federal, State, local, and Tribal government partners and media partners; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s9705/b/2/D","parentIdentifier":"/us/usc/t15/s9705/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fb%2F2%2FD","sourceRelease":"119-100","text":"accounts for necessary changes to federally operated watch and warning propagation and dissemination infrastructure and protocols.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Definitions","label":"c Definitions","identifier":"/us/usc/t15/s9705/c","parentIdentifier":"/us/usc/t15/s9705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Watch; warning","label":"1 Watch; warning","identifier":"/us/usc/t15/s9705/c/1","parentIdentifier":"/us/usc/t15/s9705/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s9705/c/1/A","parentIdentifier":"/us/usc/t15/s9705/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9705/c/1/A/i","parentIdentifier":"/us/usc/t15/s9705/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"to alert the general public to the potential for or presence of the event; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9705/c/1/A/ii","parentIdentifier":"/us/usc/t15/s9705/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"to inform action to prevent loss of life and property.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exclusion","label":"B Exclusion","identifier":"/us/usc/t15/s9705/c/1/B","parentIdentifier":"/us/usc/t15/s9705/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fc%2F1%2FB","sourceRelease":"119-100","text":"The terms “watch” and “warning” do not include technical or specialized meteorological and hydrological forecasts, outlooks, or model guidance products.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Weather enterprise","label":"2 Weather enterprise","identifier":"/us/usc/t15/s9705/c/2","parentIdentifier":"/us/usc/t15/s9705/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9705%2Fc%2F2","sourceRelease":"119-100","text":"The term “weather enterprise” has the meaning given that term in .section 8501 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
