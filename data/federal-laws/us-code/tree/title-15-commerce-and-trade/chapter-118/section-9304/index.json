{"type":"section","nativeType":"section","number":"9304","heading":"Partnerships in sustainable chemistry","label":"9304 Partnerships in sustainable chemistry","identifier":"/us/usc/t15/s9304","parentIdentifier":"/us/usc/t15/ch118","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9304","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s9304/a","parentIdentifier":"/us/usc/t15/s9304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9304%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9304/a/1","parentIdentifier":"/us/usc/t15/s9304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9304%2Fa%2F1","sourceRelease":"119-100","text":"create collaborative sustainable chemistry research, development, demonstration, technology transfer, and commercialization programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9304/a/2","parentIdentifier":"/us/usc/t15/s9304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9304%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9304/a/2/A","parentIdentifier":"/us/usc/t15/s9304/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9304%2Fa%2F2%2FA","sourceRelease":"119-100","text":"developing or recognizing curricular materials and courses for undergraduate and graduate levels and for the professional development of scientists, engineers, and others involved in materials specification; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9304/a/2/B","parentIdentifier":"/us/usc/t15/s9304/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9304%2Fa%2F2%2FB","sourceRelease":"119-100","text":"publicizing the availability of professional development courses in sustainable chemistry and recruiting professionals to pursue such courses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Private sector participation","label":"b Private sector participation","identifier":"/us/usc/t15/s9304/b","parentIdentifier":"/us/usc/t15/s9304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9304%2Fb","sourceRelease":"119-100","text":"To be eligible for support under this section, a partnership in sustainable chemistry shall include at least one private sector organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Selection of partnerships","label":"c Selection of partnerships","identifier":"/us/usc/t15/s9304/c","parentIdentifier":"/us/usc/t15/s9304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9304%2Fc","sourceRelease":"119-100","text":"In selecting partnerships for support under this section, the agencies participating in the Entity shall also consider the extent to which the applicants are willing and able to demonstrate evidence of support for, and commitment to, the goals outlined in the strategic plan and report described in .section 9302 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Prohibited use of funds","label":"d Prohibited use of funds","identifier":"/us/usc/t15/s9304/d","parentIdentifier":"/us/usc/t15/s9304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9304%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9304/d/1","parentIdentifier":"/us/usc/t15/s9304/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9304%2Fd%2F1","sourceRelease":"119-100","text":"to support or expand a regulatory chemical management program at an implementing agency under a State law;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9304/d/2","parentIdentifier":"/us/usc/t15/s9304/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9304%2Fd%2F2","sourceRelease":"119-100","text":"to construct or renovate a building or structure; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s9304/d/3","parentIdentifier":"/us/usc/t15/s9304/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9304%2Fd%2F3","sourceRelease":"119-100","text":"to promote the sale of a specific product, process, or technology, or to disparage a specific product, process, or technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
