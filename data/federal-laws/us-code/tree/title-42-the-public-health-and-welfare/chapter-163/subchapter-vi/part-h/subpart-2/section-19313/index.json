{"type":"section","nativeType":"section","number":"19313","heading":"National Laboratory non-Federal employee outside employment authority","label":"19313 National Laboratory non-Federal employee outside employment authority","identifier":"/us/usc/t42/s19313","parentIdentifier":"/us/usc/t42/ch163/schVI/ptH/spt2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s19313/a","parentIdentifier":"/us/usc/t42/s19313","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19313/a/1","parentIdentifier":"/us/usc/t42/s19313/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313%2Fa%2F1","sourceRelease":"119-100","text":"to engage in outside employment, including start-up companies based on licensing technologies developed at National Laboratories and consulting in their areas of expertise, and receive compensation from such entities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19313/a/2","parentIdentifier":"/us/usc/t42/s19313/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313%2Fa%2F2","sourceRelease":"119-100","text":"to engage in outside activities related to their areas of expertise at the National Laboratory and may allow employees, in their employment capacity at such outside employment, to access the National Laboratories under the same contracting mechanisms as non-Laboratory employees and entities, in accordance with appropriate conflict of interest protocols.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirements","label":"b Requirements","identifier":"/us/usc/t42/s19313/b","parentIdentifier":"/us/usc/t42/s19313","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19313/b/1","parentIdentifier":"/us/usc/t42/s19313/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313%2Fb%2F1","sourceRelease":"119-100","text":"require employees to disclose to and obtain approval from the Director or their designee prior to engaging in any outside employment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19313/b/2","parentIdentifier":"/us/usc/t42/s19313/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313%2Fb%2F2","sourceRelease":"119-100","text":"develop and require appropriate conflict of interest protocols for employees that engage in outside employment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19313/b/3","parentIdentifier":"/us/usc/t42/s19313/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313%2Fb%2F3","sourceRelease":"119-100","text":"maintain the authority to terminate employees engaging in outside employment if they are found to violate terms, including conflict of interest protocols, mandated by the Director; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s19313/b/4","parentIdentifier":"/us/usc/t42/s19313/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313%2Fb%2F4","sourceRelease":"119-100","text":"ensure that any such programs or activities are in conformance with the Department’s research security policies, including DOE Order 486.1.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Additional restrictions","label":"c Additional restrictions","identifier":"/us/usc/t42/s19313/c","parentIdentifier":"/us/usc/t42/s19313","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19313/c/1","parentIdentifier":"/us/usc/t42/s19313/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313%2Fc%2F1","sourceRelease":"119-100","text":"allow such activities to interfere with or impede their duties at the National Laboratory;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19313/c/2","parentIdentifier":"/us/usc/t42/s19313/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313%2Fc%2F2","sourceRelease":"119-100","text":"engage in activities related to outside employment using National Laboratory government equipment, property, or resources, unless such activities are performed under National Laboratory contracting mechanisms, such as Cooperative Research and Development Agreements or Strategic Partnership Projects, whereby all conflicts of interest requirements apply; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19313/c/3","parentIdentifier":"/us/usc/t42/s19313/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313%2Fc%2F3","sourceRelease":"119-100","text":"use their position at a National Laboratory to provide an unfair competitive advantage to an outside employer or start-up activity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Federal ethics","label":"d Federal ethics","identifier":"/us/usc/t42/s19313/d","parentIdentifier":"/us/usc/t42/s19313","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19313%2Fd","sourceRelease":"119-100","text":"Nothing in this section shall affect existing Federal ethics rules applicable to Federal personnel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
