07/a/3","parentIdentifier":"/us/usc/t52/s21007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21007%2Fa%2F3","sourceRelease":"119-100","text":"For fiscal year 2005, $600,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t52/s21007/a/4","parentIdentifier":"/us/usc/t52/s21007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21007%2Fa%2F4","sourceRelease":"119-100","text":"For fiscal year 2010 and subsequent fiscal years, such sums as are necessary for purposes of making requirements payments to States to carry out the activities described in .section 21001(b)(3) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Availability","label":"b Availability","identifier":"/us/usc/t52/s21007/b","parentIdentifier":"/us/usc/t52/s21007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21007%2Fb","sourceRelease":"119-100","text":"Any amounts appropriated pursuant to the authority of subsection (a) shall remain available without fiscal year limitation until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
