{"type":"section","nativeType":"section","number":"13457","heading":"Energy efficient environmental program","label":"13457 Energy efficient environmental program","identifier":"/us/usc/t42/s13457","parentIdentifier":"/us/usc/t42/ch134/schIX/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Program direction","label":"a Program direction","identifier":"/us/usc/t42/s13457/a","parentIdentifier":"/us/usc/t42/s13457","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13457/a/1","parentIdentifier":"/us/usc/t42/s13457/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fa%2F1","sourceRelease":"119-100","text":"apply a systems approach to minimizing adverse environmental effects of industrial production in the most cost effective and energy efficient manner; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13457/a/2","parentIdentifier":"/us/usc/t42/s13457/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fa%2F2","sourceRelease":"119-100","text":"incorporate consideration of the entire materials and energy cycle with the goal of minimizing adverse environmental impacts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Identification of opportunities","label":"b Identification of opportunities","identifier":"/us/usc/t42/s13457/b","parentIdentifier":"/us/usc/t42/s13457","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fb","sourceRelease":"119-100","text":"Within 9 months after , the Secretary, in consultation with the Administrator of the Environmental Protection Agency, shall identify opportunities for the demonstration of energy efficient pollution prevention technologies and processes.October 24, 1992","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Report","label":"c Report","identifier":"/us/usc/t42/s13457/c","parentIdentifier":"/us/usc/t42/s13457","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13457/c/1","parentIdentifier":"/us/usc/t42/s13457/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fc%2F1","sourceRelease":"119-100","text":"an assessment of the technologies available to increase productivity and simultaneously reduce the consumption of energy and material resources and the production of wastes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13457/c/2","parentIdentifier":"/us/usc/t42/s13457/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fc%2F2","sourceRelease":"119-100","text":"an assessment of the current use of such technologies by industry in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13457/c/3","parentIdentifier":"/us/usc/t42/s13457/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fc%2F3","sourceRelease":"119-100","text":"the status of any such technologies currently being developed, together with projected schedules of their commercial availability;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s13457/c/4","parentIdentifier":"/us/usc/t42/s13457/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fc%2F4","sourceRelease":"119-100","text":"the energy savings resulting from the use of such technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s13457/c/5","parentIdentifier":"/us/usc/t42/s13457/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fc%2F5","sourceRelease":"119-100","text":"the environmental benefits of such technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s13457/c/6","parentIdentifier":"/us/usc/t42/s13457/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fc%2F6","sourceRelease":"119-100","text":"the costs of such technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s13457/c/7","parentIdentifier":"/us/usc/t42/s13457/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fc%2F7","sourceRelease":"119-100","text":"an evaluation of any existing Federal or State regulatory disincentives for the employment of such technologies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s13457/c/8","parentIdentifier":"/us/usc/t42/s13457/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fc%2F8","sourceRelease":"119-100","text":"an evaluation of any other barriers to the use of such technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Proposals","label":"d Proposals","identifier":"/us/usc/t42/s13457/d","parentIdentifier":"/us/usc/t42/s13457","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13457/d/1","parentIdentifier":"/us/usc/t42/s13457/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fd%2F1","sourceRelease":"119-100","text":"technical viability and cost effectiveness; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13457/d/2","parentIdentifier":"/us/usc/t42/s13457/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13457%2Fd%2F2","sourceRelease":"119-100","text":"procedures for technology transfer and information outreach during and after completion of the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
