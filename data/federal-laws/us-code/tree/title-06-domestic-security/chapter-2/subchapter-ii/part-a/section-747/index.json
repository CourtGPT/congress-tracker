{"type":"section","nativeType":"section","number":"747","heading":"Equipment and training standards","label":"747 Equipment and training standards","identifier":"/us/usc/t6/s747","parentIdentifier":"/us/usc/t6/ch2/schII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs747","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Equipment standards","label":"a Equipment standards","identifier":"/us/usc/t6/s747/a","parentIdentifier":"/us/usc/t6/s747","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs747%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s747/a/1","parentIdentifier":"/us/usc/t6/s747/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs747%2Fa%2F1","sourceRelease":"119-100","text":"The Administrator, in coordination with the heads of appropriate Federal agencies and the National Advisory Council, shall support the development, promulgation, and updating, as necessary, of national voluntary consensus standards for the performance, use, and validation of equipment used by Federal, State, local, and tribal governments and nongovernmental emergency response providers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t6/s747/a/2","parentIdentifier":"/us/usc/t6/s747/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs747%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s747/a/2/A","parentIdentifier":"/us/usc/t6/s747/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs747%2Fa%2F2%2FA","sourceRelease":"119-100","text":"be designed to achieve equipment and other capabilities consistent with the national preparedness goal, including the safety and health of emergency response providers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s747/a/2/B","parentIdentifier":"/us/usc/t6/s747/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs747%2Fa%2F2%2FB","sourceRelease":"119-100","text":"to the maximum extent practicable, be consistent with existing national voluntary consensus standards;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s747/a/2/C","parentIdentifier":"/us/usc/t6/s747/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs747%2Fa%2F2%2FC","sourceRelease":"119-100","text":"take into account, as appropriate, threats that may not have been contemplated when the existing standards were developed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s747/a/2/D","parentIdentifier":"/us/usc/t6/s747/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs747%2Fa%2F2%2FD","sourceRelease":"119-100","text":"focus on maximizing operability, interoperability, interchangeability, durability, flexibility, efficiency, efficacy, portability, sustainability, and safety.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Training standards","label":"b Training standards","identifier":"/us/usc/t6/s747/b","parentIdentifier":"/us/usc/t6/s747","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs747%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s747/b/1","parentIdentifier":"/us/usc/t6/s747/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs747%2Fb%2F1","sourceRelease":"119-100","text":"support the development, promulgation, and regular updating, as necessary, of national voluntary consensus standards for training; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s747/b/2","parentIdentifier":"/us/usc/t6/s747/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs747%2Fb%2F2","sourceRelease":"119-100","text":"ensure that the training provided under the national training program is consistent with the standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Consultation with standards organizations","label":"c Consultation with standards organizations","identifier":"/us/usc/t6/s747/c","parentIdentifier":"/us/usc/t6/s747","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs747%2Fc","sourceRelease":"119-100","text":"In carrying out this section, the Administrator shall consult with representatives of relevant public and private sector national voluntary consensus standards development organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
