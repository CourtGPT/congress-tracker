{"type":"section","nativeType":"section","number":"4421","heading":"Definitions","label":"4421 Definitions","identifier":"/us/usc/t26/s4421","parentIdentifier":"/us/usc/t26/stD/ch35/schC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4421","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Wager","label":"1 Wager","identifier":"/us/usc/t26/s4421/1","parentIdentifier":"/us/usc/t26/s4421","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4421%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s4421/1/A","parentIdentifier":"/us/usc/t26/s4421/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4421%2F1%2FA","sourceRelease":"119-100","text":"any wager with respect to a sports event or a contest placed with a person engaged in the business of accepting such wagers,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s4421/1/B","parentIdentifier":"/us/usc/t26/s4421/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4421%2F1%2FB","sourceRelease":"119-100","text":"any wager placed in a wagering pool with respect to a sports event or a contest, if such pool is conducted for profit, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t26/s4421/1/C","parentIdentifier":"/us/usc/t26/s4421/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4421%2F1%2FC","sourceRelease":"119-100","text":"any wager placed in a lottery conducted for profit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Lottery","label":"2 Lottery","identifier":"/us/usc/t26/s4421/2","parentIdentifier":"/us/usc/t26/s4421","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4421%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s4421/2/A","parentIdentifier":"/us/usc/t26/s4421/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4421%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s4421/2/A/i","parentIdentifier":"/us/usc/t26/s4421/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4421%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the wagers are placed,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s4421/2/A/ii","parentIdentifier":"/us/usc/t26/s4421/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4421%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the winners are determined, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t26/s4421/2/A/iii","parentIdentifier":"/us/usc/t26/s4421/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4421%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"the distribution of prizes or other property is made, in the presence of all persons placing wagers in such game, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s4421/2/B","parentIdentifier":"/us/usc/t26/s4421/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4421%2F2%2FB","sourceRelease":"119-100","text":"any drawing conducted by an organization exempt from tax under sections 501 and 521, if no part of the net proceeds derived from such drawing inures to the benefit of any private shareholder or individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
