%2Ff%2F2%2FC%2Fii","sourceRelease":"119-100","text":"delivery, including transmission by pipeline and other distribution methods for hydrogen; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16154/f/2/C/iii","parentIdentifier":"/us/usc/t42/s16154/f/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16154%2Ff%2F2%2FC%2Fiii","sourceRelease":"119-100","text":"storage, including storage in surface transportation vehicles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16154/f/2/D","parentIdentifier":"/us/usc/t42/s16154/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16154%2Ff%2F2%2FD","sourceRelease":"119-100","text":"hydrogen for fuel cells, internal combustion engines, and other energy conversion devices for portable, stationary, micro, critical needs facilities, and transportation applications; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16154/f/2/E","parentIdentifier":"/us/usc/t42/s16154/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16154%2Ff%2F2%2FE","sourceRelease":"119-100","text":"other technologies consistent with the Department’s plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Fuel cells","label":"3 Fuel cells","identifier":"/us/usc/t42/s16154/f/3","parentIdentifier":"/us/usc/t42/s16154/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16154%2Ff%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"ty