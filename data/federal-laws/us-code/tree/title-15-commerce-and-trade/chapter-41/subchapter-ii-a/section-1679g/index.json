{"type":"section","nativeType":"section","number":"1679g","heading":"Civil liability","label":"1679g Civil liability","identifier":"/us/usc/t15/s1679g","parentIdentifier":"/us/usc/t15/ch41/schII–A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection applicable after the end of the 6-month period beginning on , except with respect to contracts entered into by a credit repair organization before the end of such period, see , as added by , set out as a note under .Sept. 30, 1996section 413 of Pub. L. 90–321Pub. L. 104–208section 1679 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Liability established","label":"a Liability established","identifier":"/us/usc/t15/s1679g/a","parentIdentifier":"/us/usc/t15/s1679g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Actual damages","label":"1 Actual damages","identifier":"/us/usc/t15/s1679g/a/1","parentIdentifier":"/us/usc/t15/s1679g/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s1679g/a/1/A","parentIdentifier":"/us/usc/t15/s1679g/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the amount of any actual damage sustained by such person as a result of such failure; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s1679g/a/1/B","parentIdentifier":"/us/usc/t15/s1679g/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fa%2F1%2FB","sourceRelease":"119-100","text":"any amount paid by the person to the credit repair organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Punitive damages","label":"2 Punitive damages","identifier":"/us/usc/t15/s1679g/a/2","parentIdentifier":"/us/usc/t15/s1679g/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Individual actions","label":"A Individual actions","identifier":"/us/usc/t15/s1679g/a/2/A","parentIdentifier":"/us/usc/t15/s1679g/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fa%2F2%2FA","sourceRelease":"119-100","text":"In the case of any action by an individual, such additional amount as the court may allow.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Class actions","label":"B Class actions","identifier":"/us/usc/t15/s1679g/a/2/B","parentIdentifier":"/us/usc/t15/s1679g/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s1679g/a/2/B/i","parentIdentifier":"/us/usc/t15/s1679g/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the aggregate of the amount which the court may allow for each named plaintiff; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s1679g/a/2/B/ii","parentIdentifier":"/us/usc/t15/s1679g/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the aggregate of the amount which the court may allow for each other class member, without regard to any minimum individual recovery.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Attorneys’ fees","label":"3 Attorneys’ fees","identifier":"/us/usc/t15/s1679g/a/3","parentIdentifier":"/us/usc/t15/s1679g/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fa%2F3","sourceRelease":"119-100","text":"In the case of any successful action to enforce any liability under paragraph (1) or (2), the costs of the action, together with reasonable attorneys’ fees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Factors to be considered in awarding punitive damages","label":"b Factors to be considered in awarding punitive damages","identifier":"/us/usc/t15/s1679g/b","parentIdentifier":"/us/usc/t15/s1679g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s1679g/b/1","parentIdentifier":"/us/usc/t15/s1679g/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fb%2F1","sourceRelease":"119-100","text":"the frequency and persistence of noncompliance by the credit repair organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s1679g/b/2","parentIdentifier":"/us/usc/t15/s1679g/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fb%2F2","sourceRelease":"119-100","text":"the nature of the noncompliance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s1679g/b/3","parentIdentifier":"/us/usc/t15/s1679g/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fb%2F3","sourceRelease":"119-100","text":"the extent to which such noncompliance was intentional; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s1679g/b/4","parentIdentifier":"/us/usc/t15/s1679g/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679g%2Fb%2F4","sourceRelease":"119-100","text":"in the case of any class action, the number of consumers adversely affected.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
