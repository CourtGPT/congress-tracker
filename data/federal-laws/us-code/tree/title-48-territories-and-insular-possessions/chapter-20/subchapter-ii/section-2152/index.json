{"type":"section","nativeType":"section","number":"2152","heading":"Intervention in litigation","label":"2152 Intervention in litigation","identifier":"/us/usc/t48/s2152","parentIdentifier":"/us/usc/t48/ch20/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs2152","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Intervention","label":"a Intervention","identifier":"/us/usc/t48/s2152/a","parentIdentifier":"/us/usc/t48/s2152","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs2152%2Fa","sourceRelease":"119-100","text":"The Oversight Board may intervene in any litigation filed against the territorial government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Injunctive relief","label":"b Injunctive relief","identifier":"/us/usc/t48/s2152/b","parentIdentifier":"/us/usc/t48/s2152","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs2152%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t48/s2152/b/1","parentIdentifier":"/us/usc/t48/s2152/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs2152%2Fb%2F1","sourceRelease":"119-100","text":"If the Oversight Board intervenes in a litigation under subsection (a), the Oversight Board may seek injunctive relief, including a stay of litigation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"No independent basis for relief","label":"2 No independent basis for relief","identifier":"/us/usc/t48/s2152/b/2","parentIdentifier":"/us/usc/t48/s2152/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs2152%2Fb%2F2","sourceRelease":"119-100","text":"This section does not create an independent basis on which injunctive relief, including a stay of litigation, may be granted.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
