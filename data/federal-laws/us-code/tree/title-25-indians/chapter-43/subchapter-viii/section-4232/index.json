ull,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t25/s4232/a/2/B/i/I","parentIdentifier":"/us/usc/t25/s4232/a/2/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4232%2Fa%2F2%2FB%2Fi%2FI","sourceRelease":"119-100","text":"avoid termination of low-income affordability, in the case of foreclosure; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t25/s4232/a/2/B/i/II","parentIdentifier":"/us/usc/t25/s4232/a/2/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4232%2Fa%2F2%2FB%2Fi%2FII","sourceRelease":"119-100","text":"transfer ownership in lieu of foreclosure; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s4232/a/2/B/ii","parentIdentifier":"/us/usc/t25/s4232/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4232%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"is not for the purpose of avoiding low-income affordability restrictions, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Exception","label":"b Exception","identifier":"/us/usc/t25/s4232/b","parentIdentifier":"/us/usc/t25/s4232","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4232%2Fb","sourceRelease":"119-100","text":"Notwithstanding subsection (a), housing assistance pursuant to shall be considered affordable housing for purposes of this subchapter.section 4228(a)(2)(B) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
