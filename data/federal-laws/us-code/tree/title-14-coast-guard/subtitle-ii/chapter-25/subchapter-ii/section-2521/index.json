ourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2521%2Fc%2F2","sourceRelease":"119-100","text":"may submit to the Commandant recommendations in connection with its duties under this subsection, including recommendations to implement the advice described in paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t14/s2521/c/3","parentIdentifier":"/us/usc/t14/s2521/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2521%2Fc%2F3","sourceRelease":"119-100","text":"may brief Congress on its duties under this subsection, including the advice described in paragraph (1) and any recommendations described in paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
