{"type":"section","nativeType":"section","number":"19194","heading":"Research awards","label":"19194 Research awards","identifier":"/us/usc/t42/s19194","parentIdentifier":"/us/usc/t42/ch163/schV/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19194","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s19194/a","parentIdentifier":"/us/usc/t42/s19194","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19194%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19194/a/1","parentIdentifier":"/us/usc/t42/s19194/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19194%2Fa%2F1","sourceRelease":"119-100","text":"to expand research efforts to better understand the factors contributing to, and consequences of, sex-based and sexual harassment affecting individuals in the STEM workforce, including students and trainees; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19194/a/2","parentIdentifier":"/us/usc/t42/s19194/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19194%2Fa%2F2","sourceRelease":"119-100","text":"to examine approaches to reduce the incidence and negative consequences of such harassment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Use of funds","label":"b Use of funds","identifier":"/us/usc/t42/s19194/b","parentIdentifier":"/us/usc/t42/s19194","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19194%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19194/b/1","parentIdentifier":"/us/usc/t42/s19194/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19194%2Fb%2F1","sourceRelease":"119-100","text":"research on the sex-based and sexual harassment experiences of individuals, including in racial and ethnic minority groups, disabled individuals, foreign nationals, sexual-minority individuals, and others;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19194/b/2","parentIdentifier":"/us/usc/t42/s19194/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19194%2Fb%2F2","sourceRelease":"119-100","text":"development and assessment of policies, procedures, trainings, and interventions, with respect to sex-based and sexual harassment, conflict management, and ways to foster respectful and inclusive climates;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19194/b/3","parentIdentifier":"/us/usc/t42/s19194/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19194%2Fb%2F3","sourceRelease":"119-100","text":"research on approaches for remediating the negative impacts and outcomes of such harassment on individuals experiencing such harassment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s19194/b/4","parentIdentifier":"/us/usc/t42/s19194/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19194%2Fb%2F4","sourceRelease":"119-100","text":"support for institutions of higher education or nonprofit organizations to develop, adapt, implement, and assess the impact of innovative, evidence-based strategies, policies, and approaches to policy implementation to prevent and address sex-based and sexual harassment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s19194/b/5","parentIdentifier":"/us/usc/t42/s19194/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19194%2Fb%2F5","sourceRelease":"119-100","text":"research on alternatives to the power dynamics, hierarchical, and dependent relationships, including but not limited to the mentor-mentee relationship, in academia that have been shown to create higher levels of risk for and lower levels of reporting of sex- based and sexual harassment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s19194/b/6","parentIdentifier":"/us/usc/t42/s19194/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19194%2Fb%2F6","sourceRelease":"119-100","text":"establishing a center for the ongoing compilation, management, and analysis of organizational climate survey data.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
