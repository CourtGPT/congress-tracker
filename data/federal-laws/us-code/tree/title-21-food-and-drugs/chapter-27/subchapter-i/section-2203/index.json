{"type":"section","nativeType":"section","number":"2203","heading":"Food and Agriculture Coordinating Councils","label":"2203 Food and Agriculture Coordinating Councils","identifier":"/us/usc/t21/s2203","parentIdentifier":"/us/usc/t21/ch27/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2203","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s2203/1","parentIdentifier":"/us/usc/t21/s2203","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2203%2F1","sourceRelease":"119-100","text":"facilitating partnerships between public and private entities to help coordinate and enhance the protection of the agriculture and food system of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s2203/2","parentIdentifier":"/us/usc/t21/s2203","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2203%2F2","sourceRelease":"119-100","text":"providing for the regular and timely interchange of information between each council relating to the security of the agriculture and food system (including intelligence information);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t21/s2203/3","parentIdentifier":"/us/usc/t21/s2203","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2203%2F3","sourceRelease":"119-100","text":"identifying best practices and methods for improving the coordination among Federal, State, local, and private sector preparedness and response plans for agriculture and food defense; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragrap