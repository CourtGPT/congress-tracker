{"type":"section","nativeType":"section","number":"7106","heading":"Management rights","label":"7106 Management rights","identifier":"/us/usc/t5/s7106","parentIdentifier":"/us/usc/t5/ptIII/sptF/ch71/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective 90 days after , see , set out as an Effective Date of 1978 Amendment note under .Oct. 13, 1978section 907 of Pub. L. 95–454section 1101 of this title"],"amendments":["Effective DateSection effective 90 days after , see , set out as an Effective Date of 1978 Amendment note under .Oct. 13, 1978section 907 of Pub. L. 95–454section 1101 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s7106/a","parentIdentifier":"/us/usc/t5/s7106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s7106/a/1","parentIdentifier":"/us/usc/t5/s7106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106%2Fa%2F1","sourceRelease":"119-100","text":"to determine the mission, budget, organization, number of employees, and internal security practices of the agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s7106/a/2","parentIdentifier":"/us/usc/t5/s7106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s7106/a/2/A","parentIdentifier":"/us/usc/t5/s7106/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106%2Fa%2F2%2FA","sourceRelease":"119-100","text":"to hire, assign, direct, layoff, and retain employees in the agency, or to suspend, remove, reduce in grade or pay, or take other disciplinary action against such employees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s7106/a/2/B","parentIdentifier":"/us/usc/t5/s7106/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106%2Fa%2F2%2FB","sourceRelease":"119-100","text":"to assign work, to make determinations with respect to contracting out, and to determine the personnel by which agency operations shall be conducted;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s7106/a/2/C","parentIdentifier":"/us/usc/t5/s7106/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106%2Fa%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t5/s7106/a/2/C/i","parentIdentifier":"/us/usc/t5/s7106/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106%2Fa%2F2%2FC%2Fi","sourceRelease":"119-100","text":"among properly ranked and certified candidates for promotion; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t5/s7106/a/2/C/ii","parentIdentifier":"/us/usc/t5/s7106/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106%2Fa%2F2%2FC%2Fii","sourceRelease":"119-100","text":"any other appropriate source; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t5/s7106/a/2/D","parentIdentifier":"/us/usc/t5/s7106/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106%2Fa%2F2%2FD","sourceRelease":"119-100","text":"to take whatever actions may be necessary to carry out the agency mission during emergencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s7106/b","parentIdentifier":"/us/usc/t5/s7106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s7106/b/1","parentIdentifier":"/us/usc/t5/s7106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106%2Fb%2F1","sourceRelease":"119-100","text":"at the election of the agency, on the numbers, types, and grades of employees or positions assigned to any organizational subdivision, work project, or tour of duty, or on the technology, methods, and means of performing work;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s7106/b/2","parentIdentifier":"/us/usc/t5/s7106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106%2Fb%2F2","sourceRelease":"119-100","text":"procedures which management officials of the agency will observe in exercising any authority under this section; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s7106/b/3","parentIdentifier":"/us/usc/t5/s7106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7106%2Fb%2F3","sourceRelease":"119-100","text":"appropriate arrangements for employees adversely affected by the exercise of any authority under this section by such management officials.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
