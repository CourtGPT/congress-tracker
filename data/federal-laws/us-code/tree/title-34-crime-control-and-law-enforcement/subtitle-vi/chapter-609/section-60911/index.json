{"type":"section","nativeType":"section","number":"60911","heading":"Definitions","label":"60911 Definitions","identifier":"/us/usc/t34/s60911","parentIdentifier":"/us/usc/t34/stVI/ch609","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60911","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s60911/1","parentIdentifier":"/us/usc/t34/s60911","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60911%2F1","sourceRelease":"119-100","text":"The term “designated person” means an immediate family member or someone similarly situated, as defined by the Attorney General.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s60911/2","parentIdentifier":"/us/usc/t34/s60911","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60911%2F2","sourceRelease":"119-100","text":"The term “immediate family member” means a parent, parent-in-law, grandparent, grandparent-in-law, sibling, spouse, child, or step-child of a murder victim.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s60911/3","parentIdentifier":"/us/usc/t34/s60911","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60911%2F3","sourceRelease":"119-100","text":"The term “victim” means a natural person who died as a result of a cold case murder.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t34/s60911/4","parentIdentifier":"/us/usc/t34/s60911","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60911%2F4","sourceRelease":"119-100","text":"The term “murder” means any criminal offense under or any offense the elements of which are substantially identical to such section.section 1111(a) of title 18","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t34/s60911/5","parentIdentifier":"/us/usc/t34/s60911","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60911%2F5","sourceRelease":"119-100","text":"The term “agency” means a Federal law enforcement entity with jurisdiction to engage in the detection, investigation, or prosecution of a cold case murder.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t34/s60911/6","parentIdentifier":"/us/usc/t34/s60911","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60911%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s60911/6/A","parentIdentifier":"/us/usc/t34/s60911/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60911%2F6%2FA","sourceRelease":"119-100","text":"committed more than three years prior to the date of an application by a designated person under ;section 60901(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s60911/6/B","parentIdentifier":"/us/usc/t34/s60911/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60911%2F6%2FB","sourceRelease":"119-100","text":"previously investigated by a Federal law enforcement entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s60911/6/C","parentIdentifier":"/us/usc/t34/s60911/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60911%2F6%2FC","sourceRelease":"119-100","text":"for which all probative investigative leads have been exhausted; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s60911/6/D","parentIdentifier":"/us/usc/t34/s60911/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60911%2F6%2FD","sourceRelease":"119-100","text":"for which no likely perpetrator has been identified.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
