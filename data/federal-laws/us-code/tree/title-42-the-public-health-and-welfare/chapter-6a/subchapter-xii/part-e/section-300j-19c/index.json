{"type":"section","nativeType":"section","number":"300j–19c","heading":"Study on intractable water systems","label":"300j–19c Study on intractable water systems","identifier":"/us/usc/t42/s300j–19c","parentIdentifier":"/us/usc/t42/ch6A/schXII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definition of intractable water system","label":"a Definition of intractable water system","identifier":"/us/usc/t42/s300j–19c/a","parentIdentifier":"/us/usc/t42/s300j–19c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300j–19c/a/1","parentIdentifier":"/us/usc/t42/s300j–19c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fa%2F1","sourceRelease":"119-100","text":"that serves fewer than 1,000 individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300j–19c/a/2","parentIdentifier":"/us/usc/t42/s300j–19c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–19c/a/2/A","parentIdentifier":"/us/usc/t42/s300j–19c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fa%2F2%2FA","sourceRelease":"119-100","text":"is unable or unwilling to provide safe and adequate service to those individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–19c/a/2/B","parentIdentifier":"/us/usc/t42/s300j–19c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fa%2F2%2FB","sourceRelease":"119-100","text":"has abandoned or effectively abandoned the community water system or noncommunity water system, as applicable;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300j–19c/a/2/C","parentIdentifier":"/us/usc/t42/s300j–19c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fa%2F2%2FC","sourceRelease":"119-100","text":"has defaulted on a financial obligation relating to the community water system or noncommunity water system, as applicable; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s300j–19c/a/2/D","parentIdentifier":"/us/usc/t42/s300j–19c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fa%2F2%2FD","sourceRelease":"119-100","text":"fails to maintain the facilities of the community water system or noncommunity water system, as applicable, in a manner so as to prevent a potential public health hazard; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300j–19c/a/3","parentIdentifier":"/us/usc/t42/s300j–19c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–19c/a/3/A","parentIdentifier":"/us/usc/t42/s300j–19c/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fa%2F3%2FA","sourceRelease":"119-100","text":"in significant noncompliance with this chapter or any regulation promulgated pursuant to this chapter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–19c/a/3/B","parentIdentifier":"/us/usc/t42/s300j–19c/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fa%2F3%2FB","sourceRelease":"119-100","text":"listed as having a history of significant noncompliance with this subchapter pursuant to .section 300g–9(b)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Study required","label":"b Study required","identifier":"/us/usc/t42/s300j–19c/b","parentIdentifier":"/us/usc/t42/s300j–19c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s300j–19c/b/1","parentIdentifier":"/us/usc/t42/s300j–19c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–19c/b/1/A","parentIdentifier":"/us/usc/t42/s300j–19c/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fb%2F1%2FA","sourceRelease":"119-100","text":"identifies intractable water systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–19c/b/1/B","parentIdentifier":"/us/usc/t42/s300j–19c/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fb%2F1%2FB","sourceRelease":"119-100","text":"describes barriers to delivery of potable water to individuals served by an intractable water system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report to Congress","label":"2 Report to Congress","identifier":"/us/usc/t42/s300j–19c/b/2","parentIdentifier":"/us/usc/t42/s300j–19c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319c%2Fb%2F2","sourceRelease":"119-100","text":"Not later than 2 years after , the Administrator shall submit to Congress a report describing findings and recommendations based on the study under this subsection.October 23, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
