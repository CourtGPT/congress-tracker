81/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17081%2Fe%2F10","sourceRelease":"119-100","text":"the Office of Science Technology and Policy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t42/s17081/e/11","parentIdentifier":"/us/usc/t42/s17081/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17081%2Fe%2F11","sourceRelease":"119-100","text":"such nonprofit high-performance green building rating and analysis entities as the Commercial Director determines can offer support, expertise, and review services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"High-Performance Green Building Partnership Consortium","label":"f High-Performance Green Building Partnership Consortium","identifier":"/us/usc/t42/s17081/f","parentIdentifier":"/us/usc/t42/s17081","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17081%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Recognition","label":"1 Recognition","identifier":"/us/usc/t42/s17081/f/1","parentIdentifier":"/us/usc/t42/s17081/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17081%2Ff%2F1","sourceRelease":"119-100","text":"Not later than 90 days after , the Commercial Director shall formally recognize one or more groups that qualify as a high-performance green building partnership consortium.December 19, 2007","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Representation to qualify","label":"2 Representation to qualify","identifier":"/us/usc/t42/s17081/f/2","parentIdentifier":"/us/usc/t42/s17081/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17081%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17081/f/2/A","parentIdentifier":"/us/usc/t42/s17081/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17081%2Ff%2F2%2FA","sourceRelease":"119-100","text":"the design professions, including national associations of architects and of professional engineers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17081/f/2/B","parentIdentifier":"/us/usc/t42/s17081/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17081%2Ff%2F2%2FB","sourceRelease":"119-100","text":"the development, construction, financial, and real estate industries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17081/f/2/C","parentIdentifier":"/us/usc/t42/s17081/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17081%2Ff%2F2%2FC","sourceRelease":"119-100","text":"building owners and operators from the public and private sectors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17081/f/2/D","parentIdentifier":"/us/usc/t42/s17081/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17081%2Ff%2F2%2FD","sourceRelease":"119-100","text":"academic and research organizations, including at least one national laboratory with extensive commercial building energy expertise;","notes":[],"amendments":[],"effectiveDate":nu