{"type":"section","nativeType":"section","number":"2365","heading":"Sense of Congress concerning purchase, packaging, and transportation of fissile materials at risk of theft","label":"2365 Sense of Congress concerning purchase, packaging, and transportation of fissile materials at risk of theft","identifier":"/us/usc/t50/s2365","parentIdentifier":"/us/usc/t50/ch40/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2365","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2365/1","parentIdentifier":"/us/usc/t50/s2365","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2365%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s2365/1/A","parentIdentifier":"/us/usc/t50/s2365/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2365%2F1%2FA","sourceRelease":"119-100","text":"there is a significant risk of theft of such materials; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s2365/1/B","parentIdentifier":"/us/usc/t50/s2365/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2365%2F1%2FB","sourceRelease":"119-100","text":"there is no reasonable and economically feasible alternative for securing such materials; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2365/2","parentIdentifier":"/us/usc/t50/s2365","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2365%2F2","sourceRelease":"119-100","text":"if it is necessary to do so in order to secure the materials, the materials should be imported into the United States, subject to the laws and regulations that are applicable to the importation of such materials into the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
