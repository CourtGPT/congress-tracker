{"type":"section","nativeType":"section","number":"4413","heading":"Executive Board","label":"4413 Executive Board","identifier":"/us/usc/t20/s4413","parentIdentifier":"/us/usc/t20/ch56/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4413","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Composition","label":"a Composition","identifier":"/us/usc/t20/s4413/a","parentIdentifier":"/us/usc/t20/s4413","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4413%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s4413/a/1","parentIdentifier":"/us/usc/t20/s4413/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4413%2Fa%2F1","sourceRelease":"119-100","text":"the chairman of the Board;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s4413/a/2","parentIdentifier":"/us/usc/t20/s4413/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4413%2Fa%2F2","sourceRelease":"119-100","text":"the vice chairman of the Board;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s4413/a/3","parentIdentifier":"/us/usc/t20/s4413/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4413%2Fa%2F3","sourceRelease":"119-100","text":"the secretary of the Board;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s4413/a/4","parentIdentifier":"/us/usc/t20/s4413/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4413%2Fa%2F4","sourceRelease":"119-100","text":"the treasurer of the Board; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t20/s4413/a/5","parentIdentifier":"/us/usc/t20/s4413/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4413%2Fa%2F5","sourceRelease":"119-100","text":"an at-large member of the Board elected by the Board at its initial meeting.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Vacancies","label":"b Vacancies","identifier":"/us/usc/t20/s4413/b","parentIdentifier":"/us/usc/t20/s4413","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4413%2Fb","sourceRelease":"119-100","text":"In the case of any vacancy which occurs in the position of at-large member before the expiration of such member’s term, the Board shall elect a replacement to complete that term.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Meetings","label":"c Meetings","identifier":"/us/usc/t20/s4413/c","parentIdentifier":"/us/usc/t20/s4413","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4413%2Fc","sourceRelease":"119-100","text":"The Executive Board shall hold not more than 4 regular meetings per calendar year. Special meetings may be held upon the call of the chairman or 3 members of the Executive Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Quorum","label":"d Quorum","identifier":"/us/usc/t20/s4413/d","parentIdentifier":"/us/usc/t20/s4413","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4413%2Fd","sourceRelease":"119-100","text":"A majority of the Executive Board shall constitute a quorum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Powers","label":"e Powers","identifier":"/us/usc/t20/s4413/e","parentIdentifier":"/us/usc/t20/s4413","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4413%2Fe","sourceRelease":"119-100","text":"The Executive Board may hold and use all the powers of the Board, subject to the approval of the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
