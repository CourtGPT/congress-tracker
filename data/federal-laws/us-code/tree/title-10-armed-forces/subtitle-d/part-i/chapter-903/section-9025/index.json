{"type":"section","nativeType":"section","number":"9025","heading":"Office of Expanded Competition","label":"9025 Office of Expanded Competition","identifier":"/us/usc/t10/s9025","parentIdentifier":"/us/usc/t10/stD/ptI/ch903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t10/s9025/a","parentIdentifier":"/us/usc/t10/s9025","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fa","sourceRelease":"119-100","text":"There is in the Office of the Secretary of the Air Force an office to be known as the Office of Expanded Competition (in this section referred to as the “Office”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Director","label":"b .—Director","identifier":"/us/usc/t10/s9025/b","parentIdentifier":"/us/usc/t10/s9025","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s9025/b/1","parentIdentifier":"/us/usc/t10/s9025/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fb%2F1","sourceRelease":"119-100","text":"are in a Senior Executive Service position (as defined in ) at the time of appointment; orsection 3132 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s9025/b/2","parentIdentifier":"/us/usc/t10/s9025/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fb%2F2","sourceRelease":"119-100","text":"are not in a Senior Executive Service position at the time of appointment, but meet the Executive Core Qualifications (ECQs) for such a position.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Duties","label":"c .—Duties","identifier":"/us/usc/t10/s9025/c","parentIdentifier":"/us/usc/t10/s9025","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s9025/c/1","parentIdentifier":"/us/usc/t10/s9025/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fc%2F1","sourceRelease":"119-100","text":"In consultation with other components of the Department of Defense and the Federal Government, conduct coordinated and integrated assessments of adversarial capital flows into industries or businesses of interest to the Department of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s9025/c/2","parentIdentifier":"/us/usc/t10/s9025/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fc%2F2","sourceRelease":"119-100","text":"Identify and prioritize promising critical technologies and assets for the Joint Force in need of capital assistance, including critical technologies and assets available from foreign entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s9025/c/3","parentIdentifier":"/us/usc/t10/s9025/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fc%2F3","sourceRelease":"119-100","text":"Fund investments in such technologies and assets, including supply chain technologies not always supported through direct investment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s9025/c/4","parentIdentifier":"/us/usc/t10/s9025/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fc%2F4","sourceRelease":"119-100","text":"Support the coordination and outreach efforts of technology scouting and acquisition elements within the Department of Defense to enable investment decision-making by those elements that counteract entities employing adversarial capital flows against industries or businesses described in paragraph (1), including the employment of relevant authorities vested in other components of the Department and the Federal Government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s9025/c/5","parentIdentifier":"/us/usc/t10/s9025/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fc%2F5","sourceRelease":"119-100","text":"Identify, accelerate, and sustain the establishment, research, development, construction, procurement, leasing, consolidation, alteration, improvement, modernization, and repair of tangible and intangible assets vital to the national security of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t10/s9025/c/6","parentIdentifier":"/us/usc/t10/s9025/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fc%2F6","sourceRelease":"119-100","text":"Help the Department of Defense provide capital assistance to entities, including foreign entities, engaged in investments that facilitate the efforts of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t10/s9025/c/7","parentIdentifier":"/us/usc/t10/s9025/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fc%2F7","sourceRelease":"119-100","text":"Experiment, prototype, test, or validate Government-developed or commercially developed analytical tools, processes, and tradecraft to improve the due diligence and investment analysis processes for the Department of Defense, including the employment of relevant delegated authorities vested in other components of the Department and the Federal Government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t10/s9025/c/8","parentIdentifier":"/us/usc/t10/s9025/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fc%2F8","sourceRelease":"119-100","text":"Assist the Secretary of Defense in developing access and placement using commercial means.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t10/s9025/c/9","parentIdentifier":"/us/usc/t10/s9025/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fc%2F9","sourceRelease":"119-100","text":"Otherwise engage with, coordinate, and collaborate with other components of the Department of Defense and the Federal Government to maximize efficiencies and promote whole-of-government solutions to protect the national security of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Definitions","label":"d .—Definitions","identifier":"/us/usc/t10/s9025/d","parentIdentifier":"/us/usc/t10/s9025","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s9025/d/1","parentIdentifier":"/us/usc/t10/s9025/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s9025/d/1/A","parentIdentifier":"/us/usc/t10/s9025/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the government of a country that is an adversary of the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s9025/d/1/B","parentIdentifier":"/us/usc/t10/s9025/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fd%2F1%2FB","sourceRelease":"119-100","text":"an entity organized under the laws of, or otherwise subject to the jurisdiction of, such a country.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s9025/d/2","parentIdentifier":"/us/usc/t10/s9025/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9025%2Fd%2F2","sourceRelease":"119-100","text":"The term “capital assistance” means a loan, loan guarantee, or technical assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
