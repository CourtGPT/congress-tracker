{"type":"section","nativeType":"section","number":"283","heading":"Situations involving bombings of places of public use, Government facilities, public transportation systems, and infrastructure facilities","label":"283 Situations involving bombings of places of public use, Government facilities, public transportation systems, and infrastructure facilities","identifier":"/us/usc/t10/s283","parentIdentifier":"/us/usc/t10/stA/ptI/ch15","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in Text, referred to in subsec. (b), was renumbered by , , .Section 382 of this titlesection 282 of this titlePub. L. 114–328, div. A, title XII, § 1241(a)(2)130 Stat. 2497Dec. 23, 2016","Amendments2016— renumbered as this section.Pub. L. 114–328section 383 of this title"],"amendments":["References in Text, referred to in subsec. (b), was renumbered by , , .Section 382 of this titlesection 282 of this titlePub. L. 114–328, div. A, title XII, § 1241(a)(2)130 Stat. 2497Dec. 23, 2016","Amendments2016— renumbered as this section.Pub. L. 114–328section 383 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t10/s283/a","parentIdentifier":"/us/usc/t10/s283","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fa","sourceRelease":"119-100","text":"Upon the request of the Attorney General, the Secretary of Defense may provide assistance in support of Department of Justice activities related to the enforcement of during situations involving bombings of places of public use, Government facilities, public transportation systems, and infrastructure facilities.section 2332f of title 18","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Rendering-safe Support","label":"b .—Rendering-safe Support","identifier":"/us/usc/t10/s283/b","parentIdentifier":"/us/usc/t10/s283","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fb","sourceRelease":"119-100","text":"Military explosive ordnance disposal units providing rendering-safe support to Department of Justice activities relating to the enforcement of section 175, 229, or 2332a of title 18 in emergency situations involving weapons of mass destruction shall provide such support in a manner consistent with the provisions of section 382 of this title.1See References in Text note below.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Regulations","label":"c .—Regulations","identifier":"/us/usc/t10/s283/c","parentIdentifier":"/us/usc/t10/s283","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s283/c/1","parentIdentifier":"/us/usc/t10/s283/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary of Defense and the Attorney General shall jointly prescribe regulations concerning the types of assistance that may be provided under this section. Such regulations shall also describe the actions that Department of Defense personnel may take in circumstances incident to the provision of assistance under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s283/c/2","parentIdentifier":"/us/usc/t10/s283/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s283/c/2/A","parentIdentifier":"/us/usc/t10/s283/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s283/c/2/A/i","parentIdentifier":"/us/usc/t10/s283/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"Arrest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s283/c/2/A/ii","parentIdentifier":"/us/usc/t10/s283/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":"Any direct participation in conducting a search for or seizure of evidence related to a violation of section 175, 229, or 2332a of title 18.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t10/s283/c/2/A/iii","parentIdentifier":"/us/usc/t10/s283/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fc%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"Any direct participation in the collection of intelligence for law enforcement purposes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s283/c/2/B","parentIdentifier":"/us/usc/t10/s283/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s283/c/2/B/i","parentIdentifier":"/us/usc/t10/s283/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"The action is considered necessary for the immediate protection of human life, and civilian law enforcement officials are not capable of taking the action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s283/c/2/B/ii","parentIdentifier":"/us/usc/t10/s283/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"The action is otherwise authorized under subsection (a) or under otherwise applicable law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Explosive Ordnance Defined","label":"d .—Explosive Ordnance Defined","identifier":"/us/usc/t10/s283/d","parentIdentifier":"/us/usc/t10/s283","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s283/d/1","parentIdentifier":"/us/usc/t10/s283/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s283/d/1/A","parentIdentifier":"/us/usc/t10/s283/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd%2F1%2FA","sourceRelease":"119-100","text":"bombs and warheads;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s283/d/1/B","parentIdentifier":"/us/usc/t10/s283/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd%2F1%2FB","sourceRelease":"119-100","text":"guided and ballistic missiles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s283/d/1/C","parentIdentifier":"/us/usc/t10/s283/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd%2F1%2FC","sourceRelease":"119-100","text":"artillery, mortar, rocket, and small arms ammunition;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s283/d/1/D","parentIdentifier":"/us/usc/t10/s283/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd%2F1%2FD","sourceRelease":"119-100","text":"all mines, torpedoes, and depth charges;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t10/s283/d/1/E","parentIdentifier":"/us/usc/t10/s283/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd%2F1%2FE","sourceRelease":"119-100","text":"grenades demolition charges;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t10/s283/d/1/F","parentIdentifier":"/us/usc/t10/s283/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd%2F1%2FF","sourceRelease":"119-100","text":"pyrotechnics;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t10/s283/d/1/G","parentIdentifier":"/us/usc/t10/s283/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd%2F1%2FG","sourceRelease":"119-100","text":"clusters and dispensers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t10/s283/d/1/H","parentIdentifier":"/us/usc/t10/s283/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd%2F1%2FH","sourceRelease":"119-100","text":"cartridge- and propellant- actuated devices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t10/s283/d/1/I","parentIdentifier":"/us/usc/t10/s283/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd%2F1%2FI","sourceRelease":"119-100","text":"electroexplosives devices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t10/s283/d/1/J","parentIdentifier":"/us/usc/t10/s283/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd%2F1%2FJ","sourceRelease":"119-100","text":"clandestine and improvised explosive devices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"K","heading":null,"label":"K","identifier":"/us/usc/t10/s283/d/1/K","parentIdentifier":"/us/usc/t10/s283/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd%2F1%2FK","sourceRelease":"119-100","text":"all similar or related items or components explosive in nature; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s283/d/2","parentIdentifier":"/us/usc/t10/s283/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs283%2Fd%2F2","sourceRelease":"119-100","text":"includes all munitions containing explosives, propellants, nuclear fission or fusion materials, and biological and chemical agents.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
