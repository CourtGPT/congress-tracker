{"type":"section","nativeType":"section","number":"7416","heading":"Assessments","label":"7416 Assessments","identifier":"/us/usc/t7/s7416","parentIdentifier":"/us/usc/t7/ch101/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Assessments authorized","label":"a Assessments authorized","identifier":"/us/usc/t7/s7416/a","parentIdentifier":"/us/usc/t7/s7416","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7416/a/1","parentIdentifier":"/us/usc/t7/s7416/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fa%2F1","sourceRelease":"119-100","text":"paid by first handlers with respect to the agricultural commodity produced and marketed in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7416/a/2","parentIdentifier":"/us/usc/t7/s7416/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fa%2F2","sourceRelease":"119-100","text":"paid by importers with respect to the agricultural commodity imported into the United States, if the imported agricultural commodity is covered by the order pursuant to .section 7415(f) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Collection","label":"b Collection","identifier":"/us/usc/t7/s7416/b","parentIdentifier":"/us/usc/t7/s7416","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fb","sourceRelease":"119-100","text":"Assessments required under an order shall be remitted to the board established under the order at the time and in the manner prescribed by the order.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Limitation on assessments","label":"c Limitation on assessments","identifier":"/us/usc/t7/s7416/c","parentIdentifier":"/us/usc/t7/s7416","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fc","sourceRelease":"119-100","text":"Not more than 1 assessment may be levied on a first handler or importer under subsection (a) with respect to any agricultural commodity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Assessment rates","label":"d Assessment rates","identifier":"/us/usc/t7/s7416/d","parentIdentifier":"/us/usc/t7/s7416","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fd","sourceRelease":"119-100","text":"The board shall recommend to the Secretary 1 or more rates of assessment to be levied under subsection (a). If approved by the Secretary, the rates shall take effect. An order may provide that an assessment rate may not be increased unless approved by a referendum conducted pursuant to .section 7417 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Late-payment and interest charges","label":"e Late-payment and interest charges","identifier":"/us/usc/t7/s7416/e","parentIdentifier":"/us/usc/t7/s7416","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s7416/e/1","parentIdentifier":"/us/usc/t7/s7416/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fe%2F1","sourceRelease":"119-100","text":"Late-payment and interest charges may be levied on each person subject to an order who fails to remit an assessment in accordance with subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Rate","label":"2 Rate","identifier":"/us/usc/t7/s7416/e/2","parentIdentifier":"/us/usc/t7/s7416/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fe%2F2","sourceRelease":"119-100","text":"The rate for the charges shall be specified by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Investment of assessments","label":"f Investment of assessments","identifier":"/us/usc/t7/s7416/f","parentIdentifier":"/us/usc/t7/s7416","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7416/f/1","parentIdentifier":"/us/usc/t7/s7416/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Ff%2F1","sourceRelease":"119-100","text":"obligations of the United States or any agency of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7416/f/2","parentIdentifier":"/us/usc/t7/s7416/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Ff%2F2","sourceRelease":"119-100","text":"general obligations of any State or any political subdivision of a State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7416/f/3","parentIdentifier":"/us/usc/t7/s7416/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Ff%2F3","sourceRelease":"119-100","text":"interest-bearing accounts or certificates of deposit of financial institutions that are members of the Federal Reserve System; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s7416/f/4","parentIdentifier":"/us/usc/t7/s7416/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Ff%2F4","sourceRelease":"119-100","text":"obligations fully guaranteed as to principal and interest by the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Refund of assessments from escrow account","label":"g Refund of assessments from escrow account","identifier":"/us/usc/t7/s7416/g","parentIdentifier":"/us/usc/t7/s7416","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Escrow account","label":"1 Escrow account","identifier":"/us/usc/t7/s7416/g/1","parentIdentifier":"/us/usc/t7/s7416/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7416/g/1/A","parentIdentifier":"/us/usc/t7/s7416/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg%2F1%2FA","sourceRelease":"119-100","text":"establish and maintain an escrow account of the kind described in subsection (f)(3) to be used to refund assessments; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7416/g/1/B","parentIdentifier":"/us/usc/t7/s7416/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg%2F1%2FB","sourceRelease":"119-100","text":"deposit funds in the account in accordance with paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Amount to be deposited","label":"2 Amount to be deposited","identifier":"/us/usc/t7/s7416/g/2","parentIdentifier":"/us/usc/t7/s7416/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg%2F2","sourceRelease":"119-100","text":"The board shall deposit in the account an amount equal to 10 percent of the assessments collected during the period referred to in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Right to receive refund","label":"3 Right to receive refund","identifier":"/us/usc/t7/s7416/g/3","parentIdentifier":"/us/usc/t7/s7416/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7416/g/3/A","parentIdentifier":"/us/usc/t7/s7416/g/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg%2F3%2FA","sourceRelease":"119-100","text":"the assessments were remitted on behalf of the person; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7416/g/3/B","parentIdentifier":"/us/usc/t7/s7416/g/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg%2F3%2FB","sourceRelease":"119-100","text":"the order is not approved in the referendum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Form of demand","label":"4 Form of demand","identifier":"/us/usc/t7/s7416/g/4","parentIdentifier":"/us/usc/t7/s7416/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg%2F4","sourceRelease":"119-100","text":"The demand for a refund shall be made at such time and in such form as specified by the order.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Payment of refund","label":"5 Payment of refund","identifier":"/us/usc/t7/s7416/g/5","parentIdentifier":"/us/usc/t7/s7416/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg%2F5","sourceRelease":"119-100","text":"A person entitled to a refund shall be paid promptly after the board receives satisfactory proof that the assessment for which the refund is demanded was paid on behalf of the person who makes the demand.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Proration","label":"6 Proration","identifier":"/us/usc/t7/s7416/g/6","parentIdentifier":"/us/usc/t7/s7416/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg%2F6","sourceRelease":"119-100","text":"If the funds in the escrow account required by paragraph (1) are insufficient to pay the amount of all refunds that persons subject to an order otherwise would have a right to receive under this subsection, the board shall prorate the amount of the funds among all the persons.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Closing of escrow account","label":"7 Closing of escrow account","identifier":"/us/usc/t7/s7416/g/7","parentIdentifier":"/us/usc/t7/s7416/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7416/g/7/A","parentIdentifier":"/us/usc/t7/s7416/g/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg%2F7%2FA","sourceRelease":"119-100","text":"the escrow account shall be closed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7416/g/7/B","parentIdentifier":"/us/usc/t7/s7416/g/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7416%2Fg%2F7%2FB","sourceRelease":"119-100","text":"the funds shall be available to the board for disbursement as authorized in the order.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
