{"type":"section","nativeType":"section","number":"562","heading":"Definitions","label":"562 Definitions","identifier":"/us/usc/t5/s562","parentIdentifier":"/us/usc/t5/ptI/ch5/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2022—Par. (7). substituted “chapter 10 of this title” for “the Federal Advisory Committee Act”.Pub. L. 117–2861992— renumbered as this section.Pub. L. 102–354section 582 of this title"],"amendments":["Amendments2022—Par. (7). substituted “chapter 10 of this title” for “the Federal Advisory Committee Act”.Pub. L. 117–2861992— renumbered as this section.Pub. L. 102–354section 582 of this title"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s562/1","parentIdentifier":"/us/usc/t5/s562","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562%2F1","sourceRelease":"119-100","text":"“agency” has the same meaning as in ;section 551(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s562/2","parentIdentifier":"/us/usc/t5/s562","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s562/2/A","parentIdentifier":"/us/usc/t5/s562/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562%2F2%2FA","sourceRelease":"119-100","text":"agrees to define such term to mean a general but not unanimous concurrence; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s562/2/B","parentIdentifier":"/us/usc/t5/s562/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562%2F2%2FB","sourceRelease":"119-100","text":"agrees upon another specified definition;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s562/3","parentIdentifier":"/us/usc/t5/s562","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562%2F3","sourceRelease":"119-100","text":"“convener” means a person who impartially assists an agency in determining whether establishment of a negotiated rulemaking committee is feasible and appropriate in a particular rulemaking;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t5/s562/4","parentIdentifier":"/us/usc/t5/s562","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562%2F4","sourceRelease":"119-100","text":"“facilitator” means a person who impartially aids in the discussions and negotiations among the members of a negotiated rulemaking committee to develop a proposed rule;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t5/s562/5","parentIdentifier":"/us/usc/t5/s562","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562%2F5","sourceRelease":"119-100","text":"“interest” means, with respect to an issue or matter, multiple parties which have a similar point of view or which are likely to be affected in a similar manner;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t5/s562/6","parentIdentifier":"/us/usc/t5/s562","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562%2F6","sourceRelease":"119-100","text":"“negotiated rulemaking” means rulemaking through the use of a negotiated rulemaking committee;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t5/s562/7","parentIdentifier":"/us/usc/t5/s562","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562%2F7","sourceRelease":"119-100","text":"“negotiated rulemaking committee” or “committee” means an advisory committee established by an agency in accordance with this subchapter and chapter 10 of this title to consider and discuss issues for the purpose of reaching a consensus in the development of a proposed rule;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t5/s562/8","parentIdentifier":"/us/usc/t5/s562","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562%2F8","sourceRelease":"119-100","text":"“party” has the same meaning as in ;section 551(3) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t5/s562/9","parentIdentifier":"/us/usc/t5/s562","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562%2F9","sourceRelease":"119-100","text":"“person” has the same meaning as in ;section 551(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t5/s562/10","parentIdentifier":"/us/usc/t5/s562","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562%2F10","sourceRelease":"119-100","text":"“rule” has the same meaning as in ; andsection 551(4) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t5/s562/11","parentIdentifier":"/us/usc/t5/s562","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs562%2F11","sourceRelease":"119-100","text":"“rulemaking” means “rule making” as that term is defined in .section 551(5) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
