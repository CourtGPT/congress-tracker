{"type":"section","nativeType":"section","number":"371","heading":"Relationship to other incentives and pays","label":"371 Relationship to other incentives and pays","identifier":"/us/usc/t37/s371","parentIdentifier":"/us/usc/t37/ch5/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft37%2Fs371","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Treatment","label":"a .—Treatment","identifier":"/us/usc/t37/s371/a","parentIdentifier":"/us/usc/t37/s371","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft37%2Fs371%2Fa","sourceRelease":"119-100","text":"A bonus or incentive pay paid to a member of the uniformed services under subchapter II is in addition to any other pay and allowance to which a member is entitled, unless otherwise provided under this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Exception","label":"b .—Exception","identifier":"/us/usc/t37/s371/b","parentIdentifier":"/us/usc/t37/s371","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft37%2Fs371%2Fb","sourceRelease":"119-100","text":"A member may not receive a bonus or incentive pay under both subchapter I and subchapter II for the same activity, skill, or period of service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Relationship to Other Computations","label":"c .—Relationship to Other Computations","identifier":"/us/usc/t37/s371/c","parentIdentifier":"/us/usc/t37/s371","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft37%2Fs371%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t37/s371/c/1","parentIdentifier":"/us/usc/t37/s371/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft37%2Fs371%2Fc%2F1","sourceRelease":"119-100","text":"any increase in pay authorized by any other provision of this title; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t37/s371/c/2","parentIdentifier":"/us/usc/t37/s371/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft37%2Fs371%2Fc%2F2","sourceRelease":"119-100","text":"any retired pay, retainer pay, separation pay, or disability severance pay.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
