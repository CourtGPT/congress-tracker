{"type":"section","nativeType":"section","number":"3334t","heading":"Program for beyond 5G","label":"3334t Program for beyond 5G","identifier":"/us/usc/t50/s3334t","parentIdentifier":"/us/usc/t50/ch45/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334t","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","DefinitionsFor definition of “intelligence community” as used in this section, see , set out as a note under .section 7002 of Pub. L. 118–31section 3003 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t50/s3334t/a","parentIdentifier":"/us/usc/t50/s3334t","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334t%2Fa","sourceRelease":"119-100","text":"The Director of National Intelligence, acting through the Director of the Intelligence Advanced Research Projects Activity, may initiate or otherwise carry out a program dedicated to research and development efforts relevant to 6G technology and any successor technologies, but only if such efforts are specific to potential applications of 6G technology (or any successor technologies) for the intelligence community or for other national security purposes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Consultation and coordination","label":"b Consultation and coordination","identifier":"/us/usc/t50/s3334t/b","parentIdentifier":"/us/usc/t50/s3334t","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334t%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3334t/b/1","parentIdentifier":"/us/usc/t50/s3334t/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334t%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3334t/b/1/A","parentIdentifier":"/us/usc/t50/s3334t/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334t%2Fb%2F1%2FA","sourceRelease":"119-100","text":"heads of Federal departments and agencies, including the Administrator of the National Telecommunications and Information Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3334t/b/1/B","parentIdentifier":"/us/usc/t50/s3334t/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334t%2Fb%2F1%2FB","sourceRelease":"119-100","text":"interagency bodies, such as the Committee for the Assessment of Foreign Participation in the United States Telecommunications Sector;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t50/s3334t/b/1/C","parentIdentifier":"/us/usc/t50/s3334t/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334t%2Fb%2F1%2FC","sourceRelease":"119-100","text":"private sector entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t50/s3334t/b/1/D","parentIdentifier":"/us/usc/t50/s3334t/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334t%2Fb%2F1%2FD","sourceRelease":"119-100","text":"institutions of higher learning; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t50/s3334t/b/1/E","parentIdentifier":"/us/usc/t50/s3334t/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334t%2Fb%2F1%2FE","sourceRelease":"119-100","text":"federally funded research and development centers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3334t/b/2","parentIdentifier":"/us/usc/t50/s3334t/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334t%2Fb%2F2","sourceRelease":"119-100","text":"such other individuals and entities as the Director determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"6G technology defined","label":"c 6G technology defined","identifier":"/us/usc/t50/s3334t/c","parentIdentifier":"/us/usc/t50/s3334t","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334t%2Fc","sourceRelease":"119-100","text":"In this section, the term “6G technology” means hardware, software, or other technologies relating to sixth-generation wireless networks.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
