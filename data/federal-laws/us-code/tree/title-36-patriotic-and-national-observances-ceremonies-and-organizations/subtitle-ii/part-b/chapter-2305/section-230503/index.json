{"type":"section","nativeType":"section","number":"230503","heading":"Purposes","label":"230503 Purposes","identifier":"/us/usc/t36/s230503","parentIdentifier":"/us/usc/t36/stII/ptB/ch2305","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230503","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevisedSectionSource (U.S. Code)Source (Statutes at Large)23050336:3803., , .May 23, 1986Pub. L. 99–318, § 3100 Stat. 474Before clause (1), the word “objects” is omitted as included in “purposes”."],"amendments":["Historical and Revision NotesRevisedSectionSource (U.S. Code)Source (Statutes at Large)23050336:3803., , .May 23, 1986Pub. L. 99–318, § 3100 Stat. 474Before clause (1), the word “objects” is omitted as included in “purposes”."],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t36/s230503/1","parentIdentifier":"/us/usc/t36/s230503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230503%2F1","sourceRelease":"119-100","text":"to uphold and defend the Constitution of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t36/s230503/2","parentIdentifier":"/us/usc/t36/s230503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230503%2F2","sourceRelease":"119-100","text":"to foster improvement of the condition of Vietnam-era veterans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t36/s230503/3","parentIdentifier":"/us/usc/t36/s230503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230503%2F3","sourceRelease":"119-100","text":"to promote the social welfare (including educational, economic, social, physical, and cultural improvement) of Vietnam-era veterans and other veterans in the United States by encouraging their growth, development, readjustment, self-respect, self-confidence, and usefulness;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t36/s230503/4","parentIdentifier":"/us/usc/t36/s230503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230503%2F4","sourceRelease":"119-100","text":"to improve conditions for Vietnam-era veterans and develop channels of communication to assist Vietnam-era veterans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t36/s230503/5","parentIdentifier":"/us/usc/t36/s230503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230503%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t36/s230503/5/A","parentIdentifier":"/us/usc/t36/s230503/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230503%2F5%2FA","sourceRelease":"119-100","text":"the relationship between Vietnam-era veterans and American society;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t36/s230503/5/B","parentIdentifier":"/us/usc/t36/s230503/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230503%2F5%2FB","sourceRelease":"119-100","text":"the Vietnam war experience;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t36/s230503/5/C","parentIdentifier":"/us/usc/t36/s230503/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230503%2F5%2FC","sourceRelease":"119-100","text":"the role of the United States in securing peaceful coexistence for the world community; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t36/s230503/5/D","parentIdentifier":"/us/usc/t36/s230503/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230503%2F5%2FD","sourceRelease":"119-100","text":"other matters that affect the educational, economic, social, physical, or cultural welfare of Vietnam-era veterans, other veterans, and their families;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t36/s230503/6","parentIdentifier":"/us/usc/t36/s230503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230503%2F6","sourceRelease":"119-100","text":"to assist disabled Vietnam-era veterans and other veterans in need of assistance and the dependents and survivors of those veterans; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t36/s230503/7","parentIdentifier":"/us/usc/t36/s230503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230503%2F7","sourceRelease":"119-100","text":"to consecrate the efforts of the members of the corporation, and Vietnam-era veterans generally, to mutual helpfulness and service to their country.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
