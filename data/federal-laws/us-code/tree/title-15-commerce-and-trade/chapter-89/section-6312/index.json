{"type":"section","nativeType":"section","number":"6312","heading":"Professional boxing matches conducted on Indian reservations","label":"6312 Professional boxing matches conducted on Indian reservations","identifier":"/us/usc/t15/s6312","parentIdentifier":"/us/usc/t15/ch89","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6312","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , see , set out as a note under .Jan. 1, 1997section 23 of Pub. L. 104–272section 6301 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t15/s6312/a","parentIdentifier":"/us/usc/t15/s6312","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6312%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Indian tribe","label":"1 Indian tribe","identifier":"/us/usc/t15/s6312/a/1","parentIdentifier":"/us/usc/t15/s6312/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6312%2Fa%2F1","sourceRelease":"119-100","text":"The term “Indian tribe” has the same meaning as in .section 5304(e) of title 25","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Reservation","label":"2 Reservation","identifier":"/us/usc/t15/s6312/a/2","parentIdentifier":"/us/usc/t15/s6312/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6312%2Fa%2F2","sourceRelease":"119-100","text":"The term “reservation” means the geographically defined area over which a tribal organization exercises governmental jurisdiction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Tribal organization","label":"3 Tribal organization","identifier":"/us/usc/t15/s6312/a/3","parentIdentifier":"/us/usc/t15/s6312/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6312%2Fa%2F3","sourceRelease":"119-100","text":"The term “tribal organization” has the same meaning as in section 5304() of title 25.l","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirements","label":"b Requirements","identifier":"/us/usc/t15/s6312/b","parentIdentifier":"/us/usc/t15/s6312","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6312%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s6312/b/1","parentIdentifier":"/us/usc/t15/s6312/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6312%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s6312/b/1/A","parentIdentifier":"/us/usc/t15/s6312/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6312%2Fb%2F1%2FA","sourceRelease":"119-100","text":"regulate professional boxing matches held within the reservation under the jurisdiction of that tribal organization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s6312/b/1/B","parentIdentifier":"/us/usc/t15/s6312/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6312%2Fb%2F1%2FB","sourceRelease":"119-100","text":"carry out that regulation or enter into a contract with a boxing commission to carry out that regulation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Standards and licensing","label":"2 Standards and licensing","identifier":"/us/usc/t15/s6312/b/2","parentIdentifier":"/us/usc/t15/s6312/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6312%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s6312/b/2/A","parentIdentifier":"/us/usc/t15/s6312/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6312%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the otherwise applicable standards and requirements of a State in which the reservation is located; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s6312/b/2/B","parentIdentifier":"/us/usc/t15/s6312/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6312%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the most recently published version of the recommended regulatory guidelines certified and published by the Association of Boxing Commissions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
