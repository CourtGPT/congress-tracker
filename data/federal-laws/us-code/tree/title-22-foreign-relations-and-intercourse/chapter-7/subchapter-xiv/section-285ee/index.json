{"type":"section","nativeType":"section","number":"285ee","heading":"Fifth capital increase","label":"285ee Fifth capital increase","identifier":"/us/usc/t22/s285ee","parentIdentifier":"/us/usc/t22/ch7/schXIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs285ee","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Subscription authorized","label":"a Subscription authorized","identifier":"/us/usc/t22/s285ee/a","parentIdentifier":"/us/usc/t22/s285ee","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs285ee%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s285ee/a/1","parentIdentifier":"/us/usc/t22/s285ee/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs285ee%2Fa%2F1","sourceRelease":"119-100","text":"The United States Governor of the Bank may subscribe on behalf of the United States to 1,104,420 additional shares of the capital stock of the Bank.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s285ee/a/2","parentIdentifier":"/us/usc/t22/s285ee/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs285ee%2Fa%2F2","sourceRelease":"119-100","text":"Any subscription by the United States to capital stock of the Bank shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Authorization of appropriations","label":"b Authorization of appropriations","identifier":"/us/usc/t22/s285ee/b","parentIdentifier":"/us/usc/t22/s285ee","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs285ee%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s285ee/b/1","parentIdentifier":"/us/usc/t22/s285ee/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs285ee%2Fb%2F1","sourceRelease":"119-100","text":"In order to pay for the increase in the United States subscription to the Bank provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $13,323,173,083, for payment by the Secretary of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s285ee/b/2","parentIdentifier":"/us/usc/t22/s285ee/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs285ee%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s285ee/b/2/A","parentIdentifier":"/us/usc/t22/s285ee/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs285ee%2Fb%2F2%2FA","sourceRelease":"119-100","text":"$532,929,240 is authorized to be appropriated for paid-in shares of the Bank; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s285ee/b/2/B","parentIdentifier":"/us/usc/t22/s285ee/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs285ee%2Fb%2F2%2FB","sourceRelease":"119-100","text":"$12,790,243,843 is authorized to be appropriated for callable shares of the Bank, for payment by the Secretary of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
