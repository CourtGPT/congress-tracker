{"type":"section","nativeType":"section","number":"2160","heading":"Prohibition on slaughter of dogs and cats for human consumption","label":"2160 Prohibition on slaughter of dogs and cats for human consumption","identifier":"/us/usc/t7/s2160","parentIdentifier":"/us/usc/t7/ch54","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Agriculture Improvement Act of 2018, and not as part of the Animal Welfare Act which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t7/s2160/a","parentIdentifier":"/us/usc/t7/s2160","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2160/a/1","parentIdentifier":"/us/usc/t7/s2160/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160%2Fa%2F1","sourceRelease":"119-100","text":"knowingly slaughter a dog or cat for human consumption; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2160/a/2","parentIdentifier":"/us/usc/t7/s2160/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2160/a/2/A","parentIdentifier":"/us/usc/t7/s2160/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160%2Fa%2F2%2FA","sourceRelease":"119-100","text":"a dog or cat to be slaughtered for human consumption; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2160/a/2/B","parentIdentifier":"/us/usc/t7/s2160/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160%2Fa%2F2%2FB","sourceRelease":"119-100","text":"a dog or cat part for human consumption.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Scope","label":"b Scope","identifier":"/us/usc/t7/s2160/b","parentIdentifier":"/us/usc/t7/s2160","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2160/b/1","parentIdentifier":"/us/usc/t7/s2160/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160%2Fb%2F1","sourceRelease":"119-100","text":"in or affecting interstate commerce or foreign commerce; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2160/b/2","parentIdentifier":"/us/usc/t7/s2160/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160%2Fb%2F2","sourceRelease":"119-100","text":"within the special maritime and territorial jurisdiction of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Exception for Indian tribes","label":"c Exception for Indian tribes","identifier":"/us/usc/t7/s2160/c","parentIdentifier":"/us/usc/t7/s2160","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160%2Fc","sourceRelease":"119-100","text":"The prohibition in subsection (a) shall not apply to an Indian (as defined in ) carrying out any activity described in subsection (a) for the purpose of a religious ceremony.section 5304 of title 25","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Penalty","label":"d Penalty","identifier":"/us/usc/t7/s2160/d","parentIdentifier":"/us/usc/t7/s2160","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160%2Fd","sourceRelease":"119-100","text":"Any person who violates subsection (a) shall be subject to a fine in an amount not greater than $5,000 for each violation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Effect on State law","label":"e Effect on State law","identifier":"/us/usc/t7/s2160/e","parentIdentifier":"/us/usc/t7/s2160","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2160/e/1","parentIdentifier":"/us/usc/t7/s2160/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160%2Fe%2F1","sourceRelease":"119-100","text":"limits any State or local law or regulation protecting the welfare of animals; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2160/e/2","parentIdentifier":"/us/usc/t7/s2160/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2160%2Fe%2F2","sourceRelease":"119-100","text":"prevents a State or unit of local government from adopting and enforcing an animal welfare law or regulation that is more stringent than this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
