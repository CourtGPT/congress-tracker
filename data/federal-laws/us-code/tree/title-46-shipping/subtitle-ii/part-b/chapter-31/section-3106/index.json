{"type":"section","nativeType":"section","number":"3106","heading":"Master key control system","label":"3106 Master key control system","identifier":"/us/usc/t46/s3106","parentIdentifier":"/us/usc/t46/stII/ptB/ch31","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t46/s3106/a","parentIdentifier":"/us/usc/t46/s3106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s3106/a/1","parentIdentifier":"/us/usc/t46/s3106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fa%2F1","sourceRelease":"119-100","text":"ensure that such vessel is equipped with a vessel master key control system, manual or electronic, which provides controlled access to all copies of the vessel’s master key of which access shall only be available to the individuals described in paragraph (2);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s3106/a/2","parentIdentifier":"/us/usc/t46/s3106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fa%2F2","sourceRelease":"119-100","text":"establish a list of all crew, identified by position, allowed to access and use the master key and maintain such list upon the vessel, within owner records and included in the vessel safety management system;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s3106/a/3","parentIdentifier":"/us/usc/t46/s3106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s3106/a/3/A","parentIdentifier":"/us/usc/t46/s3106/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fa%2F3%2FA","sourceRelease":"119-100","text":"dates and times of access;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s3106/a/3/B","parentIdentifier":"/us/usc/t46/s3106/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fa%2F3%2FB","sourceRelease":"119-100","text":"the room or location accessed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t46/s3106/a/3/C","parentIdentifier":"/us/usc/t46/s3106/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fa%2F3%2FC","sourceRelease":"119-100","text":"the name and rank of the crew member that used the master key; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t46/s3106/a/4","parentIdentifier":"/us/usc/t46/s3106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fa%2F4","sourceRelease":"119-100","text":"make the list under paragraph (2) and the log book under paragraph (3) available upon request to any agent of the Federal Bureau of Investigation, any member of the Coast Guard, and any law enforcement officer performing official duties in the course and scope of an investigation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Prohibited Use","label":"b .—Prohibited Use","identifier":"/us/usc/t46/s3106/b","parentIdentifier":"/us/usc/t46/s3106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fb","sourceRelease":"119-100","text":"Crew not included on the list described in subsection (a)(2) shall not have access to or use the master key unless in an emergency and shall immediately notify the master and owner of the vessel following use of such key.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Requirements for Log Book","label":"c .—Requirements for Log Book","identifier":"/us/usc/t46/s3106/c","parentIdentifier":"/us/usc/t46/s3106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s3106/c/1","parentIdentifier":"/us/usc/t46/s3106/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fc%2F1","sourceRelease":"119-100","text":"may be electronic; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s3106/c/2","parentIdentifier":"/us/usc/t46/s3106/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fc%2F2","sourceRelease":"119-100","text":"shall be located in a centralized location that is readily accessible to law enforcement personnel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Penalty","label":"d .—Penalty","identifier":"/us/usc/t46/s3106/d","parentIdentifier":"/us/usc/t46/s3106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fd","sourceRelease":"119-100","text":"Any crew member who uses the master key without having been granted access pursuant to subsection (a)(2) shall be liable to the United States Government for a civil penalty of not more than $1,000 and may be subject to suspension or revocation under section 7703.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Exemption","label":"e .—Exemption","identifier":"/us/usc/t46/s3106/e","parentIdentifier":"/us/usc/t46/s3106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs3106%2Fe","sourceRelease":"119-100","text":"This section shall not apply to vessels subject to section 3507(f).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
