{"type":"section","nativeType":"section","number":"3403","heading":"Matter for blind and other handicapped persons","label":"3403 Matter for blind and other handicapped persons","identifier":"/us/usc/t39/s3403","parentIdentifier":"/us/usc/t39/ptIV/ch34","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3403","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , pursuant to Resolution No. 71–9 of the Board of Governors. See , set out as a note preceding .July 1, 1971section 15(a) of Pub. L. 91–375section 101 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t39/s3403/a","parentIdentifier":"/us/usc/t39/s3403","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3403%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t39/s3403/a/1","parentIdentifier":"/us/usc/t39/s3403/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3403%2Fa%2F1","sourceRelease":"119-100","text":"the matter is for the use of the blind or other persons who cannot use or read conventionally printed material because of a physical impairment and who are certified by competent authority as unable to read normal reading material in accordance with the provisions of sections 135a and 135b of title 2;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t39/s3403/a/2","parentIdentifier":"/us/usc/t39/s3403/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3403%2Fa%2F2","sourceRelease":"119-100","text":"no charge, or rental, subscription, or other fee, is required for such matter or a charge, or rental, subscription, or other fee is required for such matter not in excess of the cost thereof;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t39/s3403/a/3","parentIdentifier":"/us/usc/t39/s3403/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3403%2Fa%2F3","sourceRelease":"119-100","text":"the matter may be opened by the Postal Service for inspection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t39/s3403/a/4","parentIdentifier":"/us/usc/t39/s3403/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3403%2Fa%2F4","sourceRelease":"119-100","text":"the matter contains no advertising.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t39/s3403/b","parentIdentifier":"/us/usc/t39/s3403","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3403%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t39/s3403/b/1","parentIdentifier":"/us/usc/t39/s3403/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3403%2Fb%2F1","sourceRelease":"119-100","text":"reading matter and musical scores;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t39/s3403/b/2","parentIdentifier":"/us/usc/t39/s3403/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3403%2Fb%2F2","sourceRelease":"119-100","text":"sound reproductions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t39/s3403/b/3","parentIdentifier":"/us/usc/t39/s3403/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3403%2Fb%2F3","sourceRelease":"119-100","text":"paper, records, tapes, and other material for the production of reading matter, musical scores, or sound reproductions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t39/s3403/b/4","parentIdentifier":"/us/usc/t39/s3403/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3403%2Fb%2F4","sourceRelease":"119-100","text":"reproducers or parts thereof, for sound reproductions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t39/s3403/b/5","parentIdentifier":"/us/usc/t39/s3403/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3403%2Fb%2F5","sourceRelease":"119-100","text":"braille writers, typewriters, educational or other materials or devices, or parts thereof, used for writing by, or specifically designed or adapted for use of, a blind person or a person having a physical impairment as described in subsection (a)(1) of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
