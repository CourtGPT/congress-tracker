{"type":"section","nativeType":"section","number":"7031","heading":"Electronic filing and retrieval","label":"7031 Electronic filing and retrieval","identifier":"/us/usc/t7/s7031","parentIdentifier":"/us/usc/t7/ch98/schX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t7/s7031/a","parentIdentifier":"/us/usc/t7/s7031","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fa","sourceRelease":"119-100","text":"Not later than 180 days after , in accordance with subsection (c), the Secretary of Agriculture (referred to in this subchapter as the “Secretary”) shall, to the maximum extent practicable, establish an Internet-based system that enables agricultural producers to access all forms of the agencies of the Department of Agriculture (referred to in this subchapter as the “Department”) specified in subsection (b).June 20, 2000","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Applicability","label":"b Applicability","identifier":"/us/usc/t7/s7031/b","parentIdentifier":"/us/usc/t7/s7031","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7031/b/1","parentIdentifier":"/us/usc/t7/s7031/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fb%2F1","sourceRelease":"119-100","text":"The Farm Service Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7031/b/2","parentIdentifier":"/us/usc/t7/s7031/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fb%2F2","sourceRelease":"119-100","text":"The Natural Resources Conservation Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7031/b/3","parentIdentifier":"/us/usc/t7/s7031/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fb%2F3","sourceRelease":"119-100","text":"The rural development components of the Department included in the Secretary’s service center initiative regarding State and field office collocation implemented pursuant to .section 6915 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s7031/b/4","parentIdentifier":"/us/usc/t7/s7031/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fb%2F4","sourceRelease":"119-100","text":"The agricultural producer programs component of the Commodity Credit Corporation administered by the Farm Service Agency and the Natural Resources Conservation Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Implementation","label":"c Implementation","identifier":"/us/usc/t7/s7031/c","parentIdentifier":"/us/usc/t7/s7031","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7031/c/1","parentIdentifier":"/us/usc/t7/s7031/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7031/c/1/A","parentIdentifier":"/us/usc/t7/s7031/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fc%2F1%2FA","sourceRelease":"119-100","text":"download from the Internet the forms of the agencies specified in subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7031/c/1/B","parentIdentifier":"/us/usc/t7/s7031/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fc%2F1%2FB","sourceRelease":"119-100","text":"submit completed forms via electronic facsimile, mail, or similar means;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7031/c/2","parentIdentifier":"/us/usc/t7/s7031/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fc%2F2","sourceRelease":"119-100","text":"redesign the forms by incorporating into the forms user-friendly formats and self-help guidance materials; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7031/c/3","parentIdentifier":"/us/usc/t7/s7031/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7031/c/3/A","parentIdentifier":"/us/usc/t7/s7031/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fc%2F3%2FA","sourceRelease":"119-100","text":"use computer hardware and software that is compatible among the agencies and will operate in a common computing environment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7031/c/3/B","parentIdentifier":"/us/usc/t7/s7031/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fc%2F3%2FB","sourceRelease":"119-100","text":"develop common Internet user-interface locations and applications to consolidate the agencies’ news, information, and program materials.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Progress reports","label":"d Progress reports","identifier":"/us/usc/t7/s7031/d","parentIdentifier":"/us/usc/t7/s7031","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7031%2Fd","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary shall submit to Congress a report that describes the progress made toward implementing the Internet-based system required under this section.June 20, 2000","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
