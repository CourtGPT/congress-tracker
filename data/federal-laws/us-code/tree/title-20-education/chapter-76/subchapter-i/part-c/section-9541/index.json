{"type":"section","nativeType":"section","number":"9541","heading":"Establishment","label":"9541 Establishment","identifier":"/us/usc/t20/s9541","parentIdentifier":"/us/usc/t20/ch76/schI/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9541","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t20/s9541/a","parentIdentifier":"/us/usc/t20/s9541","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9541%2Fa","sourceRelease":"119-100","text":"There is established in the Institute a National Center for Education Statistics (in this part referred to as the “Statistics Center”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Mission","label":"b Mission","identifier":"/us/usc/t20/s9541/b","parentIdentifier":"/us/usc/t20/s9541","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9541%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s9541/b/1","parentIdentifier":"/us/usc/t20/s9541/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9541%2Fb%2F1","sourceRelease":"119-100","text":"to collect and analyze education information and statistics in a manner that meets the highest methodological standards;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s9541/b/2","parentIdentifier":"/us/usc/t20/s9541/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9541%2Fb%2F2","sourceRelease":"119-100","text":"to report education information and statistics in a timely manner; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s9541/b/3","parentIdentifier":"/us/usc/t20/s9541/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9541%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s9541/b/3/A","parentIdentifier":"/us/usc/t20/s9541/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9541%2Fb%2F3%2FA","sourceRelease":"119-100","text":"is objective, secular, neutral, and nonideological and is free of partisan political influence and racial, cultural, gender, or regional bias; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s9541/b/3/B","parentIdentifier":"/us/usc/t20/s9541/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9541%2Fb%2F3%2FB","sourceRelease":"119-100","text":"is relevant and useful to practitioners, researchers, policymakers, and the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
