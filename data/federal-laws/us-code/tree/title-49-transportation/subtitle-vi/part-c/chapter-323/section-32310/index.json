ifier":"/us/usc/t49/s32310/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32310%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s32310/c/2/A","parentIdentifier":"/us/usc/t49/s32310/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32310%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s32310/c/2/A/i","parentIdentifier":"/us/usc/t49/s32310/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32310%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"that are practicable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s32310/c/2/A/ii","parentIdentifier":"/us/usc/t49/s32310/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32310%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":"for which objective rating tests, evaluation criteria, and other consumer data exist for a market-based, consumer information approach; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s32310/c/2/B","parentIdentifier":"/us/usc/t49/s32310/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32310%2Fc%2F2%2FB","sourceRelease":"119-100","text":"with respect to the long-term component of the roadmap under subsection (b)(1)(B), exist or are in development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragra