{"type":"section","nativeType":"section","number":"13508","heading":"Limited authority over cooperative associations","label":"13508 Limited authority over cooperative associations","identifier":"/us/usc/t49/s13508","parentIdentifier":"/us/usc/t49/stIV/ptB/ch135/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsProvisions similar to those in this section were contained in prior to the general amendment of this subtitle by .section 10529 of this titlePub. L. 104–88, § 102(a)","Statutory Notes and Related Subsidiaries","Effective DateSection effective , except as otherwise provided in , see , set out as a note under .Jan. 1, 1996Pub. L. 104–88section 2 of Pub. L. 104–88section 1301 of this title"],"amendments":["Prior ProvisionsProvisions similar to those in this section were contained in prior to the general amendment of this subtitle by .section 10529 of this titlePub. L. 104–88, § 102(a)"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t49/s13508/a","parentIdentifier":"/us/usc/t49/s13508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s13508/a/1","parentIdentifier":"/us/usc/t49/s13508/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fa%2F1","sourceRelease":"119-100","text":"inspect and examine the lands, buildings, and equipment of such association or federation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s13508/a/2","parentIdentifier":"/us/usc/t49/s13508/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fa%2F2","sourceRelease":"119-100","text":"inspect and copy any record of such association or federation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Reports","label":"b .—Reports","identifier":"/us/usc/t49/s13508/b","parentIdentifier":"/us/usc/t49/s13508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fb","sourceRelease":"119-100","text":"Notwithstanding section 13506(a)(5), the Secretary or the Board may require a cooperative association or federation of cooperative associations described in subsection (a) of this section to file reports with the Secretary or the Board containing answers to questions about transportation provided by such association or federation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Enforcement","label":"c .—Enforcement","identifier":"/us/usc/t49/s13508/c","parentIdentifier":"/us/usc/t49/s13508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fc","sourceRelease":"119-100","text":"The Secretary or the Board may bring a civil action to enforce subsections (a) and (b) of this section or a regulation or order of the Secretary or the Board issued under this section, when violated by a cooperative association or federation of cooperative associations described in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Reporting Penalties.—","label":"d Reporting Penalties.—","identifier":"/us/usc/t49/s13508/d","parentIdentifier":"/us/usc/t49/s13508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s13508/d/1","parentIdentifier":"/us/usc/t49/s13508/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s13508/d/1/A","parentIdentifier":"/us/usc/t49/s13508/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fd%2F1%2FA","sourceRelease":"119-100","text":"does not make the report;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s13508/d/1/B","parentIdentifier":"/us/usc/t49/s13508/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fd%2F1%2FB","sourceRelease":"119-100","text":"does not specifically, completely, and truthfully answer the question; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s13508/d/1/C","parentIdentifier":"/us/usc/t49/s13508/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fd%2F1%2FC","sourceRelease":"119-100","text":"does not maintain the record in the form and manner prescribed under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Venue","label":"2 .—Venue","identifier":"/us/usc/t49/s13508/d/2","parentIdentifier":"/us/usc/t49/s13508/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s13508/d/2/A","parentIdentifier":"/us/usc/t49/s13508/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fd%2F2%2FA","sourceRelease":"119-100","text":"the cooperative association or federation of cooperative associations has its principal office;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s13508/d/2/B","parentIdentifier":"/us/usc/t49/s13508/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fd%2F2%2FB","sourceRelease":"119-100","text":"the violation occurred; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s13508/d/2/C","parentIdentifier":"/us/usc/t49/s13508/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fd%2F2%2FC","sourceRelease":"119-100","text":"the offender is found.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Evasion Penalties","label":"e .—Evasion Penalties","identifier":"/us/usc/t49/s13508/e","parentIdentifier":"/us/usc/t49/s13508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Fe","sourceRelease":"119-100","text":"A person, or an officer, employee, or agent of that person, that by any means knowingly and willfully tries to evade compliance with the provisions of this section shall be fined at least $200 but not more than $500 for the first violation and at least $250 but not more than $2,000 for a subsequent violation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Recordkeeping Penalties","label":"f .—Recordkeeping Penalties","identifier":"/us/usc/t49/s13508/f","parentIdentifier":"/us/usc/t49/s13508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s13508/f/1","parentIdentifier":"/us/usc/t49/s13508/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Ff%2F1","sourceRelease":"119-100","text":"willfully does not make that report;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s13508/f/2","parentIdentifier":"/us/usc/t49/s13508/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Ff%2F2","sourceRelease":"119-100","text":"willfully does not specifically, completely, and truthfully answer that question in 30 days from the date that the question is required to be answered;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s13508/f/3","parentIdentifier":"/us/usc/t49/s13508/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Ff%2F3","sourceRelease":"119-100","text":"willfully does not maintain that record in the form and manner prescribed;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s13508/f/4","parentIdentifier":"/us/usc/t49/s13508/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Ff%2F4","sourceRelease":"119-100","text":"knowingly and willfully falsifies, destroys, mutilates, or changes that report or record;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t49/s13508/f/5","parentIdentifier":"/us/usc/t49/s13508/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Ff%2F5","sourceRelease":"119-100","text":"knowingly and willfully files a false report or record under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t49/s13508/f/6","parentIdentifier":"/us/usc/t49/s13508/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Ff%2F6","sourceRelease":"119-100","text":"knowingly and willfully makes a false or incomplete entry in that record about a business-related fact or transaction; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t49/s13508/f/7","parentIdentifier":"/us/usc/t49/s13508/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs13508%2Ff%2F7","sourceRelease":"119-100","text":"knowingly and willfully maintains a record in violation of a regulation or order issued under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
