{"type":"section","nativeType":"section","number":"1389","heading":"De minimis rule","label":"1389 De minimis rule","identifier":"/us/usc/t29/s1389","parentIdentifier":"/us/usc/t29/ch18/schIII/stE/pt1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1389","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Reduction of unfunded vested benefits allocable to employer withdrawn from plan","label":"a Reduction of unfunded vested benefits allocable to employer withdrawn from plan","identifier":"/us/usc/t29/s1389/a","parentIdentifier":"/us/usc/t29/s1389","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1389%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s1389/a/1","parentIdentifier":"/us/usc/t29/s1389/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1389%2Fa%2F1","sourceRelease":"119-100","text":"¾ of 1 percent of the plan’s unfunded vested obligations (determined as of the end of the plan year ending before the date of withdrawal), or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s1389/a/2","parentIdentifier":"/us/usc/t29/s1389/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1389%2Fa%2F2","sourceRelease":"119-100","text":"$50,000,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Amendment of plan for reduction of amount of unfunded vested benefits allocable to employer withdrawn from plan","label":"b Amendment of plan for reduction of amount of unfunded vested benefits allocable to employer withdrawn from plan","identifier":"/us/usc/t29/s1389/b","parentIdentifier":"/us/usc/t29/s1389","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1389%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s1389/b/1","parentIdentifier":"/us/usc/t29/s1389/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1389%2Fb%2F1","sourceRelease":"119-100","text":"the amount determined under subsection (a), or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s1389/b/2","parentIdentifier":"/us/usc/t29/s1389/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1389%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s1389/b/2/A","parentIdentifier":"/us/usc/t29/s1389/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1389%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the amount determined under subsection (a)(1), or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s1389/b/2/B","parentIdentifier":"/us/usc/t29/s1389/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1389%2Fb%2F2%2FB","sourceRelease":"119-100","text":"$100,000,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Nonapplicability","label":"c Nonapplicability","identifier":"/us/usc/t29/s1389/c","parentIdentifier":"/us/usc/t29/s1389","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1389%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s1389/c/1","parentIdentifier":"/us/usc/t29/s1389/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1389%2Fc%2F1","sourceRelease":"119-100","text":"to an employer who withdraws in a plan year in which substantially all employers withdraw from the plan, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s1389/c/2","parentIdentifier":"/us/usc/t29/s1389/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1389%2Fc%2F2","sourceRelease":"119-100","text":"in any case in which substantially all employers withdraw from the plan during a period of one or more plan years pursuant to an agreement or arrangement to withdraw, to an employer who withdraws pursuant to such agreement or arrangement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Presumption of employer withdrawal from plan pursuant to agreement or arrangement applicable in action or proceeding to determine or collect withdrawal liability","label":"d Presumption of employer withdrawal from plan pursuant to agreement or arrangement applicable in action or proceeding to determine or collect withdrawal liability","identifier":"/us/usc/t29/s1389/d","parentIdentifier":"/us/usc/t29/s1389","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1389%2Fd","sourceRelease":"119-100","text":"In any action or proceeding to determine or collect withdrawal liability, if substantially all employers have withdrawn from a plan within a period of 3 plan years, an employer who has withdrawn from such plan during such period shall be presumed to have withdrawn from the plan pursuant to an agreement or arrangement, unless the employer proves otherwise by a preponderance of the evidence.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
