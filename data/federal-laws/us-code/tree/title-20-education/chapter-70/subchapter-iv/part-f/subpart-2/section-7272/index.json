2F1%2FB%2Fi%2FII","sourceRelease":"119-100","text":"the Bureau of Indian Education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s7272/1/B/ii","parentIdentifier":"/us/usc/t20/s7272/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7272%2F1%2FB%2Fii","sourceRelease":"119-100","text":"1 or more community-based organizations, nonprofit organizations, or other public or private entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Full-service community school","label":"2 Full-service community school","identifier":"/us/usc/t20/s7272/2","parentIdentifier":"/us/usc/t20/s7272","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7272%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s7272/2/A","parentIdentifier":"/us/usc/t20/s7272/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7272%2F2%2FA","sourceRelease":"119-100","text":"participates in a community-based effort to coordinate and integrate educational, developmental, family, health, and other comprehensive services through community-based organizations and public and private partnerships; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s7272/2/B","parentIdentifier":"/us/usc/t20/s7272/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7272%2F2%2FB","sourceRelease":"119-100","text":"provides access to such services in school to students, families, and the community, such as access during the school year (including before- and after-school hours and weekends), as well as during the summer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Pipeline services","label":"3 Pipeline services","identifier":"/us/usc/t20/s7272/3","parentIdentifier":"/us/usc/t20/s7272","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7272%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s7272/3/A","parentIdentifier":"/us/usc/t20/s7272/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7272%2F3%2FA","sourceRelease":"119-100","text":"High-quality early childhood education programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s7272/3/B","parentIdentifier":"/us/usc/t20/s7272/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7272%2F3%2FB","sourceRelease":"119-100","text":"High-quality school and out-of-school-time programs and strategies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s7272/3/C","parentIdentifier":"/us/usc/t20/s7272/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7272%2F3%2FC","sourceRelease":"119-100","text":"Support for a child’s transition to elementary school, from elementary school to middle school, from middle school to high school, and from high school into and through postsecondary education and into the workforce, including any comprehensive readiness assessment determined necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s7272/3/D","parentIdentifier":"/us/usc/t20/s7272/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7272%2F3%2FD","sourceRelease":"119-100","text":"Family and community engagement and supports, which may include engaging or supporting families at school or at home.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s7272/3/E","parentIdentifier":"/us/usc/t20/s7272/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7272%2F3%2FE","sourceRelease":"119-100","text":"Activities that support postsecondary and workforce readiness, which may include job training, internship opportunities, and career counseling.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t20/s7272/3/F","parentIdentifier":"/us/usc/t20/s7272/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7272%2F3%2FF","sourceRelease":"119-100","text":"Community-based support for students who have attended the schools in the area served by the pipeline, or students who are members of the community, facilitating their continued connection to the community and success in postsecondary education and the workforce.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t20/s7272/3/G","parentIdentifier":"/us/usc/t20/s7272/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7272%2F3%2FG","sourceRelease":"119-100","text":"Social, health, nutrition, and mental health services and supports.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t20/s7272/3/H","parentIdentifier":"/us/usc/t20/s7272/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7272%2F3%2FH","sourceRelease":"119-100","text":"Juvenile crime prevention and rehabilitation programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
