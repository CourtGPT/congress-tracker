{"type":"section","nativeType":"section","number":"1158","heading":"Authority to enter into transactions other than contracts and grants to procure cost-effective, advanced technology for mission-critical needs","label":"1158 Authority to enter into transactions other than contracts and grants to procure cost-effective, advanced technology for mission-critical needs","identifier":"/us/usc/t14/s1158","parentIdentifier":"/us/usc/t14/stI/ch11/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1158","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t14/s1158/a","parentIdentifier":"/us/usc/t14/s1158","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1158%2Fa","sourceRelease":"119-100","text":"Subject to subsections (b) and (c), the Commandant may enter into transactions (other than contracts, cooperative agreements, and grants) to operate, test, and acquire cost-effective technology for the purpose of meeting the mission needs of the Coast Guard.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Operation, Testing, and Acquisition","label":"b .—Operation, Testing, and Acquisition","identifier":"/us/usc/t14/s1158/b","parentIdentifier":"/us/usc/t14/s1158","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1158%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s1158/b/1","parentIdentifier":"/us/usc/t14/s1158/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1158%2Fb%2F1","sourceRelease":"119-100","text":"carried out in accordance with Coast Guard policies and guidance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s1158/b/2","parentIdentifier":"/us/usc/t14/s1158/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1158%2Fb%2F2","sourceRelease":"119-100","text":"consistent with the operational requirements of the Coast Guard.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Limitations","label":"c .—Limitations","identifier":"/us/usc/t14/s1158/c","parentIdentifier":"/us/usc/t14/s1158","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1158%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s1158/c/1","parentIdentifier":"/us/usc/t14/s1158/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1158%2Fc%2F1","sourceRelease":"119-100","text":"does not comply with the cybersecurity standards of the Coast Guard; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s1158/c/2","parentIdentifier":"/us/usc/t14/s1158/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1158%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t14/s1158/c/2/A","parentIdentifier":"/us/usc/t14/s1158/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1158%2Fc%2F2%2FA","sourceRelease":"119-100","text":"counter-UAS or surrogate testing; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t14/s1158/c/2/B","parentIdentifier":"/us/usc/t14/s1158/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1158%2Fc%2F2%2FB","sourceRelease":"119-100","text":"intelligence, electronic warfare, and information warfare, testing, and analysis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Education and Training","label":"d .—Education and Training","identifier":"/us/usc/t14/s1158/d","parentIdentifier":"/us/usc/t14/s1158","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1158%2Fd","sourceRelease":"119-100","text":"The Commandant shall ensure that management, technical, and contracting personnel of the Coast Guard involved in the award or administration of transactions under this section are provided adequate education and training with respect to the authority under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Regulations","label":"e .—Regulations","identifier":"/us/usc/t14/s1158/e","parentIdentifier":"/us/usc/t14/s1158","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1158%2Fe","sourceRelease":"119-100","text":"The Commandant shall prescribe regulations as necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Counter-UAS Defined","label":"f .—Counter-UAS Defined","identifier":"/us/usc/t14/s1158/f","parentIdentifier":"/us/usc/t14/s1158","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1158%2Ff","sourceRelease":"119-100","text":"In this section, the term “counter-UAS” has the meaning given such term in .section 44801 of title 49","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
