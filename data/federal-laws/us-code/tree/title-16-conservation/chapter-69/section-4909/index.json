{"type":"section","nativeType":"section","number":"4909","heading":"Petitions","label":"4909 Petitions","identifier":"/us/usc/t16/s4909","parentIdentifier":"/us/usc/t16/ch69","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4909","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s4909/a","parentIdentifier":"/us/usc/t16/s4909","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4909%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s4909/a/1","parentIdentifier":"/us/usc/t16/s4909/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4909%2Fa%2F1","sourceRelease":"119-100","text":"establish, modify, or terminate any prohibition, suspension, or quota under this chapter on importation of any species of exotic bird;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s4909/a/2","parentIdentifier":"/us/usc/t16/s4909/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4909%2Fa%2F2","sourceRelease":"119-100","text":"add a species of exotic bird to, or remove such a species from, a list under ; orsection 4905 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s4909/a/3","parentIdentifier":"/us/usc/t16/s4909/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4909%2Fa%2F3","sourceRelease":"119-100","text":"determine under whether an exotic bird breeding facility is a qualifying facility.section 4906 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Consideration and ruling","label":"b Consideration and ruling","identifier":"/us/usc/t16/s4909/b","parentIdentifier":"/us/usc/t16/s4909","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4909%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s4909/b/1","parentIdentifier":"/us/usc/t16/s4909/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4909%2Fb%2F1","sourceRelease":"119-100","text":"within 90 days after receiving the petition, issue and publish in the Federal Register a preliminary ruling regarding whether the petition presents sufficient information indicating that the action requested in the petition might be warranted; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s4909/b/2","parentIdentifier":"/us/usc/t16/s4909/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4909%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s4909/b/2/A","parentIdentifier":"/us/usc/t16/s4909/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4909%2Fb%2F2%2FA","sourceRelease":"119-100","text":"provide an opportunity for the submission of public comment on the petition; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s4909/b/2/B","parentIdentifier":"/us/usc/t16/s4909/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4909%2Fb%2F2%2FB","sourceRelease":"119-100","text":"issue and publish in the Federal Register a final ruling on the petition, by not later than 90 days after the end of the period for public comment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
