{"type":"section","nativeType":"section","number":"7696","heading":"Term of obligated service","label":"7696 Term of obligated service","identifier":"/us/usc/t38/s7696","parentIdentifier":"/us/usc/t38/ptV/ch76/schVIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2019—Subsec. (c)(1). struck out second closing parenthesis before period at end.Pub. L. 116–61"],"amendments":["Amendments2019—Subsec. (c)(1). struck out second closing parenthesis before period at end.Pub. L. 116–61"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t38/s7696/a","parentIdentifier":"/us/usc/t38/s7696","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s7696/a/1","parentIdentifier":"/us/usc/t38/s7696/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696%2Fa%2F1","sourceRelease":"119-100","text":"obtain a license to practice medicine in a State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s7696/a/2","parentIdentifier":"/us/usc/t38/s7696/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696%2Fa%2F2","sourceRelease":"119-100","text":"successfully complete post-graduate training leading to eligibility for board certification in a specialty;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s7696/a/3","parentIdentifier":"/us/usc/t38/s7696/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696%2Fa%2F3","sourceRelease":"119-100","text":"serve as a full-time clinical practice employee of the Veterans Health Administration for 12 months for every $40,000 in such benefits that the employee receives, but in no case for fewer than 24 months; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s7696/a/4","parentIdentifier":"/us/usc/t38/s7696/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696%2Fa%2F4","sourceRelease":"119-100","text":"except as provided in subsection (b), to begin such service as a full-time practice employee by not later than 60 days after completing a residency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Fellowship","label":"b .—Fellowship","identifier":"/us/usc/t38/s7696/b","parentIdentifier":"/us/usc/t38/s7696","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696%2Fb","sourceRelease":"119-100","text":"In the case of a participant who receives an accredited fellowship in a medical specialty other than a medical specialty described in , the Secretary, on written request of the participant, may delay the term of obligated service under subsection (a) for the participant until after the participant completes the fellowship, but in no case later than 60 days after completion of such fellowship.section 7692 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Penalty","label":"c .—Penalty","identifier":"/us/usc/t38/s7696/c","parentIdentifier":"/us/usc/t38/s7696","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s7696/c/1","parentIdentifier":"/us/usc/t38/s7696/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696%2Fc%2F1","sourceRelease":"119-100","text":"An employee who does not complete a period of obligated service under this section shall owe the Federal Government an amount determined in accordance with the following formula: .A = B ×((T − S) ÷T)","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s7696/c/2","parentIdentifier":"/us/usc/t38/s7696/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s7696/c/2/A","parentIdentifier":"/us/usc/t38/s7696/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696%2Fc%2F2%2FA","sourceRelease":"119-100","text":"“” is the amount the employee owes the Federal Government.A","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s7696/c/2/B","parentIdentifier":"/us/usc/t38/s7696/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696%2Fc%2F2%2FB","sourceRelease":"119-100","text":"“” is the sum of all payments to or for the participant under the Specialty Education Loan Repayment Program.B","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s7696/c/2/C","parentIdentifier":"/us/usc/t38/s7696/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696%2Fc%2F2%2FC","sourceRelease":"119-100","text":"“” is the number of months in the period of obligated service of the employee.T","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t38/s7696/c/2/D","parentIdentifier":"/us/usc/t38/s7696/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7696%2Fc%2F2%2FD","sourceRelease":"119-100","text":"“” is the number of whole months of such period of obligated service served by the employee.S","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
