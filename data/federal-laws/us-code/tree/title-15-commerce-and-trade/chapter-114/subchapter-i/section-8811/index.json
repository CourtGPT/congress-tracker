{"type":"section","nativeType":"section","number":"8811","heading":"National Quantum Initiative Program","label":"8811 National Quantum Initiative Program","identifier":"/us/usc/t15/s8811","parentIdentifier":"/us/usc/t15/ch114/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8811","sourceRelease":"119-100","text":null,"notes":["Termination of SectionFor termination of section, see .section 8815 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s8811/a","parentIdentifier":"/us/usc/t15/s8811","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8811%2Fa","sourceRelease":"119-100","text":"The President shall implement a National Quantum Initiative Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirements","label":"b Requirements","identifier":"/us/usc/t15/s8811/b","parentIdentifier":"/us/usc/t15/s8811","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8811%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8811/b/1","parentIdentifier":"/us/usc/t15/s8811/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8811%2Fb%2F1","sourceRelease":"119-100","text":"establish the goals, priorities, and metrics for a 10-year plan to accelerate development of quantum information science and technology applications in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8811/b/2","parentIdentifier":"/us/usc/t15/s8811/b","sourceUrl":"https://uscod