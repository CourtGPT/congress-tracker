{"type":"section","nativeType":"section","number":"3773","heading":"Measure of damages generally","label":"3773 Measure of damages generally","identifier":"/us/usc/t22/s3773","parentIdentifier":"/us/usc/t22/ch51/schI/pt4/sptii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3773","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s3773/1","parentIdentifier":"/us/usc/t22/s3773","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3773%2F1","sourceRelease":"119-100","text":"the actual or estimated cost of repairs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s3773/2","parentIdentifier":"/us/usc/t22/s3773","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3773%2F2","sourceRelease":"119-100","text":"charter hire actually lost by the owners, or charter hire actually paid, depending upon the terms of the charter party, for the time the vessel is undergoing repairs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s3773/3","parentIdentifier":"/us/usc/t22/s3773","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3773%2F3","sourceRelease":"119-100","text":"maintenance of the vessel and wages of the crew, if they are found to be actual additional expenses or losses incurred outside of the charter hire; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s3773/4","parentIdentifier":"/us/usc/t22/s3773","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3773%2F4","sourceRelease":"119-100","text":"other expenses which are definitely and accurately shown to have been incurred necessarily and by reason of the accident or injuries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
