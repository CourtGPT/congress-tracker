{"type":"section","nativeType":"section","number":"2283","heading":"Eligible projects","label":"2283 Eligible projects","identifier":"/us/usc/t22/s2283","parentIdentifier":"/us/usc/t22/ch32/schI/ptVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationAnother is classified to .section 463 of Pub. L. 87–195section 2273 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t22/s2283/a","parentIdentifier":"/us/usc/t22/s2283","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s2283/a/1","parentIdentifier":"/us/usc/t22/s2283/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283%2Fa%2F1","sourceRelease":"119-100","text":"restoration, protection, or sustainable use of the world’s oceans and atmosphere;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s2283/a/2","parentIdentifier":"/us/usc/t22/s2283/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283%2Fa%2F2","sourceRelease":"119-100","text":"restoration, protection, or sustainable use of diverse animal and plant species;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s2283/a/3","parentIdentifier":"/us/usc/t22/s2283/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283%2Fa%2F3","sourceRelease":"119-100","text":"establishment, restoration, protection, and maintenance of parks and reserves;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s2283/a/4","parentIdentifier":"/us/usc/t22/s2283/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283%2Fa%2F4","sourceRelease":"119-100","text":"development and implementation of sound systems of natural resource management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s2283/a/5","parentIdentifier":"/us/usc/t22/s2283/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283%2Fa%2F5","sourceRelease":"119-100","text":"development and support of local conservation programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s2283/a/6","parentIdentifier":"/us/usc/t22/s2283/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283%2Fa%2F6","sourceRelease":"119-100","text":"training programs to strengthen conservation institutions and increase scientific, technical, and managerial capabilities of individuals and organizations involved in conservation efforts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t22/s2283/a/7","parentIdentifier":"/us/usc/t22/s2283/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283%2Fa%2F7","sourceRelease":"119-100","text":"efforts to generate knowledge, increase understanding, and enhance public commitment to conservation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t22/s2283/a/8","parentIdentifier":"/us/usc/t22/s2283/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283%2Fa%2F8","sourceRelease":"119-100","text":"design and implementation of sound programs of land and ecosystem management; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t22/s2283/a/9","parentIdentifier":"/us/usc/t22/s2283/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283%2Fa%2F9","sourceRelease":"119-100","text":"promotion of regenerative approaches in farming, forestry, fishing, and watershed management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t22/s2283/b","parentIdentifier":"/us/usc/t22/s2283","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s2283/b/1","parentIdentifier":"/us/usc/t22/s2283/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283%2Fb%2F1","sourceRelease":"119-100","text":"In cooperation with nongovernmental organizations, the Administrator of the Agency for International Development shall seek to identify those areas, which because of an imminent threat, are in particular need of immediate attention to prevent the loss of unique biological life or valuable ecosystem.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s2283/b/2","parentIdentifier":"/us/usc/t22/s2283/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2283%2Fb%2F2","sourceRelease":"119-100","text":"The Administrator of the Agency for International Development shall encourage as many eligible countries as possible to propose such exchanges with the purpose of demonstrating to a large number of governments the feasibility and benefits of sustainable development.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
