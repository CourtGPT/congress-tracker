{"type":"section","nativeType":"section","number":"5737a","heading":"Employees temporarily deployed in contingency operations","label":"5737a Employees temporarily deployed in contingency operations","identifier":"/us/usc/t5/s5737a","parentIdentifier":"/us/usc/t5/ptIII/sptD/ch57/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Definitions","label":"a .—Definitions","identifier":"/us/usc/t5/s5737a/a","parentIdentifier":"/us/usc/t5/s5737a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s5737a/a/1","parentIdentifier":"/us/usc/t5/s5737a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s5737a/a/1/A","parentIdentifier":"/us/usc/t5/s5737a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a%2Fa%2F1%2FA","sourceRelease":"119-100","text":"is an employee of an Executive agency or a military department, excluding a Government controlled corporation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s5737a/a/1/B","parentIdentifier":"/us/usc/t5/s5737a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a%2Fa%2F1%2FB","sourceRelease":"119-100","text":"is assigned on a temporary change of station in support of a contingency operation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s5737a/a/2","parentIdentifier":"/us/usc/t5/s5737a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s5737a/a/2/A","parentIdentifier":"/us/usc/t5/s5737a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a%2Fa%2F2%2FA","sourceRelease":"119-100","text":"from the employee’s official duty station to a temporary duty station; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s5737a/a/2/B","parentIdentifier":"/us/usc/t5/s5737a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a%2Fa%2F2%2FB","sourceRelease":"119-100","text":"for which such employee is eligible for expenses under section 5737; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s5737a/a/3","parentIdentifier":"/us/usc/t5/s5737a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a%2Fa%2F3","sourceRelease":"119-100","text":"the term “contingency operation” has the meaning given such term by .section 1482a(c) of title 10","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Quarters and Rations","label":"b .—Quarters and Rations","identifier":"/us/usc/t5/s5737a/b","parentIdentifier":"/us/usc/t5/s5737a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a%2Fb","sourceRelease":"119-100","text":"The head of an agency may provide quarters and rations, without charge, to any covered employee of such agency during the period of such employee’s temporary assignment (as described in subsection (a)(1)(B)).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Storage of Motor Vehicle","label":"c .—Storage of Motor Vehicle","identifier":"/us/usc/t5/s5737a/c","parentIdentifier":"/us/usc/t5/s5737a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s5737a/c/1","parentIdentifier":"/us/usc/t5/s5737a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a%2Fc%2F1","sourceRelease":"119-100","text":"with respect to storage during the period of the employee’s temporary assignment (as described in subsection (a)(1)(B)); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s5737a/c/2","parentIdentifier":"/us/usc/t5/s5737a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a%2Fc%2F2","sourceRelease":"119-100","text":"in the case of a covered employee, with respect to not more than one motor vehicle as of any given time.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Relationship to Other Benefits","label":"d .—Relationship to Other Benefits","identifier":"/us/usc/t5/s5737a/d","parentIdentifier":"/us/usc/t5/s5737a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5737a%2Fd","sourceRelease":"119-100","text":"Any benefits under this section shall be in addition to (and not in lieu of) any other benefits for which the covered employee is otherwise eligible.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
