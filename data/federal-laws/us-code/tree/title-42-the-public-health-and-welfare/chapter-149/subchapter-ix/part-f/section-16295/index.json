{"type":"section","nativeType":"section","number":"16295","heading":"Oil and gas research programs","label":"16295 Oil and gas research programs","identifier":"/us/usc/t42/s16295","parentIdentifier":"/us/usc/t42/ch149/schIX/ptF","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s16295/a","parentIdentifier":"/us/usc/t42/s16295","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16295/a/1","parentIdentifier":"/us/usc/t42/s16295/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fa%2F1","sourceRelease":"119-100","text":"exploration and production;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16295/a/2","parentIdentifier":"/us/usc/t42/s16295/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fa%2F2","sourceRelease":"119-100","text":"gas hydrates;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16295/a/3","parentIdentifier":"/us/usc/t42/s16295/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fa%2F3","sourceRelease":"119-100","text":"reservoir life and extension;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16295/a/4","parentIdentifier":"/us/usc/t42/s16295/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fa%2F4","sourceRelease":"119-100","text":"transportation and distribution infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16295/a/5","parentIdentifier":"/us/usc/t42/s16295/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fa%2F5","sourceRelease":"119-100","text":"ultraclean fuels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s16295/a/6","parentIdentifier":"/us/usc/t42/s16295/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fa%2F6","sourceRelease":"119-100","text":"heavy oil, oil shale, and tar sands; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s16295/a/7","parentIdentifier":"/us/usc/t42/s16295/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fa%2F7","sourceRelease":"119-100","text":"related environmental research.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Objectives","label":"b Objectives","identifier":"/us/usc/t42/s16295/b","parentIdentifier":"/us/usc/t42/s16295","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fb","sourceRelease":"119-100","text":"The objectives of this program shall include advancing the science and technology available to domestic petroleum producers, particularly independent operators, to minimize the economic dislocation caused by the decline of domestic supplies of oil and natural gas resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Natural gas and oil deposits report","label":"c Natural gas and oil deposits report","identifier":"/us/usc/t42/s16295/c","parentIdentifier":"/us/usc/t42/s16295","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fc","sourceRelease":"119-100","text":"Not later than 2 years after , and every 2 years thereafter, the Secretary of the Interior, in consultation with other appropriate Federal agencies, shall submit to Congress a report on the latest estimates of natural gas and oil reserves, reserves growth, and undiscovered resources in Federal and State waters off the coast of Louisiana, Texas, Alabama, and Mississippi.August 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Integrated clean power and energy research","label":"d Integrated clean power and energy research","identifier":"/us/usc/t42/s16295/d","parentIdentifier":"/us/usc/t42/s16295","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment of center","label":"1 Establishment of center","identifier":"/us/usc/t42/s16295/d/1","parentIdentifier":"/us/usc/t42/s16295/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary shall establish a national center or consortium of excellence in clean energy and power generation, using the resources of the Clean Power and Energy Research Consortium in existence on , to address the critical dependence of the United States on energy and the need to reduce emissions.August 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Focus areas","label":"2 Focus areas","identifier":"/us/usc/t42/s16295/d/2","parentIdentifier":"/us/usc/t42/s16295/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16295/d/2/A","parentIdentifier":"/us/usc/t42/s16295/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fd%2F2%2FA","sourceRelease":"119-100","text":"Efficiency and reliability of gas turbines for power generation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16295/d/2/B","parentIdentifier":"/us/usc/t42/s16295/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fd%2F2%2FB","sourceRelease":"119-100","text":"Reduction in emissions from power generation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16295/d/2/C","parentIdentifier":"/us/usc/t42/s16295/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fd%2F2%2FC","sourceRelease":"119-100","text":"Promotion of energy conservation issues.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16295/d/2/D","parentIdentifier":"/us/usc/t42/s16295/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fd%2F2%2FD","sourceRelease":"119-100","text":"Effectively using alternative fuels and renewable energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16295/d/2/E","parentIdentifier":"/us/usc/t42/s16295/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fd%2F2%2FE","sourceRelease":"119-100","text":"Development of advanced materials technology for oil and gas exploration and use in harsh environments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s16295/d/2/F","parentIdentifier":"/us/usc/t42/s16295/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16295%2Fd%2F2%2FF","sourceRelease":"119-100","text":"Education on energy and power generation issues.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
