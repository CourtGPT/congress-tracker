{"type":"section","nativeType":"section","number":"283z–5","heading":"Capital increase; increase in resources of Fund for Special Operations","label":"283z–5 Capital increase; increase in resources of Fund for Special Operations","identifier":"/us/usc/t22/s283z–5","parentIdentifier":"/us/usc/t22/ch7/schXII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authority to vote for, and to subscribe and contribute to, increase in authorized capital stock of Bank and increase in resources of Fund for Special Operations","label":"a Authority to vote for, and to subscribe and contribute to, increase in authorized capital stock of Bank and increase in resources of Fund for Special Operations","identifier":"/us/usc/t22/s283z–5/a","parentIdentifier":"/us/usc/t22/s283z–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Vote authorized","label":"1 Vote authorized","identifier":"/us/usc/t22/s283z–5/a/1","parentIdentifier":"/us/usc/t22/s283z–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s283z–5/a/1/A","parentIdentifier":"/us/usc/t22/s283z–5/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fa%2F1%2FA","sourceRelease":"119-100","text":"were transmitted by the Board of Executive Directors to the Governors of the Bank by resolution of ;April 19, 1989","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s283z–5/a/1/B","parentIdentifier":"/us/usc/t22/s283z–5/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fa%2F1%2FB","sourceRelease":"119-100","text":"are pending before the Board of Governors of the Bank; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s283z–5/a/1/C","parentIdentifier":"/us/usc/t22/s283z–5/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fa%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s283z–5/a/1/C/i","parentIdentifier":"/us/usc/t22/s283z–5/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fa%2F1%2FC%2Fi","sourceRelease":"119-100","text":"an increase in the authorized capital stock of the Bank and subscriptions to the Bank; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s283z–5/a/1/C/ii","parentIdentifier":"/us/usc/t22/s283z–5/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fa%2F1%2FC%2Fii","sourceRelease":"119-100","text":"an increase in the resources of the Fund for Special Operations and contributions to the Fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Subscription and contribution authority","label":"2 Subscription and contribution authority","identifier":"/us/usc/t22/s283z–5/a/2","parentIdentifier":"/us/usc/t22/s283z–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s283z–5/a/2/A","parentIdentifier":"/us/usc/t22/s283z–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fa%2F2%2FA","sourceRelease":"119-100","text":"subscribe to 760,112 shares of the increase in the authorized capital stock of the Bank; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s283z–5/a/2/B","parentIdentifier":"/us/usc/t22/s283z–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fa%2F2%2FB","sourceRelease":"119-100","text":"contribute $82,304,000 to the Fund for Special Operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitation on authorization of appropriations","label":"b Limitation on authorization of appropriations","identifier":"/us/usc/t22/s283z–5/b","parentIdentifier":"/us/usc/t22/s283z–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s283z–5/b/1","parentIdentifier":"/us/usc/t22/s283z–5/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fb%2F1","sourceRelease":"119-100","text":"$9,169,559,712, for the United States subscription to the capital stock of the Bank; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s283z–5/b/2","parentIdentifier":"/us/usc/t22/s283z–5/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fb%2F2","sourceRelease":"119-100","text":"$82,304,000, for the United States contribution to the Fund for Special Operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Organizational changes required to be made before payment for subscription to capital stock and contribution to Fund for Special Operations","label":"c Organizational changes required to be made before payment for subscription to capital stock and contribution to Fund for Special Operations","identifier":"/us/usc/t22/s283z–5/c","parentIdentifier":"/us/usc/t22/s283z–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s283z–5/c/1","parentIdentifier":"/us/usc/t22/s283z–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fc%2F1","sourceRelease":"119-100","text":"has established an environmental unit with responsibility for the development, evaluation, and integration of Bank policies, projects, and programs designed to promote environmentally sustainable development in borrower countries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s283z–5/c/2","parentIdentifier":"/us/usc/t22/s283z–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fc%2F2","sourceRelease":"119-100","text":"has increased the number of the staff of the Bank with environmentally oriented responsibilities and training;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s283z–5/c/3","parentIdentifier":"/us/usc/t22/s283z–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fc%2F3","sourceRelease":"119-100","text":"provides for an increase in the number of environmentally beneficial projects and programs financed by the Bank; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s283z–5/c/4","parentIdentifier":"/us/usc/t22/s283z–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fc%2F4","sourceRelease":"119-100","text":"has designed a process for ensuring the access of indigenous non-governmental organizations to the process for designing projects and programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Certification of access to Bank records required before payment for subscription to capital stock and contribution to Fund for Special Operations","label":"d Certification of access to Bank records required before payment for subscription to capital stock and contribution to Fund for Special Operations","identifier":"/us/usc/t22/s283z–5/d","parentIdentifier":"/us/usc/t22/s283z–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s283z–5/d/1","parentIdentifier":"/us/usc/t22/s283z–5/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fd%2F1","sourceRelease":"119-100","text":"the Bank has given the Comptroller General of the United States access to the audit memorandum issued by the Auditor General of the Bank with respect to the November 1987 disbursement of funds to the Government of Nicaragua;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s283z–5/d/2","parentIdentifier":"/us/usc/t22/s283z–5/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fd%2F2","sourceRelease":"119-100","text":"the Bank has implemented and is continuing to implement revised procedures issued in 1988 for collecting loan services payments in arrears;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s283z–5/d/3","parentIdentifier":"/us/usc/t22/s283z–5/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fd%2F3","sourceRelease":"119-100","text":"the revised procedures referred to in paragraph (2) satisfy the recommendations of the Auditor General of the Bank; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s283z–5/d/4","parentIdentifier":"/us/usc/t22/s283z–5/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs283z%E2%80%935%2Fd%2F4","sourceRelease":"119-100","text":"the Comptroller General of the United States has access to all documents of the Bank on the same terms and under the same conditions as such documents are made available to the United States Executive Director of the Bank.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
