{"type":"section","nativeType":"section","number":"285l–1","heading":"Applied Toxicological Research and Testing Program","label":"285l–1 Applied Toxicological Research and Testing Program","identifier":"/us/usc/t42/s285l–1","parentIdentifier":"/us/usc/t42/ch6A/schIII/ptC/spt12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%931","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t42/s285l–1/a","parentIdentifier":"/us/usc/t42/s285l–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%931%2Fa","sourceRelease":"119-100","text":"There is established within the Institute a program for conducting applied research and testing regarding toxicology, which program shall be known as the Applied Toxicological Research and Testing Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t42/s285l–1/b","parentIdentifier":"/us/usc/t42/s285l–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%931%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s285l–1/b/1","parentIdentifier":"/us/usc/t42/s285l–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%931%2Fb%2F1","sourceRelease":"119-100","text":"to expand knowledge of the health effects of environmental agents;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s285l–1/b/2","parentIdentifier":"/us/usc/t42/s285l–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%931%2Fb%2F2","sourceRelease":"119-100","text":"to broaden the spectrum of toxicology information that is obtained on selected chemicals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s285l–1/b/3","parentIdentifier":"/us/usc/t42/s285l–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%931%2Fb%2F3","sourceRelease":"119-100","text":"to develop and validate assays and protocols, including alternative methods that can reduce or eliminate the use of animals in acute or chronic safety testing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s285l–1/b/4","parentIdentifier":"/us/usc/t42/s285l–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%931%2Fb%2F4","sourceRelease":"119-100","text":"to establish criteria for the validation and regulatory acceptance of alternative testing and to recommend a process through which scientifically validated alternative methods can be accepted for regulatory use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s285l–1/b/5","parentIdentifier":"/us/usc/t42/s285l–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%931%2Fb%2F5","sourceRelease":"119-100","text":"to communicate the results of research to government agencies, to medical, scientific, and regulatory communities, and to the public; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s285l–1/b/6","parentIdentifier":"/us/usc/t42/s285l–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%931%2Fb%2F6","sourceRelease":"119-100","text":"to integrate related activities of the Department of Health and Human Services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
