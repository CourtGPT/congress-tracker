43/s390g–9/c/1/A/i/III","parentIdentifier":"/us/usc/t43/s390g–9/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F1%2FA%2Fi%2FIII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t43/s390g–9/c/1/A/i/III/aa","parentIdentifier":"/us/usc/t43/s390g–9/c/1/A/i/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F1%2FA%2Fi%2FIII%2Faa","sourceRelease":"119-100","text":"Federal laws; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t43/s390g–9/c/1/A/i/III/bb","parentIdentifier":"/us/usc/t43/s390g–9/c/1/A/i/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F1%2FA%2Fi%2FIII%2Fbb","sourceRelease":"119-100","text":"policies of the Bureau; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t43/s390g–9/c/1/A/i/IV","parentIdentifier":"/us/usc/t43/s390g–9/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F1%2FA%2Fi%2FIV","sourceRelease":"119-100","text":"shall comply with all applicable State laws and policies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s390g–9/c/1/A/ii","parentIdentifier":"/us/usc/t43/s390g–9/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the non-Federal party to an existing contract for water or water capacity in a Reclamation facility consents to the use of the Reclamation facility under this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Effect on existing contracts","label":"B Effect on existing contracts","identifier":"/us/usc/t43/s390g–9/c/1/B","parentIdentifier":"/us/usc/t43/s390g–9/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s390g–9/c/1/B/i","parentIdentifier":"/us/usc/t43/s390g–9/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"in effect on ; andDecember 27, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s390g–9/c/1/B/ii","parentIdentifier":"/us/usc/t43/s390g–9/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"under which the use of excess capacity in a Bureau conveyance facility for carriage of non-Reclamation project water for aquifer recharge is allowed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Aquifer recharge on eligible land","label":"2 Aquifer recharge on eligible land","identifier":"/us/usc/t43/s390g–9/c/2","parentIdentifier":"/us/usc/t43/s390g–9/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":