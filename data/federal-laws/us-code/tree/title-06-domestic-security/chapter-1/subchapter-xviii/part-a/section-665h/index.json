{"type":"section","nativeType":"section","number":"665h","heading":"National Cyber Exercise Program","label":"665h National Cyber Exercise Program","identifier":"/us/usc/t6/s665h","parentIdentifier":"/us/usc/t6/ch1/schXVIII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment of program","label":"a Establishment of program","identifier":"/us/usc/t6/s665h/a","parentIdentifier":"/us/usc/t6/s665h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s665h/a/1","parentIdentifier":"/us/usc/t6/s665h/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F1","sourceRelease":"119-100","text":"There is established in the Agency the National Cyber Exercise Program (referred to in this section as the “Exercise Program”) to evaluate the National Cyber Incident Response Plan, and other related plans and strategies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t6/s665h/a/2","parentIdentifier":"/us/usc/t6/s665h/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t6/s665h/a/2/A","parentIdentifier":"/us/usc/t6/s665h/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s665h/a/2/A/i","parentIdentifier":"/us/usc/t6/s665h/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"based on current risk assessments, including credible threats, vulnerabilities, and consequences;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s665h/a/2/A/ii","parentIdentifier":"/us/usc/t6/s665h/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"designed, to the extent practicable, to simulate the partial or complete incapacitation of a government or critical infrastructure network resulting from a cyber incident;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t6/s665h/a/2/A/iii","parentIdentifier":"/us/usc/t6/s665h/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"designed to provide for the systematic evaluation of cyber readiness and enhance operational understanding of the cyber incident response system and relevant information sharing agreements; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t6/s665h/a/2/A/iv","parentIdentifier":"/us/usc/t6/s665h/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"designed to promptly develop after-action reports and plans that can quickly incorporate lessons learned into future operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Model exercise selection","label":"B Model exercise selection","identifier":"/us/usc/t6/s665h/a/2/B","parentIdentifier":"/us/usc/t6/s665h/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s665h/a/2/B/i","parentIdentifier":"/us/usc/t6/s665h/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"include a selection of model exercises that government and private entities can readily adapt for use; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s665h/a/2/B/ii","parentIdentifier":"/us/usc/t6/s665h/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t6/s665h/a/2/B/ii/I","parentIdentifier":"/us/usc/t6/s665h/a/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F2%2FB%2Fii%2FI","sourceRelease":"119-100","text":"conform to the requirements described in subparagraph (A);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t6/s665h/a/2/B/ii/II","parentIdentifier":"/us/usc/t6/s665h/a/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F2%2FB%2Fii%2FII","sourceRelease":"119-100","text":"are consistent with any applicable national, State, local, or Tribal strategy or plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t6/s665h/a/2/B/ii/III","parentIdentifier":"/us/usc/t6/s665h/a/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F2%2FB%2Fii%2FIII","sourceRelease":"119-100","text":"provide for systematic evaluation of readiness.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Consultation","label":"3 Consultation","identifier":"/us/usc/t6/s665h/a/3","parentIdentifier":"/us/usc/t6/s665h/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fa%2F3","sourceRelease":"119-100","text":"In carrying out the Exercise Program, the Director may consult with appropriate representatives from Sector Risk Management Agencies, the Office of the National Cyber Director, cybersecurity research stakeholders, and Sector Coordinating Councils.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Definitions","label":"b Definitions","identifier":"/us/usc/t6/s665h/b","parentIdentifier":"/us/usc/t6/s665h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"State","label":"1 State","identifier":"/us/usc/t6/s665h/b/1","parentIdentifier":"/us/usc/t6/s665h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fb%2F1","sourceRelease":"119-100","text":"The term “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Northern Mariana Islands, the United States Virgin Islands, Guam, American Samoa, and any other territory or possession of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Private entity","label":"2 Private entity","identifier":"/us/usc/t6/s665h/b/2","parentIdentifier":"/us/usc/t6/s665h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fb%2F2","sourceRelease":"119-100","text":"The term “private entity” has the meaning given such term in .section 1501 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Rule of construction","label":"c Rule of construction","identifier":"/us/usc/t6/s665h/c","parentIdentifier":"/us/usc/t6/s665h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665h%2Fc","sourceRelease":"119-100","text":"Nothing in this section shall be construed to affect the authorities or responsibilities of the Administrator of the Federal Emergency Management Agency pursuant to .section 748 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
