{"type":"section","nativeType":"section","number":"705a","heading":"Rest and recuperation absence: certain members undergoing extended deployment to a combat zone","label":"705a Rest and recuperation absence: certain members undergoing extended deployment to a combat zone","identifier":"/us/usc/t10/s705a","parentIdentifier":"/us/usc/t10/stA/ptII/ch40","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs705a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2017—Subsec. (b)(1)(B). inserted “or 352(a)” after “section 305”.Pub. L. 115–91"],"amendments":["Amendments2017—Subsec. (b)(1)(B). inserted “or 352(a)” after “section 305”.Pub. L. 115–91"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Rest and Recuperation Authorized","label":"a .—Rest and Recuperation Authorized","identifier":"/us/usc/t10/s705a/a","parentIdentifier":"/us/usc/t10/s705a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs705a%2Fa","sourceRelease":"119-100","text":"Under regulations prescribed by the Secretary of Defense, the Secretary concerned may provide a member of the armed forces described in subsection (b) the benefits described in subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Covered Members","label":"b .—Covered Members","identifier":"/us/usc/t10/s705a/b","parentIdentifier":"/us/usc/t10/s705a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs705a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s705a/b/1","parentIdentifier":"/us/usc/t10/s705a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs705a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s705a/b/1/A","parentIdentifier":"/us/usc/t10/s705a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs705a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"that is designated by the President as a combat zone; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s705a/b/1/B","parentIdentifier":"/us/usc/t10/s705a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs705a%2Fb%2F1%2FB","sourceRelease":"119-100","text":"in which hardship duty pay is authorized to be paid under section 305 or 352(a) of title 37; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s705a/b/2","parentIdentifier":"/us/usc/t10/s705a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs705a%2Fb%2F2","sourceRelease":"119-100","text":"meets such other criteria as the Secretary of Defense may prescribe in the regulations required by subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Benefits","label":"c .—Benefits","identifier":"/us/usc/t10/s705a/c","parentIdentifier":"/us/usc/t10/s705a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs705a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s705a/c/1","parentIdentifier":"/us/usc/t10/s705a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs705a%2Fc%2F1","sourceRelease":"119-100","text":"A period of rest and recuperation absence for not more than 15 days.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s705a/c/2","parentIdentifier":"/us/usc/t10/s705a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs705a%2Fc%2F2","sourceRelease":"119-100","text":"Round-trip transportation at Government expense from the area or location in which the member is serving in connection with the exercise of the period of rest and recuperation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Construction With Other Leave","label":"d .—Construction With Other Leave","identifier":"/us/usc/t10/s705a/d","parentIdentifier":"/us/usc/t10/s705a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs705a%2Fd","sourceRelease":"119-100","text":"Any benefits provided a member under this section are in addition to any other leave or absence to which the member may be entitled.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
