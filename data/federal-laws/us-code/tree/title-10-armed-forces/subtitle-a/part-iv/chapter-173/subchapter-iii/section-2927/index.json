{"type":"section","nativeType":"section","number":"2927","heading":"Global bulk fuel management and delivery","label":"2927 Global bulk fuel management and delivery","identifier":"/us/usc/t10/s2927","parentIdentifier":"/us/usc/t10/stA/ptIV/ch173/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2927","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Responsible Element","label":"a .—Responsible Element","identifier":"/us/usc/t10/s2927/a","parentIdentifier":"/us/usc/t10/s2927","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2927%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2927/a/1","parentIdentifier":"/us/usc/t10/s2927/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2927%2Fa%2F1","sourceRelease":"119-100","text":"Beginning during the period described in paragraph (2) and permanently thereafter, the United States Transportation Command shall be the element responsible for bulk fuel management and delivery of the Department of Defense on a global basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2927/a/2","parentIdentifier":"/us/usc/t10/s2927/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2927%2Fa%2F2","sourceRelease":"119-100","text":"The period described in this paragraph is the period beginning on , and ending on .January 1, 2023February 1, 2023","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Coordination With Defense Logistics Agency","label":"b .—Coordination With Defense Logistics Agency","identifier":"/us/usc/t10/s2927/b","parentIdentifier":"/us/usc/t10/s2927","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2927%2Fb","sourceRelease":"119-100","text":"In carrying out the responsibilities specified in subsection (a), the Commander of the United States Transportation Command shall coordinate with the Director of the Defense Logistics Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Rule of Construction","label":"c .—Rule of Construction","identifier":"/us/usc/t10/s2927/c","parentIdentifier":"/us/usc/t10/s2927","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2927%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2927/c/1","parentIdentifier":"/us/usc/t10/s2927/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2927%2Fc%2F1","sourceRelease":"119-100","text":"limiting any other function of the Defense Logistics Agency Energy; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2927/c/2","parentIdentifier":"/us/usc/t10/s2927/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2927%2Fc%2F2","sourceRelease":"119-100","text":"requiring the transfer of any function, personnel, or asset from the Defense Logistics Agency Energy to the United States Transportation Command.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
