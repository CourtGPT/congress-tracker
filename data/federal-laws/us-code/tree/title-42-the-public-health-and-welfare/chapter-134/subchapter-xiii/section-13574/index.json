ion of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t42/s13574/c","parentIdentifier":"/us/usc/t42/s13574","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13574%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13574/c/1","parentIdentifier":"/us/usc/t42/s13574/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13574%2Fc%2F1","sourceRelease":"119-100","text":"$300,000,000 for fiscal year 2007;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13574/c/2","parentIdentifier":"/us/usc/t42/s13574/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13574%2Fc%2F2","sourceRelease":"119-100","text":"$100,000,000 for fiscal year 2008;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13574/c/3","parentIdentifier":"/us/usc/t42/s13574/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13574%2Fc%2F3","sourceRelease":"119-100","text":"$40,000,000 for fiscal year 2009;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s13574/c/4","parentIdentifier":"/us/usc/t42/s13574/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13574%2Fc%2F4","sourceRelease":"119-100","text":"$30,000,000 for fiscal year 2010; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s13574/c/5","