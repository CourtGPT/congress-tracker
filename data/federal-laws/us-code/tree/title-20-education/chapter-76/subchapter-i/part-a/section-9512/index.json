{"type":"section","nativeType":"section","number":"9512","heading":"Functions","label":"9512 Functions","identifier":"/us/usc/t20/s9512","parentIdentifier":"/us/usc/t20/ch76/schI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9512","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s9512/1","parentIdentifier":"/us/usc/t20/s9512","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9512%2F1","sourceRelease":"119-100","text":"conduct and support scientifically valid research activities, including basic research and applied research, statistics activities, scientifically valid education evaluation, development, and wide dissemination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s9512/2","parentIdentifier":"/us/usc/t20/s9512","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9512%2F2","sourceRelease":"119-100","text":"widely disseminate the findings and results of scientifically valid research in education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s9512/3","parentIdentifier":"/us/usc/t20/s9512","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9512%2F3","sourceRelease":"119-100","text":"promote the use, development, and application of knowledge gained from scientifically valid research activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s9512/4","parentIdentifier":"/us/usc/t20/s9512","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9512%2F4","sourceRelease":"119-100","text":"strengthen the national capacity to conduct, develop, and widely disseminate scientifically valid research in education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t20/s9512/5","parentIdentifier":"/us/usc/t20/s9512","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9512%2F5","sourceRelease":"119-100","text":"promote the coordination, development, and dissemination of scientifically valid research in education within the Department and the Federal Government; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t20/s9512/6","parentIdentifier":"/us/usc/t20/s9512","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9512%2F6","sourceRelease":"119-100","text":"promote the use and application of research and development to improve practice in the classroom.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
