{"type":"section","nativeType":"section","number":"3236","heading":"Inspector General external review panel","label":"3236 Inspector General external review panel","identifier":"/us/usc/t50/s3236","parentIdentifier":"/us/usc/t50/ch44/schIX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Request for review","label":"a Request for review","identifier":"/us/usc/t50/s3236/a","parentIdentifier":"/us/usc/t50/s3236","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fa","sourceRelease":"119-100","text":"An individual with a claim described in subsection (b) may submit to the Inspector General of the Intelligence Community a request for a review of such claim by an external review panel convened under subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Claims and individuals described","label":"b Claims and individuals described","identifier":"/us/usc/t50/s3236/b","parentIdentifier":"/us/usc/t50/s3236","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3236/b/1","parentIdentifier":"/us/usc/t50/s3236/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3236/b/1/A","parentIdentifier":"/us/usc/t50/s3236/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fb%2F1%2FA","sourceRelease":"119-100","text":"that the individual has been subjected to a personnel action that is prohibited under ; andsection 3234 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3236/b/1/B","parentIdentifier":"/us/usc/t50/s3236/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fb%2F1%2FB","sourceRelease":"119-100","text":"who has exhausted the applicable review process for the claim pursuant to enforcement of such section; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3236/b/2","parentIdentifier":"/us/usc/t50/s3236/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3236/b/2/A","parentIdentifier":"/us/usc/t50/s3236/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fb%2F2%2FA","sourceRelease":"119-100","text":"that he or she has been subjected to a reprisal prohibited by paragraph (1) of ; andsection 3341(j) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3236/b/2/B","parentIdentifier":"/us/usc/t50/s3236/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fb%2F2%2FB","sourceRelease":"119-100","text":"who received a decision on an appeal regarding that claim under paragraph (4) of such section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"External review panel convened","label":"c External review panel convened","identifier":"/us/usc/t50/s3236/c","parentIdentifier":"/us/usc/t50/s3236","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Discretion to convene","label":"1 Discretion to convene","identifier":"/us/usc/t50/s3236/c/1","parentIdentifier":"/us/usc/t50/s3236/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F1","sourceRelease":"119-100","text":"Upon receipt of a request under subsection (a) regarding a claim, the Inspector General of the Intelligence Community may, at the discretion of the Inspector General, convene an external review panel under this subsection to review the claim.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Membership","label":"2 Membership","identifier":"/us/usc/t50/s3236/c/2","parentIdentifier":"/us/usc/t50/s3236/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Composition","label":"A Composition","identifier":"/us/usc/t50/s3236/c/2/A","parentIdentifier":"/us/usc/t50/s3236/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t50/s3236/c/2/A/i","parentIdentifier":"/us/usc/t50/s3236/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"The Inspector General of the Intelligence Community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t50/s3236/c/2/A/ii","parentIdentifier":"/us/usc/t50/s3236/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t50/s3236/c/2/A/ii/I","parentIdentifier":"/us/usc/t50/s3236/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA%2Fii%2FI","sourceRelease":"119-100","text":"The Department of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t50/s3236/c/2/A/ii/II","parentIdentifier":"/us/usc/t50/s3236/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA%2Fii%2FII","sourceRelease":"119-100","text":"The Department of Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t50/s3236/c/2/A/ii/III","parentIdentifier":"/us/usc/t50/s3236/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA%2Fii%2FIII","sourceRelease":"119-100","text":"The Department of Homeland Security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t50/s3236/c/2/A/ii/IV","parentIdentifier":"/us/usc/t50/s3236/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA%2Fii%2FIV","sourceRelease":"119-100","text":"The Department of Justice.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t50/s3236/c/2/A/ii/V","parentIdentifier":"/us/usc/t50/s3236/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA%2Fii%2FV","sourceRelease":"119-100","text":"The Department of State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VI","heading":null,"label":"VI","identifier":"/us/usc/t50/s3236/c/2/A/ii/VI","parentIdentifier":"/us/usc/t50/s3236/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA%2Fii%2FVI","sourceRelease":"119-100","text":"The Department of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VII","heading":null,"label":"VII","identifier":"/us/usc/t50/s3236/c/2/A/ii/VII","parentIdentifier":"/us/usc/t50/s3236/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA%2Fii%2FVII","sourceRelease":"119-100","text":"The Central Intelligence Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VIII","heading":null,"label":"VIII","identifier":"/us/usc/t50/s3236/c/2/A/ii/VIII","parentIdentifier":"/us/usc/t50/s3236/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA%2Fii%2FVIII","sourceRelease":"119-100","text":"The Defense Intelligence Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IX","heading":null,"label":"IX","identifier":"/us/usc/t50/s3236/c/2/A/ii/IX","parentIdentifier":"/us/usc/t50/s3236/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA%2Fii%2FIX","sourceRelease":"119-100","text":"The National Geospatial-Intelligence Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"X","heading":null,"label":"X","identifier":"/us/usc/t50/s3236/c/2/A/ii/X","parentIdentifier":"/us/usc/t50/s3236/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA%2Fii%2FX","sourceRelease":"119-100","text":"The National Reconnaissance Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"XI","heading":null,"label":"XI","identifier":"/us/usc/t50/s3236/c/2/A/ii/XI","parentIdentifier":"/us/usc/t50/s3236/c/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FA%2Fii%2FXI","sourceRelease":"119-100","text":"The National Security Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Limitation","label":"B Limitation","identifier":"/us/usc/t50/s3236/c/2/B","parentIdentifier":"/us/usc/t50/s3236/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FB","sourceRelease":"119-100","text":"An inspector general of an agency may not be selected to sit on the panel under subparagraph (A)(ii) to review any matter relating to a decision made by such agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Chairperson","label":"C Chairperson","identifier":"/us/usc/t50/s3236/c/2/C","parentIdentifier":"/us/usc/t50/s3236/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t50/s3236/c/2/C/i","parentIdentifier":"/us/usc/t50/s3236/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FC%2Fi","sourceRelease":"119-100","text":"Except as provided in clause (ii), the chairperson of any panel convened under this subsection shall be the Inspector General of the Intelligence Community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Conflicts of interest","label":"ii Conflicts of interest","identifier":"/us/usc/t50/s3236/c/2/C/ii","parentIdentifier":"/us/usc/t50/s3236/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FC%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t50/s3236/c/2/C/ii/I","parentIdentifier":"/us/usc/t50/s3236/c/2/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FC%2Fii%2FI","sourceRelease":"119-100","text":"select a chairperson from inspectors general of the elements listed under subparagraph (A)(ii) whom the Inspector General of the Intelligence Community considers appropriate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t50/s3236/c/2/C/ii/II","parentIdentifier":"/us/usc/t50/s3236/c/2/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F2%2FC%2Fii%2FII","sourceRelease":"119-100","text":"notify the congressional intelligence committees of such selection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Period of review","label":"3 Period of review","identifier":"/us/usc/t50/s3236/c/3","parentIdentifier":"/us/usc/t50/s3236/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fc%2F3","sourceRelease":"119-100","text":"Each external review panel convened under this subsection to review a claim shall complete review of the claim no later than 270 days after the date on which the Inspector General convenes the external review panel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Remedies","label":"d Remedies","identifier":"/us/usc/t50/s3236/d","parentIdentifier":"/us/usc/t50/s3236","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Panel recommendations","label":"1 Panel recommendations","identifier":"/us/usc/t50/s3236/d/1","parentIdentifier":"/us/usc/t50/s3236/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3236/d/1/A","parentIdentifier":"/us/usc/t50/s3236/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fd%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t50/s3236/d/1/A/i","parentIdentifier":"/us/usc/t50/s3236/d/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fd%2F1%2FA%2Fi","sourceRelease":"119-100","text":"to return the employee or former employee, as nearly as practicable and reasonable, to the position such employee or former employee would have held had the reprisal not occurred; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t50/s3236/d/1/A/ii","parentIdentifier":"/us/usc/t50/s3236/d/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fd%2F1%2FA%2Fii","sourceRelease":"119-100","text":"reconsider the employee’s or former employee’s eligibility for access to classified information consistent with national security; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3236/d/1/B","parentIdentifier":"/us/usc/t50/s3236/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fd%2F1%2FB","sourceRelease":"119-100","text":"in any other case, such other action as the external review panel considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Agency action","label":"2 Agency action","identifier":"/us/usc/t50/s3236/d/2","parentIdentifier":"/us/usc/t50/s3236/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t50/s3236/d/2/A","parentIdentifier":"/us/usc/t50/s3236/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t50/s3236/d/2/A/i","parentIdentifier":"/us/usc/t50/s3236/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":"give full consideration to such recommendation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t50/s3236/d/2/A/ii","parentIdentifier":"/us/usc/t50/s3236/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":"inform the panel and the Director of National Intelligence of what action the head has taken with respect to the recommendation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Failure to inform","label":"B Failure to inform","identifier":"/us/usc/t50/s3236/d/2/B","parentIdentifier":"/us/usc/t50/s3236/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fd%2F2%2FB","sourceRelease":"119-100","text":"The Director shall notify the President of any failures to comply with subparagraph (A)(ii).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Annual reports","label":"e Annual reports","identifier":"/us/usc/t50/s3236/e","parentIdentifier":"/us/usc/t50/s3236","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t50/s3236/e/1","parentIdentifier":"/us/usc/t50/s3236/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fe%2F1","sourceRelease":"119-100","text":"Not less frequently than once each year, the Inspector General of the Intelligence Community shall submit to the congressional intelligence committees and the Director of National Intelligence a report on the activities under this section during the previous year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t50/s3236/e/2","parentIdentifier":"/us/usc/t50/s3236/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3236/e/2/A","parentIdentifier":"/us/usc/t50/s3236/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fe%2F2%2FA","sourceRelease":"119-100","text":"The determinations and recommendations made by the external review panels convened under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3236/e/2/B","parentIdentifier":"/us/usc/t50/s3236/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3236%2Fe%2F2%2FB","sourceRelease":"119-100","text":"The responses of the heads of agencies that received recommendations from the external review panels.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
