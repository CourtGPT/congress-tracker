:[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1078–12/b/1/B","parentIdentifier":"/us/usc/t20/s1078–12/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F1%2FB","sourceRelease":"119-100","text":"as such employee, provides civil legal assistance as described in subparagraph (A) on a full-time basis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1078–12/b/1/C","parentIdentifier":"/us/usc/t20/s1078–12/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F1%2FC","sourceRelease":"119-100","text":"is continually licensed to practice law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Student loan","label":"2 Student loan","identifier":"/us/usc/t20/s1078–12/b/2","parentIdentifier":"/us/usc/t20/s1078–12/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t20/s1078–12/b/2/A","parentIdentifier":"/us/usc/t20/s1078–12/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1078–12/b/2/A/i","parentIdentifier":"/us/usc/t20/s1078–12/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"subject to clause (ii), a loan made, insured, or guaranteed under this part, part D, or part E; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1078–12/b/2/A/ii","parentIdentifier":"/us/usc/t20/s1078–12/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t20/s1078–12/b/2/A/ii/I","parentIdentifier":"/us/usc/t20/s1078–12/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F2%2FA%2Fii%2FI","sourceRelease":"119-100","text":"a Federal Direct Stafford Loan, a Federal Direct Unsubsidized Stafford Loan, or a Federal Direct PLUS Loan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t20/s1078–12/b/2/A/ii/II","parentIdentifier":"/us/usc/t20/s1078–12/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F2%2FA%2Fii%2FII","sourceRelease":"119-100","text":"a loan made under section 1078, 1078–2, or 1078–8 of this title; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t20/s1078–12/b/2/A/ii/III","parentIdentifier":"/us/usc/t20/s1078–12/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F2%2FA%2Fii%2FIII","sourceRelease":"119-100","text":"a loan made under part E.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exclusion of parent plus loans","label":"B Exclusion of parent plus loans","identifier":"/us/usc/t20/s1078–12/b/2/B","parentIdentifier":"/us/usc/t20/s1078–12/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1078–12/b/2/B/i","parentIdentifier":"/us/usc/t20/s1078–12/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"A loan made to the parents of a dependent student under .section 1078–2 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1078–12/b/2/B/ii","parentIdentifier":"/us/usc/t20/s1078–12/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"A Federal Direct PLUS Loan made to the parents of a dependent student.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t20/s1078–12/b/2/B/iii","parentIdentifier":"/us/usc/t20/s1078–12/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t20/s1078–12/b/2/B/iii/I","parentIdentifier":"/us/usc/t20/s1078–12/b/2/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F2%2FB%2Fiii%2FI","sourceRelease":"119-100","text":"a loan made to the parents of a dependent student under ; orsection 1078–2 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t20/s1078–12/b/2/B/iii/II","parentIdentifier":"/us/usc/t20/s1078–12/b/2/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F2%2FB%2Fiii%2FII","sourceRelease":"119-100","text":"a Federal Direct PLUS Loan made to the parents of a dependent student.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Program authorized","label":"c Program authorized","identifier":"/us/usc/t20/s1078–12/c","parentIdentifier":"/us/usc/t20/s1078–12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1078–12/c/1","parentIdentifier":"/us/usc/t20/s1078–12/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fc%2F1","sourceRelease":"119-100","text":"is employed as a civil legal assistance attorney; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1078–12/c/2","parentIdentifier":"/us/usc/t20/s1078–12/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fc%2F2","sourceRelease":"119-100","text":"is not in default on a loan for which the borrower seeks repayment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Terms of agreement","label":"d Terms of agreement","identifier":"/us/usc/t20/s1078–12/d","parentIdentifier":"/us/usc/t20/s1078–12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t20/s1078–12/d/1","parentIdentifier":"/us/usc/t20/s1078–12/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1078–12/d/1/A","parentIdentifier":"/us/usc/t20/s1078–12/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the borrower will remain employed as a civil legal assistance attorney for a required period of service of not less than three years, unless involuntarily separated from that employment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1078–12/d/1/B","parentIdentifier":"/us/usc/t20/s1078–12/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F1%2FB","sourceRelease":"119-100","text":"if the borrower is involuntarily separated from employment on account of misconduct, or voluntarily separates from employment, before the end of the period specified in the agreement, the borrower will repay the Secretary the amount of any benefits received by such employee under this agreement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1078–12/d/1/C","parentIdentifier":"/us/usc/t20/s1078–12/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F1%2FC","sourceRelease":"119-100","text":"if the borrower is required to repay an amount to the Secretary under subparagraph (B) and fails to repay such amount, a sum equal to that amount shall be recoverable by the Federal Government from the employee by such methods as are provided by law for the recovery of amounts owed to the Federal Government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1078–12/d/1/D","parentIdentifier":"/us/usc/t20/s1078–12/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F1%2FD","sourceRelease":"119-100","text":"the Secretary may waive, in whole or in part, a right of recovery under this subsection if it is shown that recovery would be contrary to the public interest; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s1078–12/d/1/E","parentIdentifier":"/us/usc/t20/s1078–12/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F1%2FE","sourceRelease":"119-100","text":"the Secretary shall make student loan payments under this section for the period of the agreement, subject to the availability of appropriations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Repayments","label":"2 Repayments","identifier":"/us/usc/t20/s1078–12/d/2","parentIdentifier":"/us/usc/t20/s1078–12/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t20/s1078–12/d/2/A","parentIdentifier":"/us/usc/t20/s1078–12/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F2%2FA","sourceRelease":"119-100","text":"Any amount repaid by, or recovered from, an individual under this subsection shall be credited to the appropriation account from which the amount involved was originally paid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Merger","label":"B Merger","identifier":"/us/usc/t20/s1078–12/d/2/B","parentIdentifier":"/us/usc/t20/s1078–12/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F2%2FB","sourceRelease":"119-100","text":"Any amount credited under subparagraph (A) shall be merged with other sums in such account and shall be available for the same purposes and period, and subject to the same limitations, if any, as the sums with which the amount was merged.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Limitations","label":"3 Limitations","identifier":"/us/usc/t20/s1078–12/d/3","parentIdentifier":"/us/usc/t20/s1078–12/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Student loan payment amount","label":"A Student loan payment amount","identifier":"/us/usc/t20/s1078–12/d/3/A","parentIdentifier":"/us/usc/t20/s1078–12/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1078–12/d/3/A/i","parentIdentifier":"/us/usc/t20/s1078–12/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F3%2FA%2Fi","sourceRelease":"119-100","text":"$6,000 for any borrower in any calendar year; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1078–12/d/3/A/ii","parentIdentifier":"/us/usc/t20/s1078–12/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F3%2FA%2Fii","sourceRelease":"119-100","text":"an aggregate total of $40,000 in the case of any borrower.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Beginning of payments","label":"B Beginning of payments","identifier":"/us/usc/t20/s1078–12/d/3/B","parentIdentifier":"/us/usc/t20/s1078–12/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fd%2F3%2FB","sourceRelease":"119-100","text":"Nothing in this section shall authorize the Secretary to pay any amount to reimburse a borrower for any repayments made by such borrower prior to the date on which the Secretary entered into an agreement with the borrower under this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Additional agreements","label":"e Additional agreements","identifier":"/us/usc/t20/s1078–12/e","parentIdentifier":"/us/usc/t20/s1078–12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t20/s1078–12/e/1","parentIdentifier":"/us/usc/t20/s1078–12/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fe%2F1","sourceRelease":"119-100","text":"On completion of the required period of service under an agreement under subsection (d), the borrower and the Secretary may, subject to paragraph (2), enter into an additional agreement in accordance with subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Term","label":"2 Term","identifier":"/us/usc/t20/s1078–12/e/2","parentIdentifier":"/us/usc/t20/s1078–12/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fe%2F2","sourceRelease":"119-100","text":"An agreement entered into under paragraph (1) may require the borrower to remain employed as a civil legal assistance attorney for less than three years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Award basis; priority","label":"f Award basis; priority","identifier":"/us/usc/t20/s1078–12/f","parentIdentifier":"/us/usc/t20/s1078–12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Award basis","label":"1 Award basis","identifier":"/us/usc/t20/s1078–12/f/1","parentIdentifier":"/us/usc/t20/s1078–12/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Ff%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2), the Secretary shall provide repayment benefits under this section on a first-come, first-served basis, and subject to the availability of appropriations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Priority","label":"2 Priority","identifier":"/us/usc/t20/s1078–12/f/2","parentIdentifier":"/us/usc/t20/s1078–12/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1078–12/f/2/A","parentIdentifier":"/us/usc/t20/s1078–12/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Ff%2F2%2FA","sourceRelease":"119-100","text":"has practiced law for five years or less and, for not less than 90 percent of the time in such practice, has served as a civil legal assistance attorney;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1078–12/f/2/B","parentIdentifier":"/us/usc/t20/s1078–12/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Ff%2F2%2FB","sourceRelease":"119-100","text":"received repayment benefits under this section during the preceding fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1078–12/f/2/C","parentIdentifier":"/us/usc/t20/s1078–12/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Ff%2F2%2FC","sourceRelease":"119-100","text":"has completed less than three years of the first required period of service specified for the borrower in an agreement entered into under subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Ineligibility for double benefits","label":"g Ineligibility for double benefits","identifier":"/us/usc/t20/s1078–12/g","parentIdentifier":"/us/usc/t20/s1078–12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fg","sourceRelease":"119-100","text":"No borrower may, for the same service, receive a reduction of loan obligations under both this section and section 1078–11 or 1087e(m) of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Regulations","label":"h Regulations","identifier":"/us/usc/t20/s1078–12/h","parentIdentifier":"/us/usc/t20/s1078–12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fh","sourceRelease":"119-100","text":"The Secretary is authorized to issue such regulations as may be necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Authorization of appropriations","label":"i Authorization of appropriations","identifier":"/us/usc/t20/s1078–12/i","parentIdentifier":"/us/usc/t20/s1078–12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fi","sourceRelease":"119-100","text":"There are authorized to be appropriated to carry out this section $10,000,000 for fiscal year 2009 and such sums as may be necessary for each of the five succeeding fiscal years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
