el":"B","identifier":"/us/usc/t47/s1308/b/1/B","parentIdentifier":"/us/usc/t47/s1308/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1308/b/1/B/i","parentIdentifier":"/us/usc/t47/s1308/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the program for Universal Service Support for High-Cost Areas set forth under subpart D of part 54 of title 47, Code of Federal Regulations, or any successor thereto;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1308/b/1/B/ii","parentIdentifier":"/us/usc/t47/s1308/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the Rural Digital Opportunity Fund set forth under subpart J of part 54 of title 47, Code of Federal Regulations, or any successor thereto;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t47/s1308/b/1/B/iii","parentIdentifier":"/us/usc/t47/s1308/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"the Interstate Common Line Support Mechanism for Rate-of-Return Carriers set forth under subpart K of part 54 of title 47, Code of Federal Regulations, or any successor thereto;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t47/s1308/b/1/B/iv","parentIdentifier":"/us/usc/t47/s1308/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"the Mobility Fund and 5G Fund set forth under subpart L of part 54 of title 47, Code of Federal Regulations, or any successor thereto; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t47/s1308/b/1/B/v","parentIdentifier":"/us/usc/t47/s1308/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F1%2FB%2Fv","sourceRelease":"119-100","text":"the High Cost Loop Support for Rate-of-Return Carriers program set forth under subpart M of part 54 of title 47, Code of Federal Regulations, or any successor thereto.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Interagency agreement","label":"2 Interagency agreement","identifier":"/us/usc/t47/s1308/b/2","parentIdentifier":"/us/usc/t47/s1308/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1308/b/2/A","parentIdentifier":"/us/usc/t47/s1308/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the high-cost programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1308/b/2/B","parentIdentifier":"/us/usc/t47/s1308/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the programs administered by the Rural Utilities Service of the Department of Agriculture and the Department of Agriculture; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t47/s1308/b/2/C","parentIdentifier":"/us/usc/t47/s1308/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F2%2FC","sourceRelease":"119-100","text":"the programs administered by or coordinated through the National Telecommunications and Information Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Requirements","label":"3 Requirements","identifier":"/us/usc/t47/s1308/b/3","parentIdentifier":"/us/usc/t47/s1308/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1308/b/3/A","parentIdentifier":"/us/usc/t47/s1308/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F3%2FA","sourceRelease":"119-100","text":"require that the covered agencies share information with each other about existing or planned projects that have received or will receive funds under the programs described in paragraph (2) for new broadband deployment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1308/b/3/B","parentIdentifier":"/us/usc/t47/s1308/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1308/b/3/B/i","parentIdentifier":"/us/usc/t47/s1308/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t47/s1308/b/3/B/i/I","parentIdentifier":"/us/usc/t47/s1308/b/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F3%2FB%2Fi%2FI","sourceRelease":"119-100","text":"each entity that provides broadband service in the area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t47/s1308/b/3/B/i/II","parentIdentifier":"/us/usc/t47/s1308/b/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F3%2FB%2Fi%2FII","sourceRelease":"119-100","text":"levels of broadband service provided in the area, including the speed of broadband service and the technology provided;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t47/s1308/b/3/B/i/III","parentIdentifier":"/us/usc/t47/s1308/b/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F3%2FB%2Fi%2FIII","sourceRelease":"119-100","text":"the geographic scope of broadband service coverage in the area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t47/s1308/b/3/B/i/IV","parentIdentifier":"/us/usc/t47/s1308/b/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F3%2FB%2Fi%2FIV","sourceRelease":"119-100","text":"each entity that has received or will receive funds under the programs described in paragraph (2) to provide broadband service in the area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1308/b/3/B/ii","parentIdentifier":"/us/usc/t47/s1308/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"if a covered agency designates any information provided to another covered agency under clause (i) as confidential, the other covered agency shall protect the confidentiality of that information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t47/s1308/b/3/C","parentIdentifier":"/us/usc/t47/s1308/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F3%2FC","sourceRelease":"119-100","text":"consider basing the distribution of funds for broadband deployment under the programs described in paragraph (2) on standardized data regarding broadband coverage; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t47/s1308/b/3/D","parentIdentifier":"/us/usc/t47/s1308/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F3%2FD","sourceRelease":"119-100","text":"provide that the interagency agreement shall be updated periodically, except that the scope of the agreement with respect to the Federal Communications Commission may not expand beyond the high-cost programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Assessment of agreement","label":"4 Assessment of agreement","identifier":"/us/usc/t47/s1308/b/4","parentIdentifier":"/us/usc/t47/s1308/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Public comment","label":"A Public comment","identifier":"/us/usc/t47/s1308/b/4/A","parentIdentifier":"/us/usc/t47/s1308/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1308/b/4/A/i","parentIdentifier":"/us/usc/t47/s1308/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F4%2FA%2Fi","sourceRelease":"119-100","text":"the effectiveness of the interagency agreement in facilitating efficient use of funds for broadband deployment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1308/b/4/A/ii","parentIdentifier":"/us/usc/t47/s1308/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F4%2FA%2Fii","sourceRelease":"119-100","text":"the availability of Tribal, State, and local data regarding broadband deployment and the inclusion of that data in interagency coordination; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t47/s1308/b/4/A/iii","parentIdentifier":"/us/usc/t47/s1308/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F4%2FA%2Fiii","sourceRelease":"119-100","text":"modifications to the interagency agreement that would improve the efficacy of interagency coordination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Assessment; report","label":"B Assessment; report","identifier":"/us/usc/t47/s1308/b/4/B","parentIdentifier":"/us/usc/t47/s1308/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1308/b/4/B/i","parentIdentifier":"/us/usc/t47/s1308/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F4%2FB%2Fi","sourceRelease":"119-100","text":"review and assess the comments received under subparagraph (A); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1308/b/4/B/ii","parentIdentifier":"/us/usc/t47/s1308/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1308%2Fb%2F4%2FB%2Fii","sourceRelease":"119-100","text":"submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Energy and Commerce of the House of Representatives a report detailing any findings and recommendations from the assessment conducted under clause (i).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
