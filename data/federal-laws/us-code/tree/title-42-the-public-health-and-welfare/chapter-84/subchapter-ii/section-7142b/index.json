{"type":"section","nativeType":"section","number":"7142b","heading":"Authority","label":"7142b Authority","identifier":"/us/usc/t42/s7142b","parentIdentifier":"/us/usc/t42/ch84/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7142b","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Miscellaneous Appropriations Act, 2001, and also as part of the Consolidated Appropriations Act, 2001, and not as part of the Department of Energy Organization Act which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s7142b/1","parentIdentifier":"/us/usc/t42/s7142b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7142b%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7142b/1/A","parentIdentifier":"/us/usc/t42/s7142b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7142b%2F1%2FA","sourceRelease":"119-100","text":"designated in a written document by the person making the gift, devise, or bequest as intended for the Museum; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7142b/1/B","parentIdentifier":"/us/usc/t42/s7142b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7142b%2F1%2FB","sourceRelease":"119-100","text":"determined by the Secretary to be suitable and beneficial for use by the Museum;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s7142b/2","parentIdentifier":"/us/usc/t42/s7142b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7142b%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7142b/2/A","parentIdentifier":"/us/usc/t42/s7142b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7142b%2F2%2FA","sourceRelease":"119-100","text":"relevant to the contents of the Museum; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7142b/2/B","parentIdentifier":"/us/usc/t42/s7142b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7142b%2F2%2FB","sourceRelease":"119-100","text":"informative, educational, and tasteful;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s7142b/3","parentIdentifier":"/us/usc/t42/s7142b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7142b%2F3","sourceRelease":"119-100","text":"collect reasonable fees where feasible and appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s7142b/4","parentIdentifier":"/us/usc/t42/s7142b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7142b%2F4","sourceRelease":"119-100","text":"exhibit, perform, display, and publish materials and information of or relating to the Museum in any media or place;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s7142b/5","parentIdentifier":"/us/usc/t42/s7142b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7142b%2F5","sourceRelease":"119-100","text":"consistent with guidelines approved by the Secretary, lease space on the premises of the Museum at reasonable rates and for uses consistent with such guidelines; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s7142b/6","parentIdentifier":"/us/usc/t42/s7142b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7142b%2F6","sourceRelease":"119-100","text":"use the proceeds of activities authorized under this section to pay the costs of the Museum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
