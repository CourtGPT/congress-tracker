ml?req=%2Fus%2Fusc%2Ft5%2Fs3111a%2Fc%2F3","sourceRelease":"119-100","text":"the term “agency” means an Executive agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
