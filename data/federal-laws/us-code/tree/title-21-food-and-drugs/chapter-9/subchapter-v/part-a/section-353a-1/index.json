{"type":"section","nativeType":"section","number":"353a–1","heading":"Enhanced communication","label":"353a–1 Enhanced communication","identifier":"/us/usc/t21/s353a–1","parentIdentifier":"/us/usc/t21/ch9/schV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs353a%E2%80%931","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Compounding Quality Act and also as part of the Drug Quality and Security Act, and not as part of the Federal Food, Drug, and Cosmetic Act which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Submissions from State boards of pharmacy","label":"a Submissions from State boards of pharmacy","identifier":"/us/usc/t21/s353a–1/a","parentIdentifier":"/us/usc/t21/s353a–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs353a%E2%80%931%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s353a–1/a/1","parentIdentifier":"/us/usc/t21/s353a–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs353a%E2%80%931%2Fa%2F1","sourceRelease":"119-100","text":"describing actions taken against compounding pharmacies, as described in subsection (b); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s353a–1/a/2","parentIdentifier":"/us/usc/t21/s353a–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs353a%E2%80%931%2Fa%2F2","sourceRelease":"119-100","text":"expressing concerns that a compounding pharmacy may be acting contrary to .section 353a of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"