{"type":"section","nativeType":"section","number":"153302","heading":"Purposes","label":"153302 Purposes","identifier":"/us/usc/t36/s153302","parentIdentifier":"/us/usc/t36/stII/ptB/ch1533","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs153302","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevisedSectionSource (U.S. Code)Source (Statutes at Large)15330236:20b., .June 9, 1906, ch. 3065, § 234 Stat. 227Before clause (1), the words “objects” and “declared to be” are omitted as unnecessary."],"amendments":["Historical and Revision NotesRevisedSectionSource (U.S. Code)Source (Statutes at Large)15330236:20b., .June 9, 1906, ch. 3065, § 234 Stat. 227Before clause (1), the words “objects” and “declared to be” are omitted as unnecessary."],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t36/s153302/1","parentIdentifier":"/us/usc/t36/s153302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs153302%2F1","sourceRelease":"119-100","text":"to perpetuate the memory of the men who, by their services or sacrifices during the war of the American Revolution, achieved the independence of the American people;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t36/s153302/2","parentIdentifier":"/us/usc/t36/s153302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs153302%2F2","sourceRelease":"119-100","text":"to unite and promote fellowship among their descendants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t36/s153302/3","parentIdentifier":"/us/usc/t36/s153302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs153302%2F3","sourceRelease":"119-100","text":"to inspire them and the community at large with a more profound reverence for the principles of the government founded by our forefathers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t36/s153302/4","parentIdentifier":"/us/usc/t36/s153302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs153302%2F4","sourceRelease":"119-100","text":"to encourage historical research in relation to the American Revolution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t36/s153302/5","parentIdentifier":"/us/usc/t36/s153302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs153302%2F5","sourceRelease":"119-100","text":"to acquire and preserve the records of the individual services of the patriots of the war, as well as documents, relics, and landmarks;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t36/s153302/6","parentIdentifier":"/us/usc/t36/s153302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs153302%2F6","sourceRelease":"119-100","text":"to mark the scenes of the American Revolution by appropriate memorials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t36/s153302/7","parentIdentifier":"/us/usc/t36/s153302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs153302%2F7","sourceRelease":"119-100","text":"to celebrate the anniversaries of the prominent events of the war and of the Revolutionary period;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t36/s153302/8","parentIdentifier":"/us/usc/t36/s153302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs153302%2F8","sourceRelease":"119-100","text":"to foster true patriotism;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t36/s153302/9","parentIdentifier":"/us/usc/t36/s153302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs153302%2F9","sourceRelease":"119-100","text":"to maintain and extend the institutions of American freedom; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t36/s153302/10","parentIdentifier":"/us/usc/t36/s153302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs153302%2F10","sourceRelease":"119-100","text":"to carry out the purposes expressed in the preamble to the Constitution of our country and the injunctions of Washington in his farewell address to the American people.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
