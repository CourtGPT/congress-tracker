{"type":"section","nativeType":"section","number":"7783","heading":"Grants to weed management entities","label":"7783 Grants to weed management entities","identifier":"/us/usc/t7/s7783","parentIdentifier":"/us/usc/t7/ch104/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Consultation and consent","label":"a Consultation and consent","identifier":"/us/usc/t7/s7783/a","parentIdentifier":"/us/usc/t7/s7783","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7783/a/1","parentIdentifier":"/us/usc/t7/s7783/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fa%2F1","sourceRelease":"119-100","text":"if the activities funded under the grant will take place on Federal land, consult with the heads of the Federal agencies having jurisdiction over the land; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7783/a/2","parentIdentifier":"/us/usc/t7/s7783/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fa%2F2","sourceRelease":"119-100","text":"obtain the written consent of the non-Federal landowner.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Grant considerations","label":"b Grant considerations","identifier":"/us/usc/t7/s7783/b","parentIdentifier":"/us/usc/t7/s7783","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7783/b/1","parentIdentifier":"/us/usc/t7/s7783/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fb%2F1","sourceRelease":"119-100","text":"the severity or potential severity of the noxious weed problem;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7783/b/2","parentIdentifier":"/us/usc/t7/s7783/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fb%2F2","sourceRelease":"119-100","text":"the extent to which the Federal funds will be used to leverage non-Federal funds to address the noxious weed problem;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7783/b/3","parentIdentifier":"/us/usc/t7/s7783/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fb%2F3","sourceRelease":"119-100","text":"the extent to which the weed management entity has made progress in addressing the noxious weeds problem; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s7783/b/4","parentIdentifier":"/us/usc/t7/s7783/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fb%2F4","sourceRelease":"119-100","text":"other factors that the Secretary determines to be relevant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Use of grant funds; cost shares","label":"c Use of grant funds; cost shares","identifier":"/us/usc/t7/s7783/c","parentIdentifier":"/us/usc/t7/s7783","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Use of grants","label":"1 Use of grants","identifier":"/us/usc/t7/s7783/c/1","parentIdentifier":"/us/usc/t7/s7783/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fc%2F1","sourceRelease":"119-100","text":"A weed management entity that receives a grant under subsection (a) shall use the grant funds to carry out a project authorized by subsection (d) for the control or eradication of a noxious weed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Cost shares","label":"2 Cost shares","identifier":"/us/usc/t7/s7783/c/2","parentIdentifier":"/us/usc/t7/s7783/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Federal cost share","label":"A Federal cost share","identifier":"/us/usc/t7/s7783/c/2/A","parentIdentifier":"/us/usc/t7/s7783/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fc%2F2%2FA","sourceRelease":"119-100","text":"The Federal share of the cost of carrying out an authorized project under this section exclusively on non-Federal land shall not exceed 50 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Form of non-Federal cost share","label":"B Form of non-Federal cost share","identifier":"/us/usc/t7/s7783/c/2/B","parentIdentifier":"/us/usc/t7/s7783/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fc%2F2%2FB","sourceRelease":"119-100","text":"The non-Federal share of the cost of carrying out an authorized project under this section may be provided in cash or in kind.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorized projects","label":"d Authorized projects","identifier":"/us/usc/t7/s7783/d","parentIdentifier":"/us/usc/t7/s7783","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7783/d/1","parentIdentifier":"/us/usc/t7/s7783/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fd%2F1","sourceRelease":"119-100","text":"Education, inventories and mapping, management, monitoring, methods development, and other capacity building activities, including the payment of the cost of personnel and equipment that promote control or eradication of noxious weeds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7783/d/2","parentIdentifier":"/us/usc/t7/s7783/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fd%2F2","sourceRelease":"119-100","text":"Other activities to control or eradicate noxious weeds or promote control or eradication of noxious weeds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Application","label":"e Application","identifier":"/us/usc/t7/s7783/e","parentIdentifier":"/us/usc/t7/s7783","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fe","sourceRelease":"119-100","text":"To be eligible to receive assistance under this section, a weed management entity shall prepare and submit to the Secretary an application containing such information as the Secretary shall by regulation require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Selection of projects","label":"f Selection of projects","identifier":"/us/usc/t7/s7783/f","parentIdentifier":"/us/usc/t7/s7783","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7783/f/1","parentIdentifier":"/us/usc/t7/s7783/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Ff%2F1","sourceRelease":"119-100","text":"The severity of the noxious weed problem or potential problem addressed by the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7783/f/2","parentIdentifier":"/us/usc/t7/s7783/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Ff%2F2","sourceRelease":"119-100","text":"The likelihood that the project will prevent or resolve the problem, or increase knowledge about resolving similar problems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7783/f/3","parentIdentifier":"/us/usc/t7/s7783/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Ff%2F3","sourceRelease":"119-100","text":"The extent to which the Federal funds will leverage non-Federal funds to address the noxious weed problem addressed by the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s7783/f/4","parentIdentifier":"/us/usc/t7/s7783/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Ff%2F4","sourceRelease":"119-100","text":"The extent to which the program will improve the overall capacity of the United States to address noxious weed control and management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s7783/f/5","parentIdentifier":"/us/usc/t7/s7783/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Ff%2F5","sourceRelease":"119-100","text":"The extent to which the weed management entity has made progress in addressing noxious weed problems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s7783/f/6","parentIdentifier":"/us/usc/t7/s7783/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Ff%2F6","sourceRelease":"119-100","text":"The extent to which the project will provide a comprehensive approach to the control or eradication of noxious weeds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t7/s7783/f/7","parentIdentifier":"/us/usc/t7/s7783/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Ff%2F7","sourceRelease":"119-100","text":"The extent to which the project will reduce the total population of noxious weeds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t7/s7783/f/8","parentIdentifier":"/us/usc/t7/s7783/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Ff%2F8","sourceRelease":"119-100","text":"The extent to which the project promotes cooperation and participation between States that have common interests in controlling and eradicating noxious weeds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t7/s7783/f/9","parentIdentifier":"/us/usc/t7/s7783/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Ff%2F9","sourceRelease":"119-100","text":"Other factors that the Secretary determines to be relevant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Regional, State, and local involvement","label":"g Regional, State, and local involvement","identifier":"/us/usc/t7/s7783/g","parentIdentifier":"/us/usc/t7/s7783","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7783/g/1","parentIdentifier":"/us/usc/t7/s7783/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fg%2F1","sourceRelease":"119-100","text":"rely on technical and merit reviews provided by regional, State, or local weed management experts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7783/g/2","parentIdentifier":"/us/usc/t7/s7783/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fg%2F2","sourceRelease":"119-100","text":"give priority to projects that maximize the involvement of State, local and, where applicable, Indian Tribe governments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Special consideration","label":"h Special consideration","identifier":"/us/usc/t7/s7783/h","parentIdentifier":"/us/usc/t7/s7783","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7783%2Fh","sourceRelease":"119-100","text":"The Secretary shall give special consideration to States with approved weed management entities established by Indian Tribes and may provide an additional allocation to a State to meet the particular needs and projects that the weed management entity plans to address.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
