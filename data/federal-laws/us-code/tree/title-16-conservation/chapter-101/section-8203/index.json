ablished under ; orsection 1852 of this title“(ii) a representative of the Marine Fisheries Commissions;”.Subsec. (e)(1)(B). , substituted “the members present” for “all members”.Pub. L. 118–198, § 201(2)"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t16/s8203/a","parentIdentifier":"/us/usc/t16/s8203","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Fish Habitat Board","label":"1 Fish Habitat Board","identifier":"/us/usc/t16/s8203/a/1","parentIdentifier":"/us/usc/t16/s8203/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8203/a/1/A","parentIdentifier":"/us/usc/t16/s8203/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F1%2FA","sourceRelease":"119-100","text":"to promote, oversee, and coordinate the implementation of this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8203/a/1/B","parentIdentifier":"/us/usc/t16/s8203/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F1%2FB","sourceRelease":"119-100","text":"to establish national goals and priorities for fish habitat conservation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8203/a/1/C","paren