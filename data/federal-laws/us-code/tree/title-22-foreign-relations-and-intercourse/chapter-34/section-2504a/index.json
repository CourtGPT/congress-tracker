{"type":"section","nativeType":"section","number":"2504a","heading":"Health care for volunteers at Peace Corps posts","label":"2504a Health care for volunteers at Peace Corps posts","identifier":"/us/usc/t22/s2504a","parentIdentifier":"/us/usc/t22/ch34","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s2504a/a","parentIdentifier":"/us/usc/t22/s2504a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fa","sourceRelease":"119-100","text":"The President shall ensure that each overseas post has the services of a medical office that is consistent in size and scope with the needs of the Peace Corps at such post, including, if necessary, by detailing to any such post the licensed medical staff of other United States departments, agencies, or establishments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Hiring criteria","label":"b Hiring criteria","identifier":"/us/usc/t22/s2504a/b","parentIdentifier":"/us/usc/t22/s2504a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s2504a/b/1","parentIdentifier":"/us/usc/t22/s2504a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fb%2F1","sourceRelease":"119-100","text":"medical training, experience, and accreditations or other qualifications;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s2504a/b/2","parentIdentifier":"/us/usc/t22/s2504a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fb%2F2","sourceRelease":"119-100","text":"record of performance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s2504a/b/3","parentIdentifier":"/us/usc/t22/s2504a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fb%2F3","sourceRelease":"119-100","text":"administrative capabilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s2504a/b/4","parentIdentifier":"/us/usc/t22/s2504a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fb%2F4","sourceRelease":"119-100","text":"understanding of the local language and culture;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s2504a/b/5","parentIdentifier":"/us/usc/t22/s2504a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fb%2F5","sourceRelease":"119-100","text":"ability to work in the English language;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s2504a/b/6","parentIdentifier":"/us/usc/t22/s2504a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fb%2F6","sourceRelease":"119-100","text":"interpersonal skills; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t22/s2504a/b/7","parentIdentifier":"/us/usc/t22/s2504a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fb%2F7","sourceRelease":"119-100","text":"such other factors that the Director determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Certain training","label":"c Certain training","identifier":"/us/usc/t22/s2504a/c","parentIdentifier":"/us/usc/t22/s2504a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fc","sourceRelease":"119-100","text":"The Director of the Peace Corps shall ensure that each Peace Corps medical officer serving in a malaria-endemic country receives training in the recognition of the side effects of such medications.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Review and evaluation","label":"d Review and evaluation","identifier":"/us/usc/t22/s2504a/d","parentIdentifier":"/us/usc/t22/s2504a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s2504a/d/1","parentIdentifier":"/us/usc/t22/s2504a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s2504a/d/1/A","parentIdentifier":"/us/usc/t22/s2504a/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fd%2F1%2FA","sourceRelease":"119-100","text":"ensure compliance with all relevant Peace Corps policies, practices, and guidelines; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s2504a/d/1/B","parentIdentifier":"/us/usc/t22/s2504a/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fd%2F1%2FB","sourceRelease":"119-100","text":"ensure that medical staff complete the necessary continuing medical education to maintain their skills and satisfy licensing and credentialing standards, as designated by the Director.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report to Congress","label":"2 Report to Congress","identifier":"/us/usc/t22/s2504a/d/2","parentIdentifier":"/us/usc/t22/s2504a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fd%2F2","sourceRelease":"119-100","text":"The Director of the Peace Corps shall include, in the annual Peace Corps congressional budget justification, a confirmation that the review and evaluation of all Peace Corps medical staff required under paragraph (1) has been completed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Antimalarial drugs","label":"e Antimalarial drugs","identifier":"/us/usc/t22/s2504a/e","parentIdentifier":"/us/usc/t22/s2504a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2504a%2Fe","sourceRelease":"119-100","text":"The Director of the Peace Corps shall consult with experts at the Centers for Disease Control and Prevention regarding recommendations for prescribing malaria prophylaxis, in order to provide the best standard of care within the context of the Peace Corps environment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
