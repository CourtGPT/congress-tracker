{"type":"section","nativeType":"section","number":"42304","heading":"Widespread disruptions","label":"42304 Widespread disruptions","identifier":"/us/usc/t49/s42304","parentIdentifier":"/us/usc/t49/stVII/ptA/sptii/ch423","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs42304","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—General Requirements","label":"a .—General Requirements","identifier":"/us/usc/t49/s42304/a","parentIdentifier":"/us/usc/t49/s42304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs42304%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s42304/a/1","parentIdentifier":"/us/usc/t49/s42304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs42304%2Fa%2F1","sourceRelease":"119-100","text":"provide for hotel accommodations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s42304/a/2","parentIdentifier":"/us/usc/t49/s42304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs42304%2Fa%2F2","sourceRelease":"119-100","text":"arrange for ground transportation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s42304/a/3","parentIdentifier":"/us/usc/t49/s42304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs42304%2Fa%2F3","sourceRelease":"119-100","text":"provide meal vouchers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s42304/a/4","parentIdentifier":"/us/usc/t49/s42304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs42304%2Fa%2F4","sourceRelease":"119-100","text":"arrange for air transportation on another air carrier or foreign air carrier to the passenger’s destination; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t49/s42304/a/5","parentIdentifier":"/us/usc/t49/s42304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs42304%2Fa%2F5","sourceRelease":"119-100","text":"provide for sleeping facilities inside the airport terminal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Definitions","label":"b .—Definitions","identifier":"/us/usc/t49/s42304/b","parentIdentifier":"/us/usc/t49/s42304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs42304%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Widespread disruption","label":"1 .—Widespread disruption","identifier":"/us/usc/t49/s42304/b/1","parentIdentifier":"/us/usc/t49/s42304/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs42304%2Fb%2F1","sourceRelease":"119-100","text":"The term “widespread disruption” means, with respect to a covered air carrier, the interruption of all or the overwhelming majority of the air carrier’s systemwide flight operations, including flight delays and cancellations, as the result of the failure of 1 or more computer systems or computer networks of the air carrier.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Covered air carrier","label":"2 .—Covered air carrier","identifier":"/us/usc/t49/s42304/b/2","parentIdentifier":"/us/usc/t49/s42304/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs42304%2Fb%2F2","sourceRelease":"119-100","text":"The term “covered air carrier” means an air carrier that provides scheduled passenger air transportation by operating an aircraft that as originally designed has a passenger capacity of 30 or more seats.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Savings Provision","label":"c .—Savings Provision","identifier":"/us/usc/t49/s42304/c","parentIdentifier":"/us/usc/t49/s42304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs42304%2Fc","sourceRelease":"119-100","text":"Nothing in this section may be construed to modify, abridge, or repeal any obligation of an air carrier under section 42301.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
