{"type":"section","nativeType":"section","number":"13452","heading":"Natural gas and electric heating and cooling technologies","label":"13452 Natural gas and electric heating and cooling technologies","identifier":"/us/usc/t42/s13452","parentIdentifier":"/us/usc/t42/ch134/schIX/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13452","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Program direction","label":"a Program direction","identifier":"/us/usc/t42/s13452/a","parentIdentifier":"/us/usc/t42/s13452","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13452%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13452/a/1","parentIdentifier":"/us/usc/t42/s13452/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13452%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary shall conduct a 5-year program, in accordance with sections 13541 and 13542 of this title, on energy efficient natural gas and electric heating and cooling technologies for residential and commercial buildings.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13452/a/2","parentIdentifier":"/us/usc/t42/s13452/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13452%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13452/a/2/A","parentIdentifier":"/us/usc/t42/s13452/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13452%2Fa%2F2%2FA","sourceRelease":"119-100","text":"thermally activated heat pumps, including absorption heat pumps and engine-driven heat pumps; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13452/a/2/B","parentIdentifier":"/us/usc/t42/s13452/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13452%2Fa%2F2%2FB","sourceRelease":"119-100","text":"other advanced natural gas technologies, including fuel cells for residential and commercial applications.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13452/a/3","parentIdentifier":"/us/usc/t42/s13452/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13452%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13452/a/3/A","parentIdentifier":"/us/usc/t42/s13452/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13452%2Fa%2F3%2FA","sourceRelease":"119-100","text":"advanced heat pumps;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13452/a/3/B","parentIdentifier":"/us/usc/t42/s13452/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13452%2Fa%2F3%2FB","sourceRelease":"119-100","text":"thermal storage; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s13452/a/3/C","parentIdentifier":"/us/usc/t42/s13452/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13452%2Fa%2F3%2FC","sourceRelease":"119-100","text":"advanced electric HVAC (heating, ventilating, and air conditioning) and refrigeration systems that utilize replacements for chlorofluorocarbons.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Proposals","label":"b Proposals","identifier":"/us/usc/t42/s13452/b","parentIdentifier":"/us/usc/t42/s13452","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13452%2Fb","sourceRelease":"119-100","text":"Within 180 days after , the Secretary shall solicit proposals for conducting activities under this section.October 24, 1992","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
