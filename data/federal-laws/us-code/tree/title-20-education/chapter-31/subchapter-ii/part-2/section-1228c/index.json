veType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1228c/b/2/A","parentIdentifier":"/us/usc/t20/s1228c/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fb%2F2%2FA","sourceRelease":"119-100","text":"participation in an educational program or any benefit associated with such program; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1228c/b/2/B","parentIdentifier":"/us/usc/t20/s1228c/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fb%2F2%2FB","sourceRelease":"119-100","text":"a waiver of any fee charged for such participation or benefit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Enforcement","label":"c Enforcement","identifier":"/us/usc/t20/s1228c/c","parentIdentifier":"/us/usc/t20/s1228c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1228c/c/1","parentIdentifier":"/us/usc/t20/s1228c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1228c/c/1/A","parentIdentifier":"/us/usc/t20/s1228c/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fc%2F1%2FA","sourceRelease":"119-100","text":"widely disseminate information about the requirements of this section to State and local school officials and parents; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1228c/c/1/B","parentIdentifier":"/us/usc/t20/s1228c/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fc%2F1%2FB","sourceRelease":"119-100","text":"require educational organizations to submit appropriate information or assurances regarding such organizations’ compliance with this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1228c/c/2","parentIdentifier":"/us/usc/t20/s1228c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1228c/c/2/A","parentIdentifier":"/us/usc/t20/s1228c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fc%2F2%2FA","sourceRelease":"119-100","text":"promulgating regulations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1228c/c/2/B","parentIdentifier":"/us/usc/t20/s1228c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fc%2F2%2FB","sourceRelease":"119-100","text":"establishing a complaint process;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1228c/c/2/C","parentIdentifier":"/us/usc/t20/s1228c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fc%2F2%2FC","sourceRelease":"119-100","text":"referring complaints to the relevant Federal, State, or local authorities for appropriate action;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1228c/c/2/D","parentIdentifier":"/us/usc/t20/s1228c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fc%2F2%2FD","sourceRelease":"119-100","text":"alerting educational agencies, schools, and parents to the practices of educational organizations that violate the provisions of this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s1228c/c/2/E","parentIdentifier":"/us/usc/t20/s1228c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fc%2F2%2FE","sourceRelease":"119-100","text":"imposing civil fines (not to exceed $1,000 per violation) on educational organizations that knowingly violate this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definitions","label":"d Definitions","identifier":"/us/usc/t20/s1228c/d","parentIdentifier":"/us/usc/t20/s1228c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Disability","label":"1 Disability","identifier":"/us/usc/t20/s1228c/d/1","parentIdentifier":"/us/usc/t20/s1228c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F1","sourceRelease":"119-100","text":"The term “disability” has the same meaning given to such term by .section 12102(2) of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Educational organization","label":"2 Educational organization","identifier":"/us/usc/t20/s1228c/d/2","parentIdentifier":"/us/usc/t20/s1228c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1228c/d/2/A","parentIdentifier":"/us/usc/t20/s1228c/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1228c/d/2/A/i","parentIdentifier":"/us/usc/t20/s1228c/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":"provides an educational program for a fee; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1228c/d/2/A/ii","parentIdentifier":"/us/usc/t20/s1228c/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":"recruits students through means such as commercial media, direct mailings, school recruitment programs, school administrators, teachers or staff, or current or former participants in an educational program offered by such organization or entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1228c/d/2/B","parentIdentifier":"/us/usc/t20/s1228c/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1228c/d/2/B/i","parentIdentifier":"/us/usc/t20/s1228c/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F2%2FB%2Fi","sourceRelease":"119-100","text":"a local educational agency, State educational agency, a State department of education, or an elementary or secondary school (as defined by the terms “elementary school” and “secondary school” in );section 7801 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1228c/d/2/B/ii","parentIdentifier":"/us/usc/t20/s1228c/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F2%2FB%2Fii","sourceRelease":"119-100","text":"an institution of higher education as defined by ; orsection 1001 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t20/s1228c/d/2/B/iii","parentIdentifier":"/us/usc/t20/s1228c/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"a local organization sponsored by an elementary or secondary school, a recreational organization, an entertainment organization, a local sports activity group, or a social club.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1228c/d/2/C","parentIdentifier":"/us/usc/t20/s1228c/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1228c/d/2/C/i","parentIdentifier":"/us/usc/t20/s1228c/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F2%2FC%2Fi","sourceRelease":"119-100","text":"recruits, for participation in such program, solely through a local school official; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1228c/d/2/C/ii","parentIdentifier":"/us/usc/t20/s1228c/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F2%2FC%2Fii","sourceRelease":"119-100","text":"does not offer a local school official, teacher, or other school personnel compensation (other than compensation for actual expenses incurred in performing chaperon activities or for participating in separate, professionally-staffed teacher training and technical assistance seminars and workshops related to such program) or any other benefit for such recruitment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Educational program","label":"3 Educational program","identifier":"/us/usc/t20/s1228c/d/3","parentIdentifier":"/us/usc/t20/s1228c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1228c/d/3/A","parentIdentifier":"/us/usc/t20/s1228c/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1228c/d/3/A/i","parentIdentifier":"/us/usc/t20/s1228c/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F3%2FA%2Fi","sourceRelease":"119-100","text":"that is generally directed toward minors or secondary school students;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1228c/d/3/A/ii","parentIdentifier":"/us/usc/t20/s1228c/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F3%2FA%2Fii","sourceRelease":"119-100","text":"for which a tuition or enrollment fee is charged;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t20/s1228c/d/3/A/iii","parentIdentifier":"/us/usc/t20/s1228c/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"that is offered away from a student’s regular place of school attendance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t20/s1228c/d/3/A/iv","parentIdentifier":"/us/usc/t20/s1228c/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F3%2FA%2Fiv","sourceRelease":"119-100","text":"that includes not less than one supervised night away from home; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t20/s1228c/d/3/A/v","parentIdentifier":"/us/usc/t20/s1228c/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F3%2FA%2Fv","sourceRelease":"119-100","text":"that is intended to enhance a student’s regular course of study.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1228c/d/3/B","parentIdentifier":"/us/usc/t20/s1228c/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F3%2FB","sourceRelease":"119-100","text":"Such term does not include a recreational program, or a social or religious activity.1So in original. The comma probably should not appear.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Local school official","label":"4 Local school official","identifier":"/us/usc/t20/s1228c/d/4","parentIdentifier":"/us/usc/t20/s1228c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F4","sourceRelease":"119-100","text":"The term “local school official” means the highest administrative official serving a school district, or such individual’s designee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Minor","label":"5 Minor","identifier":"/us/usc/t20/s1228c/d/5","parentIdentifier":"/us/usc/t20/s1228c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F5","sourceRelease":"119-100","text":"The term “minor” means an individual who has not attained the age of 18 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Membership organization","label":"6 Membership organization","identifier":"/us/usc/t20/s1228c/d/6","parentIdentifier":"/us/usc/t20/s1228c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F6","sourceRelease":"119-100","text":"The term “membership organization” includes any organization that maintains a membership list or collects dues or membership fees from its members.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Recreational organization","label":"7 Recreational organization","identifier":"/us/usc/t20/s1228c/d/7","parentIdentifier":"/us/usc/t20/s1228c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F7","sourceRelease":"119-100","text":"The term “recreational organization” includes any organization or entity that has as its primary function pleasure, amusement, or sports activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Recreational program","label":"8 Recreational program","identifier":"/us/usc/t20/s1228c/d/8","parentIdentifier":"/us/usc/t20/s1228c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fd%2F8","sourceRelease":"119-100","text":"The term “recreational program” includes any activity or service that is intended as an entertainment pastime.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
