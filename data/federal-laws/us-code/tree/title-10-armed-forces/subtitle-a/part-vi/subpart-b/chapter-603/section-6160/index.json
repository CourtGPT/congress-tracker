{"type":"section","nativeType":"section","number":"6160","heading":"Information relating to certain defense nuclear nonproliferation programs","label":"6160 Information relating to certain defense nuclear nonproliferation programs","identifier":"/us/usc/t10/s6160","parentIdentifier":"/us/usc/t10/stA/ptVI/sptB/ch603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6160","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsA prior section 6160 was renumbered .section 8270 of this titleProvisions similar to those in this section were contained in , War and National Defense, prior to repeal by .section 2576 of Title 50Pub. L. 119–60, § 3111(b)(1)","Amendments2025—, realigned margins.Pub. L. 119–60, § 3111(d)(2)(B)"],"amendments":["Amendments2025—, realigned margins.Pub. L. 119–60, § 3111(d)(2)(B)"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Technologies and Capabilities","label":"a .—Technologies and Capabilities","identifier":"/us/usc/t10/s6160/a","parentIdentifier":"/us/usc/t10/s6160","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6160%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6160/a/1","parentIdentifier":"/us/usc/t10/s6160/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6160%2Fa%2F1","sourceRelease":"119-100","text":"are transitioned to end users for further development or deployment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6160/a/2","parentIdentifier":"/us/usc/t10/s6160/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6160%2Fa%2F2","sourceRelease":"119-100","text":"are deployed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Assessments of Status","label":"b .—Assessments of Status","identifier":"/us/usc/t10/s6160/b","parentIdentifier":"/us/usc/t10/s6160","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6160%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6160/b/1","parentIdentifier":"/us/usc/t10/s6160/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6160%2Fb%2F1","sourceRelease":"119-100","text":"In assessing projects under the defense nuclear nonproliferation research and development program or the defense nuclear nonproliferation and arms control program, the Administrator shall compare the status of each such project, including with respect to the final results of such project, to the baseline targets and goals established in the initial project plan of such project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6160/b/2","parentIdentifier":"/us/usc/t10/s6160/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6160%2Fb%2F2","sourceRelease":"119-100","text":"The Administrator may carry out paragraph (1) using a common template or such other means as the Administrator determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
