{"type":"section","nativeType":"section","number":"4573","heading":"Commission recommendations and report","label":"4573 Commission recommendations and report","identifier":"/us/usc/t19/s4573","parentIdentifier":"/us/usc/t19/ch29/schIII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4573","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t19/s4573/a","parentIdentifier":"/us/usc/t19/s4573","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4573%2Fa","sourceRelease":"119-100","text":"If the Commission makes an affirmative determination under , the Commission shall recommend the action that is necessary to address the material harm or threat of material harm found.section 4572 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitation","label":"b Limitation","identifier":"/us/usc/t19/s4573/b","parentIdentifier":"/us/usc/t19/s4573","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4573%2Fb","sourceRelease":"119-100","text":"Only those members of the Commission who agreed to the affirmative determination under are eligible to vote on the recommendation required to be made under subsection (a).section 4572 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Report","label":"c Report","identifier":"/us/usc/t19/s4573/c","parentIdentifier":"/us/usc/t19/s4573","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4573%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4573/c/1","parentIdentifier":"/us/usc/t19/s4573/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4573%2Fc%2F1","sourceRelease":"119-100","text":"the determination and an explanation of the basis for the determination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4573/c/2","parentIdentifier":"/us/usc/t19/s4573/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4573%2Fc%2F2","sourceRelease":"119-100","text":"if the determination is affirmative, recommendations for action and an explanation of the basis for the recommendation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s4573/c/3","parentIdentifier":"/us/usc/t19/s4573/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4573%2Fc%2F3","sourceRelease":"119-100","text":"any dissenting or separate views by members of the Commission regarding the determination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Public notice","label":"d Public notice","identifier":"/us/usc/t19/s4573/d","parentIdentifier":"/us/usc/t19/s4573","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4573%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4573/d/1","parentIdentifier":"/us/usc/t19/s4573/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4573%2Fd%2F1","sourceRelease":"119-100","text":"promptly make public the report (with the exception of information which the Commission determines to be confidential business information); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4573/d/2","parentIdentifier":"/us/usc/t19/s4573/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4573%2Fd%2F2","sourceRelease":"119-100","text":"publish a summary of the report in the Federal Register.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
