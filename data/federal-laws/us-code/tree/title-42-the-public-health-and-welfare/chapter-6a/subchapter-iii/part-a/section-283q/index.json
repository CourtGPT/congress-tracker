Fusc%2Ft42%2Fs283q%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s283q/b/1/A","parentIdentifier":"/us/usc/t42/s283q/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs283q%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the effect of innovations funded through the prize competitions under this section in advancing biomedical science or improving health outcomes pursuant to subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s283q/b/1/B","parentIdentifier":"/us/usc/t42/s283q/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs283q%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the effect of the innovations on Federal expenditures; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s283q/b/2","parentIdentifier":"/us/usc/t42/s283q/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs283q%2Fb%2F2","sourceRelease":"119-100","text":"include the information collected under paragraph (1) in the triennial report under (as amended by section 2032).section 283 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
