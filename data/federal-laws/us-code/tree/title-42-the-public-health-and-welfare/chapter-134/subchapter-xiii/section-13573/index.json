{"type":"section","nativeType":"section","number":"13573","heading":"Generation projects","label":"13573 Generation projects","identifier":"/us/usc/t42/s13573","parentIdentifier":"/us/usc/t42/ch134/schXIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Eligible projects","label":"a Eligible projects","identifier":"/us/usc/t42/s13573/a","parentIdentifier":"/us/usc/t42/s13573","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13573/a/1","parentIdentifier":"/us/usc/t42/s13573/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fa%2F1","sourceRelease":"119-100","text":"equipment or processes previously supported by a Department of Energy program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13573/a/2","parentIdentifier":"/us/usc/t42/s13573/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fa%2F2","sourceRelease":"119-100","text":"advanced combustion equipment and processes that the Secretary determines will be cost-effective and could substantially contribute to meeting environmental or energy needs, including gasification, gasification fuel cells, gasification coproduction, oxidation combustion techniques, ultra-supercritical boilers, and chemical looping; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13573/a/3","parentIdentifier":"/us/usc/t42/s13573/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fa%2F3","sourceRelease":"119-100","text":"hybrid gasification/combustion systems, including systems integrating fuel cells with gasification or combustion units.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Criteria","label":"b Criteria","identifier":"/us/usc/t42/s13573/b","parentIdentifier":"/us/usc/t42/s13573","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13573/b/1","parentIdentifier":"/us/usc/t42/s13573/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fb%2F1","sourceRelease":"119-100","text":"prioritization of projects whose installation is likely to result in significant air quality improvements in nonattainment air quality areas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13573/b/2","parentIdentifier":"/us/usc/t42/s13573/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fb%2F2","sourceRelease":"119-100","text":"prioritization of projects whose installation is likely to result in lower emission rates of pollution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13573/b/3","parentIdentifier":"/us/usc/t42/s13573/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fb%2F3","sourceRelease":"119-100","text":"prioritization of projects that result in the repowering or replacement of older, less efficient units;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s13573/b/4","parentIdentifier":"/us/usc/t42/s13573/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fb%2F4","sourceRelease":"119-100","text":"documented broad interest in the procurement of the equipment and utilization of the processes used in the projects by owners or operators of facilities for electricity generation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s13573/b/5","parentIdentifier":"/us/usc/t42/s13573/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13573/b/5/A","parentIdentifier":"/us/usc/t42/s13573/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fb%2F5%2FA","sourceRelease":"119-100","text":"40 percent for coal of more than 9,000 Btu per pound based on higher heating values;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13573/b/5/B","parentIdentifier":"/us/usc/t42/s13573/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fb%2F5%2FB","sourceRelease":"119-100","text":"38 percent for coal of 7,000 to 9,000 Btu per pound passed on higher heating values; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s13573/b/5/C","parentIdentifier":"/us/usc/t42/s13573/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fb%2F5%2FC","sourceRelease":"119-100","text":"36 percent for coal of less than 7,000 Btu per pound based on higher heating values;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s13573/b/6","parentIdentifier":"/us/usc/t42/s13573/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fb%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13573/b/6/A","parentIdentifier":"/us/usc/t42/s13573/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fb%2F6%2FA","sourceRelease":"119-100","text":"45 percent for coal of more than 9,000 Btu per pound based on higher heating values;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13573/b/6/B","parentIdentifier":"/us/usc/t42/s13573/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fb%2F6%2FB","sourceRelease":"119-100","text":"44 percent for coal of 7,000 to 9,000 Btu per pound passed on higher heating values; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s13573/b/6/C","parentIdentifier":"/us/usc/t42/s13573/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fb%2F6%2FC","sourceRelease":"119-100","text":"40 percent for coal of less than 7,000 Btu per pound based on higher heating values;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Program balance and priority","label":"c Program balance and priority","identifier":"/us/usc/t42/s13573/c","parentIdentifier":"/us/usc/t42/s13573","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13573/c/1","parentIdentifier":"/us/usc/t42/s13573/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fc%2F1","sourceRelease":"119-100","text":"between 25 percent and 75 percent of the projects supported are for the sole purpose of electrical generation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13573/c/2","parentIdentifier":"/us/usc/t42/s13573/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fc%2F2","sourceRelease":"119-100","text":"priority is given to projects that use electrical generation equipment and processes that have been developed and demonstrated and applied in actual production of electricity, but are not yet cost-competitive, and that achieve greater efficiency and environmental performance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s13573/d","parentIdentifier":"/us/usc/t42/s13573","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13573/d/1","parentIdentifier":"/us/usc/t42/s13573/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fd%2F1","sourceRelease":"119-100","text":"$250,000,000 for fiscal year 2007;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13573/d/2","parentIdentifier":"/us/usc/t42/s13573/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fd%2F2","sourceRelease":"119-100","text":"$350,000,000 for fiscal year 2008;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13573/d/3","parentIdentifier":"/us/usc/t42/s13573/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fd%2F3","sourceRelease":"119-100","text":"$400,000,000 for each of fiscal years 2009 through 2012; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s13573/d/4","parentIdentifier":"/us/usc/t42/s13573/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fd%2F4","sourceRelease":"119-100","text":"$300,000,000 for fiscal year 2013.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Applicability","label":"e Applicability","identifier":"/us/usc/t42/s13573/e","parentIdentifier":"/us/usc/t42/s13573","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13573%2Fe","sourceRelease":"119-100","text":"No technology, or level of emission reduction, shall be treated as adequately demonstrated for purpose of , achievable for purposes of , or achievable in practice for purposes of solely by reason of the use of such technology, or the achievement of such emission reduction, by one or more facilities receiving assistance under .1section 7411 of this titlesection 7479 of this titlesection 7501 of this titlesection 13572(a)(1) of this titleSo in original. Probably should be “purposes”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
