{"type":"section","nativeType":"section","number":"2104","heading":"State and Federal cooperation","label":"2104 State and Federal cooperation","identifier":"/us/usc/t21/s2104","parentIdentifier":"/us/usc/t21/ch26","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2104","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t21/s2104/a","parentIdentifier":"/us/usc/t21/s2104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2104%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s2104/a/1","parentIdentifier":"/us/usc/t21/s2104/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2104%2Fa%2F1","sourceRelease":"119-100","text":"establish, continue, or strengthen State food safety programs, especially with respect to the regulation of retail commercial food establishments; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s2104/a/2","parentIdentifier":"/us/usc/t21/s2104/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2104%2Fa%2F2","sourceRelease":"119-100","text":"establish procedures and requirements for ensuring that processed produce under the jurisdiction of State food safety programs is not unsafe for human consumption.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Assistance","label":"b Assistance","identifier":"/us/usc/t21/s2104/b","parentIdentifier":"/us/usc/t21/s2104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2104%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s2104/b/1","parentIdentifier":"/us/usc/t21/s2104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2104%2Fb%2F1","sourceRelease":"119-100","text":"advisory assistance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s2104/b/2","parentIdentifier":"/us/usc/t21/s2104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2104%2Fb%2F2","sourceRelease":"119-100","text":"technical assistance, training, and laboratory assistance (including necessary materials and equipment); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t21/s2104/b/3","parentIdentifier":"/us/usc/t21/s2104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2104%2Fb%2F3","sourceRelease":"119-100","text":"financial and other assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Service agreements","label":"c Service agreements","identifier":"/us/usc/t21/s2104/c","parentIdentifier":"/us/usc/t21/s2104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2104%2Fc","sourceRelease":"119-100","text":"The Secretary may, under an agreement entered into with a Federal, State, or local agency, use, on a reimbursable basis or otherwise, the personnel, services, and facilities of the agency to carry out the responsibilities of the agency under this section. An agreement entered into with a State agency under this subsection may provide for training of State employees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
