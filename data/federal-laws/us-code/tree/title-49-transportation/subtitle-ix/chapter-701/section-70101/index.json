{"type":"section","nativeType":"section","number":"70101","heading":"National multimodal freight policy","label":"70101 National multimodal freight policy","identifier":"/us/usc/t49/s70101","parentIdentifier":"/us/usc/t49/stIX/ch701","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsA prior section 70101 was transferred and renumbered as , National and Commercial Space Programs.section 50901 of Title 51","Amendments2021—Subsec. (c). substituted “Assistant Secretary for Multimodal Freight” for “Under Secretary of Transportation for Policy” in introductory provisions.Pub. L. 117–58","Statutory Notes and Related Subsidiaries","Effective DateSection effective , see , set out as an Effective Date of 2015 Amendment note under , Government Organization and Employees.Oct. 1, 2015section 1003 of Pub. L. 114–94section 5313 of Title 5"],"amendments":["Amendments2021—Subsec. (c). substituted “Assistant Secretary for Multimodal Freight” for “Under Secretary of Transportation for Policy” in introductory provisions.Pub. L. 117–58","Effective DateSection effective , see , set out as an Effective Date of 2015 Amendment note under , Government Organization and Employees.Oct. 1, 2015section 1003 of Pub. L. 114–94section 5313 of Title 5"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t49/s70101/a","parentIdentifier":"/us/usc/t49/s70101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fa","sourceRelease":"119-100","text":"It is the policy of the United States to maintain and improve the condition and performance of the National Multimodal Freight Network established under section 70103 to ensure that the Network provides a foundation for the United States to compete in the global economy and achieve the goals described in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Goals","label":"b .—Goals","identifier":"/us/usc/t49/s70101/b","parentIdentifier":"/us/usc/t49/s70101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s70101/b/1","parentIdentifier":"/us/usc/t49/s70101/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s70101/b/1/A","parentIdentifier":"/us/usc/t49/s70101/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F1%2FA","sourceRelease":"119-100","text":"strengthen the contribution of the National Multimodal Freight Network to the economic competitiveness of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s70101/b/1/B","parentIdentifier":"/us/usc/t49/s70101/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F1%2FB","sourceRelease":"119-100","text":"reduce congestion and eliminate bottlenecks on the National Multimodal Freight Network; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s70101/b/1/C","parentIdentifier":"/us/usc/t49/s70101/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F1%2FC","sourceRelease":"119-100","text":"increase productivity, particularly for domestic industries and businesses that create high-value jobs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s70101/b/2","parentIdentifier":"/us/usc/t49/s70101/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F2","sourceRelease":"119-100","text":"to improve the safety, security, efficiency, and resiliency of multimodal freight transportation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s70101/b/3","parentIdentifier":"/us/usc/t49/s70101/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F3","sourceRelease":"119-100","text":"to achieve and maintain a state of good repair on the National Multimodal Freight Network;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s70101/b/4","parentIdentifier":"/us/usc/t49/s70101/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F4","sourceRelease":"119-100","text":"to use innovation and advanced technology to improve the safety, efficiency, and reliability of the National Multimodal Freight Network;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t49/s70101/b/5","parentIdentifier":"/us/usc/t49/s70101/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F5","sourceRelease":"119-100","text":"to improve the economic efficiency and productivity of the National Multimodal Freight Network;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t49/s70101/b/6","parentIdentifier":"/us/usc/t49/s70101/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F6","sourceRelease":"119-100","text":"to improve the reliability of freight transportation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t49/s70101/b/7","parentIdentifier":"/us/usc/t49/s70101/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s70101/b/7/A","parentIdentifier":"/us/usc/t49/s70101/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F7%2FA","sourceRelease":"119-100","text":"travel across rural areas between population centers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s70101/b/7/B","parentIdentifier":"/us/usc/t49/s70101/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F7%2FB","sourceRelease":"119-100","text":"travel between rural areas and population centers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s70101/b/7/C","parentIdentifier":"/us/usc/t49/s70101/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F7%2FC","sourceRelease":"119-100","text":"travel from the Nation’s ports, airports, and gateways to the National Multimodal Freight Network;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t49/s70101/b/8","parentIdentifier":"/us/usc/t49/s70101/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F8","sourceRelease":"119-100","text":"to improve the flexibility of States to support multi-State corridor planning and the creation of multi-State organizations to increase the ability of States to address multimodal freight connectivity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t49/s70101/b/9","parentIdentifier":"/us/usc/t49/s70101/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F9","sourceRelease":"119-100","text":"to reduce the adverse environmental impacts of freight movement on the National Multimodal Freight Network; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t49/s70101/b/10","parentIdentifier":"/us/usc/t49/s70101/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fb%2F10","sourceRelease":"119-100","text":"to pursue the goals described in this subsection in a manner that is not burdensome to State and local governments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Implementation","label":"c .—Implementation","identifier":"/us/usc/t49/s70101/c","parentIdentifier":"/us/usc/t49/s70101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s70101/c/1","parentIdentifier":"/us/usc/t49/s70101/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fc%2F1","sourceRelease":"119-100","text":"carry out sections 70102 and 70103;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s70101/c/2","parentIdentifier":"/us/usc/t49/s70101/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fc%2F2","sourceRelease":"119-100","text":"assist with the coordination of modal freight planning; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s70101/c/3","parentIdentifier":"/us/usc/t49/s70101/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70101%2Fc%2F3","sourceRelease":"119-100","text":"identify interagency data sharing opportunities to promote freight planning and coordination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
