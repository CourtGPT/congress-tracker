{"type":"section","nativeType":"section","number":"8727","heading":"Identification of, and immigration restrictions on, senior officials of the Government of Iran and their family members","label":"8727 Identification of, and immigration restrictions on, senior officials of the Government of Iran and their family members","identifier":"/us/usc/t22/s8727","parentIdentifier":"/us/usc/t22/ch94/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727","sourceRelease":"119-100","text":null,"notes":["Termination of SectionFor termination of section, see .section 8785(a) of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Identification","label":"a Identification","identifier":"/us/usc/t22/s8727/a","parentIdentifier":"/us/usc/t22/s8727","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s8727/a/1","parentIdentifier":"/us/usc/t22/s8727/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s8727/a/1/A","parentIdentifier":"/us/usc/t22/s8727/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fa%2F1%2FA","sourceRelease":"119-100","text":"illicit nuclear activities or proliferation of weapons of mass destruction or delivery systems for weapons of mass destruction;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s8727/a/1/B","parentIdentifier":"/us/usc/t22/s8727/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fa%2F1%2FB","sourceRelease":"119-100","text":"support for international terrorism; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s8727/a/1/C","parentIdentifier":"/us/usc/t22/s8727/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fa%2F1%2FC","sourceRelease":"119-100","text":"commission of serious human rights abuses against citizens of Iran or their family members; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s8727/a/2","parentIdentifier":"/us/usc/t22/s8727/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fa%2F2","sourceRelease":"119-100","text":"a family member of such an official.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Senior officials of the Government of Iran described","label":"b Senior officials of the Government of Iran described","identifier":"/us/usc/t22/s8727/b","parentIdentifier":"/us/usc/t22/s8727","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s8727/b/1","parentIdentifier":"/us/usc/t22/s8727/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fb%2F1","sourceRelease":"119-100","text":"the Supreme Leader of Iran;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s8727/b/2","parentIdentifier":"/us/usc/t22/s8727/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fb%2F2","sourceRelease":"119-100","text":"the President of Iran;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s8727/b/3","parentIdentifier":"/us/usc/t22/s8727/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fb%2F3","sourceRelease":"119-100","text":"a member of the Cabinet of the Government of Iran;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s8727/b/4","parentIdentifier":"/us/usc/t22/s8727/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fb%2F4","sourceRelease":"119-100","text":"a member of the Assembly of Experts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s8727/b/5","parentIdentifier":"/us/usc/t22/s8727/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fb%2F5","sourceRelease":"119-100","text":"a senior member of the Intelligence Ministry of Iran; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s8727/b/6","parentIdentifier":"/us/usc/t22/s8727/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fb%2F6","sourceRelease":"119-100","text":"a senior member of Iran’s Revolutionary Guard Corps, including a senior member of a paramilitary organization such as Ansar-e-Hezbollah or Basij-e Motaz’afin.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Exclusion from United States","label":"c Exclusion from United States","identifier":"/us/usc/t22/s8727/c","parentIdentifier":"/us/usc/t22/s8727","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fc","sourceRelease":"119-100","text":"Except as provided in subsection (d), the Secretary of State shall deny a visa to, and the Secretary of Homeland Security shall exclude from the United States, any alien who is on the list required by subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Exception to comply with United Nations Headquarters agreement","label":"d Exception to comply with United Nations Headquarters agreement","identifier":"/us/usc/t22/s8727/d","parentIdentifier":"/us/usc/t22/s8727","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fd","sourceRelease":"119-100","text":"Subsection (c) shall not apply to an individual if admitting the individual to the United States is necessary to permit the United States to comply with the Agreement between the United Nations and the United States of America regarding the Headquarters of the United Nations, signed , and entered into force , and other applicable international obligations.June 26, 1947November 21, 1947","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Waiver","label":"e Waiver","identifier":"/us/usc/t22/s8727/e","parentIdentifier":"/us/usc/t22/s8727","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s8727/e/1","parentIdentifier":"/us/usc/t22/s8727/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fe%2F1","sourceRelease":"119-100","text":"determines that such a waiver is essential to the national interests of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s8727/e/2","parentIdentifier":"/us/usc/t22/s8727/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8727%2Fe%2F2","sourceRelease":"119-100","text":"not less than 7 days before the waiver takes effect, notifies Congress of the waiver and the reason for the waiver.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
