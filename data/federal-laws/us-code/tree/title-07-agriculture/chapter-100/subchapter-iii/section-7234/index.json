,"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7234/a/2/B","parentIdentifier":"/us/usc/t7/s7234/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7234%2Fa%2F2%2FB","sourceRelease":"119-100","text":"minimize the accumulation of stocks of the commodity by the Federal Government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s7234/a/2/C","parentIdentifier":"/us/usc/t7/s7234/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7234%2Fa%2F2%2FC","sourceRelease":"119-100","text":"minimize the cost incurred by the Federal Government in storing the commodity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s7234/a/2/D","parentIdentifier":"/us/usc/t7/s7234/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7234%2Fa%2F2%2FD","sourceRelease":"119-100","text":"allow the commodity produced in the United States to be marketed freely and competitively, both domestically and internationally.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Repayment rates for upland cotton and rice","label":"b Repayment rates for upland cotton and rice","identifier":"/us/usc/t7/s7234/b","parentIdentifier":"/us/usc/t7/s7234","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7234%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7234/b/1","parentIdentifier":"/us/usc/t7/s7234/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7234%2Fb%2F1","sourceRelease":"119-100","text":"the loan rate established for the commodity under , plus interest (as determined by the Secretary); orsection 7232 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7234/b/2","parentIdentifier":"/us/usc/t7/s7234/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7234%2Fb%2F2","sourceRelease":"119-100","text":"the prevailing world market price for the commodity (adjusted to United States quality and location), as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Repayment rates for extra long staple cotton","label":"c Repayment rates for extra long staple cotton","identifier":"/us/usc/t7/s7234/c","parentIdentifier":"/us/usc/t7/s7234","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7234%2Fc","sourceRelease":"119-100","text":"Repayment of a marketing assistance loan for extra long staple cotton shall be at the loan rate established for the commodity under , plus interest (as determined by the Secretary).section 7232 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Prevailing world market price","label":"d Prevailing world market price","identifier":"/us/usc/t7/s7234/d","parentIdentifier":"/us/usc/t7/s7234","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7234%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7234/d/1","parentIdentifier":"/us/usc/t7/s7234/d","sourceUrl":"