"sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F2%2FA%2Fii%2FI","sourceRelease":"119-100","text":"is physically present in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t46/s11113/a/2/A/ii/II","parentIdentifier":"/us/usc/t46/s11113/a/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F2%2FA%2Fii%2FII","sourceRelease":"119-100","text":"the Secretary determines was abandoned in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t46/s11113/a/2/A/ii/III","parentIdentifier":"/us/usc/t46/s11113/a/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F2%2FA%2Fii%2FIII","sourceRelease":"119-100","text":"has not applied for asylum under the Immigration and Nationality Act ( et seq.); and8 U.S.C. 1101","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s11113/a/2/B","parentIdentifier":"/us/usc/t46/s11113/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t46/s11113/a/2/B/i","parentIdentifier":"/us/usc/t46/s11113/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the vessel owner or operator is not convicted of a criminal offense related to such matter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t46/s11113/a/2/B/ii","parentIdentifier":"/us/usc/t46/s11113/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the Secretary determines that reimbursement is appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Crediting of amounts to fund.—","label":"3 Crediting of amounts to fund.—","identifier":"/us/usc/t46/s11113/a/3","parentIdentifier":"/us/usc/t46/s11113/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t46/s11113/a/3/A","parentIdentifier":"/us/usc/t46/s11113/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t46/s11113/a/3/A/i","parentIdentifier":"/us/usc/t46/s11113/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F3%2FA%2Fi","sourceRelease":"119-100","text":"Penalties deposited in the Fund under section 9 of the Act to Prevent Pollution from Ships ().33 U.S.C. 1908","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t46/s11113/a/3/A/ii","parentIdentifier":"/us/usc/t46/s11113/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F3%2FA%2Fii","sourceRelease":"119-100","text":"Amounts reimbursed or recovered under subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Limitation","label":"B .—Limitation","identifier":"/us/usc/t46/s11113/a/3/B","parentIdentifier":"/us/usc/t46/s11113/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F3%2FB","sourceRelease":"119-100","text":"Amounts may be credited to the Fund under subparagraph (A) only if the unobligated balance of the Fund is less than $5,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Report required","label":"4 .—Report required","identifier":"/us/usc/t46/s11113/a/4","parentIdentifier":"/us/usc/t46/s11113/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s11113/a/4/A","parentIdentifier":"/us/usc/t46/s11113/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F4%2FA","sourceRelease":"119-100","text":"the amounts credited to the Fund under paragraph (3) for the preceding fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s11113/a/4/B","parentIdentifier":"/us/usc/t46/s11113/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F4%2FB","sourceRelease":"119-100","text":"amounts in the Fund that were expended for the preceding fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":".—No report required","label":"5 .—No report required","identifier":"/us/usc/t46/s11113/a/5","parentIdentifier":"/us/usc/t46/s11113/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fa%2F5","sourceRelease":"119-100","text":"A report under paragraph (4) shall not be required if there were no expenditures from the Fund in the preceding fiscal year. The Commandant shall notify Congress in the event a report is not required under paragraph (4) by reason of this paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Limitation","label":"b .—Limitation","identifier":"/us/usc/t46/s11113/b","parentIdentifier":"/us/usc/t46/s11113","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s11113/b/1","parentIdentifier":"/us/usc/t46/s11113/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fb%2F1","sourceRelease":"119-100","text":"to create a private right of action or any other right, benefit, or entitlement to necessary support for any person; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s11113/b/2","parentIdentifier":"/us/usc/t46/s11113/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fb%2F2","sourceRelease":"119-100","text":"to compel the Secretary to pay or reimburse the cost of necessary support.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Reimbursement; Recovery.—","label":"c Reimbursement; Recovery.—","identifier":"/us/usc/t46/s11113/c","parentIdentifier":"/us/usc/t46/s11113","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t46/s11113/c/1","parentIdentifier":"/us/usc/t46/s11113/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s11113/c/1/A","parentIdentifier":"/us/usc/t46/s11113/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t46/s11113/c/1/A/i","parentIdentifier":"/us/usc/t46/s11113/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"during the course of an investigation, reporting, documentation, or adjudication of any matter that the Coast Guard referred to a United States attorney or the Attorney General, fails to provide necessary support of a seafarer who was paroled into the United States to facilitate the investigation, reporting, documentation, or adjudication; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t46/s11113/c/1/A/ii","parentIdentifier":"/us/usc/t46/s11113/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t46/s11113/c/1/A/ii/I","parentIdentifier":"/us/usc/t46/s11113/c/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F1%2FA%2Fii%2FI","sourceRelease":"119-100","text":"convicted of a criminal offense related to such matter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t46/s11113/c/1/A/ii/II","parentIdentifier":"/us/usc/t46/s11113/c/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F1%2FA%2Fii%2FII","sourceRelease":"119-100","text":"required to reimburse the Fund pursuant to a court order or negotiated settlement related to such matter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s11113/c/1/B","parentIdentifier":"/us/usc/t46/s11113/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F1%2FB","sourceRelease":"119-100","text":"the vessel owner or operator abandons a seafarer in the United States, as determined by the Secretary based on substantial evidence.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Enforcement","label":"2 .—Enforcement","identifier":"/us/usc/t46/s11113/c/2","parentIdentifier":"/us/usc/t46/s11113/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s11113/c/2/A","parentIdentifier":"/us/usc/t46/s11113/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F2%2FA","sourceRelease":"119-100","text":"proceed in rem against the vessel on which the seafarer served in the Federal district court for the district in which the vessel is found; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s11113/c/2/B","parentIdentifier":"/us/usc/t46/s11113/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F2%2FB","sourceRelease":"119-100","text":"withhold or revoke the clearance required under section 60105 for the vessel and any other vessel operated by the same operator (as that term is defined in section 2(a)(9)(A) of the Act to Prevent Pollution from Ships () as the vessel on which the seafarer served.133 U.S.C. 1901(a)(9)(A)2So in original. Probably should be “2(a)(9)(a)”.1So in original. Probably should be “))”.233 U.S.C. 1901(a)(9)(a)","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Obtaining clearance","label":"3 .—Obtaining clearance","identifier":"/us/usc/t46/s11113/c/3","parentIdentifier":"/us/usc/t46/s11113/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s11113/c/3/A","parentIdentifier":"/us/usc/t46/s11113/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F3%2FA","sourceRelease":"119-100","text":"reimburses the Fund the amount required under paragraph (1); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s11113/c/3/B","parentIdentifier":"/us/usc/t46/s11113/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F3%2FB","sourceRelease":"119-100","text":"provides a bond, or other evidence of financial responsibility, sufficient to meet the amount required to be reimbursed under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Notification required","label":"4 .—Notification required","identifier":"/us/usc/t46/s11113/c/4","parentIdentifier":"/us/usc/t46/s11113/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fc%2F4","sourceRelease":"119-100","text":"The Secretary shall notify the vessel at least 72 hours before taking any action under paragraph (2)(B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Definitions","label":"d .—Definitions","identifier":"/us/usc/t46/s11113/d","parentIdentifier":"/us/usc/t46/s11113","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Abandons; abandoned","label":"1 .—Abandons; abandoned","identifier":"/us/usc/t46/s11113/d/1","parentIdentifier":"/us/usc/t46/s11113/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s11113/d/1/A","parentIdentifier":"/us/usc/t46/s11113/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fd%2F1%2FA","sourceRelease":"119-100","text":"a vessel owner’s or operator’s unilateral severance of ties with a seafarer; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s11113/d/1/B","parentIdentifier":"/us/usc/t46/s11113/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fd%2F1%2FB","sourceRelease":"119-100","text":"a vessel owner’s or operator’s failure to provide necessary support of a seafarer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Fund","label":"2 .—Fund","identifier":"/us/usc/t46/s11113/d/2","parentIdentifier":"/us/usc/t46/s11113/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fd%2F2","sourceRelease":"119-100","text":"The term “Fund” means the Abandoned Seafarers Fund established under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Necessary support","label":"3 .—Necessary support","identifier":"/us/usc/t46/s11113/d/3","parentIdentifier":"/us/usc/t46/s11113/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fd%2F3","sourceRelease":"119-100","text":"The term “necessary support” means normal wages and expenses the Secretary considers reasonable for lodging, subsistence, clothing, medical care (including hospitalization), repatriation, and any other support the Secretary considers to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Seafarer","label":"4 .—Seafarer","identifier":"/us/usc/t46/s11113/d/4","parentIdentifier":"/us/usc/t46/s11113/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fd%2F4","sourceRelease":"119-100","text":"The term “seafarer” means an alien crew member who is employed or engaged in any capacity on board a vessel subject to the jurisdiction of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":".—Vessel subject to the jurisdiction of the united states","label":"5 .—Vessel subject to the jurisdiction of the united states","identifier":"/us/usc/t46/s11113/d/5","parentIdentifier":"/us/usc/t46/s11113/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fd%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s11113/d/5/A","parentIdentifier":"/us/usc/t46/s11113/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fd%2F5%2FA","sourceRelease":"119-100","text":"owned, or operated under a bareboat charter, by the United States, a State or political subdivision thereof, or a foreign nation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s11113/d/5/B","parentIdentifier":"/us/usc/t46/s11113/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11113%2Fd%2F5%2FB","sourceRelease":"119-100","text":"not engaged in commerce.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
