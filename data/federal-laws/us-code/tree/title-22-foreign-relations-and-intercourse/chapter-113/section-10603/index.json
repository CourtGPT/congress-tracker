{"type":"section","nativeType":"section","number":"10603","heading":"Governance of the Foundation","label":"10603 Governance of the Foundation","identifier":"/us/usc/t22/s10603","parentIdentifier":"/us/usc/t22/ch113","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThis chapter, referred to in subsec. (b)(1)(A), was in the original “this title” and was translated as reading “this subtitle”, meaning subtitle A (§§ 5101–5109) of title LI of div. E of , , , known as the United States Foundation for International Conservation Act of 2024, which is classified generally to this chapter.Pub. L. 118–159138 Stat. 2410Dec. 23, 2024"],"amendments":["References in TextThis chapter, referred to in subsec. (b)(1)(A), was in the original “this title” and was translated as reading “this subtitle”, meaning subtitle A (§§ 5101–5109) of title LI of div. E of , , , known as the United States Foundation for International Conservation Act of 2024, which is classified generally to this chapter.Pub. L. 118–159138 Stat. 2410Dec. 23, 2024"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Executive Director","label":"a Executive Director","identifier":"/us/usc/t22/s10603/a","parentIdentifier":"/us/usc/t22/s10603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10603/a/1","parentIdentifier":"/us/usc/t22/s10603/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fa%2F1","sourceRelease":"119-100","text":"manage the Foundation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10603/a/2","parentIdentifier":"/us/usc/t22/s10603/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fa%2F2","sourceRelease":"119-100","text":"report to, and be under the direct authority, of the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Board of Directors","label":"b Board of Directors","identifier":"/us/usc/t22/s10603/b","parentIdentifier":"/us/usc/t22/s10603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Governance","label":"1 Governance","identifier":"/us/usc/t22/s10603/b/1","parentIdentifier":"/us/usc/t22/s10603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10603/b/1/A","parentIdentifier":"/us/usc/t22/s10603/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F1%2FA","sourceRelease":"119-100","text":"shall perform the functions specified to be carried out by the Board under this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10603/b/1/B","parentIdentifier":"/us/usc/t22/s10603/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F1%2FB","sourceRelease":"119-100","text":"may prescribe, amend, and repeal bylaws, rules, regulations, and procedures governing the manner in which the business of the Foundation may be conducted and in which the powers granted to it by law may be exercised.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Membership","label":"2 Membership","identifier":"/us/usc/t22/s10603/b/2","parentIdentifier":"/us/usc/t22/s10603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10603/b/2/A","parentIdentifier":"/us/usc/t22/s10603/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the Secretary, the Administrator of the United States Agency for International Development, the Secretary of the Interior, the Chief of the United States Forest Service, and the head of one other relevant Federal department or agency, as determined by the Secretary, or the Senate-confirmed designees of such officials; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10603/b/2/B","parentIdentifier":"/us/usc/t22/s10603/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s10603/b/2/B/i","parentIdentifier":"/us/usc/t22/s10603/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"4 members shall be private-sector donors making financial contributions to the Foundation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s10603/b/2/B/ii","parentIdentifier":"/us/usc/t22/s10603/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"4 members shall be independent experts who, in addition to meeting the qualification requirements described in paragraph (3), represent diverse points of view and diverse geographies, to the maximum extent practicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Qualifications","label":"3 Qualifications","identifier":"/us/usc/t22/s10603/b/3","parentIdentifier":"/us/usc/t22/s10603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10603/b/3/A","parentIdentifier":"/us/usc/t22/s10603/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F3%2FA","sourceRelease":"119-100","text":"international development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10603/b/3/B","parentIdentifier":"/us/usc/t22/s10603/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F3%2FB","sourceRelease":"119-100","text":"protected area management and the conservation of global biodiversity, fish and wildlife, ecosystem restoration, adaptation, and resilience; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10603/b/3/C","parentIdentifier":"/us/usc/t22/s10603/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F3%2FC","sourceRelease":"119-100","text":"grantmaking in support of international conservation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Political affiliation","label":"4 Political affiliation","identifier":"/us/usc/t22/s10603/b/4","parentIdentifier":"/us/usc/t22/s10603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F4","sourceRelease":"119-100","text":"Not more than 5 of the members appointed to the Board pursuant to paragraph (2)(B) may be affiliated with the same political party.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Conflicts of interest","label":"5 Conflicts of interest","identifier":"/us/usc/t22/s10603/b/5","parentIdentifier":"/us/usc/t22/s10603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F5","sourceRelease":"119-100","text":"Any individual with business interests, financial holdings, or controlling interests in any entity that has sought support, or is receiving support, from the Foundation may not be appointed to the Board during the 5-year period immediately preceding such appointment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Chairperson","label":"6 Chairperson","identifier":"/us/usc/t22/s10603/b/6","parentIdentifier":"/us/usc/t22/s10603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F6","sourceRelease":"119-100","text":"The Board shall elect, from among its members, a Chairperson, who shall serve for a 2-year term.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Terms; vacancies","label":"7 Terms; vacancies","identifier":"/us/usc/t22/s10603/b/7","parentIdentifier":"/us/usc/t22/s10603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Terms","label":"A Terms","identifier":"/us/usc/t22/s10603/b/7/A","parentIdentifier":"/us/usc/t22/s10603/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F7%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t22/s10603/b/7/A/i","parentIdentifier":"/us/usc/t22/s10603/b/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F7%2FA%2Fi","sourceRelease":"119-100","text":"The term of service of each member of the Board appointed pursuant to paragraph (2)(B) shall be not more than 5 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Initial appointed directors","label":"ii Initial appointed directors","identifier":"/us/usc/t22/s10603/b/7/A/ii","parentIdentifier":"/us/usc/t22/s10603/b/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F7%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t22/s10603/b/7/A/ii/I","parentIdentifier":"/us/usc/t22/s10603/b/7/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F7%2FA%2Fii%2FI","sourceRelease":"119-100","text":"4 members, including at least 2 private-sector donors making financial contributions to the Foundation, shall serve for 4 years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t22/s10603/b/7/A/ii/II","parentIdentifier":"/us/usc/t22/s10603/b/7/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F7%2FA%2Fii%2FII","sourceRelease":"119-100","text":"4 members shall serve for 5 years, as determined by the Chairperson of the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Vacancies","label":"B Vacancies","identifier":"/us/usc/t22/s10603/b/7/B","parentIdentifier":"/us/usc/t22/s10603/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F7%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s10603/b/7/B/i","parentIdentifier":"/us/usc/t22/s10603/b/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F7%2FB%2Fi","sourceRelease":"119-100","text":"shall be filled in the manner in which the original appointment was made; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s10603/b/7/B/ii","parentIdentifier":"/us/usc/t22/s10603/b/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F7%2FB%2Fii","sourceRelease":"119-100","text":"shall not affect the power of the remaining appointed members of the Board to execute the duties of the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Quorum","label":"8 Quorum","identifier":"/us/usc/t22/s10603/b/8","parentIdentifier":"/us/usc/t22/s10603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F8","sourceRelease":"119-100","text":"A majority of the current membership of the Board, including the Secretary or the Secretary’s designee, shall constitute a quorum for the transaction of Foundation business.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":"Meetings","label":"9 Meetings","identifier":"/us/usc/t22/s10603/b/9","parentIdentifier":"/us/usc/t22/s10603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F9","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t22/s10603/b/9/A","parentIdentifier":"/us/usc/t22/s10603/b/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F9%2FA","sourceRelease":"119-100","text":"The Board shall meet not less frequently than annually at the call of the Chairperson. Such meetings may be in person, virtual, or hybrid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Initial meeting","label":"B Initial meeting","identifier":"/us/usc/t22/s10603/b/9/B","parentIdentifier":"/us/usc/t22/s10603/b/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F9%2FB","sourceRelease":"119-100","text":"Not later than 60 days after the Board is established pursuant to , the Secretary of State shall convene a meeting of the ex-officio members of the Board and the appointed members of the Board to incorporate the Foundation.section 10602(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Removal","label":"C Removal","identifier":"/us/usc/t22/s10603/b/9/C","parentIdentifier":"/us/usc/t22/s10603/b/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F9%2FC","sourceRelease":"119-100","text":"Any member of the Board appointed pursuant to paragraph (2)(B) who misses 3 consecutive regularly scheduled meetings may be removed by a majority vote of the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":"Reimbursement of expenses","label":"10 Reimbursement of expenses","identifier":"/us/usc/t22/s10603/b/10","parentIdentifier":"/us/usc/t22/s10603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F10","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t22/s10603/b/10/A","parentIdentifier":"/us/usc/t22/s10603/b/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F10%2FA","sourceRelease":"119-100","text":"Members of the Board shall serve without pay, but may be reimbursed for the actual and necessary traveling and subsistence expenses incurred in the performance of the duties of the Foundation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Limitation","label":"B Limitation","identifier":"/us/usc/t22/s10603/b/10/B","parentIdentifier":"/us/usc/t22/s10603/b/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F10%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s10603/b/10/B/i","parentIdentifier":"/us/usc/t22/s10603/b/10/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F10%2FB%2Fi","sourceRelease":"119-100","text":"shall be available exclusively for actual costs incurred by members of the Board up to the published daily per diem rate for lodging, meals, and incidentals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s10603/b/10/B/ii","parentIdentifier":"/us/usc/t22/s10603/b/10/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F10%2FB%2Fii","sourceRelease":"119-100","text":"shall not include first-class, business-class, or travel in any class other than economy class or coach class.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Other expenses","label":"C Other expenses","identifier":"/us/usc/t22/s10603/b/10/C","parentIdentifier":"/us/usc/t22/s10603/b/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F10%2FC","sourceRelease":"119-100","text":"All other expenses, including salaries for officers and staff of the Foundation, shall be established by a majority vote of the Board, as proposed by the Executive Director on no less than an annual basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":"Not Federal employees","label":"11 Not Federal employees","identifier":"/us/usc/t22/s10603/b/11","parentIdentifier":"/us/usc/t22/s10603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F11","sourceRelease":"119-100","text":"Appointment as a member of the Board and employment by the Foundation does not constitute employment by, or the holding of an office of, the United States for purposes of any Federal law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":"Duties","label":"12 Duties","identifier":"/us/usc/t22/s10603/b/12","parentIdentifier":"/us/usc/t22/s10603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F12","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10603/b/12/A","parentIdentifier":"/us/usc/t22/s10603/b/12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F12%2FA","sourceRelease":"119-100","text":"establish bylaws for the Foundation in accordance with paragraph (13);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10603/b/12/B","parentIdentifier":"/us/usc/t22/s10603/b/12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F12%2FB","sourceRelease":"119-100","text":"provide overall direction for the activities of the Foundation and establish priority activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10603/b/12/C","parentIdentifier":"/us/usc/t22/s10603/b/12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F12%2FC","sourceRelease":"119-100","text":"carry out any other necessary activities of the Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s10603/b/12/D","parentIdentifier":"/us/usc/t22/s10603/b/12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F12%2FD","sourceRelease":"119-100","text":"evaluate the performance of the Executive Director;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t22/s10603/b/12/E","parentIdentifier":"/us/usc/t22/s10603/b/12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F12%2FE","sourceRelease":"119-100","text":"take steps to limit the administrative expenses of the Foundation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t22/s10603/b/12/F","parentIdentifier":"/us/usc/t22/s10603/b/12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F12%2FF","sourceRelease":"119-100","text":"not less frequently than annually, consult and coordinate with stakeholders qualified to provide advice, assistance, and information regarding effective protected and conserved area management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"13","heading":"Bylaws","label":"13 Bylaws","identifier":"/us/usc/t22/s10603/b/13","parentIdentifier":"/us/usc/t22/s10603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t22/s10603/b/13/A","parentIdentifier":"/us/usc/t22/s10603/b/13","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s10603/b/13/A/i","parentIdentifier":"/us/usc/t22/s10603/b/13/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FA%2Fi","sourceRelease":"119-100","text":"the specific duties of the Executive Director;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s10603/b/13/A/ii","parentIdentifier":"/us/usc/t22/s10603/b/13/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FA%2Fii","sourceRelease":"119-100","text":"policies and procedures for the selection of members of the Board and officers, employees, agents, and contractors of the Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t22/s10603/b/13/A/iii","parentIdentifier":"/us/usc/t22/s10603/b/13/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t22/s10603/b/13/A/iii/I","parentIdentifier":"/us/usc/t22/s10603/b/13/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"the acceptance, solicitation, and disposition of donations and grants to the Foundation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t22/s10603/b/13/A/iii/II","parentIdentifier":"/us/usc/t22/s10603/b/13/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"the disposition of assets of the Foundation upon the dissolution of the Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t22/s10603/b/13/A/iv","parentIdentifier":"/us/usc/t22/s10603/b/13/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FA%2Fiv","sourceRelease":"119-100","text":"policies that subject all implementing partners, employees, fellows, trainees, and other agents of the Foundation (including ex-officio members of the Board and appointed members of the Board) to stringent ethical and conflict of interest standards;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t22/s10603/b/13/A/v","parentIdentifier":"/us/usc/t22/s10603/b/13/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FA%2Fv","sourceRelease":"119-100","text":"removal and exclusion procedures for implementing partners, employees, fellows, trainees, and other agents of the Foundation (including ex-officio members of the Board and appointed members of the Board) who fail to uphold the ethical and conflict of interest standards established pursuant to clause (iii);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t22/s10603/b/13/A/vi","parentIdentifier":"/us/usc/t22/s10603/b/13/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FA%2Fvi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t22/s10603/b/13/A/vi/I","parentIdentifier":"/us/usc/t22/s10603/b/13/A/vi","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FA%2Fvi%2FI","sourceRelease":"119-100","text":"to return unspent appropriations to the Treasury of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t22/s10603/b/13/A/vi/II","parentIdentifier":"/us/usc/t22/s10603/b/13/A/vi","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FA%2Fvi%2FII","sourceRelease":"119-100","text":"to donate unspent private and philanthropic contributions to projects that align with the goals and requirements described in ;section 10606 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t22/s10603/b/13/A/vii","parentIdentifier":"/us/usc/t22/s10603/b/13/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FA%2Fvii","sourceRelease":"119-100","text":"policies for vetting implementing partners and grantees to ensure the Foundation does not provide grants to for profit entities whose primary objective is activities other than conservation activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t22/s10603/b/13/A/viii","parentIdentifier":"/us/usc/t22/s10603/b/13/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FA%2Fviii","sourceRelease":"119-100","text":"clawback policies and procedures to be incorporated into grant agreements to ensure compliance with the policies referred to in clause (vii).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Requirements","label":"B Requirements","identifier":"/us/usc/t22/s10603/b/13/B","parentIdentifier":"/us/usc/t22/s10603/b/13","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s10603/b/13/B/i","parentIdentifier":"/us/usc/t22/s10603/b/13/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FB%2Fi","sourceRelease":"119-100","text":"reflect unfavorably on the ability of the Foundation to carry out activities in a fair and objective manner; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s10603/b/13/B/ii","parentIdentifier":"/us/usc/t22/s10603/b/13/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fb%2F13%2FB%2Fii","sourceRelease":"119-100","text":"compromise, or appear to compromise, the integrity of any governmental agency or program, or any officer or employee employed by, or involved in, a governmental agency or program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Foundation staff","label":"c Foundation staff","identifier":"/us/usc/t22/s10603/c","parentIdentifier":"/us/usc/t22/s10603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10603/c/1","parentIdentifier":"/us/usc/t22/s10603/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fc%2F1","sourceRelease":"119-100","text":"may not be employees of, or hold any office in, the United States Government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10603/c/2","parentIdentifier":"/us/usc/t22/s10603/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fc%2F2","sourceRelease":"119-100","text":"may not serve in the employ of any nongovernmental organization, project, or person related to or affiliated with any grantee of the Foundation while employed by the Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s10603/c/3","parentIdentifier":"/us/usc/t22/s10603/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fc%2F3","sourceRelease":"119-100","text":"may not receive compensation from any other source for work performed in carrying out the duties of the Foundation while employed by the Foundation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s10603/c/4","parentIdentifier":"/us/usc/t22/s10603/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fc%2F4","sourceRelease":"119-100","text":"should not receive a salary at a rate that is greater than the maximum rate of basic pay authorized for positions at level I of the Executive Schedule under .section 5312 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Limitation and conflicts of interests","label":"d Limitation and conflicts of interests","identifier":"/us/usc/t22/s10603/d","parentIdentifier":"/us/usc/t22/s10603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Political participation","label":"1 Political participation","identifier":"/us/usc/t22/s10603/d/1","parentIdentifier":"/us/usc/t22/s10603/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10603/d/1/A","parentIdentifier":"/us/usc/t22/s10603/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fd%2F1%2FA","sourceRelease":"119-100","text":"lobby for political or policy issues; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10603/d/1/B","parentIdentifier":"/us/usc/t22/s10603/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fd%2F1%2FB","sourceRelease":"119-100","text":"participate or intervene in any political campaign in any country.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Financial interests","label":"2 Financial interests","identifier":"/us/usc/t22/s10603/d/2","parentIdentifier":"/us/usc/t22/s10603/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10603/d/2/A","parentIdentifier":"/us/usc/t22/s10603/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fd%2F2%2FA","sourceRelease":"119-100","text":"the financial interests of such member of the Board, or officer or employee of the Foundation, not including such member’s Foundation expenses and compensation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10603/d/2/B","parentIdentifier":"/us/usc/t22/s10603/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fd%2F2%2FB","sourceRelease":"119-100","text":"the interests of any corporation, partnership, entity, or organization in which such member of the Board, officer, or employee has any fiduciary obligation or direct or indirect financial interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Recusals","label":"3 Recusals","identifier":"/us/usc/t22/s10603/d/3","parentIdentifier":"/us/usc/t22/s10603/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fd%2F3","sourceRelease":"119-100","text":"Any member of the Board that has a business, financial, or familial interest in an organization or community seeking support from the Foundation shall recuse himself or herself from all deliberations, meetings, and decisions concerning the consideration and decision relating to such support.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Project ineligibility","label":"4 Project ineligibility","identifier":"/us/usc/t22/s10603/d/4","parentIdentifier":"/us/usc/t22/s10603/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fd%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10603/d/4/A","parentIdentifier":"/us/usc/t22/s10603/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fd%2F4%2FA","sourceRelease":"119-100","text":"a current member of the Board; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10603/d/4/B","parentIdentifier":"/us/usc/t22/s10603/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10603%2Fd%2F4%2FB","sourceRelease":"119-100","text":"a former member of the Board during the 5-year period immediately following the last day of the former member’s term on the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
