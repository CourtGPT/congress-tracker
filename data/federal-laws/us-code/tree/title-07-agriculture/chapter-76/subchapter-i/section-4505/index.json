{"type":"section","nativeType":"section","number":"4505","heading":"Certification of organizations","label":"4505 Certification of organizations","identifier":"/us/usc/t7/s4505","parentIdentifier":"/us/usc/t7/ch76/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4505","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t7/s4505/a","parentIdentifier":"/us/usc/t7/s4505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4505%2Fa","sourceRelease":"119-100","text":"The eligibility of any organization to represent milk producers, and to participate in the making of nominations under shall be certified by the Secretary. The Secretary shall certify any organization that the Secretary determines meets the eligibility criteria established by the Secretary under this section and the Secretary’s determination as to eligibility shall be final.section 4504 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t7/s4505/b","parentIdentifier":"/us/usc/t7/s4505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4505%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s4505/b/1","parentIdentifier":"/us/usc/t7/s4505/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4505%2Fb%2F1","sourceRelease":"119-100","text":"geographic territory covered by the organization’s active membership;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s4505/b/2","parentIdentifier":"/us/usc/t7/s4505/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4505%2Fb%2F2","sourceRelease":"119-100","text":"nature and size of the organization’s active membership including the proportion of the total number of active milk producers represented by the organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s4505/b/3","parentIdentifier":"/us/usc/t7/s4505/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4505%2Fb%2F3","sourceRelease":"119-100","text":"evidence of stability and permanency of the organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s4505/b/4","parentIdentifier":"/us/usc/t7/s4505/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4505%2Fb%2F4","sourceRelease":"119-100","text":"sources from which the organization’s operating funds are derived;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s4505/b/5","parentIdentifier":"/us/usc/t7/s4505/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4505%2Fb%2F5","sourceRelease":"119-100","text":"functions of the organization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s4505/b/6","parentIdentifier":"/us/usc/t7/s4505/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4505%2Fb%2F6","sourceRelease":"119-100","text":"the organization’s ability and willingness to further the aims and objectives of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
