ntifier":"/us/usc/t42/s17281/c","parentIdentifier":"/us/usc/t42/s17281","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17281/c/1","parentIdentifier":"/us/usc/t42/s17281/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17281/c/1/A","parentIdentifier":"/us/usc/t42/s17281/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17281/c/1/A/i","parentIdentifier":"/us/usc/t42/s17281/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the purchase of media time and space;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17281/c/1/A/ii","parentIdentifier":"/us/usc/t42/s17281/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"creative and talent costs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s17281/c/1/A/iii","parentIdentifier":"/us/usc/t42/s17281/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fc%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"testing and evaluation of advertising; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s17281/c/1/A/iv","parentIdentifier":"/us/usc/t42/s17281/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fc%2F1%2FA%2Fiv","sourceRelease":"119-100","text":"evaluation of the effectiveness of the media campaign; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17281/c/1/B","parentIdentifier":"/us/usc/t42/s17281/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fc%2F1%2FB","sourceRelease":"119-100","text":"administrative costs, including operational and management expenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitations","label":"2 Limitations","identifier":"/us/usc/t42/s17281/c/2","parentIdentifier":"/us/usc/t42/s17281/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fc%2F2","sourceRelease":"119-100","text":"In carrying out this section, the Secretary shall allocate not less than 85 percent of funds made available under subsection (e) for each fiscal year for the advertising functions specified under paragraph (1)(A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Reports","label":"d Reports","identifier":"/us/usc/t42/s17281/d","parentIdentifier":"/us/usc/t42/s17281","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17281/d/1","parentIdentifier":"/us/usc/t42/s17281/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17281/d/1/A","parentIdentifier":"/us/usc/t42/s17281/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fd%2F1%2FA","sourceRelease":"119-100","text":"determinations concerning the rate of change of energy consumption, in both absolute and per capita terms; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17281/d/1/B","parentIdentifier":"/us/usc/t42/s17281/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fd%2F1%2FB","sourceRelease":"119-100","text":"an evaluation that enables consideration of whether the media campaign contributed to reduction of energy consumption;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17281/d/2","parentIdentifier":"/us/usc/t42/s17281/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fd%2F2","sourceRelease":"119-100","text":"steps taken to ensure that the national media campaign operates in an effective and efficient manner consistent with the overall strategy and focus of the campaign;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17281/d/3","parentIdentifier":"/us/usc/t42/s17281/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fd%2F3","sourceRelease":"119-100","text":"plans to purchase advertising time and space;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17281/d/4","parentIdentifier":"/us/usc/t42/s17281/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fd%2F4","sourceRelease":"119-100","text":"policies and practices implemented to ensure that Federal funds are used responsibly to purchase advertising time and space and eliminate the potential for waste, fraud, and abuse; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s17281/d/5","parentIdentifier":"/us/usc/t42/s17281/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fd%2F5","sourceRelease":"119-100","text":"all contracts or cooperative agreements entered into with a corporation, partnership, or individual working on behalf of the national media campaign.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s17281/e","parentIdentifier":"/us/usc/t42/s17281","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17281/e/1","parentIdentifier":"/us/usc/t42/s17281/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fe%2F1","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2008 through 2012.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Decreased oil consumption","label":"2 Decreased oil consumption","identifier":"/us/usc/t42/s17281/e/2","parentIdentifier":"/us/usc/t42/s17281/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17281%2Fe%2F2","sourceRelease":"119-100","text":"The Secretary shall use not less than 50 percent of the amount that is made available under this section for each fiscal year to develop and conduct a national media campaign to decrease oil consumption in the United States over the next decade.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
