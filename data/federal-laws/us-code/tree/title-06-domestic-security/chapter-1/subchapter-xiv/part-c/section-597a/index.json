{"type":"section","nativeType":"section","number":"597a","heading":"Medical countermeasures","label":"597a Medical countermeasures","identifier":"/us/usc/t6/s597a","parentIdentifier":"/us/usc/t6/ch1/schXIV/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t6/s597a/a","parentIdentifier":"/us/usc/t6/s597a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s597a/a/1","parentIdentifier":"/us/usc/t6/s597a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fa%2F1","sourceRelease":"119-100","text":"facilitate personnel readiness and protection for the employees and working animals of the Department in the event of a chemical, biological, radiological, nuclear, or explosives attack, naturally occurring disease outbreak, other event impacting health, or pandemic; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s597a/a/2","parentIdentifier":"/us/usc/t6/s597a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fa%2F2","sourceRelease":"119-100","text":"support the mission continuity of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Oversight","label":"b Oversight","identifier":"/us/usc/t6/s597a/b","parentIdentifier":"/us/usc/t6/s597a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s597a/b/1","parentIdentifier":"/us/usc/t6/s597a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fb%2F1","sourceRelease":"119-100","text":"provide programmatic oversight of the medical countermeasures program established under subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s597a/b/2","parentIdentifier":"/us/usc/t6/s597a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s597a/b/2/A","parentIdentifier":"/us/usc/t6/s597a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fb%2F2%2FA","sourceRelease":"119-100","text":"medical countermeasure storage, security, dispensing, and documentation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s597a/b/2/B","parentIdentifier":"/us/usc/t6/s597a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fb%2F2%2FB","sourceRelease":"119-100","text":"maintaining a stockpile of medical countermeasures, including antibiotics, antivirals, antidotes, therapeutics, and radiological countermeasures, as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s597a/b/2/C","parentIdentifier":"/us/usc/t6/s597a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fb%2F2%2FC","sourceRelease":"119-100","text":"ensuring adequate partnerships with manufacturers and executive agencies that enable advance prepositioning by vendors of inventories of appropriate medical countermeasures in strategic locations nationwide, based on risk and employee density, in accordance with applicable Federal statutes and regulations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s597a/b/2/D","parentIdentifier":"/us/usc/t6/s597a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fb%2F2%2FD","sourceRelease":"119-100","text":"providing oversight and guidance regarding the dispensing of stockpiled medical countermeasures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t6/s597a/b/2/E","parentIdentifier":"/us/usc/t6/s597a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fb%2F2%2FE","sourceRelease":"119-100","text":"ensuring rapid deployment and dispensing of medical countermeasures in a chemical, biological, radiological, nuclear, or explosives attack, naturally occurring disease outbreak, other event impacting health, or pandemic;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t6/s597a/b/2/F","parentIdentifier":"/us/usc/t6/s597a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fb%2F2%2FF","sourceRelease":"119-100","text":"providing training to employees of the Department on medical countermeasures; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t6/s597a/b/2/G","parentIdentifier":"/us/usc/t6/s597a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fb%2F2%2FG","sourceRelease":"119-100","text":"supporting dispensing exercises.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Medical countermeasures working group","label":"c Medical countermeasures working group","identifier":"/us/usc/t6/s597a/c","parentIdentifier":"/us/usc/t6/s597a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fc","sourceRelease":"119-100","text":"The Secretary, acting through the Chief Medical Officer of the Department, shall establish a medical countermeasures working group comprised of representatives from appropriate components and offices of the Department to ensure that medical countermeasures standards are maintained and guidance is consistent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Medical countermeasures management","label":"d Medical countermeasures management","identifier":"/us/usc/t6/s597a/d","parentIdentifier":"/us/usc/t6/s597a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s597a/d/1","parentIdentifier":"/us/usc/t6/s597a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fd%2F1","sourceRelease":"119-100","text":"a methodology for determining the ideal types and quantities of medical countermeasures to stockpile and how frequently such methodology shall be reevaluated;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s597a/d/2","parentIdentifier":"/us/usc/t6/s597a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fd%2F2","sourceRelease":"119-100","text":"a replenishment plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s597a/d/3","parentIdentifier":"/us/usc/t6/s597a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fd%2F3","sourceRelease":"119-100","text":"inventory tracking, reporting, and reconciliation procedures for existing stockpiles and new medical countermeasure purchases.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Transfer","label":"e Transfer","identifier":"/us/usc/t6/s597a/e","parentIdentifier":"/us/usc/t6/s597a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fe","sourceRelease":"119-100","text":"Not later than 120 days after , the Secretary shall transfer all medical countermeasures-related programmatic and personnel resources from the Under Secretary for Management to the Chief Medical Officer.December 27, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Stockpile elements","label":"f Stockpile elements","identifier":"/us/usc/t6/s597a/f","parentIdentifier":"/us/usc/t6/s597a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s597a/f/1","parentIdentifier":"/us/usc/t6/s597a/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Ff%2F1","sourceRelease":"119-100","text":"shall use a risk-based methodology for evaluating types and quantities of medical countermeasures required; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s597a/f/2","parentIdentifier":"/us/usc/t6/s597a/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s597a/f/2/A","parentIdentifier":"/us/usc/t6/s597a/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Ff%2F2%2FA","sourceRelease":"119-100","text":"chemical, biological, radiological, and nuclear risk assessments of the Department; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s597a/f/2/B","parentIdentifier":"/us/usc/t6/s597a/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Ff%2F2%2FB","sourceRelease":"119-100","text":"guidance on medical countermeasures of the Office of the Assistant Secretary for Preparedness and Response and the Centers for Disease Control and Prevention.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Briefing","label":"g Briefing","identifier":"/us/usc/t6/s597a/g","parentIdentifier":"/us/usc/t6/s597a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s597a/g/1","parentIdentifier":"/us/usc/t6/s597a/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fg%2F1","sourceRelease":"119-100","text":"the plan developed under subsection (d); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s597a/g/2","parentIdentifier":"/us/usc/t6/s597a/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fg%2F2","sourceRelease":"119-100","text":"implementation of the requirements of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Definition","label":"h Definition","identifier":"/us/usc/t6/s597a/h","parentIdentifier":"/us/usc/t6/s597a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs597a%2Fh","sourceRelease":"119-100","text":"In this section, the term “medical countermeasures” means antibiotics, antivirals, antidotes, therapeutics, radiological countermeasures, and other countermeasures that may be deployed to protect the employees and working animals of the Department in the event of a chemical, biological, radiological, nuclear, or explosives attack, naturally occurring disease outbreak, other event impacting health, or pandemic.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
