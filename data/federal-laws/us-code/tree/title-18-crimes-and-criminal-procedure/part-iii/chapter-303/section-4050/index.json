{"type":"section","nativeType":"section","number":"4050","heading":"Secure firearms storage","label":"4050 Secure firearms storage","identifier":"/us/usc/t18/s4050","parentIdentifier":"/us/usc/t18/ptIII/ch303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4050","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Definitions","label":"a .—Definitions","identifier":"/us/usc/t18/s4050/a","parentIdentifier":"/us/usc/t18/s4050","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4050%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s4050/a/1","parentIdentifier":"/us/usc/t18/s4050/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4050%2Fa%2F1","sourceRelease":"119-100","text":"the term “employee” means a qualified law enforcement officer employed by the Bureau of Prisons; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s4050/a/2","parentIdentifier":"/us/usc/t18/s4050/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4050%2Fa%2F2","sourceRelease":"119-100","text":"the terms “firearm” and “qualified law enforcement officer” have the meanings given those terms under section 926B.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Secure Firearms Storage","label":"b .—Secure Firearms Storage","identifier":"/us/usc/t18/s4050/b","parentIdentifier":"/us/usc/t18/s4050","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4050%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s4050/b/1","parentIdentifier":"/us/usc/t18/s4050/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4050%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s4050/b/1/A","parentIdentifier":"/us/usc/t18/s4050/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4050%2Fb%2F1%2FA","sourceRelease":"119-100","text":"provides a secure storage area located outside of the secure perimeter of the institution for employees to store firearms; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s4050/b/1/B","parentIdentifier":"/us/usc/t18/s4050/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4050%2Fb%2F1%2FB","sourceRelease":"119-100","text":"allows employees to store firearms in a vehicle lockbox approved by the Director of the Bureau of Prisons; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s4050/b/2","parentIdentifier":"/us/usc/t18/s4050/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4050%2Fb%2F2","sourceRelease":"119-100","text":"notwithstanding any other provision of law, allows employees to carry concealed firearms on the premises outside of the secure perimeter of the institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
