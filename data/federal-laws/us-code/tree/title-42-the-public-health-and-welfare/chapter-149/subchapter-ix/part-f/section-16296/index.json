{"type":"section","nativeType":"section","number":"16296","heading":"Low-volume oil and gas reservoir research program","label":"16296 Low-volume oil and gas reservoir research program","identifier":"/us/usc/t42/s16296","parentIdentifier":"/us/usc/t42/ch149/schIX/ptF","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definition of GIS","label":"a Definition of GIS","identifier":"/us/usc/t42/s16296/a","parentIdentifier":"/us/usc/t42/s16296","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fa","sourceRelease":"119-100","text":"In this section, the term “GIS” means geographic information systems technology that facilitates the organization and management of data with a geographic component.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Program","label":"b Program","identifier":"/us/usc/t42/s16296/b","parentIdentifier":"/us/usc/t42/s16296","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fb","sourceRelease":"119-100","text":"The Secretary shall establish a program of research, development, demonstration, and commercial application to maximize the productive capacity of marginal wells and reservoirs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Data collection","label":"c Data collection","identifier":"/us/usc/t42/s16296/c","parentIdentifier":"/us/usc/t42/s16296","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16296/c/1","parentIdentifier":"/us/usc/t42/s16296/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fc%2F1","sourceRelease":"119-100","text":"the status and location of marginal wells and oil and gas reservoirs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16296/c/2","parentIdentifier":"/us/usc/t42/s16296/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fc%2F2","sourceRelease":"119-100","text":"the production capacity of marginal wells and oil and gas reservoirs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16296/c/3","parentIdentifier":"/us/usc/t42/s16296/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fc%2F3","sourceRelease":"119-100","text":"the location of low-pressure gathering facilities and pipelines; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16296/c/4","parentIdentifier":"/us/usc/t42/s16296/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fc%2F4","sourceRelease":"119-100","text":"the quantity of natural gas vented or flared in association with crude oil production.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Analysis","label":"d Analysis","identifier":"/us/usc/t42/s16296/d","parentIdentifier":"/us/usc/t42/s16296","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16296/d/1","parentIdentifier":"/us/usc/t42/s16296/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fd%2F1","sourceRelease":"119-100","text":"estimate the remaining producible reserves based on variable pipeline pressures; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16296/d/2","parentIdentifier":"/us/usc/t42/s16296/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fd%2F2","sourceRelease":"119-100","text":"recommend measures that will enable the continued production of those resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Study","label":"e Study","identifier":"/us/usc/t42/s16296/e","parentIdentifier":"/us/usc/t42/s16296","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16296/e/1","parentIdentifier":"/us/usc/t42/s16296/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fe%2F1","sourceRelease":"119-100","text":"The Secretary may award a grant to an organization of States that contain significant numbers of marginal oil and natural gas wells to conduct an annual study of low-volume natural gas reservoirs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Organization with no GIS capabilities","label":"2 Organization with no GIS capabilities","identifier":"/us/usc/t42/s16296/e/2","parentIdentifier":"/us/usc/t42/s16296/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fe%2F2","sourceRelease":"119-100","text":"If an organization receiving a grant under paragraph (1) does not have GIS capabilities, the organization shall contract with an institution of higher education with GIS capabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"State geologists","label":"3 State geologists","identifier":"/us/usc/t42/s16296/e/3","parentIdentifier":"/us/usc/t42/s16296/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Fe%2F3","sourceRelease":"119-100","text":"The organization receiving a grant under paragraph (1) shall collaborate with the State geologist of each State being studied.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Public information","label":"f Public information","identifier":"/us/usc/t42/s16296/f","parentIdentifier":"/us/usc/t42/s16296","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16296%2Ff","sourceRelease":"119-100","text":"The Secretary may use the data collected and analyzed under this section to produce maps and literature to disseminate to States to promote conservation of natural gas reserves.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
