ourceRelease":"119-100","text":"the number and names of cases that have not been terminated within three years after filing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t28/s476/b","parentIdentifier":"/us/usc/t28/s476","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs476%2Fb","sourceRelease":"119-100","text":"To ensure uniformity of reporting, the standards for categorization or characterization of judicial actions to be prescribed in accordance with shall apply to the semiannual report prepared under subsection (a).section 481 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
