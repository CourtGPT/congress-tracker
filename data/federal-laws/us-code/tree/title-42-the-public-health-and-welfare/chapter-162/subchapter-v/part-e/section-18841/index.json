:"/us/usc/t42/s18841/b/2/C","parentIdentifier":"/us/usc/t42/s18841/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18841%2Fb%2F2%2FC","sourceRelease":"119-100","text":"is designed to elicit a comparable number of responses from businesses in each State and with the same North American Industry Classification System codes as were received for the 2016 and 2017 reports entitled “U.S. Energy and Employment Report”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Consultation","label":"3 Consultation","identifier":"/us/usc/t42/s18841/b/3","parentIdentifier":"/us/usc/t42/s18841/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18841%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18841/b/3/A","parentIdentifier":"/us/usc/t42/s18841/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18841%2Fb%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18841/b/3/A/i","parentIdentifier":"/us/usc/t42/s18841/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18841%2Fb%2F3%2FA%2Fi","sourceRelease":"119-100","text":"the Secretary of Commerce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18841/b/3/A/ii","parentIdentifier":"/us/usc/t42/s18841/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18841%2Fb%2F3%2FA%2Fii","sourceRelease":"119-100","text":"the Secretary of Transportation;","notes":[],"amendment