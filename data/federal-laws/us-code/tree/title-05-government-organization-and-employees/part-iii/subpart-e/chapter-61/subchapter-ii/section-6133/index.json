{"type":"section","nativeType":"section","number":"6133","heading":"Regulations; technical assistance; program review","label":"6133 Regulations; technical assistance; program review","identifier":"/us/usc/t5/s6133","parentIdentifier":"/us/usc/t5/ptIII/sptE/ch61/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2009—Subsec. (c)(3). added par. (3).Pub. L. 111–681989—Subsec. (c). designated existing provisions as par. (1) and added par. (2).Pub. L. 101–163","Statutory Notes and Related Subsidiaries","Change of Name“Government Publishing Office” substituted for “Government Printing Office” in subsec. (c)(2) on authority of , set out as a note preceding , Public Printing and Documents.section 1301(b) of Pub. L. 113–235section 301 of Title 44“Director of the Government Publishing Office” substituted for “Public Printer” in subsec. (c)(2) on authority of , set out as a note under , Public Printing and Documents.section 1301(d) of Pub. L. 113–235section 301 of Title 44"],"amendments":["Amendments2009—Subsec. (c)(3). added par. (3).Pub. L. 111–681989—Subsec. (c). designated existing provisions as par. (1) and added par. (2).Pub. L. 101–163"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s6133/a","parentIdentifier":"/us/usc/t5/s6133","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fa","sourceRelease":"119-100","text":"The Office of Personnel Management shall prescribe regulations necessary for the administration of the programs established under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s6133/b","parentIdentifier":"/us/usc/t5/s6133","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6133/b/1","parentIdentifier":"/us/usc/t5/s6133/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fb%2F1","sourceRelease":"119-100","text":"The Office shall provide educational material, and technical aids and assistance, for use by an agency in connection with establishing and maintaining programs under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6133/b/2","parentIdentifier":"/us/usc/t5/s6133/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s6133/b/2/A","parentIdentifier":"/us/usc/t5/s6133/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the efficiency of Government operations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s6133/b/2/B","parentIdentifier":"/us/usc/t5/s6133/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fb%2F2%2FB","sourceRelease":"119-100","text":"mass transit facilities and traffic;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s6133/b/2/C","parentIdentifier":"/us/usc/t5/s6133/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fb%2F2%2FC","sourceRelease":"119-100","text":"levels of energy consumption;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t5/s6133/b/2/D","parentIdentifier":"/us/usc/t5/s6133/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fb%2F2%2FD","sourceRelease":"119-100","text":"service to the public;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t5/s6133/b/2/E","parentIdentifier":"/us/usc/t5/s6133/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fb%2F2%2FE","sourceRelease":"119-100","text":"increased opportunities for full-time and part-time employment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t5/s6133/b/2/F","parentIdentifier":"/us/usc/t5/s6133/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fb%2F2%2FF","sourceRelease":"119-100","text":"employees’ job satisfaction and nonworklife.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t5/s6133/c","parentIdentifier":"/us/usc/t5/s6133","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6133/c/1","parentIdentifier":"/us/usc/t5/s6133/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fc%2F1","sourceRelease":"119-100","text":"With respect to employees in the Library of Congress, the authority granted to the Office of Personnel Management under this subchapter shall be exercised by the Librarian of Congress.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6133/c/2","parentIdentifier":"/us/usc/t5/s6133/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fc%2F2","sourceRelease":"119-100","text":"With respect to employees in the Government Publishing Office, the authority granted to the Office of Personnel Management under this subchapter shall be exercised by the Director of the Government Publishing Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s6133/c/3","parentIdentifier":"/us/usc/t5/s6133/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6133%2Fc%2F3","sourceRelease":"119-100","text":"With respect to employees of the Architect of the Capitol and the Botanic Garden, the authority granted to the Office of Personnel Management under this subchapter shall be exercised by the Architect of the Capitol.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
