{"type":"section","nativeType":"section","number":"11802","heading":"Application for grants and contracts","label":"11802 Application for grants and contracts","identifier":"/us/usc/t42/s11802","parentIdentifier":"/us/usc/t42/ch123/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11802","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Submission of applications","label":"a Submission of applications","identifier":"/us/usc/t42/s11802/a","parentIdentifier":"/us/usc/t42/s11802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11802%2Fa","sourceRelease":"119-100","text":"Any agency, organization, institution, or individual desiring to receive a grant, or to enter into a contract, under shall submit to the Secretary an application at such time, in such manner, and containing or accompanied by such information as the Secretary may require by rule.section 11801 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Contents of application","label":"b Contents of application","identifier":"/us/usc/t42/s11802/b","parentIdentifier":"/us/usc/t42/s11802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11802%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s11802/b/1","parentIdentifier":"/us/usc/t42/s11802/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11802%2Fb%2F1","sourceRelease":"119-100","text":"set forth a project or activity for carrying out one or more of the purposes specified in and specifically identify each such purpose such project or activity is designed to carry out,section 11801 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s11802/b/2","parentIdentifier":"/us/usc/t42/s11802/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11802%2Fb%2F2","sourceRelease":"119-100","text":"provide that such project or activity shall be administered by or under the supervision of the applicant,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s11802/b/3","parentIdentifier":"/us/usc/t42/s11802/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11802%2Fb%2F3","sourceRelease":"119-100","text":"provide for the proper and efficient administration of such project or activity,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s11802/b/4","parentIdentifier":"/us/usc/t42/s11802/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11802%2Fb%2F4","sourceRelease":"119-100","text":"provide for regular evaluation of the operation of such project or activity,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s11802/b/5","parentIdentifier":"/us/usc/t42/s11802/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11802%2Fb%2F5","sourceRelease":"119-100","text":"provide that regular reports on such project or activity shall be submitted to the Secretary, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s11802/b/6","parentIdentifier":"/us/usc/t42/s11802/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11802%2Fb%2F6","sourceRelease":"119-100","text":"provide such fiscal control and fund accounting procedures as may be necessary to ensure prudent use, proper disbursement, and accurate accounting of funds received under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
