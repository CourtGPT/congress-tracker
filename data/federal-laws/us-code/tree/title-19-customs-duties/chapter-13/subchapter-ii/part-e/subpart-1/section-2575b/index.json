{"type":"section","nativeType":"section","number":"2575b","heading":"Subpart definitions","label":"2575b Subpart definitions","identifier":"/us/usc/t19/s2575b","parentIdentifier":"/us/usc/t19/ch13/schII/ptE/spt1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Animal","label":"1 Animal","identifier":"/us/usc/t19/s2575b/1","parentIdentifier":"/us/usc/t19/s2575b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F1","sourceRelease":"119-100","text":"The term “animal” includes fish, bees, and wild fauna.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Approval procedure","label":"2 Approval procedure","identifier":"/us/usc/t19/s2575b/2","parentIdentifier":"/us/usc/t19/s2575b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s2575b/2/A","parentIdentifier":"/us/usc/t19/s2575b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F2%2FA","sourceRelease":"119-100","text":"approving the use of an additive for a stated purpose or under stated conditions, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s2575b/2/B","parentIdentifier":"/us/usc/t19/s2575b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F2%2FB","sourceRelease":"119-100","text":"establishing a tolerance for a stated purpose or under stated conditions for a contaminant,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Contaminant","label":"3 Contaminant","identifier":"/us/usc/t19/s2575b/3","parentIdentifier":"/us/usc/t19/s2575b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F3","sourceRelease":"119-100","text":"The term “contaminant” includes pesticide and veterinary drug residues and extraneous matter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Control or inspection procedure","label":"4 Control or inspection procedure","identifier":"/us/usc/t19/s2575b/4","parentIdentifier":"/us/usc/t19/s2575b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F4","sourceRelease":"119-100","text":"The term “control or inspection procedure” means any procedure used, directly or indirectly, to determine that a sanitary or phytosanitary measure is fulfilled, including sampling, testing, inspection, evaluation, verification, monitoring, auditing, assurance of conformity, accreditation, registration, certification, or other procedure involving the physical examination of a good, of the packaging of a good, or of the equipment or facilities directly related to production, marketing, or use of a good, but does not mean an approval procedure.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Plant","label":"5 Plant","identifier":"/us/usc/t19/s2575b/5","parentIdentifier":"/us/usc/t19/s2575b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F5","sourceRelease":"119-100","text":"The term “plant” includes wild flora.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Risk assessment","label":"6 Risk assessment","identifier":"/us/usc/t19/s2575b/6","parentIdentifier":"/us/usc/t19/s2575b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s2575b/6/A","parentIdentifier":"/us/usc/t19/s2575b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F6%2FA","sourceRelease":"119-100","text":"the potential for the introduction, establishment or spread of a pest or disease and associated biological and economic consequences; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s2575b/6/B","parentIdentifier":"/us/usc/t19/s2575b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F6%2FB","sourceRelease":"119-100","text":"the potential for adverse effects on human or animal life or health arising from the presence of an additive, contaminant, toxin or disease-causing organism in a food, beverage, or feedstuff.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Sanitary or phytosanitary measure","label":"7 Sanitary or phytosanitary measure","identifier":"/us/usc/t19/s2575b/7","parentIdentifier":"/us/usc/t19/s2575b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t19/s2575b/7/A","parentIdentifier":"/us/usc/t19/s2575b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s2575b/7/A/i","parentIdentifier":"/us/usc/t19/s2575b/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FA%2Fi","sourceRelease":"119-100","text":"protect animal or plant life or health in the United States from risks arising from the introduction, establishment, or spread of a pest or disease;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s2575b/7/A/ii","parentIdentifier":"/us/usc/t19/s2575b/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FA%2Fii","sourceRelease":"119-100","text":"protect human or animal life or health in the United States from risks arising from the presence of an additive, contaminant, toxin, or disease-causing organism in a food, beverage, or feedstuff;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t19/s2575b/7/A/iii","parentIdentifier":"/us/usc/t19/s2575b/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FA%2Fiii","sourceRelease":"119-100","text":"protect human life or health in the United States from risks arising from a disease-causing organism or pest carried by an animal or plant, or a product thereof; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t19/s2575b/7/A/iv","parentIdentifier":"/us/usc/t19/s2575b/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FA%2Fiv","sourceRelease":"119-100","text":"prevent or limit other damage in the United States arising from the introduction, establishment, or spread of a pest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Form","label":"B Form","identifier":"/us/usc/t19/s2575b/7/B","parentIdentifier":"/us/usc/t19/s2575b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s2575b/7/B/i","parentIdentifier":"/us/usc/t19/s2575b/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FB%2Fi","sourceRelease":"119-100","text":"end product criteria;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s2575b/7/B/ii","parentIdentifier":"/us/usc/t19/s2575b/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FB%2Fii","sourceRelease":"119-100","text":"a product-related processing or production method;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t19/s2575b/7/B/iii","parentIdentifier":"/us/usc/t19/s2575b/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FB%2Fiii","sourceRelease":"119-100","text":"a testing, inspection, certification, or approval procedure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t19/s2575b/7/B/iv","parentIdentifier":"/us/usc/t19/s2575b/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FB%2Fiv","sourceRelease":"119-100","text":"a relevant statistical method;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t19/s2575b/7/B/v","parentIdentifier":"/us/usc/t19/s2575b/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FB%2Fv","sourceRelease":"119-100","text":"a sampling procedure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t19/s2575b/7/B/vi","parentIdentifier":"/us/usc/t19/s2575b/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FB%2Fvi","sourceRelease":"119-100","text":"a method of risk assessment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t19/s2575b/7/B/vii","parentIdentifier":"/us/usc/t19/s2575b/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FB%2Fvii","sourceRelease":"119-100","text":"a packaging and labeling requirement directly related to food safety; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t19/s2575b/7/B/viii","parentIdentifier":"/us/usc/t19/s2575b/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575b%2F7%2FB%2Fviii","sourceRelease":"119-100","text":"a quarantine treatment, such as a relevant requirement associated with the transportation of animals or plants or with material necessary for their survival during transportation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
