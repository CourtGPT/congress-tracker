{"type":"section","nativeType":"section","number":"2445","heading":"Limitation on bonuses for employees who engage in improper program management","label":"2445 Limitation on bonuses for employees who engage in improper program management","identifier":"/us/usc/t50/s2445","parentIdentifier":"/us/usc/t50/ch41/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Limitation","label":"a Limitation","identifier":"/us/usc/t50/s2445/a","parentIdentifier":"/us/usc/t50/s2445","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t50/s2445/a/1","parentIdentifier":"/us/usc/t50/s2445/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary of Energy or the Administrator may not pay to a covered employee a bonus during the one-year period beginning on the date on which the Secretary or the Administrator, as the case may be, determines that the covered employee engaged in improper program management that resulted in a notification under or significantly and detrimentally affected the cost, scope, or schedule associated with the approval of critical decision 3 in the acquisition process for a project (as defined in Department of Energy Order 413.3B (relating to program management and project management for the acquisition of capital assets)).section 2753 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Implementation guidance","label":"2 Implementation guidance","identifier":"/us/usc/t50/s2445/a/2","parentIdentifier":"/us/usc/t50/s2445/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fa%2F2","sourceRelease":"119-100","text":"Not later than one year after , the Secretary shall issue guidance for the implementation of paragraph (1).November 25, 2015","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Guidance prohibiting bonuses for additional employees","label":"b Guidance prohibiting bonuses for additional employees","identifier":"/us/usc/t50/s2445/b","parentIdentifier":"/us/usc/t50/s2445","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2445/b/1","parentIdentifier":"/us/usc/t50/s2445/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fb%2F1","sourceRelease":"119-100","text":"that jeopardized the health, safety, or security of employees or facilities of the Administration or another element of the Department of Energy involved in nuclear security; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2445/b/2","parentIdentifier":"/us/usc/t50/s2445/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fb%2F2","sourceRelease":"119-100","text":"in carrying out defense nuclear nonproliferation activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Waiver","label":"c Waiver","identifier":"/us/usc/t50/s2445/c","parentIdentifier":"/us/usc/t50/s2445","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2445/c/1","parentIdentifier":"/us/usc/t50/s2445/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fc%2F1","sourceRelease":"119-100","text":"the Secretary or the Administrator, as the case may be, notifies the appropriate congressional committees of such waiver; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2445/c/2","parentIdentifier":"/us/usc/t50/s2445/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fc%2F2","sourceRelease":"119-100","text":"a period of 60 days elapses following such notification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definitions","label":"d Definitions","identifier":"/us/usc/t50/s2445/d","parentIdentifier":"/us/usc/t50/s2445","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2445/d/1","parentIdentifier":"/us/usc/t50/s2445/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s2445/d/1/A","parentIdentifier":"/us/usc/t50/s2445/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the congressional defense committees; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s2445/d/1/B","parentIdentifier":"/us/usc/t50/s2445/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fd%2F1%2FB","sourceRelease":"119-100","text":"the Committee on Energy and Commerce of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2445/d/2","parentIdentifier":"/us/usc/t50/s2445/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fd%2F2","sourceRelease":"119-100","text":"The term “bonus” means a bonus or award paid under title 5, including under chapters 45 or 53 of such title, or any other provision of law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s2445/d/3","parentIdentifier":"/us/usc/t50/s2445/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2445%2Fd%2F3","sourceRelease":"119-100","text":"The term “covered employee” has the meaning given that term in .section 2443 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
