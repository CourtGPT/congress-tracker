 the World Customs Organization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s4314/c/2/B","parentIdentifier":"/us/usc/t19/s4314/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fc%2F2%2FB","sourceRelease":"119-100","text":"interested parties in the private sector.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Form of plan","label":"d Form of plan","identifier":"/us/usc/t19/s4314/d","parentIdentifier":"/us/usc/t19/s4314","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fd","sourceRelease":"119-100","text":"The joint strategic plan required under this section shall be submitted in unclassified form, but may include a classified annex.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
