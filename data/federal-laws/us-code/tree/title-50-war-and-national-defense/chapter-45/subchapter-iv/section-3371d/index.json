{"type":"section","nativeType":"section","number":"3371d","heading":"Designation of counterintelligence officer to lead election security matters","label":"3371d Designation of counterintelligence officer to lead election security matters","identifier":"/us/usc/t50/s3371d","parentIdentifier":"/us/usc/t50/ch45/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3371d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t50/s3371d/a","parentIdentifier":"/us/usc/t50/s3371d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3371d%2Fa","sourceRelease":"119-100","text":"The Director of National Intelligence shall designate a national counterintelligence officer within the National Counterintelligence and Security Center to lead, manage, and coordinate counterintelligence matters relating to election security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Additional responsibilities","label":"b Additional responsibilities","identifier":"/us/usc/t50/s3371d/b","parentIdentifier":"/us/usc/t50/s3371d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3371d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3371d/b/1","parentIdentifier":"/us/usc/t50/s3371d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3371d%2Fb%2F1","sourceRelease":"119-100","text":"The Federal Government election security supply chain.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","id