{"type":"section","nativeType":"section","number":"78d–3","heading":"Appearance and practice before the Commission","label":"78d–3 Appearance and practice before the Commission","identifier":"/us/usc/t15/s78d–3","parentIdentifier":"/us/usc/t15/ch2B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78d%E2%80%933","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authority to censure","label":"a Authority to censure","identifier":"/us/usc/t15/s78d–3/a","parentIdentifier":"/us/usc/t15/s78d–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78d%E2%80%933%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s78d–3/a/1","parentIdentifier":"/us/usc/t15/s78d–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78d%E2%80%933%2Fa%2F1","sourceRelease":"119-100","text":"not to possess the requisite qualifications to represent others;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s78d–3/a/2","parentIdentifier":"/us/usc/t15/s78d–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78d%E2%80%933%2Fa%2F2","sourceRelease":"119-100","text":"to be lacking in character or integrity, or to have engaged in unethical or improper professional conduct; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s78d–3/a/3","parentIdentifier":"/us/usc/t15/s78d–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78d%E2%80%933%2Fa%2F3","sourceRelease":"119-100","text":"to have willfully violated, or willfully aided and abetted the violation of, any provision of the securities laws or the rules and regulations issued thereunder.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Definition","label":"b Definition","identifier":"/us/usc/t15/s78d–3/b","parentIdentifier":"/us/usc/t15/s78d–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78d%E2%80%933%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s78d–3/b/1","parentIdentifier":"/us/usc/t15/s78d–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78d%E2%80%933%2Fb%2F1","sourceRelease":"119-100","text":"intentional or knowing conduct, including reckless conduct, that results in a violation of applicable professional standards; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s78d–3/b/2","parentIdentifier":"/us/usc/t15/s78d–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78d%E2%80%933%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s78d–3/b/2/A","parentIdentifier":"/us/usc/t15/s78d–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78d%E2%80%933%2Fb%2F2%2FA","sourceRelease":"119-100","text":"a single instance of highly unreasonable conduct that results in a violation of applicable professional standards in circumstances in which the registered public accounting firm or associated person knows, or should know, that heightened scrutiny is warranted; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s78d–3/b/2/B","parentIdentifier":"/us/usc/t15/s78d–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78d%E2%80%933%2Fb%2F2%2FB","sourceRelease":"119-100","text":"repeated instances of unreasonable conduct, each resulting in a violation of applicable professional standards, that indicate a lack of competence to practice before the Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
