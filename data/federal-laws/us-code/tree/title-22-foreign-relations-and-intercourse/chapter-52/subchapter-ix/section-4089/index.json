{"type":"section","nativeType":"section","number":"4089","heading":"Portability of professional licenses","label":"4089 Portability of professional licenses","identifier":"/us/usc/t22/s4089","parentIdentifier":"/us/usc/t22/ch52/schIX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4089","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s4089/a","parentIdentifier":"/us/usc/t22/s4089","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4089%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4089/a/1","parentIdentifier":"/us/usc/t22/s4089/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4089%2Fa%2F1","sourceRelease":"119-100","text":"provides a copy of the member’s notification of assignment to the licensing authority in the jurisdiction in which the new residency is located;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4089/a/2","parentIdentifier":"/us/usc/t22/s4089/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4089%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s4089/a/2/A","parentIdentifier":"/us/usc/t22/s4089/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4089%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the licensing authority that issued the covered license; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s4089/a/2/B","parentIdentifier":"/us/usc/t22/s4089/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4089%2Fa%2F2%2FB","sourceRelease":"119-100","text":"every other licensing authority that has issued to the member of the Foreign Service or spouse a license valid at a similar scope of practice and in the discipline applied in the jurisdiction of such licensing authority; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s4089/a/3","parentIdentifier":"/us/usc/t22/s4089/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4089%2Fa%2F3","sourceRelease":"119-100","text":"submits to the authority of the licensing authority in the new jurisdiction for the purposes of standards of practice, discipline, and fulfillment of any continuing education requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Interstate licensure compacts","label":"b Interstate licensure compacts","identifier":"/us/usc/t22/s4089/b","parentIdentifier":"/us/usc/t22/s4089","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4089%2Fb","sourceRelease":"119-100","text":"If a member of the Foreign Service or spouse of a member of the Foreign Service is licensed and able to operate in multiple jurisdictions through an interstate licensure compact, with respect to services provided in the jurisdiction of the interstate licensure compact by a licensee covered by such compact, the member of the Foreign Service or spouse of a member of the Foreign Service shall be subject to the requirements of the compact or the applicable provisions of law of the applicable State and not this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Covered license defined","label":"c Covered license defined","identifier":"/us/usc/t22/s4089/c","parentIdentifier":"/us/usc/t22/s4089","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4089%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4089/c/1","parentIdentifier":"/us/usc/t22/s4089/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4089%2Fc%2F1","sourceRelease":"119-100","text":"that is in good standing with the licensing authority that issued such professional license or certificate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4089/c/2","parentIdentifier":"/us/usc/t22/s4089/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4089%2Fc%2F2","sourceRelease":"119-100","text":"that the member of the Foreign Service or spouse of a member of the Foreign Service has actively used during the two years immediately preceding the relocation described in subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s4089/c/3","parentIdentifier":"/us/usc/t22/s4089/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4089%2Fc%2F3","sourceRelease":"119-100","text":"that is not a license to practice law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
