{"type":"section","nativeType":"section","number":"7244","heading":"Uses of funds","label":"7244 Uses of funds","identifier":"/us/usc/t20/s7244","parentIdentifier":"/us/usc/t20/ch70/schIV/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , except with respect to certain noncompetitive programs and competitive programs, see , set out as an Effective Date of 2015 Amendment note under .Dec. 10, 2015section 5 of Pub. L. 114–95section 6301 of this title"],"amendments":["Effective DateSection effective , except with respect to certain noncompetitive programs and competitive programs, see , set out as an Effective Date of 2015 Amendment note under .Dec. 10, 2015section 5 of Pub. L. 114–95section 6301 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t20/s7244/a","parentIdentifier":"/us/usc/t20/s7244","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s7244/a/1","parentIdentifier":"/us/usc/t20/s7244/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s7244/a/1/A","parentIdentifier":"/us/usc/t20/s7244/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fa%2F1%2FA","sourceRelease":"119-100","text":"to engage in activities that will improve student academic achievement, including understanding how parents can support learning in the classroom with activities at home and in after school and extracurricular programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s7244/a/1/B","parentIdentifier":"/us/usc/t20/s7244/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fa%2F1%2FB","sourceRelease":"119-100","text":"to communicate effectively with their children, teachers, school leaders, counselors, administrators, and other school personnel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s7244/a/1/C","parentIdentifier":"/us/usc/t20/s7244/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fa%2F1%2FC","sourceRelease":"119-100","text":"to become active participants in the development, implementation, and review of school-parent compacts, family engagement in education policies, and school planning and improvement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s7244/a/1/D","parentIdentifier":"/us/usc/t20/s7244/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fa%2F1%2FD","sourceRelease":"119-100","text":"to participate in the design and provision of assistance to students who are not making academic progress;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s7244/a/1/E","parentIdentifier":"/us/usc/t20/s7244/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fa%2F1%2FE","sourceRelease":"119-100","text":"to participate in State and local decisionmaking;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t20/s7244/a/1/F","parentIdentifier":"/us/usc/t20/s7244/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fa%2F1%2FF","sourceRelease":"119-100","text":"to train other parents; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t20/s7244/a/1/G","parentIdentifier":"/us/usc/t20/s7244/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fa%2F1%2FG","sourceRelease":"119-100","text":"in learning and using technology applied in their children’s education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s7244/a/2","parentIdentifier":"/us/usc/t20/s7244/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fa%2F2","sourceRelease":"119-100","text":"to develop and implement, in partnership with the State educational agency, statewide family engagement in education policy and systemic initiatives that will provide for a continuum of services to remove barriers for family engagement in education and support school reform efforts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s7244/a/3","parentIdentifier":"/us/usc/t20/s7244/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fa%2F3","sourceRelease":"119-100","text":"to develop and implement parental involvement policies under this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Rule of construction","label":"b Rule of construction","identifier":"/us/usc/t20/s7244/b","parentIdentifier":"/us/usc/t20/s7244","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s7244/b/1","parentIdentifier":"/us/usc/t20/s7244/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fb%2F1","sourceRelease":"119-100","text":"having its employees or agents meet with a parent at a site that is not on school grounds; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s7244/b/2","parentIdentifier":"/us/usc/t20/s7244/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fb%2F2","sourceRelease":"119-100","text":"working with another agency that serves children.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Parental rights","label":"c Parental rights","identifier":"/us/usc/t20/s7244/c","parentIdentifier":"/us/usc/t20/s7244","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s7244/c/1","parentIdentifier":"/us/usc/t20/s7244/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fc%2F1","sourceRelease":"119-100","text":"no person (including a parent who educates a child at home, a public school parent, or a private school parent) shall be required to participate in any program of parent education or developmental screening under this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s7244/c/2","parentIdentifier":"/us/usc/t20/s7244/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7244%2Fc%2F2","sourceRelease":"119-100","text":"no program or center assisted under this section shall take any action that infringes in any manner on the right of parents to direct the education of their children.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
