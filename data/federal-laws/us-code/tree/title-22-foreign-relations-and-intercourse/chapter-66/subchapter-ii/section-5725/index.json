{"type":"section","nativeType":"section","number":"5725","heading":"Secretary of State report regarding the autonomy of Hong Kong","label":"5725 Secretary of State report regarding the autonomy of Hong Kong","identifier":"/us/usc/t22/s5725","parentIdentifier":"/us/usc/t22/ch66/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Certification","label":"a Certification","identifier":"/us/usc/t22/s5725/a","parentIdentifier":"/us/usc/t22/s5725","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s5725/a/1","parentIdentifier":"/us/usc/t22/s5725/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s5725/a/1/A","parentIdentifier":"/us/usc/t22/s5725/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FA","sourceRelease":"119-100","text":"indicates whether Hong Kong continues to warrant treatment under United States law in the same manner as United States laws were applied to Hong Kong before ;July 1, 1997","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s5725/a/1/B","parentIdentifier":"/us/usc/t22/s5725/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s5725/a/1/B/i","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"commercial agreements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s5725/a/1/B/ii","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"law enforcement cooperation, including extradition requests;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t22/s5725/a/1/B/iii","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"sanctions enforcement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t22/s5725/a/1/B/iv","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"export controls, and any other agreements and forms of exchange involving dual use, critical, or other sensitive technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t22/s5725/a/1/B/v","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fv","sourceRelease":"119-100","text":"any formal treaties or agreements between the United States and Hong Kong;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t22/s5725/a/1/B/vi","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fvi","sourceRelease":"119-100","text":"other areas of bilateral cooperation that the Secretary determines to be relevant; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t22/s5725/a/1/B/vii","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fvii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t22/s5725/a/1/B/vii/I","parentIdentifier":"/us/usc/t22/s5725/a/1/B/vii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fvii%2FI","sourceRelease":"119-100","text":"freedom of assembly;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t22/s5725/a/1/B/vii/II","parentIdentifier":"/us/usc/t22/s5725/a/1/B/vii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fvii%2FII","sourceRelease":"119-100","text":"freedom of speech;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t22/s5725/a/1/B/vii/III","parentIdentifier":"/us/usc/t22/s5725/a/1/B/vii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fvii%2FIII","sourceRelease":"119-100","text":"freedom of expression; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t22/s5725/a/1/B/vii/IV","parentIdentifier":"/us/usc/t22/s5725/a/1/B/vii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fvii%2FIV","sourceRelease":"119-100","text":"freedom of the press, including the Internet and social media;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t22/s5725/a/1/B/viii","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fviii","sourceRelease":"119-100","text":"universal suffrage, including the ultimate aim of the selection of the Chief Executive and all members of the Legislative Council by universal suffrage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ix","heading":null,"label":"ix","identifier":"/us/usc/t22/s5725/a/1/B/ix","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fix","sourceRelease":"119-100","text":"judicial independence;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"x","heading":null,"label":"x","identifier":"/us/usc/t22/s5725/a/1/B/x","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fx","sourceRelease":"119-100","text":"police and security functions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xi","heading":null,"label":"xi","identifier":"/us/usc/t22/s5725/a/1/B/xi","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fxi","sourceRelease":"119-100","text":"education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xii","heading":null,"label":"xii","identifier":"/us/usc/t22/s5725/a/1/B/xii","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fxii","sourceRelease":"119-100","text":"laws or regulations regarding treason, secession, sedition, subversion against the Central People’s Government of the People’s Republic of China, or theft of state secrets;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xiii","heading":null,"label":"xiii","identifier":"/us/usc/t22/s5725/a/1/B/xiii","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fxiii","sourceRelease":"119-100","text":"laws or regulations regarding foreign political organizations or bodies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xiv","heading":null,"label":"xiv","identifier":"/us/usc/t22/s5725/a/1/B/xiv","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fxiv","sourceRelease":"119-100","text":"laws or regulations regarding political organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xv","heading":null,"label":"xv","identifier":"/us/usc/t22/s5725/a/1/B/xv","parentIdentifier":"/us/usc/t22/s5725/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FB%2Fxv","sourceRelease":"119-100","text":"other rights enumerated in the Universal Declaration of Human Rights, done at Paris , and the International Covenant on Civil and Political Rights, done at New York ; andDecember 10, 1948December 19, 1966","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s5725/a/1/C","parentIdentifier":"/us/usc/t22/s5725/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s5725/a/1/C/i","parentIdentifier":"/us/usc/t22/s5725/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FC%2Fi","sourceRelease":"119-100","text":"an assessment of the degree of any erosions to Hong Kong’s autonomy in each category listed in subparagraph (B) resulting from actions by the Government of the People’s Republic of China that are inconsistent with its commitments under the Basic Law or the Joint Declaration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s5725/a/1/C/ii","parentIdentifier":"/us/usc/t22/s5725/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FC%2Fii","sourceRelease":"119-100","text":"an evaluation of the specific impacts to any areas of cooperation between the United States and Hong Kong resulting from erosions of autonomy in Hong Kong or failures of the Government of Hong Kong to fulfill obligations to the United States under international agreements within the categories listed in subparagraph (B); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t22/s5725/a/1/C/iii","parentIdentifier":"/us/usc/t22/s5725/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"a list of any specific actions taken by the United States Government in response to any erosion of autonomy or failures to fulfill obligations to the United States under international agreements identified in this certification and the report required under .section 5731 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Factor for consideration","label":"2 Factor for consideration","identifier":"/us/usc/t22/s5725/a/2","parentIdentifier":"/us/usc/t22/s5725/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F2","sourceRelease":"119-100","text":"In making each certification under paragraph (1), the Secretary of State should consider the terms, obligations, and expectations expressed in the Joint Declaration with respect to Hong Kong.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Additional certifications","label":"3 Additional certifications","identifier":"/us/usc/t22/s5725/a/3","parentIdentifier":"/us/usc/t22/s5725/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fa%2F3","sourceRelease":"119-100","text":"The certification under section (1) shall be issued annually, but the Secretary may issue additional certifications at any time if the Secretary determines it is warranted by circumstances in Hong Kong.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Waiver authority","label":"b Waiver authority","identifier":"/us/usc/t22/s5725/b","parentIdentifier":"/us/usc/t22/s5725","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s5725/b/1","parentIdentifier":"/us/usc/t22/s5725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s5725/b/1/A","parentIdentifier":"/us/usc/t22/s5725/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the Secretary determines that such a waiver is in the national security interests of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s5725/b/1/B","parentIdentifier":"/us/usc/t22/s5725/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fb%2F1%2FB","sourceRelease":"119-100","text":"on or before the date on which the waiver takes effect, the Secretary notifies the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives of the intent to waive such subsection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Partial waiver","label":"2 Partial waiver","identifier":"/us/usc/t22/s5725/b/2","parentIdentifier":"/us/usc/t22/s5725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5725%2Fb%2F2","sourceRelease":"119-100","text":"Except for the list of actions described in subsection (a)(1)(C)(iii), the Secretary of State may waive relevant parts of the application of subsection (a) if the President issues an Executive order under that suspends the application of any particular United States law to Hong Kong.section 5722 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
