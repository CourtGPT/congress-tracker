{"type":"section","nativeType":"section","number":"4351","heading":"Purposes","label":"4351 Purposes","identifier":"/us/usc/t25/s4351","parentIdentifier":"/us/usc/t25/ch44A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4351","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Short Title, , , provided that:Pub. L. 114–221, § 1130 Stat. 847Sept. 23, 2016“This Act [enacting this chapter] may be cited as the ‘Native American Tourism and Improving Visitor Experience Act’ or the ‘NATIVE Act’.”"],"amendments":["Short Title, , , provided that:Pub. L. 114–221, § 1130 Stat. 847Sept. 23, 2016“This Act [enacting this chapter] may be cited as the ‘Native American Tourism and Improving Visitor Experience Act’ or the ‘NATIVE Act’.”"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4351/1","parentIdentifier":"/us/usc/t25/s4351","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4351%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s4351/1/A","parentIdentifier":"/us/usc/t25/s4351/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4351%2F1%2FA","sourceRelease":"119-100","text":"to empower Native American communities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s4351/1/B","parentIdentifier":"/us/usc/t25/s4351/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4351%2F1%2FB","sourceRelease":"119-100","text":"to advance the National Travel and Tourism Strategy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4351/2","parentIdentifier":"/us/usc/t25/s4351","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4351%2F2","sourceRelease":"119-100","text":"to increase coordination and collaboration between Federal tourism assets to support Native American tourism and bolster recreational travel and tourism;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s4351/3","parentIdentifier":"/us/usc/t25/s4351","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4351%2F3","sourceRelease":"119-100","text":"to expand heritage and cultural tourism opportunities in the United States to spur economic development, create jobs, and increase tourism revenues;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s4351/4","parentIdentifier":"/us/usc/t25/s4351","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4351%2F4","sourceRelease":"119-100","text":"to enhance and improve self-determination and self-governance capabilities in the Native American community and to promote greater self-sufficiency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s4351/5","parentIdentifier":"/us/usc/t25/s4351","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4351%2F5","sourceRelease":"119-100","text":"to encourage Indian tribes, tribal organizations, and Native Hawaiian organizations to engage more fully in Native American tourism activities to increase visitation to rural and remote areas in the United States that are too difficult to access or are unknown to domestic travelers and international tourists;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t25/s4351/6","parentIdentifier":"/us/usc/t25/s4351","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4351%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s4351/6/A","parentIdentifier":"/us/usc/t25/s4351/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4351%2F6%2FA","sourceRelease":"119-100","text":"spur important infrastructure development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s4351/6/B","parentIdentifier":"/us/usc/t25/s4351/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4351%2F6%2FB","sourceRelease":"119-100","text":"increase tourism capacity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s4351/6/C","parentIdentifier":"/us/usc/t25/s4351/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4351%2F6%2FC","sourceRelease":"119-100","text":"elevate living standards in Native American communities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t25/s4351/7","parentIdentifier":"/us/usc/t25/s4351","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4351%2F7","sourceRelease":"119-100","text":"to support the development of technologically innovative projects that will incorporate recreational travel and tourism information and data from Federal assets to improve the visitor experience.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
