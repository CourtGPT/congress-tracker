{"type":"section","nativeType":"section","number":"15824","heading":"State Technologies Advancement Collaborative","label":"15824 State Technologies Advancement Collaborative","identifier":"/us/usc/t42/s15824","parentIdentifier":"/us/usc/t42/ch149/schI/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15824","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s15824/a","parentIdentifier":"/us/usc/t42/s15824","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15824%2Fa","sourceRelease":"119-100","text":"The Secretary, in cooperation with the States, shall establish a cooperative program for research, development, demonstration, and deployment of technologies in which there is a common Federal and State energy efficiency, renewable energy, and fossil energy interest, to be known as the “State Technologies Advancement Collaborative” (referred to in this section as the “Collaborative”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties","label":"b Duties","identifier":"/us/usc/t42/s15824/b","parentIdentifier":"/us/usc/t42/s15824","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15824%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15824/b/1","parentIdentifier":"/us/usc/t42/s15824/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15824%2Fb%2F1","sourceRelease":"119-100","text":"leverage Federal and State funding through cost-shared activity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15824/b/2","parentIdentifier":"/us/usc/t42/s15824/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15824%2Fb%2F2","sourceRelease":"119-100","text":"reduce redundancies in Federal and State funding; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s15824/b/3","parentIdentifier":"/us/usc/t42/s15824/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15824%2Fb%2F3","sourceRelease":"119-100","text":"create multistate projects to be awarded through a competitive process.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Administration","label":"c Administration","identifier":"/us/usc/t42/s15824/c","parentIdentifier":"/us/usc/t42/s15824","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15824%2Fc","sourceRelease":"119-100","text":"The Collaborative shall be administered through an agreement between the Department and appropriate State-based organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Funding sources","label":"d Funding sources","identifier":"/us/usc/t42/s15824/d","parentIdentifier":"/us/usc/t42/s15824","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15824%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15824/d/1","parentIdentifier":"/us/usc/t42/s15824/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15824%2Fd%2F1","sourceRelease":"119-100","text":"amounts specifically appropriated for the Collaborative; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15824/d/2","parentIdentifier":"/us/usc/t42/s15824/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15824%2Fd%2F2","sourceRelease":"119-100","text":"amounts that may be allocated from other appropriations without changing the purpose for which the amounts are appropriated.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s15824/e","parentIdentifier":"/us/usc/t42/s15824","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15824%2Fe","sourceRelease":"119-100","text":"There are authorized to carry out this section such sums as are necessary for each of fiscal years 2006 through 2010.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
