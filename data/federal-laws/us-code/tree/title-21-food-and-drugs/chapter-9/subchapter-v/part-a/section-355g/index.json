{"type":"section","nativeType":"section","number":"355g","heading":"Utilizing real world evidence","label":"355g Utilizing real world evidence","identifier":"/us/usc/t21/s355g","parentIdentifier":"/us/usc/t21/ch9/schV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2017—Subsec. (b). , substituted “traditional” for “randomized”.Pub. L. 115–52, § 901(c)Subsec. (d). , substituted “3 years” for “2 years”.Pub. L. 115–52, § 901(d)"],"amendments":["Amendments2017—Subsec. (b). , substituted “traditional” for “randomized”.Pub. L. 115–52, § 901(c)Subsec. (d). , substituted “3 years” for “2 years”.Pub. L. 115–52, § 901(d)"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t21/s355g/a","parentIdentifier":"/us/usc/t21/s355g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s355g/a/1","parentIdentifier":"/us/usc/t21/s355g/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fa%2F1","sourceRelease":"119-100","text":"to help to support the approval of a new indication for a drug approved under ; andsection 355(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s355g/a/2","parentIdentifier":"/us/usc/t21/s355g/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fa%2F2","sourceRelease":"119-100","text":"to help to support or satisfy postapproval study requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Real world evidence defined","label":"b Real world evidence defined","identifier":"/us/usc/t21/s355g/b","parentIdentifier":"/us/usc/t21/s355g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fb","sourceRelease":"119-100","text":"In this section, the term “real world evidence” means data regarding the usage, or the potential benefits or risks, of a drug derived from sources other than traditional clinical trials.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Program framework","label":"c Program framework","identifier":"/us/usc/t21/s355g/c","parentIdentifier":"/us/usc/t21/s355g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t21/s355g/c/1","parentIdentifier":"/us/usc/t21/s355g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fc%2F1","sourceRelease":"119-100","text":"Not later than 2 years after , the Secretary shall establish a draft framework for implementation of the program under this section.December 13, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents of framework","label":"2 Contents of framework","identifier":"/us/usc/t21/s355g/c/2","parentIdentifier":"/us/usc/t21/s355g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s355g/c/2/A","parentIdentifier":"/us/usc/t21/s355g/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the sources of real world evidence, including ongoing safety surveillance, observational studies, registries, claims, and patient-centered outcomes research activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s355g/c/2/B","parentIdentifier":"/us/usc/t21/s355g/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the gaps in data collection activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t21/s355g/c/2/C","parentIdentifier":"/us/usc/t21/s355g/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fc%2F2%2FC","sourceRelease":"119-100","text":"the standards and methodologies for collection and analysis of real world evidence; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t21/s355g/c/2/D","parentIdentifier":"/us/usc/t21/s355g/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fc%2F2%2FD","sourceRelease":"119-100","text":"the priority areas, remaining challenges, and potential pilot opportunities that the program established under this section will address.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Consultation","label":"3 Consultation","identifier":"/us/usc/t21/s355g/c/3","parentIdentifier":"/us/usc/t21/s355g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t21/s355g/c/3/A","parentIdentifier":"/us/usc/t21/s355g/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fc%2F3%2FA","sourceRelease":"119-100","text":"In developing the program framework under this subsection, the Secretary shall consult with regulated industry, academia, medical professional organizations, representatives of patient advocacy organizations, consumer organizations, disease research foundations, and other interested parties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Process","label":"B Process","identifier":"/us/usc/t21/s355g/c/3/B","parentIdentifier":"/us/usc/t21/s355g/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s355g/c/3/B/i","parentIdentifier":"/us/usc/t21/s355g/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":"a public-private partnership with the entities described in such subparagraph in which the Secretary may participate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s355g/c/3/B/ii","parentIdentifier":"/us/usc/t21/s355g/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":"a contract, grant, or other arrangement, as the Secretary determines appropriate, with such a partnership or an independent research organization; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t21/s355g/c/3/B/iii","parentIdentifier":"/us/usc/t21/s355g/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fc%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"public workshops with the entities described in such subparagraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Program implementation","label":"d Program implementation","identifier":"/us/usc/t21/s355g/d","parentIdentifier":"/us/usc/t21/s355g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fd","sourceRelease":"119-100","text":"The Secretary shall, not later than 3 years after , and in accordance with the framework established under subsection (c), implement the program to evaluate the potential use of real world evidence.December 13, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Guidance for industry","label":"e Guidance for industry","identifier":"/us/usc/t21/s355g/e","parentIdentifier":"/us/usc/t21/s355g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s355g/e/1","parentIdentifier":"/us/usc/t21/s355g/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s355g/e/1/A","parentIdentifier":"/us/usc/t21/s355g/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fe%2F1%2FA","sourceRelease":"119-100","text":"the circumstances under which sponsors of drugs and the Secretary may rely on real world evidence for the purposes described in paragraphs (1) and (2) of subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s355g/e/1/B","parentIdentifier":"/us/usc/t21/s355g/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fe%2F1%2FB","sourceRelease":"119-100","text":"the appropriate standards and methodologies for collection and analysis of real world evidence submitted for such purposes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s355g/e/2","parentIdentifier":"/us/usc/t21/s355g/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fe%2F2","sourceRelease":"119-100","text":"not later than 5 years after , issue draft guidance for industry as described in paragraph (1); andDecember 13, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t21/s355g/e/3","parentIdentifier":"/us/usc/t21/s355g/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Fe%2F3","sourceRelease":"119-100","text":"not later than 18 months after the close of the public comment period for the draft guidance described in paragraph (2), issue revised draft guidance or final guidance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Rule of construction","label":"f Rule of construction","identifier":"/us/usc/t21/s355g/f","parentIdentifier":"/us/usc/t21/s355g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t21/s355g/f/1","parentIdentifier":"/us/usc/t21/s355g/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Ff%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2), nothing in this section prohibits the Secretary from using real world evidence for purposes not specified in this section, provided the Secretary determines that sufficient basis exists for any such nonspecified use.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Standards of evidence and Secretary’s authority","label":"2 Standards of evidence and Secretary’s authority","identifier":"/us/usc/t21/s355g/f/2","parentIdentifier":"/us/usc/t21/s355g/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s355g/f/2/A","parentIdentifier":"/us/usc/t21/s355g/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Ff%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s355g/f/2/A/i","parentIdentifier":"/us/usc/t21/s355g/f/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Ff%2F2%2FA%2Fi","sourceRelease":"119-100","text":"subsection (c) or (d) of , including the substantial evidence standard in such subsection (d); orsection 355 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s355g/f/2/A/ii","parentIdentifier":"/us/usc/t21/s355g/f/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Ff%2F2%2FA%2Fii","sourceRelease":"119-100","text":"; orsection 262(a) of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s355g/f/2/B","parentIdentifier":"/us/usc/t21/s355g/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355g%2Ff%2F2%2FB","sourceRelease":"119-100","text":"the Secretary’s authority to require postapproval studies or clinical trials, or the standards of evidence under which studies or trials are evaluated.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
