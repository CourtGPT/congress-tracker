{"type":"section","nativeType":"section","number":"16251","heading":"Production incentives for cellulosic biofuels","label":"16251 Production incentives for cellulosic biofuels","identifier":"/us/usc/t42/s16251","parentIdentifier":"/us/usc/t42/ch149/schIX/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purpose","label":"a Purpose","identifier":"/us/usc/t42/s16251/a","parentIdentifier":"/us/usc/t42/s16251","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16251/a/1","parentIdentifier":"/us/usc/t42/s16251/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fa%2F1","sourceRelease":"119-100","text":"accelerate deployment and commercialization of biofuels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16251/a/2","parentIdentifier":"/us/usc/t42/s16251/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fa%2F2","sourceRelease":"119-100","text":"deliver the first 1,000,000,000 gallons in annual cellulosic biofuels production by 2015;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16251/a/3","parentIdentifier":"/us/usc/t42/s16251/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fa%2F3","sourceRelease":"119-100","text":"ensure biofuels produced after 2015 are cost competitive with gasoline and diesel; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16251/a/4","parentIdentifier":"/us/usc/t42/s16251/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fa%2F4","sourceRelease":"119-100","text":"ensure that small feedstock producers and rural small businesses are full participants in the development of the cellulosic biofuels industry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Definitions","label":"b Definitions","identifier":"/us/usc/t42/s16251/b","parentIdentifier":"/us/usc/t42/s16251","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Cellulosic biofuels","label":"1 Cellulosic biofuels","identifier":"/us/usc/t42/s16251/b/1","parentIdentifier":"/us/usc/t42/s16251/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fb%2F1","sourceRelease":"119-100","text":"The term “cellulosic biofuels” means any fuel that is produced from cellulosic feedstocks.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible entity","label":"2 Eligible entity","identifier":"/us/usc/t42/s16251/b/2","parentIdentifier":"/us/usc/t42/s16251/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16251/b/2/A","parentIdentifier":"/us/usc/t42/s16251/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fb%2F2%2FA","sourceRelease":"119-100","text":"is located in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16251/b/2/B","parentIdentifier":"/us/usc/t42/s16251/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fb%2F2%2FB","sourceRelease":"119-100","text":"meets all applicable Federal and State permitting requirements; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16251/b/2/C","parentIdentifier":"/us/usc/t42/s16251/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fb%2F2%2FC","sourceRelease":"119-100","text":"meets any financial criteria established by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Program","label":"c Program","identifier":"/us/usc/t42/s16251/c","parentIdentifier":"/us/usc/t42/s16251","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t42/s16251/c/1","parentIdentifier":"/us/usc/t42/s16251/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary, in consultation with the Secretary of Agriculture, the Secretary of Defense, and the Administrator of the Environmental Protection Agency, shall establish an incentive program for the production of cellulosic biofuels.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Basis of incentives","label":"2 Basis of incentives","identifier":"/us/usc/t42/s16251/c/2","parentIdentifier":"/us/usc/t42/s16251/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16251/c/2/A","parentIdentifier":"/us/usc/t42/s16251/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F2%2FA","sourceRelease":"119-100","text":"set payments per gallon of cellulosic biofuels produced in an amount determined by the Secretary, until initiation of the first reverse auction; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16251/c/2/B","parentIdentifier":"/us/usc/t42/s16251/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F2%2FB","sourceRelease":"119-100","text":"reverse auction thereafter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"First reverse auction","label":"3 First reverse auction","identifier":"/us/usc/t42/s16251/c/3","parentIdentifier":"/us/usc/t42/s16251/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16251/c/3/A","parentIdentifier":"/us/usc/t42/s16251/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F3%2FA","sourceRelease":"119-100","text":"not later than 1 year after the first year of annual production in the United States of 100,000,000 gallons of cellulosic biofuels, as determined by the Secretary; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16251/c/3/B","parentIdentifier":"/us/usc/t42/s16251/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F3%2FB","sourceRelease":"119-100","text":"not later than 3 years after .August 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Reverse auction procedure","label":"4 Reverse auction procedure","identifier":"/us/usc/t42/s16251/c/4","parentIdentifier":"/us/usc/t42/s16251/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16251/c/4/A","parentIdentifier":"/us/usc/t42/s16251/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16251/c/4/A/i","parentIdentifier":"/us/usc/t42/s16251/c/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F4%2FA%2Fi","sourceRelease":"119-100","text":"the Secretary shall solicit bids from eligible entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16251/c/4/A/ii","parentIdentifier":"/us/usc/t42/s16251/c/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F4%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s16251/c/4/A/ii/I","parentIdentifier":"/us/usc/t42/s16251/c/4/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F4%2FA%2Fii%2FI","sourceRelease":"119-100","text":"a desired level of production incentive on a per gallon basis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s16251/c/4/A/ii/II","parentIdentifier":"/us/usc/t42/s16251/c/4/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F4%2FA%2Fii%2FII","sourceRelease":"119-100","text":"an estimated annual production amount in gallons; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16251/c/4/A/iii","parentIdentifier":"/us/usc/t42/s16251/c/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F4%2FA%2Fiii","sourceRelease":"119-100","text":"the Secretary shall issue awards for the production amount submitted, beginning with the eligible entity submitting the bid for the lowest level of production incentive on a per gallon basis and meeting such other criteria as are established by the Secretary, until the amount of funds available for the reverse auction is committed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Amount of incentive received","label":"B Amount of incentive received","identifier":"/us/usc/t42/s16251/c/4/B","parentIdentifier":"/us/usc/t42/s16251/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F4%2FB","sourceRelease":"119-100","text":"An eligible entity selected by the Secretary through a reverse auction shall receive the amount of performance incentive requested in the auction for each gallon produced and sold by the entity during the first 6 years of operation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Commencement of production of cellulosic biofuels","label":"C Commencement of production of cellulosic biofuels","identifier":"/us/usc/t42/s16251/c/4/C","parentIdentifier":"/us/usc/t42/s16251/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fc%2F4%2FC","sourceRelease":"119-100","text":"As a condition of the receipt of an award under this section, an eligible entity shall enter into an agreement with the Secretary under which the eligible entity agrees to begin production of cellulosic biofuels not later than 3 years after the date of the reverse auction in which the eligible entity participates.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Limitations","label":"d Limitations","identifier":"/us/usc/t42/s16251/d","parentIdentifier":"/us/usc/t42/s16251","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16251/d/1","parentIdentifier":"/us/usc/t42/s16251/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fd%2F1","sourceRelease":"119-100","text":"a per gallon amount determined by the Secretary during the first 4 years of the program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16251/d/2","parentIdentifier":"/us/usc/t42/s16251/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fd%2F2","sourceRelease":"119-100","text":"a declining per gallon cap over the remaining lifetime of the program, to be established by the Secretary so that cellulosic biofuels produced after the first year of annual cellulosic biofuels production in the United States in excess of 1,000,000,000 gallons are cost competitive with gasoline and diesel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16251/d/3","parentIdentifier":"/us/usc/t42/s16251/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fd%2F3","sourceRelease":"119-100","text":"not more than 25 percent of the funds committed within each reverse auction to any 1 project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16251/d/4","parentIdentifier":"/us/usc/t42/s16251/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fd%2F4","sourceRelease":"119-100","text":"not more than $100,000,000 in any 1 year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16251/d/5","parentIdentifier":"/us/usc/t42/s16251/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fd%2F5","sourceRelease":"119-100","text":"not more than $1,000,000,000 over the lifetime of the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Priority","label":"e Priority","identifier":"/us/usc/t42/s16251/e","parentIdentifier":"/us/usc/t42/s16251","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16251/e/1","parentIdentifier":"/us/usc/t42/s16251/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fe%2F1","sourceRelease":"119-100","text":"demonstrate outstanding potential for local and regional economic development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16251/e/2","parentIdentifier":"/us/usc/t42/s16251/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fe%2F2","sourceRelease":"119-100","text":"include agricultural producers or cooperatives of agricultural producers as equity partners in the ventures; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16251/e/3","parentIdentifier":"/us/usc/t42/s16251/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Fe%2F3","sourceRelease":"119-100","text":"have a strategic agreement in place to fairly reward feedstock suppliers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorizations of appropriations","label":"f Authorizations of appropriations","identifier":"/us/usc/t42/s16251/f","parentIdentifier":"/us/usc/t42/s16251","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16251%2Ff","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $250,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
