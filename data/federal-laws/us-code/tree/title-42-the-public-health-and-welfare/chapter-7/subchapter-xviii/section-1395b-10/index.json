{"type":"section","nativeType":"section","number":"1395b–10","heading":"Addressing health care disparities","label":"1395b–10 Addressing health care disparities","identifier":"/us/usc/t42/s1395b–10","parentIdentifier":"/us/usc/t42/ch7/schXVIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1395b%E2%80%9310","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Evaluating data collection approaches","label":"a Evaluating data collection approaches","identifier":"/us/usc/t42/s1395b–10/a","parentIdentifier":"/us/usc/t42/s1395b–10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1395b%E2%80%9310%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s1395b–10/a/1","parentIdentifier":"/us/usc/t42/s1395b–10/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1395b%E2%80%9310%2Fa%2F1","sourceRelease":"119-100","text":"Protecting patient privacy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s1395b–10/a/2","parentIdentifier":"/us/usc/t42/s1395b–10/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1395b%E2%80%9310%2Fa%2F2","sourceRelease":"119-100","text":"Minimizing the administrative burdens of data collection and reporting on providers and health plans participating under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s1395b–10/a/3","parentIdentifier":"/us/usc/t42/s1395b–10/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1395b%E2%80%9310%2Fa%2F3","sourceRelease":"119-100","text":"Improving Medicare program data on race, ethnicity, and gender.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Reports to Congress","label":"b Reports to Congress","identifier":"/us/usc/t42/s1395b–10/b","parentIdentifier":"/us/usc/t42/s1395b–10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1395b%E2%80%9310%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Report on evaluation","label":"1 Report on evaluation","identifier":"/us/usc/t42/s1395b–10/b/1","parentIdentifier":"/us/usc/t42/s1395b–10/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1395b%E2%80%9310%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s1395b–10/b/1/A","parentIdentifier":"/us/usc/t42/s1395b–10/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1395b%E2%80%9310%2Fb%2F1%2FA","sourceRelease":"119-100","text":"identify approaches (including defining methodologies) for identifying and collecting and evaluating data on health care disparities on the basis of race, ethnicity, and gender for the original Medicare fee-for-service program under parts A and B, the Medicare Advantage program under part C, and the Medicare prescription drug program under part D; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s1395b–10/b/1/B","parentIdentifier":"/us/usc/t42/s1395b–10/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1395b%E2%80%9310%2Fb%2F1%2FB","sourceRelease":"119-100","text":"include recommendations on the most effective strategies and approaches to reporting HEDIS quality measures as required under and other nationally recognized quality performance measures, as appropriate, on the basis of race, ethnicity, and gender.section 1395w–22(e)(3) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Reports on data analyses","label":"2 Reports on data analyses","identifier":"/us/usc/t42/s1395b–10/b/2","parentIdentifier":"/us/usc/t42/s1395b–10/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1395b%E2%80%9310%2Fb%2F2","sourceRelease":"119-100","text":"Not later than 4 years after , and 4 years thereafter, the Secretary shall submit to Congress a report that includes recommendations for improving the identification of health care disparities for Medicare beneficiaries based on analyses of the data collected under subsection (c).July 15, 2008","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Implementing effective approaches","label":"c Implementing effective approaches","identifier":"/us/usc/t42/s1395b–10/c","parentIdentifier":"/us/usc/t42/s1395b–10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1395b%E2%80%9310%2Fc","sourceRelease":"119-100","text":"Not later than 24 months after , the Secretary shall implement the approaches identified in the report submitted under subsection (b)(1) for the ongoing, accurate, and timely collection and evaluation of data on health care disparities on the basis of race, ethnicity, and gender.July 15, 2008","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
