{"type":"section","nativeType":"section","number":"11132","heading":"Reporting of sanctions taken by Boards of Medical Examiners","label":"11132 Reporting of sanctions taken by Boards of Medical Examiners","identifier":"/us/usc/t42/s11132","parentIdentifier":"/us/usc/t42/ch117/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11132","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s11132/a","parentIdentifier":"/us/usc/t42/s11132","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11132%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Actions subject to reporting","label":"1 Actions subject to reporting","identifier":"/us/usc/t42/s11132/a/1","parentIdentifier":"/us/usc/t42/s11132/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11132%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s11132/a/1/A","parentIdentifier":"/us/usc/t42/s11132/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11132%2Fa%2F1%2FA","sourceRelease":"119-100","text":"which revokes or suspends (or otherwise restricts) a physician’s license or censures, reprimands, or places on probation a physician, for reasons relating to the physician’s professional competence or professional conduct, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s11132/a/1/B","parentIdentifier":"/us/usc/t42/s11132/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11132%2Fa%2F1%2FB","sourceRelease":"119-100","text":"to which a physician’s license is surrendered,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Information to be reported","label":"2 Information to be reported","identifier":"/us/usc/t42/s11132/a/2","parentIdentifier":"/us/usc/t42/s11132/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11132%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s11132/a/2/A","parentIdentifier":"/us/usc/t42/s11132/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11132%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the name of the physician involved,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s11132/a/2/B","parentIdentifier":"/us/usc/t42/s11132/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11132%2Fa%2F2%2FB","sourceRelease":"119-100","text":"a description of the acts or omissions or other reasons (if known) for the revocation, suspension, or surrender of license, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s11132/a/2/C","parentIdentifier":"/us/usc/t42/s11132/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11132%2Fa%2F2%2FC","sourceRelease":"119-100","text":"such other information respecting the circumstances of the action or surrender as the Secretary deems appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Failure to report","label":"b Failure to report","identifier":"/us/usc/t42/s11132/b","parentIdentifier":"/us/usc/t42/s11132","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11132%2Fb","sourceRelease":"119-100","text":"If, after notice of noncompliance and providing opportunity to correct noncompliance, the Secretary determines that a Board of Medical Examiners has failed to report information in accordance with subsection (a), the Secretary shall designate another qualified entity for the reporting of information under .section 11133 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
