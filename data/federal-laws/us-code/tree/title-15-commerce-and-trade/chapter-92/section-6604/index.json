{"type":"section","nativeType":"section","number":"6604","heading":"Punitive damages limitations","label":"6604 Punitive damages limitations","identifier":"/us/usc/t15/s6604","parentIdentifier":"/us/usc/t15/ch92","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments1999—Subsec. (d). added subsec. (d).Pub. L. 106–113"],"amendments":["Amendments1999—Subsec. (d). added subsec. (d).Pub. L. 106–113"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s6604/a","parentIdentifier":"/us/usc/t15/s6604","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fa","sourceRelease":"119-100","text":"In any Y2K action in which punitive damages are permitted by applicable law, the defendant shall not be liable for punitive damages unless the plaintiff proves by clear and convincing evidence that the applicable standard for awarding damages has been met.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Caps on punitive damages","label":"b Caps on punitive damages","identifier":"/us/usc/t15/s6604/b","parentIdentifier":"/us/usc/t15/s6604","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s6604/b/1","parentIdentifier":"/us/usc/t15/s6604/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s6604/b/1/A","parentIdentifier":"/us/usc/t15/s6604/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fb%2F1%2FA","sourceRelease":"119-100","text":"three times the amount awarded for compensatory damages; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s6604/b/1/B","parentIdentifier":"/us/usc/t15/s6604/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fb%2F1%2FB","sourceRelease":"119-100","text":"$250,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Defendant described","label":"2 Defendant described","identifier":"/us/usc/t15/s6604/b/2","parentIdentifier":"/us/usc/t15/s6604/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s6604/b/2/A","parentIdentifier":"/us/usc/t15/s6604/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s6604/b/2/A/i","parentIdentifier":"/us/usc/t15/s6604/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"is sued in his or her capacity as an individual; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s6604/b/2/A/ii","parentIdentifier":"/us/usc/t15/s6604/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"whose net worth does not exceed $500,000; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s6604/b/2/B","parentIdentifier":"/us/usc/t15/s6604/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fb%2F2%2FB","sourceRelease":"119-100","text":"that is an unincorporated business, a partnership, corporation, association, or organization, with fewer than 50 full-time employees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"No cap if injury specifically intended","label":"3 No cap if injury specifically intended","identifier":"/us/usc/t15/s6604/b/3","parentIdentifier":"/us/usc/t15/s6604/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fb%2F3","sourceRelease":"119-100","text":"Paragraph (1) does not apply if the plaintiff establishes by clear and convincing evidence that the defendant acted with specific intent to injure the plaintiff.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Government entities","label":"c Government entities","identifier":"/us/usc/t15/s6604/c","parentIdentifier":"/us/usc/t15/s6604","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fc","sourceRelease":"119-100","text":"Punitive damages in a Y2K action may not be awarded against a government entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Institutions of higher education","label":"d Institutions of higher education","identifier":"/us/usc/t15/s6604/d","parentIdentifier":"/us/usc/t15/s6604","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s6604/d/1","parentIdentifier":"/us/usc/t15/s6604/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fd%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2), punitive damages in a Y2K action may not be awarded against an instituion of higher education as defined in .1section 1001(a) of title 20So in original. Probably should be “institution”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Exception","label":"2 Exception","identifier":"/us/usc/t15/s6604/d/2","parentIdentifier":"/us/usc/t15/s6604/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s6604/d/2/A","parentIdentifier":"/us/usc/t15/s6604/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fd%2F2%2FA","sourceRelease":"119-100","text":"has passed Y2K data exchange testing with the Department of Education; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s6604/d/2/B","parentIdentifier":"/us/usc/t15/s6604/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6604%2Fd%2F2%2FB","sourceRelease":"119-100","text":"is not or was not in the process of performing data exchange testing with the Department of Education at the time the Department terminates such testing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
