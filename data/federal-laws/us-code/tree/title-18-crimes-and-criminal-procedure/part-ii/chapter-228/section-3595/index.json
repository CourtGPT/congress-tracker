{"type":"section","nativeType":"section","number":"3595","heading":"Review of a sentence of death","label":"3595 Review of a sentence of death","identifier":"/us/usc/t18/s3595","parentIdentifier":"/us/usc/t18/ptII/ch228","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Appeal","label":"a .—Appeal","identifier":"/us/usc/t18/s3595/a","parentIdentifier":"/us/usc/t18/s3595","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595%2Fa","sourceRelease":"119-100","text":"In a case in which a sentence of death is imposed, the sentence shall be subject to review by the court of appeals upon appeal by the defendant. Notice of appeal must be filed within the time specified for the filing of a notice of appeal. An appeal under this section may be consolidated with an appeal of the judgment of conviction and shall have priority over all other cases.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Review","label":"b .—Review","identifier":"/us/usc/t18/s3595/b","parentIdentifier":"/us/usc/t18/s3595","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s3595/b/1","parentIdentifier":"/us/usc/t18/s3595/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595%2Fb%2F1","sourceRelease":"119-100","text":"the evidence submitted during the trial;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s3595/b/2","parentIdentifier":"/us/usc/t18/s3595/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595%2Fb%2F2","sourceRelease":"119-100","text":"the information submitted during the sentencing hearing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s3595/b/3","parentIdentifier":"/us/usc/t18/s3595/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595%2Fb%2F3","sourceRelease":"119-100","text":"the procedures employed in the sentencing hearing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t18/s3595/b/4","parentIdentifier":"/us/usc/t18/s3595/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595%2Fb%2F4","sourceRelease":"119-100","text":"the special findings returned under section 3593(d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Decision and Disposition.—","label":"c Decision and Disposition.—","identifier":"/us/usc/t18/s3595/c","parentIdentifier":"/us/usc/t18/s3595","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s3595/c/1","parentIdentifier":"/us/usc/t18/s3595/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595%2Fc%2F1","sourceRelease":"119-100","text":"The court of appeals shall address all substantive and procedural issues raised on the appeal of a sentence of death, and shall consider whether the sentence of death was imposed under the influence of passion, prejudice, or any other arbitrary factor and whether the evidence supports the special finding of the existence of an aggravating factor required to be considered under section 3592.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s3595/c/2","parentIdentifier":"/us/usc/t18/s3595/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s3595/c/2/A","parentIdentifier":"/us/usc/t18/s3595/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the sentence of death was imposed under the influence of passion, prejudice, or any other arbitrary factor;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s3595/c/2/B","parentIdentifier":"/us/usc/t18/s3595/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the admissible evidence and information adduced does not support the special finding of the existence of the required aggravating factor; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t18/s3595/c/2/C","parentIdentifier":"/us/usc/t18/s3595/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595%2Fc%2F2%2FC","sourceRelease":"119-100","text":"the proceedings involved any other legal error requiring reversal of the sentence that was properly preserved for appeal under the rules of criminal procedure,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s3595/c/3","parentIdentifier":"/us/usc/t18/s3595/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3595%2Fc%2F3","sourceRelease":"119-100","text":"The court of appeals shall state in writing the reasons for its disposition of an appeal of a sentence of death under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
