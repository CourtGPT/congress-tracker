{"type":"section","nativeType":"section","number":"4304","heading":"Native American trade and export promotion","label":"4304 Native American trade and export promotion","identifier":"/us/usc/t25/s4304","parentIdentifier":"/us/usc/t25/ch44","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2020—Subsec. (b)(1). substituted “Tribes” for “tribes”.Pub. L. 116–261"],"amendments":["Amendments2020—Subsec. (b)(1). substituted “Tribes” for “tribes”.Pub. L. 116–261"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t25/s4304/a","parentIdentifier":"/us/usc/t25/s4304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fa","sourceRelease":"119-100","text":"The Secretary, acting through the Director, shall carry out a Native American export and trade promotion program (referred to in this section as the “program”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Coordination of Federal programs and services","label":"b Coordination of Federal programs and services","identifier":"/us/usc/t25/s4304/b","parentIdentifier":"/us/usc/t25/s4304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4304/b/1","parentIdentifier":"/us/usc/t25/s4304/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fb%2F1","sourceRelease":"119-100","text":"develop the economies of Indian Tribes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4304/b/2","parentIdentifier":"/us/usc/t25/s4304/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fb%2F2","sourceRelease":"119-100","text":"stimulate the demand for Indian goods and services that are available from eligible entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Activities","label":"c Activities","identifier":"/us/usc/t25/s4304/c","parentIdentifier":"/us/usc/t25/s4304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4304/c/1","parentIdentifier":"/us/usc/t25/s4304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fc%2F1","sourceRelease":"119-100","text":"Federal programs designed to provide technical or financial assistance to eligible entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4304/c/2","parentIdentifier":"/us/usc/t25/s4304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fc%2F2","sourceRelease":"119-100","text":"the development of promotional materials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s4304/c/3","parentIdentifier":"/us/usc/t25/s4304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fc%2F3","sourceRelease":"119-100","text":"the financing of appropriate trade missions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s4304/c/4","parentIdentifier":"/us/usc/t25/s4304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fc%2F4","sourceRelease":"119-100","text":"the marketing of Indian goods and services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s4304/c/5","parentIdentifier":"/us/usc/t25/s4304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fc%2F5","sourceRelease":"119-100","text":"the participation of appropriate Federal agencies or eligible entities in international trade fairs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t25/s4304/c/6","parentIdentifier":"/us/usc/t25/s4304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fc%2F6","sourceRelease":"119-100","text":"any other activity related to the development of markets for Indian goods and services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Technical assistance","label":"d Technical assistance","identifier":"/us/usc/t25/s4304/d","parentIdentifier":"/us/usc/t25/s4304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4304/d/1","parentIdentifier":"/us/usc/t25/s4304/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fd%2F1","sourceRelease":"119-100","text":"the identification of appropriate markets for Indian goods and services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4304/d/2","parentIdentifier":"/us/usc/t25/s4304/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fd%2F2","sourceRelease":"119-100","text":"entering the markets referred to in paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s4304/d/3","parentIdentifier":"/us/usc/t25/s4304/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fd%2F3","sourceRelease":"119-100","text":"compliance with foreign or domestic laws and practices with respect to financial institutions with respect to the export and import of Indian goods and services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s4304/d/4","parentIdentifier":"/us/usc/t25/s4304/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fd%2F4","sourceRelease":"119-100","text":"entering into financial arrangements to provide for the export and import of Indian goods and services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Priorities","label":"e Priorities","identifier":"/us/usc/t25/s4304/e","parentIdentifier":"/us/usc/t25/s4304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4304/e/1","parentIdentifier":"/us/usc/t25/s4304/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fe%2F1","sourceRelease":"119-100","text":"provide the greatest degree of economic benefits to Indians; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4304/e/2","parentIdentifier":"/us/usc/t25/s4304/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4304%2Fe%2F2","sourceRelease":"119-100","text":"foster long-term stable international markets for Indian goods and services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
