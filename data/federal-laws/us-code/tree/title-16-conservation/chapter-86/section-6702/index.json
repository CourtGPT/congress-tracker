{"type":"section","nativeType":"section","number":"6702","heading":"Purposes","label":"6702 Purposes","identifier":"/us/usc/t16/s6702","parentIdentifier":"/us/usc/t16/ch86","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s6702/1","parentIdentifier":"/us/usc/t16/s6702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F1","sourceRelease":"119-100","text":"to enhance the capacity to develop, transfer, apply, monitor, and regularly update practical science-based forest restoration treatments that will reduce the risk of severe wildfires, and improve the health of dry forest and woodland ecosystems in the interior West;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6702/2","parentIdentifier":"/us/usc/t16/s6702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F2","sourceRelease":"119-100","text":"to synthesize and adapt scientific findings from conventional research programs to the implementation of forest and woodland restoration on a landscape scale;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s6702/3","parentIdentifier":"/us/usc/t16/s6702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F3","sourceRelease":"119-100","text":"to facilitate the transfer of interdisciplinary knowledge required to understand the socioeconomic and environmental impacts of wildfire on ecosystems and landscapes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s6702/4","parentIdentifier":"/us/usc/t16/s6702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6702/4/A","parentIdentifier":"/us/usc/t16/s6702/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F4%2FA","sourceRelease":"119-100","text":"to use ecological restoration treatments to reverse declining forest health and reduce the risk of severe wildfires across the forest landscape; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6702/4/B","parentIdentifier":"/us/usc/t16/s6702/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F4%2FB","sourceRelease":"119-100","text":"to design, implement, monitor, and regularly revise representative wildfire treatments based on the use of adaptive ecosystem management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s6702/5","parentIdentifier":"/us/usc/t16/s6702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6702/5/A","parentIdentifier":"/us/usc/t16/s6702/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F5%2FA","sourceRelease":"119-100","text":"treating acres with restoration-based applications; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6702/5/B","parentIdentifier":"/us/usc/t16/s6702/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F5%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s6702/5/B/i","parentIdentifier":"/us/usc/t16/s6702/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F5%2FB%2Fi","sourceRelease":"119-100","text":"the National Fire Plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s6702/5/B/ii","parentIdentifier":"/us/usc/t16/s6702/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F5%2FB%2Fii","sourceRelease":"119-100","text":"the report entitled “Protecting People and Sustaining Resources in Fire-Adapted Ecosystems-A Cohesive Strategy” (65 Fed. Reg. 67480); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s6702/5/B/iii","parentIdentifier":"/us/usc/t16/s6702/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F5%2FB%2Fiii","sourceRelease":"119-100","text":"the report entitled “10-Year Comprehensive Strategy: A Collaborative Approach for Reducing Wildland Fire Risks to Communities and the Environment” of the Western Governors’ Association;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s6702/6","parentIdentifier":"/us/usc/t16/s6702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F6","sourceRelease":"119-100","text":"to provide technical assistance to collaborative efforts by affected entities to develop, implement, and monitor adaptive ecosystem management restoration treatments that are ecologically sound, economically viable, and socially responsible; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t16/s6702/7","parentIdentifier":"/us/usc/t16/s6702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6702%2F7","sourceRelease":"119-100","text":"to assist Federal and non-Federal land managers in providing information to the public on the role of fire and fire management in dry forest and woodland ecosystems in the interior West.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
