{"type":"section","nativeType":"section","number":"17054","heading":"Biofuels distribution and advanced biofuels infrastructure","label":"17054 Biofuels distribution and advanced biofuels infrastructure","identifier":"/us/usc/t42/s17054","parentIdentifier":"/us/usc/t42/ch152/schII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17054","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s17054/a","parentIdentifier":"/us/usc/t42/s17054","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17054%2Fa","sourceRelease":"119-100","text":"The Secretary, in coordination with the Secretary of Transportation and in consultation with the Administrator of the Environmental Protection Agency, shall carry out a program of research, development, and demonstration relating to existing transportation fuel distribution infrastructure and new alternative distribution infrastructure.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Focus","label":"b Focus","identifier":"/us/usc/t42/s17054/b","parentIdentifier":"/us/usc/t42/s17054","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17054%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17054/b/1","parentIdentifier":"/us/usc/t42/s17054/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17054%2Fb%2F1","sourceRelease":"119-100","text":"corrosion of metal, plastic, rubber, cork, fiberglass, glues, or any other material used in pipes and storage tanks;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17054/b/2","parentIdentifier":"/us/usc/t42/s17054/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17054%2Fb%2F2","sourceRelease":"119-100","text":"dissolving of storage tank sediments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17054/b/3","parentIdentifier":"/us/usc/t42/s17054/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17054%2Fb%2F3","sourceRelease":"119-100","text":"clogging of filters;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17054/b/4","parentIdentifier":"/us/usc/t42/s17054/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17054%2Fb%2F4","sourceRelease":"119-100","text":"contamination from water or other adulterants or pollutants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s17054/b/5","parentIdentifier":"/us/usc/t42/s17054/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17054%2Fb%2F5","sourceRelease":"119-100","text":"poor flow properties related to low temperatures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s17054/b/6","parentIdentifier":"/us/usc/t42/s17054/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17054%2Fb%2F6","sourceRelease":"119-100","text":"oxidative and thermal instability in long-term storage and uses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s17054/b/7","parentIdentifier":"/us/usc/t42/s17054/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17054%2Fb%2F7","sourceRelease":"119-100","text":"microbial contamination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s17054/b/8","parentIdentifier":"/us/usc/t42/s17054/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17054%2Fb%2F8","sourceRelease":"119-100","text":"problems associated with electrical conductivity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t42/s17054/b/9","parentIdentifier":"/us/usc/t42/s17054/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17054%2Fb%2F9","sourceRelease":"119-100","text":"such other areas as the Secretary considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
