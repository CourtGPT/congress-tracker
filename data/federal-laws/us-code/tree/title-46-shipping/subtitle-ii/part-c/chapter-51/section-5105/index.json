{"type":"section","nativeType":"section","number":"5105","heading":"Load line surveys","label":"5105 Load line surveys","identifier":"/us/usc/t46/s5105","parentIdentifier":"/us/usc/t46/stII/ptC/ch51","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs5105","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevised section 5105Section 5105 authorizes the Secretary of Transportation to provide for load line surveys and requires that while conducting a load line survey, the Secretary must consider various strength, stability, design, and construction features of the vessel."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t46/s5105/a","parentIdentifier":"/us/usc/t46/s5105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs5105%2Fa","sourceRelease":"119-100","text":"The Secretary may provide for annual, renewal, and other load line surveys.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t46/s5105/b","parentIdentifier":"/us/usc/t46/s5105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs5105%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s5105/b/1","parentIdentifier":"/us/usc/t46/s5105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs5105%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s5105/b/1/A","parentIdentifier":"/us/usc/t46/s5105/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs5105%2Fb%2F1%2FA","sourceRelease":"119-100","text":"are adequate to protect the vessel from the sea; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s5105/b/1/B","parentIdentifier":"/us/usc/t46/s5105/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs5105%2Fb%2F1%2FB","sourceRelease":"119-100","text":"meet other requirements the Secretary may prescribe by regulation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s5105/b/2","parentIdentifier":"/us/usc/t46/s5105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs5105%2Fb%2F2","sourceRelease":"119-100","text":"the strength of the hull is adequate for all loading conditions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s5105/b/3","parentIdentifier":"/us/usc/t46/s5105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs5105%2Fb%2F3","sourceRelease":"119-100","text":"the stability of the vessel is adequate for all loading conditions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t46/s5105/b/4","parentIdentifier":"/us/usc/t46/s5105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs5105%2Fb%2F4","sourceRelease":"119-100","text":"the topsides of the vessel are arranged and constructed to allow rapid overboard drainage of deck water in heavy weather; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t46/s5105/b/5","parentIdentifier":"/us/usc/t46/s5105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs5105%2Fb%2F5","sourceRelease":"119-100","text":"the topsides of the vessel are adequate in design, arrangement, and equipment to protect crewmembers performing outside tasks necessary for safe operation of the vessel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
