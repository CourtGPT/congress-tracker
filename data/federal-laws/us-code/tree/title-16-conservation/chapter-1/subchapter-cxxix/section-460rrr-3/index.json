{"type":"section","nativeType":"section","number":"460rrr–3","heading":"Powers of the Commission","label":"460rrr–3 Powers of the Commission","identifier":"/us/usc/t16/s460rrr–3","parentIdentifier":"/us/usc/t16/ch1/schCXXIX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Hearings","label":"a Hearings","identifier":"/us/usc/t16/s460rrr–3/a","parentIdentifier":"/us/usc/t16/s460rrr–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fa","sourceRelease":"119-100","text":"The Commission may hold such hearings, meet and act at such times and places, take such testimony, and receive such evidence as the Commission considers advisable to carry out this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Cooperative agreements","label":"b Cooperative agreements","identifier":"/us/usc/t16/s460rrr–3/b","parentIdentifier":"/us/usc/t16/s460rrr–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s460rrr–3/b/1","parentIdentifier":"/us/usc/t16/s460rrr–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fb%2F1","sourceRelease":"119-100","text":"For purposes of carrying out the management plan on non-Federal land in the Natural Area, the Commission may enter into a cooperative agreement with the State of Colorado, a political subdivision of the State, or any person.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t16/s460rrr–3/b/2","parentIdentifier":"/us/usc/t16/s460rrr–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fb%2F2","sourceRelease":"119-100","text":"A cooperative agreement entered into under paragraph (1) shall establish procedures for providing notice to the Commission of any action proposed by the State of Colorado, a political subdivision of the State, or any person that may affect the implementation of the management plan on non-Federal land in the Natural Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Effect","label":"3 Effect","identifier":"/us/usc/t16/s460rrr–3/b/3","parentIdentifier":"/us/usc/t16/s460rrr–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fb%2F3","sourceRelease":"119-100","text":"A cooperative agreement entered into under paragraph (1) shall not enlarge or diminish any right or duty of a Federal agency under Federal law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Prohibition of acquisition of real property","label":"c Prohibition of acquisition of real property","identifier":"/us/usc/t16/s460rrr–3/c","parentIdentifier":"/us/usc/t16/s460rrr–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fc","sourceRelease":"119-100","text":"The Commission may not acquire any real property or interest in real property.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Implementation of management plan","label":"d Implementation of management plan","identifier":"/us/usc/t16/s460rrr–3/d","parentIdentifier":"/us/usc/t16/s460rrr–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s460rrr–3/d/1","parentIdentifier":"/us/usc/t16/s460rrr–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fd%2F1","sourceRelease":"119-100","text":"The Commission shall assist the Secretary in implementing the management plan by carrying out the activities described in paragraph (2) to preserve and interpret the natural, historic, cultural, scientific, scenic, wildlife, and recreational resources of the Natural Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Authorized activities","label":"2 Authorized activities","identifier":"/us/usc/t16/s460rrr–3/d/2","parentIdentifier":"/us/usc/t16/s460rrr–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460rrr–3/d/2/A","parentIdentifier":"/us/usc/t16/s460rrr–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fd%2F2%2FA","sourceRelease":"119-100","text":"assist the State of Colorado in preserving State land and wildlife within the Natural Area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460rrr–3/d/2/B","parentIdentifier":"/us/usc/t16/s460rrr–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fd%2F2%2FB","sourceRelease":"119-100","text":"assist the State of Colorado and political subdivisions of the State in increasing public awareness of, and appreciation for, the natural, historic, scientific, scenic, wildlife, and recreational resources in the Natural Area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s460rrr–3/d/2/C","parentIdentifier":"/us/usc/t16/s460rrr–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fd%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460rrr–3/d/2/C/i","parentIdentifier":"/us/usc/t16/s460rrr–3/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fd%2F2%2FC%2Fi","sourceRelease":"119-100","text":"the management of the Natural Area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460rrr–3/d/2/C/ii","parentIdentifier":"/us/usc/t16/s460rrr–3/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fd%2F2%2FC%2Fii","sourceRelease":"119-100","text":"the management plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s460rrr–3/d/2/D","parentIdentifier":"/us/usc/t16/s460rrr–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%933%2Fd%2F2%2FD","sourceRelease":"119-100","text":"encourage and assist private landowners in the Natural Area in the implementation of the management plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
