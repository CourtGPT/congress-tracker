{"type":"section","nativeType":"section","number":"15891","heading":"Projects enhancing insular energy independence","label":"15891 Projects enhancing insular energy independence","identifier":"/us/usc/t42/s15891","parentIdentifier":"/us/usc/t42/ch149/schII/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Project feasibility studies","label":"a Project feasibility studies","identifier":"/us/usc/t42/s15891/a","parentIdentifier":"/us/usc/t42/s15891","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s15891/a/1","parentIdentifier":"/us/usc/t42/s15891/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15891/a/1/A","parentIdentifier":"/us/usc/t42/s15891/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fa%2F1%2FA","sourceRelease":"119-100","text":"significantly reduce the dependence of an insular area on imported fossil fuels; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15891/a/1/B","parentIdentifier":"/us/usc/t42/s15891/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fa%2F1%2FB","sourceRelease":"119-100","text":"provide needed distributed generation to an insular area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Request","label":"2 Request","identifier":"/us/usc/t42/s15891/a/2","parentIdentifier":"/us/usc/t42/s15891/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15891/a/2/A","parentIdentifier":"/us/usc/t42/s15891/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the request of an electric utility located in an insular area that commits to fund at least 10 percent of the cost of the study; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15891/a/2/B","parentIdentifier":"/us/usc/t42/s15891/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fa%2F2%2FB","sourceRelease":"119-100","text":"if the electric utility is located in the Federated States of Micronesia, the Republic of the Marshall Islands, or the Republic of Palau, written support for that request by the President or the Ambassador of the affected freely associated state.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Consultation","label":"3 Consultation","identifier":"/us/usc/t42/s15891/a/3","parentIdentifier":"/us/usc/t42/s15891/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15891/a/3/A","parentIdentifier":"/us/usc/t42/s15891/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fa%2F3%2FA","sourceRelease":"119-100","text":"conducting feasibility studies under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15891/a/3/B","parentIdentifier":"/us/usc/t42/s15891/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fa%2F3%2FB","sourceRelease":"119-100","text":"determining the feasibility of potential projects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Feasibility","label":"4 Feasibility","identifier":"/us/usc/t42/s15891/a/4","parentIdentifier":"/us/usc/t42/s15891/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fa%2F4","sourceRelease":"119-100","text":"For the purpose of a feasibility study under paragraph (1), a project shall be determined to be feasible if the project would significantly reduce the dependence of an insular area on imported fossil fuels, or provide needed distributed generation to an insular area, at a reasonable cost.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Implementation","label":"b Implementation","identifier":"/us/usc/t42/s15891/b","parentIdentifier":"/us/usc/t42/s15891","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s15891/b/1","parentIdentifier":"/us/usc/t42/s15891/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fb%2F1","sourceRelease":"119-100","text":"On a determination by the Secretary (in consultation with the Secretary of the Interior) that a project is feasible under subsection (a) and a commitment by an electric utility to operate and maintain the project, the Secretary may provide such technical and financial assistance as the Secretary determines is appropriate for the implementation of the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Regional utility organizations","label":"2 Regional utility organizations","identifier":"/us/usc/t42/s15891/b/2","parentIdentifier":"/us/usc/t42/s15891/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fb%2F2","sourceRelease":"119-100","text":"In providing assistance under paragraph (1), the Secretary shall consider providing the assistance through regional utility organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t42/s15891/c","parentIdentifier":"/us/usc/t42/s15891","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s15891/c/1","parentIdentifier":"/us/usc/t42/s15891/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15891/c/1/A","parentIdentifier":"/us/usc/t42/s15891/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fc%2F1%2FA","sourceRelease":"119-100","text":"$500,000 for each fiscal year for project feasibility studies under subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15891/c/1/B","parentIdentifier":"/us/usc/t42/s15891/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fc%2F1%2FB","sourceRelease":"119-100","text":"$4,000,000 for each fiscal year for project implementation under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitation of funds received by insular areas","label":"2 Limitation of funds received by insular areas","identifier":"/us/usc/t42/s15891/c/2","parentIdentifier":"/us/usc/t42/s15891/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15891%2Fc%2F2","sourceRelease":"119-100","text":"No insular area may receive, during any 3-year period, more than 20 percent of the total funds made available during that 3-year period under subparagraphs (A) and (B) of paragraph (1) unless the Secretary determines that providing funding in excess of that percentage best advances existing opportunities to meet the objectives of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
