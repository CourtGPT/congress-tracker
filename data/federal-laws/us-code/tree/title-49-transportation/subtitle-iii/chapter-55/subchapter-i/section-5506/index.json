ogram","label":"b .—Pilot Program","identifier":"/us/usc/t49/s5506/b","parentIdentifier":"/us/usc/t49/s5506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s5506/b/1","parentIdentifier":"/us/usc/t49/s5506/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fb%2F1","sourceRelease":"119-100","text":"shall establish a process for eligible entities to submit to the Secretary unsolicited research proposals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s5506/b/2","parentIdentifier":"/us/usc/t49/s5506/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fb%2F2","sourceRelease":"119-100","text":"may enter into arrangements with 1 or more eligible entities to fund research proposed under paragraph (1), in accordance with this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Eligible Research","label":"c .—Eligible Research","identifier":"/us/usc/t49/s5506/c","parentIdentifier":"/us/usc/t49/s5506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s5506/c/1","parentIdentifier":"/us/usc/t49/s5506/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s5506/c/1/A","parentIdentifier":"/us/usc/t49/s5506/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s5506/c/1/A/i","parentIdentifier":"/us/usc/t49/s5506/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the Secretary; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s5506/c/1/A/ii","parentIdentifier":"/us/usc/t49/s5506/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the Administrator of a modal administration of the Department of Transportation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s5506/c/1/B","parentIdentifier":"/us/usc/t49/s5506/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fc%2F1%2FB","sourceRelease":"119-100","text":"an issue that the Secretary determines to be important; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s5506/c/2","parentIdentifier":"/us/usc/t49/s5506/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s5506/c/2/A","parentIdentifier":"/us/usc/t49/s5506/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fc%2F2%2FA","sourceRelease":"119-100","text":"any other Federal research project; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s5506/c/2/B","parentIdentifier":"/us/usc/t49/s5506/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fc%2F2%2FB","sourceRelease":"119-100","text":"any project for which funding is provided by another Federal agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Project Review","label":"d .—Project Review","identifier":"/us/usc/t49/s5506/d","parentIdentifier":"/us/usc/t49/s5506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s5506/d/1","parentIdentifier":"/us/usc/t49/s5506/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fd%2F1","sourceRelease":"119-100","text":"review each research proposal submitted under the pilot program established under subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s5506/d/2","parentIdentifier":"/us/usc/t49/s5506/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s5506/d/2/A","parentIdentifier":"/us/usc/t49/s5506/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s5506/d/2/A/i","parentIdentifier":"/us/usc/t49/s5506/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t49/s5506/d/2/A/i/I","parentIdentifier":"/us/usc/t49/s5506/d/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fd%2F2%2FA%2Fi%2FI","sourceRelease":"119-100","text":"explains why the research proposal was not selected, including whether the research proposal fails to cover an area of need; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t49/s5506/d/2/A/i/II","parentIdentifier":"/us/usc/t49/s5506/d/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fd%2F2%2FA%2Fi%2FII","sourceRelease":"119-100","text":"recommends that the research proposal be submitted to another research program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s5506/d/2/A/ii","parentIdentifier":"/us/usc/t49/s5506/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t49/s5506/d/2/A/ii/I","parentIdentifier":"/us/usc/t49/s5506/d/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fd%2F2%2FA%2Fii%2FI","sourceRelease":"119-100","text":"the eligible entity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t49/s5506/d/2/A/ii/II","parentIdentifier":"/us/usc/t49/s5506/d/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fd%2F2%2FA%2Fii%2FII","sourceRelease":"119-100","text":"the proposed research program office; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s5506/d/2/B","parentIdentifier":"/us/usc/t49/s5506/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fd%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s5506/d/2/B/i","parentIdentifier":"/us/usc/t49/s5506/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fd%2F2%2FB%2Fi","sourceRelease":"119-100","text":"provide to the eligible entity that submitted the proposal a written notice of the selection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s5506/d/2/B/ii","parentIdentifier":"/us/usc/t49/s5506/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fd%2F2%2FB%2Fii","sourceRelease":"119-100","text":"seek to enter into an arrangement with the eligible entity to provide funding for the proposed research.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Coordination.—","label":"e Coordination.—","identifier":"/us/usc/t49/s5506/e","parentIdentifier":"/us/usc/t49/s5506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s5506/e/1","parentIdentifier":"/us/usc/t49/s5506/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe%2F1","sourceRelease":"119-100","text":"The Secretary shall ensure that the activities carried out under subsection (c) are coordinated with, and do not duplicate the efforts of, programs of the Department of Transportation and other Federal agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Intraagency coordination","label":"2 .—Intraagency coordination","identifier":"/us/usc/t49/s5506/e/2","parentIdentifier":"/us/usc/t49/s5506/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s5506/e/2/A","parentIdentifier":"/us/usc/t49/s5506/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe%2F2%2FA","sourceRelease":"119-100","text":"the research, education, and technology transfer activities carried out by grant recipients under section 5505; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s5506/e/2/B","parentIdentifier":"/us/usc/t49/s5506/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe%2F2%2FB","sourceRelease":"119-100","text":"the research, development, demonstration, and commercial application activities of other relevant programs of the Department of Transportation, including all modal administrations of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Interagency collaboration","label":"3 .—Interagency collaboration","identifier":"/us/usc/t49/s5506/e/3","parentIdentifier":"/us/usc/t49/s5506/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s5506/e/3/A","parentIdentifier":"/us/usc/t49/s5506/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe%2F3%2FA","sourceRelease":"119-100","text":"the Director of the Office of Science and Technology Policy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s5506/e/3/B","parentIdentifier":"/us/usc/t49/s5506/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe%2F3%2FB","sourceRelease":"119-100","text":"the Director of the National Science Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s5506/e/3/C","parentIdentifier":"/us/usc/t49/s5506/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe%2F3%2FC","sourceRelease":"119-100","text":"the Secretary of Energy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t49/s5506/e/3/D","parentIdentifier":"/us/usc/t49/s5506/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe%2F3%2FD","sourceRelease":"119-100","text":"the Director of the National Institute of Standards and Technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t49/s5506/e/3/E","parentIdentifier":"/us/usc/t49/s5506/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe%2F3%2FE","sourceRelease":"119-100","text":"the Secretary of Homeland Security;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t49/s5506/e/3/F","parentIdentifier":"/us/usc/t49/s5506/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe%2F3%2FF","sourceRelease":"119-100","text":"the Administrator of the National Oceanic and Atmospheric Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t49/s5506/e/3/G","parentIdentifier":"/us/usc/t49/s5506/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe%2F3%2FG","sourceRelease":"119-100","text":"the Secretary of Defense; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t49/s5506/e/3/H","parentIdentifier":"/us/usc/t49/s5506/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fe%2F3%2FH","sourceRelease":"119-100","text":"the heads of other appropriate Federal agencies, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Review, Evaluation, and Report","label":"f .—Review, Evaluation, and Report","identifier":"/us/usc/t49/s5506/f","parentIdentifier":"/us/usc/t49/s5506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s5506/f/1","parentIdentifier":"/us/usc/t49/s5506/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Ff%2F1","sourceRelease":"119-100","text":"review and evaluate the pilot program established under subsection (b), including the research carried out under that pilot program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s5506/f/2","parentIdentifier":"/us/usc/t49/s5506/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Ff%2F2","sourceRelease":"119-100","text":"make public on a website of the Department of Transportation a report describing the review and evaluation under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Federal Share.—","label":"g Federal Share.—","identifier":"/us/usc/t49/s5506/g","parentIdentifier":"/us/usc/t49/s5506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s5506/g/1","parentIdentifier":"/us/usc/t49/s5506/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fg%2F1","sourceRelease":"119-100","text":"The Federal share of the cost of an activity carried out under this section shall not exceed 80 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Non-federal share","label":"2 .—Non-federal share","identifier":"/us/usc/t49/s5506/g/2","parentIdentifier":"/us/usc/t49/s5506/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fg%2F2","sourceRelease":"119-100","text":"All costs directly incurred by the non-Federal partners (including personnel, travel, facility, and hardware development costs) shall be credited toward the non-Federal share of the cost of an activity carried out under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":".—Limitation on Certain Expenses","label":"h .—Limitation on Certain Expenses","identifier":"/us/usc/t49/s5506/h","parentIdentifier":"/us/usc/t49/s5506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fh","sourceRelease":"119-100","text":"Of any amounts made available to carry out this section for a fiscal year, the Secretary may use not more than 1.5 percent for coordination, evaluation, and oversight activities under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"i","heading":".—Authorization of Appropriations","label":"i .—Authorization of Appropriations","identifier":"/us/usc/t49/s5506/i","parentIdentifier":"/us/usc/t49/s5506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs5506%2Fi","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary to carry out this section $50,000,000 for each of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
