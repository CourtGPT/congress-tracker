{"type":"section","nativeType":"section","number":"9542","heading":"Agency study on alternative financing solutions","label":"9542 Agency study on alternative financing solutions","identifier":"/us/usc/t15/s9542","parentIdentifier":"/us/usc/t15/ch120/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9542","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purpose","label":"a Purpose","identifier":"/us/usc/t15/s9542/a","parentIdentifier":"/us/usc/t15/s9542","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9542%2Fa","sourceRelease":"119-100","text":"The purpose of this section is to provide information relating to alternative financing solutions to minority business enterprises, as those business enterprises are more likely to struggle in accessing, particularly at affordable rates, traditional sources of capital.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Study and report","label":"b Study and report","identifier":"/us/usc/t15/s9542/b","parentIdentifier":"/us/usc/t15/s9542","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9542%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9542/b/1","parentIdentifier":"/us/usc/t15/s9542/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9542%2Fb%2F1","sourceRelease":"119-100","text":"conduct a study on opportunities for providing alternative financing solutions to minority business enterprises; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9542/b/2","parentIdentifier":"/us/usc/t15/s9542/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9542%2Fb%2F2","sourceRelease":"119-100","text":"submit to Congress, and publish on the website of the Agency, a report describing the findings of the study carried out under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
