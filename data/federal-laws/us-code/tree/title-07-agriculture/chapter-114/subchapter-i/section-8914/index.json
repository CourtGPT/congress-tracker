100","text":"benchmarking to provide assessments of capabilities, capacity, and readiness to achieve response goals and objectives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s8914/b/2/B/iii/II","parentIdentifier":"/us/usc/t7/s8914/b/2/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F2%2FB%2Fiii%2FII","sourceRelease":"119-100","text":"progressive exercise evaluation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t7/s8914/b/2/B/iii/III","parentIdentifier":"/us/usc/t7/s8914/b/2/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F2%2FB%2Fiii%2FIII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t7/s8914/b/2/B/iii/III/aa","parentIdentifier":"/us/usc/t7/s8914/b/2/B/iii/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F2%2FB%2Fiii%2FIII%2Faa","sourceRelease":"119-100","text":"ongoing exercises;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t7/s8914/b/2/B/iii/III/bb","parentIdentifier":"/us/usc/t7/s8914/b/2/B/iii/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F2%2FB%2Fiii%2FIII%2Fbb","sourceRelease":"119-100","text":"improvement planning and the implementation of corrective actions to enhance a response plan over time; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"cc","heading":null,"label":"cc","identifier":"/us/usc/t7/s8914/b/2/B/iii/III/cc","parentIdentifier":"/us/usc/t7/s8914/b/2/B/iii/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F2%2FB%2Fiii%2FIII%2Fcc","sourceRelease":"119-100","text":"strategic information to guide investment in any appropriate research to mitigate the risk of a disease or pest of concern; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s8914/b/2/B/iv","parentIdentifier":"/us/usc/t7/s8914/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F2%2FB%2Fiv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s8914/b/2/B/iv/I","parentIdentifier":"/us/usc/t7/s8914/b/2/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F2%2FB%2Fiv%2FI","sourceRelease":"119-100","text":"an exercise evaluation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s8914/b/2/B/iv/II","parentIdentifier":"/us/usc/t7/s8914/b/2/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F2%2FB%2Fiv%2FII","sourceRelease":"119-100","text":"new risk information becoming available regarding a disease or pest of concern.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Coordination of plans","label":"3 Coordination of plans","identifier":"/us/usc/t7/s8914/b/3","parentIdentifier":"/us/usc/t7/s8914/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fb%2F3","sourceRelease":"119-100","text":"Pursuant to , as added by section 12202, the Secretary shall, as appropriate, assist in coordinating with other appropriate Federal, State, regional, or local officials in the exercising of the plans developed under paragraph (2).section 6922(d)(6) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"National Plant Diagnostic Network","label":"c National Plant Diagnostic Network","identifier":"/us/usc/t7/s8914/c","parentIdentifier":"/us/usc/t7/s8914","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s8914/c/1","parentIdentifier":"/us/usc/t7/s8914/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary shall establish in the Department of Agriculture a National Plant Diagnostic Network to monitor and surveil through diagnostics threats to plant health from diseases or pests of concern in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t7/s8914/c/2","parentIdentifier":"/us/usc/t7/s8914/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s8914/c/2/A","parentIdentifier":"/us/usc/t7/s8914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F2%2FA","sourceRelease":"119-100","text":"provide for increased awareness, surveillance, early identification, rapid communication, warning, and diagnosis of a threat to plant health from a disease or pest of concern to protect natural and agricultural plant resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s8914/c/2/B","parentIdentifier":"/us/usc/t7/s8914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F2%2FB","sourceRelease":"119-100","text":"coordinate and collaborate with agencies of the Department of Agriculture and State agencies and authorities involved in plant health;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s8914/c/2/C","parentIdentifier":"/us/usc/t7/s8914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F2%2FC","sourceRelease":"119-100","text":"establish diagnostic laboratory standards;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s8914/c/2/D","parentIdentifier":"/us/usc/t7/s8914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F2%2FD","sourceRelease":"119-100","text":"establish regional hubs throughout the United States that provide expertise, leadership, and support to diagnostic labs relating to the agricultural crops and plants in the covered regions of those hubs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s8914/c/2/E","parentIdentifier":"/us/usc/t7/s8914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F2%2FE","sourceRelease":"119-100","text":"establish a national repository for records of endemic or emergent diseases and pests of concern.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Head of network","label":"3 Head of network","identifier":"/us/usc/t7/s8914/c/3","parentIdentifier":"/us/usc/t7/s8914/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s8914/c/3/A","parentIdentifier":"/us/usc/t7/s8914/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F3%2FA","sourceRelease":"119-100","text":"The Director of the National Institute of Food and Agriculture shall serve as the head of the National Plant Diagnostic Network.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Duties","label":"B Duties","identifier":"/us/usc/t7/s8914/c/3/B","parentIdentifier":"/us/usc/t7/s8914/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s8914/c/3/B/i","parentIdentifier":"/us/usc/t7/s8914/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":"coordinate and collaborate with land-grant colleges and universities (as defined in ) in carrying out the requirements under paragraph (2), including through cooperative agreements described in paragraph (4);section 3103 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s8914/c/3/B/ii","parentIdentifier":"/us/usc/t7/s8914/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":"partner with the Administrator of the Animal and Plant Health Inspection Service for assistance with plant health regulation and inspection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s8914/c/3/B/iii","parentIdentifier":"/us/usc/t7/s8914/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"coordinate with other Federal agencies, as appropriate, in carrying out activities relating to the National Plant Diagnostic Network, including the sharing of biosurveillance information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Collaboration with land-grant colleges and universities","label":"4 Collaboration with land-grant colleges and universities","identifier":"/us/usc/t7/s8914/c/4","parentIdentifier":"/us/usc/t7/s8914/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F4","sourceRelease":"119-100","text":"The Secretary shall seek to establish cooperative agreements with land-grant colleges and universities (as defined in ) that have the appropriate level of skill, experience, and competence with plant diseases or pests of concern.section 3103 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Authorization of appropriations","label":"5 Authorization of appropriations","identifier":"/us/usc/t7/s8914/c/5","parentIdentifier":"/us/usc/t7/s8914/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fc%2F5","sourceRelease":"119-100","text":"In addition to the amount authorized to carry out this subtitle under section 12205, there is authorized to be appropriated to carry out this subsection $15,000,000 for each of fiscal years 2019 through 2023.1See References in Text note below.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"National Plant Disease Recovery System","label":"d National Plant Disease Recovery System","identifier":"/us/usc/t7/s8914/d","parentIdentifier":"/us/usc/t7/s8914","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Recovery System","label":"1 Recovery System","identifier":"/us/usc/t7/s8914/d/1","parentIdentifier":"/us/usc/t7/s8914/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary shall establish in the Department of Agriculture a National Plant Disease Recovery System to engage in strategic long-range planning to recover from high-consequence plant transboundary diseases.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t7/s8914/d/2","parentIdentifier":"/us/usc/t7/s8914/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s8914/d/2/A","parentIdentifier":"/us/usc/t7/s8914/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fd%2F2%2FA","sourceRelease":"119-100","text":"coordinate with disease or pest of concern concept of operations response plans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s8914/d/2/B","parentIdentifier":"/us/usc/t7/s8914/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fd%2F2%2FB","sourceRelease":"119-100","text":"make long-range plans for the initiation of future research projects relating to high-consequence plant transboundary diseases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s8914/d/2/C","parentIdentifier":"/us/usc/t7/s8914/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fd%2F2%2FC","sourceRelease":"119-100","text":"establish research plans for long-term recovery;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s8914/d/2/D","parentIdentifier":"/us/usc/t7/s8914/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fd%2F2%2FD","sourceRelease":"119-100","text":"plan for the identification and use of specific genotypes, cultivars, breeding lines, and other disease-resistant materials necessary for crop stabilization or improvement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s8914/d/2/E","parentIdentifier":"/us/usc/t7/s8914/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fd%2F2%2FE","sourceRelease":"119-100","text":"establish a watch list of high-consequence plant transboundary diseases for the purpose of making long-range plans under subparagraph (B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
