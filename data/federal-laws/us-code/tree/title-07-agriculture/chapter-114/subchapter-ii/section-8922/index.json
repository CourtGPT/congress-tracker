:null,"label":"2","identifier":"/us/usc/t7/s8922/e/2","parentIdentifier":"/us/usc/t7/s8922/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8922%2Fe%2F2","sourceRelease":"119-100","text":"$5,000,000 for each of fiscal years 2014 through 2023, to remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
