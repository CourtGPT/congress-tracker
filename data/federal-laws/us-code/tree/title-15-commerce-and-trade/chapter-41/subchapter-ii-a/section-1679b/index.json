ndments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s1679b/a/1/B","parentIdentifier":"/us/usc/t15/s1679b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679b%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s1679b/a/1/B/i","parentIdentifier":"/us/usc/t15/s1679b/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679b%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"who has extended credit to the consumer; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s1679b/a/1/B/ii","parentIdentifier":"/us/usc/t15/s1679b/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679b%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"to whom the consumer has applied or is applying for an extension of credit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s1679b/a/2","parentIdentifier":"/us/usc/t15/s1679b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679b%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s1679b/a/2/A","parentIdentifier":"/us/usc/t15/s1679b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679b%2Fa%2F2%2FA","sourceRelease":"119-100","text":"any consumer reporting agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s1679b/a/2/B","parentIdentifier":"/us/usc/t15/s1679b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679b%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s1679b/a/2/B/i","parentIdentifier":"/us/usc/t15/s1679b/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679b%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"who has extended credit to the consumer; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s1679b/a/2/B/ii","parentIdentifier":"/us/usc/t15/s1679b/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679b%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"to whom the consumer has applied or is applying for an extension of credit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s1679b/a/3","parentIdentifier":"/us/usc/t15/s1679b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679b%2Fa%2F3","sourceRelease":"119-100","text":"make or use any untrue or misleading representation of the services of the credit repair organization; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s1679b/a/4","parentIdentifier":"/us/usc/t15/s1679b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679b%2Fa%2F4","sourceRelease":"119-100","text":"engage, directly or indirectly, in any act, practice, or course of business that constitutes or results in the commission of, or an attempt to commit, a fraud or deception on any person in connection with the offer or sale of the services of the credit repair organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Payment in advance","label":"b Payment in advance","identifier":"/us/usc/t15/s1679b/b","parentIdentifier":"/us/usc/t15/s1679b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1679b%2Fb","sourceRelease":"119-100","text":"No credit repair organization may charge or receive any money or other valuable consideration for the performance of any service which the credit repair organization has agreed to perform for any consumer before such service is fully performed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
