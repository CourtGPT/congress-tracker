{"type":"section","nativeType":"section","number":"7505","heading":"Grants","label":"7505 Grants","identifier":"/us/usc/t16/s7505","parentIdentifier":"/us/usc/t16/ch94","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in Text, referred to in subsec. (b), was in the original “section 904”, meaning , which is classified to , but probably should have been a reference to , which is classified to . See subsec. (c)(1) of this section.Section 7503 of this titlesection 904 of div. O of Pub. L. 114–113section 7503 of this titlesection 905 of div. O of Pub. L. 114–113section 7504 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Administration of grants","label":"a Administration of grants","identifier":"/us/usc/t16/s7505/a","parentIdentifier":"/us/usc/t16/s7505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s7505/a/1","parentIdentifier":"/us/usc/t16/s7505/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s7505/a/1/A","parentIdentifier":"/us/usc/t16/s7505/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FA","sourceRelease":"119-100","text":"Application and review procedures for the awarding of grants under this section, including requirements ensuring that any amounts awarded under such subsections may only be used for an eligible use described under .section 7504 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s7505/a/1/B","parentIdentifier":"/us/usc/t16/s7505/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s7505/a/1/B/i","parentIdentifier":"/us/usc/t16/s7505/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"require consultation with the Administrator and the Secretary of the Interior; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s7505/a/1/B/ii","parentIdentifier":"/us/usc/t16/s7505/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"prioritize the projects or activities where non-Federal partners have committed to share the cost of the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s7505/a/1/C","parentIdentifier":"/us/usc/t16/s7505/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s7505/a/1/C/i","parentIdentifier":"/us/usc/t16/s7505/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FC%2Fi","sourceRelease":"119-100","text":"under subsection (b) to coastal States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s7505/a/1/C/ii","parentIdentifier":"/us/usc/t16/s7505/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FC%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s7505/a/1/C/ii/I","parentIdentifier":"/us/usc/t16/s7505/a/1/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FC%2Fii%2FI","sourceRelease":"119-100","text":"entities including States, local governments, and Indian tribes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s7505/a/1/C/ii/II","parentIdentifier":"/us/usc/t16/s7505/a/1/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FC%2Fii%2FII","sourceRelease":"119-100","text":"the research and restoration work of associations, nongovernmental organizations, public-private partnerships, and academic institutions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s7505/a/1/D","parentIdentifier":"/us/usc/t16/s7505/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FD","sourceRelease":"119-100","text":"Performance accountability and monitoring measures for programs and activities funded by a grant awarded under subsection (b) or (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s7505/a/1/E","parentIdentifier":"/us/usc/t16/s7505/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FE","sourceRelease":"119-100","text":"Procedures and methods to ensure accurate accounting and appropriate administration of grants awarded under this section, including standards of recordkeeping.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t16/s7505/a/1/F","parentIdentifier":"/us/usc/t16/s7505/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FF","sourceRelease":"119-100","text":"Procedures to carry out audits of the Fund as necessary, but not less frequently than once every year if grants have been awarded in that year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t16/s7505/a/1/G","parentIdentifier":"/us/usc/t16/s7505/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FG","sourceRelease":"119-100","text":"Procedures to carry out audits of the recipients of grants under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t16/s7505/a/1/H","parentIdentifier":"/us/usc/t16/s7505/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F1%2FH","sourceRelease":"119-100","text":"Procedures to make publicly available on the Internet a list of all projects funded by the Fund, that includes at a minimum the grant recipient, grant amount, project description, and project status.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Approval","label":"2 Approval","identifier":"/us/usc/t16/s7505/a/2","parentIdentifier":"/us/usc/t16/s7505/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fa%2F2","sourceRelease":"119-100","text":"The Foundation shall submit to the Administrator for approval each procedure, measure, method, and standard established under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Grants to coastal States","label":"b Grants to coastal States","identifier":"/us/usc/t16/s7505/b","parentIdentifier":"/us/usc/t16/s7505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s7505/b/1","parentIdentifier":"/us/usc/t16/s7505/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s7505/b/1/A","parentIdentifier":"/us/usc/t16/s7505/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s7505/b/1/A/i","parentIdentifier":"/us/usc/t16/s7505/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"percent of total United States shoreline miles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s7505/b/1/A/ii","parentIdentifier":"/us/usc/t16/s7505/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"coastal population density; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s7505/b/1/A/iii","parentIdentifier":"/us/usc/t16/s7505/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fb%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"other factors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s7505/b/1/B","parentIdentifier":"/us/usc/t16/s7505/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fb%2F1%2FB","sourceRelease":"119-100","text":"establish criteria for States, including the requirement for a State to establish a plan to distribute the funds; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s7505/b/1/C","parentIdentifier":"/us/usc/t16/s7505/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fb%2F1%2FC","sourceRelease":"119-100","text":"establish a maximum and minimum percentage of funding to be awarded to each State or United States territory.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Indian tribes","label":"2 Indian tribes","identifier":"/us/usc/t16/s7505/b/2","parentIdentifier":"/us/usc/t16/s7505/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fb%2F2","sourceRelease":"119-100","text":"As a condition on receipt of a grant under this subsection, a State that receives a grant under this subsection shall ensure that Indian tribes in the State are eligible to participate in any competitive grants established in this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"National grants for oceans, coasts, and Great Lakes","label":"c National grants for oceans, coasts, and Great Lakes","identifier":"/us/usc/t16/s7505/c","parentIdentifier":"/us/usc/t16/s7505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s7505/c/1","parentIdentifier":"/us/usc/t16/s7505/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fc%2F1","sourceRelease":"119-100","text":"The Administrator and the Foundation may award grants according to the procedures established in subsection (a) to support activities consistent with .section 7504 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Advisory panel","label":"2 Advisory panel","identifier":"/us/usc/t16/s7505/c/2","parentIdentifier":"/us/usc/t16/s7505/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s7505/c/2/A","parentIdentifier":"/us/usc/t16/s7505/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fc%2F2%2FA","sourceRelease":"119-100","text":"The Foundation may establish an advisory panel to conduct reviews of applications for grants under paragraph (1) and the Foundation may consider the recommendations of the advisory panel with respect to such applications.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Membership","label":"B Membership","identifier":"/us/usc/t16/s7505/c/2/B","parentIdentifier":"/us/usc/t16/s7505/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s7505/c/2/B/i","parentIdentifier":"/us/usc/t16/s7505/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"ocean and coastal dependent industries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s7505/c/2/B/ii","parentIdentifier":"/us/usc/t16/s7505/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"geographic regions as defined by the Foundation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s7505/c/2/B/iii","parentIdentifier":"/us/usc/t16/s7505/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7505%2Fc%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"academic institutions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
