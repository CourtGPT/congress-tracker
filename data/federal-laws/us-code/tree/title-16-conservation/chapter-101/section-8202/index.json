{"type":"section","nativeType":"section","number":"8202","heading":"Definitions","label":"8202 Definitions","identifier":"/us/usc/t16/s8202","parentIdentifier":"/us/usc/t16/ch101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Appropriate congressional committees","label":"1 Appropriate congressional committees","identifier":"/us/usc/t16/s8202/1","parentIdentifier":"/us/usc/t16/s8202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8202/1/A","parentIdentifier":"/us/usc/t16/s8202/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F1%2FA","sourceRelease":"119-100","text":"the Committee on Commerce, Science, and Transportation and the Committee on Environment and Public Works of the Senate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8202/1/B","parentIdentifier":"/us/usc/t16/s8202/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F1%2FB","sourceRelease":"119-100","text":"the Committee on Natural Resources of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Board","label":"2 Board","identifier":"/us/usc/t16/s8202/2","parentIdentifier":"/us/usc/t16/s8202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F2","sourceRelease":"119-100","text":"The term “Board” means the National Fish Habitat Board established by .section 8203 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Director","label":"3 Director","identifier":"/us/usc/t16/s8202/3","parentIdentifier":"/us/usc/t16/s8202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F3","sourceRelease":"119-100","text":"The term “Director” means the Director of the United States Fish and Wildlife Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Environmental Protection Agency Assistant Administrator","label":"4 Environmental Protection Agency Assistant Administrator","identifier":"/us/usc/t16/s8202/4","parentIdentifier":"/us/usc/t16/s8202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F4","sourceRelease":"119-100","text":"The term “Environmental Protection Agency Assistant Administrator” means the Assistant Administrator for Water of the Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Indian Tribe","label":"5 Indian Tribe","identifier":"/us/usc/t16/s8202/5","parentIdentifier":"/us/usc/t16/s8202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F5","sourceRelease":"119-100","text":"The term “Indian Tribe” has the meaning given to the term “Indian tribe” in .section 5304 of title 25","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"National Oceanic and Atmospheric Administration Assistant Administrator","label":"6 National Oceanic and Atmospheric Administration Assistant Administrator","identifier":"/us/usc/t16/s8202/6","parentIdentifier":"/us/usc/t16/s8202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F6","sourceRelease":"119-100","text":"The term “National Oceanic and Atmospheric Administration Assistant Administrator” means the Assistant Administrator for Fisheries of the National Oceanic and Atmospheric Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Partnership","label":"7 Partnership","identifier":"/us/usc/t16/s8202/7","parentIdentifier":"/us/usc/t16/s8202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F7","sourceRelease":"119-100","text":"The term “Partnership” means an entity designated by Congress as a Fish Habitat Partnership under .section 8204 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Real property interest","label":"8 Real property interest","identifier":"/us/usc/t16/s8202/8","parentIdentifier":"/us/usc/t16/s8202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8202/8/A","parentIdentifier":"/us/usc/t16/s8202/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F8%2FA","sourceRelease":"119-100","text":"land; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8202/8/B","parentIdentifier":"/us/usc/t16/s8202/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F8%2FB","sourceRelease":"119-100","text":"water (including water rights).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":"Marine Fisheries Commissions","label":"9 Marine Fisheries Commissions","identifier":"/us/usc/t16/s8202/9","parentIdentifier":"/us/usc/t16/s8202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F9","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8202/9/A","parentIdentifier":"/us/usc/t16/s8202/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F9%2FA","sourceRelease":"119-100","text":"the Atlantic States Marine Fisheries Commission;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8202/9/B","parentIdentifier":"/us/usc/t16/s8202/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F9%2FB","sourceRelease":"119-100","text":"the Gulf States Marine Fisheries Commission; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8202/9/C","parentIdentifier":"/us/usc/t16/s8202/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F9%2FC","sourceRelease":"119-100","text":"the Pacific States Marine Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":"Secretary","label":"10 Secretary","identifier":"/us/usc/t16/s8202/10","parentIdentifier":"/us/usc/t16/s8202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F10","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of the Interior.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":"State","label":"11 State","identifier":"/us/usc/t16/s8202/11","parentIdentifier":"/us/usc/t16/s8202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F11","sourceRelease":"119-100","text":"The term “State” means each of the several States, Puerto Rico, American Samoa, Guam, the Northern Mariana Islands, the United States Virgin Islands, and the District of Columbia.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":"State agency","label":"12 State agency","identifier":"/us/usc/t16/s8202/12","parentIdentifier":"/us/usc/t16/s8202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F12","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8202/12/A","parentIdentifier":"/us/usc/t16/s8202/12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F12%2FA","sourceRelease":"119-100","text":"the fish and wildlife agency of a State; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8202/12/B","parentIdentifier":"/us/usc/t16/s8202/12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8202%2F12%2FB","sourceRelease":"119-100","text":"any department or division of a department or agency of a State that manages in the public trust the inland or marine fishery resources of the State or sustains the habitat for those fishery resources pursuant to State law or the constitution of the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
