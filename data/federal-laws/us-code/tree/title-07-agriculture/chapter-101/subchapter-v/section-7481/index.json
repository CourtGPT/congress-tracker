{"type":"section","nativeType":"section","number":"7481","heading":"Findings and declaration of policy","label":"7481 Findings and declaration of policy","identifier":"/us/usc/t7/s7481","parentIdentifier":"/us/usc/t7/ch101/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Findings","label":"a Findings","identifier":"/us/usc/t7/s7481/a","parentIdentifier":"/us/usc/t7/s7481","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7481/a/1","parentIdentifier":"/us/usc/t7/s7481/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fa%2F1","sourceRelease":"119-100","text":"popcorn is an important food that is a valuable part of the human diet;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7481/a/2","parentIdentifier":"/us/usc/t7/s7481/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fa%2F2","sourceRelease":"119-100","text":"the production and processing of popcorn plays a significant role in the economy of the United States in that popcorn is processed by several popcorn processors, distributed through wholesale and retail outlets, and consumed by millions of people throughout the United States and foreign countries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7481/a/3","parentIdentifier":"/us/usc/t7/s7481/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fa%2F3","sourceRelease":"119-100","text":"popcorn must be of high quality, readily available, handled properly, and marketed efficiently to ensure that the benefits of popcorn are available to the people of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s7481/a/4","parentIdentifier":"/us/usc/t7/s7481/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fa%2F4","sourceRelease":"119-100","text":"the maintenance and expansion of existing markets and uses and the development of new markets and uses for popcorn are vital to the welfare of processors and persons concerned with marketing, using, and producing popcorn for the market, as well as to the agricultural economy of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s7481/a/5","parentIdentifier":"/us/usc/t7/s7481/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fa%2F5","sourceRelease":"119-100","text":"the cooperative development, financing, and implementation of a coordinated program of popcorn promotion, research, consumer information, and industry information is necessary to maintain and expand markets for popcorn; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s7481/a/6","parentIdentifier":"/us/usc/t7/s7481/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fa%2F6","sourceRelease":"119-100","text":"popcorn moves in interstate and foreign commerce, and popcorn that does not move in those channels of commerce directly burdens or affects interstate commerce in popcorn.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Policy","label":"b Policy","identifier":"/us/usc/t7/s7481/b","parentIdentifier":"/us/usc/t7/s7481","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7481/b/1","parentIdentifier":"/us/usc/t7/s7481/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fb%2F1","sourceRelease":"119-100","text":"strengthen the position of the popcorn industry in the marketplace; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7481/b/2","parentIdentifier":"/us/usc/t7/s7481/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fb%2F2","sourceRelease":"119-100","text":"maintain and expand domestic and foreign markets and uses for popcorn.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Purposes","label":"c Purposes","identifier":"/us/usc/t7/s7481/c","parentIdentifier":"/us/usc/t7/s7481","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7481/c/1","parentIdentifier":"/us/usc/t7/s7481/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7481/c/1/A","parentIdentifier":"/us/usc/t7/s7481/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fc%2F1%2FA","sourceRelease":"119-100","text":"is not designed to maintain or expand any individual share of a producer or processor of the market;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7481/c/1/B","parentIdentifier":"/us/usc/t7/s7481/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fc%2F1%2FB","sourceRelease":"119-100","text":"does not compete with or replace individual advertising or promotion efforts designed to promote individual brand name or trade name popcorn products; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s7481/c/1/C","parentIdentifier":"/us/usc/t7/s7481/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fc%2F1%2FC","sourceRelease":"119-100","text":"authorizes and funds programs that result in government speech promoting government objectives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7481/c/2","parentIdentifier":"/us/usc/t7/s7481/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fc%2F2","sourceRelease":"119-100","text":"establish a nationally coordinated program for popcorn promotion, research, consumer information, and industry information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Statutory construction","label":"d Statutory construction","identifier":"/us/usc/t7/s7481/d","parentIdentifier":"/us/usc/t7/s7481","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7481/d/1","parentIdentifier":"/us/usc/t7/s7481/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fd%2F1","sourceRelease":"119-100","text":"provides for the imposition of a trade barrier to the entry into the United States of imported popcorn for the domestic market; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7481/d/2","parentIdentifier":"/us/usc/t7/s7481/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7481%2Fd%2F2","sourceRelease":"119-100","text":"provides for the control of production or otherwise limits the right of any individual processor to produce popcorn.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
