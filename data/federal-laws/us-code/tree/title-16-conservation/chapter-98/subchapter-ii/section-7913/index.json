{"type":"section","nativeType":"section","number":"7913","heading":"Closure of Federal land to hunting, fishing, and recreational shooting","label":"7913 Closure of Federal land to hunting, fishing, and recreational shooting","identifier":"/us/usc/t16/s7913","parentIdentifier":"/us/usc/t16/ch98/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authorization","label":"a Authorization","identifier":"/us/usc/t16/s7913/a","parentIdentifier":"/us/usc/t16/s7913","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s7913/a/1","parentIdentifier":"/us/usc/t16/s7913/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fa%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2) and in accordance with , the Secretary concerned may designate any area on Federal land in which, and establish any period during which, for reasons of public safety, administration, or compliance with applicable laws, no hunting, fishing, or recreational shooting shall be permitted.section 1732(b) of title 43","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirement","label":"2 Requirement","identifier":"/us/usc/t16/s7913/a/2","parentIdentifier":"/us/usc/t16/s7913/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fa%2F2","sourceRelease":"119-100","text":"In making a designation under paragraph (1), the Secretary concerned shall designate the smallest area for the least amount of time that is required for public safety, administration, or compliance with applicable laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Closure procedures","label":"b Closure procedures","identifier":"/us/usc/t16/s7913/b","parentIdentifier":"/us/usc/t16/s7913","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s7913/b/1","parentIdentifier":"/us/usc/t16/s7913/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s7913/b/1/A","parentIdentifier":"/us/usc/t16/s7913/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F1%2FA","sourceRelease":"119-100","text":"consult with State fish and wildlife agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s7913/b/1/B","parentIdentifier":"/us/usc/t16/s7913/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F1%2FB","sourceRelease":"119-100","text":"provide public notice and opportunity for comment under paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Public notice and comment","label":"2 Public notice and comment","identifier":"/us/usc/t16/s7913/b/2","parentIdentifier":"/us/usc/t16/s7913/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s7913/b/2/A","parentIdentifier":"/us/usc/t16/s7913/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s7913/b/2/A/i","parentIdentifier":"/us/usc/t16/s7913/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s7913/b/2/A/i/I","parentIdentifier":"/us/usc/t16/s7913/b/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA%2Fi%2FI","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t16/s7913/b/2/A/i/I/aa","parentIdentifier":"/us/usc/t16/s7913/b/2/A/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA%2Fi%2FI%2Faa","sourceRelease":"119-100","text":"in the Federal Register;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t16/s7913/b/2/A/i/I/bb","parentIdentifier":"/us/usc/t16/s7913/b/2/A/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA%2Fi%2FI%2Fbb","sourceRelease":"119-100","text":"on the website of the applicable Federal agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"cc","heading":null,"label":"cc","identifier":"/us/usc/t16/s7913/b/2/A/i/I/cc","parentIdentifier":"/us/usc/t16/s7913/b/2/A/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA%2Fi%2FI%2Fcc","sourceRelease":"119-100","text":"on the website of the Federal land unit, if available; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"dd","heading":null,"label":"dd","identifier":"/us/usc/t16/s7913/b/2/A/i/I/dd","parentIdentifier":"/us/usc/t16/s7913/b/2/A/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA%2Fi%2FI%2Fdd","sourceRelease":"119-100","text":"in at least 1 local newspaper;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s7913/b/2/A/i/II","parentIdentifier":"/us/usc/t16/s7913/b/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA%2Fi%2FII","sourceRelease":"119-100","text":"made available in advance of the public comment period to local offices, chapters, and affiliate organizations in the vicinity of the closure that are signatories to the memorandum of understanding entitled “Federal Lands Hunting, Fishing, and Shooting Sports Roundtable Memorandum of Understanding”; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s7913/b/2/A/i/III","parentIdentifier":"/us/usc/t16/s7913/b/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA%2Fi%2FIII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t16/s7913/b/2/A/i/III/aa","parentIdentifier":"/us/usc/t16/s7913/b/2/A/i/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA%2Fi%2FIII%2Faa","sourceRelease":"119-100","text":"the proposed closure; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t16/s7913/b/2/A/i/III/bb","parentIdentifier":"/us/usc/t16/s7913/b/2/A/i/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA%2Fi%2FIII%2Fbb","sourceRelease":"119-100","text":"the justification for the proposed closure, including an explanation of the reasons and necessity for the decision to close the area to hunting, fishing, or recreational shooting; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s7913/b/2/A/ii","parentIdentifier":"/us/usc/t16/s7913/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s7913/b/2/A/ii/I","parentIdentifier":"/us/usc/t16/s7913/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA%2Fii%2FI","sourceRelease":"119-100","text":"not less than 60 days for a permanent closure; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s7913/b/2/A/ii/II","parentIdentifier":"/us/usc/t16/s7913/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FA%2Fii%2FII","sourceRelease":"119-100","text":"not less than 30 days for a temporary closure.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Final decision","label":"B Final decision","identifier":"/us/usc/t16/s7913/b/2/B","parentIdentifier":"/us/usc/t16/s7913/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s7913/b/2/B/i","parentIdentifier":"/us/usc/t16/s7913/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"respond in a reasoned manner to the comments received;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s7913/b/2/B/ii","parentIdentifier":"/us/usc/t16/s7913/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"explain how the Secretary concerned resolved any significant issues raised by the comments; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s7913/b/2/B/iii","parentIdentifier":"/us/usc/t16/s7913/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"show how the resolution led to the closure.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Temporary closures","label":"c Temporary closures","identifier":"/us/usc/t16/s7913/c","parentIdentifier":"/us/usc/t16/s7913","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s7913/c/1","parentIdentifier":"/us/usc/t16/s7913/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fc%2F1","sourceRelease":"119-100","text":"A temporary closure under this section may not exceed a period of 180 days.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Renewal","label":"2 Renewal","identifier":"/us/usc/t16/s7913/c/2","parentIdentifier":"/us/usc/t16/s7913/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s7913/c/2/A","parentIdentifier":"/us/usc/t16/s7913/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fc%2F2%2FA","sourceRelease":"119-100","text":"may not be renewed more than 3 times after the first temporary closure; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s7913/c/2/B","parentIdentifier":"/us/usc/t16/s7913/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fc%2F2%2FB","sourceRelease":"119-100","text":"must be subject to a separate notice and comment procedure in accordance with subsection (b)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Effect of temporary closure","label":"3 Effect of temporary closure","identifier":"/us/usc/t16/s7913/c/3","parentIdentifier":"/us/usc/t16/s7913/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fc%2F3","sourceRelease":"119-100","text":"Any Federal land that is temporarily closed to hunting, fishing, or recreational shooting under this section shall not become permanently closed to that activity without a separate public notice and opportunity to comment in accordance with subsection (b)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Reporting","label":"d Reporting","identifier":"/us/usc/t16/s7913/d","parentIdentifier":"/us/usc/t16/s7913","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s7913/d/1","parentIdentifier":"/us/usc/t16/s7913/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fd%2F1","sourceRelease":"119-100","text":"publish on a public website a list of all areas of Federal land temporarily or permanently subject to a closure under this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s7913/d/2","parentIdentifier":"/us/usc/t16/s7913/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s7913/d/2/A","parentIdentifier":"/us/usc/t16/s7913/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fd%2F2%2FA","sourceRelease":"119-100","text":"a list of each area of Federal land temporarily or permanently subject to a closure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s7913/d/2/B","parentIdentifier":"/us/usc/t16/s7913/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fd%2F2%2FB","sourceRelease":"119-100","text":"the acreage of each closure; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s7913/d/2/C","parentIdentifier":"/us/usc/t16/s7913/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fd%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s7913/d/2/C/i","parentIdentifier":"/us/usc/t16/s7913/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fd%2F2%2FC%2Fi","sourceRelease":"119-100","text":"the aggregate areas and acreage closed under this section in each State; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s7913/d/2/C/ii","parentIdentifier":"/us/usc/t16/s7913/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fd%2F2%2FC%2Fii","sourceRelease":"119-100","text":"the percentage of Federal land in each State closed under this section with respect to hunting, fishing, and recreational shooting.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Application","label":"e Application","identifier":"/us/usc/t16/s7913/e","parentIdentifier":"/us/usc/t16/s7913","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s7913/e/1","parentIdentifier":"/us/usc/t16/s7913/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fe%2F1","sourceRelease":"119-100","text":"less than 14 days in duration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s7913/e/2","parentIdentifier":"/us/usc/t16/s7913/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7913%2Fe%2F2","sourceRelease":"119-100","text":"covered by a special use permit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
