{"type":"section","nativeType":"section","number":"3665a","heading":"Office of Tribal Justice","label":"3665a Office of Tribal Justice","identifier":"/us/usc/t25/s3665a","parentIdentifier":"/us/usc/t25/ch38A/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3665a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsA prior was renumbered section 107 and is classified to .section 106 of Pub. L. 106–559section 3666 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t25/s3665a/a","parentIdentifier":"/us/usc/t25/s3665a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3665a%2Fa","sourceRelease":"119-100","text":"Not later than 90 days after , the Attorney General shall establish the Office of Tribal Justice as a component of the Department.July 29, 2010","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Personnel and funding","label":"b Personnel and funding","identifier":"/us/usc/t25/s3665a/b","parentIdentifier":"/us/usc/t25/s3665a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3665a%2Fb","sourceRelease":"119-100","text":"The Attorney General shall provide to the Office of Tribal Justice such personnel and funds as are necessary to establish the Office of Tribal Justice as a component of the Department under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duties","label":"c Duties","identifier":"/us/usc/t25/s3665a/c","parentIdentifier":"/us/usc/t25/s3665a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3665a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s3665a/c/1","parentIdentifier":"/us/usc/t25/s3665a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3665a%2Fc%2F1","sourceRelease":"119-100","text":"serve as the program and legal policy advisor to the Attorney General with respect to the treaty and trust relationship between the United States and Indian tribes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s3665a/c/2","parentIdentifier":"/us/usc/t25/s3665a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3665a%2Fc%2F2","sourceRelease":"119-100","text":"serve as the point of contact for federally recognized tribal governments and tribal organizations with respect to questions and comments regarding policies and programs of the Department and issues relating to public safety and justice in Indian country; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s3665a/c/3","parentIdentifier":"/us/usc/t25/s3665a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3665a%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3665a/c/3/A","parentIdentifier":"/us/usc/t25/s3665a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3665a%2Fc%2F3%2FA","sourceRelease":"119-100","text":"the trust responsibility of the United States to Indian tribes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3665a/c/3/B","parentIdentifier":"/us/usc/t25/s3665a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3665a%2Fc%2F3%2FB","sourceRelease":"119-100","text":"any tribal treaty provision;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s3665a/c/3/C","parentIdentifier":"/us/usc/t25/s3665a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3665a%2Fc%2F3%2FC","sourceRelease":"119-100","text":"the status of Indian tribes as sovereign governments; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s3665a/c/3/D","parentIdentifier":"/us/usc/t25/s3665a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3665a%2Fc%2F3%2FD","sourceRelease":"119-100","text":"any other tribal interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
