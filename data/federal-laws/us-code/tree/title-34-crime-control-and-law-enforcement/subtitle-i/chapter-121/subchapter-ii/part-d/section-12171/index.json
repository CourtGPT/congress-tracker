{"type":"section","nativeType":"section","number":"12171","heading":"Grant authority","label":"12171 Grant authority","identifier":"/us/usc/t34/s12171","parentIdentifier":"/us/usc/t34/stI/ch121/schII/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to , The Public Health and Welfare, prior to editorial reclassification and renumbering as this section.section 13811 of Title 42"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Grants","label":"a Grants","identifier":"/us/usc/t34/s12171/a","parentIdentifier":"/us/usc/t34/s12171","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t34/s12171/a/1","parentIdentifier":"/us/usc/t34/s12171/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fa%2F1","sourceRelease":"119-100","text":"The Attorney General may make grants to qualified community organizations to assist in meeting the costs of qualified programs which are designed to recruit and retain applicants to police departments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Consultation with the Ounce of Prevention Council","label":"2 Consultation with the Ounce of Prevention Council","identifier":"/us/usc/t34/s12171/a/2","parentIdentifier":"/us/usc/t34/s12171/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fa%2F2","sourceRelease":"119-100","text":"The Attorney General may consult with the Ounce of Prevention Council in making grants under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Qualified community organizations","label":"b Qualified community organizations","identifier":"/us/usc/t34/s12171/b","parentIdentifier":"/us/usc/t34/s12171","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s12171/b/1","parentIdentifier":"/us/usc/t34/s12171/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fb%2F1","sourceRelease":"119-100","text":"is a nonprofit organization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s12171/b/2","parentIdentifier":"/us/usc/t34/s12171/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s12171/b/2/A","parentIdentifier":"/us/usc/t34/s12171/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fb%2F2%2FA","sourceRelease":"119-100","text":"working with a police department and with teachers, counselors, and similar personnel,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s12171/b/2/B","parentIdentifier":"/us/usc/t34/s12171/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fb%2F2%2FB","sourceRelease":"119-100","text":"providing services to the community in which the organization is located,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s12171/b/2/C","parentIdentifier":"/us/usc/t34/s12171/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fb%2F2%2FC","sourceRelease":"119-100","text":"developing and managing services and techniques to recruit individuals to become members of a police department and to assist such individuals in meeting the membership requirements of police departments,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s12171/b/2/D","parentIdentifier":"/us/usc/t34/s12171/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fb%2F2%2FD","sourceRelease":"119-100","text":"developing and managing services and techniques to assist in the retention of applicants to police departments, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t34/s12171/b/2/E","parentIdentifier":"/us/usc/t34/s12171/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fb%2F2%2FE","sourceRelease":"119-100","text":"developing other programs that contribute to the community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Qualified programs","label":"c Qualified programs","identifier":"/us/usc/t34/s12171/c","parentIdentifier":"/us/usc/t34/s12171","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s12171/c/1","parentIdentifier":"/us/usc/t34/s12171/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fc%2F1","sourceRelease":"119-100","text":"the overall design of the program is to recruit and retain applicants to a police department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s12171/c/2","parentIdentifier":"/us/usc/t34/s12171/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fc%2F2","sourceRelease":"119-100","text":"the program provides recruiting services which include tutorial programs to enable individuals to meet police force academic requirements and to pass entrance examinations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s12171/c/3","parentIdentifier":"/us/usc/t34/s12171/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fc%2F3","sourceRelease":"119-100","text":"the program provides counseling to applicants to police departments who may encounter problems throughout the application process; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t34/s12171/c/4","parentIdentifier":"/us/usc/t34/s12171/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fc%2F4","sourceRelease":"119-100","text":"the program provides retention services to assist in retaining individuals to stay in the application process of a police department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Applications","label":"d Applications","identifier":"/us/usc/t34/s12171/d","parentIdentifier":"/us/usc/t34/s12171","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s12171/d/1","parentIdentifier":"/us/usc/t34/s12171/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s12171/d/1/A","parentIdentifier":"/us/usc/t34/s12171/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the need for the grant;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s12171/d/1/B","parentIdentifier":"/us/usc/t34/s12171/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fd%2F1%2FB","sourceRelease":"119-100","text":"the intended use of grant funds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s12171/d/1/C","parentIdentifier":"/us/usc/t34/s12171/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fd%2F1%2FC","sourceRelease":"119-100","text":"expected results from the use of grant funds; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s12171/d/1/D","parentIdentifier":"/us/usc/t34/s12171/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fd%2F1%2FD","sourceRelease":"119-100","text":"demographic characteristics of the population to be served, including age, disability, race, ethnicity, and languages used; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s12171/d/2","parentIdentifier":"/us/usc/t34/s12171/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fd%2F2","sourceRelease":"119-100","text":"contain assurances satisfactory to the Attorney General that the program for which a grant is made will meet the applicable requirements of the program guidelines prescribed by the Attorney General under subsection (i).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Action by Attorney General","label":"e Action by Attorney General","identifier":"/us/usc/t34/s12171/e","parentIdentifier":"/us/usc/t34/s12171","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s12171/e/1","parentIdentifier":"/us/usc/t34/s12171/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fe%2F1","sourceRelease":"119-100","text":"approve the application and disburse the grant funds applied for; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s12171/e/2","parentIdentifier":"/us/usc/t34/s12171/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fe%2F2","sourceRelease":"119-100","text":"disapprove the application and inform the applicant that the application is not approved and provide the applicant with the reasons for the disapproval.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Grant disbursement","label":"f Grant disbursement","identifier":"/us/usc/t34/s12171/f","parentIdentifier":"/us/usc/t34/s12171","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s12171/f/1","parentIdentifier":"/us/usc/t34/s12171/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Ff%2F1","sourceRelease":"119-100","text":"priority is given to applications for areas and organizations with the greatest showing of need;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s12171/f/2","parentIdentifier":"/us/usc/t34/s12171/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Ff%2F2","sourceRelease":"119-100","text":"that grant funds are equitably distributed on a geographic basis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s12171/f/3","parentIdentifier":"/us/usc/t34/s12171/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Ff%2F3","sourceRelease":"119-100","text":"the needs of underserved populations are recognized and addressed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Grant period","label":"g Grant period","identifier":"/us/usc/t34/s12171/g","parentIdentifier":"/us/usc/t34/s12171","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fg","sourceRelease":"119-100","text":"A grant under subsection (a) shall be made for a period not longer than 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Grantee reporting","label":"h Grantee reporting","identifier":"/us/usc/t34/s12171/h","parentIdentifier":"/us/usc/t34/s12171","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s12171/h/1","parentIdentifier":"/us/usc/t34/s12171/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fh%2F1","sourceRelease":"119-100","text":"For each year of a grant period for a grant under subsection (a), the recipient of the grant shall file a performance report with the Attorney General explaining the activities carried out with the funds received and assessing the effectiveness of such activities in meeting the purpose of the recipient’s qualified program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s12171/h/2","parentIdentifier":"/us/usc/t34/s12171/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fh%2F2","sourceRelease":"119-100","text":"If there was more than one recipient of a grant, each recipient shall file such report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s12171/h/3","parentIdentifier":"/us/usc/t34/s12171/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fh%2F3","sourceRelease":"119-100","text":"The Attorney General shall suspend the funding of a grant, pending compliance, if the recipient of the grant does not file the report required by this subsection or uses the grant for a purpose not authorized by this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Guidelines","label":"i Guidelines","identifier":"/us/usc/t34/s12171/i","parentIdentifier":"/us/usc/t34/s12171","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s12171/i/1","parentIdentifier":"/us/usc/t34/s12171/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fi%2F1","sourceRelease":"119-100","text":"individuals providing recruiting services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s12171/i/2","parentIdentifier":"/us/usc/t34/s12171/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fi%2F2","sourceRelease":"119-100","text":"individuals providing tutorials and other academic assistance programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s12171/i/3","parentIdentifier":"/us/usc/t34/s12171/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fi%2F3","sourceRelease":"119-100","text":"individuals providing retention services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t34/s12171/i/4","parentIdentifier":"/us/usc/t34/s12171/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12171%2Fi%2F4","sourceRelease":"119-100","text":"the content and duration of recruitment, retention, and counseling programs and the means and devices used to publicize such programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
