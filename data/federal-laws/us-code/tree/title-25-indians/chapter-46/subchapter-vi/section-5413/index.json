/t25/s5413/a/3","parentIdentifier":"/us/usc/t25/s5413/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5413%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s5413/a/3/A","parentIdentifier":"/us/usc/t25/s5413/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5413%2Fa%2F3%2FA","sourceRelease":"119-100","text":"services provided under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s5413/a/3/B","parentIdentifier":"/us/usc/t25/s5413/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5413%2Fa%2F3%2FB","sourceRelease":"119-100","text":"funds provided under paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Reimbursement","label":"b Reimbursement","identifier":"/us/usc/t25/s5413/b","parentIdentifier":"/us/usc/t25/s5413","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5413%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s5413/b/1","parentIdentifier":"/us/usc/t25/s5413/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5413%2Fb%2F1","sourceRelease":"119-100","text":"shall be deposited in the Treasury of the United States to the credit of the applicable appropriations account; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s541