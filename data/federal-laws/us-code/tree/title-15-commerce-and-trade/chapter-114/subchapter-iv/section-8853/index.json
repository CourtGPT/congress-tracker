{"type":"section","nativeType":"section","number":"8853","heading":"Department of Energy quantum network infrastructure research and development program","label":"8853 Department of Energy quantum network infrastructure research and development program","identifier":"/us/usc/t15/s8853","parentIdentifier":"/us/usc/t15/ch114/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s8853/a","parentIdentifier":"/us/usc/t15/s8853","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8853/a/1","parentIdentifier":"/us/usc/t15/s8853/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fa%2F1","sourceRelease":"119-100","text":"facilitate the advancement of distributed quantum computing systems through the internet and intranet;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8853/a/2","parentIdentifier":"/us/usc/t15/s8853/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fa%2F2","sourceRelease":"119-100","text":"improve the precision of measurements of scientific phenomena and physical imaging technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8853/a/3","parentIdentifier":"/us/usc/t15/s8853/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fa%2F3","sourceRelease":"119-100","text":"develop secure national quantum communications technologies and strategies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s8853/a/4","parentIdentifier":"/us/usc/t15/s8853/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fa%2F4","sourceRelease":"119-100","text":"demonstrate quantum networking utilizing the Department of Energy’s Energy Sciences Network User Facility; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s8853/a/5","parentIdentifier":"/us/usc/t15/s8853/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fa%2F5","sourceRelease":"119-100","text":"advance the relevant domestic supply chains, manufacturing capabilities, and associated simulations or modeling capabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Program","label":"b Program","identifier":"/us/usc/t15/s8853/b","parentIdentifier":"/us/usc/t15/s8853","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8853/b/1","parentIdentifier":"/us/usc/t15/s8853/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8853/b/1/A","parentIdentifier":"/us/usc/t15/s8853/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the Director of the National Science Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8853/b/1/B","parentIdentifier":"/us/usc/t15/s8853/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the Director of the National Institute of Standards and Technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s8853/b/1/C","parentIdentifier":"/us/usc/t15/s8853/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the Chair of the Subcommittee on Quantum Information Science of the National Science and Technology Council established under ; andsection 8813(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s8853/b/1/D","parentIdentifier":"/us/usc/t15/s8853/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F1%2FD","sourceRelease":"119-100","text":"the Chair of the Subcommittee on the Economic and Security Implications of Quantum Science;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8853/b/2","parentIdentifier":"/us/usc/t15/s8853/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8853/b/2/A","parentIdentifier":"/us/usc/t15/s8853/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F2%2FA","sourceRelease":"119-100","text":"quantum-limited detectors, ultra-low loss optical channels, space-to-ground connections, and classical networking and cybersecurity protocols;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8853/b/2/B","parentIdentifier":"/us/usc/t15/s8853/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F2%2FB","sourceRelease":"119-100","text":"entanglement and hyper-entangled state sources and transmission, control, and measurement of quantum states;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s8853/b/2/C","parentIdentifier":"/us/usc/t15/s8853/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F2%2FC","sourceRelease":"119-100","text":"quantum interconnects that allow short range local connections between quantum processors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s8853/b/2/D","parentIdentifier":"/us/usc/t15/s8853/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F2%2FD","sourceRelease":"119-100","text":"transducers for quantum sources and signals between optical wavelength regimes, including telecommunications regimes and quantum computer-relevant domains, including microwaves;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s8853/b/2/E","parentIdentifier":"/us/usc/t15/s8853/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F2%2FE","sourceRelease":"119-100","text":"development of quantum memory buffers and small-scale quantum computers that are compatible with photon-based quantum bits in the optical or telecommunications wavelengths;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t15/s8853/b/2/F","parentIdentifier":"/us/usc/t15/s8853/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F2%2FF","sourceRelease":"119-100","text":"long-range entanglement distribution, including allowing entanglement-based protocols between small- and large scale quantum processors, at the terrestrial and space-based level using quantum repeaters and optical or laser communications;1So in original. Probably should be followed by a hyphen.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t15/s8853/b/2/G","parentIdentifier":"/us/usc/t15/s8853/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F2%2FG","sourceRelease":"119-100","text":"quantum routers, multiplexers, repeaters, and related technologies necessary to create secure long-distance quantum communication; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t15/s8853/b/2/H","parentIdentifier":"/us/usc/t15/s8853/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F2%2FH","sourceRelease":"119-100","text":"integration of systems across the quantum technology stack into traditional computing networks, including the development of remote controlled, high-performance, and reliable implementations of key quantum network components by leveraging the expertise, infrastructure and supplemental investments at the National Laboratories in the Energy Sciences Network User Facility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8853/b/3","parentIdentifier":"/us/usc/t15/s8853/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F3","sourceRelease":"119-100","text":"engage with the Quantum Economic Development Consortium and other organizations, as applicable, to transition component technologies to help facilitate as appropriate the development of a quantum supply chain for quantum network technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s8853/b/4","parentIdentifier":"/us/usc/t15/s8853/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F4","sourceRelease":"119-100","text":"advance basic research in advanced scientific computing, particle and nuclear physics, and material science to enhance the understanding, prediction, and manipulation of materials, processes, and physical phenomena relevant to quantum network infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s8853/b/5","parentIdentifier":"/us/usc/t15/s8853/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F5","sourceRelease":"119-100","text":"develop experimental tools and testbeds in collaboration with the Energy Sciences Network User Facility necessary to support cross-cutting fundamental research and development activities with diverse stakeholders from industry, National Laboratories, and institutions of higher education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s8853/b/6","parentIdentifier":"/us/usc/t15/s8853/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fb%2F6","sourceRelease":"119-100","text":"consider quantum network infrastructure applications that span the Department of Energy’s missions in energy, environment, and national security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Leveraging","label":"c Leveraging","identifier":"/us/usc/t15/s8853/c","parentIdentifier":"/us/usc/t15/s8853","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8853/c/1","parentIdentifier":"/us/usc/t15/s8853/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fc%2F1","sourceRelease":"119-100","text":"the National Institute of Standards and Technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8853/c/2","parentIdentifier":"/us/usc/t15/s8853/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fc%2F2","sourceRelease":"119-100","text":"the National Science Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8853/c/3","parentIdentifier":"/us/usc/t15/s8853/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fc%2F3","sourceRelease":"119-100","text":"the National Aeronautics and Space Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s8853/c/4","parentIdentifier":"/us/usc/t15/s8853/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fc%2F4","sourceRelease":"119-100","text":"other relevant Federal agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s8853/c/5","parentIdentifier":"/us/usc/t15/s8853/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fc%2F5","sourceRelease":"119-100","text":"the National Laboratories;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s8853/c/6","parentIdentifier":"/us/usc/t15/s8853/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fc%2F6","sourceRelease":"119-100","text":"industry stakeholders;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t15/s8853/c/7","parentIdentifier":"/us/usc/t15/s8853/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fc%2F7","sourceRelease":"119-100","text":"institutions of higher education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t15/s8853/c/8","parentIdentifier":"/us/usc/t15/s8853/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fc%2F8","sourceRelease":"119-100","text":"the National Quantum Information Science Research Centers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Research plan","label":"d Research plan","identifier":"/us/usc/t15/s8853/d","parentIdentifier":"/us/usc/t15/s8853","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fd","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a 4-year research plan that identifies and prioritizes basic research needs relating to quantum network infrastructure.August 9, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Standard of review","label":"e Standard of review","identifier":"/us/usc/t15/s8853/e","parentIdentifier":"/us/usc/t15/s8853","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Fe","sourceRelease":"119-100","text":"The Secretary shall review activities carried out under this section to determine the achievement of technical milestones.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Funding","label":"f Funding","identifier":"/us/usc/t15/s8853/f","parentIdentifier":"/us/usc/t15/s8853","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8853%2Ff","sourceRelease":"119-100","text":"Of the funds authorized to be appropriated for the Department of Energy’s Office of Science, there is authorized to be appropriated to the Secretary to carry out the activities under this section $100,000,000 for each of fiscal years 2023 through 2027.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
