{"type":"section","nativeType":"section","number":"4114","heading":"Resolution of implementation disputes","label":"4114 Resolution of implementation disputes","identifier":"/us/usc/t22/s4114","parentIdentifier":"/us/usc/t22/ch52/schX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4114","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Grievance procedure","label":"a Grievance procedure","identifier":"/us/usc/t22/s4114/a","parentIdentifier":"/us/usc/t22/s4114","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4114%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4114/a/1","parentIdentifier":"/us/usc/t22/s4114/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4114%2Fa%2F1","sourceRelease":"119-100","text":"be fair and simple,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4114/a/2","parentIdentifier":"/us/usc/t22/s4114/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4114%2Fa%2F2","sourceRelease":"119-100","text":"provide for expeditious processing, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s4114/a/3","parentIdentifier":"/us/usc/t22/s4114/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4114%2Fa%2F3","sourceRelease":"119-100","text":"include provision for appeal to the Foreign Service Grievance Board by either party of any dispute not satisfactorily settled.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Review by Foreign Service Labor Relations Board","label":"b Review by Foreign Service Labor Relations Board","identifier":"/us/usc/t22/s4114/b","parentIdentifier":"/us/usc/t22/s4114","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4114%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4114/b/1","parentIdentifier":"/us/usc/t22/s4114/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4114%2Fb%2F1","sourceRelease":"119-100","text":"because it is contrary to any law, rule, or regulation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4114/b/2","parentIdentifier":"/us/usc/t22/s4114/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4114%2Fb%2F2","sourceRelease":"119-100","text":"on other grounds similar to those applied by Federal courts in private sector labor-management relations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Time of filing exceptions; finality and binding nature of action","label":"c Time of filing exceptions; finality and binding nature of action","identifier":"/us/usc/t22/s4114/c","parentIdentifier":"/us/usc/t22/s4114","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4114%2Fc","sourceRelease":"119-100","text":"If no exception to a Foreign Service Grievance Board action is filed under subsection (b) within 30 days after such action is communicated to the parties, such action shall become final and binding and shall be implemented by the parties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Judicial review","label":"d Judicial review","identifier":"/us/usc/t22/s4114/d","parentIdentifier":"/us/usc/t22/s4114","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4114%2Fd","sourceRelease":"119-100","text":"Resolutions of disputes under this section shall not be subject to judicial review.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
