{"type":"section","nativeType":"section","number":"2341","heading":"Elimination of plutonium production","label":"2341 Elimination of plutonium production","identifier":"/us/usc/t50/s2341","parentIdentifier":"/us/usc/t50/ch40/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2341","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Replacement program","label":"a Replacement program","identifier":"/us/usc/t50/s2341/a","parentIdentifier":"/us/usc/t50/s2341","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2341%2Fa","sourceRelease":"119-100","text":"The Secretary of Energy, in consultation with the Secretary of Defense, shall develop a cooperative program with the Government of Russia to eliminate the production of weapons grade plutonium by modifying or replacing the reactor cores at Tomsk–7 and Krasnoyarsk–26 with reactor cores that are less suitable for the production of weapons-grade plutonium.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Program requirements","label":"b Program requirements","identifier":"/us/usc/t50/s2341/b","parentIdentifier":"/us/usc/t50/s2341","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2341%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2341/b/1","parentIdentifier":"/us/usc/t50/s2341/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2341%2Fb%2F1","sourceRelease":"119-100","text":"The program shall be designed to achieve completion of the modifications or replacements of the reactor cores within three years after the modification or replacement activities under the program are begun.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2341/b/2","parentIdentifier":"/us/usc/t50/s2341/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2341%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s2341/b/2/A","parentIdentifier":"/us/usc/t50/s2341/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2341%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t50/s2341/b/2/A/i","parentIdentifier":"/us/usc/t50/s2341/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2341%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"successive steps for the modification or replacement of the reactor cores; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t50/s2341/b/2/A/ii","parentIdentifier":"/us/usc/t50/s2341/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2341%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"clearly defined milestones to be achieved; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s2341/b/2/B","parentIdentifier":"/us/usc/t50/s2341/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2341%2Fb%2F2%2FB","sourceRelease":"119-100","text":"include estimates of the costs of the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Submission of program plan to Congress","label":"c Submission of program plan to Congress","identifier":"/us/usc/t50/s2341/c","parentIdentifier":"/us/usc/t50/s2341","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2341%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2341/c/1","parentIdentifier":"/us/usc/t50/s2341/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2341%2Fc%2F1","sourceRelease":"119-100","text":"a plan for the program under subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2341/c/2","parentIdentifier":"/us/usc/t50/s2341/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2341%2Fc%2F2","sourceRelease":"119-100","text":"an estimate of the United States funding that is necessary for carrying out the activities under the program for each fiscal year covered by the program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s2341/c/3","parentIdentifier":"/us/usc/t50/s2341/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2341%2Fc%2F3","sourceRelease":"119-100","text":"a comparison of the benefits of the program with the benefits of other nonproliferation programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
