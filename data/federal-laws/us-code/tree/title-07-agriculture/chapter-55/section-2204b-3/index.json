ll,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Chair","label":"2 Chair","identifier":"/us/usc/t7/s2204b–3/c/2","parentIdentifier":"/us/usc/t7/s2204b–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fc%2F2","sourceRelease":"119-100","text":"The Secretary shall serve as the Chair of the Council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Designees","label":"3 Designees","identifier":"/us/usc/t7/s2204b–3/c/3","parentIdentifier":"/us/usc/t7/s2204b–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2204b–3/c/3/A","parentIdentifier":"/us/usc/t7/s2204b–3/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fc%2F3%2FA","sourceRelease":"119-100","text":"part of the department, agency, or office of the member; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2204b–3/c/3/B","parentIdentifier":"/us/usc/t7/s2204b–3/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fc%2F3%2FB","sourceRelease":"119-100","text":"a full-time officer or employee of the Federal Government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Administration","label":"4 Administration","identifier":"/us/usc/t7/s2204b–3/c/4","parentIdentifier":"/us/usc/t7/s2204b–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fc%2F4","sourceRelease":"119-100","text":"The Council shall coordinate policy development through the rural development mission area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Funding","label":"d Funding","identifier":"/us/usc/t7/s2204b–3/d","parentIdentifier":"/us/usc/t7/s2204b–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fd","sourceRelease":"119-100","text":"The Secretary shall provide funding and administrative support for the Council to the extent permitted by law and within existing appropriations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Mission and function of the Council","label":"e Mission and function of the Council","identifier":"/us/usc/t7/s2204b–3/e","parentIdentifier":"/us/usc/t7/s2204b–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2204b–3/e/1","parentIdentifier":"/us/usc/t7/s2204b–3/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fe%2F1","sourceRelease":"119-100","text":"to maximize the impact of Federal investment on rural communities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2204b–3/e/2","parentIdentifier":"/us/usc/t7/s2204b–3/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fe%2F2","sourceRelease":"119-100","text":"to promote economic prosperity and quality of life in rural communities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s2204b–3/e/3","parentIdentifier":"/us/usc/t7/s2204b–3/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fe%2F3","sourceRelease":"119-100","text":"to use innovation to resolve local and regional challenges faced by rural communities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Duties","label":"f Duties","identifier":"/us/usc/t7/s2204b–3/f","parentIdentifier":"/us/usc/t7/s2204b–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2204b–3/f/1","parentIdentifier":"/us/usc/t7/s2204b–3/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Ff%2F1","sourceRelease":"119-100","text":"make recommendations to the President, acting through the Director of the Domestic Policy Council and the Director of the National Economic Council, on streamlining and leveraging Federal investments in rural areas, where appropriate, to increase the impact of Federal dollars and create economic opportunities to improve the quality of life in rural areas in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2204b–3/f/2","parentIdentifier":"/us/usc/t7/s2204b–3/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Ff%2F2","sourceRelease":"119-100","text":"coordinate and increase the effectiveness of Federal engagement with rural stakeholders, including agricultural organizations, small businesses, education and training institutions, health-care providers, telecommunications services providers, electric service providers, transportation providers, research and land grant institutions, law enforcement, State, local, and tribal governments, and nongovernmental organizations regarding the needs of rural areas in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s2204b–3/f/3","parentIdentifier":"/us/usc/t7/s2204b–3/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Ff%2F3","sourceRelease":"119-100","text":"coordinate Federal efforts directed toward the growth and development of rural geographic regions that encompass both metropolitan and nonmetropolitan areas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s2204b–3/f/4","parentIdentifier":"/us/usc/t7/s2204b–3/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Ff%2F4","sourceRelease":"119-100","text":"identify and facilitate rural economic opportunities associated with energy development, outdoor recreation, and other conservation related activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s2204b–3/f/5","parentIdentifier":"/us/usc/t7/s2204b–3/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Ff%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2204b–3/f/5/A","parentIdentifier":"/us/usc/t7/s2204b–3/f/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Ff%2F5%2FA","sourceRelease":"119-100","text":"better coordination of existing Federal and non-Federal resources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2204b–3/f/5/B","parentIdentifier":"/us/usc/t7/s2204b–3/f/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Ff%2F5%2FB","sourceRelease":"119-100","text":"innovative solutions utilizing governmental and nongovernmental resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Executive departments and agencies","label":"g Executive departments and agencies","identifier":"/us/usc/t7/s2204b–3/g","parentIdentifier":"/us/usc/t7/s2204b–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s2204b–3/g/1","parentIdentifier":"/us/usc/t7/s2204b–3/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fg%2F1","sourceRelease":"119-100","text":"The heads of executive departments and agencies shall assist and provide information to the Council, consistent with applicable law, as may be necessary to carry out the functions of the Council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Expenses","label":"2 Expenses","identifier":"/us/usc/t7/s2204b–3/g/2","parentIdentifier":"/us/usc/t7/s2204b–3/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fg%2F2","sourceRelease":"119-100","text":"Each executive department or agency shall be responsible for paying any expenses of the executive department or agency for participating in the Council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Council working groups","label":"h Council working groups","identifier":"/us/usc/t7/s2204b–3/h","parentIdentifier":"/us/usc/t7/s2204b–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s2204b–3/h/1","parentIdentifier":"/us/usc/t7/s2204b–3/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F1","sourceRelease":"119-100","text":"The Council may establish, in addition to the working groups established under paragraph (3), such other working groups as necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Membership","label":"2 Membership","identifier":"/us/usc/t7/s2204b–3/h/2","parentIdentifier":"/us/usc/t7/s2204b–3/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F2","sourceRelease":"119-100","text":"The Secretary shall include as members of each working group such Council members, other heads of Federal agencies (or their designees as defined in (d)(3) ), and non-Federal partners as determined appropriate to the subject matter.1So in original. Probably should be “subsection (c)(3)”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Required working groups","label":"3 Required working groups","identifier":"/us/usc/t7/s2204b–3/h/3","parentIdentifier":"/us/usc/t7/s2204b–3/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"The rural smart communities working group","label":"A The rural smart communities working group","identifier":"/us/usc/t7/s2204b–3/h/3/A","parentIdentifier":"/us/usc/t7/s2204b–3/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"Establishment","label":"i Establishment","identifier":"/us/usc/t7/s2204b–3/h/3/A/i","parentIdentifier":"/us/usc/t7/s2204b–3/h/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FA%2Fi","sourceRelease":"119-100","text":"The Council shall establish a Rural Smart Communities Working Group.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Duties","label":"ii Duties","identifier":"/us/usc/t7/s2204b–3/h/3/A/ii","parentIdentifier":"/us/usc/t7/s2204b–3/h/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s2204b–3/h/3/A/ii/I","parentIdentifier":"/us/usc/t7/s2204b–3/h/3/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FA%2Fii%2FI","sourceRelease":"119-100","text":"not later than 1 year after the establishment of such Working Group, submit to Congress a report describing efforts of rural areas to integrate smart technology into their communities to solve challenges relating to governance, economic development, quality of life, or other relevant rural issues, as determined by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s2204b–3/h/3/A/ii/II","parentIdentifier":"/us/usc/t7/s2204b–3/h/3/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FA%2Fii%2FII","sourceRelease":"119-100","text":"create, publish, and maintain a resource guide designed to assist States and other rural communities in developing and implementing rural smart community programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":"Smart community defined","label":"iii Smart community defined","identifier":"/us/usc/t7/s2204b–3/h/3/A/iii","parentIdentifier":"/us/usc/t7/s2204b–3/h/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"For the purposes of this subparagraph, the term “smart community” means a community that has the ability to integrate multiple technological solutions, in a secure fashion, to manage a community’s assets, including local government information systems, schools, libraries, transportation systems, hospitals, power plants, law enforcement, and other community services with the goal of promoting quality of life through the use of technology in ways that improve the efficiency of services and meet residents’ needs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Jobs accelerator working group","label":"B Jobs accelerator working group","identifier":"/us/usc/t7/s2204b–3/h/3/B","parentIdentifier":"/us/usc/t7/s2204b–3/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"Establishment","label":"i Establishment","identifier":"/us/usc/t7/s2204b–3/h/3/B/i","parentIdentifier":"/us/usc/t7/s2204b–3/h/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FB%2Fi","sourceRelease":"119-100","text":"The Council shall establish a Jobs Accelerator Working Group.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Goals","label":"ii Goals","identifier":"/us/usc/t7/s2204b–3/h/3/B/ii","parentIdentifier":"/us/usc/t7/s2204b–3/h/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s2204b–3/h/3/B/ii/I","parentIdentifier":"/us/usc/t7/s2204b–3/h/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FB%2Fii%2FI","sourceRelease":"119-100","text":"to improve the ability of rural communities to create high-wage jobs, accelerate the formation of new businesses with high-growth potential, and strengthen regional economies, including by helping to build capacity in the applicable region to achieve those goals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s2204b–3/h/3/B/ii/II","parentIdentifier":"/us/usc/t7/s2204b–3/h/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FB%2Fii%2FII","sourceRelease":"119-100","text":"to help rural communities identify and maximize local assets and connect to regional opportunities, networks, and industry clusters that demonstrate high growth potential.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":"Duties","label":"iii Duties","identifier":"/us/usc/t7/s2204b–3/h/3/B/iii","parentIdentifier":"/us/usc/t7/s2204b–3/h/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FB%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s2204b–3/h/3/B/iii/I","parentIdentifier":"/us/usc/t7/s2204b–3/h/3/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FB%2Fiii%2FI","sourceRelease":"119-100","text":"provide the public with available information and technical assistance on Federal resources relevant to a project and region;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s2204b–3/h/3/B/iii/II","parentIdentifier":"/us/usc/t7/s2204b–3/h/3/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FB%2Fiii%2FII","sourceRelease":"119-100","text":"establish a Federal support team comprised of staff from participating agencies in the working group that shall provide coordinated and dedicated support services to rural jobs accelerators; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t7/s2204b–3/h/3/B/iii/III","parentIdentifier":"/us/usc/t7/s2204b–3/h/3/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204b%E2%80%933%2Fh%2F3%2FB%2Fiii%2FIII","sourceRelease":"119-100","text":"provide opportunities for rural jobs accelerators to share best practices and further collaborate with one another.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}]}
