{"type":"section","nativeType":"section","number":"1905","heading":"Coast Guard Academy minority outreach team program","label":"1905 Coast Guard Academy minority outreach team program","identifier":"/us/usc/t14/s1905","parentIdentifier":"/us/usc/t14/stII/ch19/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1905","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t14/s1905/a","parentIdentifier":"/us/usc/t14/s1905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1905%2Fa","sourceRelease":"119-100","text":"There is established within the Coast Guard Academy a minority outreach team program (in this section referred to as the “Program”) under which officers, including minority officers and officers from territories and other possessions of the United States, who are Academy graduates may volunteer their time to recruit minority students and strengthen cadet retention through mentorship of cadets.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Administration","label":"b .—Administration","identifier":"/us/usc/t14/s1905/b","parentIdentifier":"/us/usc/t14/s1905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1905%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s1905/b/1","parentIdentifier":"/us/usc/t14/s1905/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1905%2Fb%2F1","sourceRelease":"119-100","text":"overseeing administration of the Program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s1905/b/2","parentIdentifier":"/us/usc/t14/s1905/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1905%2Fb%2F2","sourceRelease":"119-100","text":"serving as a resource to volunteers and outside stakeholders;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t14/s1905/b/3","parentIdentifier":"/us/usc/t14/s1905/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1905%2Fb%2F3","sourceRelease":"119-100","text":"advising Academy leadership on recruitment and retention efforts based on recommendations from volunteers and outside stakeholders;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t14/s1905/b/4","parentIdentifier":"/us/usc/t14/s1905/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1905%2Fb%2F4","sourceRelease":"119-100","text":"establishing strategic goals and performance metrics for the Program with input from active volunteers and Academy leadership; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t14/s1905/b/5","parentIdentifier":"/us/usc/t14/s1905/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1905%2Fb%2F5","sourceRelease":"119-100","text":"reporting annually to the Commandant on academic year and performance outcomes of the goals for the Program before the end of each academic year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
