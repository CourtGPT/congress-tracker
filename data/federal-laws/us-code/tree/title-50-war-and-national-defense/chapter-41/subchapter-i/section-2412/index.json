{"type":"section","nativeType":"section","number":"2412","heading":"Cybersecurity Risk Inventory, Assessment, and Mitigation Working Group","label":"2412 Cybersecurity Risk Inventory, Assessment, and Mitigation Working Group","identifier":"/us/usc/t50/s2412","parentIdentifier":"/us/usc/t50/ch41/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t50/s2412/a","parentIdentifier":"/us/usc/t50/s2412","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fa","sourceRelease":"119-100","text":"There is in the Administration a working group, to be known as the “Cybersecurity Risk Inventory, Assessment, and Mitigation Working Group” (referred to in this section as the “working group”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Membership","label":"b Membership","identifier":"/us/usc/t50/s2412/b","parentIdentifier":"/us/usc/t50/s2412","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2412/b/1","parentIdentifier":"/us/usc/t50/s2412/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fb%2F1","sourceRelease":"119-100","text":"the Deputy Administrator for Defense Programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2412/b/2","parentIdentifier":"/us/usc/t50/s2412/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fb%2F2","sourceRelease":"119-100","text":"the Associate Administrator for Information Management and Chief Information Officer; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s2412/b/3","parentIdentifier":"/us/usc/t50/s2412/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fb%2F3","sourceRelease":"119-100","text":"such other personnel of the Administration as are determined appropriate for inclusion in the working group by the Chairperson.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Chairperson","label":"c Chairperson","identifier":"/us/usc/t50/s2412/c","parentIdentifier":"/us/usc/t50/s2412","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fc","sourceRelease":"119-100","text":"The Deputy Administrator for Defense Programs shall serve as the Chairperson of the working group, except that the Administrator may designate another member of the working group to serve as Chairperson in lieu of the Deputy Administrator if the Administrator determines it is appropriate to do so.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Comprehensive strategy","label":"d Comprehensive strategy","identifier":"/us/usc/t50/s2412/d","parentIdentifier":"/us/usc/t50/s2412","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2412/d/1","parentIdentifier":"/us/usc/t50/s2412/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fd%2F1","sourceRelease":"119-100","text":"goals, objectives, activities, and performance measures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2412/d/2","parentIdentifier":"/us/usc/t50/s2412/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fd%2F2","sourceRelease":"119-100","text":"organizational roles, responsibilities, and coordination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s2412/d/3","parentIdentifier":"/us/usc/t50/s2412/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fd%2F3","sourceRelease":"119-100","text":"resources needed to implement the strategy through 2034; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t50/s2412/d/4","parentIdentifier":"/us/usc/t50/s2412/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fd%2F4","sourceRelease":"119-100","text":"detailed milestones and schedules for completion of tasks.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Submission to Congress","label":"e Submission to Congress","identifier":"/us/usc/t50/s2412/e","parentIdentifier":"/us/usc/t50/s2412","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Interim briefing","label":"1 Interim briefing","identifier":"/us/usc/t50/s2412/e/1","parentIdentifier":"/us/usc/t50/s2412/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fe%2F1","sourceRelease":"119-100","text":"Not later than 120 days after , the working group shall provide to the congressional defense committees a briefing on the plan of the working group to develop the strategy required under subsection (d).December 22, 2023","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Completed strategy","label":"2 Completed strategy","identifier":"/us/usc/t50/s2412/e/2","parentIdentifier":"/us/usc/t50/s2412/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Fe%2F2","sourceRelease":"119-100","text":"Not later than , the working group shall submit the congressional defense committees a copy of the completed strategy.April 1, 2025","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Termination","label":"f Termination","identifier":"/us/usc/t50/s2412/f","parentIdentifier":"/us/usc/t50/s2412","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2412%2Ff","sourceRelease":"119-100","text":"The working group shall terminate on a date determined by the Administrator that is not earlier than the date that is five years after .December 22, 2023","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
