n":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6838/a/2/A","parentIdentifier":"/us/usc/t42/s6838/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fa%2F2%2FA","sourceRelease":"119-100","text":"Local building code agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6838/a/2/B","parentIdentifier":"/us/usc/t42/s6838/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fa%2F2%2FB","sourceRelease":"119-100","text":"Codes and standards developers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6838/a/2/C","parentIdentifier":"/us/usc/t42/s6838/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fa%2F2%2FC","sourceRelease":"119-100","text":"Associations of builders and design and construction professionals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6838/a/2/D","parentIdentifier":"/us/usc/t42/s6838/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fa%2F2%2FD","sourceRelease":"119-100","text":"Local and utility energy efficiency programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s6838/a/2/E","parentIdentifier":"/us/usc/t42/s6838/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fa%2F2%2FE","sourceRelease":"119-100","text":"Consumer, energy efficiency, and environmental advocates.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s6838/a/2/F","parentIdentifier":"/us/usc/t42/s6838/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fa%2F2%2FF","sourceRelease":"119-100","text":"Other entities, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Secretary","label":"3 Secretary","identifier":"/us/usc/t42/s6838/a/3","parentIdentifier":"/us/usc/t42/s6838/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fa%2F3","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t42/s6838/b","parentIdentifier":"/us/usc/t42/s6838","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s6838/b/1","parentIdentifier":"/us/usc/t42/s6838/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall establish within the Building Technologies Office of the Department of Energy a program under which the Secretary shall award grants on a competitive basis to eligible entities to enable sustained cost-effective implementation of updated building energy codes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Updated building energy code","label":"2 Updated building energy code","identifier":"/us/usc/t42/s6838/b/2","parentIdentifier":"/us/usc/t42/s6838/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fb%2F2","sourceRelease":"119-100","text":"An update to a building energy code under this section, including an amendment that results in increased efficiency compared to the previously adopted building energy code, shall include any update made available after the existing building energy code, even if it is not the most recent updated code available.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Criteria; priority","label":"c Criteria; priority","identifier":"/us/usc/t42/s6838/c","parentIdentifier":"/us/usc/t42/s6838","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6838/c/1","parentIdentifier":"/us/usc/t42/s6838/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6838/c/1/A","parentIdentifier":"/us/usc/t42/s6838/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fc%2F1%2FA","sourceRelease":"119-100","text":"prospective energy savings and plans to measure the savings, including utilizing the Environmental Protection Agency Portfolio Manager, the Home Energy Score rating of the Office of Energy Efficiency and Renewable Energy of the Department of Energy, the Energy Star Building rating methodologies of the Environmental Protection Agency, and other methodologies determined appropriate by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6838/c/1/B","parentIdentifier":"/us/usc/t42/s6838/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fc%2F1%2FB","sourceRelease":"119-100","text":"the long-term sustainability of those measures and savings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6838/c/1/C","parentIdentifier":"/us/usc/t42/s6838/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fc%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s6838/c/1/C/i","parentIdentifier":"/us/usc/t42/s6838/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fc%2F1%2FC%2Fi","sourceRelease":"119-100","text":"resilience and peak load reduction;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s6838/c/1/C/ii","parentIdentifier":"/us/usc/t42/s6838/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fc%2F1%2FC%2Fii","sourceRelease":"119-100","text":"occupant safety and health; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s6838/c/1/C/iii","parentIdentifier":"/us/usc/t42/s6838/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fc%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"environmental performance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6838/c/1/D","parentIdentifier":"/us/usc/t42/s6838/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fc%2F1%2FD","sourceRelease":"119-100","text":"the demonstrated capacity of the eligible entity to carry out the proposed project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s6838/c/1/E","parentIdentifier":"/us/usc/t42/s6838/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fc%2F1%2FE","sourceRelease":"119-100","text":"the need of the eligible entity for assistance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6838/c/2","parentIdentifier":"/us/usc/t42/s6838/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fc%2F2","sourceRelease":"119-100","text":"give priority to applications from partnerships.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Eligible activities","label":"d Eligible activities","identifier":"/us/usc/t42/s6838/d","parentIdentifier":"/us/usc/t42/s6838","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s6838/d/1","parentIdentifier":"/us/usc/t42/s6838/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6838/d/1/A","parentIdentifier":"/us/usc/t42/s6838/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s6838/d/1/A/i","parentIdentifier":"/us/usc/t42/s6838/d/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F1%2FA%2Fi","sourceRelease":"119-100","text":"builders, contractors and subcontractors, architects, and other design and construction professionals, relating to meeting updated building energy codes in a cost-effective manner; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s6838/d/1/A/ii","parentIdentifier":"/us/usc/t42/s6838/d/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F1%2FA%2Fii","sourceRelease":"119-100","text":"building code officials, relating to improving implementation of and compliance with building energy codes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6838/d/1/B","parentIdentifier":"/us/usc/t42/s6838/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F1%2FB","sourceRelease":"119-100","text":"to collect and disseminate quantitative data on construction and codes implementation, including code pathways, performance metrics, and technologies used;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6838/d/1/C","parentIdentifier":"/us/usc/t42/s6838/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F1%2FC","sourceRelease":"119-100","text":"to develop and implement a plan for highly effective codes implementation, including measuring compliance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6838/d/1/D","parentIdentifier":"/us/usc/t42/s6838/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F1%2FD","sourceRelease":"119-100","text":"to address various implementation needs in rural, suburban, and urban areas; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s6838/d/1/E","parentIdentifier":"/us/usc/t42/s6838/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F1%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s6838/d/1/E/i","parentIdentifier":"/us/usc/t42/s6838/d/1/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F1%2FE%2Fi","sourceRelease":"119-100","text":"new residential and commercial buildings (including multifamily buildings); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s6838/d/1/E/ii","parentIdentifier":"/us/usc/t42/s6838/d/1/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F1%2FE%2Fii","sourceRelease":"119-100","text":"additions and alterations to existing residential and commercial buildings (including multifamily buildings).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Related topics","label":"2 Related topics","identifier":"/us/usc/t42/s6838/d/2","parentIdentifier":"/us/usc/t42/s6838/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6838/d/2/A","parentIdentifier":"/us/usc/t42/s6838/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F2%2FA","sourceRelease":"119-100","text":"cost-effective, high-performance, and zero-net-energy buildings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6838/d/2/B","parentIdentifier":"/us/usc/t42/s6838/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F2%2FB","sourceRelease":"119-100","text":"improving resilience, health, and safety;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6838/d/2/C","parentIdentifier":"/us/usc/t42/s6838/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F2%2FC","sourceRelease":"119-100","text":"water savings and other environmental impacts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6838/d/2/D","parentIdentifier":"/us/usc/t42/s6838/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fd%2F2%2FD","sourceRelease":"119-100","text":"the economic impacts of energy codes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s6838/e","parentIdentifier":"/us/usc/t42/s6838","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6838%2Fe","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary to carry out this section $225,000,000 for the period of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
