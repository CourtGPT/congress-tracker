{"type":"section","nativeType":"section","number":"9804","heading":"Recruitment, redesignation, and relocation bonuses","label":"9804 Recruitment, redesignation, and relocation bonuses","identifier":"/us/usc/t5/s9804","parentIdentifier":"/us/usc/t5/ptIII/sptI/ch98","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s9804/a","parentIdentifier":"/us/usc/t5/s9804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s9804/a/1","parentIdentifier":"/us/usc/t5/s9804/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fa%2F1","sourceRelease":"119-100","text":"the Administrator determines that the Administration would be likely, in the absence of a bonus, to encounter difficulty in filling a position; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s9804/a/2","parentIdentifier":"/us/usc/t5/s9804/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s9804/a/2/A","parentIdentifier":"/us/usc/t5/s9804/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fa%2F2%2FA","sourceRelease":"119-100","text":"is newly appointed as an employee of the Federal Government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s9804/a/2/B","parentIdentifier":"/us/usc/t5/s9804/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fa%2F2%2FB","sourceRelease":"119-100","text":"is currently employed by the Federal Government and is newly appointed to another position in the same geographic area; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s9804/a/2/C","parentIdentifier":"/us/usc/t5/s9804/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fa%2F2%2FC","sourceRelease":"119-100","text":"is currently employed by the Federal Government and is required to relocate to a different geographic area to accept a position with the Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s9804/b","parentIdentifier":"/us/usc/t5/s9804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s9804/b/1","parentIdentifier":"/us/usc/t5/s9804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fb%2F1","sourceRelease":"119-100","text":"50 percent of the employee’s annual rate of basic pay (including comparability payments under sections 5304 and 5304a) as of the beginning of the service period multiplied by the service period specified under subsection (d)(1)(B)(i); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s9804/b/2","parentIdentifier":"/us/usc/t5/s9804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fb%2F2","sourceRelease":"119-100","text":"100 percent of the employee’s annual rate of basic pay (including comparability payments under sections 5304 and 5304a) as of the beginning of the service period.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t5/s9804/c","parentIdentifier":"/us/usc/t5/s9804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fc","sourceRelease":"119-100","text":"If the position is not described as addressing a critical need in the workforce plan under section 9802(b)(2)(A), the amount of a bonus may not exceed 25 percent of the employee’s annual rate of basic pay (excluding comparability payments under sections 5304 and 5304a) as of the beginning of the service period.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t5/s9804/d","parentIdentifier":"/us/usc/t5/s9804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s9804/d/1","parentIdentifier":"/us/usc/t5/s9804/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s9804/d/1/A","parentIdentifier":"/us/usc/t5/s9804/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fd%2F1%2FA","sourceRelease":"119-100","text":"Payment of a bonus under this section shall be contingent upon the individual entering into a service agreement with the Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s9804/d/1/B","parentIdentifier":"/us/usc/t5/s9804/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fd%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t5/s9804/d/1/B/i","parentIdentifier":"/us/usc/t5/s9804/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fd%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the required service period;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t5/s9804/d/1/B/ii","parentIdentifier":"/us/usc/t5/s9804/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fd%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the method of payment, including a payment schedule, which may include a lump-sum payment, installment payments, or a combination thereof;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t5/s9804/d/1/B/iii","parentIdentifier":"/us/usc/t5/s9804/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fd%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"the amount of the bonus and the basis for calculating that amount; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t5/s9804/d/1/B/iv","parentIdentifier":"/us/usc/t5/s9804/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fd%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"the conditions under which the agreement may be terminated before the agreed-upon service period has been completed, and the effect of the termination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s9804/d/2","parentIdentifier":"/us/usc/t5/s9804/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fd%2F2","sourceRelease":"119-100","text":"For purposes of determinations under subsections (b)(1) and (c)(1), the employee’s service period shall be expressed as the number equal to the full years and twelfth parts thereof, rounding the fractional part of a month to the nearest twelfth part of a year. The service period may not be less than 6 months and may not exceed 4 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s9804/d/3","parentIdentifier":"/us/usc/t5/s9804/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fd%2F3","sourceRelease":"119-100","text":"A bonus under this section may not be considered to be part of the basic pay of an employee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":null,"label":"e","identifier":"/us/usc/t5/s9804/e","parentIdentifier":"/us/usc/t5/s9804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Fe","sourceRelease":"119-100","text":"Before paying a bonus under this section, the Administration shall establish a plan for paying recruitment, redesignation, and relocation bonuses, subject to approval by the Office of Personnel Management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":null,"label":"f","identifier":"/us/usc/t5/s9804/f","parentIdentifier":"/us/usc/t5/s9804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9804%2Ff","sourceRelease":"119-100","text":"No more than 25 percent of the total amount in bonuses awarded under subsection (a) in any year may be awarded to supervisors or management officials.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
