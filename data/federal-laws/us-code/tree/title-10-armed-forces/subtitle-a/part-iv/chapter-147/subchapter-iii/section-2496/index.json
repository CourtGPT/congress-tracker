{"type":"section","nativeType":"section","number":"2496","heading":"Sale of certain goods from the Xinjiang Uyghur Autonomous Region prohibited","label":"2496 Sale of certain goods from the Xinjiang Uyghur Autonomous Region prohibited","identifier":"/us/usc/t10/s2496","parentIdentifier":"/us/usc/t10/stA/ptIV/ch147/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2496","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Prohibition","label":"a .—Prohibition","identifier":"/us/usc/t10/s2496/a","parentIdentifier":"/us/usc/t10/s2496","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2496%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2496/a/1","parentIdentifier":"/us/usc/t10/s2496/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2496%2Fa%2F1","sourceRelease":"119-100","text":"containing any product mined, produced, or manufactured, wholly or in part, by forced labor from the XUAR; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2496/a/2","parentIdentifier":"/us/usc/t10/s2496/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2496%2Fa%2F2","sourceRelease":"119-100","text":"from an entity that has used labor from within or transferred from XUAR as part of a “poverty alleviation” or “pairing assistance” program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Definitions","label":"b .—Definitions","identifier":"/us/usc/t10/s2496/b","parentIdentifier":"/us/usc/t10/s2496","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2496%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2496/b/1","parentIdentifier":"/us/usc/t10/s2496/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2496%2Fb%2F1","sourceRelease":"119-100","text":"The term “forced labor” means any work or service that is exacted from any person under the menace of any penalty for nonperformance and that the worker does not offer to perform.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2496/b/2","parentIdentifier":"/us/usc/t10/s2496/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2496%2Fb%2F2","sourceRelease":"119-100","text":"The term “XUAR” means the Xinjiang Uyghur Autonomous Region of the People’s Republic of China.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
