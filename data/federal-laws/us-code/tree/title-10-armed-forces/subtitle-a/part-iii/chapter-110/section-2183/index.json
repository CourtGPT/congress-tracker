"parentIdentifier":"/us/usc/t10/s2183/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2183%2Fb%2F1","sourceRelease":"119-100","text":"after the termination of the status of that person as a captive; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2183/b/2","parentIdentifier":"/us/usc/t10/s2183/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2183%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2183/b/2/A","parentIdentifier":"/us/usc/t10/s2183/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2183%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the end of any semester or quarter (as appropriate) that begins before the end of the 10-year period beginning on the date on which the status of that person as a captive terminates; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2183/b/2/B","parentIdentifier":"/us/usc/t10/s2183/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2183%2Fb%2F2%2FB","sourceRelease":"119-100","text":"if the educational or training institution is not operated on a semester or quarter system, the earlier of the end of any course that began before such date or the end of the 16-week period following that date.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t10/s2183/c","parentIdentifier":"/us/usc/t10/s2183","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2183%2Fc","sourceRelease":"119-100","text":"Payments shall be available under this section only to the extent that such payments are not otherwise authorized by law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
