{"type":"section","nativeType":"section","number":"410fff–3","heading":"Acquisition of property and minor boundary adjustments","label":"410fff–3 Acquisition of property and minor boundary adjustments","identifier":"/us/usc/t16/s410fff–3","parentIdentifier":"/us/usc/t16/ch1/schLIX–DD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2003—Subsec. (a)(1). substituted “Map or the map described in ” for “Map”.Pub. L. 108–128section 410fff–2(a)(2) of this title"],"amendments":["Amendments2003—Subsec. (a)(1). substituted “Map or the map described in ” for “Map”.Pub. L. 108–128section 410fff–2(a)(2) of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Additional acquisitions","label":"a Additional acquisitions","identifier":"/us/usc/t16/s410fff–3/a","parentIdentifier":"/us/usc/t16/s410fff–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s410fff–3/a/1","parentIdentifier":"/us/usc/t16/s410fff–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary may acquire land or interests in land depicted on the Map or the map described in as proposed additions.section 410fff–2(a)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Method of acquisition","label":"2 Method of acquisition","identifier":"/us/usc/t16/s410fff–3/a/2","parentIdentifier":"/us/usc/t16/s410fff–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s410fff–3/a/2/A","parentIdentifier":"/us/usc/t16/s410fff–3/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s410fff–3/a/2/A/i","parentIdentifier":"/us/usc/t16/s410fff–3/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"donation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s410fff–3/a/2/A/ii","parentIdentifier":"/us/usc/t16/s410fff–3/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"transfer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s410fff–3/a/2/A/iii","parentIdentifier":"/us/usc/t16/s410fff–3/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fa%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"purchase with donated or appropriated funds; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s410fff–3/a/2/A/iv","parentIdentifier":"/us/usc/t16/s410fff–3/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fa%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"exchange.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Consent","label":"B Consent","identifier":"/us/usc/t16/s410fff–3/a/2/B","parentIdentifier":"/us/usc/t16/s410fff–3/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fa%2F2%2FB","sourceRelease":"119-100","text":"No land or interest in land may be acquired without the consent of the owner of the land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Boundary revision","label":"b Boundary revision","identifier":"/us/usc/t16/s410fff–3/b","parentIdentifier":"/us/usc/t16/s410fff–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410fff–3/b/1","parentIdentifier":"/us/usc/t16/s410fff–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fb%2F1","sourceRelease":"119-100","text":"revise the boundary of the Park to include newly-acquired land within the boundary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410fff–3/b/2","parentIdentifier":"/us/usc/t16/s410fff–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fb%2F2","sourceRelease":"119-100","text":"administer newly-acquired land subject to applicable laws (including regulations).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Boundary survey","label":"c Boundary survey","identifier":"/us/usc/t16/s410fff–3/c","parentIdentifier":"/us/usc/t16/s410fff–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fc","sourceRelease":"119-100","text":"As soon as practicable and subject to the availability of funds the Secretary shall complete an official boundary survey of the Park.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Hunting on privately owned lands","label":"d Hunting on privately owned lands","identifier":"/us/usc/t16/s410fff–3/d","parentIdentifier":"/us/usc/t16/s410fff–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s410fff–3/d/1","parentIdentifier":"/us/usc/t16/s410fff–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary may permit hunting on privately owned land added to the Park under this subchapter, subject to limitations, conditions, or regulations that may be prescribed by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Termination of authority","label":"2 Termination of authority","identifier":"/us/usc/t16/s410fff–3/d/2","parentIdentifier":"/us/usc/t16/s410fff–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%933%2Fd%2F2","sourceRelease":"119-100","text":"On the date that the Secretary acquires fee ownership of any privately owned land added to the Park under this subchapter, the authority under paragraph (1) shall terminate with respect to the privately owned land acquired.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
