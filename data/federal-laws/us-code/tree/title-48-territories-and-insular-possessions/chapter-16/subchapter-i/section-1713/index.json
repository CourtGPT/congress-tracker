{"type":"section","nativeType":"section","number":"1713","heading":"Qualifications for Office of Delegate","label":"1713 Qualifications for Office of Delegate","identifier":"/us/usc/t48/s1713","parentIdentifier":"/us/usc/t48/ch16/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1713","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t48/s1713/a","parentIdentifier":"/us/usc/t48/s1713","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1713%2Fa","sourceRelease":"119-100","text":"be at least twenty-five years of age on the date of the election,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t48/s1713/b","parentIdentifier":"/us/usc/t48/s1713","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1713%2Fb","sourceRelease":"119-100","text":"have been a citizen of the United States for at least seven years prior to the date of the election,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t48/s1713/c","parentIdentifier":"/us/usc/t48/s1713","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1713%2Fc","sourceRelease":"119-100","text":"be an inhabitant of the territory from which he is elected, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t48/s1713/d","parentIdentifier":"/us/usc/t48/s1713","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1713%2Fd","sourceRelease":"119-100","text":"not be, on the date of the election, a candidat