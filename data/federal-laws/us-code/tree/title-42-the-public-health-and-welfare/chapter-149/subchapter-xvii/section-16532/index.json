,"label":"E","identifier":"/us/usc/t42/s16532/f/1/E","parentIdentifier":"/us/usc/t42/s16532/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Ff%2F1%2FE","sourceRelease":"119-100","text":"$10,100,000 for fiscal year 2012; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s16532/f/1/F","parentIdentifier":"/us/usc/t42/s16532/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Ff%2F1%2FF","sourceRelease":"119-100","text":"$10,400,000 for fiscal year 2013.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Nuclear science competitiveness grants for institutions of higher education","label":"2 Nuclear science competitiveness grants for institutions of higher education","identifier":"/us/usc/t42/s16532/f/2","parentIdentifier":"/us/usc/t42/s16532/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16532/f/2/A","parentIdentifier":"/us/usc/t42/s16532/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Ff%2F2%2FA","sourceRelease":"119-100","text":"$3,000,000 for fiscal year 2008;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16532/f/2/B","parentIdentifier":"/us/usc/t42/s16532/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Ff%2F2%2FB","sourceRelease":"119-100","text":"$5,500,000 for fiscal year 2009;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16532/f/2/C","parentIdentifier":"/us/usc/t42/s16532/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Ff%2F2%2FC","sourceRelease":"119-100","text":"$8,000,000 for fiscal year 2010;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16532/f/2/D","parentIdentifier":"/us/usc/t42/s16532/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Ff%2F2%2FD","sourceRelease":"119-100","text":"$8,240,000 for fiscal year 2011;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16532/f/2/E","parentIdentifier":"/us/usc/t42/s16532/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Ff%2F2%2FE","sourceRelease":"119-100","text":"$8,500,000 for fiscal year 2012; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s16532/f/2/F","parentIdentifier":"/us/usc/t42/s16532/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Ff%2F2%2FF","sourceRelease":"119-100","text":"$8,750,000 for fiscal year 2013.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
