{"type":"section","nativeType":"section","number":"10102a","heading":"Deployment prioritization and readiness of Army components","label":"10102a Deployment prioritization and readiness of Army components","identifier":"/us/usc/t10/s10102a","parentIdentifier":"/us/usc/t10/stE/ptI/ch1003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs10102a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Deployment Prioritization","label":"a .—Deployment Prioritization","identifier":"/us/usc/t10/s10102a/a","parentIdentifier":"/us/usc/t10/s10102a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs10102a%2Fa","sourceRelease":"119-100","text":"The Secretary of the Army shall maintain a system for identifying the priority of deployment for units of all components of the Army.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Deployability Readiness Rating","label":"b .—Deployability Readiness Rating","identifier":"/us/usc/t10/s10102a/b","parentIdentifier":"/us/usc/t10/s10102a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs10102a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s10102a/b/1","parentIdentifier":"/us/usc/t10/s10102a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs10102a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s10102a/b/1/A","parentIdentifier":"/us/usc/t10/s10102a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs10102a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"both the percentage of the overall personnel requirement of the unit that is manned and deployable and the fill and deployability rate for critical occupational specialties necessary for the unit to carry out its basic mission requirements; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s10102a/b/1/B","parentIdentifier":"/us/usc/t10/s10102a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs10102a%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the number of personnel in the unit who are qualified in their primary military occupational specialty; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s10102a/b/2","parentIdentifier":"/us/usc/t10/s10102a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs10102a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s10102a/b/2/A","parentIdentifier":"/us/usc/t10/s10102a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs10102a%2Fb%2F2%2FA","sourceRelease":"119-100","text":"documents all equipment required for deployment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s10102a/b/2/B","parentIdentifier":"/us/usc/t10/s10102a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs10102a%2Fb%2F2%2FB","sourceRelease":"119-100","text":"reflects only that equipment that is directly possessed by the unit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s10102a/b/2/C","parentIdentifier":"/us/usc/t10/s10102a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs10102a%2Fb%2F2%2FC","sourceRelease":"119-100","text":"specifies the effect of substitute items; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s10102a/b/2/D","parentIdentifier":"/us/usc/t10/s10102a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs10102a%2Fb%2F2%2FD","sourceRelease":"119-100","text":"assesses the effect of missing components and sets on the readiness of major equipment items.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
