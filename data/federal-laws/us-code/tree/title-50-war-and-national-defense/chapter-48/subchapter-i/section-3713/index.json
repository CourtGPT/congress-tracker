paragraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t50/s3713/c/2/D","parentIdentifier":"/us/usc/t50/s3713/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3713%2Fc%2F2%2FD","sourceRelease":"119-100","text":"the expected cost of such activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Covered activity defined","label":"d Covered activity defined","identifier":"/us/usc/t50/s3713/d","parentIdentifier":"/us/usc/t50/s3713","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3713%2Fd","sourceRelease":"119-100","text":"In this section, the term “covered activity” means an activity under the Program to address a threat arising from the proliferation of chemical, nuclear, or biological weapons or weapons-related materials, technologies, or expertise.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
