{"type":"section","nativeType":"section","number":"16093","heading":"Fuel cell school buses","label":"16093 Fuel cell school buses","identifier":"/us/usc/t42/s16093","parentIdentifier":"/us/usc/t42/ch149/schVII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16093","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t42/s16093/a","parentIdentifier":"/us/usc/t42/s16093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16093%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16093/a/1","parentIdentifier":"/us/usc/t42/s16093/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16093%2Fa%2F1","sourceRelease":"119-100","text":"with private sector fuel cell bus developers for the development of fuel cell-powered school buses; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16093/a/2","parentIdentifier":"/us/usc/t42/s16093/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16093%2Fa%2F2","sourceRelease":"119-100","text":"subsequently, with not less than 2 units of local government using natural gas-powered school buses and such private sector fuel cell bus developers to demonstrate the use of fuel cell-powered school buses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Cost sharing","label":"b Cost sharing","identifier":"/us/usc/t42/s16093/b","parentIdentifier":"/us/usc/t42/s16093","sourceUrl":"https://uscode.hou