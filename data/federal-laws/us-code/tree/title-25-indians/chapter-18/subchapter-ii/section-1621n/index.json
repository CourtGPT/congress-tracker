{"type":"section","nativeType":"section","number":"1621n","heading":"Comprehensive school health education programs","label":"1621n Comprehensive school health education programs","identifier":"/us/usc/t25/s1621n","parentIdentifier":"/us/usc/t25/ch18/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Award of grants","label":"a Award of grants","identifier":"/us/usc/t25/s1621n/a","parentIdentifier":"/us/usc/t25/s1621n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fa","sourceRelease":"119-100","text":"The Secretary, acting through the Service and in consultation with the Secretary of the Interior, may award grants to Indian tribes to develop comprehensive school health education programs for children from preschool through grade 12 in schools located on Indian reservations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Use of grants","label":"b Use of grants","identifier":"/us/usc/t25/s1621n/b","parentIdentifier":"/us/usc/t25/s1621n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s1621n/b/1","parentIdentifier":"/us/usc/t25/s1621n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fb%2F1","sourceRelease":"119-100","text":"develop health education curricula;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s1621n/b/2","parentIdentifier":"/us/usc/t25/s1621n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fb%2F2","sourceRelease":"119-100","text":"train teachers in comprehensive school health education curricula;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s1621n/b/3","parentIdentifier":"/us/usc/t25/s1621n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fb%2F3","sourceRelease":"119-100","text":"integrate school-based, community-based, and other public and private health promotion efforts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s1621n/b/4","parentIdentifier":"/us/usc/t25/s1621n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fb%2F4","sourceRelease":"119-100","text":"encourage healthy, tobacco-free school environments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s1621n/b/5","parentIdentifier":"/us/usc/t25/s1621n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fb%2F5","sourceRelease":"119-100","text":"coordinate school-based health programs with existing services and programs available in the community;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t25/s1621n/b/6","parentIdentifier":"/us/usc/t25/s1621n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fb%2F6","sourceRelease":"119-100","text":"develop school programs on nutrition education, personal health, and fitness;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t25/s1621n/b/7","parentIdentifier":"/us/usc/t25/s1621n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fb%2F7","sourceRelease":"119-100","text":"develop mental health wellness programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t25/s1621n/b/8","parentIdentifier":"/us/usc/t25/s1621n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fb%2F8","sourceRelease":"119-100","text":"develop chronic disease prevention programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t25/s1621n/b/9","parentIdentifier":"/us/usc/t25/s1621n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fb%2F9","sourceRelease":"119-100","text":"develop substance abuse prevention programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t25/s1621n/b/10","parentIdentifier":"/us/usc/t25/s1621n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fb%2F10","sourceRelease":"119-100","text":"develop accident prevention and safety education programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t25/s1621n/b/11","parentIdentifier":"/us/usc/t25/s1621n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fb%2F11","sourceRelease":"119-100","text":"develop activities for the prevention and control of communicable diseases; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t25/s1621n/b/12","parentIdentifier":"/us/usc/t25/s1621n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fb%2F12","sourceRelease":"119-100","text":"develop community and environmental health education programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Assistance","label":"c Assistance","identifier":"/us/usc/t25/s1621n/c","parentIdentifier":"/us/usc/t25/s1621n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fc","sourceRelease":"119-100","text":"The Secretary shall provide technical assistance to Indian tribes in the development of health education plans, and the dissemination of health education materials and information on existing health programs and resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Criteria for review and approval of applications","label":"d Criteria for review and approval of applications","identifier":"/us/usc/t25/s1621n/d","parentIdentifier":"/us/usc/t25/s1621n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fd","sourceRelease":"119-100","text":"The Secretary shall establish criteria for the review and approval of applications for grants made pursuant to this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Report of recipient","label":"e Report of recipient","identifier":"/us/usc/t25/s1621n/e","parentIdentifier":"/us/usc/t25/s1621n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s1621n/e/1","parentIdentifier":"/us/usc/t25/s1621n/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fe%2F1","sourceRelease":"119-100","text":"the number of preschools, elementary schools, and secondary schools served;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s1621n/e/2","parentIdentifier":"/us/usc/t25/s1621n/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fe%2F2","sourceRelease":"119-100","text":"the number of students served;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s1621n/e/3","parentIdentifier":"/us/usc/t25/s1621n/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fe%2F3","sourceRelease":"119-100","text":"any new curricula established with funds provided under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s1621n/e/4","parentIdentifier":"/us/usc/t25/s1621n/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fe%2F4","sourceRelease":"119-100","text":"the number of teachers trained in the health curricula; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s1621n/e/5","parentIdentifier":"/us/usc/t25/s1621n/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fe%2F5","sourceRelease":"119-100","text":"the involvement of parents, members of the community, and community health workers in programs established with funds provided under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Program development","label":"f Program development","identifier":"/us/usc/t25/s1621n/f","parentIdentifier":"/us/usc/t25/s1621n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s1621n/f/1","parentIdentifier":"/us/usc/t25/s1621n/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Ff%2F1","sourceRelease":"119-100","text":"The Secretary of the Interior, acting through the Bureau of Indian Affairs and in cooperation with the Secretary, shall develop a comprehensive school health education program for children from preschool through grade 12 in schools operated by the Bureau of Indian Affairs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s1621n/f/2","parentIdentifier":"/us/usc/t25/s1621n/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1621n/f/2/A","parentIdentifier":"/us/usc/t25/s1621n/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Ff%2F2%2FA","sourceRelease":"119-100","text":"school programs on nutrition education, personal health, and fitness;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","nu