{"type":"section","nativeType":"section","number":"3296","heading":"Counts dismissed pursuant to a plea agreement","label":"3296 Counts dismissed pursuant to a plea agreement","identifier":"/us/usc/t18/s3296","parentIdentifier":"/us/usc/t18/ptII/ch213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3296","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t18/s3296/a","parentIdentifier":"/us/usc/t18/s3296","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3296%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s3296/a/1","parentIdentifier":"/us/usc/t18/s3296/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3296%2Fa%2F1","sourceRelease":"119-100","text":"the counts sought to be reinstated were originally filed within the applicable limitations period;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s3296/a/2","parentIdentifier":"/us/usc/t18/s3296/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3296%2Fa%2F2","sourceRelease":"119-100","text":"the counts were dismissed pursuant to a plea agreement approved by the District Court under which the defendant pled guilty to other charges;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s3296/a/3","parentIdentifier":"/us/usc/t18/s3296/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3296%2Fa%2F3","sourceRelease":"119-100","text":"the guilty plea was subsequently vacated on the motion of the defendant; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t18/s3296/a/4","parentIdentifier":"/us/usc/t18/s3296/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3296%2Fa%2F4","sourceRelease":"119-100","text":"the United States moves to reinstate the dismissed counts within 60 days of the date on which the order vacating the plea becomes final.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Defenses; Objections","label":"b .—Defenses; Objections","identifier":"/us/usc/t18/s3296/b","parentIdentifier":"/us/usc/t18/s3296","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3296%2Fb","sourceRelease":"119-100","text":"Nothing in this section shall preclude the District Court from considering any defense or objection, other than statute of limitations, to the prosecution of the counts reinstated under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
