{"type":"section","nativeType":"section","number":"115","heading":"Veterans’ preference","label":"115 Veterans’ preference","identifier":"/us/usc/t3/s115","parentIdentifier":"/us/usc/t3/ch2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft3%2Fs115","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t3/s115/a","parentIdentifier":"/us/usc/t3/s115","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft3%2Fs115%2Fa","sourceRelease":"119-100","text":"Subject to subsection (b), appointments under sections 105, 106, and 107 shall be made in accordance with section 2108, and sections 3309 through 3312, of title 5.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t3/s115/b","parentIdentifier":"/us/usc/t3/s115","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft3%2Fs115%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t3/s115/b/1","parentIdentifier":"/us/usc/t3/s115/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft3%2Fs115%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t3/s115/b/1/A","parentIdentifier":"/us/usc/t3/s115/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft3%2Fs115%2Fb%2F1%2FA","sourceRelease":"119-100","text":"a confidential or policy-making position; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph"