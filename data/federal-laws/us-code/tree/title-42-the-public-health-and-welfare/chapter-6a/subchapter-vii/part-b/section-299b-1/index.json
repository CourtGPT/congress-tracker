ective use of drugs, biological products, and devices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t42/s299b–1/b/2/A/i/III","parentIdentifier":"/us/usc/t42/s299b–1/b/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb%2F2%2FA%2Fi%2FIII","sourceRelease":"119-100","text":"risks of new uses and risks of combinations of drugs and biological products.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s299b–1/b/2/A/ii","parentIdentifier":"/us/usc/t42/s299b–1/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s299b–1/b/2/A/ii/I","parentIdentifier":"/us/usc/t42/s299b–1/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb%2F2%2FA%2Fii%2FI","sourceRelease":"119-100","text":"Health care practitioners and other providers of health care goods or services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s299b–1/b/2/A/ii/II","parentIdentifier":"/us/usc/t42/s299b–1/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb%2F2%2FA%2Fii%2FII","sourceRelease":"119-100","text":"Pharmacists, pharmacy benefit managers and purchasers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t42/s299b–1/b/2/A/ii/III","parentIdentifier":"/us/usc/t42/s299b–1/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb%2F2%2FA%2Fii%2FIII","sourceRelease":"119-100","text":"Health maintenance organizations and other managed health care organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t42/s299b–1/b/2/A/ii/IV","parentIdentifier":"/us/usc/t42/s299b–1/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb%2F2%2FA%2Fii%2FIV","sourceRelease":"119-100","text":"Health care insurers and governmental agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t42/s299b–1/b/2/A/ii/V","parentIdentifier":"/us/usc/t42/s299b–1/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb%2F2%2FA%2Fii%2FV","sourceRelease":"119-100","text":"Patients and consumers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s299b–1/b/2/A/iii","parentIdentifier":"/us/usc/t42/s299b–1/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb%2F2%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s299b–1/b/2/A/iii/I","parentIdentifier":"/us/usc/t42/s299b–1/b/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb%2F2%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"an increase in the appropriate use of drugs, biological products, or devices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s299b–1/b/2/A/iii/II","parentIdentifier":"/us/usc/t42/s299b–1/b/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb%2F2%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"the prevention of adverse effects of drugs, biological products, and devices and the consequences of such effects, such as unnecessary hospitalizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s299b–1/b/2/B","parentIdentifier":"/us/usc/t42/s299b–1/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb%2F2%2FB","sourceRelease":"119-100","text":"The conduct of research on the comparative effectiveness, cost-effectiveness, and safety of drugs, biological products, and devices.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s299b–1/b/2/C","parentIdentifier":"/us/usc/t42/s299b–1/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb%2F2%2FC","sourceRelease":"119-100","text":"Such other activities as the Secretary determines to be appropriate, except that a grant may not be expended to assist the Secretary in the review of new drugs, biological products, and devices.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Reducing errors in medicine","label":"c Reducing errors in medicine","identifier":"/us/usc/t42/s299b–1/c","parentIdentifier":"/us/usc/t42/s299b–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s299b–1/c/1","parentIdentifier":"/us/usc/t42/s299b–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fc%2F1","sourceRelease":"119-100","text":"identify the causes of preventable health care errors and patient injury in health care delivery;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s299b–1/c/2","parentIdentifier":"/us/usc/t42/s299b–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fc%2F2","sourceRelease":"119-100","text":"develop, demonstrate, and evaluate strategies for reducing errors and improving patient safety; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s299b–1/c/3","parentIdentifier":"/us/usc/t42/s299b–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fc%2F3","sourceRelease":"119-100","text":"disseminate such effective strategies throughout the health care industry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
