{"type":"section","nativeType":"section","number":"922","heading":"National spectrum allocation planning","label":"922 National spectrum allocation planning","identifier":"/us/usc/t47/s922","parentIdentifier":"/us/usc/t47/ch8/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs922","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s922/1","parentIdentifier":"/us/usc/t47/s922","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs922%2F1","sourceRelease":"119-100","text":"the extent to which licenses for spectrum use can be issued pursuant to to increase Federal revenues;section 309(j) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s922/2","parentIdentifier":"/us/usc/t47/s922","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs922%2F2","sourceRelease":"119-100","text":"the future spectrum requirements for public and private uses, including State and local government public safety agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t47/s922/3","parentIdentifier":"/us/usc/t47/s922","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs922%2F3","sourceRelease":"119-100","text":"the spectrum allocation actions necessary to accommodate those uses; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t47/s922/4","parentIdentifier":"/us/usc/t47/s922","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs922%2F4","sourceRelease":"119-100","text":"actions necessary to promote the efficient use of the spectrum, including spectrum management techniques to promote increased shared use of the spectrum that does not cause harmful interference as a means of increasing commercial access.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
