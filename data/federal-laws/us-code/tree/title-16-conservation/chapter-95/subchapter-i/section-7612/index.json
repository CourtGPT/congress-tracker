{"type":"section","nativeType":"section","number":"7612","heading":"Statement of United States policy","label":"7612 Statement of United States policy","identifier":"/us/usc/t16/s7612","parentIdentifier":"/us/usc/t16/ch95/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s7612/1","parentIdentifier":"/us/usc/t16/s7612","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612%2F1","sourceRelease":"119-100","text":"to take immediate actions to stop the illegal global trade in wildlife and wildlife products and associated transnational organized crime;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s7612/2","parentIdentifier":"/us/usc/t16/s7612","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s7612/2/A","parentIdentifier":"/us/usc/t16/s7612/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612%2F2%2FA","sourceRelease":"119-100","text":"wildlife protection and management of wildlife populations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s7612/2/B","parentIdentifier":"/us/usc/t16/s7612/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612%2F2%2FB","sourceRelease":"119-100","text":"anti-poaching and effective management of protected areas including community managed and privately-owned lands;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s7612/2/C","parentIdentifier":"/us/usc/t16/s7612/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612%2F2%2FC","sourceRelease":"119-100","text":"local engagement of security forces in anti-poaching responsibilities, where appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s7612/2/D","parentIdentifier":"/us/usc/t16/s7612/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612%2F2%2FD","sourceRelease":"119-100","text":"wildlife trafficking investigative techniques, including forensic tools;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s7612/2/E","parentIdentifier":"/us/usc/t16/s7612/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612%2F2%2FE","sourceRelease":"119-100","text":"transparency and corruption issues;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t16/s7612/2/F","parentIdentifier":"/us/usc/t16/s7612/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612%2F2%2FF","sourceRelease":"119-100","text":"management, tracking, and inventory of confiscated wildlife contraband;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t16/s7612/2/G","parentIdentifier":"/us/usc/t16/s7612/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612%2F2%2FG","sourceRelease":"119-100","text":"demand reduction strategies in countries that lack the means and resources to conduct them; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t16/s7612/2/H","parentIdentifier":"/us/usc/t16/s7612/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612%2F2%2FH","sourceRelease":"119-100","text":"bilateral and multilateral agreements and cooperation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s7612/3","parentIdentifier":"/us/usc/t16/s7612","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612%2F3","sourceRelease":"119-100","text":"to employ appropriate assets and resources of the United States Government in a coordinated manner to curtail poaching and disrupt and dismantle illegal wildlife trade networks and the financing of those networks in a manner appropriate for each focus country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s7612/4","parentIdentifier":"/us/usc/t16/s7612","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612%2F4","sourceRelease":"119-100","text":"to build upon the National Strategy and Implementation Plan to further combat wildlife trafficking in a holistic manner and guide the response of the United States Government to ensure progress in the fight against wildlife trafficking; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s7612/5","parentIdentifier":"/us/usc/t16/s7612","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7612%2F5","sourceRelease":"119-100","text":"to recognize the ties of wildlife trafficking to broader forms of transnational organized criminal activities, including trafficking, and where applicable, to focus on those crimes in a coordinated, cross-cutting manner.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
