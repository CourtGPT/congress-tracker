{"type":"section","nativeType":"section","number":"21002","heading":"Allocation of funds","label":"21002 Allocation of funds","identifier":"/us/usc/t52/s21002","parentIdentifier":"/us/usc/t52/stII/ch209/schII/ptD/spt1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21002","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to , The Public Health and Welfare, prior to editorial reclassification and renumbering as this section.section 15402 of Title 42"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t52/s21002/a","parentIdentifier":"/us/usc/t52/s21002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21002%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t52/s21002/a/1","parentIdentifier":"/us/usc/t52/s21002/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21002%2Fa%2F1","sourceRelease":"119-100","text":"the total amount appropriated for requirements payments for the year pursuant to the authorization under ; andsection 21007 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t52/s21002/a/2","parentIdentifier":"/us/usc/t52/s21002/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21002%2Fa%2F2","sourceRelease":"119-100","text":"the State allocation percentage for the State (as determined under subsection (b)).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"State allocation percentage defined","label":"b State allocation percentage defined","identifier":"/us/usc/t52/s21002/b","parentIdentifier":"/us/usc/t52/s21002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21002%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t52/s21002/b/1","parentIdentifier":"/us/usc/t52/s21002/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21002%2Fb%2F1","sourceRelease":"119-100","text":"the voting age population of the State (as reported in the most recent decennial census); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t52/s21002/b/2","parentIdentifier":"/us/usc/t52/s21002/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21002%2Fb%2F2","sourceRelease":"119-100","text":"the total voting age population of all States (as reported in the most recent decennial census).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Minimum amount of payment","label":"c Minimum amount of payment","identifier":"/us/usc/t52/s21002/c","parentIdentifier":"/us/usc/t52/s21002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21002%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t52/s21002/c/1","parentIdentifier":"/us/usc/t52/s21002/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21002%2Fc%2F1","sourceRelease":"119-100","text":"in the case of any of the several States or the District of Columbia, one-half of 1 percent of the total amount appropriated for requirements payments for the year under ; orsection 21007 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t52/s21002/c/2","parentIdentifier":"/us/usc/t52/s21002/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21002%2Fc%2F2","sourceRelease":"119-100","text":"in the case of the Commonwealth of Puerto Rico, Guam, American Samoa, or the United States Virgin Islands, one-tenth of 1 percent of such total amount.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Pro rata reductions","label":"d Pro rata reductions","identifier":"/us/usc/t52/s21002/d","parentIdentifier":"/us/usc/t52/s21002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21002%2Fd","sourceRelease":"119-100","text":"The Administrator shall make such pro rata reductions to the allocations determined under subsection (a) as are necessary to comply with the requirements of subsection (c).1So in original. Probably should be “Commission”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Continuing availability of funds after appropriation","label":"e Continuing availability of funds after appropriation","identifier":"/us/usc/t52/s21002/e","parentIdentifier":"/us/usc/t52/s21002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21002%2Fe","sourceRelease":"119-100","text":"A requirements payment made to a State under this subpart shall be available to the State without fiscal year limitation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
