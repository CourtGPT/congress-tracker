{"type":"section","nativeType":"section","number":"3105","heading":"Forest management deduction","label":"3105 Forest management deduction","identifier":"/us/usc/t25/s3105","parentIdentifier":"/us/usc/t25/ch33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3105","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Withholding of deduction","label":"a Withholding of deduction","identifier":"/us/usc/t25/s3105/a","parentIdentifier":"/us/usc/t25/s3105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3105%2Fa","sourceRelease":"119-100","text":"Pursuant to the authority of , the Secretary shall withhold a reasonable deduction from the gross proceeds of sales of forest products harvested from Indian forest land under a timber sale contract, permit, or other harvest sale document, which has been approved by the Secretary, to cover in whole or part the cost of managing and protecting such Indian forest land.section 413 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Amount of deduction","label":"b Amount of deduction","identifier":"/us/usc/t25/s3105/b","parentIdentifier":"/us/usc/t25/s3105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3105%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s3105/b/1","parentIdentifier":"/us/usc/t25/s3105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3105%2Fb%2F1","sourceRelease":"119-100","text":"10 percent of gross proceeds, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s3105/b/2","parentIdentifier":"/us/usc/t25/s3105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3105%2Fb%2F2","sourceRelease":"119-100","text":"the percentage of gross proceeds collected on , as forest management deductions by the Secretary on such sales of Indian forest products,November 28, 1990","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Use of deduction","label":"c Use of deduction","identifier":"/us/usc/t25/s3105/c","parentIdentifier":"/us/usc/t25/s3105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3105%2Fc","sourceRelease":"119-100","text":"The full amount of any deduction collected by the Secretary shall be expended according to an approved expenditure plan, approved by the Secretary and the appropriate Indian tribe, for the performance of forest land management activities on the reservation from which such deductions are collected and shall be made available to the tribe, upon its request, by contract or agreement for the performance of such activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Limitations","label":"d Limitations","identifier":"/us/usc/t25/s3105/d","parentIdentifier":"/us/usc/t25/s3105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3105%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s3105/d/1","parentIdentifier":"/us/usc/t25/s3105/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3105%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3105/d/1/A","parentIdentifier":"/us/usc/t25/s3105/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3105%2Fd%2F1%2FA","sourceRelease":"119-100","text":"cover the costs that are paid from funds appropriated specifically for fire suppression or pest control, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3105/d/1/B","parentIdentifier":"/us/usc/t25/s3105/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3105%2Fd%2F1%2FB","sourceRelease":"119-100","text":"otherwise offset Federal appropriations for meeting the Federal trust responsibility for management of Indian forest lands.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s3105/d/2","parentIdentifier":"/us/usc/t25/s3105/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3105%2Fd%2F2","sourceRelease":"119-100","text":"No other forest management deductions derived from Indian forest lands shall be collected to be covered into the general funds of the United States Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
