{"type":"section","nativeType":"section","number":"4705","heading":"Notice of contract cancellation or termination relating to remote or isolated installations","label":"4705 Notice of contract cancellation or termination relating to remote or isolated installations","identifier":"/us/usc/t10/s4705","parentIdentifier":"/us/usc/t10/stA/ptV/sptH/ch365","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextSection 565 of the National Defense Authorization Act for Fiscal Year 2022, referred to in subsec. (d)(1), is , which is set out as a note under .section 565 of Pub. L. 117–81section 1781b of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t10/s4705/a","parentIdentifier":"/us/usc/t10/s4705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s4705/a/1","parentIdentifier":"/us/usc/t10/s4705/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705%2Fa%2F1","sourceRelease":"119-100","text":"50 remote or isolated installation contractor employees; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s4705/a/2","parentIdentifier":"/us/usc/t10/s4705/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705%2Fa%2F2","sourceRelease":"119-100","text":"100 employees of contractors, including remote or isolated installation contractor employees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Requirements","label":"b .—Requirements","identifier":"/us/usc/t10/s4705/b","parentIdentifier":"/us/usc/t10/s4705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705%2Fb","sourceRelease":"119-100","text":"A notice described in subsection (a) shall include an assessment of the effect of such cancellation or termination on members of the armed forces.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Waiver","label":"c .—Waiver","identifier":"/us/usc/t10/s4705/c","parentIdentifier":"/us/usc/t10/s4705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s4705/c/1","parentIdentifier":"/us/usc/t10/s4705/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary of Defense may waive the requirements of subsection (a) with respect to the cancellation or termination of a contract if the Secretary determines that such waiver is in the interest of national security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s4705/c/2","parentIdentifier":"/us/usc/t10/s4705/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705%2Fc%2F2","sourceRelease":"119-100","text":"If the Secretary waives the requirements of subsection (a) with respect to the cancellation or termination of a contract, the Secretary shall submit the notice required by such subsection with respect to such cancellation or termination not later than one week after such cancellation or termination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Definitions","label":"d .—Definitions","identifier":"/us/usc/t10/s4705/d","parentIdentifier":"/us/usc/t10/s4705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s4705/d/1","parentIdentifier":"/us/usc/t10/s4705/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705%2Fd%2F1","sourceRelease":"119-100","text":"The term “remote or isolated installation” means a military installation (as defined in ) that is a remote military installation, as determined by the Secretary pursuant to the policy required by section 565 of the National Defense Authorization Act for Fiscal Year 2022 ( note).section 2801 of this title10 U.S.C. 1781b","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s4705/d/2","parentIdentifier":"/us/usc/t10/s4705/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s4705/d/2/A","parentIdentifier":"/us/usc/t10/s4705/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705%2Fd%2F2%2FA","sourceRelease":"119-100","text":"is an employee of a contractor;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s4705/d/2/B","parentIdentifier":"/us/usc/t10/s4705/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705%2Fd%2F2%2FB","sourceRelease":"119-100","text":"as such an employee, provides goods or services to a remote or isolated installation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s4705/d/2/C","parentIdentifier":"/us/usc/t10/s4705/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs4705%2Fd%2F2%2FC","sourceRelease":"119-100","text":"resides in the same geographic area as such remote or isolated installation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
