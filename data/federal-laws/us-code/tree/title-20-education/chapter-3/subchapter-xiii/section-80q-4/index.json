{"type":"section","nativeType":"section","number":"80q–4","heading":"Director and staff of National Museum","label":"80q–4 Director and staff of National Museum","identifier":"/us/usc/t20/s80q–4","parentIdentifier":"/us/usc/t20/ch3/schXIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%934","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t20/s80q–4/a","parentIdentifier":"/us/usc/t20/s80q–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%934%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s80q–4/a/1","parentIdentifier":"/us/usc/t20/s80q–4/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%934%2Fa%2F1","sourceRelease":"119-100","text":"a Director who, subject to the policies of the Board of Trustees, shall manage the National Museum; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s80q–4/a/2","parentIdentifier":"/us/usc/t20/s80q–4/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%934%2Fa%2F2","sourceRelease":"119-100","text":"other employees of the National Museum, to serve under the Director.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Offer of employment to Heye Foundation employees","label":"b Offer of employment to Heye Foundation employees","identifier":"/us/usc/t20/s80q–4/b","parentIdentifier":"/us/usc/t20/s80q–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%934%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s80q–4/b/1","parentIdentifier":"/us/usc/t20/s80q–4/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%934%2Fb%2F1","sourceRelease":"119-100","text":"under the usual terms of such employment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s80q–4/b/2","parentIdentifier":"/us/usc/t20/s80q–4/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%934%2Fb%2F2","sourceRelease":"119-100","text":"at a rate of pay not less than the rate applicable to the employee on the day before the date of the transfer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Applicability of certain civil service laws","label":"c Applicability of certain civil service laws","identifier":"/us/usc/t20/s80q–4/c","parentIdentifier":"/us/usc/t20/s80q–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%934%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s80q–4/c/1","parentIdentifier":"/us/usc/t20/s80q–4/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%934%2Fc%2F1","sourceRelease":"119-100","text":"appoint the Director, 2 employees under subsection (a)(2), and the employees under subsection (b) without regard to the provisions of title 5, governing appointments in the competitive service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s80q–4/c/2","parentIdentifier":"/us/usc/t20/s80q–4/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%934%2Fc%2F2","sourceRelease":"119-100","text":"fix the pay of the Director and such 2 employees without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title, relating to classification and General Schedule pay rates; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s80q–4/c/3","parentIdentifier":"/us/usc/t20/s80q–4/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%934%2Fc%2F3","sourceRelease":"119-100","text":"fix the pay of the employees under subsection (b) in accordance with the provisions of chapter 51 and subchapter III of chapter 53 of such title, relating to classification and General Schedule pay rates, subject to subsection (b)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
