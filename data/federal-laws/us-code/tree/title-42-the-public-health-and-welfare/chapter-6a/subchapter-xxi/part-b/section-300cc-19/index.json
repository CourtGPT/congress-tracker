{"type":"section","nativeType":"section","number":"300cc–19","heading":"National blood resource education program","label":"300cc–19 National blood resource education program","identifier":"/us/usc/t42/s300cc–19","parentIdentifier":"/us/usc/t42/ch6A/schXXI/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9319","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300cc–19/1","parentIdentifier":"/us/usc/t42/s300cc–19","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9319%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300cc–19/1/A","parentIdentifier":"/us/usc/t42/s300cc–19/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9319%2F1%2FA","sourceRelease":"119-100","text":"increase awareness that the process of donating blood is safe;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300cc–19/1/B","parentIdentifier":"/us/usc/t42/s300cc–19/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9319%2F1%2FB","sourceRelease":"119-100","text":"promote the concept that blood donors are contributors to a national need to maintain an adequate and safe blood supply;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300cc–19/1/C","parentIdentifier":"/us/usc/t42/s300cc–19/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9319%2F1%2FC","sourceRelease":"119-100","text":"encourage blood donors to donate more than once a year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s300cc–19/1/D","parentIdentifier":"/us/usc/t42/s300cc–19/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9319%2F1%2FD","sourceRelease":"119-100","text":"encourage repeat blood donors to recruit new donors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300cc–19/2","parentIdentifier":"/us/usc/t42/s300cc–19","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9319%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300cc–19/2/A","parentIdentifier":"/us/usc/t42/s300cc–19/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9319%2F2%2FA","sourceRelease":"119-100","text":"improve knowledge, attitudes, and skills of health professionals in the appropriate use of blood and blood components;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300cc–19/2/B","parentIdentifier":"/us/usc/t42/s300cc–19/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9319%2F2%2FB","sourceRelease":"119-100","text":"increase the awareness and understanding of health professionals regarding the risks versus benefits of blood transfusion; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300cc–19/2/C","parentIdentifier":"/us/usc/t42/s300cc–19/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9319%2F2%2FC","sourceRelease":"119-100","text":"encourage health professionals to consider alternatives to the administration of blood or blood components for their patients; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300cc–19/3","parentIdentifier":"/us/usc/t42/s300cc–19","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9319%2F3","sourceRelease":"119-100","text":"in the case of the community, increase coordination, communication, and collaboration among community, professional, industry, and government organizations regarding blood donation and transfusion issues.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
