{"type":"section","nativeType":"section","number":"2192b","heading":"Program on enhancement of preparation of dependents of members of armed forces for careers in science, technology, engineering, and mathematics","label":"2192b Program on enhancement of preparation of dependents of members of armed forces for careers in science, technology, engineering, and mathematics","identifier":"/us/usc/t10/s2192b","parentIdentifier":"/us/usc/t10/stA/ptIII/ch111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Program Required","label":"a .—Program Required","identifier":"/us/usc/t10/s2192b/a","parentIdentifier":"/us/usc/t10/s2192b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2192b/a/1","parentIdentifier":"/us/usc/t10/s2192b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fa%2F1","sourceRelease":"119-100","text":"enhance the preparation of students at covered schools for careers in science, technology, engineering, and mathematics; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2192b/a/2","parentIdentifier":"/us/usc/t10/s2192b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fa%2F2","sourceRelease":"119-100","text":"provide assistance to teachers at covered schools to enhance preparation described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Coordination","label":"b .—Coordination","identifier":"/us/usc/t10/s2192b/b","parentIdentifier":"/us/usc/t10/s2192b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2192b/b/1","parentIdentifier":"/us/usc/t10/s2192b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fb%2F1","sourceRelease":"119-100","text":"The Secretaries of the military departments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2192b/b/2","parentIdentifier":"/us/usc/t10/s2192b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary of Education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2192b/b/3","parentIdentifier":"/us/usc/t10/s2192b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fb%2F3","sourceRelease":"119-100","text":"The National Science Foundation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s2192b/b/4","parentIdentifier":"/us/usc/t10/s2192b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fb%2F4","sourceRelease":"119-100","text":"Other organizations as the Secretary of Defense considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Activities","label":"c .—Activities","identifier":"/us/usc/t10/s2192b/c","parentIdentifier":"/us/usc/t10/s2192b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2192b/c/1","parentIdentifier":"/us/usc/t10/s2192b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fc%2F1","sourceRelease":"119-100","text":"Establishment of targeted internships and cooperative research opportunities at defense laboratories and other technical centers for students and teachers at covered schools.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2192b/c/2","parentIdentifier":"/us/usc/t10/s2192b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fc%2F2","sourceRelease":"119-100","text":"Establishment of scholarships and fellowships for students at covered schools.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2192b/c/3","parentIdentifier":"/us/usc/t10/s2192b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fc%2F3","sourceRelease":"119-100","text":"Efforts and activities that improve the quality of science, technology, engineering, and mathematics educational and training opportunities for students and teachers at covered schools, including with respect to improving the development of curricula at covered schools.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s2192b/c/4","parentIdentifier":"/us/usc/t10/s2192b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fc%2F4","sourceRelease":"119-100","text":"Development of travel opportunities, demonstrations, mentoring programs, and informal science education for students and teachers at covered schools.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Metrics","label":"d .—Metrics","identifier":"/us/usc/t10/s2192b/d","parentIdentifier":"/us/usc/t10/s2192b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fd","sourceRelease":"119-100","text":"The Secretary shall establish outcome-based metrics and internal and external assessments to evaluate the merits and benefits of activities conducted under the program with respect to the needs of the Department of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Covered Schools Defined","label":"e .—Covered Schools Defined","identifier":"/us/usc/t10/s2192b/e","parentIdentifier":"/us/usc/t10/s2192b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2192b%2Fe","sourceRelease":"119-100","text":"In this section, the term “covered schools” means elementary or secondary schools at which the Secretary determines a significant number of dependents of members of the armed forces are enrolled.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
