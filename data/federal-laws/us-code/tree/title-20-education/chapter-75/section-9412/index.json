{"type":"section","nativeType":"section","number":"9412","heading":"Local applications","label":"9412 Local applications","identifier":"/us/usc/t20/s9412","parentIdentifier":"/us/usc/t20/ch75","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9412","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t20/s9412/a","parentIdentifier":"/us/usc/t20/s9412","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9412%2Fa","sourceRelease":"119-100","text":"To be eligible to receive assistance under this chapter, the Local Council shall submit an application to the Lead State Agency at such time, in such manner, and containing such information as the Lead State Agency may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Contents","label":"b Contents","identifier":"/us/usc/t20/s9412/b","parentIdentifier":"/us/usc/t20/s9412","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9412%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s9412/b/1","parentIdentifier":"/us/usc/t20/s9412/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9412%2Fb%2F1","sourceRelease":"119-100","text":"a needs and resources assessment concerning early learning services and a statement describing how early learning programs will be funded consistent with the assessment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s9412/b/2","parentIdentifier":"/us/usc/t20/s9412/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9412%2Fb%2F2","sourceRelease":"119-100","text":"a statement of how the Local Council will ensure that early learning programs will meet the performance goals reported by the Lead State Agency under this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s9412/b/3","parentIdentifier":"/us/usc/t20/s9412/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9412%2Fb%2F3","sourceRelease":"119-100","text":"a description of how the Local Council will form collaboratives among local youth, social service, and educational providers to maximize resources and concentrate efforts on areas of greatest need.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
