a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F1%2FA%2Fiv","sourceRelease":"119-100","text":"environmental mitigation in or adjacent to Federal land to improve public safety and reduce vehicle-caused wildlife mortality while maintaining habitat connectivity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t23/s204/a/1/A/v","parentIdentifier":"/us/usc/t23/s204/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F1%2FA%2Fv","sourceRelease":"119-100","text":"construction and reconstruction of roadside rest areas, including sanitary and water facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t23/s204/a/1/A/vi","parentIdentifier":"/us/usc/t23/s204/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F1%2FA%2Fvi","sourceRelease":"119-100","text":"contextual wayfinding markers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t23/s204/a/1/A/vii","parentIdentifier":"/us/usc/t23/s204/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F1%2FA%2Fvii","sourceRelease":"119-100","text":"landscaping;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t23/s204/a/1/A/viii","parentIdentifier":"/us/usc/t23/s204/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F1%2FA%2Fviii","sourceRelease":"119-100","text":"cooperative mitigation of visual blight, including screening or removal; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ix","heading":null,"label":"ix","identifier":"/us/usc/t23/s204/a/1/A/ix","parentIdentifier":"/us/usc/t23/s204/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F1%2FA%2Fix","sourceRelease":"119-100","text":"other appropriate public road facilities, as determined by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t23/s204/a/1/B","parentIdentifier":"/us/usc/t23/s204/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F1%2FB","sourceRelease":"119-100","text":"operation and maintenance of transit facilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t23/s204/a/1/C","parentIdentifier":"/us/usc/t23/s204/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F1%2FC","sourceRelease":"119-100","text":"any transportation project eligible for assistance under this title that is within or adjacent to, or that provides access to, Federal land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Contract","label":"2 .—Contract","identifier":"/us/usc/t23/s204/a/2","parentIdentifier":"/us/usc/t23/s204/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t23/s204/a/2/A","parentIdentifier":"/us/usc/t23/s204/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F2%2FA","sourceRelease":"119-100","text":"a State (including a political subdivision of a State); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t23/s204/a/2/B","parentIdentifier":"/us/usc/t23/s204/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F2%2FB","sourceRelease":"119-100","text":"an Indian tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Administration","label":"3 .—Administration","identifier":"/us/usc/t23/s204/a/3","parentIdentifier":"/us/usc/t23/s204/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F3","sourceRelease":"119-100","text":"All appropriations for the construction and improvement of Federal lands access transportation facilities shall be administered in conformity with regulations and agreements approved by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Cooperation.—","label":"4 Cooperation.—","identifier":"/us/usc/t23/s204/a/4","parentIdentifier":"/us/usc/t23/s204/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t23/s204/a/4/A","parentIdentifier":"/us/usc/t23/s204/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F4%2FA","sourceRelease":"119-100","text":"The cooperation of States, counties, or other local subdivisions may be accepted in construction and improvement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Funds received","label":"B .—Funds received","identifier":"/us/usc/t23/s204/a/4/B","parentIdentifier":"/us/usc/t23/s204/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F4%2FB","sourceRelease":"119-100","text":"Any funds received from a State, county, or local subdivision for a Federal lands access transportation facility project shall be credited to appropriations available under the Federal lands access program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Competitive bidding.—","label":"5 Competitive bidding.—","identifier":"/us/usc/t23/s204/a/5","parentIdentifier":"/us/usc/t23/s204/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t23/s204/a/5/A","parentIdentifier":"/us/usc/t23/s204/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F5%2FA","sourceRelease":"119-100","text":"Subject to subparagraph (B), construction of each project shall be performed by contract awarded by competitive bidding.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Exception","label":"B .—Exception","identifier":"/us/usc/t23/s204/a/5/B","parentIdentifier":"/us/usc/t23/s204/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F5%2FB","sourceRelease":"119-100","text":"Subparagraph (A) shall not apply if the Secretary or the Secretary of the appropriate Federal land management agency affirmatively finds that, under the circumstances relating to the project, a different method is in the public interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":".—Native plant materials","label":"6 .—Native plant materials","identifier":"/us/usc/t23/s204/a/6","parentIdentifier":"/us/usc/t23/s204/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t23/s204/a/6/A","parentIdentifier":"/us/usc/t23/s204/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F6%2FA","sourceRelease":"119-100","text":"the use of locally adapted native plant materials; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t23/s204/a/6/B","parentIdentifier":"/us/usc/t23/s204/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fa%2F6%2FB","sourceRelease":"119-100","text":"designs that minimize runoff and heat generation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Program Distributions.—","label":"b Program Distributions.—","identifier":"/us/usc/t23/s204/b","parentIdentifier":"/us/usc/t23/s204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t23/s204/b/1","parentIdentifier":"/us/usc/t23/s204/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs204%2Fb%2F1","sourceRelease":