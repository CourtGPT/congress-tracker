{"type":"section","nativeType":"section","number":"608","heading":"Prioritization","label":"608 Prioritization","identifier":"/us/usc/t6/s608","parentIdentifier":"/us/usc/t6/ch1/schXV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t6/s608/a","parentIdentifier":"/us/usc/t6/s608","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s608/a/1","parentIdentifier":"/us/usc/t6/s608/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s608/a/1/A","parentIdentifier":"/us/usc/t6/s608/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1%2FA","sourceRelease":"119-100","text":"its population, including appropriate consideration of military, tourist, and commuter populations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s608/a/1/B","parentIdentifier":"/us/usc/t6/s608/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1%2FB","sourceRelease":"119-100","text":"its population density;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s608/a/1/C","parentIdentifier":"/us/usc/t6/s608/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1%2FC","sourceRelease":"119-100","text":"its history of threats, including whether it has been the target of a prior act of terrorism;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s608/a/1/D","parentIdentifier":"/us/usc/t6/s608/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1%2FD","sourceRelease":"119-100","text":"its degree of threat, vulnerability, and consequences related to critical infrastructure (for all critical infrastructure sectors) or key resources identified by the Administrator or the State homeland security plan, including threats, vulnerabilities, and consequences related to critical infrastructure or key resources in nearby jurisdictions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t6/s608/a/1/E","parentIdentifier":"/us/usc/t6/s608/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1%2FE","sourceRelease":"119-100","text":"the most current threat assessments available to the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t6/s608/a/1/F","parentIdentifier":"/us/usc/t6/s608/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1%2FF","sourceRelease":"119-100","text":"whether the State has, or the high-risk urban area is located at or near, an international border;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t6/s608/a/1/G","parentIdentifier":"/us/usc/t6/s608/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1%2FG","sourceRelease":"119-100","text":"whether it has a coastline bordering an ocean (including the Gulf of Mexico) or international waters;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t6/s608/a/1/H","parentIdentifier":"/us/usc/t6/s608/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1%2FH","sourceRelease":"119-100","text":"its likely need to respond to acts of terrorism occurring in nearby jurisdictions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t6/s608/a/1/I","parentIdentifier":"/us/usc/t6/s608/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1%2FI","sourceRelease":"119-100","text":"the extent to which it has unmet target capabilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t6/s608/a/1/J","parentIdentifier":"/us/usc/t6/s608/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1%2FJ","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s608/a/1/J/i","parentIdentifier":"/us/usc/t6/s608/a/1/J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1%2FJ%2Fi","sourceRelease":"119-100","text":"those incorporated municipalities, counties, parishes, and Indian tribes within the relevant eligible metropolitan area, the inclusion of which will enhance regional efforts to prevent, prepare for, protect against, and respond to acts of terrorism; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s608/a/1/J/ii","parentIdentifier":"/us/usc/t6/s608/a/1/J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1%2FJ%2Fii","sourceRelease":"119-100","text":"other local and tribal governments in the surrounding area that are likely to be called upon to respond to acts of terrorism within the high-risk urban area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"K","heading":null,"label":"K","identifier":"/us/usc/t6/s608/a/1/K","parentIdentifier":"/us/usc/t6/s608/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F1%2FK","sourceRelease":"119-100","text":"such other factors as are specified in writing by the Administrator; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s608/a/2","parentIdentifier":"/us/usc/t6/s608/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fa%2F2","sourceRelease":"119-100","text":"the anticipated effectiveness of the proposed use of the grant by the State or high-risk urban area in increasing the ability of that State or high-risk urban area to prevent, prepare for, protect against, and respond to acts of terrorism, to meet its target capabilities, and to otherwise reduce the overall risk to the high-risk urban area, the State, or the Nation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Types of threat","label":"b Types of threat","identifier":"/us/usc/t6/s608/b","parentIdentifier":"/us/usc/t6/s608","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s608/b/1","parentIdentifier":"/us/usc/t6/s608/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fb%2F1","sourceRelease":"119-100","text":"Biological.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s608/b/2","parentIdentifier":"/us/usc/t6/s608/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fb%2F2","sourceRelease":"119-100","text":"Chemical.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s608/b/3","parentIdentifier":"/us/usc/t6/s608/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fb%2F3","sourceRelease":"119-100","text":"Cyber.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s608/b/4","parentIdentifier":"/us/usc/t6/s608/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fb%2F4","sourceRelease":"119-100","text":"Explosives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s608/b/5","parentIdentifier":"/us/usc/t6/s608/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fb%2F5","sourceRelease":"119-100","text":"Incendiary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t6/s608/b/6","parentIdentifier":"/us/usc/t6/s608/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fb%2F6","sourceRelease":"119-100","text":"Nuclear.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t6/s608/b/7","parentIdentifier":"/us/usc/t6/s608/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fb%2F7","sourceRelease":"119-100","text":"Radiological.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t6/s608/b/8","parentIdentifier":"/us/usc/t6/s608/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fb%2F8","sourceRelease":"119-100","text":"Suicide bombers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t6/s608/b/9","parentIdentifier":"/us/usc/t6/s608/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs608%2Fb%2F9","sourceRelease":"119-100","text":"Such other types of threat determined relevant by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
