{"type":"section","nativeType":"section","number":"18647","heading":"Science laboratories infrastructure program","label":"18647 Science laboratories infrastructure program","identifier":"/us/usc/t42/s18647","parentIdentifier":"/us/usc/t42/ch161/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2022—Subsecs. (c) to (e). added subsecs. (c) to (e).Pub. L. 117–167"],"amendments":["Amendments2022—Subsecs. (c) to (e). added subsecs. (c) to (e).Pub. L. 117–167"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s18647/a","parentIdentifier":"/us/usc/t42/s18647","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fa","sourceRelease":"119-100","text":"The Director shall carry out a program to improve the safety, efficiency, and mission readiness of infrastructure at laboratories of the Office of Science.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Inclusions","label":"b Inclusions","identifier":"/us/usc/t42/s18647/b","parentIdentifier":"/us/usc/t42/s18647","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18647/b/1","parentIdentifier":"/us/usc/t42/s18647/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fb%2F1","sourceRelease":"119-100","text":"to renovate or replace space that does not meet research needs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18647/b/2","parentIdentifier":"/us/usc/t42/s18647/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fb%2F2","sourceRelease":"119-100","text":"to replace facilities that are no longer cost effective to renovate or operate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18647/b/3","parentIdentifier":"/us/usc/t42/s18647/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fb%2F3","sourceRelease":"119-100","text":"to modernize utility systems to prevent failures and ensure efficiency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18647/b/4","parentIdentifier":"/us/usc/t42/s18647/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fb%2F4","sourceRelease":"119-100","text":"to remove excess facilities to allow safe and efficient operations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s18647/b/5","parentIdentifier":"/us/usc/t42/s18647/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fb%2F5","sourceRelease":"119-100","text":"to construct modern facilities to conduct advanced research in controlled environmental conditions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Approach","label":"c Approach","identifier":"/us/usc/t42/s18647/c","parentIdentifier":"/us/usc/t42/s18647","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18647/c/1","parentIdentifier":"/us/usc/t42/s18647/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fc%2F1","sourceRelease":"119-100","text":"capital line items;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18647/c/2","parentIdentifier":"/us/usc/t42/s18647/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fc%2F2","sourceRelease":"119-100","text":"minor construction projects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18647/c/3","parentIdentifier":"/us/usc/t42/s18647/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fc%2F3","sourceRelease":"119-100","text":"energy savings performance contracts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18647/c/4","parentIdentifier":"/us/usc/t42/s18647/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fc%2F4","sourceRelease":"119-100","text":"utility energy service contracts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s18647/c/5","parentIdentifier":"/us/usc/t42/s18647/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fc%2F5","sourceRelease":"119-100","text":"alternative financing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s18647/c/6","parentIdentifier":"/us/usc/t42/s18647/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fc%2F6","sourceRelease":"119-100","text":"expense funding.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Submission to Congress","label":"d Submission to Congress","identifier":"/us/usc/t42/s18647/d","parentIdentifier":"/us/usc/t42/s18647","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fd","sourceRelease":"119-100","text":"For each fiscal year through fiscal year 2027, at the same time as the annual budget submission of the President, the Secretary shall submit to the Committee on Appropriations and the Committee on Energy and Natural Resources of the Senate and the Committee on Appropriations and the Committee on Science, Space, and Technology of the House of Representatives a list of projects for which the Secretary will provide funding under this section, including a description of each project and the funding profile for the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s18647/e","parentIdentifier":"/us/usc/t42/s18647","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18647%2Fe","sourceRelease":"119-100","text":"Out of funds authorized to be appropriated for the Office of Science in a fiscal year, there is authorized to be appropriated to the Secretary to carry out the activities described in this section $550,000,000 for each of fiscal years 2023 through 2027.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
