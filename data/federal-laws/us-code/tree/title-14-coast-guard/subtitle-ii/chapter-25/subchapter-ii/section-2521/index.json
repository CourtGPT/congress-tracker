{"type":"section","nativeType":"section","number":"2521","heading":"Advisory Board on Women in the Coast Guard","label":"2521 Advisory Board on Women in the Coast Guard","identifier":"/us/usc/t14/s2521","parentIdentifier":"/us/usc/t14/stII/ch25/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2521","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t14/s2521/a","parentIdentifier":"/us/usc/t14/s2521","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2521%2Fa","sourceRelease":"119-100","text":"The Commandant shall establish within the Coast Guard an Advisory Board on Women in the Coast Guard.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Membership","label":"b .—Membership","identifier":"/us/usc/t14/s2521/b","parentIdentifier":"/us/usc/t14/s2521","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2521%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s2521/b/1","parentIdentifier":"/us/usc/t14/s2521/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2521%2Fb%2F1","sourceRelease":"119-100","text":"Active duty officers of the Coast Guard.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s2521/b/2","parentIdentifier":"/us/usc/t14/s2521/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2521%2Fb%2F2","sourceRelease":"119-100","text":"Active duty enlisted members of the Coast Guard.","notes":[],"