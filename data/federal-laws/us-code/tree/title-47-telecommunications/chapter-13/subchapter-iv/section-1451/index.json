{"type":"section","nativeType":"section","number":"1451","heading":"Deadlines for auction of certain spectrum","label":"1451 Deadlines for auction of certain spectrum","identifier":"/us/usc/t47/s1451","parentIdentifier":"/us/usc/t47/ch13/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1451","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection is comprised of . Subsec. (c) of amended .section 6401 of Pub. L. 112–96section 6401 of Pub. L. 112–96section 309 of this title"],"amendments":["CodificationSection is comprised of . Subsec. (c) of amended .section 6401 of Pub. L. 112–96section 6401 of Pub. L. 112–96section 309 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Clearing certain Federal spectrum","label":"a Clearing certain Federal spectrum","identifier":"/us/usc/t47/s1451/a","parentIdentifier":"/us/usc/t47/s1451","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1451%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t47/s1451/a/1","parentIdentifier":"/us/usc/t47/s1451/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1451%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1451/a/1/A","parentIdentifier":"/us/usc/t47/s1451/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1451%2Fa%2F1%2FA","sourceRelease":"119-100","text":"not later than 3 years after , begin the process of withdrawing or modifying the assignment to a Federal Government station of the electromagnetic spectrum described in paragraph (2); andFebruary 22, 2012","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1451/a/1/B","parentIdentifier":"/us/usc/t47/s1451/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1451%2Fa%2F1%2FB","sourceRelease":"119-100","text":"not later than 30 days after completing the withdrawal or modification, notify the Commission that the withdrawal or modification is complete.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Spectrum described","label":"2 Spectrum described","identifier":"/us/usc/t47/s1451/a/2","parentIdentifier":"/us/usc/t47/s1451/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1451%2Fa%2F2","sourceRelease":"119-100","text":"The electromagnetic spectrum described in this paragraph is the 15 megahertz of spectrum between 1675 megahertz and 1710 megahertz identified under paragraph (3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Identification by Secretary of Commerce","label":"3 Identification by Secretary of Commerce","identifier":"/us/usc/t47/s1451/a/3","parentIdentifier":"/us/usc/t47/s1451/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1451%2Fa%2F3","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary of Commerce shall submit to the President a report identifying 15 megahertz of spectrum between 1675 megahertz and 1710 megahertz for reallocation from Federal use to non-Federal use.February 22, 2012","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Reallocation and auction","label":"b Reallocation and auction","identifier":"/us/usc/t47/s1451/b","parentIdentifier":"/us/usc/t47/s1451","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1451%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t47/s1451/b/1","parentIdentifier":"/us/usc/t47/s1451/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1451%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1451/b/1/A","parentIdentifier":"/us/usc/t47/s1451/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1451%2Fb%2F1%2FA","sourceRelease":"119-100","text":"allocate the spectrum described in paragraph (2) for commercial use; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1451/b/1/B","parentIdentifier":"/us/usc/t47/s1451/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1451%2Fb%2F1%2FB","sourceRelease":"119-100","text":"through a system of competitive bidding under such section, grant new initial licenses for the use of such spectrum, subject to flexible-use service rules.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Spectrum described","label":"2 Spectrum described","identifier":"/us/usc/t47/s1451/b/2","parentIdentifier":"/us/usc/t47/s1451/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1451%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A"