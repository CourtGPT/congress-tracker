{"type":"section","nativeType":"section","number":"3154h","heading":"Critical Supply Chain Site Development grant program","label":"3154h Critical Supply Chain Site Development grant program","identifier":"/us/usc/t42/s3154h","parentIdentifier":"/us/usc/t42/ch38/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s3154h/a","parentIdentifier":"/us/usc/t42/s3154h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fa","sourceRelease":"119-100","text":"On the application of an eligible recipient, the Secretary may make grants under the “Critical Supply Chain Site Development grant program” (referred to in this section as the “grant program”) to carry out site development or expansion projects for the purpose of making the site ready for manufacturing projects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Considerations","label":"b Considerations","identifier":"/us/usc/t42/s3154h/b","parentIdentifier":"/us/usc/t42/s3154h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s3154h/b/1","parentIdentifier":"/us/usc/t42/s3154h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fb%2F1","sourceRelease":"119-100","text":"the proposed improvements to the site will improve economic conditions for rural areas, Tribal communities, or areas that meet 1 or more of the criteria described in ;section 3161(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s3154h/b/2","parentIdentifier":"/us/usc/t42/s3154h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fb%2F2","sourceRelease":"119-100","text":"the project is consistent with regional economic development plans, which may include a comprehensive economic development strategy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s3154h/b/3","parentIdentifier":"/us/usc/t42/s3154h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fb%2F3","sourceRelease":"119-100","text":"the eligible recipient has initiatives to prioritize job training and workforce development; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s3154h/b/4","parentIdentifier":"/us/usc/t42/s3154h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fb%2F4","sourceRelease":"119-100","text":"the project supports industries determined by the Secretary to be of strategic importance to the national or economic security of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Priority","label":"c Priority","identifier":"/us/usc/t42/s3154h/c","parentIdentifier":"/us/usc/t42/s3154h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s3154h/c/1","parentIdentifier":"/us/usc/t42/s3154h/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fc%2F1","sourceRelease":"119-100","text":"has State, local, private, or nonprofit funds being contributed to assist with site development efforts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s3154h/c/2","parentIdentifier":"/us/usc/t42/s3154h/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fc%2F2","sourceRelease":"119-100","text":"if the site development or expansion project is carried out, will result in a demonstrated interest in the site by commercial entities or other entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Use of funds","label":"d Use of funds","identifier":"/us/usc/t42/s3154h/d","parentIdentifier":"/us/usc/t42/s3154h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s3154h/d/1","parentIdentifier":"/us/usc/t42/s3154h/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s3154h/d/1/A","parentIdentifier":"/us/usc/t42/s3154h/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F1%2FA","sourceRelease":"119-100","text":"construction of on-site utility infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s3154h/d/1/B","parentIdentifier":"/us/usc/t42/s3154h/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F1%2FB","sourceRelease":"119-100","text":"construction of last-mile infrastructure, including road infrastructure, water infrastructure, power infrastructure, broadband infrastructure, and other physical last-mile infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s3154h/d/1/C","parentIdentifier":"/us/usc/t42/s3154h/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F1%2FC","sourceRelease":"119-100","text":"site grading; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s3154h/d/1/D","parentIdentifier":"/us/usc/t42/s3154h/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F1%2FD","sourceRelease":"119-100","text":"other activities to extend public utilities or services to a site, as determined appropriate by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s3154h/d/2","parentIdentifier":"/us/usc/t42/s3154h/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s3154h/d/2/A","parentIdentifier":"/us/usc/t42/s3154h/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F2%2FA","sourceRelease":"119-100","text":"land assembly;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s3154h/d/2/B","parentIdentifier":"/us/usc/t42/s3154h/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F2%2FB","sourceRelease":"119-100","text":"environmental reviews;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s3154h/d/2/C","parentIdentifier":"/us/usc/t42/s3154h/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F2%2FC","sourceRelease":"119-100","text":"zoning;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s3154h/d/2/D","parentIdentifier":"/us/usc/t42/s3154h/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F2%2FD","sourceRelease":"119-100","text":"design;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s3154h/d/2/E","parentIdentifier":"/us/usc/t42/s3154h/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F2%2FE","sourceRelease":"119-100","text":"engineering; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s3154h/d/2/F","parentIdentifier":"/us/usc/t42/s3154h/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F2%2FF","sourceRelease":"119-100","text":"permitting.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s3154h/d/3","parentIdentifier":"/us/usc/t42/s3154h/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F3","sourceRelease":"119-100","text":"Investments in workforce development and sustainability programs, including job training and retraining programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s3154h/d/4","parentIdentifier":"/us/usc/t42/s3154h/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fd%2F4","sourceRelease":"119-100","text":"Investments to ensure that disadvantaged communities have access to on-site jobs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Prohibition","label":"e Prohibition","identifier":"/us/usc/t42/s3154h/e","parentIdentifier":"/us/usc/t42/s3154h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s3154h/e/1","parentIdentifier":"/us/usc/t42/s3154h/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fe%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2), in awarding grants under the grant program, the Secretary shall not require an eligible recipient to demonstrate that a private company or investment has selected the site for development or expansion.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Safeguards","label":"2 Safeguards","identifier":"/us/usc/t42/s3154h/e/2","parentIdentifier":"/us/usc/t42/s3154h/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s3154h/e/2/A","parentIdentifier":"/us/usc/t42/s3154h/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fe%2F2%2FA","sourceRelease":"119-100","text":"the site development is fully completed within a reasonable timeframe; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s3154h/e/2/B","parentIdentifier":"/us/usc/t42/s3154h/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154h%2Fe%2F2%2FB","sourceRelease":"119-100","text":"the eligible recipient has sufficiently demonstrated private sector interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
