{"type":"section","nativeType":"section","number":"50901","heading":"Confidentiality of peer support communications","label":"50901 Confidentiality of peer support communications","identifier":"/us/usc/t34/s50901","parentIdentifier":"/us/usc/t34/stV/ch509","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Short TitleFor short title of , which is classified to this chapter, as the “Confidentiality Opportunities for Peer Support Counseling Act” and also as the “COPS Counseling Act”, see , set out as a Short Title of 2021 Amendment note under .Pub. L. 117–60section 1 of Pub. L. 117–60section 10101 of this title"],"amendments":["Short TitleFor short title of , which is classified to this chapter, as the “Confidentiality Opportunities for Peer Support Counseling Act” and also as the “COPS Counseling Act”, see , set out as a Short Title of 2021 Amendment note under .Pub. L. 117–60section 1 of Pub. L. 117–60section 10101 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t34/s50901/a","parentIdentifier":"/us/usc/t34/s50901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Law enforcement agency","label":"1 Law enforcement agency","identifier":"/us/usc/t34/s50901/a/1","parentIdentifier":"/us/usc/t34/s50901/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F1","sourceRelease":"119-100","text":"The term “law enforcement agency” means a Federal agency that employs a law enforcement officer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Law enforcement officer","label":"2 Law enforcement officer","identifier":"/us/usc/t34/s50901/a/2","parentIdentifier":"/us/usc/t34/s50901/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F2","sourceRelease":"119-100","text":"The term “law enforcement officer” has the meaning given the term “Federal law enforcement officer” in .section 115 of title 18","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Peer support communication","label":"3 Peer support communication","identifier":"/us/usc/t34/s50901/a/3","parentIdentifier":"/us/usc/t34/s50901/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50901/a/3/A","parentIdentifier":"/us/usc/t34/s50901/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F3%2FA","sourceRelease":"119-100","text":"an oral or written communication made in the course of a peer support counseling session;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50901/a/3/B","parentIdentifier":"/us/usc/t34/s50901/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F3%2FB","sourceRelease":"119-100","text":"a note or report arising out of a peer support counseling session;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s50901/a/3/C","parentIdentifier":"/us/usc/t34/s50901/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F3%2FC","sourceRelease":"119-100","text":"a record of a peer support counseling session; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s50901/a/3/D","parentIdentifier":"/us/usc/t34/s50901/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F3%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s50901/a/3/D/i","parentIdentifier":"/us/usc/t34/s50901/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F3%2FD%2Fi","sourceRelease":"119-100","text":"another peer support specialist;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s50901/a/3/D/ii","parentIdentifier":"/us/usc/t34/s50901/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F3%2FD%2Fii","sourceRelease":"119-100","text":"a staff member of a peer support counseling program; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s50901/a/3/D/iii","parentIdentifier":"/us/usc/t34/s50901/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F3%2FD%2Fiii","sourceRelease":"119-100","text":"a supervisor of the peer support specialist.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Peer support counseling program","label":"4 Peer support counseling program","identifier":"/us/usc/t34/s50901/a/4","parentIdentifier":"/us/usc/t34/s50901/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F4","sourceRelease":"119-100","text":"The term “peer support counseling program” means a program provided by a law enforcement agency that provides counseling services from a peer support specialist to a law enforcement officer of the agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Peer support counseling session","label":"5 Peer support counseling session","identifier":"/us/usc/t34/s50901/a/5","parentIdentifier":"/us/usc/t34/s50901/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F5","sourceRelease":"119-100","text":"The term “peer support counseling session” means any counseling formally provided through a peer support counseling program between a peer support specialist and 1 or more law enforcement officers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Peer support participant","label":"6 Peer support participant","identifier":"/us/usc/t34/s50901/a/6","parentIdentifier":"/us/usc/t34/s50901/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F6","sourceRelease":"119-100","text":"The term “peer support participant” means a law enforcement officer who receives counseling services from a peer support specialist.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Peer support specialist","label":"7 Peer support specialist","identifier":"/us/usc/t34/s50901/a/7","parentIdentifier":"/us/usc/t34/s50901/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50901/a/7/A","parentIdentifier":"/us/usc/t34/s50901/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F7%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s50901/a/7/A/i","parentIdentifier":"/us/usc/t34/s50901/a/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F7%2FA%2Fi","sourceRelease":"119-100","text":"peer support counseling; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s50901/a/7/A/ii","parentIdentifier":"/us/usc/t34/s50901/a/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F7%2FA%2Fii","sourceRelease":"119-100","text":"providing emotional and moral support to law enforcement officers who have been involved in or exposed to an emotionally traumatic experience in the course of employment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50901/a/7/B","parentIdentifier":"/us/usc/t34/s50901/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fa%2F7%2FB","sourceRelease":"119-100","text":"is designated by a law enforcement agency to provide the services described in subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Prohibition","label":"b Prohibition","identifier":"/us/usc/t34/s50901/b","parentIdentifier":"/us/usc/t34/s50901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fb","sourceRelease":"119-100","text":"Except as provided in subsection (c), a peer support specialist or a peer support participant may not disclose the contents of a peer support communication to an individual who was not a party to the peer support communication.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Exceptions","label":"c Exceptions","identifier":"/us/usc/t34/s50901/c","parentIdentifier":"/us/usc/t34/s50901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s50901/c/1","parentIdentifier":"/us/usc/t34/s50901/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50901/c/1/A","parentIdentifier":"/us/usc/t34/s50901/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s50901/c/1/A/i","parentIdentifier":"/us/usc/t34/s50901/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t34/s50901/c/1/A/i/I","parentIdentifier":"/us/usc/t34/s50901/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F1%2FA%2Fi%2FI","sourceRelease":"119-100","text":"an intent to die by suicide; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t34/s50901/c/1/A/i/II","parentIdentifier":"/us/usc/t34/s50901/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F1%2FA%2Fi%2FII","sourceRelease":"119-100","text":"a plan for a suicide attempt or the means by which the individual plans to carry out a suicide attempt; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s50901/c/1/A/ii","parentIdentifier":"/us/usc/t34/s50901/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"does not solely share that the individual is experiencing suicidal thoughts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50901/c/1/B","parentIdentifier":"/us/usc/t34/s50901/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F1%2FB","sourceRelease":"119-100","text":"an explicit threat by an individual of imminent and serious physical bodily harm or death to another individual;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s50901/c/1/C","parentIdentifier":"/us/usc/t34/s50901/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s50901/c/1/C/i","parentIdentifier":"/us/usc/t34/s50901/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F1%2FC%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t34/s50901/c/1/C/i/I","parentIdentifier":"/us/usc/t34/s50901/c/1/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F1%2FC%2Fi%2FI","sourceRelease":"119-100","text":"a child; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t34/s50901/c/1/C/i/II","parentIdentifier":"/us/usc/t34/s50901/c/1/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F1%2FC%2Fi%2FII","sourceRelease":"119-100","text":"an older or vulnerable individual; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s50901/c/1/C/ii","parentIdentifier":"/us/usc/t34/s50901/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F1%2FC%2Fii","sourceRelease":"119-100","text":"that is required by law to be reported; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s50901/c/1/D","parentIdentifier":"/us/usc/t34/s50901/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F1%2FD","sourceRelease":"119-100","text":"an admission of criminal conduct;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s50901/c/2","parentIdentifier":"/us/usc/t34/s50901/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50901/c/2/A","parentIdentifier":"/us/usc/t34/s50901/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the peer support communication;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50901/c/2/B","parentIdentifier":"/us/usc/t34/s50901/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the peer support counseling session out of which the peer support communication arose;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s50901/c/2/C","parentIdentifier":"/us/usc/t34/s50901/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F2%2FC","sourceRelease":"119-100","text":"the peer support counseling session of which the peer support communication is a record; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s50901/c/2/D","parentIdentifier":"/us/usc/t34/s50901/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F2%2FD","sourceRelease":"119-100","text":"the communication made in the course of a peer support counseling session that the peer support communication is regarding;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s50901/c/3","parentIdentifier":"/us/usc/t34/s50901/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F3","sourceRelease":"119-100","text":"a court of competent jurisdiction issues an order or subpoena requiring the disclosure of the peer support communication; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t34/s50901/c/4","parentIdentifier":"/us/usc/t34/s50901/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fc%2F4","sourceRelease":"119-100","text":"the peer support communication contains information that is required by law to be disclosed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Rule of construction","label":"d Rule of construction","identifier":"/us/usc/t34/s50901/d","parentIdentifier":"/us/usc/t34/s50901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s50901/d/1","parentIdentifier":"/us/usc/t34/s50901/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fd%2F1","sourceRelease":"119-100","text":"an observation made by a law enforcement officer of a peer support participant outside of a peer support counseling session; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s50901/d/2","parentIdentifier":"/us/usc/t34/s50901/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fd%2F2","sourceRelease":"119-100","text":"knowledge of a law enforcement officer about a peer support participant not gained from a peer support communication.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Disclosure of rights","label":"e Disclosure of rights","identifier":"/us/usc/t34/s50901/e","parentIdentifier":"/us/usc/t34/s50901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50901%2Fe","sourceRelease":"119-100","text":"Before the initial peer support counseling session of a peer support participant, a peer support specialist shall inform the peer support participant in writing of the confidentiality requirement under subsection (b) and the exceptions to the requirement under subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
