{"type":"section","nativeType":"section","number":"460rrr–2","heading":"Establishment of the Commission","label":"460rrr–2 Establishment of the Commission","identifier":"/us/usc/t16/s460rrr–2","parentIdentifier":"/us/usc/t16/ch1/schCXXIX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t16/s460rrr–2/a","parentIdentifier":"/us/usc/t16/s460rrr–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fa","sourceRelease":"119-100","text":"There is established the Rio Grande Natural Area Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purpose","label":"b Purpose","identifier":"/us/usc/t16/s460rrr–2/b","parentIdentifier":"/us/usc/t16/s460rrr–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460rrr–2/b/1","parentIdentifier":"/us/usc/t16/s460rrr–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fb%2F1","sourceRelease":"119-100","text":"advise the Secretary with respect to the Natural Area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460rrr–2/b/2","parentIdentifier":"/us/usc/t16/s460rrr–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fb%2F2","sourceRelease":"119-100","text":"prepare a management plan relating to non-Federal land in the Natural Area under .section 460rrr–4(b)(2)(A) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Membership","label":"c Membership","identifier":"/us/usc/t16/s460rrr–2/c","parentIdentifier":"/us/usc/t16/s460rrr–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460rrr–2/c/1","parentIdentifier":"/us/usc/t16/s460rrr–2/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fc%2F1","sourceRelease":"119-100","text":"1 member shall represent the Colorado State Director of the Bureau of Land Management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460rrr–2/c/2","parentIdentifier":"/us/usc/t16/s460rrr–2/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fc%2F2","sourceRelease":"119-100","text":"1 member shall be the manager of the Alamosa National Wildlife Refuge, ex officio;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s460rrr–2/c/3","parentIdentifier":"/us/usc/t16/s460rrr–2/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460rrr–2/c/3/A","parentIdentifier":"/us/usc/t16/s460rrr–2/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fc%2F3%2FA","sourceRelease":"119-100","text":"1 member shall represent the Colorado Division of Wildlife;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460rrr–2/c/3/B","parentIdentifier":"/us/usc/t16/s460rrr–2/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fc%2F3%2FB","sourceRelease":"119-100","text":"1 member shall represent the Colorado Division of Water Resources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s460rrr–2/c/3/C","parentIdentifier":"/us/usc/t16/s460rrr–2/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fc%2F3%2FC","sourceRelease":"119-100","text":"1 member shall represent the Rio Grande Water Conservation District; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s460rrr–2/c/4","parentIdentifier":"/us/usc/t16/s460rrr–2/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460rrr–2/c/4/A","parentIdentifier":"/us/usc/t16/s460rrr–2/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fc%2F4%2FA","sourceRelease":"119-100","text":"represent the general public;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460rrr–2/c/4/B","parentIdentifier":"/us/usc/t16/s460rrr–2/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fc%2F4%2FB","sourceRelease":"119-100","text":"be citizens of the local region in which the Natural Area is established; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s460rrr–2/c/4/C","parentIdentifier":"/us/usc/t16/s460rrr–2/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fc%2F4%2FC","sourceRelease":"119-100","text":"have knowledge and experience in the fields of interest relating to the preservation, restoration, and use of the Natural Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Terms of office","label":"d Terms of office","identifier":"/us/usc/t16/s460rrr–2/d","parentIdentifier":"/us/usc/t16/s460rrr–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s460rrr–2/d/1","parentIdentifier":"/us/usc/t16/s460rrr–2/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fd%2F1","sourceRelease":"119-100","text":"Except for the manager of the Alamosa National Wildlife Refuge, the term of office of a member of the Commission shall be 5 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Reappointment","label":"2 Reappointment","identifier":"/us/usc/t16/s460rrr–2/d/2","parentIdentifier":"/us/usc/t16/s460rrr–2/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fd%2F2","sourceRelease":"119-100","text":"A member may be reappointed to the Commission on completion of the term of office of the member.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Compensation","label":"e Compensation","identifier":"/us/usc/t16/s460rrr–2/e","parentIdentifier":"/us/usc/t16/s460rrr–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fe","sourceRelease":"119-100","text":"A member of the Commission shall serve without compensation for service on the Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Chairperson","label":"f Chairperson","identifier":"/us/usc/t16/s460rrr–2/f","parentIdentifier":"/us/usc/t16/s460rrr–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Ff","sourceRelease":"119-100","text":"The Commission shall elect a chairperson of the Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Meetings","label":"g Meetings","identifier":"/us/usc/t16/s460rrr–2/g","parentIdentifier":"/us/usc/t16/s460rrr–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s460rrr–2/g/1","parentIdentifier":"/us/usc/t16/s460rrr–2/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fg%2F1","sourceRelease":"119-100","text":"The Commission shall meet at least quarterly at the call of the chairperson.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Public meetings","label":"2 Public meetings","identifier":"/us/usc/t16/s460rrr–2/g/2","parentIdentifier":"/us/usc/t16/s460rrr–2/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fg%2F2","sourceRelease":"119-100","text":"A meeting of the Commission shall be open to the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Notice","label":"3 Notice","identifier":"/us/usc/t16/s460rrr–2/g/3","parentIdentifier":"/us/usc/t16/s460rrr–2/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fg%2F3","sourceRelease":"119-100","text":"Notice of any meeting of the Commission shall be published in advance of the meeting.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Technical assistance","label":"h Technical assistance","identifier":"/us/usc/t16/s460rrr–2/h","parentIdentifier":"/us/usc/t16/s460rrr–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%932%2Fh","sourceRelease":"119-100","text":"The Secretary and the heads of other Federal agencies shall, to the maximum extent practicable, provide any information and technical services requested by the Commission to assist in carrying out the duties of the Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
