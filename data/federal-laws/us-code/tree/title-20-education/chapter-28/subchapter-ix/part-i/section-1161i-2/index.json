0","text":"Grants under this part shall be awarded on a competitive basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Equitable geographic distribution","label":"c Equitable geographic distribution","identifier":"/us/usc/t20/s1161i–2/c","parentIdentifier":"/us/usc/t20/s1161i–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%932%2Fc","sourceRelease":"119-100","text":"In awarding grants under this part, the Secretary shall take into consideration providing an equitable geographic distribution of such grants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Duration","label":"d Duration","identifier":"/us/usc/t20/s1161i–2/d","parentIdentifier":"/us/usc/t20/s1161i–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%932%2Fd","sourceRelease":"119-100","text":"Grants under this part shall be awarded for a period of five years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
