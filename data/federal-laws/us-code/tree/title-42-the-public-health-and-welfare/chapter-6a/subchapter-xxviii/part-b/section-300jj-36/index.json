{"type":"section","nativeType":"section","number":"300jj–36","heading":"Information technology professionals in health care","label":"300jj–36 Information technology professionals in health care","identifier":"/us/usc/t42/s300jj–36","parentIdentifier":"/us/usc/t42/ch6A/schXXVIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9336","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s300jj–36/a","parentIdentifier":"/us/usc/t42/s300jj–36","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9336%2Fa","sourceRelease":"119-100","text":"The Secretary, in consultation with the Director of the National Science Foundation, shall provide assistance to institutions of higher education (or consortia thereof) to establish or expand medical health informatics education programs, including certification, undergraduate, and masters degree programs, for both health care and information technology students to ensure the rapid and effective utilization and development of health information technologies (in the United States health care infrastructure).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Activities","label":"b Activities","identifier":"/us/usc/t42/s300jj–36/b","parentIdentifier":"/us/usc/t42/s300jj–36","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9336%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300jj–36/b/1","parentIdentifier":"/us/usc/t42/s300jj–36/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9336%2Fb%2F1","sourceRelease":"119-100","text":"Developing and revising curricula in medical health informatics and related disciplines.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300jj–36/b/2","parentIdentifier":"/us/usc/t42/s300jj–36/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9336%2Fb%2F2","sourceRelease":"119-100","text":"Recruiting and retaining students to the program involved.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300jj–36/b/3","parentIdentifier":"/us/usc/t42/s300jj–36/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9336%2Fb%2F3","sourceRelease":"119-100","text":"Acquiring equipment necessary for student instruction in these programs, including the installation of testbed networks for student use.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s300jj–36/b/4","parentIdentifier":"/us/usc/t42/s300jj–36/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9336%2Fb%2F4","sourceRelease":"119-100","text":"Establishing or enhancing bridge programs in the health informatics fields between community colleges and universities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Priority","label":"c Priority","identifier":"/us/usc/t42/s300jj–36/c","parentIdentifier":"/us/usc/t42/s300jj–36","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9336%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300jj–36/c/1","parentIdentifier":"/us/usc/t42/s300jj–36/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9336%2Fc%2F1","sourceRelease":"119-100","text":"Existing education and training programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300jj–36/c/2","parentIdentifier":"/us/usc/t42/s300jj–36/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9336%2Fc%2F2","sourceRelease":"119-100","text":"Programs designed to be completed in less than six months.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
