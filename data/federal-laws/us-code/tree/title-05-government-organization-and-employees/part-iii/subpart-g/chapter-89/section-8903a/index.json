{"type":"section","nativeType":"section","number":"8903a","heading":"Additional health benefits plans","label":"8903a Additional health benefits plans","identifier":"/us/usc/t5/s8903a","parentIdentifier":"/us/usc/t5/ptIII/sptG/ch89","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8903a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s8903a/a","parentIdentifier":"/us/usc/t5/s8903a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8903a%2Fa","sourceRelease":"119-100","text":"In addition to any plan under , the Office of Personnel Management may contract for or approve one or more health benefits plans under this section.section 8903 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s8903a/b","parentIdentifier":"/us/usc/t5/s8903a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8903a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s8903a/b/1","parentIdentifier":"/us/usc/t5/s8903a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8903a%2Fb%2F1","sourceRelease":"119-100","text":"is sponsored or underwritten, and administered, in whole or substantial part, by an employee organization described in ;section 8901(8)(B) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s8903a/b/2","parentIdentifier":"/us/usc/t5/s8903a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8903a%2Fb%2F2","sourceRelease":"119-100","text":"offers benefits of the types named by paragraph (1) or (2) of or both;section 8904 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s8903a/b/3","parentIdentifier":"/us/usc/t5/s8903a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8903a%2Fb%2F3","sourceRelease":"119-100","text":"provides for benefits only by paying for, or providing reimbursement for, the cost of such benefits (as provided for under paragraph (1) or (2) of ) or a combination thereof; andsection 8903 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t5/s8903a/b/4","parentIdentifier":"/us/usc/t5/s8903a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8903a%2Fb%2F4","sourceRelease":"119-100","text":"is available only to individuals who, at the time of enrollment, are full members of the organization and to members of their families.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t5/s8903a/c","parentIdentifier":"/us/usc/t5/s8903a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8903a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s8903a/c/1","parentIdentifier":"/us/usc/t5/s8903a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8903a%2Fc%2F1","sourceRelease":"119-100","text":"to enter into an agreement approved by the Office with an underwriting subcontractor licensed to issue group health insurance in all the States and the District of Columbia; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s8903a/c/2","parentIdentifier":"/us/usc/t5/s8903a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8903a%2Fc%2F2","sourceRelease":"119-100","text":"to demonstrate ability to meet reasonable minimum financial standards prescribed by the Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t5/s8903a/d","parentIdentifier":"/us/usc/t5/s8903a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8903a%2Fd","sourceRelease":"119-100","text":"For the purpose of this section, an individual shall be considered a full member of an organization if such individual is eligible to exercise all rights and privileges incident to full membership in such organization (determined without regard to the right to hold elected office).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
