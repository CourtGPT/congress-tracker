{"type":"section","nativeType":"section","number":"539m–5","heading":"Management of the Area","label":"539m–5 Management of the Area","identifier":"/us/usc/t16/s539m–5","parentIdentifier":"/us/usc/t16/ch2/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Process","label":"a Process","identifier":"/us/usc/t16/s539m–5/a","parentIdentifier":"/us/usc/t16/s539m–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s539m–5/a/1","parentIdentifier":"/us/usc/t16/s539m–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary shall consult with the Pueblo not less than twice each year, unless otherwise mutually agreed, concerning protection, preservation, and management of the Area (including proposed new uses and modified uses in the Area and authorizations that are anticipated during the next 6 months and were approved in the preceding 6 months).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"New uses","label":"2 New uses","identifier":"/us/usc/t16/s539m–5/a/2","parentIdentifier":"/us/usc/t16/s539m–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Request for consent after consultation","label":"A Request for consent after consultation","identifier":"/us/usc/t16/s539m–5/a/2/A","parentIdentifier":"/us/usc/t16/s539m–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"Denial of consent","label":"i Denial of consent","identifier":"/us/usc/t16/s539m–5/a/2/A/i","parentIdentifier":"/us/usc/t16/s539m–5/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"If the Pueblo denies consent for a new use within 30 days after completion of the consultation process, the Secretary shall not proceed with the new use.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Granting of consent","label":"ii Granting of consent","identifier":"/us/usc/t16/s539m–5/a/2/A/ii","parentIdentifier":"/us/usc/t16/s539m–5/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"If the Pueblo consents to the new use in writing or fails to respond within 30 days after completion of the consultation process, the Secretary may proceed with the notice and comment process and the environmental analysis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Final request for consent","label":"B Final request for consent","identifier":"/us/usc/t16/s539m–5/a/2/B","parentIdentifier":"/us/usc/t16/s539m–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"Request","label":"i Request","identifier":"/us/usc/t16/s539m–5/a/2/B/i","parentIdentifier":"/us/usc/t16/s539m–5/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"Before the Secretary (or a designee) signs a record of decision or decision notice for a proposed new use, the Secretary shall again request the consent of the Pueblo.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Denial of consent","label":"ii Denial of consent","identifier":"/us/usc/t16/s539m–5/a/2/B/ii","parentIdentifier":"/us/usc/t16/s539m–5/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"If the Pueblo denies consent for a new use within 30 days after receipt by the Pueblo of the proposed record of decision or decision notice, the new use shall not be authorized.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":"Failure to respond","label":"iii Failure to respond","identifier":"/us/usc/t16/s539m–5/a/2/B/iii","parentIdentifier":"/us/usc/t16/s539m–5/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F2%2FB%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s539m–5/a/2/B/iii/I","parentIdentifier":"/us/usc/t16/s539m–5/a/2/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F2%2FB%2Fiii%2FI","sourceRelease":"119-100","text":"the Pueblo shall be deemed to have consented to the proposed record of decision or decision notice; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s539m–5/a/2/B/iii/II","parentIdentifier":"/us/usc/t16/s539m–5/a/2/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F2%2FB%2Fiii%2FII","sourceRelease":"119-100","text":"the Secretary may proceed to issue the final record of decision or decision notice.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Public involvement","label":"3 Public involvement","identifier":"/us/usc/t16/s539m–5/a/3","parentIdentifier":"/us/usc/t16/s539m–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s539m–5/a/3/A","parentIdentifier":"/us/usc/t16/s539m–5/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s539m–5/a/3/A/i","parentIdentifier":"/us/usc/t16/s539m–5/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F3%2FA%2Fi","sourceRelease":"119-100","text":"the purpose and need for the proposed new use or modified use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s539m–5/a/3/A/ii","parentIdentifier":"/us/usc/t16/s539m–5/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F3%2FA%2Fii","sourceRelease":"119-100","text":"the role of the Pueblo in the decisionmaking process; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s539m–5/a/3/A/iii","parentIdentifier":"/us/usc/t16/s539m–5/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"the position of the Pueblo on the proposal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Court challenge","label":"B Court challenge","identifier":"/us/usc/t16/s539m–5/a/3/B","parentIdentifier":"/us/usc/t16/s539m–5/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fa%2F3%2FB","sourceRelease":"119-100","text":"Any person may bring a civil action in the United States District Court for the District of New Mexico to challenge a determination by the Secretary concerning whether a use constitutes a new use or a modified use.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Emergencies and emergency closure orders","label":"b Emergencies and emergency closure orders","identifier":"/us/usc/t16/s539m–5/b","parentIdentifier":"/us/usc/t16/s539m–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Authority","label":"1 Authority","identifier":"/us/usc/t16/s539m–5/b/1","parentIdentifier":"/us/usc/t16/s539m–5/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s539m–5/b/1/A","parentIdentifier":"/us/usc/t16/s539m–5/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fb%2F1%2FA","sourceRelease":"119-100","text":"provide for public safety; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s539m–5/b/1/B","parentIdentifier":"/us/usc/t16/s539m–5/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fb%2F1%2FB","sourceRelease":"119-100","text":"issue emergency closure orders in the Area subject to applicable law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Notice","label":"2 Notice","identifier":"/us/usc/t16/s539m–5/b/2","parentIdentifier":"/us/usc/t16/s539m–5/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary shall notify the Pueblo regarding emergencies, public safety issues, and emergency closure orders as soon as practicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"No consent","label":"3 No consent","identifier":"/us/usc/t16/s539m–5/b/3","parentIdentifier":"/us/usc/t16/s539m–5/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fb%2F3","sourceRelease":"119-100","text":"An action of the Secretary described in paragraph (1) shall not require the consent of the Pueblo.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Disputes involving Forest Service management and Pueblo traditional uses","label":"c Disputes involving Forest Service management and Pueblo traditional uses","identifier":"/us/usc/t16/s539m–5/c","parentIdentifier":"/us/usc/t16/s539m–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s539m–5/c/1","parentIdentifier":"/us/usc/t16/s539m–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fc%2F1","sourceRelease":"119-100","text":"In a case in which the management of the Area by the Secretary conflicts with a traditional or cultural use, if the conflict does not pertain to a new use subject to the process specified in subsection (a)(2), the process for dispute resolution specified in this subsection shall apply.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Dispute resolution process","label":"2 Dispute resolution process","identifier":"/us/usc/t16/s539m–5/c/2","parentIdentifier":"/us/usc/t16/s539m–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s539m–5/c/2/A","parentIdentifier":"/us/usc/t16/s539m–5/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s539m–5/c/2/A/i","parentIdentifier":"/us/usc/t16/s539m–5/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the party identifying the conflict shall notify the other party in writing addressed to the Governor of the Pueblo or the Regional Forester, as appropriate, specifying the nature of the dispute; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s539m–5/c/2/A/ii","parentIdentifier":"/us/usc/t16/s539m–5/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the Governor of the Pueblo or the Regional Forester shall attempt to resolve the dispute for a period of at least 30 days after notice has been provided before bringing a civil action in the United States District Court for the District of New Mexico.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Disputes requiring immediate resolution","label":"B Disputes requiring immediate resolution","identifier":"/us/usc/t16/s539m–5/c/2/B","parentIdentifier":"/us/usc/t16/s539m–5/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s539m–5/c/2/B/i","parentIdentifier":"/us/usc/t16/s539m–5/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the party identifying the conflict shall notify the other party and seek to resolve the dispute within 3 days of the date of notification; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s539m–5/c/2/B/ii","parentIdentifier":"/us/usc/t16/s539m–5/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s539m–5/c/2/B/ii/I","parentIdentifier":"/us/usc/t16/s539m–5/c/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fc%2F2%2FB%2Fii%2FI","sourceRelease":"119-100","text":"either party may bring a civil action for immediate relief in the United States District Court for the District of New Mexico; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s539m–5/c/2/B/ii/II","parentIdentifier":"/us/usc/t16/s539m–5/c/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%935%2Fc%2F2%2FB%2Fii%2FII","sourceRelease":"119-100","text":"the procedural requirements specified in subparagraph (A) shall not apply.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}]}
