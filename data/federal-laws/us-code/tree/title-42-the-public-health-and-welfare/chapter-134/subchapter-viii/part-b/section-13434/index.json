{"type":"section","nativeType":"section","number":"13434","heading":"Biofuels user facility","label":"13434 Biofuels user facility","identifier":"/us/usc/t42/s13434","parentIdentifier":"/us/usc/t42/ch134/schVIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13434","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t42/s13434/a","parentIdentifier":"/us/usc/t42/s13434","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13434%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish a biofuels user facility to expedite industry adoption of biofuels technologies, including production of alcohol fuels from biomass.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t42/s13434/b","parentIdentifier":"/us/usc/t42/s13434","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13434%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13434/b/1","parentIdentifier":"/us/usc/t42/s13434/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13434%2Fb%2F1","sourceRelease":"119-100","text":"the economic feasibility of production of oilseed crops for biofuels purposes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13434/b/2","parentIdentifier":"/us/usc/t42/s13434/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13434%2Fb%2F2","sourceRelease":"119-100","text":"the establishment of a mobile small-scale oilseed pressing and esterification unit and a stationary small-scale commercial oilseed pressing and esterification unit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
