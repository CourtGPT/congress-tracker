{"type":"section","nativeType":"section","number":"300cc–14","heading":"Evaluation of certain treatments","label":"300cc–14 Evaluation of certain treatments","identifier":"/us/usc/t42/s300cc–14","parentIdentifier":"/us/usc/t42/ch6A/schXXI/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsA prior section 300cc–14, act , § 2315, was successively renumbered by subsequent acts and transferred, see section 238 of this title.July 1, 1944l","Amendments1993—Subsec. (a)(1). substituted “AIDS Research Advisory Committee” for “Clinical Research Review Committee” in introductory provisions.Pub. L. 103–43"],"amendments":["Amendments1993—Subsec. (a)(1). substituted “AIDS Research Advisory Committee” for “Clinical Research Review Committee” in introductory provisions.Pub. L. 103–43"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment of program","label":"a Establishment of program","identifier":"/us/usc/t42/s300cc–14/a","parentIdentifier":"/us/usc/t42/s300cc–14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300cc–14/a/1","parentIdentifier":"/us/usc/t42/s300cc–14/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300cc–14/a/1/A","parentIdentifier":"/us/usc/t42/s300cc–14/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fa%2F1%2FA","sourceRelease":"119-100","text":"are not approved by the Commissioner of Food and Drugs for the purpose of treatments with respect to acquired immune deficiency syndrome; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300cc–14/a/1/B","parentIdentifier":"/us/usc/t42/s300cc–14/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fa%2F1%2FB","sourceRelease":"119-100","text":"are being utilized for such purpose by individuals infected with the etiologic agent for such syndrome.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300cc–14/a/2","parentIdentifier":"/us/usc/t42/s300cc–14/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fa%2F2","sourceRelease":"119-100","text":"The program established under paragraph (1) shall include evaluations of the effectiveness and the risks of the treatment involved, including the risks of foregoing treatments with respect to acquired immune deficiency syndrome that are approved by the Commissioner of Food and Drugs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Authority with respect to grants and contracts","label":"b Authority with respect to grants and contracts","identifier":"/us/usc/t42/s300cc–14/b","parentIdentifier":"/us/usc/t42/s300cc–14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300cc–14/b/1","parentIdentifier":"/us/usc/t42/s300cc–14/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fb%2F1","sourceRelease":"119-100","text":"For the purpose of conducting evaluations required in subsection (a), the Secretary may make grants to, and enter into cooperative agreements and contracts with, public and nonprofit private entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300cc–14/b/2","parentIdentifier":"/us/usc/t42/s300cc–14/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300cc–14/b/2/A","parentIdentifier":"/us/usc/t42/s300cc–14/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fb%2F2%2FA","sourceRelease":"119-100","text":"are established for the purpose of evaluating treatments with respect to acquired immune deficiency syndrome; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300cc–14/b/2/B","parentIdentifier":"/us/usc/t42/s300cc–14/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fb%2F2%2FB","sourceRelease":"119-100","text":"consist primarily of individuals infected with the etiologic agent for such syndrome.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Scientific and ethical guidelines","label":"c Scientific and ethical guidelines","identifier":"/us/usc/t42/s300cc–14/c","parentIdentifier":"/us/usc/t42/s300cc–14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300cc–14/c/1","parentIdentifier":"/us/usc/t42/s300cc–14/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary shall establish appropriate scientific and ethical guidelines for the conduct of evaluations carried out pursuant to this section. The Secretary may not provide financial assistance under subsection (b)(1) unless the applicant for such assistance agrees to comply with such guidelines.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300cc–14/c/2","parentIdentifier":"/us/usc/t42/s300cc–14/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300cc–14/c/2/A","parentIdentifier":"/us/usc/t42/s300cc–14/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fc%2F2%2FA","sourceRelease":"119-100","text":"physicians whose clinical practice includes a significant number of individuals with acquired immune deficiency syndrome;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300cc–14/c/2/B","parentIdentifier":"/us/usc/t42/s300cc–14/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fc%2F2%2FB","sourceRelease":"119-100","text":"individuals who are infected with the etiologic agent for such syndrome; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300cc–14/c/2/C","parentIdentifier":"/us/usc/t42/s300cc–14/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fc%2F2%2FC","sourceRelease":"119-100","text":"other individuals with appropriate expertise or experience.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s300cc–14/d","parentIdentifier":"/us/usc/t42/s300cc–14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300cc%E2%80%9314%2Fd","sourceRelease":"119-100","text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
