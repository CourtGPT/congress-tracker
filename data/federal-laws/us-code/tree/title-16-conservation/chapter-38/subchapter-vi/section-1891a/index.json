{"type":"section","nativeType":"section","number":"1891a","heading":"Community-based restoration program for fishery and coastal habitats","label":"1891a Community-based restoration program for fishery and coastal habitats","identifier":"/us/usc/t16/s1891a","parentIdentifier":"/us/usc/t16/ch38/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1891a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Magnuson-Stevens Fishery Conservation and Management Reauthorization Act of 2006, and not as part of the Magnuson-Stevens Fishery Conservation and Management Act which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s1891a/a","parentIdentifier":"/us/usc/t16/s1891a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1891a%2Fa","sourceRelease":"119-100","text":"The Secretary of Commerce shall establish a community-based fishery and coastal habitat restoration program to implement and support the restoration of fishery and coastal habitats.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Authorized activities","label":"b Authorized activities","identifier":"/us/usc/t16/s1891a/b","parentIdentifier":"/us/usc/t16/s1891a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1891a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s1891a/b/1","parentIdentifier":"/us/usc/t16/s1891a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1891a%2Fb%2F1","sourceRelease":"119-100","text":"provide funding and technical expertise to fishery and coastal communities to assist them in restoring fishery and coastal habitat;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s1891a/b/2","parentIdentifier":"/us/usc/t16/s1891a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1891a%2Fb%2F2","sourceRelease":"119-100","text":"advance the science and monitoring of coastal habitat restoration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s1891a/b/3","parentIdentifier":"/us/usc/t16/s1891a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1891a%2Fb%2F3","sourceRelease":"119-100","text":"transfer restoration technologies to the private sector, the public, and other governmental agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s1891a/b/4","parentIdentifier":"/us/usc/t16/s1891a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1891a%2Fb%2F4","sourceRelease":"119-100","text":"develop public-private partnerships to accomplish sound coastal restoration projects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s1891a/b/5","parentIdentifier":"/us/usc/t16/s1891a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1891a%2Fb%2F5","sourceRelease":"119-100","text":"promote significant community support and volunteer participation in fishery and coastal habitat restoration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s1891a/b/6","parentIdentifier":"/us/usc/t16/s1891a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1891a%2Fb%2F6","sourceRelease":"119-100","text":"promote stewardship of fishery and coastal habitats; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t16/s1891a/b/7","parentIdentifier":"/us/usc/t16/s1891a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1891a%2Fb%2F7","sourceRelease":"119-100","text":"leverage resources through national, regional, and local public-private partnerships.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
