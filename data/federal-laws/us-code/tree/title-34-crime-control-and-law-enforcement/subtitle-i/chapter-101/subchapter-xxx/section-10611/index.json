{"type":"section","nativeType":"section","number":"10611","heading":"Grant authority","label":"10611 Grant authority","identifier":"/us/usc/t34/s10611","parentIdentifier":"/us/usc/t34/stI/ch101/schXXX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to , The Public Health and Welfare, prior to editorial reclassification and renumbering as this section.section 3797u of Title 42","Amendments2016—Subsec. (a)(1). inserted “, including co-occurring substance abuse and mental health problems,” after “abuse problems”.Pub. L. 114–2552006—Subsec. (a)(1). substituted “offenders, and other individuals under the jurisdiction of the court, with substance abuse problems” for “offenders with substance abuse problems”.Pub. L. 109–162Subsec. (c). added subsec. (c).Pub. L. 109–177"],"amendments":["Amendments2016—Subsec. (a)(1). inserted “, including co-occurring substance abuse and mental health problems,” after “abuse problems”.Pub. L. 114–2552006—Subsec. (a)(1). substituted “offenders, and other individuals under the jurisdiction of the court, with substance abuse problems” for “offenders with substance abuse problems”.Pub. L. 109–162Subsec. (c). added subsec. (c).Pub. L. 109–177"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t34/s10611/a","parentIdentifier":"/us/usc/t34/s10611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s10611/a/1","parentIdentifier":"/us/usc/t34/s10611/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fa%2F1","sourceRelease":"119-100","text":"continuing judicial supervision over offenders, and other individuals under the jurisdiction of the court, with substance abuse problems, including co-occurring substance abuse and mental health problems, who are not violent offenders;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s10611/a/2","parentIdentifier":"/us/usc/t34/s10611/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fa%2F2","sourceRelease":"119-100","text":"coordination with the appropriate State or local prosecutor; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s10611/a/3","parentIdentifier":"/us/usc/t34/s10611/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s10611/a/3/A","parentIdentifier":"/us/usc/t34/s10611/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fa%2F3%2FA","sourceRelease":"119-100","text":"mandatory periodic testing for the use of controlled substances or other addictive substances during any period of supervised release or probation for each participant;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s10611/a/3/B","parentIdentifier":"/us/usc/t34/s10611/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fa%2F3%2FB","sourceRelease":"119-100","text":"substance abuse treatment for each participant;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s10611/a/3/C","parentIdentifier":"/us/usc/t34/s10611/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fa%2F3%2FC","sourceRelease":"119-100","text":"diversion, probation, or other supervised release involving the possibility of prosecution, confinement, or incarceration based on noncompliance with program requirements or failure to show satisfactory progress;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s10611/a/3/D","parentIdentifier":"/us/usc/t34/s10611/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fa%2F3%2FD","sourceRelease":"119-100","text":"offender management, and aftercare services such as relapse prevention, health care, education, vocational training, job placement, housing placement, and child care or other family support services for each participant who requires such services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t34/s10611/a/3/E","parentIdentifier":"/us/usc/t34/s10611/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fa%2F3%2FE","sourceRelease":"119-100","text":"payment, in whole or part, by the offender of treatment costs, to the extent practicable, such as costs for urinalysis or counseling; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t34/s10611/a/3/F","parentIdentifier":"/us/usc/t34/s10611/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fa%2F3%2FF","sourceRelease":"119-100","text":"payment, in whole or part, by the offender of restitution, to the extent practicable, to either a victim of the offender’s offense or to a restitution or similar victim support fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitation","label":"b Limitation","identifier":"/us/usc/t34/s10611/b","parentIdentifier":"/us/usc/t34/s10611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fb","sourceRelease":"119-100","text":"Economic sanctions imposed on an offender pursuant to this section shall not be at a level that would interfere with the offender’s rehabilitation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Mandatory drug testing and mandatory sanctions","label":"c Mandatory drug testing and mandatory sanctions","identifier":"/us/usc/t34/s10611/c","parentIdentifier":"/us/usc/t34/s10611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Mandatory testing","label":"1 Mandatory testing","identifier":"/us/usc/t34/s10611/c/1","parentIdentifier":"/us/usc/t34/s10611/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s10611/c/1/A","parentIdentifier":"/us/usc/t34/s10611/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s10611/c/1/A/i","parentIdentifier":"/us/usc/t34/s10611/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"each participant is tested for every controlled substance that the participant has been known to abuse, and for any other controlled substance the Attorney General or the court may require; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s10611/c/1/A/ii","parentIdentifier":"/us/usc/t34/s10611/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the testing is accurate and practicable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s10611/c/1/B","parentIdentifier":"/us/usc/t34/s10611/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fc%2F1%2FB","sourceRelease":"119-100","text":"may require approval of the drug testing regime to ensure that adequate testing occurs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Mandatory sanctions","label":"2 Mandatory sanctions","identifier":"/us/usc/t34/s10611/c/2","parentIdentifier":"/us/usc/t34/s10611/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s10611/c/2/A","parentIdentifier":"/us/usc/t34/s10611/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fc%2F2%2FA","sourceRelease":"119-100","text":"Incarceration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s10611/c/2/B","parentIdentifier":"/us/usc/t34/s10611/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fc%2F2%2FB","sourceRelease":"119-100","text":"Detoxification treatment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s10611/c/2/C","parentIdentifier":"/us/usc/t34/s10611/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fc%2F2%2FC","sourceRelease":"119-100","text":"Residential treatment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s10611/c/2/D","parentIdentifier":"/us/usc/t34/s10611/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fc%2F2%2FD","sourceRelease":"119-100","text":"Increased time in program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t34/s10611/c/2/E","parentIdentifier":"/us/usc/t34/s10611/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10611%2Fc%2F2%2FE","sourceRelease":"119-100","text":"Termination from the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t34/s10611/c/2/F","parentIdentifier":"/us/usc/t34/s10611/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs106