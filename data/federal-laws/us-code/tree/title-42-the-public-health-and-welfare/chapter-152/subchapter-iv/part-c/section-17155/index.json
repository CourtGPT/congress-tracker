{"type":"section","nativeType":"section","number":"17155","heading":"Requirements for eligible entities","label":"17155 Requirements for eligible entities","identifier":"/us/usc/t42/s17155","parentIdentifier":"/us/usc/t42/ch152/schIV/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextReorganization Plan Numbered 14 of 1950, referred to in subsec. (a)(2)(A), is set out in the Appendix to Title 5, Government Organization and Employees. relates to Presidential authority regarding reorganization plans.Section 903 of Title 5","Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Construction requirement","label":"a Construction requirement","identifier":"/us/usc/t42/s17155/a","parentIdentifier":"/us/usc/t42/s17155","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17155/a/1","parentIdentifier":"/us/usc/t42/s17155/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fa%2F1","sourceRelease":"119-100","text":"To be eligible to receive a grant under the program, each eligible applicant shall submit to the Secretary a written assurance that all laborers and mechanics employed by any contractor or subcontractor of the eligible entity during any construction, alteration, or repair activity funded, in whole or in part, by the grant shall be paid wages at rates not less than the prevailing wages for similar construction activities in the locality, as determined by the Secretary of Labor, in accordance with sections 3141 through 3144, 3146, and 3147 of title 40.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Secretary of Labor","label":"2 Secretary of Labor","identifier":"/us/usc/t42/s17155/a/2","parentIdentifier":"/us/usc/t42/s17155/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17155/a/2/A","parentIdentifier":"/us/usc/t42/s17155/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fa%2F2%2FA","sourceRelease":"119-100","text":"Reorganization Plan Numbered 14 of 1950 ( note); and5 U.S.C. 9031See References in Text note below.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17155/a/2/B","parentIdentifier":"/us/usc/t42/s17155/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fa%2F2%2FB","sourceRelease":"119-100","text":".section 3145 of title 40","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Eligible units of local government and Indian tribes","label":"b Eligible units of local government and Indian tribes","identifier":"/us/usc/t42/s17155/b","parentIdentifier":"/us/usc/t42/s17155","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Proposed strategy","label":"1 Proposed strategy","identifier":"/us/usc/t42/s17155/b/1","parentIdentifier":"/us/usc/t42/s17155/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s17155/b/1/A","parentIdentifier":"/us/usc/t42/s17155/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F1%2FA","sourceRelease":"119-100","text":"Not later than 1 year after the date on which an eligible unit of local government or Indian tribe receives a grant under this part, the eligible unit of local government or Indian tribe shall submit to the Secretary a proposed energy efficiency and conservation strategy in accordance with this paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Inclusions","label":"B Inclusions","identifier":"/us/usc/t42/s17155/b/1/B","parentIdentifier":"/us/usc/t42/s17155/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17155/b/1/B/i","parentIdentifier":"/us/usc/t42/s17155/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"a description of the goals of the eligible unit of local government or Indian tribe, in accordance with the purposes of this part, for increased energy efficiency and conservation in the jurisdiction of the eligible unit of local government or Indian tribe; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17155/b/1/B/ii","parentIdentifier":"/us/usc/t42/s17155/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"a plan for the use of the grant to assist the eligible unit of local government or Indian tribe in achieving those goals, in accordance with .section 17154 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Requirements for eligible units of local government","label":"C Requirements for eligible units of local government","identifier":"/us/usc/t42/s17155/b/1/C","parentIdentifier":"/us/usc/t42/s17155/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17155/b/1/C/i","parentIdentifier":"/us/usc/t42/s17155/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F1%2FC%2Fi","sourceRelease":"119-100","text":"take into account any plans for the use of funds by adjacent eligible units of local governments that receive grants under the program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17155/b/1/C/ii","parentIdentifier":"/us/usc/t42/s17155/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F1%2FC%2Fii","sourceRelease":"119-100","text":"coordinate and share information with the State in which the eligible unit of local government is located regarding activities carried out using the grant to maximize the energy efficiency and conservation benefits under this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Approval by Secretary","label":"2 Approval by Secretary","identifier":"/us/usc/t42/s17155/b/2","parentIdentifier":"/us/usc/t42/s17155/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s17155/b/2/A","parentIdentifier":"/us/usc/t42/s17155/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The Secretary shall approve or disapprove a proposed strategy under paragraph (1) by not later than 120 days after the date of submission of the proposed strategy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Disapproval","label":"B Disapproval","identifier":"/us/usc/t42/s17155/b/2/B","parentIdentifier":"/us/usc/t42/s17155/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17155/b/2/B/i","parentIdentifier":"/us/usc/t42/s17155/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the Secretary shall provide to the eligible unit of local government or Indian tribe the reasons for the disapproval; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17155/b/2/B/ii","parentIdentifier":"/us/usc/t42/s17155/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the eligible unit of local government or Indian tribe may revise and resubmit the proposed strategy as many times as necessary until the Secretary approves a proposed strategy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Requirement","label":"C Requirement","identifier":"/us/usc/t42/s17155/b/2/C","parentIdentifier":"/us/usc/t42/s17155/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F2%2FC","sourceRelease":"119-100","text":"The Secretary shall not provide to an eligible unit of local government or Indian tribe any grant under the program until a proposed strategy of the eligible unit of local government or Indian tribe is approved by the Secretary under this paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Limitations on use of funds","label":"3 Limitations on use of funds","identifier":"/us/usc/t42/s17155/b/3","parentIdentifier":"/us/usc/t42/s17155/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17155/b/3/A","parentIdentifier":"/us/usc/t42/s17155/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17155/b/3/A/i","parentIdentifier":"/us/usc/t42/s17155/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F3%2FA%2Fi","sourceRelease":"119-100","text":"10 percent; and2So in original. Probably should be “or”.2","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17155/b/3/A/ii","parentIdentifier":"/us/usc/t42/s17155/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F3%2FA%2Fii","sourceRelease":"119-100","text":"$75,000;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17155/b/3/B","parentIdentifier":"/us/usc/t42/s17155/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17155/b/3/B/i","parentIdentifier":"/us/usc/t42/s17155/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"20 percent; and2","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17155/b/3/B/ii","parentIdentifier":"/us/usc/t42/s17155/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"$250,000; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17155/b/3/C","parentIdentifier":"/us/usc/t42/s17155/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17155/b/3/C/i","parentIdentifier":"/us/usc/t42/s17155/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F3%2FC%2Fi","sourceRelease":"119-100","text":"20 percent; and2","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17155/b/3/C/ii","parentIdentifier":"/us/usc/t42/s17155/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F3%2FC%2Fii","sourceRelease":"119-100","text":"$250,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Annual report","label":"4 Annual report","identifier":"/us/usc/t42/s17155/b/4","parentIdentifier":"/us/usc/t42/s17155/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17155/b/4/A","parentIdentifier":"/us/usc/t42/s17155/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F4%2FA","sourceRelease":"119-100","text":"the status of development and implementation of the energy efficiency and conservation strategy of the eligible unit of local government or Indian tribe; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17155/b/4/B","parentIdentifier":"/us/usc/t42/s17155/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fb%2F4%2FB","sourceRelease":"119-100","text":"as practicable, an assessment of energy efficiency gains within the jurisdiction of the eligible unit of local government or Indian tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"States","label":"c States","identifier":"/us/usc/t42/s17155/c","parentIdentifier":"/us/usc/t42/s17155","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Distribution of funds","label":"1 Distribution of funds","identifier":"/us/usc/t42/s17155/c/1","parentIdentifier":"/us/usc/t42/s17155/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s17155/c/1/A","parentIdentifier":"/us/usc/t42/s17155/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F1%2FA","sourceRelease":"119-100","text":"A State that receives a grant under the program shall use not less than 60 percent of the amount received to provide subgrants to units of local government in the State that are not eligible units of local government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Deadline","label":"B Deadline","identifier":"/us/usc/t42/s17155/c/1/B","parentIdentifier":"/us/usc/t42/s17155/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F1%2FB","sourceRelease":"119-100","text":"The State shall provide the subgrants required under subparagraph (A) by not later than 180 days after the date on which the Secretary approves a proposed energy efficiency and conservation strategy of the State under paragraph (3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Revision of conservation plan; proposed strategy","label":"2 Revision of conservation plan; proposed strategy","identifier":"/us/usc/t42/s17155/c/2","parentIdentifier":"/us/usc/t42/s17155/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17155/c/2/A","parentIdentifier":"/us/usc/t42/s17155/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F2%2FA","sourceRelease":"119-100","text":"modify the State energy conservation plan of the State under to establish additional goals for increased energy efficiency and conservation in the State; andsection 6322 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17155/c/2/B","parentIdentifier":"/us/usc/t42/s17155/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17155/c/2/B/i","parentIdentifier":"/us/usc/t42/s17155/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"establishes a process for providing subgrants as required under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17155/c/2/B/ii","parentIdentifier":"/us/usc/t42/s17155/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"includes a plan of the State for the use of funds received under the program to assist the State in achieving the goals established under subparagraph (A), in accordance with sections 17152(b) and 17154 of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Approval by Secretary","label":"3 Approval by Secretary","identifier":"/us/usc/t42/s17155/c/3","parentIdentifier":"/us/usc/t42/s17155/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s17155/c/3/A","parentIdentifier":"/us/usc/t42/s17155/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F3%2FA","sourceRelease":"119-100","text":"The Secretary shall approve or disapprove a proposed strategy under paragraph (2)(B) by not later than 120 days after the date of submission of the proposed strategy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Disapproval","label":"B Disapproval","identifier":"/us/usc/t42/s17155/c/3/B","parentIdentifier":"/us/usc/t42/s17155/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17155/c/3/B/i","parentIdentifier":"/us/usc/t42/s17155/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":"the Secretary shall provide to the State the reasons for the disapproval; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17155/c/3/B/ii","parentIdentifier":"/us/usc/t42/s17155/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":"the State may revise and resubmit the proposed strategy as many times as necessary until the Secretary approves a proposed strategy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Requirement","label":"C Requirement","identifier":"/us/usc/t42/s17155/c/3/C","parentIdentifier":"/us/usc/t42/s17155/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F3%2FC","sourceRelease":"119-100","text":"The Secretary shall not provide to a State any grant under the program until a proposed strategy of the State is approved by the Secretary under this paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Limitations on use of funds","label":"4 Limitations on use of funds","identifier":"/us/usc/t42/s17155/c/4","parentIdentifier":"/us/usc/t42/s17155/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F4","sourceRelease":"119-100","text":"A State may use not more than 10 percent of amounts provided under the program for administrative expenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Annual reports","label":"5 Annual reports","identifier":"/us/usc/t42/s17155/c/5","parentIdentifier":"/us/usc/t42/s17155/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17155/c/5/A","parentIdentifier":"/us/usc/t42/s17155/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F5%2FA","sourceRelease":"119-100","text":"the status of development and implementation of the energy efficiency and conservation strategy of the State during the preceding calendar year;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17155/c/5/B","parentIdentifier":"/us/usc/t42/s17155/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F5%2FB","sourceRelease":"119-100","text":"the status of the subgrant program of the State under paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17155/c/5/C","parentIdentifier":"/us/usc/t42/s17155/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F5%2FC","sourceRelease":"119-100","text":"the energy efficiency gains achieved through the energy efficiency and conservation strategy of the State during the preceding calendar year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17155/c/5/D","parentIdentifier":"/us/usc/t42/s17155/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17155%2Fc%2F5%2FD","sourceRelease":"119-100","text":"specific energy efficiency and conservation goals of the State for subsequent calendar years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
