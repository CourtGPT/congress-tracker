{"type":"section","nativeType":"section","number":"5707","heading":"Remedies for State program termination or failures","label":"5707 Remedies for State program termination or failures","identifier":"/us/usc/t12/s5707","parentIdentifier":"/us/usc/t12/ch54","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5707","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Remedies","label":"a Remedies","identifier":"/us/usc/t12/s5707/a","parentIdentifier":"/us/usc/t12/s5707","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5707%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t12/s5707/a/1","parentIdentifier":"/us/usc/t12/s5707/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5707%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s5707/a/1/A","parentIdentifier":"/us/usc/t12/s5707/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5707%2Fa%2F1%2FA","sourceRelease":"119-100","text":"reduce the amount of Federal funds allocated to the State under the Program; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s5707/a/1/B","parentIdentifier":"/us/usc/t12/s5707/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5707%2Fa%2F1%2FB","sourceRelease":"119-100","text":"terminate any further transfers of allocated amounts that have not yet been transferred to the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Causal events","label":"2 Causal events","identifier":"/us/usc/t12/s5707/a/2","parentIdentifier":"/us/usc/t12/s5707/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5707%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s5707/a/2/A","parentIdentifier":"/us/usc/t12/s5707/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5707%2Fa%2F2%2FA","sourceRelease":"119-100","text":"termination by a participating State of its participation in the Program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s5707/a/2/B","parentIdentifier":"/us/usc/t12/s5707/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5707%2Fa%2F2%2FB","sourceRelease":"119-100","text":"failure on the part of a participating State to submit complete reports under on a timely basis; orsection 5706 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s5707/a/2/C","parentIdentifier":"/us/usc/t12/s5707/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5707%2Fa%2F2%2FC","sourceRelease":"119-100","text":"noncompliance by the State with the terms of the allocation agreement between the Secretary and the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Deallocated amounts to be reallocated","label":"b Deallocated amounts to be reallocated","identifier":"/us/usc/t12/s5707/b","parentIdentifier":"/us/usc/t12/s5707","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5707%2Fb","sourceRelease":"119-100","text":"If, after 13 months, any portion of the amount of Federal funds allocated to a participating State is deemed by the Secretary to be no longer allocated to the State after actions taken by the Secretary under subsection (a)(1), the Secretary shall reallocate that portion among the participating States, excluding the State whose allocated funds were deemed to be no longer allocated, as provided in .section 5702(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
