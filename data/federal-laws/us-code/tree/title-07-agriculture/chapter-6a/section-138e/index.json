{"type":"section","nativeType":"section","number":"138e","heading":"Reporting","label":"138e Reporting","identifier":"/us/usc/t7/s138e","parentIdentifier":"/us/usc/t7/ch6A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138e","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t7/s138e/a","parentIdentifier":"/us/usc/t7/s138e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138e%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s138e/a/1","parentIdentifier":"/us/usc/t7/s138e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138e%2Fa%2F1","sourceRelease":"119-100","text":"for which no chemical residue tolerance or exemption has been established;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s138e/a/2","parentIdentifier":"/us/usc/t7/s138e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138e%2Fa%2F2","sourceRelease":"119-100","text":"that is in excess of residue tolerances; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s138e/a/3","parentIdentifier":"/us/usc/t7/s138e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138e%2Fa%2F3","sourceRelease":"119-100","text":"for which the chemical residue tolerance has been revoked or the chemical residue is otherwise not permitted by the Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Timing of report","label":"b Timing of report","identifier":"/us/usc/t7/s138e/b","parentIdentifier":"/us/usc/t7/s138e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138e%2Fb","sourceRelease":"119-100","text":"A laboratory shall submit the report required under subsection (a) to the Secretary, the Secretary of Health and Human Services, and the owner of such food as soon as practicable after the completion of the analysis of such food.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Guidelines","label":"c Guidelines","identifier":"/us/usc/t7/s138e/c","parentIdentifier":"/us/usc/t7/s138e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138e%2Fc","sourceRelease":"119-100","text":"The Secretary shall adopt standardized reporting guidelines to be applied to laboratories under this section and shall provide such guidelines to laboratories accredited under this chapter, as well as other sources of information regarding applicable pesticide chemical tolerances.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
