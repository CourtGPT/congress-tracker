{"type":"section","nativeType":"section","number":"460ttt–1","heading":"Map and description","label":"460ttt–1 Map and description","identifier":"/us/usc/t16/s460ttt–1","parentIdentifier":"/us/usc/t16/ch1/schCXXXI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ttt%E2%80%931","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Change of NameCommittee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, .Jan. 5, 2007"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s460ttt–1/a","parentIdentifier":"/us/usc/t16/s460ttt–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ttt%E2%80%931%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460ttt–1/a/1","parentIdentifier":"/us/usc/t16/s460ttt–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ttt%E2%80%931%2Fa%2F1","sourceRelease":"119-100","text":"the Committee on Resources of the House of Representatives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460ttt–1/a/2","parentIdentifier":"/us/usc/t16/s460ttt–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ttt%E2%80%931%2Fa%2F2","sourceRelease":"119-100","text":"the Committee on Agriculture of the House of Representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s460ttt–1/a/3","parentIdentifier":"/us/usc/t16/s460ttt–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ttt%E2%80%931%2Fa%2F3","sourceRelease":"119-100","text":"the Committee on Agriculture, Nutrition, and Forestry of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Force of law","label":"b Force of law","identifier":"/us/usc/t16/s460ttt–1/b","parentIdentifier":"/us/usc/t16/s460ttt–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ttt%E2%80%931%2Fb","sourceRelease":"119-100","text":"A map and legal description filed under subsection (a) shall have the same force and effect as if included in this subchapter, except that the Secretary may correct clerical and typographical errors in the map and legal description.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Public availability","label":"c Public availability","identifier":"/us/usc/t16/s460ttt–1/c","parentIdentifier":"/us/usc/t16/s460ttt–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ttt%E2%80%931%2Fc","sourceRelease":"119-100","text":"Each map and legal description filed under subsection (a) shall be filed and made available for public inspection in the Office of the Chief of the Forest Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
