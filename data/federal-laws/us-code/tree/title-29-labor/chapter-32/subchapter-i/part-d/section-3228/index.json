{"type":"section","nativeType":"section","number":"3228","heading":"Worker ownership, readiness, and knowledge","label":"3228 Worker ownership, readiness, and knowledge","identifier":"/us/usc/t29/s3228","parentIdentifier":"/us/usc/t29/ch32/schI/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the SECURE 2.0 Act of 2022, and also as part of the Consolidated Appropriations Act, 2023, and not as part of title I of the Workforce Innovation and Opportunity Act which comprises this subchapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t29/s3228/a","parentIdentifier":"/us/usc/t29/s3228","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Existing program","label":"1 Existing program","identifier":"/us/usc/t29/s3228/a/1","parentIdentifier":"/us/usc/t29/s3228/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fa%2F1","sourceRelease":"119-100","text":"The term “existing program” means a program, designed to promote employee ownership, that exists on the date on which the Secretary is carrying out a responsibility authorized under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Initiative","label":"2 Initiative","identifier":"/us/usc/t29/s3228/a/2","parentIdentifier":"/us/usc/t29/s3228/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fa%2F2","sourceRelease":"119-100","text":"The term “Initiative” means the Employee Ownership Initiative established under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"New program","label":"3 New program","identifier":"/us/usc/t29/s3228/a/3","parentIdentifier":"/us/usc/t29/s3228/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fa%2F3","sourceRelease":"119-100","text":"The term “new program” means a program, designed to promote employee ownership, that does not exist on the date on which the Secretary is carrying out a responsibility authorized under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Secretary","label":"4 Secretary","identifier":"/us/usc/t29/s3228/a/4","parentIdentifier":"/us/usc/t29/s3228/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fa%2F4","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Labor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"State","label":"5 State","identifier":"/us/usc/t29/s3228/a/5","parentIdentifier":"/us/usc/t29/s3228/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fa%2F5","sourceRelease":"119-100","text":"The term “State” has the meaning given the term under .section 3102 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Employee Ownership Initiative","label":"b Employee Ownership Initiative","identifier":"/us/usc/t29/s3228/b","parentIdentifier":"/us/usc/t29/s3228","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t29/s3228/b/1","parentIdentifier":"/us/usc/t29/s3228/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall establish within the Department of Labor an Employee Ownership Initiative to promote employee ownership.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Functions","label":"2 Functions","identifier":"/us/usc/t29/s3228/b/2","parentIdentifier":"/us/usc/t29/s3228/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s3228/b/2/A","parentIdentifier":"/us/usc/t29/s3228/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fb%2F2%2FA","sourceRelease":"119-100","text":"support within the States existing programs designed to promote employee ownership; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s3228/b/2/B","parentIdentifier":"/us/usc/t29/s3228/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fb%2F2%2FB","sourceRelease":"119-100","text":"facilitate within the States the formation of new programs designed to promote employee ownership.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Duties","label":"3 Duties","identifier":"/us/usc/t29/s3228/b/3","parentIdentifier":"/us/usc/t29/s3228/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s3228/b/3/A","parentIdentifier":"/us/usc/t29/s3228/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fb%2F3%2FA","sourceRelease":"119-100","text":"making Federal grants authorized under subsection (d); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s3228/b/3/B","parentIdentifier":"/us/usc/t29/s3228/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t29/s3228/b/3/B/i","parentIdentifier":"/us/usc/t29/s3228/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"acting as a clearinghouse on techniques employed by new programs and existing programs within the States, and disseminating information relating to those techniques to the programs; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t29/s3228/b/3/B/ii","parentIdentifier":"/us/usc/t29/s3228/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"funding projects for information gathering on those techniques, and dissemination of that information to the programs, by groups outside the Department of Labor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Consultation with Treasury","label":"4 Consultation with Treasury","identifier":"/us/usc/t29/s3228/b/4","parentIdentifier":"/us/usc/t29/s3228/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fb%2F4","sourceRelease":"119-100","text":"The Secretary shall consult with the Secretary of the Treasury, or the Secretary’s delegate, in the case of any employee ownership arrangements or structures the administration and enforcement of which are within the jurisdiction of the Department of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Programs regarding employee ownership","label":"c Programs regarding employee ownership","identifier":"/us/usc/t29/s3228/c","parentIdentifier":"/us/usc/t29/s3228","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment of program","label":"1 Establishment of program","identifier":"/us/usc/t29/s3228/c/1","parentIdentifier":"/us/usc/t29/s3228/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F1","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary shall establish a program to encourage new programs and existing programs within the States to foster employee ownership throughout the United States.December 29, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Purpose of program","label":"2 Purpose of program","identifier":"/us/usc/t29/s3228/c/2","parentIdentifier":"/us/usc/t29/s3228/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s3228/c/2/A","parentIdentifier":"/us/usc/t29/s3228/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F2%2FA","sourceRelease":"119-100","text":"providing education and outreach to inform employees and employers about the possibilities and benefits of employee ownership and business ownership succession planning, including providing information about financial education, employee teams, open-book management, and other tools that enable employees to share ideas and information about how their businesses can succeed;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s3228/c/2/B","parentIdentifier":"/us/usc/t29/s3228/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F2%2FB","sourceRelease":"119-100","text":"providing technical assistance to assist employee efforts to become business owners, to enable employers and employees to explore and assess the feasibility of transferring full or partial ownership to employees, and to encourage employees and employers to start new employee-owned businesses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t29/s3228/c/2/C","parentIdentifier":"/us/usc/t29/s3228/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F2%2FC","sourceRelease":"119-100","text":"training employees and employers with respect to methods of employee participation in open-book management, work teams, committees, and other approaches for seeking greater employee input; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t29/s3228/c/2/D","parentIdentifier":"/us/usc/t29/s3228/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F2%2FD","sourceRelease":"119-100","text":"training other entities to apply for funding under this subsection, to establish new programs, and to carry out program activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Program details","label":"3 Program details","identifier":"/us/usc/t29/s3228/c/3","parentIdentifier":"/us/usc/t29/s3228/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s3228/c/3/A","parentIdentifier":"/us/usc/t29/s3228/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t29/s3228/c/3/A/i","parentIdentifier":"/us/usc/t29/s3228/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FA%2Fi","sourceRelease":"119-100","text":"target key groups, such as retiring business owners, senior managers, labor organizations, trade associations, community organizations, and economic development organizations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t29/s3228/c/3/A/ii","parentIdentifier":"/us/usc/t29/s3228/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FA%2Fii","sourceRelease":"119-100","text":"encourage cooperation in the organization of workshops and conferences; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t29/s3228/c/3/A/iii","parentIdentifier":"/us/usc/t29/s3228/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"prepare and distribute materials concerning employee ownership, and business ownership succession planning;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s3228/c/3/B","parentIdentifier":"/us/usc/t29/s3228/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t29/s3228/c/3/B/i","parentIdentifier":"/us/usc/t29/s3228/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":"provide preliminary technical assistance to employee groups, managers, and retiring owners exploring the possibility of employee ownership;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t29/s3228/c/3/B/ii","parentIdentifier":"/us/usc/t29/s3228/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":"provide for the performance of preliminary feasibility assessments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t29/s3228/c/3/B/iii","parentIdentifier":"/us/usc/t29/s3228/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"assist in the funding of objective third-party feasibility studies and preliminary business valuations, and in selecting and monitoring professionals qualified to conduct such studies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t29/s3228/c/3/B/iv","parentIdentifier":"/us/usc/t29/s3228/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FB%2Fiv","sourceRelease":"119-100","text":"provide a data bank to help employees find legal, financial, and technical advice in connection with business ownership;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t29/s3228/c/3/C","parentIdentifier":"/us/usc/t29/s3228/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t29/s3228/c/3/C/i","parentIdentifier":"/us/usc/t29/s3228/c/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FC%2Fi","sourceRelease":"119-100","text":"provide for courses on employee participation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t29/s3228/c/3/C/ii","parentIdentifier":"/us/usc/t29/s3228/c/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FC%2Fii","sourceRelease":"119-100","text":"provide for the development and fostering of networks of employee-owned companies to spread the use of successful participation techniques; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t29/s3228/c/3/D","parentIdentifier":"/us/usc/t29/s3228/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t29/s3228/c/3/D/i","parentIdentifier":"/us/usc/t29/s3228/c/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FD%2Fi","sourceRelease":"119-100","text":"provide for visits to existing programs by staff from new programs receiving funding under this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t29/s3228/c/3/D/ii","parentIdentifier":"/us/usc/t29/s3228/c/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F3%2FD%2Fii","sourceRelease":"119-100","text":"provide materials to be used for such training.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Guidance","label":"4 Guidance","identifier":"/us/usc/t29/s3228/c/4","parentIdentifier":"/us/usc/t29/s3228/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s3228/c/4/A","parentIdentifier":"/us/usc/t29/s3228/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t29/s3228/c/4/A/i","parentIdentifier":"/us/usc/t29/s3228/c/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F4%2FA%2Fi","sourceRelease":"119-100","text":"proactive in encouraging actions and activities that promote employee ownership of businesses; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t29/s3228/c/4/A/ii","parentIdentifier":"/us/usc/t29/s3228/c/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F4%2FA%2Fii","sourceRelease":"119-100","text":"comprehensive in emphasizing both employee ownership of businesses so as to increase productivity and broaden capital ownership; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s3228/c/4/B","parentIdentifier":"/us/usc/t29/s3228/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fc%2F4%2FB","sourceRelease":"119-100","text":"acceptable standards and procedures to establish good faith fair market value for shares of a business to be acquired by an employee stock ownership plan (as defined in ).section 1107(d)(6) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Grants","label":"d Grants","identifier":"/us/usc/t29/s3228/d","parentIdentifier":"/us/usc/t29/s3228","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t29/s3228/d/1","parentIdentifier":"/us/usc/t29/s3228/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s3228/d/1/A","parentIdentifier":"/us/usc/t29/s3228/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F1%2FA","sourceRelease":"119-100","text":"Education and outreach as provided in subsection (c)(2)(A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s3228/d/1/B","parentIdentifier":"/us/usc/t29/s3228/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F1%2FB","sourceRelease":"119-100","text":"Technical assistance as provided in subsection (c)(2)(B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t29/s3228/d/1/C","parentIdentifier":"/us/usc/t29/s3228/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F1%2FC","sourceRelease":"119-100","text":"Training activities for employees and employers as provided in subsection (c)(2)(C).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t29/s3228/d/1/D","parentIdentifier":"/us/usc/t29/s3228/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F1%2FD","sourceRelease":"119-100","text":"Activities facilitating cooperation among employee-owned firms.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t29/s3228/d/1/E","parentIdentifier":"/us/usc/t29/s3228/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F1%2FE","sourceRelease":"119-100","text":"Training as provided in subsection (c)(2)(D) for new programs provided by participants in existing programs dedicated to the objectives of this section, except that, for each fiscal year, the amount of the grants made for such training shall not exceed 10 percent of the total amount of the grants made under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Amounts and conditions","label":"2 Amounts and conditions","identifier":"/us/usc/t29/s3228/d/2","parentIdentifier":"/us/usc/t29/s3228/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F2","sourceRelease":"119-100","text":"The Secretary shall determine the amount and any conditions for a grant made under this subsection. The amount of the grant shall be subject to paragraph (6), and shall reflect the capacity of the applicant for the grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Applications","label":"3 Applications","identifier":"/us/usc/t29/s3228/d/3","parentIdentifier":"/us/usc/t29/s3228/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F3","sourceRelease":"119-100","text":"Each entity desiring a grant under this subsection shall submit an application to the Secretary at such time, in such manner, and accompanied by such information as the Secretary may reasonably require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"State applications","label":"4 State applications","identifier":"/us/usc/t29/s3228/d/4","parentIdentifier":"/us/usc/t29/s3228/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F4","sourceRelease":"119-100","text":"Each State may sponsor and submit an application under paragraph (3) on behalf of any local entity consisting of a unit of State or local government, State-supported institution of higher education, or nonprofit organization, meeting the requirements of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Applications by entities","label":"5 Applications by entities","identifier":"/us/usc/t29/s3228/d/5","parentIdentifier":"/us/usc/t29/s3228/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Entity applications","label":"A Entity applications","identifier":"/us/usc/t29/s3228/d/5/A","parentIdentifier":"/us/usc/t29/s3228/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F5%2FA","sourceRelease":"119-100","text":"If a State fails to support or establish a program pursuant to this section during any fiscal year, the Secretary shall, in the subsequent fiscal years, allow local entities described in paragraph (4) from that State to make applications for grants under paragraph (3) on their own initiative.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Application screening","label":"B Application screening","identifier":"/us/usc/t29/s3228/d/5/B","parentIdentifier":"/us/usc/t29/s3228/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F5%2FB","sourceRelease":"119-100","text":"Any State failing to support or establish a program pursuant to this section during any fiscal year may submit applications under paragraph (3) in the subsequent fiscal years but may not screen applications by local entities described in paragraph (4) before submitting the applications to the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Limitations","label":"6 Limitations","identifier":"/us/usc/t29/s3228/d/6","parentIdentifier":"/us/usc/t29/s3228/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s3228/d/6/A","parentIdentifier":"/us/usc/t29/s3228/d/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F6%2FA","sourceRelease":"119-100","text":"For fiscal year 2025, $300,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s3228/d/6/B","parentIdentifier":"/us/usc/t29/s3228/d/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F6%2FB","sourceRelease":"119-100","text":"For fiscal year 2026, $330,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t29/s3228/d/6/C","parentIdentifier":"/us/usc/t29/s3228/d/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F6%2FC","sourceRelease":"119-100","text":"For fiscal year 2027, $363,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t29/s3228/d/6/D","parentIdentifier":"/us/usc/t29/s3228/d/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F6%2FD","sourceRelease":"119-100","text":"For fiscal year 2028, $399,300.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t29/s3228/d/6/E","parentIdentifier":"/us/usc/t29/s3228/d/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F6%2FE","sourceRelease":"119-100","text":"For fiscal year 2029, $439,200.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Annual report","label":"7 Annual report","identifier":"/us/usc/t29/s3228/d/7","parentIdentifier":"/us/usc/t29/s3228/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fd%2F7","sourceRelease":"119-100","text":"For each year, each recipient of a grant under this subsection shall submit to the Secretary a report describing how grant funds allocated pursuant to this subsection were expended during the 12-month period preceding the date of the submission of the report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Evaluations","label":"e Evaluations","identifier":"/us/usc/t29/s3228/e","parentIdentifier":"/us/usc/t29/s3228","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fe","sourceRelease":"119-100","text":"The Secretary is authorized to reserve not more than 10 percent of the funds appropriated for a fiscal year to carry out this section, for the purposes of conducting evaluations of the grant programs identified in subsection (d) and to provide related technical assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Reporting","label":"f Reporting","identifier":"/us/usc/t29/s3228/f","parentIdentifier":"/us/usc/t29/s3228","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s3228/f/1","parentIdentifier":"/us/usc/t29/s3228/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Ff%2F1","sourceRelease":"119-100","text":"on progress related to employee ownership in businesses in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s3228/f/2","parentIdentifier":"/us/usc/t29/s3228/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Ff%2F2","sourceRelease":"119-100","text":"containing an analysis of critical costs and benefits of activities carried out under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Authorizations of appropriations","label":"g Authorizations of appropriations","identifier":"/us/usc/t29/s3228/g","parentIdentifier":"/us/usc/t29/s3228","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t29/s3228/g/1","parentIdentifier":"/us/usc/t29/s3228/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fg%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s3228/g/1/A","parentIdentifier":"/us/usc/t29/s3228/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fg%2F1%2FA","sourceRelease":"119-100","text":"For fiscal year 2025, $4,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s3228/g/1/B","parentIdentifier":"/us/usc/t29/s3228/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fg%2F1%2FB","sourceRelease":"119-100","text":"For fiscal year 2026, $7,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t29/s3228/g/1/C","parentIdentifier":"/us/usc/t29/s3228/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fg%2F1%2FC","sourceRelease":"119-100","text":"For fiscal year 2027, $10,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t29/s3228/g/1/D","parentIdentifier":"/us/usc/t29/s3228/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fg%2F1%2FD","sourceRelease":"119-100","text":"For fiscal year 2028, $13,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t29/s3228/g/1/E","parentIdentifier":"/us/usc/t29/s3228/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fg%2F1%2FE","sourceRelease":"119-100","text":"For fiscal year 2029, $16,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Administrative expenses","label":"2 Administrative expenses","identifier":"/us/usc/t29/s3228/g/2","parentIdentifier":"/us/usc/t29/s3228/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fg%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s3228/g/2/A","parentIdentifier":"/us/usc/t29/s3228/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fg%2F2%2FA","sourceRelease":"119-100","text":"for fiscal year 2024, $200,000, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s3228/g/2/B","parentIdentifier":"/us/usc/t29/s3228/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fg%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t29/s3228/g/2/B/i","parentIdentifier":"/us/usc/t29/s3228/g/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fg%2F2%2FB%2Fi","sourceRelease":"119-100","text":"$350,000; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t29/s3228/g/2/B/ii","parentIdentifier":"/us/usc/t29/s3228/g/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs3228%2Fg%2F2%2FB%2Fii","sourceRelease":"119-100","text":"5.0 percent of the maximum amount available under paragraph (1) for that fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
