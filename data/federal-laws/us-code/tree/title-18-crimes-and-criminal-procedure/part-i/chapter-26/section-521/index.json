{"type":"section","nativeType":"section","number":"521","heading":"Criminal street gangs","label":"521 Criminal street gangs","identifier":"/us/usc/t18/s521","parentIdentifier":"/us/usc/t18/ptI/ch26","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2018—Subsec. (c)(3), (4). added par. (3), redesignated former par. (3) as (4), and in par. (4), substituted “(1), (2), or (3)” for “(1) or (2)”.Pub. L. 115–3922002—Subsec. (a). realigned margins of par. defining “State”.Pub. L. 107–2731996—Subsec. (a). inserted par. defining “State” at end.Pub. L. 104–294"],"amendments":["Amendments2018—Subsec. (c)(3), (4). added par. (3), redesignated former par. (3) as (4), and in par. (4), substituted “(1), (2), or (3)” for “(1) or (2)”.Pub. L. 115–3922002—Subsec. (a). realigned margins of par. defining “State”.Pub. L. 107–2731996—Subsec. (a). inserted par. defining “State” at end.Pub. L. 104–294"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions.—","label":"a Definitions.—","identifier":"/us/usc/t18/s521/a","parentIdentifier":"/us/usc/t18/s521","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s521/a/A","parentIdentifier":"/us/usc/t18/s521/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fa%2FA","sourceRelease":"119-100","text":"that has as 1 of its primary purposes the commission of 1 or more of the criminal offenses described in subsection (c);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s521/a/B","parentIdentifier":"/us/usc/t18/s521/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fa%2FB","sourceRelease":"119-100","text":"the members of which engage, or have engaged within the past 5 years, in a continuing series of offenses described in subsection (c); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t18/s521/a/C","parentIdentifier":"/us/usc/t18/s521/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fa%2FC","sourceRelease":"119-100","text":"the activities of which affect interstate or foreign commerce.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Penalty","label":"b .—Penalty","identifier":"/us/usc/t18/s521/b","parentIdentifier":"/us/usc/t18/s521","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fb","sourceRelease":"119-100","text":"The sentence of a person convicted of an offense described in subsection (c) shall be increased by up to 10 years if the offense is committed under the circumstances described in subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Offenses","label":"c .—Offenses","identifier":"/us/usc/t18/s521/c","parentIdentifier":"/us/usc/t18/s521","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s521/c/1","parentIdentifier":"/us/usc/t18/s521/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fc%2F1","sourceRelease":"119-100","text":"a Federal felony involving a controlled substance (as defined in section 102 of the Controlled Substances Act ()) for which the maximum penalty is not less than 5 years;21 U.S.C. 802","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s521/c/2","parentIdentifier":"/us/usc/t18/s521/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fc%2F2","sourceRelease":"119-100","text":"a Federal felony crime of violence that has as an element the use or attempted use of physical force against the person of another;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s521/c/3","parentIdentifier":"/us/usc/t18/s521/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fc%2F3","sourceRelease":"119-100","text":"a Federal offense involving human trafficking, sexual abuse, sexual exploitation, or transportation for prostitution or any illegal sexual activity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t18/s521/c/4","parentIdentifier":"/us/usc/t18/s521/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fc%2F4","sourceRelease":"119-100","text":"a conspiracy to commit an offense described in paragraph (1), (2), or (3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Circumstances","label":"d .—Circumstances","identifier":"/us/usc/t18/s521/d","parentIdentifier":"/us/usc/t18/s521","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s521/d/1","parentIdentifier":"/us/usc/t18/s521/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fd%2F1","sourceRelease":"119-100","text":"participates in a criminal street gang with knowledge that its members engage in or have engaged in a continuing series of offenses described in subsection (c);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s521/d/2","parentIdentifier":"/us/usc/t18/s521/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fd%2F2","sourceRelease":"119-100","text":"intends to promote or further the felonious activities of the criminal street gang or maintain or increase his or her position in the gang; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s521/d/3","parentIdentifier":"/us/usc/t18/s521/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s521/d/3/A","parentIdentifier":"/us/usc/t18/s521/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fd%2F3%2FA","sourceRelease":"119-100","text":"an offense described in subsection (c);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s521/d/3/B","parentIdentifier":"/us/usc/t18/s521/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fd%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t18/s521/d/3/B/i","parentIdentifier":"/us/usc/t18/s521/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fd%2F3%2FB%2Fi","sourceRelease":"119-100","text":"involving a controlled substance (as defined in section 102 of the Controlled Substances Act ()) for which the maximum penalty is not less than 5 years’ imprisonment; or21 U.S.C. 802","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t18/s521/d/3/B/ii","parentIdentifier":"/us/usc/t18/s521/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fd%2F3%2FB%2Fii","sourceRelease":"119-100","text":"that is a felony crime of violence that has as an element the use or attempted use of physical force against the person of another;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t18/s521/d/3/C","parentIdentifier":"/us/usc/t18/s521/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fd%2F3%2FC","sourceRelease":"119-100","text":"any Federal or State felony offense that by its nature involves a substantial risk that physical force against the person of another may be used in the course of committing the offense; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t18/s521/d/3/D","parentIdentifier":"/us/usc/t18/s521/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs521%2Fd%2F3%2FD","sourceRelease":"119-100","text":"a conspiracy to commit an offense described in subparagraph (A), (B), or (C).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
