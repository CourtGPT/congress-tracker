{"type":"section","nativeType":"section","number":"4711","heading":"Abandonment of vessels prohibited","label":"4711 Abandonment of vessels prohibited","identifier":"/us/usc/t46/s4711","parentIdentifier":"/us/usc/t46/stII/ptB/ch47/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t46/s4711/a","parentIdentifier":"/us/usc/t46/s4711","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fa","sourceRelease":"119-100","text":"An owner or operator of a covered vessel may not abandon such vessel on the navigable waters of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Determination of Abandonment.—","label":"b Determination of Abandonment.—","identifier":"/us/usc/t46/s4711/b","parentIdentifier":"/us/usc/t46/s4711","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Notification.—","label":"1 Notification.—","identifier":"/us/usc/t46/s4711/b/1","parentIdentifier":"/us/usc/t46/s4711/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t46/s4711/b/1/A","parentIdentifier":"/us/usc/t46/s4711/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t46/s4711/b/1/A/i","parentIdentifier":"/us/usc/t46/s4711/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"attempt to identify the owner using the vessel registration number, hull identification number, or any other information that can be reasonably inferred or gathered; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t46/s4711/b/1/A/ii","parentIdentifier":"/us/usc/t46/s4711/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t46/s4711/b/1/A/ii/I","parentIdentifier":"/us/usc/t46/s4711/b/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fb%2F1%2FA%2Fii%2FI","sourceRelease":"119-100","text":"of the penalty described in subsection (c); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t46/s4711/b/1/A/ii/II","parentIdentifier":"/us/usc/t46/s4711/b/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fb%2F1%2FA%2Fii%2FII","sourceRelease":"119-100","text":"that the vessel will be removed at the expense of the owner if the Commandant determines that the vessel is abandoned and the owner does not remove or account for the vessel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Form","label":"B .—Form","identifier":"/us/usc/t46/s4711/b/1/B","parentIdentifier":"/us/usc/t46/s4711/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t46/s4711/b/1/B/i","parentIdentifier":"/us/usc/t46/s4711/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"if the owner can be identified, via certified mail or other appropriate forms determined by the Commandant; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t46/s4711/b/1/B/ii","parentIdentifier":"/us/usc/t46/s4711/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"if the owner cannot be identified, via an announcement in a local publication and on a website maintained by the Coast Guard.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Determination","label":"2 .—Determination","identifier":"/us/usc/t46/s4711/b/2","parentIdentifier":"/us/usc/t46/s4711/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fb%2F2","sourceRelease":"119-100","text":"The Commandant shall make a determination not earlier than 45 days after the date on which the Commandant provides the notification required under paragraph (1) of whether a covered vessel described in such paragraph is abandoned.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Penalty.—","label":"c Penalty.—","identifier":"/us/usc/t46/s4711/c","parentIdentifier":"/us/usc/t46/s4711","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t46/s4711/c/1","parentIdentifier":"/us/usc/t46/s4711/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fc%2F1","sourceRelease":"119-100","text":"The Commandant may assess a civil penalty of not more than $500 against an owner or operator of a covered vessel determined to be abandoned under subsection (b) for a violation of subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Liability in rem","label":"2 .—Liability in rem","identifier":"/us/usc/t46/s4711/c/2","parentIdentifier":"/us/usc/t46/s4711/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fc%2F2","sourceRelease":"119-100","text":"The owner or operator of a covered vessel shall also be liable in rem for a penalty imposed under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Limitation","label":"3 .—Limitation","identifier":"/us/usc/t46/s4711/c/3","parentIdentifier":"/us/usc/t46/s4711/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fc%2F3","sourceRelease":"119-100","text":"The Commandant shall not assess a penalty if the Commandant determines the vessel was abandoned due to major extenuating circumstances of the owner or operator of the vessel, including long term medical incapacitation of the owner or operator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Vessels Not Abandoned","label":"d .—Vessels Not Abandoned","identifier":"/us/usc/t46/s4711/d","parentIdentifier":"/us/usc/t46/s4711","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s4711/d/1","parentIdentifier":"/us/usc/t46/s4711/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fd%2F1","sourceRelease":"119-100","text":"such vessel is located at a federally approved or State approved mooring area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s4711/d/2","parentIdentifier":"/us/usc/t46/s4711/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fd%2F2","sourceRelease":"119-100","text":"such vessel is located on private property with the permission of the owner of such property;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s4711/d/3","parentIdentifier":"/us/usc/t46/s4711/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s4711/d/3/A","parentIdentifier":"/us/usc/t46/s4711/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fd%2F3%2FA","sourceRelease":"119-100","text":"indicates the location of the vessel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s4711/d/3/B","parentIdentifier":"/us/usc/t46/s4711/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fd%2F3%2FB","sourceRelease":"119-100","text":"indicates that the vessel is not abandoned; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t46/s4711/d/3/C","parentIdentifier":"/us/usc/t46/s4711/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fd%2F3%2FC","sourceRelease":"119-100","text":"contains documentation proving that the vessel is allowed to be in such location; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t46/s4711/d/4","parentIdentifier":"/us/usc/t46/s4711/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4711%2Fd%2F4","sourceRelease":"119-100","text":"the Commandant determines that such an abandonment determination would not be in the public interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
