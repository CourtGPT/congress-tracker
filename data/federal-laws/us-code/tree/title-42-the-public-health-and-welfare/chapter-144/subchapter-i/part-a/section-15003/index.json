{"type":"section","nativeType":"section","number":"15003","heading":"Records and audits","label":"15003 Records and audits","identifier":"/us/usc/t42/s15003","parentIdentifier":"/us/usc/t42/ch144/schI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15003","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Records","label":"a Records","identifier":"/us/usc/t42/s15003/a","parentIdentifier":"/us/usc/t42/s15003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15003%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15003/a/1","parentIdentifier":"/us/usc/t42/s15003/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15003%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15003/a/1/A","parentIdentifier":"/us/usc/t42/s15003/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15003%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the amount and disposition by such recipient of the assistance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15003/a/1/B","parentIdentifier":"/us/usc/t42/s15003/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15003%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the total cost of the project or undertaking in connection with which such assistance is given or used; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s15003/a/1/C","parentIdentifier":"/us/usc/t42/s15003/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15003%2Fa%2F1%2FC","sourceRelease":"119-100","text":"the amount of that portion of the cost of the project or undertaking that is supplied by other sources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15003/a/2","parentIdentifier":"/us/usc/t42/s15003/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15003%2Fa%2F2","sourceRelease":"119-100","text":"such other records as will facilitate an effective audit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Access","label":"b Access","identifier":"/us/usc/t42/s15003/b","parentIdentifier":"/us/usc/t42/s15003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15003%2Fb","sourceRelease":"119-100","text":"The Secretary and the Comptroller General of the United States, or any of their duly authorized representatives, shall have access for the purpose of audit and examination to any books, documents, papers, and records of the recipients of assistance under this subchapter that are pertinent to such assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
