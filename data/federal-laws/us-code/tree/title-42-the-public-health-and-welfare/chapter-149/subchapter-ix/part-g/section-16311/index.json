ceRelease":"119-100","text":"$8,000,000 for fiscal year 2009.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Integrated bioenergy research and development","label":"d Integrated bioenergy research and development","identifier":"/us/usc/t42/s16311/d","parentIdentifier":"/us/usc/t42/s16311","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16311%2Fd","sourceRelease":"119-100","text":"In addition to amounts otherwise authorized by this section, there are authorized to be appropriated to the Secretary for integrated bioenergy research and development programs, projects, and activities, $49,000,000 for each of the fiscal years 2005 through 2009. Activities funded under this subsection shall be coordinated with ongoing related programs of other Federal agencies, including the Plant Genome Program of the National Science Foundation. Of the funds authorized under this subsection, at least $5,000,000 for each fiscal year shall be for training and education targeted to minority and socially disadvantaged farmers and ranchers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
