{"type":"section","nativeType":"section","number":"2804","heading":"Notification of termination or nonrenewal of franchise relationship","label":"2804 Notification of termination or nonrenewal of franchise relationship","identifier":"/us/usc/t15/s2804","parentIdentifier":"/us/usc/t15/ch55/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"General requirements applicable to franchisor","label":"a General requirements applicable to franchisor","identifier":"/us/usc/t15/s2804/a","parentIdentifier":"/us/usc/t15/s2804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2804/a/1","parentIdentifier":"/us/usc/t15/s2804/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fa%2F1","sourceRelease":"119-100","text":"in the manner described in subsection (c); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2804/a/2","parentIdentifier":"/us/usc/t15/s2804/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fa%2F2","sourceRelease":"119-100","text":"except as provided in subsection (b), not less than 90 days prior to the date on which such termination or nonrenewal takes effect.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Additional requirements applicable to franchisor","label":"b Additional requirements applicable to franchisor","identifier":"/us/usc/t15/s2804/b","parentIdentifier":"/us/usc/t15/s2804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2804/b/1","parentIdentifier":"/us/usc/t15/s2804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s2804/b/1/A","parentIdentifier":"/us/usc/t15/s2804/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fb%2F1%2FA","sourceRelease":"119-100","text":"such franchisor shall furnish notification to the franchisee affected thereby on the earliest date on which furnishing of such notification is reasonably practicable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s2804/b/1/B","parentIdentifier":"/us/usc/t15/s2804/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s2804/b/1/B/i","parentIdentifier":"/us/usc/t15/s2804/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s2804/b/1/B/i/I","parentIdentifier":"/us/usc/t15/s2804/b/1/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fb%2F1%2FB%2Fi%2FI","sourceRelease":"119-100","text":"on the date notification was posted or personally delivered, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t15/s2804/b/1/B/i/II","parentIdentifier":"/us/usc/t15/s2804/b/1/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fb%2F1%2FB%2Fi%2FII","sourceRelease":"119-100","text":"if later, on the date on which such termination or nonrenewal takes effect; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s2804/b/1/B/ii","parentIdentifier":"/us/usc/t15/s2804/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"may, if permitted to do so by the franchise agreement, repossess such premises and, in circumstances under which it would be reasonable to do so, operate such premises through employees or agents.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2804/b/2","parentIdentifier":"/us/usc/t15/s2804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s2804/b/2/A","parentIdentifier":"/us/usc/t15/s2804/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fb%2F2%2FA","sourceRelease":"119-100","text":"furnish notification to the franchisee not less than 180 days prior to the date on which such termination or nonrenewal takes effect; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s2804/b/2/B","parentIdentifier":"/us/usc/t15/s2804/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fb%2F2%2FB","sourceRelease":"119-100","text":"promptly provide a copy of such notification, together with a plan describing the schedule and conditions under which the franchisor will withdraw from the marketing of motor fuel through retail outlets in the relevant geographic area, to the Governor of each State which contains a portion of such area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Manner and form of notification","label":"c Manner and form of notification","identifier":"/us/usc/t15/s2804/c","parentIdentifier":"/us/usc/t15/s2804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2804/c/1","parentIdentifier":"/us/usc/t15/s2804/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fc%2F1","sourceRelease":"119-100","text":"shall be in writing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2804/c/2","parentIdentifier":"/us/usc/t15/s2804/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fc%2F2","sourceRelease":"119-100","text":"shall be posted by certified mail or personally delivered to the franchisee; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s2804/c/3","parentIdentifier":"/us/usc/t15/s2804/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s2804/c/3/A","parentIdentifier":"/us/usc/t15/s2804/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fc%2F3%2FA","sourceRelease":"119-100","text":"a statement of intention to terminate the franchise or not to renew the franchise relationship, together with the reasons therefor;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s2804/c/3/B","parentIdentifier":"/us/usc/t15/s2804/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fc%2F3%2FB","sourceRelease":"119-100","text":"the date on which such termination or nonrenewal takes effect; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s2804/c/3/C","parentIdentifier":"/us/usc/t15/s2804/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fc%2F3%2FC","sourceRelease":"119-100","text":"the summary statement prepared under subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Preparation, publication, etc., of statutory summaries","label":"d Preparation, publication, etc., of statutory summaries","identifier":"/us/usc/t15/s2804/d","parentIdentifier":"/us/usc/t15/s2804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2804/d/1","parentIdentifier":"/us/usc/t15/s2804/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fd%2F1","sourceRelease":"119-100","text":"Not later than 30 days after , the Secretary of Energy shall prepare and publish in the Federal Register a simple and concise summary of the provisions of this subchapter, including a statement of the respective responsibilities of, and the remedies and relief available to, any franchisor and franchisee under this subchapter.June 19, 1978","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2804/d/2","parentIdentifier":"/us/usc/t15/s2804/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2804%2Fd%2F2","sourceRelease":"119-100","text":"In the case of summaries required to be furnished under the provisions of or subsection (c)(3)(C) of this section before the date of publication of such summary in the Federal Register, such summary may be furnished not later than 5 days after it is so published rather than at the time required under such provisions.section 2802(b)(2)(D) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
