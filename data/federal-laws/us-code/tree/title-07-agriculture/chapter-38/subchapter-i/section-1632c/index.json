{"type":"section","nativeType":"section","number":"1632c","heading":"Acer access and development program","label":"1632c Acer access and development program","identifier":"/us/usc/t7/s1632c","parentIdentifier":"/us/usc/t7/ch38/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Agricultural Act of 2014, and not as part of the Agricultural Marketing Act of 1946 which comprises this chapter.","Amendments2018—Subsec. (f). substituted “2023” for “2018”.Pub. L. 115–334"],"amendments":["Amendments2018—Subsec. (f). substituted “2023” for “2018”.Pub. L. 115–334"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Grants authorized","label":"a Grants authorized","identifier":"/us/usc/t7/s1632c/a","parentIdentifier":"/us/usc/t7/s1632c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s1632c/a/1","parentIdentifier":"/us/usc/t7/s1632c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fa%2F1","sourceRelease":"119-100","text":"Promotion of research and education related to maple syrup production.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s1632c/a/2","parentIdentifier":"/us/usc/t7/s1632c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fa%2F2","sourceRelease":"119-100","text":"Promotion of natural resource sustainability in the maple syrup industry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s1632c/a/3","parentIdentifier":"/us/usc/t7/s1632c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fa%2F3","sourceRelease":"119-100","text":"Market promotion for maple syrup and maple-sap products.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s1632c/a/4","parentIdentifier":"/us/usc/t7/s1632c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1632c/a/4/A","parentIdentifier":"/us/usc/t7/s1632c/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fa%2F4%2FA","sourceRelease":"119-100","text":"to initiate or expand maple-sugaring activities on the land; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1632c/a/4/B","parentIdentifier":"/us/usc/t7/s1632c/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fa%2F4%2FB","sourceRelease":"119-100","text":"to voluntarily make the land available, including by lease or other means, for access by the public for maple-sugaring activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Application","label":"b Application","identifier":"/us/usc/t7/s1632c/b","parentIdentifier":"/us/usc/t7/s1632c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s1632c/b/1","parentIdentifier":"/us/usc/t7/s1632c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fb%2F1","sourceRelease":"119-100","text":"a description of the activities to be supported using the grant funds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s1632c/b/2","parentIdentifier":"/us/usc/t7/s1632c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fb%2F2","sourceRelease":"119-100","text":"a description of the benefits that the State, tribal government, or research institution intends to achieve as a result of engaging in such activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s1632c/b/3","parentIdentifier":"/us/usc/t7/s1632c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fb%2F3","sourceRelease":"119-100","text":"an estimate of the increase in maple-sugaring activities or maple syrup production that the State, tribal government, or research institution anticipates will occur as a result of engaging in such activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Rule of construction","label":"c Rule of construction","identifier":"/us/usc/t7/s1632c/c","parentIdentifier":"/us/usc/t7/s1632c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fc","sourceRelease":"119-100","text":"Nothing in this section shall be construed so as to preempt a State or tribal government law, including a State or tribal government liability law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definition of maple-sugaring","label":"d Definition of maple-sugaring","identifier":"/us/usc/t7/s1632c/d","parentIdentifier":"/us/usc/t7/s1632c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fd","sourceRelease":"119-100","text":"In this section, the term “maple-sugaring” means the collection of sap from any species of tree in the genus Acer for the purpose of boiling to produce food.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Regulations","label":"e Regulations","identifier":"/us/usc/t7/s1632c/e","parentIdentifier":"/us/usc/t7/s1632c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Fe","sourceRelease":"119-100","text":"The Secretary of Agriculture shall promulgate such regulations as are necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorization of appropriations","label":"f Authorization of appropriations","identifier":"/us/usc/t7/s1632c/f","parentIdentifier":"/us/usc/t7/s1632c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1632c%2Ff","sourceRelease":"119-100","text":"There are authorized to be appropriated to carry out this section $20,000,000 for each of fiscal years 2014 through 2023.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
