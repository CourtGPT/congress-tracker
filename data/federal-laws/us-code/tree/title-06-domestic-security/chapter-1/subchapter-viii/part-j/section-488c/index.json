{"type":"section","nativeType":"section","number":"488c","heading":"Administrative provisions","label":"488c Administrative provisions","identifier":"/us/usc/t6/s488c","parentIdentifier":"/us/usc/t6/ch1/schVIII/ptJ","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Cooperative agreements","label":"a Cooperative agreements","identifier":"/us/usc/t6/s488c/a","parentIdentifier":"/us/usc/t6/s488c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s488c/a/1","parentIdentifier":"/us/usc/t6/s488c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fa%2F1","sourceRelease":"119-100","text":"may enter into a cooperative agreement with the Secretary of Agriculture, or the head of any State department of agriculture or its designee involved in agricultural regulation, in consultation with the State agency responsible for homeland security, to carry out the provisions of this part; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s488c/a/2","parentIdentifier":"/us/usc/t6/s488c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fa%2F2","sourceRelease":"119-100","text":"wherever possible, shall seek to cooperate with State agencies or their designees that oversee ammonium nitrate facility operations when seeking cooperative agreements to implement the registration and enforcement provisions of this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Delegation","label":"b Delegation","identifier":"/us/usc/t6/s488c/b","parentIdentifier":"/us/usc/t6/s488c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Authority","label":"1 Authority","identifier":"/us/usc/t6/s488c/b/1","parentIdentifier":"/us/usc/t6/s488c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary may delegate to a State the authority to assist the Secretary in the administration and enforcement of this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Delegation required","label":"2 Delegation required","identifier":"/us/usc/t6/s488c/b/2","parentIdentifier":"/us/usc/t6/s488c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fb%2F2","sourceRelease":"119-100","text":"At the request of a Governor of a State, the Secretary shall delegate to that State the authority to carry out functions under sections 488a and 488b of this title, if the Secretary determines that the State is capable of satisfactorily carrying out such functions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Funding","label":"3 Funding","identifier":"/us/usc/t6/s488c/b/3","parentIdentifier":"/us/usc/t6/s488c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fb%2F3","sourceRelease":"119-100","text":"Subject to the availability of appropriations, if the Secretary delegates functions to a State under this subsection, the Secretary shall provide to that State sufficient funds to carry out the delegated functions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Provision of guidance and notification materials to ammonium nitrate facilities","label":"c Provision of guidance and notification materials to ammonium nitrate facilities","identifier":"/us/usc/t6/s488c/c","parentIdentifier":"/us/usc/t6/s488c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Guidance","label":"1 Guidance","identifier":"/us/usc/t6/s488c/c/1","parentIdentifier":"/us/usc/t6/s488c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s488c/c/1/A","parentIdentifier":"/us/usc/t6/s488c/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the identification of suspicious ammonium nitrate purchases or transfers or attempted purchases or transfers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s488c/c/1/B","parentIdentifier":"/us/usc/t6/s488c/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s488c/c/1/B/i","parentIdentifier":"/us/usc/t6/s488c/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"exercising the right of the owner of the ammonium nitrate facility to decline sale of ammonium nitrate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s488c/c/1/B/ii","parentIdentifier":"/us/usc/t6/s488c/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"notifying appropriate law enforcement entities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s488c/c/1/C","parentIdentifier":"/us/usc/t6/s488c/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fc%2F1%2FC","sourceRelease":"119-100","text":"additional subjects determined appropriate to prevent the misappropriation or use of ammonium nitrate in an act of terrorism.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Use of materials and programs","label":"2 Use of materials and programs","identifier":"/us/usc/t6/s488c/c/2","parentIdentifier":"/us/usc/t6/s488c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fc%2F2","sourceRelease":"119-100","text":"In providing guidance under this subsection, the Secretary shall, to the extent practicable, leverage any relevant materials and programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Notification materials","label":"3 Notification materials","identifier":"/us/usc/t6/s488c/c/3","parentIdentifier":"/us/usc/t6/s488c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t6/s488c/c/3/A","parentIdentifier":"/us/usc/t6/s488c/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fc%2F3%2FA","sourceRelease":"119-100","text":"The Secretary shall make available materials suitable for posting at locations where ammonium nitrate is sold.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Design of materials","label":"B Design of materials","identifier":"/us/usc/t6/s488c/c/3/B","parentIdentifier":"/us/usc/t6/s488c/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s488c/c/3/B/i","parentIdentifier":"/us/usc/t6/s488c/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":"the record-keeping requirements under ; andsection 488a of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s488c/c/3/B/ii","parentIdentifier":"/us/usc/t6/s488c/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs488c%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":"the penalties for violating such requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
