req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fa%2F1","sourceRelease":"119-100","text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Battery","label":"2 Battery","identifier":"/us/usc/t42/s6966c/a/2","parentIdentifier":"/us/usc/t42/s6966c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6966c/a/2/A","parentIdentifier":"/us/usc/t42/s6966c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fa%2F2%2FA","sourceRelease":"119-100","text":"consists of 1 or more electrochemical cells that are electrically connected; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6966c/a/2/B","parentIdentifier":"/us/usc/t42/s6966c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fa%2F2%2FB","sourceRelease":"119-100","text":"is designed to store and deliver electric energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Recycling","label":"3 Recycling","identifier":"/us/usc/t42/s6966c/a/3","parentIdentifier":"/us/usc/t42/s6966c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6966c/a/3/A","parentIdentifier":"/us/usc/t42/s6966c/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fa%2F3%2FA","sourceRelease":"119-100","text":"during which recyclable materials are processed into specification-grade commodities, and consumed as raw-material feedstock, in lieu of virgin materials, in the manufacturing of new products;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6966c/a/3/B","parentIdentifier":"/us/usc/t42/s6966c/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fa%2F3%2FB","sourceRelease":"119-100","text":"that may include collection, processing, and brokering; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6966c/a/3/C","parentIdentifier":"/us/usc/t42/s6966c/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fa%2F3%2FC","sourceRelease":"119-100","text":"that result in subsequent consumption by a materials manufacturer, including for the manufacturing of new products.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Best practices for collection of batteries to be recycled","label":"b Best practices for collection of batteries to be recycled","identifier":"/us/usc/t42/s6966c/b","parentIdentifier":"/us/usc/t42/s6966c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s6966c/b/1","parentIdentifier":"/us/usc/t42/s6966c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6966c/b/1/A","parentIdentifier":"/us/usc/t42/s6966c/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fb%2F1%2FA","sourceRelease":"119-100","text":"to the maximum extent practicable, is technically and economically feasible for State, Tribal, and local governments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6966c/b/1/B","parentIdentifier":"/us/usc/t42/s6966c/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fb%2F1%2FB","sourceRelease":"119-100","text":"is environmentally sound and safe for waste management workers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6966c/b/1/C","parentIdentifier":"/us/usc/t42/s6966c/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fb%2F1%2FC","sourceRelease":"119-100","text":"optimizes the value and use of material derived from recycling of batteries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Consultation","label":"2 Consultation","identifier":"/us/usc/t42/s6966c/b/2","parentIdentifier":"/us/usc/t42/s6966c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6966c%2Fb%2F2","sourceRelease":"119-100","text":"The Administrator shall develop the best practices described in paragraph (1) in coordination with State, Tribal, and local governments and relevant nongovernmental and private sector entities.","not