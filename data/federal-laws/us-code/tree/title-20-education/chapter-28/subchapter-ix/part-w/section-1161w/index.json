{"type":"section","nativeType":"section","number":"1161w","heading":"Path to success","label":"1161w Path to success","identifier":"/us/usc/t20/s1161w","parentIdentifier":"/us/usc/t20/ch28/schIX/ptW","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purpose","label":"a Purpose","identifier":"/us/usc/t20/s1161w/a","parentIdentifier":"/us/usc/t20/s1161w","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1161w/a/1","parentIdentifier":"/us/usc/t20/s1161w/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fa%2F1","sourceRelease":"119-100","text":"leverage and enhance community support for at-risk young adults by facilitating the transition of such young adults who are eligible individuals into productive learning environments where such young adults can obtain the life, social, academic, career, and technical skills and credentials necessary to strengthen the Nation’s workforce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1161w/a/2","parentIdentifier":"/us/usc/t20/s1161w/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fa%2F2","sourceRelease":"119-100","text":"provide counseling, as appropriate, for eligible individuals participating in the programs to allow the eligible individuals to build a relationship with one or more guidance counselors during the period that the individuals are enrolled in the programs, including providing referrals and connections to community resources that help eligible individuals transition back into the community with the necessary life, social, academic, career, and technical skills after being in detention, or incarcerated, particularly resources related to health, housing, job training, and workplace readiness;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s1161w/a/3","parentIdentifier":"/us/usc/t20/s1161w/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fa%2F3","sourceRelease":"119-100","text":"provide training and education for eligible individuals participating in the programs, to allow such individuals to assist community officials and law enforcement agencies with the deterrence and prevention of gang and youth violence by participating in seminars, training, and workshops throughout the community; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s1161w/a/4","parentIdentifier":"/us/usc/t20/s1161w/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fa%2F4","sourceRelease":"119-100","text":"provide each eligible individual participating in the programs with individual attention based on a curriculum that matches the interests and abilities of the individual to the resources of the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Reentry education program","label":"b Reentry education program","identifier":"/us/usc/t20/s1161w/b","parentIdentifier":"/us/usc/t20/s1161w","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Grant program established","label":"1 Grant program established","identifier":"/us/usc/t20/s1161w/b/1","parentIdentifier":"/us/usc/t20/s1161w/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161w/b/1/A","parentIdentifier":"/us/usc/t20/s1161w/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fb%2F1%2FA","sourceRelease":"119-100","text":"A certificate of completion for a specialized area of study, such as career and technical training and other alternative postsecondary educational programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161w/b/1/B","parentIdentifier":"/us/usc/t20/s1161w/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fb%2F1%2FB","sourceRelease":"119-100","text":"An associate’s degree.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Grant period","label":"2 Grant period","identifier":"/us/usc/t20/s1161w/b/2","parentIdentifier":"/us/usc/t20/s1161w/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fb%2F2","sourceRelease":"119-100","text":"A grant awarded under this part shall be for one four-year period, and may be renewed for an additional period as the Secretary determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Application","label":"3 Application","identifier":"/us/usc/t20/s1161w/b/3","parentIdentifier":"/us/usc/t20/s1161w/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161w/b/3/A","parentIdentifier":"/us/usc/t20/s1161w/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fb%2F3%2FA","sourceRelease":"119-100","text":"an assessment of the existing community resources available to serve at-risk youth;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161w/b/3/B","parentIdentifier":"/us/usc/t20/s1161w/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fb%2F3%2FB","sourceRelease":"119-100","text":"a detailed description of the program and activities the community college will carry out with such grant; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161w/b/3/C","parentIdentifier":"/us/usc/t20/s1161w/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fb%2F3%2FC","sourceRelease":"119-100","text":"a proposed budget describing how the community college will use the funds made available by such grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Priority","label":"4 Priority","identifier":"/us/usc/t20/s1161w/b/4","parentIdentifier":"/us/usc/t20/s1161w/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fb%2F4","sourceRelease":"119-100","text":"In awarding grants under this part, the Secretary shall give priority to community colleges that propose to serve the highest number of priority individuals, and, among such community colleges, shall give priority to community colleges that the Secretary determines will best carry out the purposes of this part, based on the applications submitted in accordance with paragraph (3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Allowable uses of funds","label":"c Allowable uses of funds","identifier":"/us/usc/t20/s1161w/c","parentIdentifier":"/us/usc/t20/s1161w","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1161w/c/1","parentIdentifier":"/us/usc/t20/s1161w/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fc%2F1","sourceRelease":"119-100","text":"pay for tuition and transportation costs of eligible individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1161w/c/2","parentIdentifier":"/us/usc/t20/s1161w/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161w/c/2/A","parentIdentifier":"/us/usc/t20/s1161w/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fc%2F2%2FA","sourceRelease":"119-100","text":"provide marketable life and social skills to such individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161w/c/2/B","parentIdentifier":"/us/usc/t20/s1161w/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fc%2F2%2FB","sourceRelease":"119-100","text":"meet the education program requirements under subsection (d), including as appropriate, courses necessary for the completion of a secondary school diploma or the recognized equivalent;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161w/c/2/C","parentIdentifier":"/us/usc/t20/s1161w/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fc%2F2%2FC","sourceRelease":"119-100","text":"promote the civic engagement of such individuals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1161w/c/2/D","parentIdentifier":"/us/usc/t20/s1161w/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fc%2F2%2FD","sourceRelease":"119-100","text":"facilitate a smooth reentry of such individuals into the community;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s1161w/c/3","parentIdentifier":"/us/usc/t20/s1161w/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161w/c/3/A","parentIdentifier":"/us/usc/t20/s1161w/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fc%2F3%2FA","sourceRelease":"119-100","text":"specifically designed to help eligible individuals with the potential challenges of the transitional period from detention to release;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161w/c/3/B","parentIdentifier":"/us/usc/t20/s1161w/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fc%2F3%2FB","sourceRelease":"119-100","text":"created in consultation with guidance counselors, academic advisors, law enforcement officials, and other community resources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161w/c/3/C","parentIdentifier":"/us/usc/t20/s1161w/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fc%2F3%2FC","sourceRelease":"119-100","text":"administered by a program coordinator, selected and employed by the community college, who shall oversee each individual’s development and shall serve as the immediate supervisor and reporting officer to whom the academic advisors, guidance counselors, and volunteers shall report regarding the progress of each such individual;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s1161w/c/4","parentIdentifier":"/us/usc/t20/s1161w/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fc%2F4","sourceRelease":"119-100","text":"facilitate employment opportunities for eligible individuals by entering into partnerships with public and private entities to provide opportunities for internships, apprenticeships, and permanent employment, as possible, for such individuals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t20/s1161w/c/5","parentIdentifier":"/us/usc/t20/s1161w/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fc%2F5","sourceRelease":"119-100","text":"provide training for eligible individuals participating in the programs, to allow such individuals to assist community officials and law enforcement agencies with the deterrence and prevention of gang and youth violence by participating in seminars and workshop series throughout the community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Education program requirements","label":"d Education program requirements","identifier":"/us/usc/t20/s1161w/d","parentIdentifier":"/us/usc/t20/s1161w","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1161w/d/1","parentIdentifier":"/us/usc/t20/s1161w/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fd%2F1","sourceRelease":"119-100","text":"include classes that are required for completion of a certificate, diploma, or degree described in subparagraph (A) or (B) of subsection (b)(1), including as appropriate courses necessary for the completion of a secondary school diploma or the recognized equivalent;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1161w/d/2","parentIdentifier":"/us/usc/t20/s1161w/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fd%2F2","sourceRelease":"119-100","text":"provide a variety of academic programs, with various completion requirements, to accommodate the diverse academic backgrounds, learning styles, and academic and career interests of the eligible individuals who participate in the education program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s1161w/d/3","parentIdentifier":"/us/usc/t20/s1161w/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fd%2F3","sourceRelease":"119-100","text":"offer flexible academic programs that are designed to improve the academic development and achievement of eligible individuals, and to avoid high attrition rates for such individuals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s1161w/d/4","parentIdentifier":"/us/usc/t20/s1161w/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fd%2F4","sourceRelease":"119-100","text":"provide for a uniquely designed education plan for each eligible individual participating in the program, which shall require such individual to receive, at a minimum, a certificate or degree described in subparagraph (A) or (B) of subsection (b)(1) to successfully complete such program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Reports","label":"e Reports","identifier":"/us/usc/t20/s1161w/e","parentIdentifier":"/us/usc/t20/s1161w","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1161w/e/1","parentIdentifier":"/us/usc/t20/s1161w/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fe%2F1","sourceRelease":"119-100","text":"documenting the results of the program carried out with such grant; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1161w/e/2","parentIdentifier":"/us/usc/t20/s1161w/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fe%2F2","sourceRelease":"119-100","text":"evaluating the effectiveness of activities carried out through such program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Definitions","label":"f Definitions","identifier":"/us/usc/t20/s1161w/f","parentIdentifier":"/us/usc/t20/s1161w","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Community college","label":"1 Community college","identifier":"/us/usc/t20/s1161w/f/1","parentIdentifier":"/us/usc/t20/s1161w/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F1","sourceRelease":"119-100","text":"The term “community college” has the meaning given the term “junior or community college” in .section 1058(f) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible individual","label":"2 Eligible individual","identifier":"/us/usc/t20/s1161w/f/2","parentIdentifier":"/us/usc/t20/s1161w/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161w/f/2/A","parentIdentifier":"/us/usc/t20/s1161w/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F2%2FA","sourceRelease":"119-100","text":"is 16 to 25 years of age (inclusive); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161w/f/2/B","parentIdentifier":"/us/usc/t20/s1161w/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1161w/f/2/B/i","parentIdentifier":"/us/usc/t20/s1161w/f/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F2%2FB%2Fi","sourceRelease":"119-100","text":"has been convicted of a criminal offense; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1161w/f/2/B/ii","parentIdentifier":"/us/usc/t20/s1161w/f/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F2%2FB%2Fii","sourceRelease":"119-100","text":"is detained in, or has been released from, a juvenile detention center or secure juvenile justice residential facility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Gang-related offense","label":"3 Gang-related offense","identifier":"/us/usc/t20/s1161w/f/3","parentIdentifier":"/us/usc/t20/s1161w/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t20/s1161w/f/3/A","parentIdentifier":"/us/usc/t20/s1161w/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1161w/f/3/A/i","parentIdentifier":"/us/usc/t20/s1161w/f/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F3%2FA%2Fi","sourceRelease":"119-100","text":"a Federal or State felony involving a controlled substance (as defined in ) for which the maximum penalty is not less than five years;section 802 of title 21","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1161w/f/3/A/ii","parentIdentifier":"/us/usc/t20/s1161w/f/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F3%2FA%2Fii","sourceRelease":"119-100","text":"a Federal or State crime of violence that has as an element the use or attempted use of physical force against the person of another for which the maximum penalty is not less than six months; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t20/s1161w/f/3/A/iii","parentIdentifier":"/us/usc/t20/s1161w/f/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"a conspiracy to commit an offense described in clause (i) or (ii).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Circumstances","label":"B Circumstances","identifier":"/us/usc/t20/s1161w/f/3/B","parentIdentifier":"/us/usc/t20/s1161w/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1161w/f/3/B/i","parentIdentifier":"/us/usc/t20/s1161w/f/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F3%2FB%2Fi","sourceRelease":"119-100","text":"participates in a criminal street gang (as defined in ) with knowledge that such gang’s members engage in or have engaged in a continuing series of offenses described in subparagraph (A); andsection 521(a) of title 18","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1161w/f/3/B/ii","parentIdentifier":"/us/usc/t20/s1161w/f/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F3%2FB%2Fii","sourceRelease":"119-100","text":"intends to promote or further the felonious activities of the criminal street gang or maintain or increase the person’s position in the gang.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Priority individual","label":"4 Priority individual","identifier":"/us/usc/t20/s1161w/f/4","parentIdentifier":"/us/usc/t20/s1161w/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161w/f/4/A","parentIdentifier":"/us/usc/t20/s1161w/f/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F4%2FA","sourceRelease":"119-100","text":"is an eligible individual;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161w/f/4/B","parentIdentifier":"/us/usc/t20/s1161w/f/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F4%2FB","sourceRelease":"119-100","text":"has been convicted of a gang-related offense; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161w/f/4/C","parentIdentifier":"/us/usc/t20/s1161w/f/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F4%2FC","sourceRelease":"119-100","text":"has served or is serving a period of detention in a juvenile detention center or secure juvenile justice residential facility for such offense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Guidance counselor","label":"5 Guidance counselor","identifier":"/us/usc/t20/s1161w/f/5","parentIdentifier":"/us/usc/t20/s1161w/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Ff%2F5","sourceRelease":"119-100","text":"The term “guidance counselor” means an individual who works with at-risk youth on a one-on-one basis, to establish a supportive relationship with such at-risk youth and to provide such at-risk youth with academic assistance and exposure to new experiences that enhance their ability to become responsible citizens.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Authorization of appropriations","label":"g Authorization of appropriations","identifier":"/us/usc/t20/s1161w/g","parentIdentifier":"/us/usc/t20/s1161w","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161w%2Fg","sourceRelease":"119-100","text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
