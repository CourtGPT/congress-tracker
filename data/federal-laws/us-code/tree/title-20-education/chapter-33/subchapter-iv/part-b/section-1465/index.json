":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1465/c/2/B","parentIdentifier":"/us/usc/t20/s1465/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fc%2F2%2FB","sourceRelease":"119-100","text":"A community-based organization with a demonstrated record of effectiveness in helping children with disabilities who have behavioral challenges succeed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1465/c/2/C","parentIdentifier":"/us/usc/t20/s1465/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fc%2F2%2FC","sourceRelease":"119-100","text":"An institution of higher education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1465/c/2/D","parentIdentifier":"/us/usc/t20/s1465/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fc%2F2%2FD","sourceRelease":"119-100","text":"A community mental health provider.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s1465/c/2/E","parentIdentifier":"/us/usc/t20/s1465/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fc%2F2%2FE","sourceRelease":"119-100","text":"An educational service agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Applications","label":"d Applications","identifier":"/us/usc/t20/s1465/d","parentIdentifier":"/us/usc/t20/s1465","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1465/d/1","parentIdentifier":"/us/usc/t20/s1465/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fd%2F1","sourceRelease":"119-100","text":"submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1465/d/2","parentIdentifier":"/us/usc/t20/s1465/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fd%2F2","sourceRelease":"119-100","text":"involve parents of participating students in the design and implementation of the activities funded under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Report and evaluation","label":"e Report and evaluation","identifier":"/us/usc/t20/s1465/e","parentIdentifier":"/us/usc/t20/s1465","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fe","sourceRelease":"119-100","text":"Each eligible entity receiving a grant under this section shall prepare and submit annually to the Secretary a report on the outcomes of the activities assisted under the grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
