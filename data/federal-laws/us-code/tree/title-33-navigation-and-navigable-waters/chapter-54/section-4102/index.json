{"type":"section","nativeType":"section","number":"4102","heading":"Coordination regarding assessment and acquisition by National Oceanic and Atmospheric Administration of unmanned maritime systems","label":"4102 Coordination regarding assessment and acquisition by National Oceanic and Atmospheric Administration of unmanned maritime systems","identifier":"/us/usc/t33/s4102","parentIdentifier":"/us/usc/t33/ch54","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t33/s4102/a","parentIdentifier":"/us/usc/t33/s4102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s4102/a/1","parentIdentifier":"/us/usc/t33/s4102/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fa%2F1","sourceRelease":"119-100","text":"to coordinate the Administration’s research, assessment, and acquisition of unmanned maritime systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s4102/a/2","parentIdentifier":"/us/usc/t33/s4102/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fa%2F2","sourceRelease":"119-100","text":"to consider the use of unmanned maritime systems in cooperative activities of the Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Coordination within the Administration","label":"b Coordination within the Administration","identifier":"/us/usc/t33/s4102/b","parentIdentifier":"/us/usc/t33/s4102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Unmanned Systems Executive Oversight Board","label":"1 Unmanned Systems Executive Oversight Board","identifier":"/us/usc/t33/s4102/b/1","parentIdentifier":"/us/usc/t33/s4102/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s4102/b/1/A","parentIdentifier":"/us/usc/t33/s4102/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fb%2F1%2FA","sourceRelease":"119-100","text":"utilize the Unmanned Systems Executive Oversight Board (in this chapter referred to as the “USEOB”) as the coordinating mechanism; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s4102/b/1/B","parentIdentifier":"/us/usc/t33/s4102/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fb%2F1%2FB","sourceRelease":"119-100","text":"ensure that OAR and OMAO address requirements throughout the Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Included","label":"2 Included","identifier":"/us/usc/t33/s4102/b/2","parentIdentifier":"/us/usc/t33/s4102/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s4102/b/2/A","parentIdentifier":"/us/usc/t33/s4102/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The Office of Ocean Exploration (OER).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s4102/b/2/B","parentIdentifier":"/us/usc/t33/s4102/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fb%2F2%2FB","sourceRelease":"119-100","text":"The program office of the Integrated Ocean Observing System.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s4102/b/2/C","parentIdentifier":"/us/usc/t33/s4102/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fb%2F2%2FC","sourceRelease":"119-100","text":"Such other offices of the Administration as the Administrator determines are actively engaged with unmanned maritime systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Coordination with the Navy","label":"c Coordination with the Navy","identifier":"/us/usc/t33/s4102/c","parentIdentifier":"/us/usc/t33/s4102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s4102/c/1","parentIdentifier":"/us/usc/t33/s4102/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s4102/c/1/A","parentIdentifier":"/us/usc/t33/s4102/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F1%2FA","sourceRelease":"119-100","text":"make efforts to coordinate with the Secretary of the Navy to leverage expertise in the development and operational transition of unmanned maritime systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s4102/c/1/B","parentIdentifier":"/us/usc/t33/s4102/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F1%2FB","sourceRelease":"119-100","text":"align with, utilize, and inform the Deputy Under Secretary of Commerce for Operations and the Oceanographer of the Navy’s strategic and operational priorities, particularly for missions and geography within the Administration’s purview;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s4102/c/1/C","parentIdentifier":"/us/usc/t33/s4102/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F1%2FC","sourceRelease":"119-100","text":"seek to utilize Naval unmanned systems test or training ranges, such as the Gulf of Mexico Unmanned Systems Test and Training Range of the Naval Meteorology and Oceanography Command, and maximize interagency cooperation and sharing of best practices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t33/s4102/c/1/D","parentIdentifier":"/us/usc/t33/s4102/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F1%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s4102/c/1/D/i","parentIdentifier":"/us/usc/t33/s4102/c/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F1%2FD%2Fi","sourceRelease":"119-100","text":"incorporating consideration of priorities and requirements of the Administration into research and development activities conducted by the Secretary of the Navy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s4102/c/1/D/ii","parentIdentifier":"/us/usc/t33/s4102/c/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F1%2FD%2Fii","sourceRelease":"119-100","text":"consultation intended to encourage and facilitate efforts by the Administration to partner with the Navy to procure unmanned maritime systems and to establish, instrument, and operate test or training ranges and related facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t33/s4102/c/1/D/iii","parentIdentifier":"/us/usc/t33/s4102/c/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F1%2FD%2Fiii","sourceRelease":"119-100","text":"adopting procedures defined by the Secretary of the Navy for the Administration to access and utilize test or training ranges or related Naval facilities for purposes identified in paragraph (2)(B); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t33/s4102/c/1/D/iv","parentIdentifier":"/us/usc/t33/s4102/c/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F1%2FD%2Fiv","sourceRelease":"119-100","text":"such other topics as the Administrator considers necessary or advisable, including mapping, bathymetry, observations, and ocean exploration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Location","label":"2 Location","identifier":"/us/usc/t33/s4102/c/2","parentIdentifier":"/us/usc/t33/s4102/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s4102/c/2/A","parentIdentifier":"/us/usc/t33/s4102/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F2%2FA","sourceRelease":"119-100","text":"Gaining efficiencies through collaboration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s4102/c/2/B","parentIdentifier":"/us/usc/t33/s4102/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s4102/c/2/B/i","parentIdentifier":"/us/usc/t33/s4102/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"systems research and development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s4102/c/2/B/ii","parentIdentifier":"/us/usc/t33/s4102/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"systems testing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t33/s4102/c/2/B/iii","parentIdentifier":"/us/usc/t33/s4102/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"systems modifications; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t33/s4102/c/2/B/iv","parentIdentifier":"/us/usc/t33/s4102/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"systems integration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s4102/c/2/C","parentIdentifier":"/us/usc/t33/s4102/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fc%2F2%2FC","sourceRelease":"119-100","text":"Accelerating transition from concept to manufacturing and acquisition.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Coordination with other Federal agencies","label":"d Coordination with other Federal agencies","identifier":"/us/usc/t33/s4102/d","parentIdentifier":"/us/usc/t33/s4102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fd","sourceRelease":"119-100","text":"In carrying out this chapter, the Administrator and the Secretary of the Navy may utilize the National Oceanographic Partnership Program, established under chapter 665 of title 10, as a mechanism for providing interagency coordination for the advancement of unmanned maritime systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Coordination with academic sector","label":"e Coordination with academic sector","identifier":"/us/usc/t33/s4102/e","parentIdentifier":"/us/usc/t33/s4102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s4102/e/1","parentIdentifier":"/us/usc/t33/s4102/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fe%2F1","sourceRelease":"119-100","text":"Maximizing opportunities for research and development of unmanned maritime systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s4102/e/2","parentIdentifier":"/us/usc/t33/s4102/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fe%2F2","sourceRelease":"119-100","text":"Providing training in unmanned maritime systems as part of an accredited certificate or degree program of education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s4102/e/3","parentIdentifier":"/us/usc/t33/s4102/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fe%2F3","sourceRelease":"119-100","text":"Facilitating the commercialization of unmanned maritime systems through public-private partnerships that includes academic research institutions, private industry, and public safety agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s4102/e/4","parentIdentifier":"/us/usc/t33/s4102/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fe%2F4","sourceRelease":"119-100","text":"Arranging access to and use of additional facilities that support testing and assessment of or training with respect to unmanned maritime systems under environmental conditions of interest, increasing operational tolerance under such conditions, certifying operational capacity under such conditions, whether real or simulated, and training operators of unmanned maritime systems in real or simulated environments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t33/s4102/e/5","parentIdentifier":"/us/usc/t33/s4102/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fe%2F5","sourceRelease":"119-100","text":"Facilitating engagement with other academic institutions with interest or relevant expertise in unmanned maritime systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t33/s4102/e/6","parentIdentifier":"/us/usc/t33/s4102/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Fe%2F6","sourceRelease":"119-100","text":"Promoting information sharing between the academic, environmental, and military institutions to lead to more robust, mission-oriented unmanned maritime systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Engagement with the private sector","label":"f Engagement with the private sector","identifier":"/us/usc/t33/s4102/f","parentIdentifier":"/us/usc/t33/s4102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s4102/f/1","parentIdentifier":"/us/usc/t33/s4102/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Ff%2F1","sourceRelease":"119-100","text":"to support the commercialization of unmanned maritime systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s4102/f/2","parentIdentifier":"/us/usc/t33/s4102/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4102%2Ff%2F2","sourceRelease":"119-100","text":"to assist with their assessment of commercially available unmanned maritime systems to support the missions and goals of the Navy, the Administration, and cooperative activities of the Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
