{"type":"section","nativeType":"section","number":"17082","heading":"Zero Net Energy Commercial Buildings Initiative","label":"17082 Zero Net Energy Commercial Buildings Initiative","identifier":"/us/usc/t42/s17082","parentIdentifier":"/us/usc/t42/ch152/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2021—Subsec. (d)(3). inserted “(including demand-response technologies, practices, and policies)” after “policies”.Pub. L. 117–58","Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2","Wage Rate RequirementsFor provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of , including authority of Secretary of Labor, see .Pub. L. 117–58section 18851 of this title"],"amendments":["Amendments2021—Subsec. (d)(3). inserted “(including demand-response technologies, practices, and policies)” after “policies”.Pub. L. 117–58","Wage Rate RequirementsFor provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of , including authority of Secretary of Labor, see .Pub. L. 117–58section 18851 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s17082/a","parentIdentifier":"/us/usc/t42/s17082","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Consortium","label":"1 Consortium","identifier":"/us/usc/t42/s17082/a/1","parentIdentifier":"/us/usc/t42/s17082/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fa%2F1","sourceRelease":"119-100","text":"The term “consortium” means a High-Performance Green Building Consortium selected by the Commercial Director.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Initiative","label":"2 Initiative","identifier":"/us/usc/t42/s17082/a/2","parentIdentifier":"/us/usc/t42/s17082/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fa%2F2","sourceRelease":"119-100","text":"The term “initiative” means the Zero-Net-Energy Commercial Buildings Initiative established under subsection (b)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Zero-net-energy commercial building","label":"3 Zero-net-energy commercial building","identifier":"/us/usc/t42/s17082/a/3","parentIdentifier":"/us/usc/t42/s17082/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17082/a/3/A","parentIdentifier":"/us/usc/t42/s17082/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fa%2F3%2FA","sourceRelease":"119-100","text":"to require a greatly reduced quantity of energy to operate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17082/a/3/B","parentIdentifier":"/us/usc/t42/s17082/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fa%2F3%2FB","sourceRelease":"119-100","text":"to meet the balance of energy needs from sources of energy that do not produce greenhouse gases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17082/a/3/C","parentIdentifier":"/us/usc/t42/s17082/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fa%2F3%2FC","sourceRelease":"119-100","text":"in a manner that will result in no net emissions of greenhouse gases; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17082/a/3/D","parentIdentifier":"/us/usc/t42/s17082/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fa%2F3%2FD","sourceRelease":"119-100","text":"to be economically viable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t42/s17082/b","parentIdentifier":"/us/usc/t42/s17082","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17082/b/1","parentIdentifier":"/us/usc/t42/s17082/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17082/b/1/A","parentIdentifier":"/us/usc/t42/s17082/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fb%2F1%2FA","sourceRelease":"119-100","text":"to reduce the quantity of energy consumed by commercial buildings located in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17082/b/1/B","parentIdentifier":"/us/usc/t42/s17082/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fb%2F1%2FB","sourceRelease":"119-100","text":"to achieve the development of zero net energy commercial buildings in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Consortium","label":"2 Consortium","identifier":"/us/usc/t42/s17082/b/2","parentIdentifier":"/us/usc/t42/s17082/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s17082/b/2/A","parentIdentifier":"/us/usc/t42/s17082/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fb%2F2%2FA","sourceRelease":"119-100","text":"Not later than 180 days after , the Commercial Director shall competitively select, and enter into an agreement with, a consortium to develop and carry out the initiative.December 19, 2007","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Agreements","label":"B Agreements","identifier":"/us/usc/t42/s17082/b/2/B","parentIdentifier":"/us/usc/t42/s17082/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fb%2F2%2FB","sourceRelease":"119-100","text":"In entering into an agreement with a consortium under subparagraph (A), the Commercial Director shall use the authority described in , to the maximum extent practicable.section 7256(g) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Goal of initiative","label":"c Goal of initiative","identifier":"/us/usc/t42/s17082/c","parentIdentifier":"/us/usc/t42/s17082","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17082/c/1","parentIdentifier":"/us/usc/t42/s17082/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fc%2F1","sourceRelease":"119-100","text":"any commercial building newly constructed in the United States by 2030;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17082/c/2","parentIdentifier":"/us/usc/t42/s17082/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fc%2F2","sourceRelease":"119-100","text":"50 percent of the commercial building stock of the United States by 2040; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17082/c/3","parentIdentifier":"/us/usc/t42/s17082/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fc%2F3","sourceRelease":"119-100","text":"all commercial buildings in the United States by 2050.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Components","label":"d Components","identifier":"/us/usc/t42/s17082/d","parentIdentifier":"/us/usc/t42/s17082","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17082/d/1","parentIdentifier":"/us/usc/t42/s17082/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fd%2F1","sourceRelease":"119-100","text":"conduct research and development on building science, design, materials, components, equipment and controls, operation and other practices, integration, energy use measurement, and benchmarking;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17082/d/2","parentIdentifier":"/us/usc/t42/s17082/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fd%2F2","sourceRelease":"119-100","text":"conduct pilot programs and demonstration projects to evaluate replicable approaches to achieving energy efficient commercial buildings for a variety of building types in a variety of climate zones;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17082/d/3","parentIdentifier":"/us/usc/t42/s17082/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fd%2F3","sourceRelease":"119-100","text":"conduct deployment, dissemination, and technical assistance activities to encourage widespread adoption of technologies, practices, and policies (including demand-response technologies, practices, and policies) to achieve energy efficient commercial buildings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17082/d/4","parentIdentifier":"/us/usc/t42/s17082/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fd%2F4","sourceRelease":"119-100","text":"conduct other research, development, demonstration, and deployment activities necessary to achieve each goal of the initiative, as determined by the Commercial Director, in consultation with the consortium;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s17082/d/5","parentIdentifier":"/us/usc/t42/s17082/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fd%2F5","sourceRelease":"119-100","text":"develop training materials and courses for building professionals and trades on achieving cost-effective high-performance energy efficient buildings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s17082/d/6","parentIdentifier":"/us/usc/t42/s17082/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fd%2F6","sourceRelease":"119-100","text":"develop and disseminate public education materials to share information on the benefits and cost-effectiveness of high-performance energy efficient buildings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s17082/d/7","parentIdentifier":"/us/usc/t42/s17082/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fd%2F7","sourceRelease":"119-100","text":"support code-setting organizations and State and local governments in developing minimum performance standards in building codes that recognize the ready availability of many technologies utilized in high-performance energy efficient buildings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s17082/d/8","parentIdentifier":"/us/usc/t42/s17082/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fd%2F8","sourceRelease":"119-100","text":"develop strategies for overcoming the split incentives between builders and purchasers, and landlords and tenants, to ensure that energy efficiency and high-performance investments are made that are cost-effective on a lifecycle basis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t42/s17082/d/9","parentIdentifier":"/us/usc/t42/s17082/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fd%2F9","sourceRelease":"119-100","text":"develop improved means of measurement and verification of energy savings and performance for public dissemination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Cost sharing","label":"e Cost sharing","identifier":"/us/usc/t42/s17082/e","parentIdentifier":"/us/usc/t42/s17082","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Fe","sourceRelease":"119-100","text":"In carrying out this section, the Commercial Director shall require cost sharing in accordance with .section 16352 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorization of appropriations","label":"f Authorization of appropriations","identifier":"/us/usc/t42/s17082/f","parentIdentifier":"/us/usc/t42/s17082","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17082/f/1","parentIdentifier":"/us/usc/t42/s17082/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Ff%2F1","sourceRelease":"119-100","text":"$20,000,000 for fiscal year 2008;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17082/f/2","parentIdentifier":"/us/usc/t42/s17082/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Ff%2F2","sourceRelease":"119-100","text":"$50,000,000 for each of fiscal years 2009 and 2010;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17082/f/3","parentIdentifier":"/us/usc/t42/s17082/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Ff%2F3","sourceRelease":"119-100","text":"$100,000,000 for each of fiscal years 2011 and 2012; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17082/f/4","parentIdentifier":"/us/usc/t42/s17082/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17082%2Ff%2F4","sourceRelease":"119-100","text":"$200,000,000 for each of fiscal years 2013 through 2018.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
