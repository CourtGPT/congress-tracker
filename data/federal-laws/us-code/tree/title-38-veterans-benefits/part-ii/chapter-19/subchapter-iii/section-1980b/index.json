{"type":"section","nativeType":"section","number":"1980B","heading":"Periodic review of automatic maximum coverage","label":"1980B Periodic review of automatic maximum coverage","identifier":"/us/usc/t38/s1980B","parentIdentifier":"/us/usc/t38/ptII/ch19/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1980B","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t38/s1980B/a","parentIdentifier":"/us/usc/t38/s1980B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1980B%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1980B/a/1","parentIdentifier":"/us/usc/t38/s1980B/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1980B%2Fa%2F1","sourceRelease":"119-100","text":"complete a review of how the amount specified in section 1967(a)(3)(A)(i) compares to the amount described in subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1980B/a/2","parentIdentifier":"/us/usc/t38/s1980B/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1980B%2Fa%2F2","sourceRelease":"119-100","text":"submit to the Committees on Veterans’ Affairs of the House of Representatives and the Senate the results of the review, which may serve as a guide for coverage increases within the existing administrative incremental structure.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Amount Described","label":"b .—Amount Described","identifier":"/us/usc/t38/s1980B/b","parentIdentifier":"/us/usc/t38/s1980B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1980B%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1980B/b/1","parentIdentifier":"/us/usc/t38/s1980B/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1980B%2Fb%2F1","sourceRelease":"119-100","text":"$500,000; multiplied by","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1980B/b/2","parentIdentifier":"/us/usc/t38/s1980B/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1980B%2Fb%2F2","sourceRelease":"119-100","text":"the average percentage by which the Consumer Price Index changed during the five fiscal years preceding the review under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Consumer Price Index Defined","label":"c .—Consumer Price Index Defined","identifier":"/us/usc/t38/s1980B/c","parentIdentifier":"/us/usc/t38/s1980B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1980B%2Fc","sourceRelease":"119-100","text":"In this section, the term “Consumer Price Index” means the Consumer Price Index for All Urban Consumers published by the Bureau of Labor Statistics of the Department of Labor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
