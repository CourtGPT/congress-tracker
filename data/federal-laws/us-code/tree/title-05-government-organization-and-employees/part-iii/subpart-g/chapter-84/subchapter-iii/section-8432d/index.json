{"type":"section","nativeType":"section","number":"8432d","heading":"Qualified Roth contribution program","label":"8432d Qualified Roth contribution program","identifier":"/us/usc/t5/s8432d","parentIdentifier":"/us/usc/t5/ptIII/sptG/ch84/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8432d","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextSection 402A of the Internal Revenue Code of 1986, referred to in subsec. (a), is classified to , Internal Revenue Code.section 402A of Title 26"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Definitions","label":"a .—Definitions","identifier":"/us/usc/t5/s8432d/a","parentIdentifier":"/us/usc/t5/s8432d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8432d%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s8432d/a/1","parentIdentifier":"/us/usc/t5/s8432d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8432d%2Fa%2F1","sourceRelease":"119-100","text":"the term “qualified Roth contribution program” means a program described in paragraph (1) of section 402A(b) of the Internal Revenue Code of 1986 which meets the requirements of paragraph (2) of such section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s8432d/a/2","parentIdentifier":"/us/usc/t5/s8432d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8432d%2Fa%2F2","sourceRelease":"119-100","text":"the terms “designated Roth contribution” and “elective deferral” have the meanings given such terms in section 402A of the Internal Revenue Code of 1986.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Authority To Establish","label":"b .—Authority To Establish","identifier":"/us/usc/t5/s8432d/b","parentIdentifier":"/us/usc/t5/s8432d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8432d%2Fb","sourceRelease":"119-100","text":"The Executive Director shall by regulation provide for the inclusion in the Thrift Savings Plan of a qualified Roth contribution program, under such terms and conditions as the Board may prescribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Required Provisions","label":"c .—Required Provisions","identifier":"/us/usc/t5/s8432d/c","parentIdentifier":"/us/usc/t5/s8432d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8432d%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s8432d/c/1","parentIdentifier":"/us/usc/t5/s8432d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8432d%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s8432d/c/1/A","parentIdentifier":"/us/usc/t5/s8432d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8432d%2Fc%2F1%2FA","sourceRelease":"119-100","text":"by any individual who is eligible to make contributions under section 8351, 8432(a), 8440a, 8440b, 8440c, 8440d, or 8440e; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s8432d/c/1/B","parentIdentifier":"/us/usc/t5/s8432d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8432d%2Fc%2F1%2FB","sourceRelease":"119-100","text":"by any individual, not described in subparagraph (A), who is otherwise eligible to make elective deferrals under the Thrift Savings Plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s8432d/c/2","parentIdentifier":"/us/usc/t5/s8432d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8432d%2Fc%2F2","sourceRelease":"119-100","text":"any provisions which may, as a result of enactment of this section, be necessary in order to clarify the meaning of any reference to an “account” made in section 8432(f), 8433, 8434(d), 8435, 8437, or any other provision of law; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s8432d/c/3","parentIdentifier":"/us/usc/t5/s8432d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8432d%2Fc%2F3","sourceRelease":"119-100","text":"any other provisions which may be necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
