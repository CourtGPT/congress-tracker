{"type":"section","nativeType":"section","number":"1473","heading":"Definitions","label":"1473 Definitions","identifier":"/us/usc/t26/s1473","parentIdentifier":"/us/usc/t26/stA/ch4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Withholdable payment","label":"1 Withholdable payment","identifier":"/us/usc/t26/s1473/1","parentIdentifier":"/us/usc/t26/s1473","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t26/s1473/1/A","parentIdentifier":"/us/usc/t26/s1473/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s1473/1/A/i","parentIdentifier":"/us/usc/t26/s1473/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F1%2FA%2Fi","sourceRelease":"119-100","text":"any payment of interest (including any original issue discount), dividends, rents, salaries, wages, premiums, annuities, compensations, remunerations, emoluments, and other fixed or determinable annual or periodical gains, profits, and income, if such payment is from sources within the United States, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s1473/1/A/ii","parentIdentifier":"/us/usc/t26/s1473/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F1%2FA%2Fii","sourceRelease":"119-100","text":"any gross proceeds from the sale or other disposition of any property of a type which can produce interest or dividends from sources within the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exception for income connected with United States business","label":"B Exception for income connected with United States business","identifier":"/us/usc/t26/s1473/1/B","parentIdentifier":"/us/usc/t26/s1473/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F1%2FB","sourceRelease":"119-100","text":"Such term shall not include any item of income which is taken into account under section 871(b)(1) or 882(a)(1) for the taxable year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Special rule for sourcing interest paid by foreign branches of domestic financial institutions","label":"C Special rule for sourcing interest paid by foreign branches of domestic financial institutions","identifier":"/us/usc/t26/s1473/1/C","parentIdentifier":"/us/usc/t26/s1473/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F1%2FC","sourceRelease":"119-100","text":"Subparagraph (B) of section 861(a)(1) shall not apply.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Substantial United States owner","label":"2 Substantial United States owner","identifier":"/us/usc/t26/s1473/2","parentIdentifier":"/us/usc/t26/s1473","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t26/s1473/2/A","parentIdentifier":"/us/usc/t26/s1473/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s1473/2/A/i","parentIdentifier":"/us/usc/t26/s1473/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F2%2FA%2Fi","sourceRelease":"119-100","text":"with respect to any corporation, any specified United States person which owns, directly or indirectly, more than 10 percent of the stock of such corporation (by vote or value),","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s1473/2/A/ii","parentIdentifier":"/us/usc/t26/s1473/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F2%2FA%2Fii","sourceRelease":"119-100","text":"with respect to any partnership, any specified United States person which owns, directly or indirectly, more than 10 percent of the profits interests or capital interests in such partnership, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t26/s1473/2/A/iii","parentIdentifier":"/us/usc/t26/s1473/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F2%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t26/s1473/2/A/iii/I","parentIdentifier":"/us/usc/t26/s1473/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F2%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"any specified United States person treated as an owner of any portion of such trust under subpart E of part I of subchapter J of chapter 1, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t26/s1473/2/A/iii/II","parentIdentifier":"/us/usc/t26/s1473/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F2%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"to the extent provided by the Secretary in regulations or other guidance, any specified United States person which holds, directly or indirectly, more than 10 percent of the beneficial interests of such trust.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Special rule for investment vehicles","label":"B Special rule for investment vehicles","identifier":"/us/usc/t26/s1473/2/B","parentIdentifier":"/us/usc/t26/s1473/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F2%2FB","sourceRelease":"119-100","text":"In the case of any financial institution described in section 1471(d)(5)(C), clauses (i), (ii), and (iii) of subparagraph (A) shall be applied by substituting “0 percent” for “10 percent”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Specified United States person","label":"3 Specified United States person","identifier":"/us/usc/t26/s1473/3","parentIdentifier":"/us/usc/t26/s1473","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s1473/3/A","parentIdentifier":"/us/usc/t26/s1473/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F3%2FA","sourceRelease":"119-100","text":"any corporation the stock of which is regularly traded on an established securities market,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s1473/3/B","parentIdentifier":"/us/usc/t26/s1473/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F3%2FB","sourceRelease":"119-100","text":"any corporation which is a member of the same expanded affiliated group (as defined in section 1471(e)(2) without regard to the last sentence thereof) as a corporation the stock of which is regularly traded on an established securities market,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t26/s1473/3/C","parentIdentifier":"/us/usc/t26/s1473/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F3%2FC","sourceRelease":"119-100","text":"any organization exempt from taxation under section 501(a) or an individual retirement plan,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t26/s1473/3/D","parentIdentifier":"/us/usc/t26/s1473/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F3%2FD","sourceRelease":"119-100","text":"the United States or any wholly owned agency or instrumentality thereof,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t26/s1473/3/E","parentIdentifier":"/us/usc/t26/s1473/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F3%2FE","sourceRelease":"119-100","text":"any State, the District of Columbia, any possession of the United States, any political subdivision of any of the foregoing, or any wholly owned agency or instrumentality of any one or more of the foregoing,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t26/s1473/3/F","parentIdentifier":"/us/usc/t26/s1473/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F3%2FF","sourceRelease":"119-100","text":"any bank (as defined in section 581),","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t26/s1473/3/G","parentIdentifier":"/us/usc/t26/s1473/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F3%2FG","sourceRelease":"119-100","text":"any real estate investment trust (as defined in section 856),","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t26/s1473/3/H","parentIdentifier":"/us/usc/t26/s1473/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F3%2FH","sourceRelease":"119-100","text":"any regulated investment company (as defined in section 851),","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t26/s1473/3/I","parentIdentifier":"/us/usc/t26/s1473/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F3%2FI","sourceRelease":"119-100","text":"any common trust fund (as defined in section 584(a)), and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t26/s1473/3/J","parentIdentifier":"/us/usc/t26/s1473/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F3%2FJ","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s1473/3/J/i","parentIdentifier":"/us/usc/t26/s1473/3/J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F3%2FJ%2Fi","sourceRelease":"119-100","text":"is exempt from tax under section 664(c), or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s1473/3/J/ii","parentIdentifier":"/us/usc/t26/s1473/3/J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F3%2FJ%2Fii","sourceRelease":"119-100","text":"is described in section 4947(a)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Withholding agent","label":"4 Withholding agent","identifier":"/us/usc/t26/s1473/4","parentIdentifier":"/us/usc/t26/s1473","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F4","sourceRelease":"119-100","text":"The term “withholding agent” means all persons, in whatever capacity acting, having the control, receipt, custody, disposal, or payment of any withholdable payment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Foreign entity","label":"5 Foreign entity","identifier":"/us/usc/t26/s1473/5","parentIdentifier":"/us/usc/t26/s1473","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1473%2F5","sourceRelease":"119-100","text":"The term “foreign entity” means any entity which is not a United States person.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
