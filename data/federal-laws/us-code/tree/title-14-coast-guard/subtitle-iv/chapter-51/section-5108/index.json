{"type":"section","nativeType":"section","number":"5108","heading":"Unfunded priorities list","label":"5108 Unfunded priorities list","identifier":"/us/usc/t14/s5108","parentIdentifier":"/us/usc/t14/stIV/ch51","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs5108","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t14/s5108/a","parentIdentifier":"/us/usc/t14/s5108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs5108%2Fa","sourceRelease":"119-100","text":"Not later than 60 days after the date on which the President submits to Congress a budget pursuant to , the Commandant shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a list of each unfunded priority for the Coast Guard.section 1105 of title 31","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Prioritization","label":"b .—Prioritization","identifier":"/us/usc/t14/s5108/b","parentIdentifier":"/us/usc/t14/s5108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs5108%2Fb","sourceRelease":"119-100","text":"The list required under subsection (a) shall present the unfunded priorities in order from the highest priority to the lowest, as determined by the Commandant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Unfunded Priority Defined","label":"c .—Unfunded Priority Defined","identifier":"/us/usc/t14/s5108/c","parentIdentifier":"/us/usc/t14/s5108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs5108%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s5108/c/1","parentIdentifier":"/us/usc/t14/s5108/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs5108%2Fc%2F1","sourceRelease":"119-100","text":"has not been selected for funding in the applicable proposed budget;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s5108/c/2","parentIdentifier":"/us/usc/t14/s5108/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs5108%2Fc%2F2","sourceRelease":"119-100","text":"is necessary to fulfill a requirement associated with an operational need; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t14/s5108/c/3","parentIdentifier":"/us/usc/t14/s5108/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs5108%2Fc%2F3","sourceRelease":"119-100","text":"the Commandant would have recommended for inclusion in the applicable proposed budget had additional resources been available or had the requirement emerged before the budget was submitted.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
