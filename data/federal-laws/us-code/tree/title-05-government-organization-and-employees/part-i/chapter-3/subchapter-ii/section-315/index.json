{"type":"section","nativeType":"section","number":"315","heading":"Advisory Committee on Data for Evidence Building","label":"315 Advisory Committee on Data for Evidence Building","identifier":"/us/usc/t5/s315","parentIdentifier":"/us/usc/t5/ptI/ch3/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective 180 days after , see , set out as an Effective Date of 2019 Amendment note under .Jan. 14, 2019section 403 of Pub. L. 115–435section 306 of this title"],"amendments":["Effective DateSection effective 180 days after , see , set out as an Effective Date of 2019 Amendment note under .Jan. 14, 2019section 403 of Pub. L. 115–435section 306 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t5/s315/a","parentIdentifier":"/us/usc/t5/s315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fa","sourceRelease":"119-100","text":"The Director, or the head of an agency designated by the Director, shall establish an Advisory Committee on Data for Evidence Building (in this section referred to as the “Advisory Committee”) to review, analyze, and make recommendations on how to promote the use of Federal data for evidence building.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Membership","label":"b .—Membership","identifier":"/us/usc/t5/s315/b","parentIdentifier":"/us/usc/t5/s315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s315/b/1","parentIdentifier":"/us/usc/t5/s315/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb%2F1","sourceRelease":"119-100","text":"One member who is an agency Chief Information Officer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s315/b/2","parentIdentifier":"/us/usc/t5/s315/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb%2F2","sourceRelease":"119-100","text":"One member who is an agency Chief Privacy Officer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s315/b/3","parentIdentifier":"/us/usc/t5/s315/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb%2F3","sourceRelease":"119-100","text":"One member who is an agency Chief Performance Officer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t5/s315/b/4","parentIdentifier":"/us/usc/t5/s315/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb%2F4","sourceRelease":"119-100","text":"Three members who are agency Chief Data Officers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t5/s315/b/5","parentIdentifier":"/us/usc/t5/s315/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb%2F5","sourceRelease":"119-100","text":"Three members who are agency Evaluation Officers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t5/s315/b/6","parentIdentifier":"/us/usc/t5/s315/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb%2F6","sourceRelease":"119-100","text":"Three members who are members of the Interagency Council for Statistical Policy established under .1section 3504(e)(8) of title 44So in original. Probably should be “Interagency Council on Statistical Policy”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t5/s315/b/7","parentIdentifier":"/us/usc/t5/s315/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s315/b/7/A","parentIdentifier":"/us/usc/t5/s315/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb%2F7%2FA","sourceRelease":"119-100","text":"at least one shall have expertise in transparency policy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s315/b/7/B","parentIdentifier":"/us/usc/t5/s315/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb%2F7%2FB","sourceRelease":"119-100","text":"at least one shall have expertise in privacy policy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s315/b/7/C","parentIdentifier":"/us/usc/t5/s315/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb%2F7%2FC","sourceRelease":"119-100","text":"at least one shall have expertise in statistical data use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t5/s315/b/7/D","parentIdentifier":"/us/usc/t5/s315/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb%2F7%2FD","sourceRelease":"119-100","text":"at least one shall have expertise in information management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t5/s315/b/7/E","parentIdentifier":"/us/usc/t5/s315/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb%2F7%2FE","sourceRelease":"119-100","text":"at least one shall have expertise in information technology; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t5/s315/b/7/F","parentIdentifier":"/us/usc/t5/s315/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fb%2F7%2FF","sourceRelease":"119-100","text":"at least one shall be from the research and evaluation community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Term of Service.—","label":"c Term of Service.—","identifier":"/us/usc/t5/s315/c","parentIdentifier":"/us/usc/t5/s315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t5/s315/c/1","parentIdentifier":"/us/usc/t5/s315/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fc%2F1","sourceRelease":"119-100","text":"Each member of the Advisory Committee shall serve for a term of 2 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Vacancy","label":"2 .—Vacancy","identifier":"/us/usc/t5/s315/c/2","parentIdentifier":"/us/usc/t5/s315/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fc%2F2","sourceRelease":"119-100","text":"Any member appointed to fill a vacancy occurring before the expiration of the term for which the member’s predecessor was appointed shall be appointed only for the remainder of that term. A vacancy in the Commission shall be filled in the manner in which the original appointment was made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Compensation","label":"d .—Compensation","identifier":"/us/usc/t5/s315/d","parentIdentifier":"/us/usc/t5/s315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fd","sourceRelease":"119-100","text":"Members of the Advisory Committee shall serve without compensation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Duties","label":"e .—Duties","identifier":"/us/usc/t5/s315/e","parentIdentifier":"/us/usc/t5/s315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s315/e/1","parentIdentifier":"/us/usc/t5/s315/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fe%2F1","sourceRelease":"119-100","text":"assist the Director in carrying out the duties of the Director under part D of subchapter III of chapter 35 of title 44;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s315/e/2","parentIdentifier":"/us/usc/t5/s315/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fe%2F2","sourceRelease":"119-100","text":"evaluate and provide recommendations to the Director on how to facilitate data sharing, enable data linkage, and develop privacy enhancing techniques; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s315/e/3","parentIdentifier":"/us/usc/t5/s315/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fe%2F3","sourceRelease":"119-100","text":"review the coordination of data sharing or availability for evidence building across all agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Reports","label":"f .—Reports","identifier":"/us/usc/t5/s315/f","parentIdentifier":"/us/usc/t5/s315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Ff","sourceRelease":"119-100","text":"The Advisory Committee shall submit to the Director and make publicly available an annual report on the activities and findings of the Advisory Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":".—Termination","label":"g .—Termination","identifier":"/us/usc/t5/s315/g","parentIdentifier":"/us/usc/t5/s315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs315%2Fg","sourceRelease":"119-100","text":"The Advisory Committee shall terminate not later than two years after the date of the first meeting.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
