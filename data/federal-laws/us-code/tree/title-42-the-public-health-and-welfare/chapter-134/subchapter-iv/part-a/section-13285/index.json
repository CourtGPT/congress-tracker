{"type":"section","nativeType":"section","number":"13285","heading":"Reports to Congress","label":"13285 Reports to Congress","identifier":"/us/usc/t42/s13285","parentIdentifier":"/us/usc/t42/ch134/schIV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13285","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Progress reports","label":"a Progress reports","identifier":"/us/usc/t42/s13285/a","parentIdentifier":"/us/usc/t42/s13285","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13285%2Fa","sourceRelease":"119-100","text":"The Secretary shall report annually to Congress on the progress being made, through demonstration projects supported under this part, to accelerate the development and use of electric motor vehicles.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report on encouraging purchase and use of electric motor vehicles","label":"b Report on encouraging purchase and use of electric motor vehicles","identifier":"/us/usc/t42/s13285/b","parentIdentifier":"/us/usc/t42/s13285","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13285%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13285/b/1","parentIdentifier":"/us/usc/t42/s13285/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13285%2Fb%2F1","sourceRelease":"119-100","text":"address the potential cost of purchasing and maintaining electric motor vehicles, including the initial cost of the batteries and the cost of replacement batteries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13285/b/2","parentIdentifier":"/us/usc/t42/s13285/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13285%2Fb%2F2","sourceRelease":"119-100","text":"identify methods for reducing, subsidizing, or sharing such costs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13285/b/3","parentIdentifier":"/us/usc/t42/s13285/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13285%2Fb%2F3","sourceRelease":"119-100","text":"include recommendations for legislative and administrative measures to encourage the purchase and use of electric motor vehicles.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
