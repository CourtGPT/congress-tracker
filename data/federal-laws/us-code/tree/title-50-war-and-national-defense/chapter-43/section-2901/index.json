{"type":"section","nativeType":"section","number":"2901","heading":"Findings","label":"2901 Findings","identifier":"/us/usc/t50/s2901","parentIdentifier":"/us/usc/t50/ch43","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2901","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Strengthen “counter-proliferation” efforts","label":"1 Strengthen “counter-proliferation” efforts","identifier":"/us/usc/t50/s2901/1","parentIdentifier":"/us/usc/t50/s2901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2901%2F1","sourceRelease":"119-100","text":"The United States should work with the international community to develop laws and an international legal regime with universal jurisdiction to enable any state in the world to capture, interdict, and prosecute smugglers of nuclear material.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Expand the Proliferation Security Initiative","label":"2 Expand the Proliferation Security Initiative","identifier":"/us/usc/t50/s2901/2","parentIdentifier":"/us/usc/t50/s2901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2901%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s2901/2/A","parentIdentifier":"/us/usc/t50/s2901/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2901%2F2%2FA","sourceRelease":"119-100","text":"use intelligence and planning resources of the North Atlantic Treaty Organization (NATO) alliance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s2901/2/B","parentIdentifier":"/us/usc/t50/s2901/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2901%2F2%2FB","sourceRelease":"119-100","text":"make participation open to non-NATO countries; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t50/s2901/2/C","parentIdentifier":"/us/usc/t50/s2901/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2901%2F2%2FC","sourceRelease":"119-100","text":"encourage Russia and the People’s Republic of China to participate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Support the Cooperative Threat Reduction program","label":"3 Support the Cooperative Threat Reduction program","identifier":"/us/usc/t50/s2901/3","parentIdentifier":"/us/usc/t50/s2901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2901%2F3","sourceRelease":"119-100","text":"The United States should expand, improve, increase resources for, and otherwise fully support the Cooperative Threat Reduction program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
