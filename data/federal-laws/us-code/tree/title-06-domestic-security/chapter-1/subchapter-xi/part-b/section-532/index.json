{"type":"section","nativeType":"section","number":"532","heading":"Explosives Training and Research Facility","label":"532 Explosives Training and Research Facility","identifier":"/us/usc/t6/s532","parentIdentifier":"/us/usc/t6/ch1/schXI/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs532","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t6/s532/a","parentIdentifier":"/us/usc/t6/s532","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs532%2Fa","sourceRelease":"119-100","text":"There is established within the Bureau an Explosives Training and Research Facility at Fort AP Hill, Fredericksburg, Virginia.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purpose","label":"b Purpose","identifier":"/us/usc/t6/s532/b","parentIdentifier":"/us/usc/t6/s532","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs532%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s532/b/1","parentIdentifier":"/us/usc/t6/s532/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs532%2Fb%2F1","sourceRelease":"119-100","text":"investigate bombings and explosions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s532/b/2","parentIdentifier":"/us/usc/t6/s532/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs532%2Fb%2F2","sourceRelease":"119-100","text":"properly handle, utilize, and dispose of explosive materials and devices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s532/b/3","parentIdentifier":"/us/usc/t6/s532/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs532%2Fb%2F3","sourceRelease":"119-100","text":"train canines on explosive detection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s532/b/4","parentIdentifier":"/us/usc/t6/s532/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs532%2Fb%2F4","sourceRelease":"119-100","text":"conduct research on explosives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t6/s532/c","parentIdentifier":"/us/usc/t6/s532","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs532%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s532/c/1","parentIdentifier":"/us/usc/t6/s532/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs532%2Fc%2F1","sourceRelease":"119-100","text":"There are authorized to be appropriated such sums as may be necessary to establish and maintain the facility established under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Availability of funds","label":"2 Availability of funds","identifier":"/us/usc/t6/s532/c/2","parentIdentifier":"/us/usc/t6/s532/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs532%2Fc%2F2","sourceRelease":"119-100","text":"Any amounts appropriated pursuant to paragraph (1) shall remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
