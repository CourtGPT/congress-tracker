al base;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6104/a/2","parentIdentifier":"/us/usc/t10/s6104/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fa%2F2","sourceRelease":"119-100","text":"tracking of industrial base issues over time; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s6104/a/3","parentIdentifier":"/us/usc/t10/s6104/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fa%2F3","sourceRelease":"119-100","text":"proactively identifying gaps or risks in specific areas relating to the industrial base.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Provision of Resources","label":"b .—Provision of Resources","identifier":"/us/usc/t10/s6104/b","parentIdentifier":"/us/usc/t10/s6104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fb","sourceRelease":"119-100","text":"The Administrator shall ensure that the official designated under subsection (a) is provided with resources sufficient to conduct the monitoring required by that subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Consultations","label":"c .—Consultations","identifier":"/us/usc/t10/s6104/c","parentIdentifier":"/us/usc/t10/s6104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6104/c/1","parentIdentifier":"/us/usc/t10/s6104/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fc%2F1","sourceRelease":"119-100","text":"officials of the Department of Defense who are members of the Nuclear Weapons Council established under section 179;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6104/c/2","parentIdentifier":"/us/usc/t10/s6104/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fc%2F2","sourceRelease":"119-100","text":"officials of the Department of Defense responsible for the defense industrial base; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s6104/c/3","parentIdentifier":"/us/usc/t10/s6104/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fc%2F3","sourceRelease":"119-100","text":"other components of the Department of Energy that rely on similar components, subsystems, or materials.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Briefings","label":"d .—Briefings","identifier":"/us/usc/t10/s6104/d","parentIdentifier":"/us/usc/t10/s6104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6104/d/1","parentIdentifier":"/us/usc/t10/s6104/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s6104/d/1/A","parentIdentifier":"/us/usc/t10/s6104/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the responsibilities assigned to that official; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s6104/d/1/B","parentIdentifier":"/us/usc/t10/s6104/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fd%2F1%2FB","sourceRelease":"119-100","text":"the plan for providing that official with resources sufficient to conduct the monitoring required by subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6104/d/2","parentIdentifier":"/us/usc/t10/s6104/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fd%2F2","sourceRelease":"119-100","text":"Not later than , and annually thereafter through 2024, the Administrator shall provide to the Committees on Armed Services of the Senate and the House of Representatives a briefing on activities carried out under this section that includes an assessment of the progress made by the official designated under subsection (a) in conducting the monitoring required by that subsection.April 1, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Reports","label":"e .—Reports","identifier":"/us/usc/t10/s6104/e","parentIdentifier":"/us/usc/t10/s6104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6104/e/1","parentIdentifier":"/us/usc/t10/s6104/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fe%2F1","sourceRelease":"119-100","text":"identifying actual or potential risks to or specific gaps in any element of the industrial base that supports the nuclear weapons components, subsystems, or materials of the Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6104/e/2","parentIdentifier":"/us/usc/t10/s6104/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fe%2F2","sourceRelease":"119-100","text":"describing the actions the Administration is taking to further assess, characterize, and prioritize such risks and gaps;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s6104/e/3","parentIdentifier":"/us/usc/t10/s6104/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fe%2F3","sourceRelease":"119-100","text":"describing mitigating actions, if any, the Administration has underway or planned to mitigate any such risks or gaps;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s6104/e/4","parentIdentifier":"/us/usc/t10/s6104/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fe%2F4","sourceRelease":"119-100","text":"setting forth the anticipated timelines and resources needed for such mitigating actions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s6104/e/5","parentIdentifier":"/us/usc/t10/s6104/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6104%2Fe%2F5","sourceRelease":"119-100","text":"describing the nature of any coordination with or burden sharing by other departments or agencies of the Federal Government or the private sector to address such risks and gaps.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
