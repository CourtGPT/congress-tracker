{"type":"section","nativeType":"section","number":"9807","heading":"Biennial reports and congressional consultation","label":"9807 Biennial reports and congressional consultation","identifier":"/us/usc/t22/s9807","parentIdentifier":"/us/usc/t22/ch105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9807","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Biennial reports","label":"a Biennial reports","identifier":"/us/usc/t22/s9807/a","parentIdentifier":"/us/usc/t22/s9807","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9807%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9807/a/1","parentIdentifier":"/us/usc/t22/s9807/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9807%2Fa%2F1","sourceRelease":"119-100","text":"Descriptions of steps taken to incorporate the strategy into any relevant, existing country and regional plans or strategies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9807/a/2","parentIdentifier":"/us/usc/t22/s9807/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9807%2Fa%2F2","sourceRelease":"119-100","text":"Accountings of all funding received and obligated to implement each such country and regional plan during the previous two years, and, to the extent feasible, projections of funding to be requested, planned, and implemented for the following two years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s9807/a/3","parentIdentifier":"/us/usc/t22/s9807/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9807%2Fa%2F3","sourceRelease":"119-100","text":"Descriptions of progress made towards achieving specific targets, metrics, and indicators for each priority country and region.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s9807/a/4","parentIdentifier":"/us/usc/t22/s9807/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9807%2Fa%2F4","sourceRelease":"119-100","text":"Descriptions of any changes made to programs based on the results of assessment, monitoring, and evaluation for each priority country and region.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Congressional consultation","label":"b Congressional consultation","identifier":"/us/usc/t22/s9807/b","parentIdentifier":"/us/usc/t22/s9807","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9807%2Fb","sourceRelease":"119-100","text":"The Secretary of State, the Administrator of the United States Agency for International Development, and the Secretary of Defense shall provide to any appropriate congressional committee briefings on the implementation of this chapter upon the request of any such committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
