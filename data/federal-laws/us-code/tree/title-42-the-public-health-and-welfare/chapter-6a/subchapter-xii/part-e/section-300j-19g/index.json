{"type":"section","nativeType":"section","number":"300j–19g","heading":"Midsize and Large Drinking Water System Infrastructure Resilience and Sustainability Program","label":"300j–19g Midsize and Large Drinking Water System Infrastructure Resilience and Sustainability Program","identifier":"/us/usc/t42/s300j–19g","parentIdentifier":"/us/usc/t42/ch6A/schXII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s300j–19g/a","parentIdentifier":"/us/usc/t42/s300j–19g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible entity","label":"1 Eligible entity","identifier":"/us/usc/t42/s300j–19g/a/1","parentIdentifier":"/us/usc/t42/s300j–19g/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fa%2F1","sourceRelease":"119-100","text":"The term “eligible entity” means a public water system that serves a community with a population of 10,000 or more.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Natural hazard; resilience","label":"2 Natural hazard; resilience","identifier":"/us/usc/t42/s300j–19g/a/2","parentIdentifier":"/us/usc/t42/s300j–19g/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fa%2F2","sourceRelease":"119-100","text":"The terms “resilience” and “natural hazard” have the meanings given those terms in .section 300i–2(h) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Resilience and sustainability program","label":"3 Resilience and sustainability program","identifier":"/us/usc/t42/s300j–19g/a/3","parentIdentifier":"/us/usc/t42/s300j–19g/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fa%2F3","sourceRelease":"119-100","text":"The term “resilience and sustainability program” means the Midsize and Large Drinking Water System Infrastructure Resilience and Sustainability Program established under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t42/s300j–19g/b","parentIdentifier":"/us/usc/t42/s300j–19g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300j–19g/b/1","parentIdentifier":"/us/usc/t42/s300j–19g/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fb%2F1","sourceRelease":"119-100","text":"increasing resilience to natural hazards and extreme weather events; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300j–19g/b/2","parentIdentifier":"/us/usc/t42/s300j–19g/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fb%2F2","sourceRelease":"119-100","text":"reducing cybersecurity vulnerabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Use of funds","label":"c Use of funds","identifier":"/us/usc/t42/s300j–19g/c","parentIdentifier":"/us/usc/t42/s300j–19g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300j–19g/c/1","parentIdentifier":"/us/usc/t42/s300j–19g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fc%2F1","sourceRelease":"119-100","text":"the conservation of water or the enhancement of water-use efficiency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300j–19g/c/2","parentIdentifier":"/us/usc/t42/s300j–19g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fc%2F2","sourceRelease":"119-100","text":"the modification or relocation of existing drinking water system infrastructure made, or that is at risk of being, significantly impaired by natural hazards or extreme weather events, including risks to drinking water from flooding;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300j–19g/c/3","parentIdentifier":"/us/usc/t42/s300j–19g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fc%2F3","sourceRelease":"119-100","text":"the design or construction of new or modified desalination facilities to serve existing communities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s300j–19g/c/4","parentIdentifier":"/us/usc/t42/s300j–19g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fc%2F4","sourceRelease":"119-100","text":"the enhancement of water supply through the use of watershed management and source water protection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s300j–19g/c/5","parentIdentifier":"/us/usc/t42/s300j–19g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fc%2F5","sourceRelease":"119-100","text":"the enhancement of energy efficiency or the use and generation of renewable energy in the conveyance or treatment of drinking water;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s300j–19g/c/6","parentIdentifier":"/us/usc/t42/s300j–19g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fc%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–19g/c/6/A","parentIdentifier":"/us/usc/t42/s300j–19g/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fc%2F6%2FA","sourceRelease":"119-100","text":"to increase the resilience of the eligible entity to natural hazards and extreme weather events; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–19g/c/6/B","parentIdentifier":"/us/usc/t42/s300j–19g/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fc%2F6%2FB","sourceRelease":"119-100","text":"to reduce cybersecurity vulnerabilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s300j–19g/c/7","parentIdentifier":"/us/usc/t42/s300j–19g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fc%2F7","sourceRelease":"119-100","text":"the conservation of water or the enhancement of a water supply through the implementation of water reuse measures; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s300j–19g/c/8","parentIdentifier":"/us/usc/t42/s300j–19g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fc%2F8","sourceRelease":"119-100","text":"the formation of regional water partnerships to collaboratively address documented water shortages.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Application","label":"d Application","identifier":"/us/usc/t42/s300j–19g/d","parentIdentifier":"/us/usc/t42/s300j–19g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300j–19g/d/1","parentIdentifier":"/us/usc/t42/s300j–19g/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fd%2F1","sourceRelease":"119-100","text":"a proposal of the program or project to be planned, designed, constructed, implemented, operated, or maintained by the eligible entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300j–19g/d/2","parentIdentifier":"/us/usc/t42/s300j–19g/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fd%2F2","sourceRelease":"119-100","text":"an identification of the natural hazard risks, extreme weather events, or potential cybersecurity vulnerabilities, as applicable, to be addressed by the proposed program or project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300j–19g/d/3","parentIdentifier":"/us/usc/t42/s300j–19g/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fd%2F3","sourceRelease":"119-100","text":"documentation prepared by a Federal, State, regional, or local government agency of the natural hazard risk, potential cybersecurity vulnerability, or risk for extreme weather events to the area where the proposed program or project is to be located;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s300j–19g/d/4","parentIdentifier":"/us/usc/t42/s300j–19g/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fd%2F4","sourceRelease":"119-100","text":"a description of any recent natural hazards, cybersecurity events, or extreme weather events that have affected the community water system of the eligible entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s300j–19g/d/5","parentIdentifier":"/us/usc/t42/s300j–19g/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fd%2F5","sourceRelease":"119-100","text":"a description of how the proposed program or project would improve the performance of the community water system of the eligible entity under the anticipated natural hazards, cybersecurity vulnerabilities, or extreme weather events; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s300j–19g/d/6","parentIdentifier":"/us/usc/t42/s300j–19g/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fd%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–19g/d/6/A","parentIdentifier":"/us/usc/t42/s300j–19g/d/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fd%2F6%2FA","sourceRelease":"119-100","text":"to enhance the resilience of the community water system of the eligible entity to the anticipated natural hazards or extreme weather events; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–19g/d/6/B","parentIdentifier":"/us/usc/t42/s300j–19g/d/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fd%2F6%2FB","sourceRelease":"119-100","text":"to reduce cybersecurity vulnerabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Report","label":"e Report","identifier":"/us/usc/t42/s300j–19g/e","parentIdentifier":"/us/usc/t42/s300j–19g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Fe","sourceRelease":"119-100","text":"Not later than 2 years after , the Administrator shall submit to Congress a report that describes the implementation of the resilience and sustainability program, which shall include a description of the use and deployment of amounts made available to carry out the resilience and sustainability program.November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorization of appropriations","label":"f Authorization of appropriations","identifier":"/us/usc/t42/s300j–19g/f","parentIdentifier":"/us/usc/t42/s300j–19g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s300j–19g/f/1","parentIdentifier":"/us/usc/t42/s300j–19g/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Ff%2F1","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out the resilience and sustainability program $50,000,000 for each of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Use of funds","label":"2 Use of funds","identifier":"/us/usc/t42/s300j–19g/f/2","parentIdentifier":"/us/usc/t42/s300j–19g/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–19g/f/2/A","parentIdentifier":"/us/usc/t42/s300j–19g/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Ff%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300j–19g/f/2/A/i","parentIdentifier":"/us/usc/t42/s300j–19g/f/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Ff%2F2%2FA%2Fi","sourceRelease":"119-100","text":"equal to or greater than 10,000; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300j–19g/f/2/A/ii","parentIdentifier":"/us/usc/t42/s300j–19g/f/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Ff%2F2%2FA%2Fii","sourceRelease":"119-100","text":"fewer than 100,000; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–19g/f/2/B","parentIdentifier":"/us/usc/t42/s300j–19g/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Ff%2F2%2FB","sourceRelease":"119-100","text":"50 percent shall be used to provide grants to eligible entities that serve a population equal to or greater than 100,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Administrative costs","label":"3 Administrative costs","identifier":"/us/usc/t42/s300j–19g/f/3","parentIdentifier":"/us/usc/t42/s300j–19g/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319g%2Ff%2F3","sourceRelease":"119-100","text":"Of the amounts made available under paragraph (1), not more than 2 percent may be used by the Administrator for the administrative costs of carrying out the resilience and sustainability program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
