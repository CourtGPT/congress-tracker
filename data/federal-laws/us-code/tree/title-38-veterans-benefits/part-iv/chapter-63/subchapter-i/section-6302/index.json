{"type":"section","nativeType":"section","number":"6302","heading":"Biennial plan","label":"6302 Biennial plan","identifier":"/us/usc/t38/s6302","parentIdentifier":"/us/usc/t38/ptIV/ch63/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs6302","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Biennial Plan Required","label":"a .—Biennial Plan Required","identifier":"/us/usc/t38/s6302/a","parentIdentifier":"/us/usc/t38/s6302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs6302%2Fa","sourceRelease":"119-100","text":"The Secretary shall, during the first nine months of every odd-numbered year, prepare a biennial plan for the outreach activities of the Department for the two-fiscal-year period beginning on October 1 of that year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Elements","label":"b .—Elements","identifier":"/us/usc/t38/s6302/b","parentIdentifier":"/us/usc/t38/s6302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs6302%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s6302/b/1","parentIdentifier":"/us/usc/t38/s6302/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs6302%2Fb%2F1","sourceRelease":"119-100","text":"Plans for efforts to identify eligible veterans and eligible dependents who are not enrolled or registered with the Department for benefits or services under the programs administered by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s6302/b/2","parentIdentifier":"/us/usc/t38/s6302/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs6302%2Fb%2F2","sourceRelease":"119-100","text":"Plans for informing eligible veterans and eligible dependents of modifications of the benefits and services under the programs administered by the Secretary, including eligibility for medical and nursing care and services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Coordination in Development","label":"c .—Coordination in Development","identifier":"/us/usc/t38/s6302/c","parentIdentifier":"/us/usc/t38/s6302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs6302%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s6302/c/1","parentIdentifier":"/us/usc/t38/s6302/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs6302%2Fc%2F1","sourceRelease":"119-100","text":"Directors or other appropriate officials of organizations approved by the Secretary under .section 5902 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s6302/c/2","parentIdentifier":"/us/usc/t38/s6302/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs6302%2Fc%2F2","sourceRelease":"119-100","text":"Directors or other appropriate officials of State and local education and training programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s6302/c/3","parentIdentifier":"/us/usc/t38/s6302/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs6302%2Fc%2F3","sourceRelease":"119-100","text":"Representatives of nongovernmental organizations that carry out veterans outreach programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s6302/c/4","parentIdentifier":"/us/usc/t38/s6302/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs6302%2Fc%2F4","sourceRelease":"119-100","text":"Representatives of State and local veterans employment organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t38/s6302/c/5","parentIdentifier":"/us/usc/t38/s6302/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs6302%2Fc%2F5","sourceRelease":"119-100","text":"Other individuals and organizations that the Secretary considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
