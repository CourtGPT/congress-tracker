{"type":"section","nativeType":"section","number":"718q","heading":"State application","label":"718q State application","identifier":"/us/usc/t16/s718q","parentIdentifier":"/us/usc/t16/ch7/schIV–A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Approval of application required","label":"a Approval of application required","identifier":"/us/usc/t16/s718q/a","parentIdentifier":"/us/usc/t16/s718q","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q%2Fa","sourceRelease":"119-100","text":"The Secretary may not authorize a State to issue electronic stamps under this subchapter unless the Secretary has received and approved an application submitted by the State in accordance with this section. The Secretary may determine the number of new States per year to participate in the electronic stamp program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Contents of application","label":"b Contents of application","identifier":"/us/usc/t16/s718q/b","parentIdentifier":"/us/usc/t16/s718q","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s718q/b/1","parentIdentifier":"/us/usc/t16/s718q/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q%2Fb%2F1","sourceRelease":"119-100","text":"a description of the format of the electronic stamp that the State will issue under this subchapter, including identifying features of the licensee that will be specified on the stamp;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s718q/b/2","parentIdentifier":"/us/usc/t16/s718q/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q%2Fb%2F2","sourceRelease":"119-100","text":"a description of any fee the State will charge for issuance of an electronic stamp;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s718q/b/3","parentIdentifier":"/us/usc/t16/s718q/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q%2Fb%2F3","sourceRelease":"119-100","text":"a description of the process the State will use to account for and transfer to the Secretary the amounts collected by the State that are required to be transferred to the Secretary under the program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s718q/b/4","parentIdentifier":"/us/usc/t16/s718q/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q%2Fb%2F4","sourceRelease":"119-100","text":"the manner by which the State will transmit electronic stamp customer data to the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s718q/b/5","parentIdentifier":"/us/usc/t16/s718q/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q%2Fb%2F5","sourceRelease":"119-100","text":"the manner by which actual stamps will be delivered;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s718q/b/6","parentIdentifier":"/us/usc/t16/s718q/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q%2Fb%2F6","sourceRelease":"119-100","text":"the policies and procedures under which the State will issue duplicate electronic stamps; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t16/s718q/b/7","parentIdentifier":"/us/usc/t16/s718q/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q%2Fb%2F7","sourceRelease":"119-100","text":"such other policies, procedures, and information as may be reasonably required by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Publication of deadlines, eligibility requirements, and selection criteria","label":"c Publication of deadlines, eligibility requirements, and selection criteria","identifier":"/us/usc/t16/s718q/c","parentIdentifier":"/us/usc/t16/s718q","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s718q/c/1","parentIdentifier":"/us/usc/t16/s718q/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q%2Fc%2F1","sourceRelease":"119-100","text":"deadlines for submission of applications;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s718q/c/2","parentIdentifier":"/us/usc/t16/s718q/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q%2Fc%2F2","sourceRelease":"119-100","text":"eligibility requirements for submitting applications; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s718q/c/3","parentIdentifier":"/us/usc/t16/s718q/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs718q%2Fc%2F3","sourceRelease":"119-100","text":"criteria for approving applications.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
