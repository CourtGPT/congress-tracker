{"type":"section","nativeType":"section","number":"4146","heading":"Definitions","label":"4146 Definitions","identifier":"/us/usc/t12/s4146","parentIdentifier":"/us/usc/t12/ch42/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4146","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4146/1","parentIdentifier":"/us/usc/t12/s4146","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4146%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s4146/1/A","parentIdentifier":"/us/usc/t12/s4146/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4146%2F1%2FA","sourceRelease":"119-100","text":"has been classified by the Internal Revenue Service as an exempt organization under ;section 501(c)(3) of title 26","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s4146/1/B","parentIdentifier":"/us/usc/t12/s4146/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4146%2F1%2FB","sourceRelease":"119-100","text":"has been in existence for at least 2 years prior to the date of the grant application;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s4146/1/C","parentIdentifier":"/us/usc/t12/s4146/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4146%2F1%2FC","sourceRelease":"119-100","text":"has a record of service to low- and moderate-income people in the community in which the project is located;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t12/s4146/1/D","parentIdentifier":"/us/usc/t12/s4146/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4146%2F1%2FD","sourceRelease":"119-100","text":"is organized at the neighborhood, city, county or multi-county level; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t12/s4146/1/E","parentIdentifier":"/us/usc/t12/s4146/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4146%2F1%2FE","sourceRelease":"119-100","text":"in the case of a corporation acquiring eligible housing under subchapter I of this chapter, agrees to form a purchaser entity that conforms to the definition of a community-based nonprofit organization under such subchapter and agrees to use its best efforts to secure majority tenant consent to the acquisition of the project for which grant assistance is requested; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4146/2","parentIdentifier":"/us/usc/t12/s4146","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4146%2F2","sourceRelease":"119-100","text":"the terms “eligible low-income housing”, “nonprofit organization”, “owner”, and “resident council” have the meanings given such terms in .section 4119 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
