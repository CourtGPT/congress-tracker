{"type":"section","nativeType":"section","number":"1132–6","heading":"Science and technology advanced foreign language education grant program","label":"1132–6 Science and technology advanced foreign language education grant program","identifier":"/us/usc/t20/s1132–6","parentIdentifier":"/us/usc/t20/ch28/schVI/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purpose","label":"a Purpose","identifier":"/us/usc/t20/s1132–6/a","parentIdentifier":"/us/usc/t20/s1132–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1132–6/a/1","parentIdentifier":"/us/usc/t20/s1132–6/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1132–6/a/1/A","parentIdentifier":"/us/usc/t20/s1132–6/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fa%2F1%2FA","sourceRelease":"119-100","text":"an understanding of science and technology; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1132–6/a/1/B","parentIdentifier":"/us/usc/t20/s1132–6/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fa%2F1%2FB","sourceRelease":"119-100","text":"foreign language proficiency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1132–6/a/2","parentIdentifier":"/us/usc/t20/s1132–6/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fa%2F2","sourceRelease":"119-100","text":"foster future international scientific collaboration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s1132–6/a/3","parentIdentifier":"/us/usc/t20/s1132–6/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fa%2F3","sourceRelease":"119-100","text":"provide for professional development opportunities for elementary school and secondary school teachers of critical foreign languages to increase the number of highly qualified teachers in critical foreign languages; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s1132–6/a/4","parentIdentifier":"/us/usc/t20/s1132–6/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fa%2F4","sourceRelease":"119-100","text":"increase the number of United States students who achieve the highest level of proficiency in foreign languages critical to the security and competitiveness of the Nation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Development","label":"b Development","identifier":"/us/usc/t20/s1132–6/b","parentIdentifier":"/us/usc/t20/s1132–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fb","sourceRelease":"119-100","text":"The Secretary shall develop a program for the awarding of grants to institutions of higher education that develop innovative programs for the teaching of foreign languages, which may include the preparation of teachers to teach foreign languages.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Regulations and requirements","label":"c Regulations and requirements","identifier":"/us/usc/t20/s1132–6/c","parentIdentifier":"/us/usc/t20/s1132–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1132–6/c/1","parentIdentifier":"/us/usc/t20/s1132–6/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fc%2F1","sourceRelease":"119-100","text":"the development of an on-campus cultural awareness program by which students attend classes taught in a foreign language and study the science and technology developments and practices in a non-English speaking country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1132–6/c/2","parentIdentifier":"/us/usc/t20/s1132–6/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fc%2F2","sourceRelease":"119-100","text":"immersion programs where students take science or technology related course work in a non-English speaking country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s1132–6/c/3","parentIdentifier":"/us/usc/t20/s1132–6/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fc%2F3","sourceRelease":"119-100","text":"other programs, such as summer workshops, that emphasize the intense study of a foreign language and science technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s1132–6/c/4","parentIdentifier":"/us/usc/t20/s1132–6/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fc%2F4","sourceRelease":"119-100","text":"if applicable, recruiting highly qualified teachers in critical foreign languages, and providing professional development activities for such teachers at the elementary school and secondary school levels; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t20/s1132–6/c/5","parentIdentifier":"/us/usc/t20/s1132–6/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fc%2F5","sourceRelease":"119-100","text":"providing innovative opportunities for students that will allow for critical language learning, such as immersion environments, intensive study opportunities, internships, and distance learning.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Grant distribution","label":"d Grant distribution","identifier":"/us/usc/t20/s1132–6/d","parentIdentifier":"/us/usc/t20/s1132–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1132–6/d/1","parentIdentifier":"/us/usc/t20/s1132–6/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fd%2F1","sourceRelease":"119-100","text":"institutions that have programs focusing on curricula that combine the study of foreign languages and the study of science and technology and produce graduates who have both skills; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1132–6/d/2","parentIdentifier":"/us/usc/t20/s1132–6/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fd%2F2","sourceRelease":"119-100","text":"institutions teaching critical foreign languages.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Report on best practices","label":"e Report on best practices","identifier":"/us/usc/t20/s1132–6/e","parentIdentifier":"/us/usc/t20/s1132–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1132–6/e/1","parentIdentifier":"/us/usc/t20/s1132–6/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fe%2F1","sourceRelease":"119-100","text":"conduct a study to identify the best practices to strengthen the role of institutions of higher education that receive funding under subchapter III or subchapter V in increasing the critical foreign language education efforts in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1132–6/e/2","parentIdentifier":"/us/usc/t20/s1132–6/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Fe%2F2","sourceRelease":"119-100","text":"submit a report on the results of such study to the authorizing committees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Appropriations authorized","label":"f Appropriations authorized","identifier":"/us/usc/t20/s1132–6/f","parentIdentifier":"/us/usc/t20/s1132–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1132%E2%80%936%2Ff","sourceRelease":"119-100","text":"There are authorized to be appropriated to carry out this section, such sums as may be necessary for fiscal year 2009 and for each subsequent fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
