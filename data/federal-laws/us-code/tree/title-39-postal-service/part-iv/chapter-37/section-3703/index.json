{"type":"section","nativeType":"section","number":"3703","heading":"Postal Service program for State governments","label":"3703 Postal Service program for State governments","identifier":"/us/usc/t39/s3703","parentIdentifier":"/us/usc/t39/ptIV/ch37","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t39/s3703/a","parentIdentifier":"/us/usc/t39/s3703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t39/s3703/a/1","parentIdentifier":"/us/usc/t39/s3703/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t39/s3703/a/1/A","parentIdentifier":"/us/usc/t39/s3703/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fa%2F1%2FA","sourceRelease":"119-100","text":"provide enhanced value to the public, such as by lowering the cost or raising the quality of such services or by making such services more accessible;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t39/s3703/a/1/B","parentIdentifier":"/us/usc/t39/s3703/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t39/s3703/a/1/B/i","parentIdentifier":"/us/usc/t39/s3703/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"harming the cost and efficiency of postal services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t39/s3703/a/1/B/ii","parentIdentifier":"/us/usc/t39/s3703/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"unreasonably restricting access to postal retail service, such as customer waiting time and access to parking; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t39/s3703/a/2","parentIdentifier":"/us/usc/t39/s3703/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fa%2F2","sourceRelease":"119-100","text":"such agreements provide a net contribution to the Postal Service, defined as reimbursement that covers at least 100 percent of the costs attributable to all property and nonpostal services provided under each relevant agreement in each year, except that agreements determined to be substantially similar by the Postal Service with the concurrence of the Postal Regulatory Commission shall be reviewed based on their collective revenue and costs attributable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Public Notice","label":"b .—Public Notice","identifier":"/us/usc/t39/s3703/b","parentIdentifier":"/us/usc/t39/s3703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t39/s3703/b/1","parentIdentifier":"/us/usc/t39/s3703/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fb%2F1","sourceRelease":"119-100","text":"the agreement with the agency regarding such service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t39/s3703/b/2","parentIdentifier":"/us/usc/t39/s3703/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fb%2F2","sourceRelease":"119-100","text":"a business plan that describes the specific property or nonpostal service to be provided, the enhanced value to the public, and terms of reimbursement to the Postal Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Approval Required","label":"c .—Approval Required","identifier":"/us/usc/t39/s3703/c","parentIdentifier":"/us/usc/t39/s3703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fc","sourceRelease":"119-100","text":"The Postal Service may not establish the program under subsection (a) unless the Governors of the Postal Service approve such program by a recorded vote that is publicly disclosed on the Postal Service website with a majority of the Governors then in office voting for approval.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Confidential Information","label":"d .—Confidential Information","identifier":"/us/usc/t39/s3703/d","parentIdentifier":"/us/usc/t39/s3703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t39/s3703/d/1","parentIdentifier":"/us/usc/t39/s3703/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fd%2F1","sourceRelease":"119-100","text":"described in section 410(c); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t39/s3703/d/2","parentIdentifier":"/us/usc/t39/s3703/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3703%2Fd%2F2","sourceRelease":"119-100","text":"exempt from public disclosure under .section 552(b) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
