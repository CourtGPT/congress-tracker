{"type":"section","nativeType":"section","number":"1667","heading":"Findings and purpose","label":"1667 Findings and purpose","identifier":"/us/usc/t25/s1667","parentIdentifier":"/us/usc/t25/ch18/schV–A/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Codificationis based on section 181 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by .Section 721 of Pub. L. 94–437section 10221(a) of Pub. L. 111–148"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Findings","label":"a Findings","identifier":"/us/usc/t25/s1667/a","parentIdentifier":"/us/usc/t25/s1667","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s1667/a/1","parentIdentifier":"/us/usc/t25/s1667/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1667/a/1/A","parentIdentifier":"/us/usc/t25/s1667/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the rate of suicide of American Indians and Alaska Natives is 1.9 times higher than the national average rate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1667/a/1/B","parentIdentifier":"/us/usc/t25/s1667/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s1667/a/1/B/i","parentIdentifier":"/us/usc/t25/s1667/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"3.5 times the national average rate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s1667/a/1/B/ii","parentIdentifier":"/us/usc/t25/s1667/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the highest rate of any population group in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s1667/a/2","parentIdentifier":"/us/usc/t25/s1667/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1667/a/2/A","parentIdentifier":"/us/usc/t25/s1667/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F2%2FA","sourceRelease":"119-100","text":"history of previous suicide attempts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1667/a/2/B","parentIdentifier":"/us/usc/t25/s1667/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F2%2FB","sourceRelease":"119-100","text":"family history of suicide;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1667/a/2/C","parentIdentifier":"/us/usc/t25/s1667/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F2%2FC","sourceRelease":"119-100","text":"history of depression or other mental illness;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s1667/a/2/D","parentIdentifier":"/us/usc/t25/s1667/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F2%2FD","sourceRelease":"119-100","text":"alcohol or drug abuse;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t25/s1667/a/2/E","parentIdentifier":"/us/usc/t25/s1667/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F2%2FE","sourceRelease":"119-100","text":"health disparities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t25/s1667/a/2/F","parentIdentifier":"/us/usc/t25/s1667/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F2%2FF","sourceRelease":"119-100","text":"stressful life events and losses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t25/s1667/a/2/G","parentIdentifier":"/us/usc/t25/s1667/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F2%2FG","sourceRelease":"119-100","text":"easy access to lethal methods;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t25/s1667/a/2/H","parentIdentifier":"/us/usc/t25/s1667/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F2%2FH","sourceRelease":"119-100","text":"exposure to the suicidal behavior of others;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t25/s1667/a/2/I","parentIdentifier":"/us/usc/t25/s1667/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F2%2FI","sourceRelease":"119-100","text":"isolation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t25/s1667/a/2/J","parentIdentifier":"/us/usc/t25/s1667/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F2%2FJ","sourceRelease":"119-100","text":"incarceration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s1667/a/3","parentIdentifier":"/us/usc/t25/s1667/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F3","sourceRelease":"119-100","text":"according to national data for 2005, suicide was the second-leading cause of death for Indians and Alaska Natives of both sexes aged 10 through 34;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s1667/a/4","parentIdentifier":"/us/usc/t25/s1667/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1667/a/4/A","parentIdentifier":"/us/usc/t25/s1667/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s1667/a/4/A/i","parentIdentifier":"/us/usc/t25/s1667/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F4%2FA%2Fi","sourceRelease":"119-100","text":"as compared to suicide rates of males of any other racial group, up to 4 times greater; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s1667/a/4/A/ii","parentIdentifier":"/us/usc/t25/s1667/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F4%2FA%2Fii","sourceRelease":"119-100","text":"as compared to suicide rates of females of any other racial group, up to 11 times greater; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1667/a/4/B","parentIdentifier":"/us/usc/t25/s1667/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F4%2FB","sourceRelease":"119-100","text":"data demonstrates that, over their lifetimes, females attempt suicide 2 to 3 times more often than males;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s1667/a/5","parentIdentifier":"/us/usc/t25/s1667/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1667/a/5/A","parentIdentifier":"/us/usc/t25/s1667/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F5%2FA","sourceRelease":"119-100","text":"Indian tribes, especially Indian tribes located in the Great Plains, have experienced epidemic levels of suicide, up to 10 times the national average; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1667/a/5/B","parentIdentifier":"/us/usc/t25/s1667/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F5%2FB","sourceRelease":"119-100","text":"suicide clustering in Indian country affects entire tribal communities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t25/s1667/a/6","parentIdentifier":"/us/usc/t25/s1667/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F6","sourceRelease":"119-100","text":"death rates for Indians and Alaska Natives are statistically underestimated because many areas of Indian country lack the proper resources to identify and monitor the presence of disease;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t25/s1667/a/7","parentIdentifier":"/us/usc/t25/s1667/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1667/a/7/A","parentIdentifier":"/us/usc/t25/s1667/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F7%2FA","sourceRelease":"119-100","text":"the Indian Health Service experiences health professional shortages, with physician vacancy rates of approximately 17 percent, and nursing vacancy rates of approximately 18 percent, in 2007;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1667/a/7/B","parentIdentifier":"/us/usc/t25/s1667/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F7%2FB","sourceRelease":"119-100","text":"90 percent of all teens who die by suicide suffer from a diagnosable mental illness at time of death;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1667/a/7/C","parentIdentifier":"/us/usc/t25/s1667/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F7%2FC","sourceRelease":"119-100","text":"more than ½ of teens who die by suicide have never been seen by a mental health provider; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s1667/a/7/D","parentIdentifier":"/us/usc/t25/s1667/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F7%2FD","sourceRelease":"119-100","text":"⅓ of health needs in Indian country relate to mental health;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t25/s1667/a/8","parentIdentifier":"/us/usc/t25/s1667/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F8","sourceRelease":"119-100","text":"often, the lack of resources of Indian tribes and the remote nature of Indian reservations make it difficult to meet the requirements necessary to access Federal assistance, including grants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t25/s1667/a/9","parentIdentifier":"/us/usc/t25/s1667/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F9","sourceRelease":"119-100","text":"the Substance Abuse and Mental Health Services Administration and the Service have established specific initiatives to combat youth suicide in Indian country and among Indians and Alaska Natives throughout the United States, including the National Suicide Prevention Initiative of the Service, which has worked with Service, tribal, and urban Indian health programs since 2003;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t25/s1667/a/10","parentIdentifier":"/us/usc/t25/s1667/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F10","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1667/a/10/A","parentIdentifier":"/us/usc/t25/s1667/a/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F10%2FA","sourceRelease":"119-100","text":"the Substance Abuse and Mental Health Services Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1667/a/10/B","parentIdentifier":"/us/usc/t25/s1667/a/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F10%2FB","sourceRelease":"119-100","text":"the Service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1667/a/10/C","parentIdentifier":"/us/usc/t25/s1667/a/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F10%2FC","sourceRelease":"119-100","text":"the Centers for Disease Control and Prevention;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s1667/a/10/D","parentIdentifier":"/us/usc/t25/s1667/a/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F10%2FD","sourceRelease":"119-100","text":"the National Institutes of Health; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t25/s1667/a/10/E","parentIdentifier":"/us/usc/t25/s1667/a/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F10%2FE","sourceRelease":"119-100","text":"the Health Resources and Services Administration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t25/s1667/a/11","parentIdentifier":"/us/usc/t25/s1667/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fa%2F11","sourceRelease":"119-100","text":"the Service and other agencies of the Department of Health and Human Services use information technology and other programs to address the suicide prevention and mental health needs of Indians and Alaska Natives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purposes","label":"b Purposes","identifier":"/us/usc/t25/s1667/b","parentIdentifier":"/us/usc/t25/s1667","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s1667/b/1","parentIdentifier":"/us/usc/t25/s1667/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1667/b/1/A","parentIdentifier":"/us/usc/t25/s1667/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the use of psychotherapy, psychiatric assessments, diagnostic interviews, therapies for mental health conditions predisposing to suicide, and alcohol and substance abuse treatment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1667/b/1/B","parentIdentifier":"/us/usc/t25/s1667/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the provision of clinical expertise to, consultation services with, and medical advice and training for frontline health care providers working with Indian youth;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1667/b/1/C","parentIdentifier":"/us/usc/t25/s1667/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fb%2F1%2FC","sourceRelease":"119-100","text":"training and related support for community leaders, family members, and health and education workers who work with Indian youth;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s1667/b/1/D","parentIdentifier":"/us/usc/t25/s1667/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fb%2F1%2FD","sourceRelease":"119-100","text":"the development of culturally relevant educational materials on suicide; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t25/s1667/b/1/E","parentIdentifier":"/us/usc/t25/s1667/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fb%2F1%2FE","sourceRelease":"119-100","text":"data collection and reporting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s1667/b/2","parentIdentifier":"/us/usc/t25/s1667/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fb%2F2","sourceRelease":"119-100","text":"to encourage Indian tribes, tribal organizations, and other mental health care providers serving residents of Indian country to obtain the services of predoctoral psychology and psychiatry interns; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s1667/b/3","parentIdentifier":"/us/usc/t25/s1667/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1667%2Fb%2F3","sourceRelease":"119-100","text":"to enhance the provision of mental health care services to Indian youth through existing grant programs of the Substance Abuse and Mental Health Services Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
