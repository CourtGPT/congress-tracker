{"type":"section","nativeType":"section","number":"1960","heading":"Safe harbor with respect to keep open directives","label":"1960 Safe harbor with respect to keep open directives","identifier":"/us/usc/t12/s1960","parentIdentifier":"/us/usc/t12/ch21","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definition","label":"a Definition","identifier":"/us/usc/t12/s1960/a","parentIdentifier":"/us/usc/t12/s1960","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fa","sourceRelease":"119-100","text":"In this section, the term “financial institution” means an entity to which applies.section 1953(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Safe harbor","label":"b Safe harbor","identifier":"/us/usc/t12/s1960/b","parentIdentifier":"/us/usc/t12/s1960","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s1960/b/1","parentIdentifier":"/us/usc/t12/s1960/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fb%2F1","sourceRelease":"119-100","text":"the financial institution shall not be liable under this chapter for maintaining that account or transaction consistent with the parameters and timing of the request; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s1960/b/2","parentIdentifier":"/us/usc/t12/s1960/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fb%2F2","sourceRelease":"119-100","text":"no Federal or State department or agency may take any adverse supervisory action under this chapter with respect to the financial institution solely for maintaining that account or transaction consistent with the parameters of the request.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Rule of construction","label":"c Rule of construction","identifier":"/us/usc/t12/s1960/c","parentIdentifier":"/us/usc/t12/s1960","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s1960/c/1","parentIdentifier":"/us/usc/t12/s1960/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fc%2F1","sourceRelease":"119-100","text":"to prevent a Federal or State department or agency from verifying the validity of a keep open request submitted under subsection (b) with the law enforcement agency submitting that request;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s1960/c/2","parentIdentifier":"/us/usc/t12/s1960/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fc%2F2","sourceRelease":"119-100","text":"to relieve a financial institution from complying with any reporting requirements, including the reporting of suspicious transactions under ; orsection 5318(g) of title 31","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t12/s1960/c/3","parentIdentifier":"/us/usc/t12/s1960/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s1960/c/3/A","parentIdentifier":"/us/usc/t12/s1960/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fc%2F3%2FA","sourceRelease":"119-100","text":"before the date of the keep open request to maintain a customer account; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s1960/c/3/B","parentIdentifier":"/us/usc/t12/s1960/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fc%2F3%2FB","sourceRelease":"119-100","text":"after the termination date stated in the keep open request.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Letter termination date","label":"d Letter termination date","identifier":"/us/usc/t12/s1960/d","parentIdentifier":"/us/usc/t12/s1960","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fd","sourceRelease":"119-100","text":"For the purposes of this section, any keep open request submitted under subsection (b) shall include a termination date after which that request shall no longer apply.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Record keeping","label":"e Record keeping","identifier":"/us/usc/t12/s1960/e","parentIdentifier":"/us/usc/t12/s1960","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s1960/e/1","parentIdentifier":"/us/usc/t12/s1960/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fe%2F1","sourceRelease":"119-100","text":"submit to FinCEN a copy of the request; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s1960/e/2","parentIdentifier":"/us/usc/t12/s1960/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1960%2Fe%2F2","sourceRelease":"119-100","text":"alert FinCEN as to whether the financial institution has implemented the request.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
