{"type":"section","nativeType":"section","number":"2067","heading":"National Center on Homelessness Among Veterans","label":"2067 National Center on Homelessness Among Veterans","identifier":"/us/usc/t38/s2067","parentIdentifier":"/us/usc/t38/ptII/ch20/schVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2067","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t38/s2067/a","parentIdentifier":"/us/usc/t38/s2067","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2067%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s2067/a/1","parentIdentifier":"/us/usc/t38/s2067/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2067%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary shall establish and operate a center to carry out the functions described in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s2067/a/2","parentIdentifier":"/us/usc/t38/s2067/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2067%2Fa%2F2","sourceRelease":"119-100","text":"The center established under paragraph (1) shall be known as the “National Center on Homelessness Among Veterans”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s2067/a/3","parentIdentifier":"/us/usc/t38/s2067/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2067%2Fa%2F3","sourceRelease":"119-100","text":"To the degree practicable, the Secretary shall operate the center established under paragraph (1) independently of the other programs of the Department that address homelessness among veterans.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Functions","label":"b .—Functions","identifier":"/us/usc/t38/s2067/b","parentIdentifier":"/us/usc/t38/s2067","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2067%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s2067/b/1","parentIdentifier":"/us/usc/t38/s2067/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2067%2Fb%2F1","sourceRelease":"119-100","text":"To carry out and promote research into the causes and contributing factors to veteran homelessness.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s2067/b/2","parentIdentifier":"/us/usc/t38/s2067/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2067%2Fb%2F2","sourceRelease":"119-100","text":"To assess the effectiveness of programs of the Department to meet the needs of homeless veterans.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s2067/b/3","parentIdentifier":"/us/usc/t38/s2067/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2067%2Fb%2F3","sourceRelease":"119-100","text":"To identify and disseminate best practices with regard to housing stabilization, income support, employment assistance, community partnerships, and such other matters as the Secretary considers appropriate with respect to addressing veteran homelessness.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s2067/b/4","parentIdentifier":"/us/usc/t38/s2067/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2067%2Fb%2F4","sourceRelease":"119-100","text":"To integrate evidence-based and best practices, policies, and programs into programs of the Department for homeless veterans and veterans at risk of homelessness and to ensure that the staff of the Department and community partners can implement such practices, policies, and programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t38/s2067/b/5","parentIdentifier":"/us/usc/t38/s2067/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2067%2Fb%2F5","sourceRelease":"119-100","text":"To serve as a resource center for, and promote and seek to coordinate the exchange of information regarding, all research and training activities carried out by the Department and by other Federal and non-Federal entities with respect to veteran homelessness.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
