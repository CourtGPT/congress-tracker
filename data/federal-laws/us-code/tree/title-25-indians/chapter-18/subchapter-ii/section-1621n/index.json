":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s1621n/f/3","parentIdentifier":"/us/usc/t25/s1621n/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Ff%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1621n/f/3/A","parentIdentifier":"/us/usc/t25/s1621n/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Ff%2F3%2FA","sourceRelease":"119-100","text":"provide training to teachers in comprehensive school health education curricula;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1621n/f/3/B","parentIdentifier":"/us/usc/t25/s1621n/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Ff%2F3%2FB","sourceRelease":"119-100","text":"ensure the integration and coordination of school-based programs with existing services and health programs available in the community; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1621n/f/3/C","parentIdentifier":"/us/usc/t25/s1621n/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Ff%2F3%2FC","sourceRelease":"119-100","text":"encourage healthy, tobacco-free school environments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Authorization of appropriations","label":"g Authorization of appropriations","identifier":"/us/usc/t25/s1621n/g","parentIdentifier":"/us/usc/t25/s1621n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1621n%2Fg","sourceRelease":"119-100","text":"There are authorized to be appropriated to carry out this section $15,000,000 for fiscal year 1993 and such sums as may be necessary for each of the fiscal years 1994, 1995, 1996, 1997, 1998, 1999, and 2000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
