{"type":"section","nativeType":"section","number":"16522","heading":"Low-volume gas reservoir study","label":"16522 Low-volume gas reservoir study","identifier":"/us/usc/t42/s16522","parentIdentifier":"/us/usc/t42/ch149/schXVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Study","label":"a Study","identifier":"/us/usc/t42/s16522/a","parentIdentifier":"/us/usc/t42/s16522","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fa","sourceRelease":"119-100","text":"The Secretary shall make a grant to an organization of oil and gas producing States, specifically those containing significant numbers of marginal oil and natural gas wells, for conducting an annual study of low-volume natural gas reservoirs. Such organization shall work with the State geologist of each State being studied.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Contents","label":"b Contents","identifier":"/us/usc/t42/s16522/b","parentIdentifier":"/us/usc/t42/s16522","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16522/b/1","parentIdentifier":"/us/usc/t42/s16522/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fb%2F1","sourceRelease":"119-100","text":"determine the status and location of marginal wells and gas reservoirs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16522/b/2","parentIdentifier":"/us/usc/t42/s16522/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fb%2F2","sourceRelease":"119-100","text":"gather the production information of these marginal wells and reservoirs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16522/b/3","parentIdentifier":"/us/usc/t42/s16522/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fb%2F3","sourceRelease":"119-100","text":"estimate the remaining producible reserves based on variable pipeline pressures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16522/b/4","parentIdentifier":"/us/usc/t42/s16522/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fb%2F4","sourceRelease":"119-100","text":"locate low-pressure gathering facilities and pipelines;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16522/b/5","parentIdentifier":"/us/usc/t42/s16522/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fb%2F5","sourceRelease":"119-100","text":"recommend incentives which will enable the continued production of these resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s16522/b/6","parentIdentifier":"/us/usc/t42/s16522/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fb%2F6","sourceRelease":"119-100","text":"produce maps and literature to disseminate to States to promote conservation of natural gas reserves; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s16522/b/7","parentIdentifier":"/us/usc/t42/s16522/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fb%2F7","sourceRelease":"119-100","text":"evaluate the amount of natural gas that is being wasted through the practice of venting or flaring of natural gas produced in association with crude oil well production.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Data analysis","label":"c Data analysis","identifier":"/us/usc/t42/s16522/c","parentIdentifier":"/us/usc/t42/s16522","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16522/c/1","parentIdentifier":"/us/usc/t42/s16522/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fc%2F1","sourceRelease":"119-100","text":"technological capabilities and resources to perform advanced image processing, GIS programming, and data analysis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16522/c/2","parentIdentifier":"/us/usc/t42/s16522/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16522/c/2/A","parentIdentifier":"/us/usc/t42/s16522/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fc%2F2%2FA","sourceRelease":"119-100","text":"process remotely sensed imagery with high spatial resolution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16522/c/2/B","parentIdentifier":"/us/usc/t42/s16522/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fc%2F2%2FB","sourceRelease":"119-100","text":"deploy global positioning systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16522/c/2/C","parentIdentifier":"/us/usc/t42/s16522/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fc%2F2%2FC","sourceRelease":"119-100","text":"process and synthesize existing, variable-format gas well, pipeline, gathering facility, and reservoir data;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16522/c/2/D","parentIdentifier":"/us/usc/t42/s16522/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fc%2F2%2FD","sourceRelease":"119-100","text":"create and query GIS databases with infrastructure location and attribute information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16522/c/2/E","parentIdentifier":"/us/usc/t42/s16522/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fc%2F2%2FE","sourceRelease":"119-100","text":"write computer programs to customize relevant GIS software;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s16522/c/2/F","parentIdentifier":"/us/usc/t42/s16522/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fc%2F2%2FF","sourceRelease":"119-100","text":"generate maps, charts, and graphs which summarize findings from data research for presentation to different audiences; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s16522/c/2/G","parentIdentifier":"/us/usc/t42/s16522/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fc%2F2%2FG","sourceRelease":"119-100","text":"deliver data in a variety of formats, including Internet Map Server for query and display, desktop computer display, and access through handheld personal digital assistants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s16522/d","parentIdentifier":"/us/usc/t42/s16522","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16522/d/1","parentIdentifier":"/us/usc/t42/s16522/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fd%2F1","sourceRelease":"119-100","text":"$1,500,000 for fiscal year 2006; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16522/d/2","parentIdentifier":"/us/usc/t42/s16522/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fd%2F2","sourceRelease":"119-100","text":"$450,000 for each of the fiscal years 2007 through 2010.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Definitions","label":"e Definitions","identifier":"/us/usc/t42/s16522/e","parentIdentifier":"/us/usc/t42/s16522","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16522%2Fe","sourceRelease":"119-100","text":"For purposes of this section, the term “GIS” means geographic information systems technology that facilitates the organization and management of data with a geographic component.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
