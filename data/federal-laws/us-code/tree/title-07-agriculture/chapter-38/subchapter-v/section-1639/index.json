{"type":"section","nativeType":"section","number":"1639","heading":"Definitions","label":"1639 Definitions","identifier":"/us/usc/t7/s1639","parentIdentifier":"/us/usc/t7/ch38/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Bioengineering","label":"1 Bioengineering","identifier":"/us/usc/t7/s1639/1","parentIdentifier":"/us/usc/t7/s1639","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1639/1/A","parentIdentifier":"/us/usc/t7/s1639/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639%2F1%2FA","sourceRelease":"119-100","text":"that contains genetic material that has been modified through in vitro recombinant deoxyribonucleic acid (DNA) techniques; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1639/1/B","parentIdentifier":"/us/usc/t7/s1639/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639%2F1%2FB","sourceRelease":"119-100","text":"for which the modification could not otherwise be obtained through conventional breeding or found in nature.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Food","label":"2 Food","identifier":"/us/usc/t7/s1639/2","parentIdentifier":"/us/usc/t7/s1639","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639%2F2","sourceRelease":"119-100","text":"The term “food” means a food (as defined in ) that is intended for human consumption.section 321 of title 21","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Secretary","label":"3 Secretary","identifier":"/us/usc/t7/s1639/3","parentIdentifier":"/us/usc/t7/s1639","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639%2F3","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Agriculture.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
