{"type":"section","nativeType":"section","number":"1066","heading":"Use of commissary stores and MWR facilities: certain civilian employees","label":"1066 Use of commissary stores and MWR facilities: certain civilian employees","identifier":"/us/usc/t10/s1066","parentIdentifier":"/us/usc/t10/stA/ptII/ch54","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2025—, substituted “certain” for “protective services” in section catchline.Pub. L. 119–60, § 651(b)(1)Subsec. (a). , substituted “Certain” for “Protective Services” in heading.Pub. L. 119–60, § 651(b)(2), designated existing provisions as par. (1) and added par. (2).Pub. L. 119–60, § 651(a)"],"amendments":["Amendments2025—, substituted “certain” for “protective services” in section catchline.Pub. L. 119–60, § 651(b)(1)Subsec. (a). , substituted “Certain” for “Protective Services” in heading.Pub. L. 119–60, § 651(b)(2), designated existing provisions as par. (1) and added par. (2).Pub. L. 119–60, § 651(a)"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Eligibility of Certain Civilian Employees","label":"a .—Eligibility of Certain Civilian Employees","identifier":"/us/usc/t10/s1066/a","parentIdentifier":"/us/usc/t10/s1066","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1066/a/1","parentIdentifier":"/us/usc/t10/s1066/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fa%2F1","sourceRelease":"119-100","text":"An individual employed as a protective services civilian employee at a military installation may be permitted to purchase food and hygiene items at a commissary store or MWR retail facility located on that military installation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1066/a/2","parentIdentifier":"/us/usc/t10/s1066/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fa%2F2","sourceRelease":"119-100","text":"A civil service mariner of the Military Sealift Command may be permitted to use commissary stores and MWR retail facilities on the same basis as members of the armed forces on active duty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—User Fee Authority","label":"b .—User Fee Authority","identifier":"/us/usc/t10/s1066/b","parentIdentifier":"/us/usc/t10/s1066","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1066/b/1","parentIdentifier":"/us/usc/t10/s1066/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary of Defense shall prescribe regulations that impose a user fee on individuals who are eligible solely under this section to purchase merchandise at a commissary store or MWR retail facility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1066/b/2","parentIdentifier":"/us/usc/t10/s1066/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary shall set the user fee under this subsection at a rate that the Secretary determines will offset any increase in expenses arising from this section borne by the Department of the Treasury on behalf of commissary stores associated with the use of credit or debit cards for customer purchases, including expenses related to card network use and related transaction processing fees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s1066/b/3","parentIdentifier":"/us/usc/t10/s1066/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fb%2F3","sourceRelease":"119-100","text":"The Secretary shall deposit funds collected pursuant to a user fee under this subsection in the General Fund of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s1066/b/4","parentIdentifier":"/us/usc/t10/s1066/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fb%2F4","sourceRelease":"119-100","text":"Any fee under this subsection is in addition to the uniform surcharge under .section 2484(d) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Definitions","label":"c .—Definitions","identifier":"/us/usc/t10/s1066/c","parentIdentifier":"/us/usc/t10/s1066","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1066/c/1","parentIdentifier":"/us/usc/t10/s1066/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fc%2F1","sourceRelease":"119-100","text":"The term “MWR retail facility” has the meaning given that term in .section 1063 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1066/c/2","parentIdentifier":"/us/usc/t10/s1066/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s1066/c/2/A","parentIdentifier":"/us/usc/t10/s1066/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fc%2F2%2FA","sourceRelease":"119-100","text":"Security Administration (GS–0080).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s1066/c/2/B","parentIdentifier":"/us/usc/t10/s1066/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fc%2F2%2FB","sourceRelease":"119-100","text":"Fire Protection and Prevention (GS–0081).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s1066/c/2/C","parentIdentifier":"/us/usc/t10/s1066/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fc%2F2%2FC","sourceRelease":"119-100","text":"Police (GS–0083).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s1066/c/2/D","parentIdentifier":"/us/usc/t10/s1066/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fc%2F2%2FD","sourceRelease":"119-100","text":"Security Guard (GS–0085).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t10/s1066/c/2/E","parentIdentifier":"/us/usc/t10/s1066/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1066%2Fc%2F2%2FE","sourceRelease":"119-100","text":"Emergency Management (GS–0089).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
