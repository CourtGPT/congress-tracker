{"type":"section","nativeType":"section","number":"16294","heading":"Research and development for coal mining technologies","label":"16294 Research and development for coal mining technologies","identifier":"/us/usc/t42/s16294","parentIdentifier":"/us/usc/t42/ch149/schIX/ptF","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16294","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t42/s16294/a","parentIdentifier":"/us/usc/t42/s16294","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16294%2Fa","sourceRelease":"119-100","text":"The Secretary shall carry out a program for research and development on coal mining technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Cooperation","label":"b Cooperation","identifier":"/us/usc/t42/s16294/b","parentIdentifier":"/us/usc/t42/s16294","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16294%2Fb","sourceRelease":"119-100","text":"In carrying out the program, the Secretary shall cooperate with appropriate Federal agencies, coal producers, trade associations, equipment manufacturers, institutions of higher education with mining engineering departments, and other relevant entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Program","label":"c Program","identifier":"/us/usc/t42/s16294/c","parentIdentifier":"/us/usc/t42/s16294","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16294%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16294/c/1","parentIdentifier":"/us/usc/t42/s16294/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16294%2Fc%2F1","sourceRelease":"119-100","text":"be guided by the mining research and development priorities identified by the Mining Industry of the Future Program and in the recommendations from relevant reports of the National Academy of Sciences on mining technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16294/c/2","parentIdentifier":"/us/usc/t42/s16294/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16294%2Fc%2F2","sourceRelease":"119-100","text":"include activities exploring minimization of contaminants in mined coal that contribute to environmental concerns including development and demonstration of electromagnetic wave imaging ahead of mining operations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16294/c/3","parentIdentifier":"/us/usc/t42/s16294/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16294%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16294/c/3/A","parentIdentifier":"/us/usc/t42/s16294/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16294%2Fc%2F3%2FA","sourceRelease":"119-100","text":"identify areas of high coal gas content;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16294/c/3/B","parentIdentifier":"/us/usc/t42/s16294/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16294%2Fc%2F3%2FB","sourceRelease":"119-100","text":"increase methane recovery efficiency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16294/c/3/C","parentIdentifier":"/us/usc/t42/s16294/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16294%2Fc%2F3%2FC","sourceRelease":"119-100","text":"prevent spoilage of domestic coal reserves; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16294/c/3/D","parentIdentifier":"/us/usc/t42/s16294/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16294%2Fc%2F3%2FD","sourceRelease":"119-100","text":"minimize water disposal associated with methane extraction; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16294/c/4","parentIdentifier":"/us/usc/t42/s16294/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16294%2Fc%2F4","sourceRelease":"119-100","text":"expand mining research capabilities at institutions of higher education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
