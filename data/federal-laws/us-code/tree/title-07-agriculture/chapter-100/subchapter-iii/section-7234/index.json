 established under , as determined by the Secretary; andsection 7232 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7234/e/1/B","parentIdentifier":"/us/usc/t7/s7234/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7234%2Fe%2F1%2FB","sourceRelease":"119-100","text":"the Friday through Thursday average price quotation for the lowest-priced United States growth as quoted for Middling (M) 1⁄-inch cotton delivered C.I.F. Northern Europe is greater than the Friday through Thursday average price of the 5 lowest-priced growths of upland cotton, as quoted for Middling (M) 1⁄-inch cotton, delivered C.I.F. Northern Europe (referred to in this section as the “Northern Europe price”).333232","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Further adjustment","label":"2 Further adjustment","identifier":"/us/usc/t7/s7234/e/2","parentIdentifier":"/us/usc/t7/s7234/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7234%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7234/e/2/A","parentIdentifier":"/us/usc/t7/s7234/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7234%2Fe%2F2%2FA","sourceRelease":"119-100","text":"The United States share of world exports.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7234/e/2/B","parentIdentifier":"/us/usc/t7/s7234/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7234%2Fe%2F2%2FB","sourceRelease":"119-100"