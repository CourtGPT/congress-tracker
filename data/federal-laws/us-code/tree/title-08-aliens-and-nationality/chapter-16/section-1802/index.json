{"type":"section","nativeType":"section","number":"1802","heading":"Asylum fee","label":"1802 Asylum fee","identifier":"/us/usc/t8/s1802","parentIdentifier":"/us/usc/t8/ch16","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t8/s1802/a","parentIdentifier":"/us/usc/t8/s1802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fa","sourceRelease":"119-100","text":"In addition to any other fee authorized by law, the Secretary of Homeland Security or the Attorney General, as applicable, shall require the payment of a fee, equal to the amount specified in this section, by any alien who files an application for asylum under at the time such application is filed.section 1158 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Initial amount","label":"b Initial amount","identifier":"/us/usc/t8/s1802/b","parentIdentifier":"/us/usc/t8/s1802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t8/s1802/b/1","parentIdentifier":"/us/usc/t8/s1802/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fb%2F1","sourceRelease":"119-100","text":"$100; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t8/s1802/b/2","parentIdentifier":"/us/usc/t8/s1802/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fb%2F2","sourceRelease":"119-100","text":"such amount as the Secretary or the Attorney General, as applicable, may establish, by rule.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Annual adjustments for inflation","label":"c Annual adjustments for inflation","identifier":"/us/usc/t8/s1802/c","parentIdentifier":"/us/usc/t8/s1802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t8/s1802/c/1","parentIdentifier":"/us/usc/t8/s1802/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fc%2F1","sourceRelease":"119-100","text":"the amount of the fee required under this section for the most recently concluded fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t8/s1802/c/2","parentIdentifier":"/us/usc/t8/s1802/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fc%2F2","sourceRelease":"119-100","text":"the product resulting from the multiplication of the amount referred to in paragraph (1) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded to the next lowest multiple of $10.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Disposition of asylum fee proceeds","label":"d Disposition of asylum fee proceeds","identifier":"/us/usc/t8/s1802/d","parentIdentifier":"/us/usc/t8/s1802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t8/s1802/d/1","parentIdentifier":"/us/usc/t8/s1802/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1802/d/1/A","parentIdentifier":"/us/usc/t8/s1802/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fd%2F1%2FA","sourceRelease":"119-100","text":"shall be credited to the Executive Office for Immigration Review; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1802/d/1/B","parentIdentifier":"/us/usc/t8/s1802/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fd%2F1%2FB","sourceRelease":"119-100","text":"may be retained and expended without further appropriation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t8/s1802/d/2","parentIdentifier":"/us/usc/t8/s1802/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1802/d/2/A","parentIdentifier":"/us/usc/t8/s1802/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fd%2F2%2FA","sourceRelease":"119-100","text":"shall be credited to U.S. Citizenship and Immigration Services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1802/d/2/B","parentIdentifier":"/us/usc/t8/s1802/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fd%2F2%2FB","sourceRelease":"119-100","text":"shall be deposited into the Immigration Examinations Fee Account established under ; andsection 1356(m) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t8/s1802/d/2/C","parentIdentifier":"/us/usc/t8/s1802/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fd%2F2%2FC","sourceRelease":"119-100","text":"may be retained and expended without further appropriation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t8/s1802/d/3","parentIdentifier":"/us/usc/t8/s1802/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fd%2F3","sourceRelease":"119-100","text":"any amounts received in fees required under this section that were not credited to the Executive Office for Immigration Review pursuant to paragraph (1) or to U.S. Citizenship and Immigration Services pursuant to paragraph (2) shall be deposited into the general fund of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"No fee waiver","label":"e No fee waiver","identifier":"/us/usc/t8/s1802/e","parentIdentifier":"/us/usc/t8/s1802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1802%2Fe","sourceRelease":"119-100","text":"Fees required to be paid under this section shall not be waived or reduced.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
