{"type":"section","nativeType":"section","number":"4704","heading":"Removal of abandoned barges","label":"4704 Removal of abandoned barges","identifier":"/us/usc/t46/s4704","parentIdentifier":"/us/usc/t46/stII/ptB/ch47/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2025—Subsecs. (a)(2), (b). substituted “subchapter” for “chapter”.Pub. L. 119–60"],"amendments":["Amendments2025—Subsecs. (a)(2), (b). substituted “subchapter” for “chapter”.Pub. L. 119–60"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t46/s4704/a","parentIdentifier":"/us/usc/t46/s4704","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s4704/a/1","parentIdentifier":"/us/usc/t46/s4704/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s4704/a/1/A","parentIdentifier":"/us/usc/t46/s4704/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t46/s4704/a/1/A/i","parentIdentifier":"/us/usc/t46/s4704/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"that if the barge is not removed it will be removed at the owner’s or operator’s expense; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t46/s4704/a/1/A/ii","parentIdentifier":"/us/usc/t46/s4704/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"of the penalty under section 4703.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s4704/a/1/B","parentIdentifier":"/us/usc/t46/s4704/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t46/s4704/a/1/B/i","parentIdentifier":"/us/usc/t46/s4704/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"a notice to mariners; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t46/s4704/a/1/B/ii","parentIdentifier":"/us/usc/t46/s4704/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"an official journal of the county in which the barge is located","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s4704/a/2","parentIdentifier":"/us/usc/t46/s4704/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fa%2F2","sourceRelease":"119-100","text":"The United States, and any officer or employee of the United States is not liable to an owner or operator for damages resulting from removal of an abandoned barge under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t46/s4704/b","parentIdentifier":"/us/usc/t46/s4704","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fb","sourceRelease":"119-100","text":"The owner or operator of an abandoned barge is liable, and an abandoned barge is liable in rem, for all expenses that the United States incurs in removing an abandoned barge under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t46/s4704/c","parentIdentifier":"/us/usc/t46/s4704","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s4704/c/1","parentIdentifier":"/us/usc/t46/s4704/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary may, after providing notice under subsection (a)(1), solicit by public advertisement sealed bids for the removal of an abandoned barge.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s4704/c/2","parentIdentifier":"/us/usc/t46/s4704/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s4704/c/2/A","parentIdentifier":"/us/usc/t46/s4704/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fc%2F2%2FA","sourceRelease":"119-100","text":"may be subject to the condition that the barge and all property on the barge is the property of the barge removal contractor; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s4704/c/2/B","parentIdentifier":"/us/usc/t46/s4704/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fc%2F2%2FB","sourceRelease":"119-100","text":"must require the barge removal contractor to submit to the Secretary a plan for the removal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s4704/c/3","parentIdentifier":"/us/usc/t46/s4704/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs4704%2Fc%2F3","sourceRelease":"119-100","text":"Removal of an abandoned barge may begin thirty days after the Secretary completes the procedures under subsection (a)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
