{"type":"section","nativeType":"section","number":"4644","heading":"Assessments","label":"4644 Assessments","identifier":"/us/usc/t19/s4644","parentIdentifier":"/us/usc/t19/ch29/schVI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4644","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Ongoing assessments","label":"a Ongoing assessments","identifier":"/us/usc/t19/s4644/a","parentIdentifier":"/us/usc/t19/s4644","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4644%2Fa","sourceRelease":"119-100","text":"For the 10-year period beginning on , except as provided in subsection (b), the Interagency Labor Committee shall assess on a biannual basis the extent to which Mexico is in compliance with its obligations under Annex 23–A of the USMCA.January 29, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Consultation relating to annual assessment","label":"b Consultation relating to annual assessment","identifier":"/us/usc/t19/s4644/b","parentIdentifier":"/us/usc/t19/s4644","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4644%2Fb","sourceRelease":"119-100","text":"On or after the date that is 5 years after , the Interagency Labor Committee may consult with the appropriate congressional committees with respect to the frequency of the assessment required under subsection (a) and, with the approval of both such committees, may conduct such assessment on an annual basis for the following 5 years.January 29, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Matters to be included","label":"c Matters to be included","identifier":"/us/usc/t19/s4644/c","parentIdentifier":"/us/usc/t19/s4644","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4644%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4644/c/1","parentIdentifier":"/us/usc/t19/s4644/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4644%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s4644/c/1/A","parentIdentifier":"/us/usc/t19/s4644/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4644%2Fc%2F1%2FA","sourceRelease":"119-100","text":"$176,000,000 for 2021.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s4644/c/1/B","parentIdentifier":"/us/usc/t19/s4644/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4644%2Fc%2F1%2FB","sourceRelease":"119-100","text":"$325,000,000 for 2022.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t19/s4644/c/1/C","parentIdentifier":"/us/usc/t19/s4644/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4644%2Fc%2F1%2FC","sourceRelease":"119-100","text":"$328,000,000 for 2023.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4644/c/2","parentIdentifier":"/us/usc/t19/s4644/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4644%2Fc%2F2","sourceRelease":"119-100","text":"The extent to which any legal challenges to Mexico’s labor reform have succeeded in that court system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s4644/c/3","parentIdentifier":"/us/usc/t19/s4644/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4644%2Fc%2F3","sourceRelease":"119-100","text":"The extent to which Mexico has implemented the federal and state labor courts, registration entity, and federal and state conciliation centers consistent with the timeline set forth for Mexico’s labor reform, in the September 2019 policy statements by the Government of Mexico on a national strategy for implementation of the labor justice system, and in subsequent policy statements in accordance with Mexico’s labor reform.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
