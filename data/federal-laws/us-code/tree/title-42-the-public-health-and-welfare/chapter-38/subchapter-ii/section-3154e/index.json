{"type":"section","nativeType":"section","number":"3154e","heading":"Workforce training grants","label":"3154e Workforce training grants","identifier":"/us/usc/t42/s3154e","parentIdentifier":"/us/usc/t42/ch38/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s3154e/a","parentIdentifier":"/us/usc/t42/s3154e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fa","sourceRelease":"119-100","text":"On the application of an eligible recipient, the Secretary may make grants to support the development and expansion of innovative workforce training programs through sectoral partnerships leading to quality jobs and the acquisition of equipment or construction of facilities to support workforce development activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Eligible uses","label":"b Eligible uses","identifier":"/us/usc/t42/s3154e/b","parentIdentifier":"/us/usc/t42/s3154e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s3154e/b/1","parentIdentifier":"/us/usc/t42/s3154e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fb%2F1","sourceRelease":"119-100","text":"acquisition or development of land and improvements to house workforce training activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s3154e/b/2","parentIdentifier":"/us/usc/t42/s3154e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fb%2F2","sourceRelease":"119-100","text":"acquisition, design and engineering, construction, rehabilitation, alteration, expansion, or improvement of such a facility, including related equipment and machinery;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s3154e/b/3","parentIdentifier":"/us/usc/t42/s3154e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fb%2F3","sourceRelease":"119-100","text":"acquisition of machinery or equipment to support workforce training activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s3154e/b/4","parentIdentifier":"/us/usc/t42/s3154e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fb%2F4","sourceRelease":"119-100","text":"planning, technical assistance, and training;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s3154e/b/5","parentIdentifier":"/us/usc/t42/s3154e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fb%2F5","sourceRelease":"119-100","text":"sector partnerships development, program design, and program implementation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s3154e/b/6","parentIdentifier":"/us/usc/t42/s3154e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fb%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s3154e/b/6/A","parentIdentifier":"/us/usc/t42/s3154e/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fb%2F6%2FA","sourceRelease":"119-100","text":"requires significant post-secondary training; but","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s3154e/b/6/B","parentIdentifier":"/us/usc/t42/s3154e/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fb%2F6%2FB","sourceRelease":"119-100","text":"does not require a post-secondary degree.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"State grant pilot program","label":"c State grant pilot program","identifier":"/us/usc/t42/s3154e/c","parentIdentifier":"/us/usc/t42/s3154e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s3154e/c/1","parentIdentifier":"/us/usc/t42/s3154e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary may award grants to States for the purpose described in subsection (b)(6).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Application","label":"2 Application","identifier":"/us/usc/t42/s3154e/c/2","parentIdentifier":"/us/usc/t42/s3154e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s3154e/c/2/A","parentIdentifier":"/us/usc/t42/s3154e/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F2%2FA","sourceRelease":"119-100","text":"A method for identifying critical industry sectors driving in-State economic growth that face staffing challenges for in-demand jobs and careers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s3154e/c/2/B","parentIdentifier":"/us/usc/t42/s3154e/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F2%2FB","sourceRelease":"119-100","text":"A governance structure for the implementation of the program established by the State, including defined roles for the consortia of agencies of such State, at a minimum, to include the State departments of economic development, labor, and education, or the State departments or agencies with jurisdiction over those matters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s3154e/c/2/C","parentIdentifier":"/us/usc/t42/s3154e/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F2%2FC","sourceRelease":"119-100","text":"A strategy for recruiting participants from at least 1 community that meets 1 or more of the criteria described in .section 3161(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s3154e/c/2/D","parentIdentifier":"/us/usc/t42/s3154e/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F2%2FD","sourceRelease":"119-100","text":"A plan for how the State will develop a tracking system for eligible programs, participant enrollment, participant outcomes, and an application portal for individual participants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Selection","label":"3 Selection","identifier":"/us/usc/t42/s3154e/c/3","parentIdentifier":"/us/usc/t42/s3154e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F3","sourceRelease":"119-100","text":"The Secretary shall award not more than 1 grant under this subsection to any State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Eligible uses","label":"4 Eligible uses","identifier":"/us/usc/t42/s3154e/c/4","parentIdentifier":"/us/usc/t42/s3154e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s3154e/c/4/A","parentIdentifier":"/us/usc/t42/s3154e/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F4%2FA","sourceRelease":"119-100","text":"necessary costs to carry out the matters described in this subsection, including tuition and stipends for individuals that receive funds under the program established by the applicable State, subject to the requirements described in paragraph (6); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s3154e/c/4/B","parentIdentifier":"/us/usc/t42/s3154e/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F4%2FB","sourceRelease":"119-100","text":"program implementation, planning, technical assistance, or training.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Federal share","label":"5 Federal share","identifier":"/us/usc/t42/s3154e/c/5","parentIdentifier":"/us/usc/t42/s3154e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F5","sourceRelease":"119-100","text":"Notwithstanding , the Federal share of the cost of any award carried out with a grant made under this subsection shall not exceed 70 percent.section 3144 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Participant amounts","label":"6 Participant amounts","identifier":"/us/usc/t42/s3154e/c/6","parentIdentifier":"/us/usc/t42/s3154e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s3154e/c/6/A","parentIdentifier":"/us/usc/t42/s3154e/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F6%2FA","sourceRelease":"119-100","text":"In a case in which the individual is also eligible for a Federal Pell Grant under for enrollment at the applicable training program for any award year of the training program, $11,000 minus the amount of the awarded Federal Pell Grant.section 1070a of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s3154e/c/6/B","parentIdentifier":"/us/usc/t42/s3154e/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F6%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s3154e/c/6/B/i","parentIdentifier":"/us/usc/t42/s3154e/c/6/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F6%2FB%2Fi","sourceRelease":"119-100","text":"$11,000; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s3154e/c/6/B/ii","parentIdentifier":"/us/usc/t42/s3154e/c/6/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F6%2FB%2Fii","sourceRelease":"119-100","text":"the total cost of the training program in which the individual is enrolled, including tuition, fees, career navigation services, textbook costs, expenses related to assessments and exams for certification or licensure, equipment costs, and wage stipends (in the case of a training program that is an earn-and-learn program).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Termination","label":"7 Termination","identifier":"/us/usc/t42/s3154e/c/7","parentIdentifier":"/us/usc/t42/s3154e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fc%2F7","sourceRelease":"119-100","text":"The authority provided under this subsection shall expire on .September 30, 2029","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Coordination","label":"d Coordination","identifier":"/us/usc/t42/s3154e/d","parentIdentifier":"/us/usc/t42/s3154e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154e%2Fd","sourceRelease":"119-100","text":"The Secretary shall coordinate the development of new workforce development models with the Secretary of Labor and the Secretary of Education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
