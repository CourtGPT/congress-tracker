{"type":"section","nativeType":"section","number":"6965","heading":"Reports to Congress","label":"6965 Reports to Congress","identifier":"/us/usc/t22/s6965","parentIdentifier":"/us/usc/t22/ch77/schIV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6965","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Frequency of reports","label":"a Frequency of reports","identifier":"/us/usc/t22/s6965/a","parentIdentifier":"/us/usc/t22/s6965","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6965%2Fa","sourceRelease":"119-100","text":"Not later than the date that is 1 year after , and not later than the end of each 1-year period thereafter, the Task Force shall submit to the Congress a report on the work of the Task Force during the preceding 1-year period.October 10, 2000","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Contents of reports","label":"b Contents of reports","identifier":"/us/usc/t22/s6965/b","parentIdentifier":"/us/usc/t22/s6965","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6965%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s6965/b/1","parentIdentifier":"/us/usc/t22/s6965/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6965%2Fb%2F1","sourceRelease":"119-100","text":"the number of allegations of violations of with respect to products of the Peoples’ Republic of China that were investigated during the preceding 1-year period;section 1307 of title 191So in original. Probably should be “People’s”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s6965/b/2","parentIdentifier":"/us/usc/t22/s6965/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6965%2Fb%2F2","sourceRelease":"119-100","text":"the number of actual violations of with respect to the products of the People’s Republic of China that were discovered during the preceding 1-year period;section 1307 of title 19","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s6965/b/3","parentIdentifier":"/us/usc/t22/s6965/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6965%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s6965/b/3/A","parentIdentifier":"/us/usc/t22/s6965/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6965%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the identity of the exporter of the goods;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s6965/b/3/B","parentIdentifier":"/us/usc/t22/s6965/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6965%2Fb%2F3%2FB","sourceRelease":"119-100","text":"the identity of the person or persons who attempted to sell the goods for export; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s6965/b/3/C","parentIdentifier":"/us/usc/t22/s6965/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6965%2Fb%2F3%2FC","sourceRelease":"119-100","text":"the identity of all parties involved in transshipment of the goods; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s6965/b/4","parentIdentifier":"/us/usc/t22/s6965/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6965%2Fb%2F4","sourceRelease":"119-100","text":"such other information as the Task Force considers useful in monitoring and enforcing compliance with .section 1307 of title 19","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
