B","heading":null,"label":"B","identifier":"/us/usc/t42/s15921/d/1/B","parentIdentifier":"/us/usc/t42/s15921/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15921%2Fd%2F1%2FB","sourceRelease":"119-100","text":"$20,000,000 to carry out subsection (c);","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15921/d/2","parentIdentifier":"/us/usc/t42/s15921/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15921%2Fd%2F2","sourceRelease":"119-100","text":"to the Secretary, acting through the Director of the United States Fish and Wildlife Service, $5,000,000 to carry out subsection (a)(1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s15921/d/3","parentIdentifier":"/us/usc/t42/s15921/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15921%2Fd%2F3","sourceRelease":"119-100","text":"to the Secretary of Agriculture, acting through the Chief of the Forest Service, $5,000,000 to carry out subsections (a)(2) and (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
