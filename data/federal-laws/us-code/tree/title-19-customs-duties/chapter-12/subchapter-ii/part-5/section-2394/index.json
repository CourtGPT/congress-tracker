{"type":"section","nativeType":"section","number":"2394","heading":"Firms relocating in foreign countries","label":"2394 Firms relocating in foreign countries","identifier":"/us/usc/t19/s2394","parentIdentifier":"/us/usc/t19/ch12/schII/pt5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2394","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t19/s2394/b","parentIdentifier":"/us/usc/t19/s2394","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2394%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s2394/b/1","parentIdentifier":"/us/usc/t19/s2394/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2394%2Fb%2F1","sourceRelease":"119-100","text":"apply for and use all adjustment assistance for which it is eligible under this subchapter,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s2394/b/2","parentIdentifier":"/us/usc/t19/s2394/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2394%2Fb%2F2","sourceRelease":"119-100","text":"offer employment opportunities in the United States, if any exist, to its employees who are totally or partially separated workers as a result of the move, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s2394/b/3","parentIdentifier":"/us/usc/t19/s2394/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2394%2Fb%2F3","sourceRelease":"119-100","text":"assist in relocating employees to other locations in the United States where employment opportunities exist.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s2394/1","parentIdentifier":"/us/usc/t19/s2394","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2394%2F1","sourceRelease":"119-100","text":"provide notice of the move to its employees who are likely to be totally or partially separated as a result of the move at least 60 days before the date of such move, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s2394/2","parentIdentifier":"/us/usc/t19/s2394","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2394%2F2","sourceRelease":"119-100","text":"provide notice of the move to the Secretary of Labor and the Secretary of Commerce on the same day it notifies employees under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
