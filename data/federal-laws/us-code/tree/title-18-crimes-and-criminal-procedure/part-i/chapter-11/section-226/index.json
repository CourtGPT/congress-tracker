{"type":"section","nativeType":"section","number":"226","heading":"Bribery affecting port security","label":"226 Bribery affecting port security","identifier":"/us/usc/t18/s226","parentIdentifier":"/us/usc/t18/ptI/ch11","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs226","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t18/s226/a","parentIdentifier":"/us/usc/t18/s226","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs226%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s226/a/1","parentIdentifier":"/us/usc/t18/s226/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs226%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s226/a/1/A","parentIdentifier":"/us/usc/t18/s226/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs226%2Fa%2F1%2FA","sourceRelease":"119-100","text":"influence any action or any person to commit or aid in committing, or collude in, or allow, any fraud, or make opportunity for the commission of any fraud affecting any secure or restricted area or seaport; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s226/a/1/B","parentIdentifier":"/us/usc/t18/s226/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs226%2Fa%2F1%2FB","sourceRelease":"119-100","text":"induce any official or person to do or omit to do any act in violation of the lawful duty of such official or person that affects any secure or restricted area or seaport; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s226/a/2","parentIdentifier":"/us/usc/t18/s226/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs226%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s226/a/2/A","parentIdentifier":"/us/usc/t18/s226/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs226%2Fa%2F2%2FA","sourceRelease":"119-100","text":"being influenced in the performance of any official act affecting any secure or restricted area or seaport; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s226/a/2/B","parentIdentifier":"/us/usc/t18/s226/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs226%2Fa%2F2%2FB","sourceRelease":"119-100","text":"knowing that such influence will be used to commit, or plan to commit, international or domestic terrorism,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Definition","label":"b .—Definition","identifier":"/us/usc/t18/s226/b","parentIdentifier":"/us/usc/t18/s226","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs226%2Fb","sourceRelease":"119-100","text":"In this section, the term “secure or restricted area” means an area of a vessel or facility designated as secure in an approved security plan, as required under , United States Code, and the rules and regulations promulgated under that section.section 70103 of title 46","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
