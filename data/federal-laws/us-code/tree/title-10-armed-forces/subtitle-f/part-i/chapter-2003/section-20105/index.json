{"type":"section","nativeType":"section","number":"20105","heading":"Sustained duty","label":"20105 Sustained duty","identifier":"/us/usc/t10/s20105","parentIdentifier":"/us/usc/t10/stF/ptI/ch2003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20105","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Enlisted Members","label":"a .—Enlisted Members","identifier":"/us/usc/t10/s20105/a","parentIdentifier":"/us/usc/t10/s20105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20105%2Fa","sourceRelease":"119-100","text":"An authority designated by the Secretary of the Air Force may order an enlisted member of the Space Force in a space force active status to sustained duty, or retain an enlisted member on sustained duty, with the consent of that member, as specified in the terms of the member’s enlistment or reenlistment agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Officers.—","label":"b Officers.—","identifier":"/us/usc/t10/s20105/b","parentIdentifier":"/us/usc/t10/s20105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20105%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s20105/b/1","parentIdentifier":"/us/usc/t10/s20105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20105%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s20105/b/1/A","parentIdentifier":"/us/usc/t10/s20105/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20105%2Fb%2F1%2FA","sourceRelease":"119-100","text":"with the consent of the officer; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s20105/b/1/B","parentIdentifier":"/us/usc/t10/s20105/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20105%2Fb%2F1%2FB","sourceRelease":"119-100","text":"to fulfill the terms of an active-duty service commitment incurred by the officer under any provision of law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s20105/b/2","parentIdentifier":"/us/usc/t10/s20105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20105%2Fb%2F2","sourceRelease":"119-100","text":"An officer ordered to sustained duty under paragraph (1) may not be released from sustained duty without the officer’s consent except as provided in chapter 2009 or 2011 of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
