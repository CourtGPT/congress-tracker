{"type":"section","nativeType":"section","number":"353","heading":"Acquisition professional career program","label":"353 Acquisition professional career program","identifier":"/us/usc/t6/s353","parentIdentifier":"/us/usc/t6/ch1/schVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t6/s353/a","parentIdentifier":"/us/usc/t6/s353","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fa","sourceRelease":"119-100","text":"There is established in the Department an acquisition professional career program to develop a cadre of acquisition professionals within the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Administration","label":"b Administration","identifier":"/us/usc/t6/s353/b","parentIdentifier":"/us/usc/t6/s353","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fb","sourceRelease":"119-100","text":"The Under Secretary for Management shall administer the acquisition professional career program established pursuant to subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Program requirements","label":"c Program requirements","identifier":"/us/usc/t6/s353/c","parentIdentifier":"/us/usc/t6/s353","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s353/c/1","parentIdentifier":"/us/usc/t6/s353/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fc%2F1","sourceRelease":"119-100","text":"Designate the occupational series, grades, and number of acquisition positions throughout the Department to be included in the program and manage centrally such positions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s353/c/2","parentIdentifier":"/us/usc/t6/s353/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fc%2F2","sourceRelease":"119-100","text":"Establish and publish on the Department’s website eligibility criteria for candidates to participate in the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s353/c/3","parentIdentifier":"/us/usc/t6/s353/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s353/c/3/A","parentIdentifier":"/us/usc/t6/s353/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fc%2F3%2FA","sourceRelease":"119-100","text":"from institutions of higher education, including such institutions with established acquisition specialties and courses of study, historically Black colleges and universities, and Hispanic-serving institutions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s353/c/3/B","parentIdentifier":"/us/usc/t6/s353/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fc%2F3%2FB","sourceRelease":"119-100","text":"with diverse work experience outside of the Federal Government; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s353/c/3/C","parentIdentifier":"/us/usc/t6/s353/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fc%2F3%2FC","sourceRelease":"119-100","text":"with military service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s353/c/4","parentIdentifier":"/us/usc/t6/s353/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fc%2F4","sourceRelease":"119-100","text":"Hire eligible candidates for designated positions under the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s353/c/5","parentIdentifier":"/us/usc/t6/s353/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fc%2F5","sourceRelease":"119-100","text":"Develop a structured program comprised of acquisition training, on-the-job experience, Department-wide rotations, mentorship, shadowing, and other career development opportunities for program participants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t6/s353/c/6","parentIdentifier":"/us/usc/t6/s353/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fc%2F6","sourceRelease":"119-100","text":"Provide, beyond required training established for program participants, additional specialized acquisition training, including small business contracting and innovative acquisition techniques training.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Reports","label":"d Reports","identifier":"/us/usc/t6/s353/d","parentIdentifier":"/us/usc/t6/s353","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s353/d/1","parentIdentifier":"/us/usc/t6/s353/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fd%2F1","sourceRelease":"119-100","text":"The number of candidates approved for the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s353/d/2","parentIdentifier":"/us/usc/t6/s353/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fd%2F2","sourceRelease":"119-100","text":"The number of candidates who commenced participation in the program, including generalized information on such candidates’ backgrounds with respect to education and prior work experience, but not including personally identifiable information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s353/d/3","parentIdentifier":"/us/usc/t6/s353/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fd%2F3","sourceRelease":"119-100","text":"A breakdown of the number of participants hired under the program by type of acquisition position.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s353/d/4","parentIdentifier":"/us/usc/t6/s353/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fd%2F4","sourceRelease":"119-100","text":"A list of Department components and offices that participated in the program and information regarding length of time of each program participant in each rotation at such components or offices.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s353/d/5","parentIdentifier":"/us/usc/t6/s353/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fd%2F5","sourceRelease":"119-100","text":"Program attrition rates and post-program graduation retention data, including information on how such data compare to the prior year’s data, as available.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t6/s353/d/6","parentIdentifier":"/us/usc/t6/s353/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fd%2F6","sourceRelease":"119-100","text":"The Department’s recruiting efforts for the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t6/s353/d/7","parentIdentifier":"/us/usc/t6/s353/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fd%2F7","sourceRelease":"119-100","text":"The Department’s efforts to promote retention of program participants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Definitions","label":"e Definitions","identifier":"/us/usc/t6/s353/e","parentIdentifier":"/us/usc/t6/s353","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Hispanic-serving institution","label":"1 Hispanic-serving institution","identifier":"/us/usc/t6/s353/e/1","parentIdentifier":"/us/usc/t6/s353/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fe%2F1","sourceRelease":"119-100","text":"The term “Hispanic-serving institution” has the meaning given such term in .section 1101a of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Historically Black colleges and universities","label":"2 Historically Black colleges and universities","identifier":"/us/usc/t6/s353/e/2","parentIdentifier":"/us/usc/t6/s353/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fe%2F2","sourceRelease":"119-100","text":"The term “historically Black colleges and universities” has the meaning given the term “part B institution” in .section 1061(2) of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Institution of higher education","label":"3 Institution of higher education","identifier":"/us/usc/t6/s353/e/3","parentIdentifier":"/us/usc/t6/s353/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs353%2Fe%2F3","sourceRelease":"119-100","text":"The term “institution of higher education” has the meaning given such term in .section 1001 of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
