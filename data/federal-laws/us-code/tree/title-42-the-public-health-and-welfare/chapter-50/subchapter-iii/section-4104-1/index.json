{"type":"section","nativeType":"section","number":"4104–1","heading":"Scientific Resolution Panel","label":"4104–1 Scientific Resolution Panel","identifier":"/us/usc/t42/s4104–1","parentIdentifier":"/us/usc/t42/ch50/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Availability","label":"a Availability","identifier":"/us/usc/t42/s4104–1/a","parentIdentifier":"/us/usc/t42/s4104–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s4104–1/a/1","parentIdentifier":"/us/usc/t42/s4104–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s4104–1/a/1/A","parentIdentifier":"/us/usc/t42/s4104–1/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s4104–1/a/1/A/i","parentIdentifier":"/us/usc/t42/s4104–1/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"filed a timely map appeal in accordance with ;section 4104 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s4104–1/a/1/A/ii","parentIdentifier":"/us/usc/t42/s4104–1/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"completed 60 days of consultation with the Federal Emergency Management Agency on the appeal; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s4104–1/a/1/A/iii","parentIdentifier":"/us/usc/t42/s4104–1/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"not allowed more than 120 days, or such longer period as may be provided by the Administrator by waiver, to pass since the end of the appeal period; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s4104–1/a/1/B","parentIdentifier":"/us/usc/t42/s4104–1/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa%2F1%2FB","sourceRelease":"119-100","text":"that has received an unsatisfactory ruling under the map revision process established pursuant to .section 4101(f) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Appeals by owners and lessees","label":"2 Appeals by owners and lessees","identifier":"/us/usc/t42/s4104–1/a/2","parentIdentifier":"/us/usc/t42/s4104–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s4104–1/a/2/A","parentIdentifier":"/us/usc/t42/s4104–1/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the owner or lessee shall submit scientific and technical data relating to the appeals to the Scientific Resolution Panel; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s4104–1/a/2/B","parentIdentifier":"/us/usc/t42/s4104–1/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the Scientific Resolution Panel shall make a determination with respect to the appeals in accordance with subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Definition","label":"3 Definition","identifier":"/us/usc/t42/s4104–1/a/3","parentIdentifier":"/us/usc/t42/s4104–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s4104–1/a/3/A","parentIdentifier":"/us/usc/t42/s4104–1/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa%2F3%2FA","sourceRelease":"119-100","text":"received a revised Flood Insurance Rate Map from the Federal Emergency Management Agency, via a Letter of Final Determination, after , and prior to ;September 30, 2008July 6, 2012","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s4104–1/a/3/B","parentIdentifier":"/us/usc/t42/s4104–1/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa%2F3%2FB","sourceRelease":"119-100","text":"has subsequently applied for a Letter of Map Revision or Physical Map Revision with the Federal Emergency Management Agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s4104–1/a/3/C","parentIdentifier":"/us/usc/t42/s4104–1/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fa%2F3%2FC","sourceRelease":"119-100","text":"has received an unfavorable ruling on their request for a map revision.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Membership","label":"b Membership","identifier":"/us/usc/t42/s4104–1/b","parentIdentifier":"/us/usc/t42/s4104–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fb","sourceRelease":"119-100","text":"The Scientific Resolution Panel made available under subsection (a) shall consist of 5 members with expertise that relates to the creation and study of flood hazard maps and flood insurance. The Scientific Resolution Panel may include representatives from Federal agencies not involved in the mapping study in question and from other impartial experts. Employees of the Federal Emergency Management Agency may not serve on the Scientific Resolution Panel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Determination","label":"c Determination","identifier":"/us/usc/t42/s4104–1/c","parentIdentifier":"/us/usc/t42/s4104–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s4104–1/c/1","parentIdentifier":"/us/usc/t42/s4104–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F1","sourceRelease":"119-100","text":"Following deliberations, and not later than 90 days after its formation, the Scientific Resolution Panel shall issue a determination of resolution of the dispute. Such determination shall set forth recommendations for the base flood elevation determination or the designation of an area having special flood hazards that shall be reflected in the Flood Insurance Rate Maps.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Basis","label":"2 Basis","identifier":"/us/usc/t42/s4104–1/c/2","parentIdentifier":"/us/usc/t42/s4104–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s4104–1/c/2/A","parentIdentifier":"/us/usc/t42/s4104–1/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F2%2FA","sourceRelease":"119-100","text":"data previously provided to the Administrator by the community, and, in the case of a dispute submitted under subsection (a)(2), an owner or lessee of real property in the community; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s4104–1/c/2/B","parentIdentifier":"/us/usc/t42/s4104–1/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F2%2FB","sourceRelease":"119-100","text":"data provided by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"No alternative determinations permissible","label":"3 No alternative determinations permissible","identifier":"/us/usc/t42/s4104–1/c/3","parentIdentifier":"/us/usc/t42/s4104–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s4104–1/c/3/A","parentIdentifier":"/us/usc/t42/s4104–1/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s4104–1/c/3/A/i","parentIdentifier":"/us/usc/t42/s4104–1/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F3%2FA%2Fi","sourceRelease":"119-100","text":"is either in favor of the Administrator or in favor of the community on each distinct element of the dispute; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s4104–1/c/3/A/ii","parentIdentifier":"/us/usc/t42/s4104–1/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F3%2FA%2Fii","sourceRelease":"119-100","text":"in the case of a dispute submitted under subsection (a)(2), is in favor of the Administrator, in favor of the community, or in favor of the owner or lessee of real property in the community on each distinct element of the dispute; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s4104–1/c/3/B","parentIdentifier":"/us/usc/t42/s4104–1/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F3%2FB","sourceRelease":"119-100","text":"may not offer as a resolution any other alternative determination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Effect of determination","label":"4 Effect of determination","identifier":"/us/usc/t42/s4104–1/c/4","parentIdentifier":"/us/usc/t42/s4104–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Binding","label":"A Binding","identifier":"/us/usc/t42/s4104–1/c/4/A","parentIdentifier":"/us/usc/t42/s4104–1/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s4104–1/c/4/A/i","parentIdentifier":"/us/usc/t42/s4104–1/c/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F4%2FA%2Fi","sourceRelease":"119-100","text":"pose a significant threat due to failure to identify a substantial risk of special flood hazards; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s4104–1/c/4/A/ii","parentIdentifier":"/us/usc/t42/s4104–1/c/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F4%2FA%2Fii","sourceRelease":"119-100","text":"violate applicable law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Written justification not to enforce","label":"B Written justification not to enforce","identifier":"/us/usc/t42/s4104–1/c/4/B","parentIdentifier":"/us/usc/t42/s4104–1/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F4%2FB","sourceRelease":"119-100","text":"If the Administrator elects not to implement the determination of the Scientific Resolution Panel pursuant to subparagraph (A), then not later than 60 days after the issuance of the determination, the Administrator shall issue a written justification explaining such election.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Appeal of determination not to enforce","label":"C Appeal of determination not to enforce","identifier":"/us/usc/t42/s4104–1/c/4/C","parentIdentifier":"/us/usc/t42/s4104–1/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fc%2F4%2FC","sourceRelease":"119-100","text":"If the Administrator elects not to implement the determination of the Scientific Resolution Panel pursuant to subparagraph (A), the community may appeal the determination of the Administrator as provided for under .section 4104(g) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Maps used for insurance and mandatory purchase requirements","label":"d Maps used for insurance and mandatory purchase requirements","identifier":"/us/usc/t42/s4104–1/d","parentIdentifier":"/us/usc/t42/s4104–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s4104–1/d/1","parentIdentifier":"/us/usc/t42/s4104–1/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fd%2F1","sourceRelease":"119-100","text":"the Flood Insurance Rate Map described in the most recently issued Letter of Final Determination shall be in force and effect with respect to such community; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s4104–1/d/2","parentIdentifier":"/us/usc/t42/s4104–1/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4104%E2%80%931%2Fd%2F2","sourceRelease":"119-100","text":"flood insurance shall continue to be made available to the property owners and residents of the participating community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
