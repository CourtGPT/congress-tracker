{"type":"section","nativeType":"section","number":"430f–6","heading":"Corinth Unit of the Shiloh National Military Park; findings and purposes","label":"430f–6 Corinth Unit of the Shiloh National Military Park; findings and purposes","identifier":"/us/usc/t16/s430f–6","parentIdentifier":"/us/usc/t16/ch1/schLX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Short Title, , , provided that:Pub. L. 106–271, § 1114 Stat. 792Sept. 22, 2000“This Act [enacting this section and sections 430f–7 to 430f–12 of this title] may be cited as the ‘Corinth Battlefield Preservation Act of 2000’.”"],"amendments":["Short Title, , , provided that:Pub. L. 106–271, § 1114 Stat. 792Sept. 22, 2000“This Act [enacting this section and sections 430f–7 to 430f–12 of this title] may be cited as the ‘Corinth Battlefield Preservation Act of 2000’.”"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Findings","label":"a Findings","identifier":"/us/usc/t16/s430f–6/a","parentIdentifier":"/us/usc/t16/s430f–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s430f–6/a/1","parentIdentifier":"/us/usc/t16/s430f–6/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s430f–6/a/1/A","parentIdentifier":"/us/usc/t16/s430f–6/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fa%2F1%2FA","sourceRelease":"119-100","text":"to facilitate the interpretation of the Siege and Battle of Corinth and other Civil War actions in the area in and around the city of Corinth, Mississippi; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s430f–6/a/1/B","parentIdentifier":"/us/usc/t16/s430f–6/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s430f–6/a/1/B/i","parentIdentifier":"/us/usc/t16/s430f–6/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"State or local governmental entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s430f–6/a/1/B/ii","parentIdentifier":"/us/usc/t16/s430f–6/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"private organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s430f–6/a/1/B/iii","parentIdentifier":"/us/usc/t16/s430f–6/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fa%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s430f–6/a/2","parentIdentifier":"/us/usc/t16/s430f–6/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fa%2F2","sourceRelease":"119-100","text":"the Corinth Battlefield was ranked as a priority 1 battlefield having critical need for coordinated nationwide action by the year 2000 by the Civil War Sites Advisory Commission in its report on Civil War Battlefields of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s430f–6/a/3","parentIdentifier":"/us/usc/t16/s430f–6/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fa%2F3","sourceRelease":"119-100","text":"there is a national interest in protecting and preserving sites of historic significance associated with the Civil War; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s430f–6/a/4","parentIdentifier":"/us/usc/t16/s430f–6/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s430f–6/a/4/A","parentIdentifier":"/us/usc/t16/s430f–6/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fa%2F4%2FA","sourceRelease":"119-100","text":"have the authority to prevent or minimize adverse uses of these historic resources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s430f–6/a/4/B","parentIdentifier":"/us/usc/t16/s430f–6/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fa%2F4%2FB","sourceRelease":"119-100","text":"can play a significant role in the protection of the historic resources related to the Civil War battles fought in the area in and around the city of Corinth.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purposes","label":"b Purposes","identifier":"/us/usc/t16/s430f–6/b","parentIdentifier":"/us/usc/t16/s430f–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s430f–6/b/1","parentIdentifier":"/us/usc/t16/s430f–6/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s430f–6/b/1/A","parentIdentifier":"/us/usc/t16/s430f–6/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fb%2F1%2FA","sourceRelease":"119-100","text":"in the city of Corinth, Mississippi; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s430f–6/b/1/B","parentIdentifier":"/us/usc/t16/s430f–6/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs430f%E2%80%936%2Fb%2F1%2FB","sourceRelease":"119-100","text":"in the State of Tennessee;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s430f–6/b/2",