{"type":"section","nativeType":"section","number":"4013","heading":"Petitions","label":"4013 Petitions","identifier":"/us/usc/t16/s4013","parentIdentifier":"/us/usc/t16/ch60","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4013","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Filing of petition","label":"a Filing of petition","identifier":"/us/usc/t16/s4013/a","parentIdentifier":"/us/usc/t16/s4013","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4013%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s4013/a/1","parentIdentifier":"/us/usc/t16/s4013/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4013%2Fa%2F1","sourceRelease":"119-100","text":"the assessment,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s4013/a/2","parentIdentifier":"/us/usc/t16/s4013/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4013%2Fa%2F2","sourceRelease":"119-100","text":"the plan approved under on which the assessment is based, orsection 4011(a)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s4013/a/3","parentIdentifier":"/us/usc/t16/s4013/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4013%2Fa%2F3","sourceRelease":"119-100","text":"any obligation imposed under the plan,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Form of petition","label":"b Form of petition","identifier":"/us/usc/t16/s4013/b","parentIdentifier":"/us/usc/t16/s4013","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4013%2Fb","sourceRelease":"119-100","text":"Any such petition shall be in writing and filed within the period prescribed by the Secretary. A person who files a petition under this section shall be given an opportunity for a hearing regarding the petition in accordance with regulations issued by the Secretary. After such a hearing, or if no hearing is requested, after consideration of all documentation and other evidence, the Secretary shall make a ruling upon such petition.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
