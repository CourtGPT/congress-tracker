{"type":"section","nativeType":"section","number":"4263","heading":"United States leadership in international FORA","label":"4263 United States leadership in international FORA","identifier":"/us/usc/t33/s4263","parentIdentifier":"/us/usc/t33/ch55/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s4263/1","parentIdentifier":"/us/usc/t33/s4263","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F1","sourceRelease":"119-100","text":"commit to significantly increasing efforts to promote investment in well-designed post-consumer materials management and plastic waste elimination and mitigation projects and services that increase access to safe post-consumer materials management and mitigation services, in partnership with the private sector and consistent with the constraints of other countries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s4263/2","parentIdentifier":"/us/usc/t33/s4263","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F2","sourceRelease":"119-100","text":"address the post-consumer materials management needs of individuals and communities where access to municipal post-consumer materials management services is historically impractical or cost-prohibitive;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s4263/3","parentIdentifier":"/us/usc/t33/s4263","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s4263/3/A","parentIdentifier":"/us/usc/t33/s4263/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F3%2FA","sourceRelease":"119-100","text":"to increase access to solid waste and post-consumer materials management services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s4263/3/B","parentIdentifier":"/us/usc/t33/s4263/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F3%2FB","sourceRelease":"119-100","text":"to utilize safe and affordable alternatives to disposable plastic products, to the extent practicable;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s4263/3/C","parentIdentifier":"/us/usc/t33/s4263/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F3%2FC","sourceRelease":"119-100","text":"to encourage and incentivize the use of recycled content; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t33/s4263/3/D","parentIdentifier":"/us/usc/t33/s4263/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F3%2FD","sourceRelease":"119-100","text":"to grow economic opportunities and develop markets for recyclable, compostable, reusable, and repurposed plastic waste materials and post-consumer materials and other efforts that support the circular economy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s4263/4","parentIdentifier":"/us/usc/t33/s4263","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s4263/4/A","parentIdentifier":"/us/usc/t33/s4263/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F4%2FA","sourceRelease":"119-100","text":"post-consumer materials management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s4263/4/B","parentIdentifier":"/us/usc/t33/s4263/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F4%2FB","sourceRelease":"119-100","text":"the use of safe and affordable alternatives to disposable plastic products; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s4263/4/C","parentIdentifier":"/us/usc/t33/s4263/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F4%2FC","sourceRelease":"119-100","text":"beneficial reuse of solid waste, plastic waste, post-consumer materials, plastic products, and refuse;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t33/s4263/5","parentIdentifier":"/us/usc/t33/s4263","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F5","sourceRelease":"119-100","text":"use clear, accountable, and metric-based targets to measure the effectiveness of such projects; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t33/s4263/6","parentIdentifier":"/us/usc/t33/s4263","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s4263/6/A","parentIdentifier":"/us/usc/t33/s4263/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FA","sourceRelease":"119-100","text":"creating tangible metrics for evaluating efforts to reduce plastic waste and marine debris;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s4263/6/B","parentIdentifier":"/us/usc/t33/s4263/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s4263/6/B/i","parentIdentifier":"/us/usc/t33/s4263/6/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FB%2Fi","sourceRelease":"119-100","text":"collecting, disposing, recycling, and reusing plastic waste and post-consumer materials, including building capacity for improving post-consumer materials management; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s4263/6/B/ii","parentIdentifier":"/us/usc/t33/s4263/6/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FB%2Fii","sourceRelease":"119-100","text":"integrating alternatives to disposable plastic products, to the extent practicable;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s4263/6/C","parentIdentifier":"/us/usc/t33/s4263/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FC","sourceRelease":"119-100","text":"encouraging the development of standards and practices, and increasing recycled content percentage requirements for disposable plastic products;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t33/s4263/6/D","parentIdentifier":"/us/usc/t33/s4263/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FD","sourceRelease":"119-100","text":"integrating tracking and monitoring systems into post-consumer materials management systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t33/s4263/6/E","parentIdentifier":"/us/usc/t33/s4263/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s4263/6/E/i","parentIdentifier":"/us/usc/t33/s4263/6/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FE%2Fi","sourceRelease":"119-100","text":"how microfibers and microplastics may affect marine ecosystems, human health and safety, and maritime activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s4263/6/E/ii","parentIdentifier":"/us/usc/t33/s4263/6/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FE%2Fii","sourceRelease":"119-100","text":"changes in the amount and regional concentrations of plastic waste in the ocean, based on scientific modeling and forecasting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t33/s4263/6/E/iii","parentIdentifier":"/us/usc/t33/s4263/6/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FE%2Fiii","sourceRelease":"119-100","text":"the role rivers, streams, and other inland waterways play in serving as conduits for mismanaged waste traveling from land to the ocean;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t33/s4263/6/E/iv","parentIdentifier":"/us/usc/t33/s4263/6/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FE%2Fiv","sourceRelease":"119-100","text":"effective means to eliminate present and future leakages of plastic waste into the environment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t33/s4263/6/E/v","parentIdentifier":"/us/usc/t33/s4263/6/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FE%2Fv","sourceRelease":"119-100","text":"other related areas of research the United States representatives deem necessary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t33/s4263/6/F","parentIdentifier":"/us/usc/t33/s4263/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FF","sourceRelease":"119-100","text":"encouraging the World Bank and other international finance organizations to prioritize efforts to reduce plastic waste and combat marine debris;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t33/s4263/6/G","parentIdentifier":"/us/usc/t33/s4263/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FG","sourceRelease":"119-100","text":"collaborating on technological advances in post-consumer materials management and recycled plastics;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t33/s4263/6/H","parentIdentifier":"/us/usc/t33/s4263/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FH","sourceRelease":"119-100","text":"growing economic opportunities and developing markets for recyclable, compostable, reusable, and repurposed plastic waste and post-consumer materials and other efforts that support the circular economy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t33/s4263/6/I","parentIdentifier":"/us/usc/t33/s4263/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FI","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s4263/6/I/i","parentIdentifier":"/us/usc/t33/s4263/6/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FI%2Fi","sourceRelease":"119-100","text":"solid waste;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s4263/6/I/ii","parentIdentifier":"/us/usc/t33/s4263/6/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FI%2Fii","sourceRelease":"119-100","text":"post-consumer materials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t33/s4263/6/I/iii","parentIdentifier":"/us/usc/t33/s4263/6/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FI%2Fiii","sourceRelease":"119-100","text":"plastic waste; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t33/s4263/6/I/iv","parentIdentifier":"/us/usc/t33/s4263/6/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4263%2F6%2FI%2Fiv","sourceRelease":"119-100","text":"marine debris.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
