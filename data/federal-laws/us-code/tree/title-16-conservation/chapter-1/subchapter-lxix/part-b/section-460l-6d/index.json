ication issue a de minimis use authorization for the filming or still photography activity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":"Terms","label":"F Terms","identifier":"/us/usc/t16/s460l–6d/a/3/F","parentIdentifier":"/us/usc/t16/s460l–6d/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F3%2FF","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460l–6d/a/3/F/i","parentIdentifier":"/us/usc/t16/s460l–6d/a/3/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F3%2FF%2Fi","sourceRelease":"119-100","text":"involves a group of not fewer than 6 individuals and not more than 8 individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460l–6d/a/3/F/ii","parentIdentifier":"/us/usc/t16/s460l–6d/a/3/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F3%2FF%2Fii","sourceRelease":"119-100","text":"meets each of the requirements described in paragraph (5); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s460l–6d/a/3/F/iii","parentIdentifier":"/us/usc/t16/s460l–6d/a/3/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F3%2FF%2Fiii","sourceRelease":"119-100","text":"is consistent with subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":"Contents","label":"G Contents","identifier":"/us/usc/t16/s460l–6d/a/3/G","parentIdentifier":"/us/usc/t16/s460l–6d/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F3%2FG","sourceRelease":"119-100","text":"A de minimis use authorization issued under this paragraph shall list the requirements described in subparagraph (F).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Required permits","label":"4 Required permits","identifier":"/us/usc/t16/s460l–6d/a/4","parentIdentifier":"/us/usc/t16/s460l–6d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s460l–6d/a/4/A","parentIdentifier":"/us/usc/t16/s460l–6d/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460l–6d/a/4/A/i","parentIdentifier":"/us/usc/t16/s460l–6d/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F4%2FA%2Fi","sourceRelease":"119-100","text":"involves more than 8 individuals; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460l–6d/a/4/A/ii","parentIdentifier":"/us/usc/t16/s460l–6d/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F4%2FA%2Fii","sourceRelease":"119-100","text":"does not meet each of the requirements described in paragraph (5).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Wilderness Act clarification","label":"B Wilderness Act clarification","identifier":"/us/usc/t16/s460l–6d/a/4/B","parentIdentifier":"/us/usc/t16/s460l–6d/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F4%2FB","sourceRelease":"119-100","text":"No provision of this subsection is intended to or shall be construed to conflict with the provisions of the Wilderness Act of 1964 ( et seq.).16 U.S.C. 1131","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Requirements for filming or still photography activity","label":"5 Requirements for filming or still photography activity","identifier":"/us/usc/t16/s460l–6d/a/5","parentIdentifier":"/us/usc/t16/s460l–6d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460l–6d/a/5/A","parentIdentifier":"/us/usc/t16/s460l–6d/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460l–6d/a/5/A/i","parentIdentifier":"/us/usc/t16/s460l–6d/a/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5%2FA%2Fi","sourceRelease":"119-100","text":"does not impede or intrude on the experience of other visitors to the Federal land management unit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460l–6d/a/5/A/ii","parentIdentifier":"/us/usc/t16/s460l–6d/a/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s460l–6d/a/5/A/ii/I","parentIdentifier":"/us/usc/t16/s460l–6d/a/5/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5%2FA%2Fii%2FI","sourceRelease":"119-100","text":"a natural or cultural resource; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s460l–6d/a/5/A/ii/II","parentIdentifier":"/us/usc/t16/s460l–6d/a/5/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5%2FA%2Fii%2FII","sourceRelease":"119-100","text":"an environmental or scenic value; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s460l–6d/a/5/A/iii","parentIdentifier":"/us/usc/t16/s460l–6d/a/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5%2FA%2Fiii","sourceRelease":"119-100","text":"allows for equitable allocation or use of facilities of the Federal land management unit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460l–6d/a/5/B","parentIdentifier":"/us/usc/t16/s460l–6d/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5%2FB","sourceRelease":"119-100","text":"The person conducts the filming or still photography activity at a location in which the public is allowed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s460l–6d/a/5/C","parentIdentifier":"/us/usc/t16/s460l–6d/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5%2FC","sourceRelease":"119-100","text":"The person conducting the filming or still photography activity does not require the exclusive use of a site or area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s460l–6d/a/5/D","parentIdentifier":"/us/usc/t16/s460l–6d/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5%2FD","sourceRelease":"119-100","text":"The person does not conduct the filming or still photography activity in a localized area that receives a very high volume of visitation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s460l–6d/a/5/E","parentIdentifier":"/us/usc/t16/s460l–6d/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5%2FE","sourceRelease":"119-100","text":"The person conducting the filming or still photography activity does not use a set or staging equipment, subject to the limitation that handheld equipment (such as a tripod, monopod, and handheld lighting equipment) shall not be considered staging equipment for the purposes of this subparagraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t16/s460l–6d/a/5/F","parentIdentifier":"/us/usc/t16/s460l–6d/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5%2FF","sourceRelease":"119-100","text":"The person conducting the filming or still photography activity complies with and adheres to visitor use policies, practices, and regulations applicable to the Federal land management unit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t16/s460l–6d/a/5/G","parentIdentifier":"/us/usc/t16/s460l–6d/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5%2FG","sourceRelease":"119-100","text":"The filming or still photography activity is not likely to result in additional administrative costs being incurred by the Secretary concerned with respect to the filming or still photography activity, as determined by the Secretary concerned.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t16/s460l–6d/a/5/H","parentIdentifier":"/us/usc/t16/s460l–6d/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F5%2FH","sourceRelease":"119-100","text":"The person conducting the filming or still photography activity complies with other applicable Federal, State (as such term is defined in section 3 of the EXPLORE Act), and local laws (including regulations), including laws relating to the use of unmanned aerial equipment.3See References in Text note below.3","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Content creation","label":"6 Content creation","identifier":"/us/usc/t16/s460l–6d/a/6","parentIdentifier":"/us/usc/t16/s460l–6d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F6","sourceRelease":"119-100","text":"Regardless of distribution platform, any video, still photograph, or audio recording for commercial or noncommercial content creation at a Federal land management unit shall be considered to be a filming or still photography activity under this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Effect","label":"7 Effect","identifier":"/us/usc/t16/s460l–6d/a/7","parentIdentifier":"/us/usc/t16/s460l–6d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Permits requested though not required","label":"A Permits requested though not required","identifier":"/us/usc/t16/s460l–6d/a/7/A","parentIdentifier":"/us/usc/t16/s460l–6d/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F7%2FA","sourceRelease":"119-100","text":"On the request of a person intending to carry out a filming or still photography activity, the Secretary concerned may issue a permit for the filming or still photography activity, even if a permit for the filming or still photography activity is not required under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"No additional permits, commercial use authorizations, or fees for filming and still photography at authorized events","label":"B No additional permits, commercial use authorizations, or fees for filming and still photography at authorized events","identifier":"/us/usc/t16/s460l–6d/a/7/B","parentIdentifier":"/us/usc/t16/s460l–6d/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F7%2FB","sourceRelease":"119-100","text":"A filming or still photography activity at an activity or event that is allowed or authorized, including a wedding, engagement party, family reunion, or celebration of a graduate, shall be considered merely incidental for the purposes of paragraph (2)(B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Monetary compensation","label":"C Monetary compensation","identifier":"/us/usc/t16/s460l–6d/a/7/C","parentIdentifier":"/us/usc/t16/s460l–6d/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F7%2FC","sourceRelease":"119-100","text":"The receipt of monetary compensation by the person engaged in the filming or still photography activity shall not affect the permissibility of the filming or still photography activity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Fees and recovery costs","label":"b Fees and recovery costs","identifier":"/us/usc/t16/s460l–6d/b","parentIdentifier":"/us/usc/t16/s460l–6d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Fees","label":"1 Fees","identifier":"/us/usc/t16/s460l–6d/b/1","parentIdentifier":"/us/usc/t16/s460l–6d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460l–6d/b/1/A","parentIdentifier":"/us/usc/t16/s460l–6d/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F1%2FA","sourceRelease":"119-100","text":"The reasonable fee shall provide a fair return to the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460l–6d/b/1/B","parentIdentifier":"/us/usc/t16/s460l–6d/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460l–6d/b/1/B/i","parentIdentifier":"/us/usc/t16/s460l–6d/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"The number of days of the filming or still photography activity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460l–6d/b/1/B/ii","parentIdentifier":"/us/usc/t16/s460l–6d/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"The size of the film or still photography crew present at the Federal land management unit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s460l–6d/b/1/B/iii","parentIdentifier":"/us/usc/t16/s460l–6d/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"The quantity and type of film or still photography equipment present at the Federal land management unit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s460l–6d/b/1/B/iv","parentIdentifier":"/us/usc/t16/s460l–6d/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"Any other factors that the Secretary concerned determines to be necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Recovery of costs","label":"2 Recovery of costs","identifier":"/us/usc/t16/s460l–6d/b/2","parentIdentifier":"/us/usc/t16/s460l–6d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s460l–6d/b/2/A","parentIdentifier":"/us/usc/t16/s460l–6d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460l–6d/b/2/A/i","parentIdentifier":"/us/usc/t16/s460l–6d/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the costs of the review or issuance of the permit; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460l–6d/b/2/A/ii","parentIdentifier":"/us/usc/t16/s460l–6d/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"related administrative and personnel costs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Effect on fees collected","label":"B Effect on fees collected","identifier":"/us/usc/t16/s460l–6d/b/2/B","parentIdentifier":"/us/usc/t16/s460l–6d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F2%2FB","sourceRelease":"119-100","text":"All costs recovered under subparagraph (A) shall be in addition to the fee described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Use of proceeds","label":"3 Use of proceeds","identifier":"/us/usc/t16/s460l–6d/b/3","parentIdentifier":"/us/usc/t16/s460l–6d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Fees","label":"A Fees","identifier":"/us/usc/t16/s460l–6d/b/3/A","parentIdentifier":"/us/usc/t16/s460l–6d/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460l–6d/b/3/A/i","parentIdentifier":"/us/usc/t16/s460l–6d/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F3%2FA%2Fi","sourceRelease":"119-100","text":"be available for expenditure by the Secretary concerned, without further appropriation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460l–6d/b/3/A/ii","parentIdentifier":"/us/usc/t16/s460l–6d/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F3%2FA%2Fii","sourceRelease":"119-100","text":"remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Costs","label":"B Costs","identifier":"/us/usc/t16/s460l–6d/b/3/B","parentIdentifier":"/us/usc/t16/s460l–6d/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460l–6d/b/3/B/i","parentIdentifier":"/us/usc/t16/s460l–6d/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"be available for expenditure by the Secretary concerned, without further appropriation, at the Federal land management unit at which the costs are collected; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460l–6d/b/3/B/ii","parentIdentifier":"/us/usc/t16/s460l–6d/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Protection of resources","label":"c Protection of resources","identifier":"/us/usc/t16/s460l–6d/c","parentIdentifier":"/us/usc/t16/s460l–6d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460l–6d/c/1","parentIdentifier":"/us/usc/t16/s460l–6d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fc%2F1","sourceRelease":"119-100","text":"there is a likelihood that the person would cause resource damage at the Federal land management unit, except as otherwise authorized;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460l–6d/c/2","parentIdentifier":"/us/usc/t16/s460l–6d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fc%2F2","sourceRelease":"119-100","text":"the person would create an unreasonable disruption of the use and enjoyment by the public of the Federal land management unit; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s460l–6d/c/3","parentIdentifier":"/us/usc/t16/s460l–6d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fc%2F3","sourceRelease":"119-100","text":"the filming or still photography activity poses a health or safety risk to the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Processing of permit applications","label":"d Processing of permit applications","identifier":"/us/usc/t16/s460l–6d/d","parentIdentifier":"/us/usc/t16/s460l–6d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1