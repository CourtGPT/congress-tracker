{"type":"section","nativeType":"section","number":"19016","heading":"Chief Diversity Officer of the NSF","label":"19016 Chief Diversity Officer of the NSF","identifier":"/us/usc/t42/s19016","parentIdentifier":"/us/usc/t42/ch163/schIII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Chief Diversity Officer","label":"a Chief Diversity Officer","identifier":"/us/usc/t42/s19016/a","parentIdentifier":"/us/usc/t42/s19016","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Appointment","label":"1 Appointment","identifier":"/us/usc/t42/s19016/a/1","parentIdentifier":"/us/usc/t42/s19016/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fa%2F1","sourceRelease":"119-100","text":"The Director shall appoint a senior agency official within the Office of the Director as a Chief Diversity Officer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Qualifications","label":"2 Qualifications","identifier":"/us/usc/t42/s19016/a/2","parentIdentifier":"/us/usc/t42/s19016/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19016/a/2/A","parentIdentifier":"/us/usc/t42/s19016/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fa%2F2%2FA","sourceRelease":"119-100","text":"civil rights compliance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19016/a/2/B","parentIdentifier":"/us/usc/t42/s19016/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fa%2F2%2FB","sourceRelease":"119-100","text":"harassment policy, reviews, and investigations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s19016/a/2/C","parentIdentifier":"/us/usc/t42/s19016/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fa%2F2%2FC","sourceRelease":"119-100","text":"equal employment opportunity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s19016/a/2/D","parentIdentifier":"/us/usc/t42/s19016/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fa%2F2%2FD","sourceRelease":"119-100","text":"disability policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties","label":"b Duties","identifier":"/us/usc/t42/s19016/b","parentIdentifier":"/us/usc/t42/s19016","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19016/b/1","parentIdentifier":"/us/usc/t42/s19016/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fb%2F1","sourceRelease":"119-100","text":"establishing and maintaining a strategic plan that publicly states a diversity definition, vision, and goals for the Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19016/b/2","parentIdentifier":"/us/usc/t42/s19016/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19016/b/2/A","parentIdentifier":"/us/usc/t42/s19016/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fb%2F2%2FA","sourceRelease":"119-100","text":"directly linked to key organizational priorities and goals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19016/b/2/B","parentIdentifier":"/us/usc/t42/s19016/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fb%2F2%2FB","sourceRelease":"119-100","text":"actionable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s19016/b/2/C","parentIdentifier":"/us/usc/t42/s19016/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fb%2F2%2FC","sourceRelease":"119-100","text":"actively used to implement the strategic plan under paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19016/b/3","parentIdentifier":"/us/usc/t42/s19016/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fb%2F3","sourceRelease":"119-100","text":"advising in the establishment of a strategic plan for diverse participation by individuals and institutions of higher education, including community colleges, historically Black colleges and universities, Tribal Colleges or Universities, minority serving institutions, institutions of higher education with an established STEM capacity building program focused on Native Hawaiians or Alaska Natives, and EPSCoR institutions);1So in original. The closing parenthesis probably should not appear.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s19016/b/4","parentIdentifier":"/us/usc/t42/s19016/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fb%2F4","sourceRelease":"119-100","text":"advising in the establishment of a strategic plan for outreach to, and recruiting from, untapped locations and underrepresented populations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s19016/b/5","parentIdentifier":"/us/usc/t42/s19016/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fb%2F5","sourceRelease":"119-100","text":"advising on a diversity and inclusion strategy for the Foundation’s portfolio of PreK–12 STEM education focused programs and activities, including goals for addressing barriers to participation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s19016/b/6","parentIdentifier":"/us/usc/t42/s19016/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fb%2F6","sourceRelease":"119-100","text":"advising on the application of the Foundation’s broader impacts review criterion; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s19016/b/7","parentIdentifier":"/us/usc/t42/s19016/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fb%2F7","sourceRelease":"119-100","text":"performing such additional duties and exercise such powers as the Director may prescribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t42/s19016/c","parentIdentifier":"/us/usc/t42/s19016","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19016%2Fc","sourceRelease":"119-100","text":"To carry out this section, there are authorized to be appropriated $5,000,000 for each of fiscal years 2023 through 2027.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
