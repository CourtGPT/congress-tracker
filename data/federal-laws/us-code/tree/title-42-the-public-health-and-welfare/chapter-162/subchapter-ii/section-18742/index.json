/s18742/a/6/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F6%2FA%2Fii%2FI","sourceRelease":"119-100","text":"low- or zero-carbon process heat systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s18742/a/6/A/ii/II","parentIdentifier":"/us/usc/t42/s18742/a/6/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F6%2FA%2Fii%2FII","sourceRelease":"119-100","text":"carbon capture, transport, utilization, and storage systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t42/s18742/a/6/A/ii/III","parentIdentifier":"/us/usc/t42/s18742/a/6/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F6%2FA%2Fii%2FIII","sourceRelease":"119-100","text":"technology relating to energy efficiency and reduction in waste from industrial processes; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t42/s18742/a/6/A/ii/IV","parentIdentifier":"/us/usc/t42/s18742/a/6/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F6%2FA%2Fii%2FIV","sourceRelease":"119-100","text":"any other industrial technology that significantly reduces greenhouse gas emissions, as determined by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18742/a/6/B","parentIdentifier":"/us/usc/t42/s18742/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F6%2FB","sourceRelease":"119-100","text":"has a reasonable expectation of commercial viability, as determined by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18742/a/6/C","parentIdentifier":"/us/usc/t42/s18742/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F6%2FC","sourceRelease":"119-100","text":"is located in a covered census tract.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t42/s18742/b","parentIdentifier":"/us/usc/t42/s18742","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fb","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary shall establish a program to award grants to eligible entities to carry out qualifying advanced energy projects.November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Applications","label":"c Applications","identifier":"/us/usc/t42/s18742/c","parentIdentifier":"/us/usc/t42/s18742","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18742/c/1","parentIdentifier":"/us/usc/t42/s18742/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F1","sourceRelease":"119-100","text":"Each eligible entity seeking a grant under the Program shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including a description of the proposed qualifying advanced energy project to be carried out using the grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Selection criteria","label":"2 Selection criteria","identifier":"/us/usc/t42/s18742/c/2","parentIdentifier":"/us/usc/t42/s18742/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Projects","label":"A Projects","identifier":"/us/usc/t42/s18742/c/2/A","parentIdentifier":"/us/usc/t42/s18742/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18742/c/2/A/i","parentIdentifier":"/us/usc/t42/s18742/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"will provide higher net impact in avoiding or reducing anthropogenic emissions of greenhouse gases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18742/c/2/A/ii","parentIdentifier":"/us/usc/t42/s18742/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":"will result in a higher level of domestic job creation (both direct and indirect) during the lifetime of the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s18742/c/2/A/iii","parentIdentifier":"/us/usc/t42/s18742/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F2%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s18742/c/2/A/iii/I","parentIdentifier":"/us/usc/t42/s18742/c/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F2%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"low-income communities (as described in section 45D(e) of the Internal Revenue Code of 1986); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s18742/c/2/A/iii/II","parentIdentifier":"/us/usc/t42/s18742/c/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F2%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"dislocated workers who were previously employed in manufacturing, coal power plants, or coal mining;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s18742/c/2/A/iv","parentIdentifier":"/us/usc/t42/s18742/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"have higher potential for technological innovation and commercial deployment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s18742/c/2/A/v","parentIdentifier":"/us/usc/t42/s18742/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F2%2FA%2Fv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s18742/c/2/A/v/I","parentIdentifier":"/us/usc/t42/s18742/c/2/A/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F2%2FA%2Fv%2FI","sourceRelease":"119-100","text":"generated or stored energy; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s18742/c/2/A/v/II","parentIdentifier":"/us/usc/t42/s18742/c/2/A/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F2%2FA%2Fv%2FII","sourceRelease":"119-100","text":"measured reduction in energy consumption or greenhouse gas emission (based on costs of the full supply chain); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s18742/c/2/A/vi","parentIdentifier":"/us/usc/t42/s18742/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F2%2FA%2Fvi","sourceRelease":"119-100","text":"have a shorter project time.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Eligible entities","label":"B Eligible entities","identifier":"/us/usc/t42/s18742/c/2/B","parentIdentifier":"/us/usc/t42/s18742/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fc%2F2%2FB","sourceRelease":"119-100","text":"In selecting eligible entities to receive grants under the Program, the Secretary shall give priority to eligible entities that are minority-owned.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Project completion and location; return of unobligated funds","label":"d Project completion and location; return of unobligated funds","identifier":"/us/usc/t42/s18742/d","parentIdentifier":"/us/usc/t42/s18742","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Completion; return of unobligated funds","label":"1 Completion; return of unobligated funds","identifier":"/us/usc/t42/s18742/d/1","parentIdentifier":"/us/usc/t42/s18742/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18742/d/1/A","parentIdentifier":"/us/usc/t42/s18742/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fd%2F1%2FA","sourceRelease":"119-100","text":"to complete the qualifying advanced energy project funded by the grant not later than 3 years after the date of receipt of the grant funds; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18742/d/1/B","parentIdentifier":"/us/usc/t42/s18742/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fd%2F1%2FB","sourceRelease":"119-100","text":"to return to the Secretary any grant funds that remain unobligated at the end of that 3-year period.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Location","label":"2 Location","identifier":"/us/usc/t42/s18742/d/2","parentIdentifier":"/us/usc/t42/s18742/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fd%2F2","sourceRelease":"119-100","text":"If the Secretary determines that an eligible entity awarded a grant under the Program has carried out the applicable qualifying advanced energy project at a location that is materially different from the location specified in the application for the grant, the eligible entity shall be required to return the grant funds to the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Technical assistance","label":"e Technical assistance","identifier":"/us/usc/t42/s18742/e","parentIdentifier":"/us/usc/t42/s18742","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18742/e/1","parentIdentifier":"/us/usc/t42/s18742/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fe%2F1","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary shall provide technical assistance on a selective basis to eligible entities that are seeking a grant under the Program to enhance the impact of the qualifying advanced energy project to be carried out using the grant with respect to the selection criteria described in subsection (c)(2)(A).November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Applications","label":"2 Applications","identifier":"/us/usc/t42/s18742/e/2","parentIdentifier":"/us/usc/t42/s18742/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fe%2F2","sourceRelease":"119-100","text":"An eligible entity desiring technical assistance under paragraph (1) shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Factors for consideration","label":"3 Factors for consideration","identifier":"/us/usc/t42/s18742/e/3","parentIdentifier":"/us/usc/t42/s18742/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fe%2F3","sourceRelease":"119-100","text":"In selecting eligible entities for technical assistance under paragraph (1), the Secretary shall give higher priority to eligible entities that propose a qualifying advanced energy project that has greater potential for enhancement of the impact of the project with respect to the selection criteria described in subsection (c)(2)(A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Publication of grants","label":"f Publication of grants","identifier":"/us/usc/t42/s18742/f","parentIdentifier":"/us/usc/t42/s18742","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Ff","sourceRelease":"119-100","text":"The Secretary shall make publicly available the identity of each eligible entity awarded a grant under the Program and the amount of the grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Report","label":"g Report","identifier":"/us/usc/t42/s18742/g","parentIdentifier":"/us/usc/t42/s18742","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18742/g/1","parentIdentifier":"/us/usc/t42/s18742/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fg%2F1","sourceRelease":"119-100","text":"review the grants awarded under the Program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18742/g/2","parentIdentifier":"/us/usc/t42/s18742/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fg%2F2","sourceRelease":"119-100","text":"submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Energy and Commerce of the House of Representatives a report describing those grants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Authorization of appropriations","label":"h Authorization of appropriations","identifier":"/us/usc/t42/s18742/h","parentIdentifier":"/us/usc/t42/s18742","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fh","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary to carry out the Program $750,000,000 for the period of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
