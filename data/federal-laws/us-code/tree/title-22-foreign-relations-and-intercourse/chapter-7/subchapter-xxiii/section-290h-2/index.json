{"type":"section","nativeType":"section","number":"290h–2","heading":"Congressional declaration of purposes","label":"290h–2 Congressional declaration of purposes","identifier":"/us/usc/t22/s290h–2","parentIdentifier":"/us/usc/t22/ch7/schXXIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290h%E2%80%932","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purposes of Foundation","label":"a Purposes of Foundation","identifier":"/us/usc/t22/s290h–2/a","parentIdentifier":"/us/usc/t22/s290h–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290h%E2%80%932%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s290h–2/a/1","parentIdentifier":"/us/usc/t22/s290h–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290h%E2%80%932%2Fa%2F1","sourceRelease":"119-100","text":"to strengthen the bonds of friendship and understanding between the people of Africa and the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s290h–2/a/2","parentIdentifier":"/us/usc/t22/s290h–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290h%E2%80%932%2Fa%2F2","sourceRelease":"119-100","text":"to support self-help activities at the local level designed to enlarge opportunities for community development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s290h–2/a/3","parentIdentifier":"/us/usc/t22/s290h–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290h%E2%80%932%2Fa%2F3","sourceRelease":"119-100","text":"to stimulate and assist effective and expanding participation of Africans in their development process; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s290h–2/a/4","parentIdentifier":"/us/usc/t22/s290h–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290h%E2%80%932%2Fa%2F4","sourceRelease":"119-100","text":"to encourage the establishment and growth of development institutions which are indigenous to particular countries in Africa and which can respond to the requirements of the poor in those countries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Implementation","label":"b Implementation","identifier":"/us/usc/t22/s290h–2/b","parentIdentifier":"/us/usc/t22/s290h–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290h%E2%80%932%2Fb","sourceRelease":"119-100","text":"The Foundation shall carry out the purposes specified in subsection (a) in cooperation with, and in response to, organizations indigenous to Africa which are representative of the needs and aspirations of the poor in Africa and, in carrying out such purposes, the Foundation shall, to the extent possible, coordinate its development assistance activities with the activities of the United States Government and private, regional, and international organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
