{"type":"section","nativeType":"section","number":"8933","heading":"Nationwide sampling","label":"8933 Nationwide sampling","identifier":"/us/usc/t15/s8933","parentIdentifier":"/us/usc/t15/ch115/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s8933/a","parentIdentifier":"/us/usc/t15/s8933","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fa","sourceRelease":"119-100","text":"The Director shall carry out a nationwide sampling to determine the concentration of highly fluorinated compounds in estuaries, lakes, streams, springs, wells, wetlands, rivers, aquifers, and soil using the performance standard developed under .section 8932(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirements","label":"b Requirements","identifier":"/us/usc/t15/s8933/b","parentIdentifier":"/us/usc/t15/s8933","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8933/b/1","parentIdentifier":"/us/usc/t15/s8933/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fb%2F1","sourceRelease":"119-100","text":"first carry out the sampling at sources of drinking water near locations with known or suspected releases of highly fluorinated compounds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8933/b/2","parentIdentifier":"/us/usc/t15/s8933/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fb%2F2","sourceRelease":"119-100","text":"when carrying out sampling of sources of drinking water under paragraph (1), carry out the sampling prior to and, at the request of the Administrator, after any treatment of the water;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8933/b/3","parentIdentifier":"/us/usc/t15/s8933/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fb%2F3","sourceRelease":"119-100","text":"survey for ecological exposure to highly fluorinated compounds, with a priority in determining direct human exposure through drinking water; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s8933/b/4","parentIdentifier":"/us/usc/t15/s8933/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8933/b/4/A","parentIdentifier":"/us/usc/t15/s8933/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fb%2F4%2FA","sourceRelease":"119-100","text":"States to determine areas that are a priority for sampling; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8933/b/4/B","parentIdentifier":"/us/usc/t15/s8933/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fb%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s8933/b/4/B/i","parentIdentifier":"/us/usc/t15/s8933/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fb%2F4%2FB%2Fi","sourceRelease":"119-100","text":"to enhance coverage of the sampling; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s8933/b/4/B/ii","parentIdentifier":"/us/usc/t15/s8933/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fb%2F4%2FB%2Fii","sourceRelease":"119-100","text":"to avoid unnecessary duplication.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Report","label":"c Report","identifier":"/us/usc/t15/s8933/c","parentIdentifier":"/us/usc/t15/s8933","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8933/c/1","parentIdentifier":"/us/usc/t15/s8933/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fc%2F1","sourceRelease":"119-100","text":"the Committee on Environment and Public Works and the Committee on Energy and Natural Resources of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8933/c/2","parentIdentifier":"/us/usc/t15/s8933/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fc%2F2","sourceRelease":"119-100","text":"the Committee on Energy and Commerce and the Committee on Natural Resources of the House of Representatives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8933/c/3","parentIdentifier":"/us/usc/t15/s8933/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fc%2F3","sourceRelease":"119-100","text":"the Senators of each State in which the Director carried out the sampling; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s8933/c/4","parentIdentifier":"/us/usc/t15/s8933/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8933%2Fc%2F4","sourceRelease":"119-100","text":"each Member of the House of Representatives who represents a district in which the Director carried out the sampling.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
