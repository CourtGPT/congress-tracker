{"type":"section","nativeType":"section","number":"7463","heading":"Cloud computing strategy","label":"7463 Cloud computing strategy","identifier":"/us/usc/t15/s7463","parentIdentifier":"/us/usc/t15/ch100A/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7463","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s7463/a","parentIdentifier":"/us/usc/t15/s7463","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7463%2Fa","sourceRelease":"119-100","text":"The Director, in coordination with the Office of Management and Budget, in collaboration with the Federal Chief Information Officers Council, and in consultation with other relevant Federal agencies and stakeholders from the private sector, shall continue to develop and encourage the implementation of a comprehensive strategy for the use and adoption of cloud computing services by the Federal Government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Activities","label":"b Activities","identifier":"/us/usc/t15/s7463/b","parentIdentifier":"/us/usc/t15/s7463","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7463%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7463/b/1","parentIdentifier":"/us/usc/t15/s7463/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7463%2Fb%2F1","sourceRelease":"119-100","text":"accelerate the development, in collaboration with the private sector, of standards that address interoperability and portability of cloud computing services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7463/b/2","parentIdentifier":"/us/usc/t15/s7463/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7463%2Fb%2F2","sourceRelease":"119-100","text":"advance the development of conformance testing performed by the private sector in support of cloud computing standardization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s7463/b/3","parentIdentifier":"/us/usc/t15/s7463/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7463%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7463/b/3/A","parentIdentifier":"/us/usc/t15/s7463/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7463%2Fb%2F3%2FA","sourceRelease":"119-100","text":"to ensure the physical security of cloud computing data centers and the data stored in such centers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7463/b/3/B","parentIdentifier":"/us/usc/t15/s7463/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7463%2Fb%2F3%2FB","sourceRelease":"119-100","text":"to ensure secure access to the data stored in cloud computing data centers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s7463/b/3/C","parentIdentifier":"/us/usc/t15/s7463/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7463%2Fb%2F3%2FC","sourceRelease":"119-100","text":"to develop security standards as required under ; andsection 278g–3 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s7463/b/3/D","parentIdentifier":"/us/usc/t15/s7463/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7463%2Fb%2F3%2FD","sourceRelease":"119-100","text":"to support the development of the automation of continuous monitoring systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
