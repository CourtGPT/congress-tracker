{"type":"section","nativeType":"section","number":"3382","heading":"Purposes","label":"3382 Purposes","identifier":"/us/usc/t22/s3382","parentIdentifier":"/us/usc/t22/ch48A/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3382","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s3382/1","parentIdentifier":"/us/usc/t22/s3382","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3382%2F1","sourceRelease":"119-100","text":"to further strengthen the United States-Taiwan strategic partnership and broaden understanding of the Indo-Pacific region by temporarily assigning officials of any agencies of the United States Government to Taiwan for intensive study in Mandarin and placement as Fellows in a Taiwanese civic institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s3382/2","parentIdentifier":"/us/usc/t22/s3382","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3382%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s3382/2/A","parentIdentifier":"/us/usc/t22/s3382/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3382%2F2%2FA","sourceRelease":"119-100","text":"to learn or strengthen Mandarin Chinese language skills; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s3382/2/B","parentIdentifier":"/us/usc/t22/s3382/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3382%2F2%2FB","sourceRelease":"119-100","text":"to expand their understanding of the political economy of Taiwan and the Indo-Pacific region; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s3382/3","parentIdentifier":"/us/usc/t22/s3382","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3382%2F3","sourceRelease":"119-100","text":"to better position the United States to advance its economic, security, and human rights interests and values in the Indo-Pacific region.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
