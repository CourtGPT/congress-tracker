{"type":"section","nativeType":"section","number":"6864d","heading":"Financial assistance for WAP enhancement and innovation","label":"6864d Financial assistance for WAP enhancement and innovation","identifier":"/us/usc/t42/s6864d","parentIdentifier":"/us/usc/t42/ch81/schIII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purposes","label":"a Purposes","identifier":"/us/usc/t42/s6864d/a","parentIdentifier":"/us/usc/t42/s6864d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6864d/a/1","parentIdentifier":"/us/usc/t42/s6864d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fa%2F1","sourceRelease":"119-100","text":"to expand the number of dwelling units that are occupied by low-income persons that receive weatherization assistance by making such dwelling units weatherization-ready;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6864d/a/2","parentIdentifier":"/us/usc/t42/s6864d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fa%2F2","sourceRelease":"119-100","text":"to promote the deployment of renewable energy in dwelling units that are occupied by low-income persons;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s6864d/a/3","parentIdentifier":"/us/usc/t42/s6864d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fa%2F3","sourceRelease":"119-100","text":"to ensure healthy indoor environments by enhancing or expanding health and safety measures and resources available to dwellings that are occupied by low-income persons;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s6864d/a/4","parentIdentifier":"/us/usc/t42/s6864d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fa%2F4","sourceRelease":"119-100","text":"to disseminate new methods and best practices among entities providing weatherization assistance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s6864d/a/5","parentIdentifier":"/us/usc/t42/s6864d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6864d/a/5/A","parentIdentifier":"/us/usc/t42/s6864d/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fa%2F5%2FA","sourceRelease":"119-100","text":"from the community in which the assistance is provided; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6864d/a/5/B","parentIdentifier":"/us/usc/t42/s6864d/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fa%2F5%2FB","sourceRelease":"119-100","text":"from communities or groups that are underrepresented in the home energy performance workforce, including religious and ethnic minorities, women, veterans, individuals with disabilities, and individuals who are socioeconomically disadvantaged.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Financial assistance","label":"b Financial assistance","identifier":"/us/usc/t42/s6864d/b","parentIdentifier":"/us/usc/t42/s6864d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6864d/b/1","parentIdentifier":"/us/usc/t42/s6864d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6864d/b/1/A","parentIdentifier":"/us/usc/t42/s6864d/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F1%2FA","sourceRelease":"119-100","text":"implement measures to make such dwelling units weatherization-ready by addressing structural, plumbing, roofing, and electrical issues, environmental hazards, or other measures that the Secretary determines to be appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6864d/b/1/B","parentIdentifier":"/us/usc/t42/s6864d/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F1%2FB","sourceRelease":"119-100","text":"install energy efficiency technologies, including home energy management systems, smart devices, and other technologies the Secretary determines to be appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6864d/b/1/C","parentIdentifier":"/us/usc/t42/s6864d/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F1%2FC","sourceRelease":"119-100","text":"install renewable energy systems (as defined in ); andsection 6865(c)(6)(A) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6864d/b/1/D","parentIdentifier":"/us/usc/t42/s6864d/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F1%2FD","sourceRelease":"119-100","text":"implement measures to ensure healthy indoor environments by improving indoor air quality, accessibility, and other healthy homes measures as determined by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6864d/b/2","parentIdentifier":"/us/usc/t42/s6864d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6864d/b/2/A","parentIdentifier":"/us/usc/t42/s6864d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F2%2FA","sourceRelease":"119-100","text":"to significantly increase the number of energy retrofits performed by such entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6864d/b/2/B","parentIdentifier":"/us/usc/t42/s6864d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F2%2FB","sourceRelease":"119-100","text":"to replicate best practices for work performed pursuant to this section on a larger scale;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6864d/b/2/C","parentIdentifier":"/us/usc/t42/s6864d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F2%2FC","sourceRelease":"119-100","text":"to leverage additional funds to sustain the provision of weatherization assistance and other work performed pursuant to this section after financial assistance awarded under this section is expended; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6864d/b/2/D","parentIdentifier":"/us/usc/t42/s6864d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F2%2FD","sourceRelease":"119-100","text":"to hire and retain employees who are individuals described subsection (a)(5);1So in original. Probably should be followed by “in”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s6864d/b/3","parentIdentifier":"/us/usc/t42/s6864d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F3","sourceRelease":"119-100","text":"for innovative outreach and education regarding the benefits and availability of weatherization assistance and other assistance available pursuant to this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s6864d/b/4","parentIdentifier":"/us/usc/t42/s6864d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F4","sourceRelease":"119-100","text":"for quality control of work performed pursuant to this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s6864d/b/5","parentIdentifier":"/us/usc/t42/s6864d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F5","sourceRelease":"119-100","text":"for data collection, measurement, and verification with respect to such work;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s6864d/b/6","parentIdentifier":"/us/usc/t42/s6864d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F6","sourceRelease":"119-100","text":"for program monitoring, oversight, evaluation, and reporting regarding such work;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s6864d/b/7","parentIdentifier":"/us/usc/t42/s6864d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F7","sourceRelease":"119-100","text":"for labor, training, and technical assistance relating to such work;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s6864d/b/8","parentIdentifier":"/us/usc/t42/s6864d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F8","sourceRelease":"119-100","text":"for planning, management, and administration (up to a maximum of 15 percent of the assistance provided); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t42/s6864d/b/9","parentIdentifier":"/us/usc/t42/s6864d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fb%2F9","sourceRelease":"119-100","text":"for such other activities as the Secretary determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Award factors","label":"c Award factors","identifier":"/us/usc/t42/s6864d/c","parentIdentifier":"/us/usc/t42/s6864d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6864d/c/1","parentIdentifier":"/us/usc/t42/s6864d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fc%2F1","sourceRelease":"119-100","text":"the applicant’s record of constructing, renovating, repairing, or making energy efficient single-family, multifamily, or manufactured homes that are occupied by low-income persons, either directly or through affiliates, chapters, or other partners (using the most recent year for which data are available);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6864d/c/2","parentIdentifier":"/us/usc/t42/s6864d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fc%2F2","sourceRelease":"119-100","text":"the number of dwelling units occupied by low-income persons that the applicant has built, renovated, repaired, weatherized, or made more energy efficient in the 5 years preceding the date of the application;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s6864d/c/3","parentIdentifier":"/us/usc/t42/s6864d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fc%2F3","sourceRelease":"119-100","text":"the qualifications, experience, and past performance of the applicant, including experience successfully managing and administering Federal funds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s6864d/c/4","parentIdentifier":"/us/usc/t42/s6864d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fc%2F4","sourceRelease":"119-100","text":"the strength of an applicant’s proposal to achieve one or more of the purposes under subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s6864d/c/5","parentIdentifier":"/us/usc/t42/s6864d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fc%2F5","sourceRelease":"119-100","text":"the extent to which such applicant will utilize partnerships and regional coordination to achieve one or more of the purposes under subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s6864d/c/6","parentIdentifier":"/us/usc/t42/s6864d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fc%2F6","sourceRelease":"119-100","text":"regional and climate zone diversity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s6864d/c/7","parentIdentifier":"/us/usc/t42/s6864d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fc%2F7","sourceRelease":"119-100","text":"urban, suburban, and rural localities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s6864d/c/8","parentIdentifier":"/us/usc/t42/s6864d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fc%2F8","sourceRelease":"119-100","text":"such other factors as the Secretary determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Applications","label":"d Applications","identifier":"/us/usc/t42/s6864d/d","parentIdentifier":"/us/usc/t42/s6864d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Administration","label":"1 Administration","identifier":"/us/usc/t42/s6864d/d/1","parentIdentifier":"/us/usc/t42/s6864d/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fd%2F1","sourceRelease":"119-100","text":"To be eligible for an award of financial assistance under this section, an applicant shall submit to the Secretary an application in such manner and containing such information as the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Awards","label":"2 Awards","identifier":"/us/usc/t42/s6864d/d/2","parentIdentifier":"/us/usc/t42/s6864d/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fd%2F2","sourceRelease":"119-100","text":"Subject to the availability of appropriations, not later than 270 days after , the Secretary shall make a first award of financial assistance under this section.December 27, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Maximum amount and term","label":"e Maximum amount and term","identifier":"/us/usc/t42/s6864d/e","parentIdentifier":"/us/usc/t42/s6864d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s6864d/e/1","parentIdentifier":"/us/usc/t42/s6864d/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fe%2F1","sourceRelease":"119-100","text":"The total amount of financial assistance awarded to an entity under this section shall not exceed $2,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Technical and training assistance","label":"2 Technical and training assistance","identifier":"/us/usc/t42/s6864d/e/2","parentIdentifier":"/us/usc/t42/s6864d/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fe%2F2","sourceRelease":"119-100","text":"The total amount of financial assistance awarded to an entity under this section shall be reduced by the cost of any technical and training assistance provided by the Secretary that relates to such financial assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Term","label":"3 Term","identifier":"/us/usc/t42/s6864d/e/3","parentIdentifier":"/us/usc/t42/s6864d/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fe%2F3","sourceRelease":"119-100","text":"The term of an award of financial assistance under this section shall not exceed 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Relationship to formula grants","label":"4 Relationship to formula grants","identifier":"/us/usc/t42/s6864d/e/4","parentIdentifier":"/us/usc/t42/s6864d/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fe%2F4","sourceRelease":"119-100","text":"An entity may use financial assistance awarded to such entity under this section in conjunction with other financial assistance provided to such entity under this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Requirements","label":"f Requirements","identifier":"/us/usc/t42/s6864d/f","parentIdentifier":"/us/usc/t42/s6864d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6864d/f/1","parentIdentifier":"/us/usc/t42/s6864d/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Ff%2F1","sourceRelease":"119-100","text":"standards for allowable expenditures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6864d/f/2","parentIdentifier":"/us/usc/t42/s6864d/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Ff%2F2","sourceRelease":"119-100","text":"a minimum saving-to-investment ratio; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s6864d/f/3","parentIdentifier":"/us/usc/t42/s6864d/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Ff%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6864d/f/3/A","parentIdentifier":"/us/usc/t42/s6864d/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Ff%2F3%2FA","sourceRelease":"119-100","text":"training programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6864d/f/3/B","parentIdentifier":"/us/usc/t42/s6864d/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Ff%2F3%2FB","sourceRelease":"119-100","text":"energy audits;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6864d/f/3/C","parentIdentifier":"/us/usc/t42/s6864d/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Ff%2F3%2FC","sourceRelease":"119-100","text":"the provision of technical assistance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6864d/f/3/D","parentIdentifier":"/us/usc/t42/s6864d/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Ff%2F3%2FD","sourceRelease":"119-100","text":"monitoring activities carried out using such financial assistance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s6864d/f/3/E","parentIdentifier":"/us/usc/t42/s6864d/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Ff%2F3%2FE","sourceRelease":"119-100","text":"verification of energy and cost savings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s6864d/f/3/F","parentIdentifier":"/us/usc/t42/s6864d/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Ff%2F3%2FF","sourceRelease":"119-100","text":"liability insurance requirements; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s6864d/f/3/G","parentIdentifier":"/us/usc/t42/s6864d/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Ff%2F3%2FG","sourceRelease":"119-100","text":"recordkeeping and reporting requirements, which shall include reporting to the Office of Weatherization and Intergovernmental Programs of the Department of Energy applicable data on each dwelling unit retrofitted or otherwise assisted pursuant to this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Compliance with State and local law","label":"g Compliance with State and local law","identifier":"/us/usc/t42/s6864d/g","parentIdentifier":"/us/usc/t42/s6864d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fg","sourceRelease":"119-100","text":"Nothing in this section supersedes or otherwise affects any State or local law, to the extent that the State or local law contains a requirement that is more stringent than the applicable requirement of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Review and evaluation","label":"h Review and evaluation","identifier":"/us/usc/t42/s6864d/h","parentIdentifier":"/us/usc/t42/s6864d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fh","sourceRelease":"119-100","text":"The Secretary shall review and evaluate the performance of each entity that receives an award of financial assistance under this section (which may include an audit).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Annual report","label":"i Annual report","identifier":"/us/usc/t42/s6864d/i","parentIdentifier":"/us/usc/t42/s6864d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6864d/i/1","parentIdentifier":"/us/usc/t42/s6864d/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fi%2F1","sourceRelease":"119-100","text":"actions taken under this section to achieve the purposes of this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6864d/i/2","parentIdentifier":"/us/usc/t42/s6864d/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fi%2F2","sourceRelease":"119-100","text":"accomplishments as a result of such actions, including energy and cost savings achieved.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"j","heading":"Funding","label":"j Funding","identifier":"/us/usc/t42/s6864d/j","parentIdentifier":"/us/usc/t42/s6864d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fj","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Amounts","label":"1 Amounts","identifier":"/us/usc/t42/s6864d/j/1","parentIdentifier":"/us/usc/t42/s6864d/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fj%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s6864d/j/1/A","parentIdentifier":"/us/usc/t42/s6864d/j/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fj%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s6864d/j/1/A/i","parentIdentifier":"/us/usc/t42/s6864d/j/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fj%2F1%2FA%2Fi","sourceRelease":"119-100","text":"2 percent of such amount (if such amount is $225,000,000 or more but less than $260,000,000) may be used to carry out this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s6864d/j/1/A/ii","parentIdentifier":"/us/usc/t42/s6864d/j/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fj%2F1%2FA%2Fii","sourceRelease":"119-100","text":"4 percent of such amount (if such amount is $260,000,000 or more but less than $300,000,000) may be used to carry out this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s6864d/j/1/A/iii","parentIdentifier":"/us/usc/t42/s6864d/j/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fj%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"6 percent of such amount (if such amount is $300,000,000 or more) may be used to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Minimum","label":"B Minimum","identifier":"/us/usc/t42/s6864d/j/1/B","parentIdentifier":"/us/usc/t42/s6864d/j/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fj%2F1%2FB","sourceRelease":"119-100","text":"For each of fiscal years 2021 through 2025, if the amount made available under (not including any of such amount made available for Department of Energy headquarters training or technical assistance) for such fiscal year is less than $225,000,000, no funds shall be made available to carry out this section.section 6872 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitation","label":"2 Limitation","identifier":"/us/usc/t42/s6864d/j/2","parentIdentifier":"/us/usc/t42/s6864d/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fj%2F2","sourceRelease":"119-100","text":"For any fiscal year, the Secretary may not use more than $25,000,000 of the amount made available under to carry out this section.section 6872 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"k","heading":"Termination","label":"k Termination","identifier":"/us/usc/t42/s6864d/k","parentIdentifier":"/us/usc/t42/s6864d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6864d%2Fk","sourceRelease":"119-100","text":"The Secretary may not award financial assistance under this section after .September 30, 2025","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
