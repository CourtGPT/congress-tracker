rceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204h%2Fb%2F4%2FA","sourceRelease":"119-100","text":"local job creation and economic development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2204h/b/4/B","parentIdentifier":"/us/usc/t7/s2204h/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204h%2Fb%2F4%2FB","sourceRelease":"119-100","text":"access to local and regional fruit and vegetable markets, including for new and beginning small commercial producers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s2204h/b/4/C","parentIdentifier":"/us/usc/t7/s2204h/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204h%2Fb%2F4%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s2204h/b/4/C/i","parentIdentifier":"/us/usc/t7/s2204h/b/4/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204h%2Fb%2F4%2FC%2Fi","sourceRelease":"119-100","text":"supplier networks;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s2204h/b/4/C/ii","parentIdentifier":"/us/usc/t7/s2204h/b/4/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204h%2Fb%2F4%2FC%2Fii","sourceRelease":"119-100","text":"high volume distribution systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s2204h/b/4/C/iii","parentIdentifie