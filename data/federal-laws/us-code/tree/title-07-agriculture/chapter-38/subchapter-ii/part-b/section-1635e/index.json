{"type":"section","nativeType":"section","number":"1635e","heading":"Mandatory reporting for live cattle","label":"1635e Mandatory reporting for live cattle","identifier":"/us/usc/t7/s1635e","parentIdentifier":"/us/usc/t7/ch38/schII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t7/s1635e/a","parentIdentifier":"/us/usc/t7/s1635e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s1635e/a/1","parentIdentifier":"/us/usc/t7/s1635e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fa%2F1","sourceRelease":"119-100","text":"provide timely, accurate, and reliable market information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s1635e/a/2","parentIdentifier":"/us/usc/t7/s1635e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fa%2F2","sourceRelease":"119-100","text":"facilitate more informed marketing decisions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s1635e/a/3","parentIdentifier":"/us/usc/t7/s1635e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fa%2F3","sourceRelease":"119-100","text":"promote competition in the cattle slaughtering industry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"General reporting provisions applicable to packers and the Secretary","label":"b General reporting provisions applicable to packers and the Secretary","identifier":"/us/usc/t7/s1635e/b","parentIdentifier":"/us/usc/t7/s1635e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1635e/b/1","parentIdentifier":"/us/usc/t7/s1635e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1635e/b/1/A","parentIdentifier":"/us/usc/t7/s1635e/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the prices or quantities, as applicable, of the cattle purchased in the domestic market; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1635e/b/1/B","parentIdentifier":"/us/usc/t7/s1635e/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the prices or quantities, as applicable, of imported cattle.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Packer-owned cattle","label":"2 Packer-owned cattle","identifier":"/us/usc/t7/s1635e/b/2","parentIdentifier":"/us/usc/t7/s1635e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fb%2F2","sourceRelease":"119-100","text":"Information required under this section for packer-owned cattle shall include quantity and carcass characteristics, but not price.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Daily reporting","label":"c Daily reporting","identifier":"/us/usc/t7/s1635e/c","parentIdentifier":"/us/usc/t7/s1635e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1635e/c/1","parentIdentifier":"/us/usc/t7/s1635e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1635e/c/1/A","parentIdentifier":"/us/usc/t7/s1635e/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1635e/c/1/A/i","parentIdentifier":"/us/usc/t7/s1635e/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"type of purchase;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1635e/c/1/A/ii","parentIdentifier":"/us/usc/t7/s1635e/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the quantity of cattle purchased on a live weight basis;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s1635e/c/1/A/iii","parentIdentifier":"/us/usc/t7/s1635e/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"the quantity of cattle purchased on a dressed weight basis;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s1635e/c/1/A/iv","parentIdentifier":"/us/usc/t7/s1635e/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FA%2Fiv","sourceRelease":"119-100","text":"a range of the estimated live weights of the cattle purchased;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t7/s1635e/c/1/A/v","parentIdentifier":"/us/usc/t7/s1635e/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FA%2Fv","sourceRelease":"119-100","text":"an estimate of the percentage of the cattle purchased that were of a quality grade of choice or better; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t7/s1635e/c/1/A/vi","parentIdentifier":"/us/usc/t7/s1635e/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FA%2Fvi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s1635e/c/1/A/vi/I","parentIdentifier":"/us/usc/t7/s1635e/c/1/A/vi","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FA%2Fvi%2FI","sourceRelease":"119-100","text":"weight, grade, or yield; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s1635e/c/1/A/vi/II","parentIdentifier":"/us/usc/t7/s1635e/c/1/A/vi","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FA%2Fvi%2FII","sourceRelease":"119-100","text":"any type of purchase.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1635e/c/1/B","parentIdentifier":"/us/usc/t7/s1635e/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1635e/c/1/B/i","parentIdentifier":"/us/usc/t7/s1635e/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"type of purchase;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1635e/c/1/B/ii","parentIdentifier":"/us/usc/t7/s1635e/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the quantity of cattle delivered on a live weight basis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s1635e/c/1/B/iii","parentIdentifier":"/us/usc/t7/s1635e/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"the quantity of cattle delivered on a dressed weight basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s1635e/c/1/C","parentIdentifier":"/us/usc/t7/s1635e/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1635e/c/1/C/i","parentIdentifier":"/us/usc/t7/s1635e/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FC%2Fi","sourceRelease":"119-100","text":"type of purchase;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1635e/c/1/C/ii","parentIdentifier":"/us/usc/t7/s1635e/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FC%2Fii","sourceRelease":"119-100","text":"the quantity of cattle committed on a live weight basis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s1635e/c/1/C/iii","parentIdentifier":"/us/usc/t7/s1635e/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"the quantity of cattle committed on a dressed weight basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s1635e/c/1/D","parentIdentifier":"/us/usc/t7/s1635e/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F1%2FD","sourceRelease":"119-100","text":"The terms of trade regarding the cattle, as applicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Publication","label":"2 Publication","identifier":"/us/usc/t7/s1635e/c/2","parentIdentifier":"/us/usc/t7/s1635e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fc%2F2","sourceRelease":"119-100","text":"The Secretary shall make the information available to the public not less frequently than three times each reporting day.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Weekly reporting","label":"d Weekly reporting","identifier":"/us/usc/t7/s1635e/d","parentIdentifier":"/us/usc/t7/s1635e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1635e/d/1","parentIdentifier":"/us/usc/t7/s1635e/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1635e/d/1/A","parentIdentifier":"/us/usc/t7/s1635e/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F1%2FA","sourceRelease":"119-100","text":"The quantity of cattle purchased through a forward contract that were slaughtered.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1635e/d/1/B","parentIdentifier":"/us/usc/t7/s1635e/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F1%2FB","sourceRelease":"119-100","text":"The quantity of cattle delivered under a formula marketing arrangement that were slaughtered.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s1635e/d/1/C","parentIdentifier":"/us/usc/t7/s1635e/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F1%2FC","sourceRelease":"119-100","text":"The quantity and carcass characteristics of packer-owned cattle that were slaughtered.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s1635e/d/1/D","parentIdentifier":"/us/usc/t7/s1635e/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F1%2FD","sourceRelease":"119-100","text":"The quantity, basis level, and delivery month for all cattle purchased through forward contracts that were agreed to by the parties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s1635e/d/1/E","parentIdentifier":"/us/usc/t7/s1635e/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F1%2FE","sourceRelease":"119-100","text":"The range and average of intended premiums and discounts that are expected to be in effect for the current slaughter week.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Formula purchases","label":"2 Formula purchases","identifier":"/us/usc/t7/s1635e/d/2","parentIdentifier":"/us/usc/t7/s1635e/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1635e/d/2/A","parentIdentifier":"/us/usc/t7/s1635e/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F2%2FA","sourceRelease":"119-100","text":"The quantity (quoted in both numbers of head and hundredweights) of cattle.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1635e/d/2/B","parentIdentifier":"/us/usc/t7/s1635e/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F2%2FB","sourceRelease":"119-100","text":"The weighted average price paid for a carcass, including applicable premiums and discounts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s1635e/d/2/C","parentIdentifier":"/us/usc/t7/s1635e/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F2%2FC","sourceRelease":"119-100","text":"The range of premiums and discounts paid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s1635e/d/2/D","parentIdentifier":"/us/usc/t7/s1635e/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F2%2FD","sourceRelease":"119-100","text":"The weighted average of premiums and discounts paid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s1635e/d/2/E","parentIdentifier":"/us/usc/t7/s1635e/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F2%2FE","sourceRelease":"119-100","text":"The range of prices paid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t7/s1635e/d/2/F","parentIdentifier":"/us/usc/t7/s1635e/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F2%2FF","sourceRelease":"119-100","text":"The aggregate weighted average price paid for a carcass.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t7/s1635e/d/2/G","parentIdentifier":"/us/usc/t7/s1635e/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F2%2FG","sourceRelease":"119-100","text":"The terms of trade regarding the cattle, as applicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Publication","label":"3 Publication","identifier":"/us/usc/t7/s1635e/d/3","parentIdentifier":"/us/usc/t7/s1635e/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fd%2F3","sourceRelease":"119-100","text":"The Secretary shall make available to the public the information obtained under paragraphs (1) and (2) on the first reporting day of the current slaughter week, not later than 10:00 a.m. Central Time.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Regional reporting of cattle types","label":"e Regional reporting of cattle types","identifier":"/us/usc/t7/s1635e/e","parentIdentifier":"/us/usc/t7/s1635e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1635e/e/1","parentIdentifier":"/us/usc/t7/s1635e/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fe%2F1","sourceRelease":"119-100","text":"The Secretary shall determine whether adequate data can be obtained on a regional basis for fed Holsteins and other fed dairy steers and heifers, cows, and bulls based on the number of packers required to report under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report","label":"2 Report","identifier":"/us/usc/t7/s1635e/e/2","parentIdentifier":"/us/usc/t7/s1635e/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635e%2Fe%2F2","sourceRelease":"119-100","text":"Not later than 2 years after , the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report on the determination of the Secretary under paragraph (1).October 22, 1999","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
