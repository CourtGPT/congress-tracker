{"type":"section","nativeType":"section","number":"563a","heading":"Acquisition justification and reports","label":"563a Acquisition justification and reports","identifier":"/us/usc/t6/s563a","parentIdentifier":"/us/usc/t6/ch1/schXII–A/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Acquisition justification","label":"a Acquisition justification","identifier":"/us/usc/t6/s563a/a","parentIdentifier":"/us/usc/t6/s563a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s563a/a/1","parentIdentifier":"/us/usc/t6/s563a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fa%2F1","sourceRelease":"119-100","text":"an identification of the scenarios and level of risk to transportation security from those scenarios that would be addressed by the security-related technology acquisition;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s563a/a/2","parentIdentifier":"/us/usc/t6/s563a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fa%2F2","sourceRelease":"119-100","text":"an assessment of how the proposed acquisition aligns to the Plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s563a/a/3","parentIdentifier":"/us/usc/t6/s563a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fa%2F3","sourceRelease":"119-100","text":"a comparison of the total expected lifecycle cost against the total expected quantitative and qualitative benefits to transportation security;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s563a/a/4","parentIdentifier":"/us/usc/t6/s563a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fa%2F4","sourceRelease":"119-100","text":"an analysis of alternative security solutions, including policy or procedure solutions, to determine if the proposed security-related technology acquisition is the most effective and cost-efficient solution based on cost-benefit considerations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s563a/a/5","parentIdentifier":"/us/usc/t6/s563a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fa%2F5","sourceRelease":"119-100","text":"an assessment of the potential privacy and civil liberties implications of the proposed acquisition that includes, to the extent practicable, consultation with organizations that advocate for the protection of privacy and civil liberties;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t6/s563a/a/6","parentIdentifier":"/us/usc/t6/s563a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fa%2F6","sourceRelease":"119-100","text":"a determination that the proposed acquisition is consistent with fair information practice principles issued by the Privacy Officer of the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t6/s563a/a/7","parentIdentifier":"/us/usc/t6/s563a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fa%2F7","sourceRelease":"119-100","text":"confirmation that there are no significant risks to human health or safety posed by the proposed acquisition; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t6/s563a/a/8","parentIdentifier":"/us/usc/t6/s563a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fa%2F8","sourceRelease":"119-100","text":"an estimate of the benefits to commercial aviation passengers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Reports and certification to Congress","label":"b Reports and certification to Congress","identifier":"/us/usc/t6/s563a/b","parentIdentifier":"/us/usc/t6/s563a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s563a/b/1","parentIdentifier":"/us/usc/t6/s563a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s563a/b/1/A","parentIdentifier":"/us/usc/t6/s563a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the results of the comprehensive acquisition justification under subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s563a/b/1/B","parentIdentifier":"/us/usc/t6/s563a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fb%2F1%2FB","sourceRelease":"119-100","text":"a certification by the Administrator that the benefits to transportation security justify the contract cost.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Extension due to imminent terrorist threat","label":"2 Extension due to imminent terrorist threat","identifier":"/us/usc/t6/s563a/b/2","parentIdentifier":"/us/usc/t6/s563a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s563a/b/2/A","parentIdentifier":"/us/usc/t6/s563a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fb%2F2%2FA","sourceRelease":"119-100","text":"may reduce the 30-day period under paragraph (1) to 5 days to rapidly respond to the threat; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s563a/b/2/B","parentIdentifier":"/us/usc/t6/s563a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563a%2Fb%2F2%2FB","sourceRelease":"119-100","text":"shall immediately notify the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Homeland Security of the House of Representatives of the known or suspected imminent threat.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
