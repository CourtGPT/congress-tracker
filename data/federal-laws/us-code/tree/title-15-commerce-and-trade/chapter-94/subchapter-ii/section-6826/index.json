{"type":"section","nativeType":"section","number":"6826","heading":"Reports","label":"6826 Reports","identifier":"/us/usc/t15/s6826","parentIdentifier":"/us/usc/t15/ch94/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6826","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Report to the Congress","label":"a Report to the Congress","identifier":"/us/usc/t15/s6826/a","parentIdentifier":"/us/usc/t15/s6826","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6826%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s6826/a/1","parentIdentifier":"/us/usc/t15/s6826/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6826%2Fa%2F1","sourceRelease":"119-100","text":"The efficacy and adequacy of the remedies provided in this subchapter in addressing attempts to obtain financial information by fraudulent means or by false pretenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s6826/a/2","parentIdentifier":"/us/usc/t15/s6826/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6826%2Fa%2F2","sourceRelease":"119-100","text":"Any recommendations for additional legislative or regulatory action to address threats to the privacy of financial information created by attempts to obtain information by fraudulent means or false pretenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Annual report by administering agencies","label":"b Annual report by administering agencies","identifier":"/us/usc/t15/s6826/b","parentIdentifier":"/us/usc/t15/s6826","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6826%2Fb","sourceRelease":"119-100","text":"The Federal Trade Commission and the Attorney General shall submit to Congress an annual report on number and disposition of all enforcement actions taken pursuant to this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
