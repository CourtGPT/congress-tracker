{"type":"section","nativeType":"section","number":"2806","heading":"Geospatial data standards","label":"2806 Geospatial data standards","identifier":"/us/usc/t43/s2806","parentIdentifier":"/us/usc/t43/ch46","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextSection 216 of the E-Government Act of 2002, referred to in subsec. (a), is , which is set out in a note under , Public Printing and Documents.section 216 of Pub. L. 107–347section 3501 of Title 44"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t43/s2806/a","parentIdentifier":"/us/usc/t43/s2806","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2806/a/1","parentIdentifier":"/us/usc/t43/s2806/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2806/a/1/A","parentIdentifier":"/us/usc/t43/s2806/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fa%2F1%2FA","sourceRelease":"119-100","text":"rules, conditions, guidelines, and characteristics for the geospatial data within the National Geospatial Data Asset data theme and related processes, technology, and organization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2806/a/1/B","parentIdentifier":"/us/usc/t43/s2806/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fa%2F1%2FB","sourceRelease":"119-100","text":"content standards for metadata for geospatial data within the National Geospatial Data Asset data theme;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2806/a/2","parentIdentifier":"/us/usc/t43/s2806/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fa%2F2","sourceRelease":"119-100","text":"to the maximum extent practicable, shall be consistent with international standards and protocols;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s2806/a/3","parentIdentifier":"/us/usc/t43/s2806/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fa%2F3","sourceRelease":"119-100","text":"shall include universal data standards that shall be acceptable for the purposes of declassified intelligence community data; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t43/s2806/a/4","parentIdentifier":"/us/usc/t43/s2806/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fa%2F4","sourceRelease":"119-100","text":"the Committee shall periodically review and update as necessary for the standards to remain current, relevant, and effective.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Development of standards","label":"b Development of standards","identifier":"/us/usc/t43/s2806/b","parentIdentifier":"/us/usc/t43/s2806","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2806/b/1","parentIdentifier":"/us/usc/t43/s2806/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2806/b/1/A","parentIdentifier":"/us/usc/t43/s2806/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fb%2F1%2FA","sourceRelease":"119-100","text":"in accordance with Office of Management and Budget Circular A–119, or any successor thereto; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2806/b/1/B","parentIdentifier":"/us/usc/t43/s2806/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fb%2F1%2FB","sourceRelease":"119-100","text":"after consultation with a broad range of data users and providers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2806/b/2","parentIdentifier":"/us/usc/t43/s2806/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fb%2F2","sourceRelease":"119-100","text":"to the maximum extent possible, use national and international standards adopted by voluntary standards consensus bodies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s2806/b/3","parentIdentifier":"/us/usc/t43/s2806/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fb%2F3","sourceRelease":"119-100","text":"establish new standards only to the extent standards described in paragraph (2) do not exist.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Exclusion","label":"c Exclusion","identifier":"/us/usc/t43/s2806/c","parentIdentifier":"/us/usc/t43/s2806","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2806%2Fc","sourceRelease":"119-100","text":"The Secretary of the Interior shall withhold from public disclosure any information the disclosure of which reasonably could be expected to cause damage to the national interest, security, or defense of the United States, including information relating to geospatial intelligence data activities, as determined in consultation with the Director of National Intelligence.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
