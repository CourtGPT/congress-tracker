":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Separation Pay for Discharged Officer","label":"c .—Separation Pay for Discharged Officer","identifier":"/us/usc/t10/s20505/c","parentIdentifier":"/us/usc/t10/s20505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20505%2Fc","sourceRelease":"119-100","text":"An officer who is discharged under subsection (b)(2) is entitled, if eligible therefor, to separation pay under .section 1174(a)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
