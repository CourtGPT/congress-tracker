{"type":"section","nativeType":"section","number":"1692i","heading":"Legal actions by debt collectors","label":"1692i Legal actions by debt collectors","identifier":"/us/usc/t15/s1692i","parentIdentifier":"/us/usc/t15/ch41/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1692i","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective upon the expiration of six months after , see , as added by , set out as a note under .Sept. 20, 1977section 819 of Pub. L. 90–321Pub. L. 95–109section 1692 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Venue","label":"a Venue","identifier":"/us/usc/t15/s1692i/a","parentIdentifier":"/us/usc/t15/s1692i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1692i%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s1692i/a/1","parentIdentifier":"/us/usc/t15/s1692i/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1692i%2Fa%2F1","sourceRelease":"119-100","text":"in the case of an action to enforce an interest in real property securing the consumer’s obligation, bring such action only in a judicial district or similar legal entity in which such real property is located; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s1692i/a/2","parentIdentifier":"/us/usc/t15/s1692i/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1692i%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s1692i/a/2/A","parentIdentifier":"/us/usc/t15/s1692i/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1692i%2Fa%2F2%2FA","sourceRelease":"119-100","text":"in which such consumer signed the contract sued upon; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s1692i/a/2/B","parentIdentifier":"/us/usc/t15/s1692i/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1692i%2Fa%2F2%2FB","sourceRelease":"119-100","text":"in which such consumer resides at the commencement of the action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Authorization of actions","label":"b Authorization of actions","identifier":"/us/usc/t15/s1692i/b","parentIdentifier":"/us/usc/t15/s1692i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1692i%2Fb","sourceRelease":"119-100","text":"Nothing in this subchapter shall be construed to authorize the bringing of legal actions by debt collectors.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
