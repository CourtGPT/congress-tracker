2/D/vii/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fvii%2FI%2Fbb","sourceRelease":"119-100","text":"homeless housing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"cc","heading":null,"label":"cc","identifier":"/us/usc/t25/s4223/c/2/D/vii/I/cc","parentIdentifier":"/us/usc/t25/s4223/c/2/D/vii/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fvii%2FI%2Fcc","sourceRelease":"119-100","text":"college housing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"dd","heading":null,"label":"dd","identifier":"/us/usc/t25/s4223/c/2/D/vii/I/dd","parentIdentifier":"/us/usc/t25/s4223/c/2/D/vii/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fvii%2FI%2Fdd","sourceRelease":"119-100","text":"supportive services housing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t25/s4223/c/2/D/vii/II","parentIdentifier":"/us/usc/t25/s4223/c/2/D/vii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fvii%2FII","sourceRelease":"119-100","text":"the requirements and assistance available under such programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t25/s4223/c/2/D/viii","parentIdentifier":"/us/usc/t25/s4223/c/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fviii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t25/s4223/c/2/D/viii/I","parentIdentifier":"/us/usc/t25/s4223/c/2/D/viii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fviii%2FI","sourceRelease":"119-100","text":"a description of any housing to be demolished or disposed of;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t25/s4223/c/2/D/viii/II","parentIdentifier":"/us/usc/t25/s4223/c/2/D/viii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fviii%2FII","sourceRelease":"119-100","text":"a timetable for that demolition or disposition; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t25/s4223/c/2/D/viii/III","parentIdentifier":"/us/usc/t25/s4223/c/2/D/viii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fviii%2FIII","sourceRelease":"119-100","text":"any other information required by the Secretary with respect to that demolition or disposition;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ix","heading":null,"label":"ix","identifier":"/us/usc/t25/s4223/c/2/D/ix","parentIdentifier":"/us/usc/t25/s4223/c/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fix","sourceRelease":"119-100","text":"a description of the manner in which the Department of Hawaiian Home Lands will coordinate with welfare agencies in the State of Hawaii to ensure that residents of the affordable housing will be provided with access to resources to assist in obtaining employment and achieving self-sufficiency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"x","heading":null,"label":"x","identifier":"/us/usc/t25/s4223/c/2/D/x","parentIdentifier":"/us/usc/t25/s4223/c/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fx","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t25/s4223/c/2/D/x/I","parentIdentifier":"/us/usc/t25/s4223/c/2/D/x","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fx%2FI","sourceRelease":"119-100","text":"promote the safety of residents of the affordable housing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t25/s4223/c/2/D/x/II","parentIdentifier":"/us/usc/t25/s4223/c/2/D/x","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fx%2FII","sourceRelease":"119-100","text":"facilitate the undertaking of crime prevention measures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t25/s4223/c/2/D/x/III","parentIdentifier":"/us/usc/t25/s4223/c/2/D/x","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fx%2FIII","sourceRelease":"119-100","text":"allow resident input and involvement, including the establishment of resident organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t25/s4223/c/2/D/x/IV","parentIdentifier":"/us/usc/t25/s4223/c/2/D/x","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fx%2FIV","sourceRelease":"119-100","text":"allow for the coordination of crime prevention activities between the Department and local law enforcement officials; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"xi","heading":null,"label":"xi","identifier":"/us/usc/t25/s4223/c/2/D/xi","parentIdentifier":"/us/usc/t25/s4223/c/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FD%2Fxi","sourceRelease":"119-100","text":"a description of the entities that will carry out the activities under the plan, including the organizational capacity and key personnel of the entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":".—Certification of compliance","label":"E .—Certification of compliance","identifier":"/us/usc/t25/s4223/c/2/E","parentIdentifier":"/us/usc/t25/s4223/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s4223/c/2/E/i","parentIdentifier":"/us/usc/t25/s4223/c/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FE%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t25/s4223/c/2/E/i/I","parentIdentifier":"/us/usc/t25/s4223/c/2/E/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FE%2Fi%2FI","sourceRelease":"119-100","text":"title VI of the Civil Rights Act of 1964 ( et seq.) or with the Fair Housing Act ( et seq.) in carrying out this subchapter, to the extent that such title is applicable; and42 U.S.C. 2000d42 U.S.C. 36011See Codification note below.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t25/s4223/c/2/E/i/II","parentIdentifier":"/us/usc/t25/s4223/c/2/E/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FE%2Fi%2FII","sourceRelease":"119-100","text":"other applicable Federal statutes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s4223/c/2/E/ii","parentIdentifier":"/us/usc/t25/s4223/c/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FE%2Fii","sourceRelease":"119-100","text":"a certification that the Department will require adequate insurance coverage for housing units that are owned and operated or assisted with grant amounts provided under this subchapter, in compliance with such requirements as may be established by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t25/s4223/c/2/E/iii","parentIdentifier":"/us/usc/t25/s4223/c/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FE%2Fiii","sourceRelease":"119-100","text":"a certification that policies are in effect and are available for review by the Secretary and the public governing the eligibility, admission, and occupancy of families for housing assisted with grant amounts provided under this subchapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t25/s4223/c/2/E/iv","parentIdentifier":"/us/usc/t25/s4223/c/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FE%2Fiv","sourceRelease":"119-100","text":"a certification that policies are in effect and are available for review by the Secretary and the public governing rents charged, including the methods by which such rents or homebuyer payments are determined, for housing assisted with grant amounts provided under this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t25/s4223/c/2/E/v","parentIdentifier":"/us/usc/t25/s4223/c/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fc%2F2%2FE%2Fv","sourceRelease":"119-100","text":"a certification that policies are in effect and are available for review by the Secretary and the public governing the management and maintenance of housing assisted with grant amounts provided under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Applicability of civil rights statutes","label":"d Applicability of civil rights statutes","identifier":"/us/usc/t25/s4223/d","parentIdentifier":"/us/usc/t25/s4223","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s4223/d/1","parentIdentifier":"/us/usc/t25/s4223/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s4223/d/1/A","parentIdentifier":"/us/usc/t25/s4223/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fd%2F1%2FA","sourceRelease":"119-100","text":"to the Department of Hawaiian Home Lands on the basis that the Department served Native Hawaiians; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s4223/d/1/B","parentIdentifier":"/us/usc/t25/s4223/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fd%2F1%2FB","sourceRelease":"119-100","text":"to an eligible family on the basis that the family is a Native Hawaiian family.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Civil rights","label":"2 Civil rights","identifier":"/us/usc/t25/s4223/d/2","parentIdentifier":"/us/usc/t25/s4223/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fd%2F2","sourceRelease":"119-100","text":"Program eligibility under this subchapter may be restricted to Native Hawaiians. Subject to the preceding sentence, no person may be discriminated against on the basis of race, color, national origin, religion, sex, familial status, or disability.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Use of nonprofit organizations","label":"e Use of nonprofit organizations","identifier":"/us/usc/t25/s4223/e","parentIdentifier":"/us/usc/t25/s4223","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4223%2Fe","sourceRelease":"119-100","text":"As a condition of receiving grant amounts under this subchapter, the Department of Hawaiian Home Lands shall, to the extent practicable, provide for private nonprofit organizations experienced in the planning and development of affordable housing for Native Hawaiians to carry out affordable housing activities with those grant amounts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
