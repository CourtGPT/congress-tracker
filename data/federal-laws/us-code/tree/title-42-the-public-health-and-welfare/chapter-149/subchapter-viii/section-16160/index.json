{"type":"section","nativeType":"section","number":"16160","heading":"Reports","label":"16160 Reports","identifier":"/us/usc/t42/s16160","parentIdentifier":"/us/usc/t42/ch149/schVIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Secretary","label":"a Secretary","identifier":"/us/usc/t42/s16160/a","parentIdentifier":"/us/usc/t42/s16160","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16160/a/1","parentIdentifier":"/us/usc/t42/s16160/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fa%2F1","sourceRelease":"119-100","text":"activities carried out by the Department under this subchapter, for hydrogen and fuel cell technology;1So in original. The comma probably should not appear.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16160/a/2","parentIdentifier":"/us/usc/t42/s16160/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fa%2F2","sourceRelease":"119-100","text":"measures the Secretary has taken during the preceding 3 years to support the transition of primary industry (or a related industry) to a fully commercialized hydrogen economy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16160/a/3","parentIdentifier":"/us/usc/t42/s16160/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fa%2F3","sourceRelease":"119-100","text":"any change made to the strategy relating to hydrogen and fuel cell technology to reflect the results of a learning demonstrations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16160/a/4","parentIdentifier":"/us/usc/t42/s16160/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16160/a/4/A","parentIdentifier":"/us/usc/t42/s16160/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fa%2F4%2FA","sourceRelease":"119-100","text":"100,000 hydrogen-fueled vehicles in the United States by 2010; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16160/a/4/B","parentIdentifier":"/us/usc/t42/s16160/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fa%2F4%2FB","sourceRelease":"119-100","text":"2,500,000 hydrogen-fueled vehicles in the United States by 2020;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16160/a/5","parentIdentifier":"/us/usc/t42/s16160/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16160/a/5/A","parentIdentifier":"/us/usc/t42/s16160/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fa%2F5%2FA","sourceRelease":"119-100","text":"hydrogen activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16160/a/5/B","parentIdentifier":"/us/usc/t42/s16160/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fa%2F5%2FB","sourceRelease":"119-100","text":"associated targets and timetables for the development of hydrogen technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s16160/a/6","parentIdentifier":"/us/usc/t42/s16160/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fa%2F6","sourceRelease":"119-100","text":"any problem relating to the design, execution, or funding of a program under this subchapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s16160/a/7","parentIdentifier":"/us/usc/t42/s16160/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fa%2F7","sourceRelease":"119-100","text":"progress made toward and goals achieved in carrying out this subchapter and updates to the developmental roadmap, including the results of the reviews conducted by the National Academy of Sciences under subsection (b) for the fiscal years covered by the report; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s16160/a/8","parentIdentifier":"/us/usc/t42/s16160/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fa%2F8","sourceRelease":"119-100","text":"any updates to strategic plans that are necessary to meet the goals described in paragraph (4).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"External review","label":"b External review","identifier":"/us/usc/t42/s16160/b","parentIdentifier":"/us/usc/t42/s16160","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fb","sourceRelease":"119-100","text":"The Secretary shall enter into an arrangement with the National Academy of Sciences under which the Academy will review the programs under sections 16154 and 16157 of this title every fourth year following . The Academy’s review shall include the program priorities and technical milestones, and evaluate the progress toward achieving them. The first review shall be completed not later than 5 years after . Not later than 45 days after receiving the review, the Secretary shall transmit the review to Congress along with a plan to implement the review’s recommendations or an explanation for the reasons that a recommendation will not be implemented.August 8, 2005August 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t42/s16160/c","parentIdentifier":"/us/usc/t42/s16160","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16160%2Fc","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $1,500,000 for each of fiscal years 2006 through 2020.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
