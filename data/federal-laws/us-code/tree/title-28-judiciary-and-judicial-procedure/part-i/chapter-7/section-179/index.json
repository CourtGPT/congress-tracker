{"type":"section","nativeType":"section","number":"179","heading":"Personnel application and insurance programs","label":"179 Personnel application and insurance programs","identifier":"/us/usc/t28/s179","parentIdentifier":"/us/usc/t28/ptI/ch7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t28/s179/a","parentIdentifier":"/us/usc/t28/s179","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fa","sourceRelease":"119-100","text":"For purposes of construing and applying title 5, a judge of the United States Court of Federal Claims shall be deemed to be an “officer” under section 2104(a) of such title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t28/s179/b","parentIdentifier":"/us/usc/t28/s179","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t28/s179/b/1","parentIdentifier":"/us/usc/t28/s179/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t28/s179/b/1/A","parentIdentifier":"/us/usc/t28/s179/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t28/s179/b/1/A/i","parentIdentifier":"/us/usc/t28/s179/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"is retired under subsection (b) of , andsection 178 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t28/s179/b/1/A/ii","parentIdentifier":"/us/usc/t28/s179/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t28/s179/b/1/A/ii/I","parentIdentifier":"/us/usc/t28/s179/b/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FA%2Fii%2FI","sourceRelease":"119-100","text":"was enrolled in a health benefits plan under chapter 89 of title 5, but","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t28/s179/b/1/A/ii/II","parentIdentifier":"/us/usc/t28/s179/b/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FA%2Fii%2FII","sourceRelease":"119-100","text":"did not satisfy the requirements of (relating to eligibility to continue enrollment as an annuitant),section 8905(b)(1) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t28/s179/b/1/B","parentIdentifier":"/us/usc/t28/s179/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t28/s179/b/1/B/i","parentIdentifier":"/us/usc/t28/s179/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"in order to be eligible for continued enrollment under this paragraph, notification under subparagraph (A) shall be made before the first day of the open enrollment period preceding the calendar year referred to in clause (ii)(II); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t28/s179/b/1/B/ii","parentIdentifier":"/us/usc/t28/s179/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t28/s179/b/1/B/ii/I","parentIdentifier":"/us/usc/t28/s179/b/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FB%2Fii%2FI","sourceRelease":"119-100","text":"beginning on the date on which eligibility would otherwise cease, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t28/s179/b/1/B/ii/II","parentIdentifier":"/us/usc/t28/s179/b/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FB%2Fii%2FII","sourceRelease":"119-100","text":"ending on the last day of the calendar year next beginning after the end of the open enrollment period referred to in clause (i).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t28/s179/b/1/C","parentIdentifier":"/us/usc/t28/s179/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t28/s179/b/1/C/i","parentIdentifier":"/us/usc/t28/s179/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FC%2Fi","sourceRelease":"119-100","text":"subparagraph (B)(i) shall be applied by substituting “the expiration of the term of office of the judge” for the matter following “before”; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t28/s179/b/1/C/ii","parentIdentifier":"/us/usc/t28/s179/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FC%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t28/s179/b/1/C/ii/I","parentIdentifier":"/us/usc/t28/s179/b/1/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FC%2Fii%2FI","sourceRelease":"119-100","text":"if the term of office of such judge expires before the first day of the open enrollment period referred to in subparagraph (B)(i), the period of continued eligibility for enrollment shall be as described in subparagraph (B)(ii); but","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t28/s179/b/1/C/ii/II","parentIdentifier":"/us/usc/t28/s179/b/1/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F1%2FC%2Fii%2FII","sourceRelease":"119-100","text":"if the term of office of such judge expires on or after the first day of the open enrollment period referred to in subparagraph (B)(i), the period of continued eligibility shall not end until the last day of the calendar year next beginning after the end of the next full open enrollment period beginning after the date on which the term expires.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t28/s179/b/2","parentIdentifier":"/us/usc/t28/s179/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t28/s179/b/2/A","parentIdentifier":"/us/usc/t28/s179/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the provisions of chapter 89 of title 5 shall be applied as if such judge had satisfied the requirements of section 8905(b)(1) on the last day of such period; and1So in original. Probably should be followed by “of title 5”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t28/s179/b/2/B","parentIdentifier":"/us/usc/t28/s179/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the provisions of paragraph (1) shall cease to apply.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t28/s179/b/3","parentIdentifier":"/us/usc/t28/s179/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fb%2F3","sourceRelease":"119-100","text":"For purposes of this subsection, the term “open enrollment period” refers to a period described in .section 8905(g)(1) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t28/s179/c","parentIdentifier":"/us/usc/t28/s179","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs179%2Fc","sourceRelease":"119-100","text":"For purposes of construing and applying chapter 87 of title 5, including any adjustment of insurance rates by regulation or otherwise, a judge of the United States Court of Federal Claims in regular active service or who is retired under shall be deemed to be a judge of the United States described under .section 178 of this titlesection 8701(a)(5) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
