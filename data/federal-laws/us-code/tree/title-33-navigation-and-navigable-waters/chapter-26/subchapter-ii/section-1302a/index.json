{"type":"section","nativeType":"section","number":"1302a","heading":"Clean water infrastructure resiliency and sustainability program","label":"1302a Clean water infrastructure resiliency and sustainability program","identifier":"/us/usc/t33/s1302a","parentIdentifier":"/us/usc/t33/ch26/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t33/s1302a/a","parentIdentifier":"/us/usc/t33/s1302a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible entity","label":"1 Eligible entity","identifier":"/us/usc/t33/s1302a/a/1","parentIdentifier":"/us/usc/t33/s1302a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1302a/a/1/A","parentIdentifier":"/us/usc/t33/s1302a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fa%2F1%2FA","sourceRelease":"119-100","text":"a municipality; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1302a/a/1/B","parentIdentifier":"/us/usc/t33/s1302a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fa%2F1%2FB","sourceRelease":"119-100","text":"an intermunicipal, interstate, or State agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Natural hazard","label":"2 Natural hazard","identifier":"/us/usc/t33/s1302a/a/2","parentIdentifier":"/us/usc/t33/s1302a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fa%2F2","sourceRelease":"119-100","text":"The term “natural hazard” means a hazard caused by natural forces, including extreme weather events, sea-level rise, and extreme drought conditions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Program","label":"3 Program","identifier":"/us/usc/t33/s1302a/a/3","parentIdentifier":"/us/usc/t33/s1302a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fa%2F3","sourceRelease":"119-100","text":"The term “program” means the clean water infrastructure resilience and sustainability program established under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t33/s1302a/b","parentIdentifier":"/us/usc/t33/s1302a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fb","sourceRelease":"119-100","text":"Subject to the availability of appropriations, the Administrator shall establish a clean water infrastructure resilience and sustainability program under which the Administrator shall award grants to eligible entities for the purpose of increasing the resilience of publicly owned treatment works to a natural hazard or cybersecurity vulnerabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Use of funds","label":"c Use of funds","identifier":"/us/usc/t33/s1302a/c","parentIdentifier":"/us/usc/t33/s1302a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1302a/c/1","parentIdentifier":"/us/usc/t33/s1302a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fc%2F1","sourceRelease":"119-100","text":"the conservation of water;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1302a/c/2","parentIdentifier":"/us/usc/t33/s1302a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fc%2F2","sourceRelease":"119-100","text":"the enhancement of water use efficiency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s1302a/c/3","parentIdentifier":"/us/usc/t33/s1302a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1302a/c/3/A","parentIdentifier":"/us/usc/t33/s1302a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fc%2F3%2FA","sourceRelease":"119-100","text":"natural and engineered green infrastructure; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1302a/c/3/B","parentIdentifier":"/us/usc/t33/s1302a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fc%2F3%2FB","sourceRelease":"119-100","text":"reclamation and reuse of wastewater and stormwater, such as aquifer recharge zones;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s1302a/c/4","parentIdentifier":"/us/usc/t33/s1302a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fc%2F4","sourceRelease":"119-100","text":"the modification or relocation of an existing publicly owned treatment works, conveyance, or discharge system component that is at risk of being significantly impaired or damaged by a natural hazard;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t33/s1302a/c/5","parentIdentifier":"/us/usc/t33/s1302a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fc%2F5","sourceRelease":"119-100","text":"the development and implementation of projects to increase the resilience of publicly owned treatment works to a natural hazard or cybersecurity vulnerabilities, as applicable; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t33/s1302a/c/6","parentIdentifier":"/us/usc/t33/s1302a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fc%2F6","sourceRelease":"119-100","text":"the enhancement of energy efficiency or the use and generation of recovered or renewable energy in the management, treatment, or conveyance of wastewater or stormwater.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Application","label":"d Application","identifier":"/us/usc/t33/s1302a/d","parentIdentifier":"/us/usc/t33/s1302a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1302a/d/1","parentIdentifier":"/us/usc/t33/s1302a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fd%2F1","sourceRelease":"119-100","text":"a proposal of the project to be planned, designed, or constructed using funds under the program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1302a/d/2","parentIdentifier":"/us/usc/t33/s1302a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fd%2F2","sourceRelease":"119-100","text":"an identification of the natural hazard risk of the area where the proposed project is to be located or potential cybersecurity vulnerability, as applicable, to be addressed by the proposed project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s1302a/d/3","parentIdentifier":"/us/usc/t33/s1302a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fd%2F3","sourceRelease":"119-100","text":"documentation prepared by a Federal, State, regional, or local government agency of the natural hazard risk of the area where the proposed project is to be located or potential cybersecurity vulnerability, as applicable, of the area where the proposed project is to be located;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s1302a/d/4","parentIdentifier":"/us/usc/t33/s1302a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fd%2F4","sourceRelease":"119-100","text":"a description of any recent natural hazard risk of the area where the proposed project is to be located or potential cybersecurity vulnerabilities that have affected the publicly owned treatment works;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t33/s1302a/d/5","parentIdentifier":"/us/usc/t33/s1302a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fd%2F5","sourceRelease":"119-100","text":"a description of how the proposed project would improve the performance of the publicly owned treatment works under an anticipated natural hazard or natural hazard risk of the area where the proposed project is to be located or a potential cybersecurity vulnerability, as applicable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t33/s1302a/d/6","parentIdentifier":"/us/usc/t33/s1302a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fd%2F6","sourceRelease":"119-100","text":"an explanation of how the proposed project is expected to enhance the resilience of the publicly owned treatment works to a natural hazard risk of the area where the proposed project is to be located or a potential cybersecurity vulnerability, as applicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Grant amount and other Federal requirements","label":"e Grant amount and other Federal requirements","identifier":"/us/usc/t33/s1302a/e","parentIdentifier":"/us/usc/t33/s1302a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Cost share","label":"1 Cost share","identifier":"/us/usc/t33/s1302a/e/1","parentIdentifier":"/us/usc/t33/s1302a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fe%2F1","sourceRelease":"119-100","text":"Except as provided in paragraph (2), a grant under the program shall not exceed 75 percent of the total cost of the proposed project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Exception","label":"2 Exception","identifier":"/us/usc/t33/s1302a/e/2","parentIdentifier":"/us/usc/t33/s1302a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t33/s1302a/e/2/A","parentIdentifier":"/us/usc/t33/s1302a/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fe%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s1302a/e/2/A/i","parentIdentifier":"/us/usc/t33/s1302a/e/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fe%2F2%2FA%2Fi","sourceRelease":"119-100","text":"has a population of fewer than 10,000 individuals; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s1302a/e/2/A/ii","parentIdentifier":"/us/usc/t33/s1302a/e/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fe%2F2%2FA%2Fii","sourceRelease":"119-100","text":"meets the affordability criteria established by the State in which the community is located under .section 1383(i)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Waiver","label":"B Waiver","identifier":"/us/usc/t33/s1302a/e/2/B","parentIdentifier":"/us/usc/t33/s1302a/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fe%2F2%2FB","sourceRelease":"119-100","text":"At the discretion of the Administrator, a grant for a project described in subparagraph (A) may cover 100 percent of the total cost of the proposed project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Requirements","label":"3 Requirements","identifier":"/us/usc/t33/s1302a/e/3","parentIdentifier":"/us/usc/t33/s1302a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fe%2F3","sourceRelease":"119-100","text":"The requirements of shall apply to a project funded with a grant under the program.section 1388 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Report","label":"f Report","identifier":"/us/usc/t33/s1302a/f","parentIdentifier":"/us/usc/t33/s1302a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Ff","sourceRelease":"119-100","text":"Not later than 2 years after , the Administrator shall submit to Congress a report that describes the implementation of the program, which shall include an accounting of all grants awarded under the program, including a description of each grant recipient and each project funded using a grant under the program.November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Authorization of appropriations","label":"g Authorization of appropriations","identifier":"/us/usc/t33/s1302a/g","parentIdentifier":"/us/usc/t33/s1302a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s1302a/g/1","parentIdentifier":"/us/usc/t33/s1302a/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fg%2F1","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $25,000,000 for each of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitation on use of funds","label":"2 Limitation on use of funds","identifier":"/us/usc/t33/s1302a/g/2","parentIdentifier":"/us/usc/t33/s1302a/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302a%2Fg%2F2","sourceRelease":"119-100","text":"Of the amounts made available for grants under paragraph (1), not more than 2 percent may be used to pay the administrative costs of the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
