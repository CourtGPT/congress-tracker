{"type":"section","nativeType":"section","number":"70004","heading":"Considerations by Secretary","label":"70004 Considerations by Secretary","identifier":"/us/usc/t46/s70004","parentIdentifier":"/us/usc/t46/stVII/ch700/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70004","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s70004/1","parentIdentifier":"/us/usc/t46/s70004","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70004%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s70004/1/A","parentIdentifier":"/us/usc/t46/s70004/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70004%2F1%2FA","sourceRelease":"119-100","text":"the scope and degree of the risk or hazard involved;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s70004/1/B","parentIdentifier":"/us/usc/t46/s70004/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70004%2F1%2FB","sourceRelease":"119-100","text":"vessel traffic characteristics and trends, including traffic volume, the sizes and types of vessels involved, potential interference with the flow of commercial traffic, the presence of any unusual cargoes, and other similar factors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t46/s70004/1/C","parentIdentifier":"/us/usc/t46/s70004/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70004%2F1%2FC","sourceRelease":"119-100","text":"port and waterway configurations and variations in local conditions of geography, climate, and other similar factors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t46/s70004/1/D","parentIdentifier":"/us/usc/t46/s70004/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70004%2F1%2FD","sourceRelease":"119-100","text":"the need for granting exemptions for the installation and use of equipment or devices for use with vessel traffic services for certain classes of small vessels, such as self-propelled fishing vessels and recreational vessels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t46/s70004/1/E","parentIdentifier":"/us/usc/t46/s70004/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70004%2F1%2FE","sourceRelease":"119-100","text":"the proximity of fishing grounds, oil and gas drilling and production operations, or any other potential or actual conflicting activity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t46/s70004/1/F","parentIdentifier":"/us/usc/t46/s70004/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70004%2F1%2FF","sourceRelease":"119-100","text":"environmental factors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t46/s70004/1/G","parentIdentifier":"/us/usc/t46/s70004/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70004%2F1%2FG","sourceRelease":"119-100","text":"economic impact and effects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t46/s70004/1/H","parentIdentifier":"/us/usc/t46/s70004/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70004%2F1%2FH","sourceRelease":"119-100","text":"existing vessel traffic services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t46/s70004/1/I","parentIdentifier":"/us/usc/t46/s70004/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70004%2F1%2FI","sourceRelease":"119-100","text":"local practices and customs, including voluntary arrangements and agreements within the maritime community; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s70004/2","parentIdentifier":"/us/usc/t46/s70004","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70004%2F2","sourceRelease":"119-100","text":"at the earliest possible time, consult with and receive and consider the views of representatives of the maritime community, ports and harbor authorities or associations, environmental groups, and other persons who may be affected by the proposed actions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
