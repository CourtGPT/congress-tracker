{"type":"section","nativeType":"section","number":"1708","heading":"Temporary lodging","label":"1708 Temporary lodging","identifier":"/us/usc/t38/s1708","parentIdentifier":"/us/usc/t38/ptII/ch17/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2008—Subsec. (d). substituted “medical services account” for “medical care account”.Pub. L. 110–387"],"amendments":["Amendments2008—Subsec. (d). substituted “medical services account” for “medical care account”.Pub. L. 110–387"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t38/s1708/a","parentIdentifier":"/us/usc/t38/s1708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fa","sourceRelease":"119-100","text":"The Secretary may furnish persons described in subsection (b) with temporary lodging in a Fisher house or other appropriate facility in connection with the examination, treatment, or care of a veteran under this chapter or, as provided for under subsection (e)(5), in connection with benefits administered under this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t38/s1708/b","parentIdentifier":"/us/usc/t38/s1708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1708/b/1","parentIdentifier":"/us/usc/t38/s1708/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fb%2F1","sourceRelease":"119-100","text":"A veteran who must travel a significant distance to receive care or services under this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1708/b/2","parentIdentifier":"/us/usc/t38/s1708/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fb%2F2","sourceRelease":"119-100","text":"A member of the family of a veteran and others who accompany a veteran and provide the equivalent of familial support for such veteran.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t38/s1708/c","parentIdentifier":"/us/usc/t38/s1708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1708/c/1","parentIdentifier":"/us/usc/t38/s1708/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fc%2F1","sourceRelease":"119-100","text":"is located at, or in proximity to, a Department medical facility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1708/c/2","parentIdentifier":"/us/usc/t38/s1708/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fc%2F2","sourceRelease":"119-100","text":"is available for residential use on a temporary basis by patients of that facility and others described in subsection (b)(2); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1708/c/3","parentIdentifier":"/us/usc/t38/s1708/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fc%2F3","sourceRelease":"119-100","text":"is constructed by, and donated to the Secretary by, the Zachary and Elizabeth M. Fisher Armed Services Foundation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t38/s1708/d","parentIdentifier":"/us/usc/t38/s1708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fd","sourceRelease":"119-100","text":"The Secretary may establish charges for providing lodging under this section. The proceeds from such charges shall be credited to the medical services account and shall be available until expended for the purposes of providing such lodging.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":null,"label":"e","identifier":"/us/usc/t38/s1708/e","parentIdentifier":"/us/usc/t38/s1708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1708/e/1","parentIdentifier":"/us/usc/t38/s1708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fe%2F1","sourceRelease":"119-100","text":"limiting the duration of lodging provided under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1708/e/2","parentIdentifier":"/us/usc/t38/s1708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fe%2F2","sourceRelease":"119-100","text":"establishing standards and criteria under which charges are established for such lodging under subsection (d);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1708/e/3","parentIdentifier":"/us/usc/t38/s1708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fe%2F3","sourceRelease":"119-100","text":"establishing criteria for persons considered to be accompanying a veteran under subsection (b)(2);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s1708/e/4","parentIdentifier":"/us/usc/t38/s1708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fe%2F4","sourceRelease":"119-100","text":"establishing criteria for the use of the premises of temporary lodging facilities under this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t38/s1708/e/5","parentIdentifier":"/us/usc/t38/s1708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1708%2Fe%2F5","sourceRelease":"119-100","text":"establishing any other limitations, conditions, and priorities that the Secretary considers appropriate with respect to lodging under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
