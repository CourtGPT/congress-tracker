{"type":"section","nativeType":"section","number":"5302","heading":"Definitions","label":"5302 Definitions","identifier":"/us/usc/t15/s5302","parentIdentifier":"/us/usc/t15/ch79","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5302","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s5302/1","parentIdentifier":"/us/usc/t15/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5302%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s5302/1/A","parentIdentifier":"/us/usc/t15/s5302/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5302%2F1%2FA","sourceRelease":"119-100","text":"an educational institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s5302/1/B","parentIdentifier":"/us/usc/t15/s5302/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5302%2F1%2FB","sourceRelease":"119-100","text":"a consortium of educational institutions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s5302/1/C","parentIdentifier":"/us/usc/t15/s5302/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5302%2F1%2FC","sourceRelease":"119-100","text":"a consortium of an educational institution or educational institutions with one or more of the following: Government-owned laboratories, private research organizations, nonprofit institutions, or private firms;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s5302/2","parentIdentifier":"/us/usc/t15/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5302%2F2","sourceRelease":"119-100","text":"“census region” means one of the four census regions (Northeast, South, Midwest, and West) that are designated as census regions by the Bureau of the Census as of ;October 15, 1990","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s5302/3","parentIdentifier":"/us/usc/t15/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5302%2F3","sourceRelease":"119-100","text":"“Department” means the Department of Energy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s5302/4","parentIdentifier":"/us/usc/t15/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5302%2F4","sourceRelease":"119-100","text":"“educational institution” means a degree granting institution of at least a baccalaureate level;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s5302/5","parentIdentifier":"/us/usc/t15/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5302%2F5","sourceRelease":"119-100","text":"“non-Federal source” means the United States metal casting industry, related industries, industry-related associations, individuals, organizations, universities, State agencies, or other entities supporting the metal casting industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s5302/6","parentIdentifier":"/us/usc/t15/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5302%2F6","sourceRelease":"119-100","text":"“metal casting industry” or “industry” means the industries identified by codes numbered 3321, 3322, 3324, 3325, 3363, 3364, 3365, 3366, and 3369, in the Standard Industrial Classification manual published by the Office of Management and Budget in 1987;1So in original. Probably should be capitalized.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t15/s5302/7","parentIdentifier":"/us/usc/t15/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5302%2F7","sourceRelease":"119-100","text":"“Secretary” means the Secretary of Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
