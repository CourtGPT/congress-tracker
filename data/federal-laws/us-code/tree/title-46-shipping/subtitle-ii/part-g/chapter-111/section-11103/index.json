{"type":"section","nativeType":"section","number":"11103","heading":"Slop chests","label":"11103 Slop chests","identifier":"/us/usc/t46/s11103","parentIdentifier":"/us/usc/t46/stII/ptG/ch111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11103","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevised sectionSource section (U.S. Code)1110346:67046:671Section 11103 requires that a United States vessel on a foreign or intercoastal domestic voyage be equipped with a slop chest and lists the items the slop chest must contain."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t46/s11103/a","parentIdentifier":"/us/usc/t46/s11103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11103%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s11103/a/1","parentIdentifier":"/us/usc/t46/s11103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11103%2Fa%2F1","sourceRelease":"119-100","text":"boots or shoes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s11103/a/2","parentIdentifier":"/us/usc/t46/s11103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11103%2Fa%2F2","sourceRelease":"119-100","text":"hats or caps;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s11103/a/3","parentIdentifier":"/us/usc/t46/s11103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11103%2Fa%2F3","sourceRelease":"119-100","text":"underclothing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t46/s11103/a/4","parentIdentifier":"/us/usc/t46/s11103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11103%2Fa%2F4","sourceRelease":"119-100","text":"outer clothing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t46/s11103/a/5","parentIdentifier":"/us/usc/t46/s11103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11103%2Fa%2F5","sourceRelease":"119-100","text":"foul weather clothing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t46/s11103/a/6","parentIdentifier":"/us/usc/t46/s11103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11103%2Fa%2F6","sourceRelease":"119-100","text":"everything necessary for the wear of a seaman; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t46/s11103/a/7","parentIdentifier":"/us/usc/t46/s11103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11103%2Fa%2F7","sourceRelease":"119-100","text":"a complete supply of tobacco and blankets.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t46/s11103/b","parentIdentifier":"/us/usc/t46/s11103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11103%2Fb","sourceRelease":"119-100","text":"Merchandise in the slop chest shall be sold to a seaman desiring it, for the use of the seaman, at a profit of not more than 10 percent of the reasonable wholesale value of the merchandise at the port at which the voyage began.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t46/s11103/c","parentIdentifier":"/us/usc/t46/s11103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11103%2Fc","sourceRelease":"119-100","text":"This section does not apply to a vessel on a voyage to Canada, Bermuda, the West Indies, Mexico, or Central America, or a fishing or whaling vessel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
