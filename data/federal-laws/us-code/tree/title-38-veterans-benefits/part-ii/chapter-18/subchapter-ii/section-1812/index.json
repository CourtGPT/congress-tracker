code.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1812%2Fb%2F1%2FC","sourceRelease":"119-100","text":"A fetal or neonatal infirmity with well-established causes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1812/b/2","parentIdentifier":"/us/usc/t38/s1812/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1812%2Fb%2F2","sourceRelease":"119-100","text":"In any case where affirmative evidence establishes that a covered birth defect of a child of a woman Vietnam veteran results from a cause other than the active military, naval, or air service of that veteran in the Republic of Vietnam during the Vietnam era, no benefits or assistance may be provided the child under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
