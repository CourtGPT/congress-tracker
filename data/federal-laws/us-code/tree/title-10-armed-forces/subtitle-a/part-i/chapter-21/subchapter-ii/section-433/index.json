{"type":"section","nativeType":"section","number":"433","heading":"Relationship with other Federal laws","label":"433 Relationship with other Federal laws","identifier":"/us/usc/t10/s433","parentIdentifier":"/us/usc/t10/stA/ptI/ch21/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t10/s433/a","parentIdentifier":"/us/usc/t10/s433","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433%2Fa","sourceRelease":"119-100","text":"Except as provided by subsection (b), a commercial activity conducted pursuant to this subchapter shall be carried out in accordance with applicable Federal law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Authorization of Waivers When Necessary to Maintain Security","label":"b .—Authorization of Waivers When Necessary to Maintain Security","identifier":"/us/usc/t10/s433/b","parentIdentifier":"/us/usc/t10/s433","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s433/b/1","parentIdentifier":"/us/usc/t10/s433/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433%2Fb%2F1","sourceRelease":"119-100","text":"If the Secretary of Defense determines, in connection with a commercial activity authorized pursuant to , that compliance with certain Federal laws or regulations pertaining to the management and administration of Federal agencies would create an unacceptable risk of compromise of an authorized intelligence activity, the Secretary may, to the extent necessary to prevent such compromise, waive compliance with such laws or regulations.section 431 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s433/b/2","parentIdentifier":"/us/usc/t10/s433/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433%2Fb%2F2","sourceRelease":"119-100","text":"Any determination and waiver by the Secretary under paragraph (1) shall be made in writing and shall include a specification of the laws and regulations for which compliance by the commercial activity concerned is not required consistent with this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s433/b/3","parentIdentifier":"/us/usc/t10/s433/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433%2Fb%2F3","sourceRelease":"119-100","text":"The authority of the Secretary under paragraph (1) may be delegated only to the Deputy Secretary of Defense, an Under Secretary of Defense, an Assistant Secretary of Defense, or a Secretary of a military department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Federal Laws and Regulations","label":"c .—Federal Laws and Regulations","identifier":"/us/usc/t10/s433/c","parentIdentifier":"/us/usc/t10/s433","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s433/c/1","parentIdentifier":"/us/usc/t10/s433/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433%2Fc%2F1","sourceRelease":"119-100","text":"The receipt and use of appropriated and nonappropriated funds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s433/c/2","parentIdentifier":"/us/usc/t10/s433/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433%2Fc%2F2","sourceRelease":"119-100","text":"The acquisition or management of property or services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s433/c/3","parentIdentifier":"/us/usc/t10/s433/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433%2Fc%2F3","sourceRelease":"119-100","text":"Information disclosure, retention, and management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s433/c/4","parentIdentifier":"/us/usc/t10/s433/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433%2Fc%2F4","sourceRelease":"119-100","text":"The employment of personnel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s433/c/5","parentIdentifier":"/us/usc/t10/s433/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433%2Fc%2F5","sourceRelease":"119-100","text":"Payments for travel and housing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t10/s433/c/6","parentIdentifier":"/us/usc/t10/s433/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433%2Fc%2F6","sourceRelease":"119-100","text":"The establishment of legal entities or government instrumentalities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t10/s433/c/7","parentIdentifier":"/us/usc/t10/s433/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs433%2Fc%2F7","sourceRelease":"119-100","text":"Foreign trade or financial transaction restrictions that would reveal the commercial activity as an activity of the United States Government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
