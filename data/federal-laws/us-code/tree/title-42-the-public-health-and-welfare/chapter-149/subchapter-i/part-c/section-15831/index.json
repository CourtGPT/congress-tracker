{"type":"section","nativeType":"section","number":"15831","heading":"Public energy education program","label":"15831 Public energy education program","identifier":"/us/usc/t42/s15831","parentIdentifier":"/us/usc/t42/ch149/schI/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15831","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s15831/a","parentIdentifier":"/us/usc/t42/s15831","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15831%2Fa","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary shall convene an organizational conference for the purpose of establishing an ongoing, self-sustaining national public energy education program.August 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Participants","label":"b Participants","identifier":"/us/usc/t42/s15831/b","parentIdentifier":"/us/usc/t42/s15831","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15831%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15831/b/1","parentIdentifier":"/us/usc/t42/s15831/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15831%2Fb%2F1","sourceRelease":"119-100","text":"industrial firms;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15831/b/2","parentIdentifier":"/us/usc/t42/s15831/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15831%2Fb%2F2","sourceRelease":"119-100",