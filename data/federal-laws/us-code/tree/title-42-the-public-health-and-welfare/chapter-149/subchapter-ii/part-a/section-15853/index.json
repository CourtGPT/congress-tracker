{"type":"section","nativeType":"section","number":"15853","heading":"Rebate program","label":"15853 Rebate program","identifier":"/us/usc/t42/s15853","parentIdentifier":"/us/usc/t42/ch149/schII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15853","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t42/s15853/1","parentIdentifier":"/us/usc/t42/s15853","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15853%2F1","sourceRelease":"119-100","text":"The Secretary shall establish a program providing rebates for consumers for expenditures made for the installation of a renewable energy system in connection with a dwelling unit or small business.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Amount of rebate","label":"2 Amount of rebate","identifier":"/us/usc/t42/s15853/2","parentIdentifier":"/us/usc/t42/s15853","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15853%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15853/2/A","parentIdentifier":"/us/usc/t42/s15853/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15853%2F2%2FA","sourceRelease":"119-100","text":"25 percent of the expenditures described in paragraph (1) made by the consumer; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15853/2/B","parentIdentifier":"/us/usc/t42/s15853/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15853%2F2%2FB","sourceRelease":"119-100","text":"$3,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Definition","label":"3 Definition","identifier":"/us/usc/t42/s15853/3","parentIdentifier":"/us/usc/t42/s15853","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15853%2F3","sourceRelease":"119-100","text":"For purposes of this section, the term “renewable energy system” has the meaning given that term in .section 6865(c)(6)(A) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Authorization of appropriations","label":"4 Authorization of appropriations","identifier":"/us/usc/t42/s15853/4","parentIdentifier":"/us/usc/t42/s15853","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15853%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15853/4/A","parentIdentifier":"/us/usc/t42/s15853/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15853%2F4%2FA","sourceRelease":"119-100","text":"$150,000,000 for fiscal year 2006;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15853/4/B","parentIdentifier":"/us/usc/t42/s15853/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15853%2F4%2FB","sourceRelease":"119-100","text":"$150,000,000 for fiscal year 2007;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s15853/4/C","parentIdentifier":"/us/usc/t42/s15853/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15853%2F4%2FC","sourceRelease":"119-100","text":"$200,000,000 for fiscal year 2008;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s15853/4/D","parentIdentifier":"/us/usc/t42/s15853/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15853%2F4%2FD","sourceRelease":"119-100","text":"$250,000,000 for fiscal year 2009; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s15853/4/E","parentIdentifier":"/us/usc/t42/s15853/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15853%2F4%2FE","sourceRelease":"119-100","text":"$250,000,000 for fiscal year 2010.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
