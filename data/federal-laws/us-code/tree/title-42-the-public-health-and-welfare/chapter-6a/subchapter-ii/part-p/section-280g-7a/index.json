{"type":"section","nativeType":"section","number":"280g–7a","heading":"Surveillance of neurological diseases","label":"280g–7a Surveillance of neurological diseases","identifier":"/us/usc/t42/s280g–7a","parentIdentifier":"/us/usc/t42/ch6A/schII/ptP","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s280g–7a/a","parentIdentifier":"/us/usc/t42/s280g–7a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s280g–7a/a/1","parentIdentifier":"/us/usc/t42/s280g–7a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fa%2F1","sourceRelease":"119-100","text":"enhance and expand infrastructure and activities to track the epidemiology of neurological diseases; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s280g–7a/a/2","parentIdentifier":"/us/usc/t42/s280g–7a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fa%2F2","sourceRelease":"119-100","text":"incorporate information obtained through such activities into an integrated surveillance system, which may consist of or include a registry, to be known as the National Neurological Conditions Surveillance System.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Research","label":"b Research","identifier":"/us/usc/t42/s280g–7a/b","parentIdentifier":"/us/usc/t42/s280g–7a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fb","sourceRelease":"119-100","text":"The Secretary shall ensure that the National Neurological Conditions Surveillance System is designed in a manner that facilitates further research on neurological diseases.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Content","label":"c Content","identifier":"/us/usc/t42/s280g–7a/c","parentIdentifier":"/us/usc/t42/s280g–7a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s280g–7a/c/1","parentIdentifier":"/us/usc/t42/s280g–7a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fc%2F1","sourceRelease":"119-100","text":"shall provide for the collection and storage of information on the incidence and prevalence of neurological diseases in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s280g–7a/c/2","parentIdentifier":"/us/usc/t42/s280g–7a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s280g–7a/c/2/A","parentIdentifier":"/us/usc/t42/s280g–7a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fc%2F2%2FA","sourceRelease":"119-100","text":"demographics, such as age, race, ethnicity, sex, geographic location, family history, and other information, as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s280g–7a/c/2/B","parentIdentifier":"/us/usc/t42/s280g–7a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fc%2F2%2FB","sourceRelease":"119-100","text":"risk factors that may be associated with neurological diseases, such as genetic and environmental risk factors and other information, as appropriate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s280g–7a/c/2/C","parentIdentifier":"/us/usc/t42/s280g–7a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fc%2F2%2FC","sourceRelease":"119-100","text":"diagnosis and progression markers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s280g–7a/c/3","parentIdentifier":"/us/usc/t42/s280g–7a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s280g–7a/c/3/A","parentIdentifier":"/us/usc/t42/s280g–7a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fc%2F3%2FA","sourceRelease":"119-100","text":"the natural history of the diseases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s280g–7a/c/3/B","parentIdentifier":"/us/usc/t42/s280g–7a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fc%2F3%2FB","sourceRelease":"119-100","text":"the prevention of the diseases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s280g–7a/c/3/C","parentIdentifier":"/us/usc/t42/s280g–7a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fc%2F3%2FC","sourceRelease":"119-100","text":"the detection, management, and treatment approaches for the diseases; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s280g–7a/c/3/D","parentIdentifier":"/us/usc/t42/s280g–7a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fc%2F3%2FD","sourceRelease":"119-100","text":"the development of outcomes measures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s280g–7a/c/4","parentIdentifier":"/us/usc/t42/s280g–7a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fc%2F4","sourceRelease":"119-100","text":"may address issues identified during the consultation process under subsection (d); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s280g–7a/c/5","parentIdentifier":"/us/usc/t42/s280g–7a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fc%2F5","sourceRelease":"119-100","text":"initially may address a limited number of neurological diseases.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Consultation","label":"d Consultation","identifier":"/us/usc/t42/s280g–7a/d","parentIdentifier":"/us/usc/t42/s280g–7a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s280g–7a/d/1","parentIdentifier":"/us/usc/t42/s280g–7a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fd%2F1","sourceRelease":"119-100","text":"epidemiologists with experience in disease surveillance or registries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s280g–7a/d/2","parentIdentifier":"/us/usc/t42/s280g–7a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s280g–7a/d/2/A","parentIdentifier":"/us/usc/t42/s280g–7a/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fd%2F2%2FA","sourceRelease":"119-100","text":"focus on neurological diseases; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s280g–7a/d/2/B","parentIdentifier":"/us/usc/t42/s280g–7a/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fd%2F2%2FB","sourceRelease":"119-100","text":"have demonstrated experience in research, care, or patient services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s280g–7a/d/3","parentIdentifier":"/us/usc/t42/s280g–7a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fd%2F3","sourceRelease":"119-100","text":"health information technology experts or other information management specialists;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s280g–7a/d/4","parentIdentifier":"/us/usc/t42/s280g–7a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fd%2F4","sourceRelease":"119-100","text":"clinicians with expertise in neurological diseases; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s280g–7a/d/5","parentIdentifier":"/us/usc/t42/s280g–7a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fd%2F5","sourceRelease":"119-100","text":"research scientists with experience conducting translational research or utilizing surveillance systems for scientific research purposes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Grants","label":"e Grants","identifier":"/us/usc/t42/s280g–7a/e","parentIdentifier":"/us/usc/t42/s280g–7a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fe","sourceRelease":"119-100","text":"The Secretary may award grants to, or enter into contracts or cooperative agreements with, public or private nonprofit entities to carry out activities under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Coordination with other Federal, State, and local agencies","label":"f Coordination with other Federal, State, and local agencies","identifier":"/us/usc/t42/s280g–7a/f","parentIdentifier":"/us/usc/t42/s280g–7a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s280g–7a/f/1","parentIdentifier":"/us/usc/t42/s280g–7a/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s280g–7a/f/1/A","parentIdentifier":"/us/usc/t42/s280g–7a/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Ff%2F1%2FA","sourceRelease":"119-100","text":"to Federal departments and agencies, such as the National Institutes of Health and the Department of Veterans Affairs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s280g–7a/f/1/B","parentIdentifier":"/us/usc/t42/s280g–7a/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Ff%2F1%2FB","sourceRelease":"119-100","text":"to State and local agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s280g–7a/f/2","parentIdentifier":"/us/usc/t42/s280g–7a/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Ff%2F2","sourceRelease":"119-100","text":"identify, build upon, leverage, and coordinate among existing data and surveillance systems, surveys, registries, and other Federal public health infrastructure, wherever practicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Public access","label":"g Public access","identifier":"/us/usc/t42/s280g–7a/g","parentIdentifier":"/us/usc/t42/s280g–7a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fg","sourceRelease":"119-100","text":"Subject to subsection (h), the Secretary shall ensure that information and analysis in the National Neurological Conditions Surveillance System are available, as appropriate, to the public, including researchers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Privacy","label":"h Privacy","identifier":"/us/usc/t42/s280g–7a/h","parentIdentifier":"/us/usc/t42/s280g–7a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fh","sourceRelease":"119-100","text":"The Secretary shall ensure that information and analysis in the National Neurological Conditions Surveillance System are made available only to the extent permitted by applicable Federal and State law, and in a manner that protects personal privacy, to the extent required by applicable Federal and State privacy law, at a minimum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Reports","label":"i Reports","identifier":"/us/usc/t42/s280g–7a/i","parentIdentifier":"/us/usc/t42/s280g–7a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Report on information and analyses","label":"1 Report on information and analyses","identifier":"/us/usc/t42/s280g–7a/i/1","parentIdentifier":"/us/usc/t42/s280g–7a/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fi%2F1","sourceRelease":"119-100","text":"Not later than 1 year after the date on which any system is established under this section, the Secretary shall submit an interim report to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives regarding aggregate information collected pursuant to this section and epidemiological analyses, as appropriate. Such report shall be posted on the Internet website of the Department of Health and Human Services and shall be updated biennially.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Implementation report","label":"2 Implementation report","identifier":"/us/usc/t42/s280g–7a/i/2","parentIdentifier":"/us/usc/t42/s280g–7a/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fi%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s280g–7a/i/2/A","parentIdentifier":"/us/usc/t42/s280g–7a/i/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fi%2F2%2FA","sourceRelease":"119-100","text":"the development and maintenance of the National Neurological Conditions Surveillance System;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s280g–7a/i/2/B","parentIdentifier":"/us/usc/t42/s280g–7a/i/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fi%2F2%2FB","sourceRelease":"119-100","text":"the type of information collected and stored in the surveillance system;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s280g–7a/i/2/C","parentIdentifier":"/us/usc/t42/s280g–7a/i/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fi%2F2%2FC","sourceRelease":"119-100","text":"the use and availability of such information, including guidelines for such use; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s280g–7a/i/2/D","parentIdentifier":"/us/usc/t42/s280g–7a/i/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fi%2F2%2FD","sourceRelease":"119-100","text":"the use and coordination of databases that collect or maintain information on neurological diseases.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"j","heading":"Definition","label":"j Definition","identifier":"/us/usc/t42/s280g–7a/j","parentIdentifier":"/us/usc/t42/s280g–7a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fj","sourceRelease":"119-100","text":"In this section, the term “national voluntary health association” means a national nonprofit organization with chapters, other affiliated organizations, or networks in States throughout the United States with experience serving the population of individuals with neurological disease and have demonstrated experience in neurological disease research, care, and patient services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"k","heading":"Authorization of appropriations","label":"k Authorization of appropriations","identifier":"/us/usc/t42/s280g–7a/k","parentIdentifier":"/us/usc/t42/s280g–7a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%937a%2Fk","sourceRelease":"119-100","text":"To carry out this section, there is authorized to be appropriated $5,000,000 for each of fiscal years 2018 through 2022.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
