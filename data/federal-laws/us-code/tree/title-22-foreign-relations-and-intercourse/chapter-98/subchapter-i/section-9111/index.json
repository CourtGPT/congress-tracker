International Child Abduction. The Secretary shall post the Annual Report to the publicly accessible website of the Department of State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Contents","label":"b Contents","identifier":"/us/usc/t22/s9111/b","parentIdentifier":"/us/usc/t22/s9111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9111/b/1","parentIdentifier":"/us/usc/t22/s9111/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9111/b/1/A","parentIdentifier":"/us/usc/t22/s9111/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F1%2FA","sourceRelease":"119-100","text":"is a Convention country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9111/b/1/B","parentIdentifier":"/us/usc/t22/s9111/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F1%2FB","sourceRelease":"119-100","text":"is a bilateral procedures country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9111/b/1/C","parentIdentifier":"/us/usc/t22/s9111/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F1%2FC","sourceRelease":"119-100","text":"has other procedures for resolving such abductions; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s9111/b/1/D","parentIdentifier":"/us/usc/t22/s9111/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F1%2FD","sourceRelease":"119-100","text":"adheres to no protocols with respect to child abduction;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9111/b/2","parentIdentifier":"/us/usc/t22/s9111/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9111/b/2/A","parentIdentifier":"/us/usc/t22/s9111/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the number of such new abduction and access cases, respectively, reported during the preceding year and the number of children involved;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9111/b/2/B","parentIdentifier":"/us/usc/t22/s9111/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s9111/b/2/B/i","parentIdentifier":"/us/usc/t22/s9111/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the number of abduction and access cases that the Central Authority of the United States transmitted to the Central Authority of such country; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s9111/b/2/B/ii","parentIdentifier":"/us/usc/t22/s9111/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the number of abduction and access cases that were not submitted by the Central Authority to the judicial or administrative authority, as applicable, of such country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9111/b/2/C","parentIdentifier":"/us/usc/t22/s9111/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2%2FC","sourceRelease":"119-100","text":"the reason for the delay in submission of each case identified in subparagraph (B)(ii) by the Central Authority of such country to the judicial or administrative authority of that country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s9111/b/2/D","parentIdentifier":"/us/usc/t22/s9111/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2%2FD","sourceRelease":"119-100","text":"the number of unresolved abduction and access cases, respectively, the number of children involved, and the length of time each case has been pending;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t22/s9111/b/2/E","parentIdentifier":"/us/usc/t22/s9111/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s9111/b/2/E/i","parentIdentifier":"/us/usc/t22/s9111/b/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2%2FE%2Fi","sourceRelease":"119-100","text":"not located the abducted child;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s9111/b/2/E/ii","parentIdentifier":"/us/usc/t22/s9111/b/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2%2FE%2Fii","sourceRelease":"119-100","text":"failed to undertake serious efforts to locate the abducted child; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t22/s9111/b/2/E/iii","parentIdentifier":"/us/usc/t22/s9111/b/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2%2FE%2Fiii","sourceRelease":"119-100","text":"failed to enforce a return order rendered by the judicial or administrative authorities of such country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t22/s9111/b/2/F","parentIdentifier":"/us/usc/t22/s9111/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2%2FF","sourceRelease":"119-100","text":"the total number and the percentage of the total number of abduction and access cases, respectively, resolved during the preceding year;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t22/s9111/b/2/G","parentIdentifier":"/us/usc/t22/s9111/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2%2FG","sourceRelease":"119-100","text":"recommendations to improve the resolution of abduction and access cases; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t22/s9111/b/2/H","parentIdentifier":"/us/usc/t22/s9111/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F2%2FH","sourceRelease":"119-100","text":"the average time it takes to locate a child;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s9111/b/3","parentIdentifier":"/us/usc/t22/s9111/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9111/b/3/A","parentIdentifier":"/us/usc/t22/s9111/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F3%2FA","sourceRelease":"119-100","text":"Convention countries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9111/b/3/B","parentIdentifier":"/us/usc/t22/s9111/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F3%2FB","sourceRelease":"119-100","text":"bilateral procedures countries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9111/b/3/C","parentIdentifier":"/us/usc/t22/s9111/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F3%2FC","sourceRelease":"119-100","text":"countries having other procedures for resolving such abductions; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s9111/b/3/D","parentIdentifier":"/us/usc/t22/s9111/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F3%2FD","sourceRelease":"119-100","text":"countries adhering to no protocols with respect to child abduction;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s9111/b/4","parentIdentifier":"/us/usc/t22/s9111/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F4","sourceRelease":"119-100","text":"a list of Convention countries and bilateral procedures countries that have failed to comply with any of their obligations under the Hague Abduction Convention or bilateral procedures, as applicable, with respect to the resolution of abduction and access cases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s9111/b/5","parentIdentifier":"/us/usc/t22/s9111/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F5","sourceRelease":"119-100","text":"a list of countries demonstrating a pattern of noncompliance and a description of the criteria on which the determination of a pattern of noncompliance for each country is based;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s9111/b/6","parentIdentifier":"/us/usc/t22/s9111/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9111/b/6/A","parentIdentifier":"/us/usc/t22/s9111/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F6%2FA","sourceRelease":"119-100","text":"to ratify or accede to the Hague Abduction Convention;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9111/b/6/B","parentIdentifier":"/us/usc/t22/s9111/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F6%2FB","sourceRelease":"119-100","text":"to enter into or implement other bilateral procedures, including memoranda of understanding, with the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9111/b/6/C","parentIdentifier":"/us/usc/t22/s9111/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F6%2FC","sourceRelease":"119-100","text":"to address pending abduction and access cases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t22/s9111/b/7","parentIdentifier":"/us/usc/t22/s9111/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F7","sourceRelease":"119-100","text":"the number of cases resolved without abducted children being returned to the United States from Convention countries, bilateral procedures countries, or other non-Convention countries, and number of children involved in such cases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t22/s9111/b/8","parentIdentifier":"/us/usc/t22/s9111/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F8","sourceRelease":"119-100","text":"a list of countries that became Convention countries with respect to the United States during the preceding year;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t22/s9111/b/9","parentIdentifier":"/us/usc/t22/s9111/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F9","sourceRelease":"119-100","text":"information about efforts to seek resolution of abduction cases of children whose habitual residence is in the United States and whose abduction occurred before the Hague Abduction Convention entered into force with respect to the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t22/s9111/b/10","parentIdentifier":"/us/usc/t22/s9111/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fb%2F10","sourceRelease":"119-100","text":"the total number of pending cases the Department of State has assigned to case officers and number of children involved for each country and as a total for all countries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Exceptions","label":"c Exceptions","identifier":"/us/usc/t22/s9111/c","parentIdentifier":"/us/usc/t22/s9111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fc","sourceRelease":"119-100","text":"Unless a left-behind parent provides written permission to the Central Authority of the United States to include personally identifiable information about the parent or the child in the Annual Report, the Annual Report may not include any personally identifiable information about any such parent, child, or party to an abduction or access case involving such parent or child.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Additional sections","label":"d Additional sections","identifier":"/us/usc/t22/s9111/d","parentIdentifier":"/us/usc/t22/s9111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9111/d/1","parentIdentifier":"/us/usc/t22/s9111/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fd%2F1","sourceRelease":"119-100","text":"information on the number of unresolved abduction cases affecting military parents;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9111/d/2","parentIdentifier":"/us/usc/t22/s9111/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fd%2F2","sourceRelease":"119-100","text":"a description of the assistance offered to such military parents;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s9111/d/3","parentIdentifier":"/us/usc/t22/s9111/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fd%2F3","sourceRelease":"119-100","text":"information on the use of airlines in abductions, voluntary airline practices to prevent abductions, and recommendations for best airline practices to prevent abductions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s9111/d/4","parentIdentifier":"/us/usc/t22/s9111/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fd%2F4","sourceRelease":"119-100","text":"information on actions taken by the Central Authority of the United States to train domestic judges in the application of the Hague Abduction Convention; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s9111/d/5","parentIdentifier":"/us/usc/t22/s9111/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fd%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9111/d/5/A","parentIdentifier":"/us/usc/t22/s9111/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fd%2F5%2FA","sourceRelease":"119-100","text":"abductions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9111/d/5/B","parentIdentifier":"/us/usc/t22/s9111/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fd%2F5%2FB","sourceRelease":"119-100","text":"the risk of loss of contact with children; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9111/d/5/C","parentIdentifier":"/us/usc/t22/s9111/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fd%2F5%2FC","sourceRelease":"119-100","text":"the legal means available to resolve such cases.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Omitted","label":"e Omitted","identifier":"/us/usc/t22/s9111/e","parentIdentifier":"/us/usc/t22/s9111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Notification to Congress on countries in noncompliance","label":"f Notification to Congress on countries in noncompliance","identifier":"/us/usc/t22/s9111/f","parentIdentifier":"/us/usc/t22/s9111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s9111/f/1","parentIdentifier":"/us/usc/t22/s9111/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Ff%2F1","sourceRelease":"119-100","text":"The Secretary of State shall include, in a separate section of the Annual Report, the Secretary’s determination, pursuant to the provisions under , of whether each country listed in the report has engaged in a pattern of noncompliance in cases of child abduction during the preceding 12 months.section 9122(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t22/s9111/f/2","parentIdentifier":"/us/usc/t22/s9111/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9111/f/2/A","parentIdentifier":"/us/usc/t22/s9111/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Ff%2F2%2FA","sourceRelease":"119-100","text":"shall identify any action or actions described in (or commensurate action as provided in ) that have been taken by the Secretary with respect to each country;section 9122(d) of this titlesection 9122(e) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9111/f/2/B","parentIdentifier":"/us/usc/t22/s9111/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Ff%2F2%2FB","sourceRelease":"119-100","text":"shall describe the basis for the Secretary’s determination of the pattern of noncompliance by each country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9111/f/2/C","parentIdentifier":"/us/usc/t22/s9111/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9111%2Ff%2F2%2FC","sourceRelease":"119-100","text":"shall indicate whether noneconomic policy options designed to resolve the pattern of noncompliance have reasonably been exhausted, including the consultations required under .section 9123 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
