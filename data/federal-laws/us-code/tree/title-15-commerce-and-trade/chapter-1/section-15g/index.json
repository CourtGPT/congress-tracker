/t15/s15g/2","parentIdentifier":"/us/usc/t15/s15g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs15g%2F2","sourceRelease":"119-100","text":"The term “State” means a State, the District of Columbia, the Commonwealth of Puerto Rico, and any other territory or possession of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s15g/3","parentIdentifier":"/us/usc/t15/s15g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs15g%2F3","sourceRelease":"119-100","text":"The term “natural persons” does not include proprietorships or partnerships.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
