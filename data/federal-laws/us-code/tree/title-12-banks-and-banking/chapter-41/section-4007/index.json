{"type":"section","nativeType":"section","number":"4007","heading":"Effect on State law","label":"4007 Effect on State law","identifier":"/us/usc/t12/s4007","parentIdentifier":"/us/usc/t12/ch41","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4007","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t12/s4007/a","parentIdentifier":"/us/usc/t12/s4007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4007%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4007/a/1","parentIdentifier":"/us/usc/t12/s4007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4007%2Fa%2F1","sourceRelease":"119-100","text":"supersede the provisions of this chapter and any regulations by the Board to the extent such provisions relate to the time by which funds deposited or received for deposit in an account shall be available for withdrawal; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4007/a/2","parentIdentifier":"/us/usc/t12/s4007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4007%2Fa%2F2","sourceRelease":"119-100","text":"apply to all federally insured depository institutions located within such State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Override of certain State laws","label":"b Override of certain State laws","identifier":"/us/usc/t12/s4007/b","parentIdentifier":"/us/usc/t12/s4007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4007%2Fb","sourceRelease":"119-100","text":"Except as provided in subsection (a), this chapter and regulations prescribed under this chapter shall supersede any provision of the law of any State, including the Uniform Commercial Code as in effect in such State, which is inconsistent with this chapter or such regulations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
