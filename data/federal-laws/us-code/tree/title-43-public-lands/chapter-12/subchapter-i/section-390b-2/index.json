ype":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s390b–2/b/3","parentIdentifier":"/us/usc/t43/s390b–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fb%2F3","sourceRelease":"119-100","text":"construction of facilities for delivery of water from pumping stations constructed by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t43/s390b–2/b/4","parentIdentifier":"/us/usc/t43/s390b–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fb%2F4","sourceRelease":"119-100","text":"construction of facilities to access water; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t43/s390b–2/b/5","parentIdentifier":"/us/usc/t43/s390b–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fb%2F5","sourceRelease":"119-100","text":"a combination of the activities described in paragraphs (1) through (4).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Exclusions","label":"c Exclusions","identifier":"/us/usc/t43/s390b–2/c","parentIdentifier":"/us/usc/t43/s390b–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s390b–2/c/1","parentIdentifier":"/us/usc/t43/s390b–2/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fc%2F1","sourceRelease":"119-100","text":"reallocates existing water supply or hydropower storage; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s390b–2/c/2","parentIdentifier":"/us/usc/t43/s390b–2/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fc%2F2","sourceRelease":"119-100","text":"reduces water available for any authorized project purpose.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Other Federal projects","label":"d Other Federal projects","identifier":"/us/usc/t43/s390b–2/d","parentIdentifier":"/us/usc/t43/s390b–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fd","sourceRelease":"119-100","text":"In any case in which a proposal relates to a Federal project that is not operated by the Secretary, this section shall apply only to activities under the authority of the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Review process","label":"e Review process","identifier":"/us/usc/t43/s390b–2/e","parentIdentifier":"/us/usc/t43/s390b–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Notice","label":"1 Notice","identifier":"/us/usc/t43/s390b–2/e/1","parentIdentifier":"/us/usc/t43/s390b–2/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fe%2F1","sourceRelease":"119-100","text":"On receipt of a proposal submitted under subsection (a), the Secretary shall provide a copy of the proposal to each entity described in paragraph (2) and, if applicable, the Federal agency that operates the project, in the case of a project operated by an agency other than the Department of the Army.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Public participation","label":"2 Public participation","identifier":"/us/usc/t43/s390b–2/e/2","parentIdentifier":"/us/usc/t43/s390b–2/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s390b–2/e/2/A","parentIdentifier":"/us/usc/t43/s390b–2/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fe%2F2%2FA","sourceRelease":"119-100","text":"affected States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s390b–2/e/2/B","parentIdentifier":"/us/usc/t43/s390b–2/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fe%2F2%2FB","sourceRelease":"119-100","text":"power marketing administrations, in the case of reservoirs with Federal hydropower projects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t43/s390b–2/e/2/C","parentIdentifier":"/us/usc/t43/s390b–2/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fe%2F2%2FC","sourceRelease":"119-100","text":"entities responsible for operation and maintenance costs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t43/s390b–2/e/2/D","parentIdentifier":"/us/usc/t43/s390b–2/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fe%2F2%2FD","sourceRelease":"119-100","text":"any entity that has a contractual right from the Federal Government or a State to withdraw water from, or use storage at, the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t43/s390b–2/e/2/E","parentIdentifier":"/us/usc/t43/s390b–2/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fe%2F2%2FE","sourceRelease":"119-100","text":"entities that the State determines hold rights under State law to the use of water from the project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t43/s390b–2/e/2/F","parentIdentifier":"/us/usc/t43/s390b–2/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Fe%2F2%2FF","sourceRelease":"119-100","text":"units of local government with flood risk reduction responsibilities downstream of the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorities","label":"f Authorities","identifier":"/us/usc/t43/s390b–2/f","parentIdentifier":"/us/usc/t43/s390b–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s390b–2/f/1","parentIdentifier":"/us/usc/t43/s390b–2/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390b%E2%80%932%2Ff%2F1","sourceRelease":"119-100","text":"