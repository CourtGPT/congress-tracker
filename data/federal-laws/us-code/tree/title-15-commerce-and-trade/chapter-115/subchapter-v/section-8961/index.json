{"type":"section","nativeType":"section","number":"8961","heading":"PFAS destruction and disposal guidance","label":"8961 PFAS destruction and disposal guidance","identifier":"/us/usc/t15/s8961","parentIdentifier":"/us/usc/t15/ch115/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s8961/a","parentIdentifier":"/us/usc/t15/s8961","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8961/a/1","parentIdentifier":"/us/usc/t15/s8961/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961%2Fa%2F1","sourceRelease":"119-100","text":"aqueous film-forming foam;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8961/a/2","parentIdentifier":"/us/usc/t15/s8961/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961%2Fa%2F2","sourceRelease":"119-100","text":"soil and biosolids;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8961/a/3","parentIdentifier":"/us/usc/t15/s8961/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961%2Fa%2F3","sourceRelease":"119-100","text":"textiles, other than consumer goods, treated with perfluoroalkyl and polyfluoroalkyl substances;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s8961/a/4","parentIdentifier":"/us/usc/t15/s8961/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961%2Fa%2F4","sourceRelease":"119-100","text":"spent filters, membranes, resins, granular carbon, and other waste from water treatment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s8961/a/5","parentIdentifier":"/us/usc/t15/s8961/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961%2Fa%2F5","sourceRelease":"119-100","text":"landfill leachate containing perfluoroalkyl and polyfluoroalkyl substances; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s8961/a/6","parentIdentifier":"/us/usc/t15/s8961/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961%2Fa%2F6","sourceRelease":"119-100","text":"solid, liquid, or gas waste streams containing perfluoroalkyl and polyfluoroalkyl substances from facilities manufacturing or using perfluoroalkyl and polyfluoroalkyl substances.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Considerations; inclusions","label":"b Considerations; inclusions","identifier":"/us/usc/t15/s8961/b","parentIdentifier":"/us/usc/t15/s8961","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8961/b/1","parentIdentifier":"/us/usc/t15/s8961/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8961/b/1/A","parentIdentifier":"/us/usc/t15/s8961/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the potential for releases of perfluoroalkyl and polyfluoroalkyl substances during destruction or disposal, including through volatilization, air dispersion, or leachate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8961/b/1/B","parentIdentifier":"/us/usc/t15/s8961/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961%2Fb%2F1%2FB","sourceRelease":"119-100","text":"potentially vulnerable populations living near likely destruction or disposal sites; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8961/b/2","parentIdentifier":"/us/usc/t15/s8961/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961%2Fb%2F2","sourceRelease":"119-100","text":"provide guidance on testing and monitoring air, effluent, and soil near potential destruction or disposal sites for releases described in paragraph (1)(A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Revisions","label":"c Revisions","identifier":"/us/usc/t15/s8961/c","parentIdentifier":"/us/usc/t15/s8961","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8961%2Fc","sourceRelease":"119-100","text":"The Administrator shall publish revisions to the interim guidance under subsection (a) as the Administrator determines to be appropriate, but not less frequently than once every 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
