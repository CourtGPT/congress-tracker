{"type":"section","nativeType":"section","number":"2279aa–14","heading":"Federal jurisdiction","label":"2279aa–14 Federal jurisdiction","identifier":"/us/usc/t12/s2279aa–14","parentIdentifier":"/us/usc/t12/ch23/schVIII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%9314","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s2279aa–14/1","parentIdentifier":"/us/usc/t12/s2279aa–14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%9314%2F1","sourceRelease":"119-100","text":"The Corporation shall be considered an agency under sections 1345 and 1442 of such title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s2279aa–14/2","parentIdentifier":"/us/usc/t12/s2279aa–14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%9314%2F2","sourceRelease":"119-100","text":"All civil actions to which the Corporation is a party shall be deemed to arise under the laws of the United States and, to the extent applicable, shall be deemed to be governed by Federal common law. The district courts of the United States shall have original jurisdiction of all such actions, without regard to amount of value.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t12/s2279aa–14/3","parentIdentifier":"/us/usc/t12/s2279aa–14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%9314%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s2279aa–14/3/A","parentIdentifier":"/us/usc/t12/s2279aa–14/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%9314%2F3%2FA","sourceRelease":"119-100","text":"to the District Court of the United States for the district and division embracing the place where the same is pending; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s2279aa–14/3/B","parentIdentifier":"/us/usc/t12/s2279aa–14/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%9314%2F3%2FB","sourceRelease":"119-100","text":"if there is no such district court, to the District Court of the United States for the district in which the principal office of the Corporation is located;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t12/s2279aa–14/4","parentIdentifier":"/us/usc/t12/s2279aa–14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%9314%2F4","sourceRelease":"119-100","text":"No attachment or execution shall be issued against the Corporation or any of the property of the Corporation before final judgment in any Federal, State, or other court.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
