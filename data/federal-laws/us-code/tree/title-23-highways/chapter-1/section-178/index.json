{"type":"section","nativeType":"section","number":"178","heading":"Environmental review implementation funds","label":"178 Environmental review implementation funds","identifier":"/us/usc/t23/s178","parentIdentifier":"/us/usc/t23/ch1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t23/s178/a","parentIdentifier":"/us/usc/t23/s178","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t23/s178/a/1","parentIdentifier":"/us/usc/t23/s178/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fa%2F1","sourceRelease":"119-100","text":"the provision of guidance, technical assistance, templates, training, or tools to facilitate an efficient and effective environmental review process for surface transportation projects and any administrative expenses of the Federal Highway Administration to conduct activities described in this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t23/s178/a/2","parentIdentifier":"/us/usc/t23/s178/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t23/s178/a/2/A","parentIdentifier":"/us/usc/t23/s178/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fa%2F2%2FA","sourceRelease":"119-100","text":"to build capacity of such eligible entities to conduct environmental review processes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t23/s178/a/2/B","parentIdentifier":"/us/usc/t23/s178/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t23/s178/a/2/B/i","parentIdentifier":"/us/usc/t23/s178/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"defining the scope or study areas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t23/s178/a/2/B/ii","parentIdentifier":"/us/usc/t23/s178/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"identifying impacts, mitigation measures, and reasonable alternatives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t23/s178/a/2/B/iii","parentIdentifier":"/us/usc/t23/s178/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fa%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"preparing planning and environmental studies and other documents prior to and during the environmental review process, for potential use in the environmental review process in accordance with applicable statutes and regulations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t23/s178/a/2/B/iv","parentIdentifier":"/us/usc/t23/s178/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fa%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"conducting public engagement activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t23/s178/a/2/B/v","parentIdentifier":"/us/usc/t23/s178/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fa%2F2%2FB%2Fv","sourceRelease":"119-100","text":"carrying out permitting or other activities, as the Administrator determines to be appropriate, to support the timely completion of an environmental review process required for a proposed project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t23/s178/a/2/C","parentIdentifier":"/us/usc/t23/s178/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fa%2F2%2FC","sourceRelease":"119-100","text":"for administrative expenses of the eligible entity to conduct any of the activities described in subparagraphs (A) and (B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Cost Share.—","label":"b Cost Share.—","identifier":"/us/usc/t23/s178/b","parentIdentifier":"/us/usc/t23/s178","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t23/s178/b/1","parentIdentifier":"/us/usc/t23/s178/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fb%2F1","sourceRelease":"119-100","text":"The Federal share of the cost of an activity carried out under this section by an eligible entity shall be not more than 80 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Source of funds","label":"2 .—Source of funds","identifier":"/us/usc/t23/s178/b/2","parentIdentifier":"/us/usc/t23/s178/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fb%2F2","sourceRelease":"119-100","text":"The non-Federal share of the cost of an activity carried out under this section by an eligible entity may be satisfied using funds made available to the eligible entity under any other Federal, State, or local grant program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Definitions","label":"c .—Definitions","identifier":"/us/usc/t23/s178/c","parentIdentifier":"/us/usc/t23/s178","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Administrator","label":"1 .—Administrator","identifier":"/us/usc/t23/s178/c/1","parentIdentifier":"/us/usc/t23/s178/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fc%2F1","sourceRelease":"119-100","text":"The term “Administrator” means the Administrator of the Federal Highway Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Eligible entity","label":"2 .—Eligible entity","identifier":"/us/usc/t23/s178/c/2","parentIdentifier":"/us/usc/t23/s178/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t23/s178/c/2/A","parentIdentifier":"/us/usc/t23/s178/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fc%2F2%2FA","sourceRelease":"119-100","text":"a State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t23/s178/c/2/B","parentIdentifier":"/us/usc/t23/s178/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fc%2F2%2FB","sourceRelease":"119-100","text":"a unit of local government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t23/s178/c/2/C","parentIdentifier":"/us/usc/t23/s178/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fc%2F2%2FC","sourceRelease":"119-100","text":"a political subdivision of a State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t23/s178/c/2/D","parentIdentifier":"/us/usc/t23/s178/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fc%2F2%2FD","sourceRelease":"119-100","text":"a territory of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t23/s178/c/2/E","parentIdentifier":"/us/usc/t23/s178/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fc%2F2%2FE","sourceRelease":"119-100","text":"an entity described in section 207(m)(1)(E);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t23/s178/c/2/F","parentIdentifier":"/us/usc/t23/s178/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fc%2F2%2FF","sourceRelease":"119-100","text":"a recipient of funds under section 203; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t23/s178/c/2/G","parentIdentifier":"/us/usc/t23/s178/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fc%2F2%2FG","sourceRelease":"119-100","text":"a metropolitan planning organization (as defined in section 134(b)(2)).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Environmental review process","label":"3 .—Environmental review process","identifier":"/us/usc/t23/s178/c/3","parentIdentifier":"/us/usc/t23/s178/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fc%2F3","sourceRelease":"119-100","text":"The term “environmental review process” has the meaning given the term in section 139(a)(5).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Proposed project","label":"4 .—Proposed project","identifier":"/us/usc/t23/s178/c/4","parentIdentifier":"/us/usc/t23/s178/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs178%2Fc%2F4","sourceRelease":"119-100","text":"The term “proposed project” means a surface transportation project for which an environmental review process is required.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
