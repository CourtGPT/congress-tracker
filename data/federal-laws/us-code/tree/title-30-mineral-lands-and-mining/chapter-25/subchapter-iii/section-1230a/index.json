{"type":"section","nativeType":"section","number":"1230a","heading":"Strategic Resources Generic Mineral Technology Center","label":"1230a Strategic Resources Generic Mineral Technology Center","identifier":"/us/usc/t30/s1230a","parentIdentifier":"/us/usc/t30/ch25/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1230a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Mining and Mineral Resources Research Institute Act of 1984, and not as part of the Surface Mining Control and Reclamation Act of 1977 which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t30/s1230a/a","parentIdentifier":"/us/usc/t30/s1230a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1230a%2Fa","sourceRelease":"119-100","text":"The Secretary of Interior is authorized and directed to establish a Strategic Resources Mineral Technology Center (hereinafter referred to as the “center”) for the purpose of improving existing, and developing new, technologies that will decrease the dependence of the United States on supplies of strategic and critical minerals.1So in original. Probably should be “of the”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Functions","label":"b Functions","identifier":"/us/usc/t30/s1230a/b","parentIdentifier":"/us/usc/t30/s1230a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1230a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t30/s1230a/b/1","parentIdentifier":"/us/usc/t30/s1230a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1230a%2Fb%2F1","sourceRelease":"119-100","text":"provide for studies and technology development in the areas of mineral extraction and refining processes, product substitution and conservation of mineral resources through recycling and advanced processing and fabrication methods;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t30/s1230a/b/2","parentIdentifier":"/us/usc/t30/s1230a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1230a%2Fb%2F2","sourceRelease":"119-100","text":"identify new deposits of strategic and critical mineral resources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t30/s1230a/b/3","parentIdentifier":"/us/usc/t30/s1230a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1230a%2Fb%2F3","sourceRelease":"119-100","text":"facilitate the transfer of information, studies, and technologies developed by the center to the private sector.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Criteria","label":"c Criteria","identifier":"/us/usc/t30/s1230a/c","parentIdentifier":"/us/usc/t30/s1230a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1230a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t30/s1230a/c/1","parentIdentifier":"/us/usc/t30/s1230a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1230a%2Fc%2F1","sourceRelease":"119-100","text":"does not currently host a generic mineral technology center;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t30/s1230a/c/2","parentIdentifier":"/us/usc/t30/s1230a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1230a%2Fc%2F2","sourceRelease":"119-100","text":"has established advanced degree programs in geology and geological engineering, and metallurgical and mining engineering;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t30/s1230a/c/3","parentIdentifier":"/us/usc/t30/s1230a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1230a%2Fc%2F3","sourceRelease":"119-100","text":"has expertise in materials and advanced processing research; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t30/s1230a/c/4","parentIdentifier":"/us/usc/t30/s1230a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1230a%2Fc%2F4","sourceRelease":"119-100","text":"is located west of the 100th meridian.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t30/s1230a/d","parentIdentifier":"/us/usc/t30/s1230a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1230a%2Fd","sourceRelease":"119-100","text":"There is authorized to be appropriated such sums as may be necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
