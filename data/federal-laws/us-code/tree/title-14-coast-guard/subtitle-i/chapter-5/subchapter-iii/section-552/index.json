raph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t14/s552/c/2/G","parentIdentifier":"/us/usc/t14/s552/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fc%2F2%2FG","sourceRelease":"119-100","text":"commercial and recreational fishermen, including fishing associations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t14/s552/c/2/H","parentIdentifier":"/us/usc/t14/s552/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fc%2F2%2FH","sourceRelease":"119-100","text":"ferry operators;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t14/s552/c/2/I","parentIdentifier":"/us/usc/t14/s552/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fc%2F2%2FI","sourceRelease":"119-100","text":"marina operators;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t14/s552/c/2/J","parentIdentifier":"/us/usc/t14/s552/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fc%2F2%2FJ","sourceRelease":"119-100","text":"recreational boaters;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"K","heading":null,"label":"K","identifier":"/us/usc/t14/s552/c/2/K","parentIdentifier":"/us/usc/t14/s552/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fc%2F2%2FK","sourceRelease":"119-100","text":"passenger vessel operators; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"L","heading":null,"label":"L","identifier":"/us/usc/t14/s552/c/2/L","parentIdentifier":"/us/usc/t14/s552/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fc%2F2%2FL","sourceRelease":"119-100","text":"coastal residents.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Notification","label":"d .—Notification","identifier":"/us/usc/t14/s552/d","parentIdentifier":"/us/usc/t14/s552","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fd","sourceRelease":"119-100","text":"Not later than 30 days after the date on which the process is established under subsection (a), the Secretary shall notify the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives of such process.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
