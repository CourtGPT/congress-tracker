{"type":"section","nativeType":"section","number":"7464","heading":"Identity management research and development","label":"7464 Identity management research and development","identifier":"/us/usc/t15/s7464","parentIdentifier":"/us/usc/t15/ch100A/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2022— amended section generally. Prior to amendment, section related to Director’s continuance of program to support development of voluntary and cost-effective technical standards, metrology, testbeds, and conformance criteria, taking into account appropriate user concerns.Pub. L. 117–167"],"amendments":["Amendments2022— amended section generally. Prior to amendment, section related to Director’s continuance of program to support development of voluntary and cost-effective technical standards, metrology, testbeds, and conformance criteria, taking into account appropriate user concerns.Pub. L. 117–167"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s7464/a","parentIdentifier":"/us/usc/t15/s7464","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7464/a/1","parentIdentifier":"/us/usc/t15/s7464/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fa%2F1","sourceRelease":"119-100","text":"improve interoperability and portability among identity management technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7464/a/2","parentIdentifier":"/us/usc/t15/s7464/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fa%2F2","sourceRelease":"119-100","text":"strengthen identity proofing and verification methods used in identity management systems commensurate with the level of risk, including identity and attribute validation services provided by Federal, State, and local governments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s7464/a/3","parentIdentifier":"/us/usc/t15/s7464/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fa%2F3","sourceRelease":"119-100","text":"improve privacy protection in identity management systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s7464/a/4","parentIdentifier":"/us/usc/t15/s7464/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fa%2F4","sourceRelease":"119-100","text":"improve the accuracy, usability, and inclusivity of identity management systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Digital identity technical roadmap","label":"b Digital identity technical roadmap","identifier":"/us/usc/t15/s7464/b","parentIdentifier":"/us/usc/t15/s7464","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fb","sourceRelease":"119-100","text":"The Director, in consultation with other relevant Federal agencies and stakeholders from the private sector, shall develop and maintain a technical roadmap for digital identity management research and development focused on enabling the voluntary use and adoption of modern digital identity solutions that align with the four criteria in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Digital identity management guidance","label":"c Digital identity management guidance","identifier":"/us/usc/t15/s7464/c","parentIdentifier":"/us/usc/t15/s7464","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s7464/c/1","parentIdentifier":"/us/usc/t15/s7464/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fc%2F1","sourceRelease":"119-100","text":"The Director shall develop, and periodically update, in collaboration with other public and private sector organizations, common definitions and voluntary guidance for digital identity management systems, including identity and attribute validation services provided by Federal, State, and local governments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Guidance","label":"2 Guidance","identifier":"/us/usc/t15/s7464/c/2","parentIdentifier":"/us/usc/t15/s7464/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7464/c/2/A","parentIdentifier":"/us/usc/t15/s7464/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fc%2F2%2FA","sourceRelease":"119-100","text":"align with the four criteria in subsection (a), as practicable;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7464/c/2/B","parentIdentifier":"/us/usc/t15/s7464/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fc%2F2%2FB","sourceRelease":"119-100","text":"provide case studies of implementation of guidance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s7464/c/2/C","parentIdentifier":"/us/usc/t15/s7464/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fc%2F2%2FC","sourceRelease":"119-100","text":"incorporate voluntary technical standards and industry best practices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s7464/c/2/D","parentIdentifier":"/us/usc/t15/s7464/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fc%2F2%2FD","sourceRelease":"119-100","text":"not prescribe or otherwise require the use of specific technology products or services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Consultation","label":"3 Consultation","identifier":"/us/usc/t15/s7464/c/3","parentIdentifier":"/us/usc/t15/s7464/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7464/c/3/A","parentIdentifier":"/us/usc/t15/s7464/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fc%2F3%2FA","sourceRelease":"119-100","text":"Federal and State agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7464/c/3/B","parentIdentifier":"/us/usc/t15/s7464/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fc%2F3%2FB","sourceRelease":"119-100","text":"industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s7464/c/3/C","parentIdentifier":"/us/usc/t15/s7464/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fc%2F3%2FC","sourceRelease":"119-100","text":"potential end-users and individuals that will use services related to digital identity verification; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s7464/c/3/D","parentIdentifier":"/us/usc/t15/s7464/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7464%2Fc%2F3%2FD","sourceRelease":"119-100","text":"experts with relevant experience in the systems that enable digital identity verification, as determined by the Director.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
