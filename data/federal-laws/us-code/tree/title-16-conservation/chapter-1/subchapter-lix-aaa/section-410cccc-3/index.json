{"type":"section","nativeType":"section","number":"410cccc–3","heading":"Golden Spike National Historical Park","label":"410cccc–3 Golden Spike National Historical Park","identifier":"/us/usc/t16/s410cccc–3","parentIdentifier":"/us/usc/t16/ch1/schLIX–AAA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the John D. Dingell, Jr. Conservation, Management, and Recreation Act, and not as part of which comprises this subchapter.Pub. L. 89–102","Statutory Notes and Related Subsidiaries","Definition of “Secretary”Secretary means the Secretary of the Interior, see , set out as a note under .section 2 of Pub. L. 116–9section 1 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t16/s410cccc–3/a","parentIdentifier":"/us/usc/t16/s410cccc–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Park","label":"1 Park","identifier":"/us/usc/t16/s410cccc–3/a/1","parentIdentifier":"/us/usc/t16/s410cccc–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fa%2F1","sourceRelease":"119-100","text":"The term “Park” means the Golden Spike National Historical Park designated by subsection (b)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Program","label":"2 Program","identifier":"/us/usc/t16/s410cccc–3/a/2","parentIdentifier":"/us/usc/t16/s410cccc–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fa%2F2","sourceRelease":"119-100","text":"The term “Program” means the program to commemorate and interpret the Transcontinental Railroad authorized under subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Secretary","label":"3 Secretary","identifier":"/us/usc/t16/s410cccc–3/a/3","parentIdentifier":"/us/usc/t16/s410cccc–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fa%2F3","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary, acting through the Director of the National Park Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Transcontinental railroad","label":"4 Transcontinental railroad","identifier":"/us/usc/t16/s410cccc–3/a/4","parentIdentifier":"/us/usc/t16/s410cccc–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fa%2F4","sourceRelease":"119-100","text":"The term “Transcontinental Railroad” means the approximately 1,912-mile continuous railroad constructed between 1863 and 1869 extending from Council Bluffs, Iowa, to San Francisco, California.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Redesignation","label":"b Redesignation","identifier":"/us/usc/t16/s410cccc–3/b","parentIdentifier":"/us/usc/t16/s410cccc–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Redesignation","label":"1 Redesignation","identifier":"/us/usc/t16/s410cccc–3/b/1","parentIdentifier":"/us/usc/t16/s410cccc–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fb%2F1","sourceRelease":"119-100","text":"The Golden Spike National Historic Site designated , and placed under the administration of the National Park Service under sections 410cccc to 410cccc–2 of this title, shall be known and designated as the “Golden Spike National Historical Park”.April 2, 1957","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"References","label":"2 References","identifier":"/us/usc/t16/s410cccc–3/b/2","parentIdentifier":"/us/usc/t16/s410cccc–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fb%2F2","sourceRelease":"119-100","text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the Golden Spike National Historic Site shall be considered to be a reference to the “Golden Spike National Historical Park”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Transcontinental Railroad commemoration and program","label":"c Transcontinental Railroad commemoration and program","identifier":"/us/usc/t16/s410cccc–3/c","parentIdentifier":"/us/usc/t16/s410cccc–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s410cccc–3/c/1","parentIdentifier":"/us/usc/t16/s410cccc–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2), the Secretary shall establish within the National Park Service a program to commemorate and interpret the Transcontinental Railroad.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Study","label":"2 Study","identifier":"/us/usc/t16/s410cccc–3/c/2","parentIdentifier":"/us/usc/t16/s410cccc–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410cccc–3/c/2/A","parentIdentifier":"/us/usc/t16/s410cccc–3/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F2%2FA","sourceRelease":"119-100","text":"a historical assessment of the Transcontinental Railroad;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410cccc–3/c/2/B","parentIdentifier":"/us/usc/t16/s410cccc–3/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s410cccc–3/c/2/B/i","parentIdentifier":"/us/usc/t16/s410cccc–3/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"existing National Park System land and affiliated areas, land managed by other Federal agencies, and Federal programs that may be related to preserving, commemorating, and interpreting the Transcontinental Railroad;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s410cccc–3/c/2/B/ii","parentIdentifier":"/us/usc/t16/s410cccc–3/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s410cccc–3/c/2/B/ii/I","parentIdentifier":"/us/usc/t16/s410cccc–3/c/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F2%2FB%2Fii%2FI","sourceRelease":"119-100","text":"that are designated as, or could meet the criteria for designation as, National Historic Landmarks; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s410cccc–3/c/2/B/ii/II","parentIdentifier":"/us/usc/t16/s410cccc–3/c/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F2%2FB%2Fii%2FII","sourceRelease":"119-100","text":"that are included, or eligible for inclusion, on the National Register of Historic Places;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s410cccc–3/c/2/B/iii","parentIdentifier":"/us/usc/t16/s410cccc–3/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"any objects relating to the Transcontinental Railroad that have educational, research, or interpretative value; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s410cccc–3/c/2/B/iv","parentIdentifier":"/us/usc/t16/s410cccc–3/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"any governmental programs and nongovernmental programs of an educational, research, or interpretive nature relating to the Transcontinental Railroad; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s410cccc–3/c/2/C","parentIdentifier":"/us/usc/t16/s410cccc–3/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s410cccc–3/c/2/C/i","parentIdentifier":"/us/usc/t16/s410cccc–3/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F2%2FC%2Fi","sourceRelease":"119-100","text":"incorporating the resources identified under subparagraph (B) into the Program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s410cccc–3/c/2/C/ii","parentIdentifier":"/us/usc/t16/s410cccc–3/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F2%2FC%2Fii","sourceRelease":"119-100","text":"other appropriate ways to enhance historical research, education, interpretation, and public awareness of the Transcontinental Railroad.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Report","label":"3 Report","identifier":"/us/usc/t16/s410cccc–3/c/3","parentIdentifier":"/us/usc/t16/s410cccc–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F3","sourceRelease":"119-100","text":"Not later than 3 years after the date on which funds are made available to carry out the study under paragraph (2), the Secretary shall submit to the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a report containing the findings and recommendations of the study.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Freight railroad operations","label":"4 Freight railroad operations","identifier":"/us/usc/t16/s410cccc–3/c/4","parentIdentifier":"/us/usc/t16/s410cccc–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410cccc–3/c/4/A","parentIdentifier":"/us/usc/t16/s410cccc–3/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F4%2FA","sourceRelease":"119-100","text":"used in active freight railroad operations (or other ancillary purposes); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410cccc–3/c/4/B","parentIdentifier":"/us/usc/t16/s410cccc–3/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F4%2FB","sourceRelease":"119-100","text":"reasonably anticipated to be used for freight railroad operations in the future.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Elements of the program","label":"5 Elements of the program","identifier":"/us/usc/t16/s410cccc–3/c/5","parentIdentifier":"/us/usc/t16/s410cccc–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410cccc–3/c/5/A","parentIdentifier":"/us/usc/t16/s410cccc–3/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F5%2FA","sourceRelease":"119-100","text":"shall produce and disseminate appropriate education materials relating to the history, construction, and legacy of the Transcontinental Railroad, such as handbooks, maps, interpretive guides, or electronic information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410cccc–3/c/5/B","parentIdentifier":"/us/usc/t16/s410cccc–3/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F5%2FB","sourceRelease":"119-100","text":"may enter into appropriate cooperative agreements and memoranda of understanding and provide technical assistance to the heads of other Federal agencies, States, units of local government, regional governmental bodies, and private entities to further the purposes of the Program and this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s410cccc–3/c/5/C","parentIdentifier":"/us/usc/t16/s410cccc–3/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F5%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s410cccc–3/c/5/C/i","parentIdentifier":"/us/usc/t16/s410cccc–3/c/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F5%2FC%2Fi","sourceRelease":"119-100","text":"create and adopt an official, uniform symbol or device to identify the Program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s410cccc–3/c/5/C/ii","parentIdentifier":"/us/usc/t16/s410cccc–3/c/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fc%2F5%2FC%2Fii","sourceRelease":"119-100","text":"issue guidance for the use of the symbol or device created and adopted under clause (i).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Programmatic agreement","label":"d Programmatic agreement","identifier":"/us/usc/t16/s410cccc–3/d","parentIdentifier":"/us/usc/t16/s410cccc–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s410cccc–3/d/1","parentIdentifier":"/us/usc/t16/s410cccc–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fd%2F1","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary shall seek to enter into a programmatic agreement with the Utah State Historic Preservation Officer to add to the list of undertakings eligible for streamlined review under certain uses that would have limited physical impact to land in the Park.March 12, 2019section 306108 of title 54","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Development and consultation","label":"2 Development and consultation","identifier":"/us/usc/t16/s410cccc–3/d/2","parentIdentifier":"/us/usc/t16/s410cccc–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410cccc–3/d/2/A","parentIdentifier":"/us/usc/t16/s410cccc–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fd%2F2%2FA","sourceRelease":"119-100","text":"in accordance with applicable laws (including regulations); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410cccc–3/d/2/B","parentIdentifier":"/us/usc/t16/s410cccc–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fd%2F2%2FB","sourceRelease":"119-100","text":"in consultation with adjacent landowners, Indian Tribes, and other interested parties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Approval","label":"3 Approval","identifier":"/us/usc/t16/s410cccc–3/d/3","parentIdentifier":"/us/usc/t16/s410cccc–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410cccc–3/d/3/A","parentIdentifier":"/us/usc/t16/s410cccc–3/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fd%2F3%2FA","sourceRelease":"119-100","text":"consider any application for uses covered by the programmatic agreement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410cccc–3/d/3/B","parentIdentifier":"/us/usc/t16/s410cccc–3/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fd%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s410cccc–3/d/3/B/i","parentIdentifier":"/us/usc/t16/s410cccc–3/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fd%2F3%2FB%2Fi","sourceRelease":"119-100","text":"the programmatic agreement entered into under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s410cccc–3/d/3/B/ii","parentIdentifier":"/us/usc/t16/s410cccc–3/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fd%2F3%2FB%2Fii","sourceRelease":"119-100","text":"applicable laws (including regulations).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Invasive species","label":"e Invasive species","identifier":"/us/usc/t16/s410cccc–3/e","parentIdentifier":"/us/usc/t16/s410cccc–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cccc%E2%80%933%2Fe","sourceRelease":"119-100","text":"The Secretary shall consult with, and seek to coordinate with, adjacent landowners to address the treatment of invasive species adjacent to, and within the boundaries of, the Park.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
