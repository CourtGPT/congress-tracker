{"type":"section","nativeType":"section","number":"1815","heading":"Monetary allowance","label":"1815 Monetary allowance","identifier":"/us/usc/t38/s1815","parentIdentifier":"/us/usc/t38/ptII/ch18/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsA prior section 1815 was renumbered .section 3703(a)(2) of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Monetary Allowance","label":"a .—Monetary Allowance","identifier":"/us/usc/t38/s1815/a","parentIdentifier":"/us/usc/t38/s1815","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fa","sourceRelease":"119-100","text":"The Secretary shall pay a monthly allowance to any eligible child for any disability resulting from the covered birth defects of that child.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Schedule for Rating Disabilities","label":"b .—Schedule for Rating Disabilities","identifier":"/us/usc/t38/s1815/b","parentIdentifier":"/us/usc/t38/s1815","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1815/b/1","parentIdentifier":"/us/usc/t38/s1815/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fb%2F1","sourceRelease":"119-100","text":"The amount of the monthly allowance paid under this section shall be based on the degree of disability suffered by the child concerned, as determined in accordance with a schedule for rating disabilities resulting from covered birth defects that is prescribed by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1815/b/2","parentIdentifier":"/us/usc/t38/s1815/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fb%2F2","sourceRelease":"119-100","text":"In prescribing a schedule for rating disabilities for the purposes of this section, the Secretary shall establish four levels of disability upon which the amount of the allowance provided by this section shall be based. The levels of disability established may take into account functional limitations, including limitations on cognition, communication, motor abilities, activities of daily living, and employability.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Amount of Monthly Allowance","label":"c .—Amount of Monthly Allowance","identifier":"/us/usc/t38/s1815/c","parentIdentifier":"/us/usc/t38/s1815","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1815/c/1","parentIdentifier":"/us/usc/t38/s1815/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fc%2F1","sourceRelease":"119-100","text":"In the case of a child suffering from the lowest level of disability prescribed in the schedule for rating disabilities under subsection (b), $100.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1815/c/2","parentIdentifier":"/us/usc/t38/s1815/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1815/c/2/A","parentIdentifier":"/us/usc/t38/s1815/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fc%2F2%2FA","sourceRelease":"119-100","text":"$214; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1815/c/2/B","parentIdentifier":"/us/usc/t38/s1815/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the monthly amount payable under for the lowest level of disability prescribed for purposes of that section.section 1805(b)(3) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1815/c/3","parentIdentifier":"/us/usc/t38/s1815/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1815/c/3/A","parentIdentifier":"/us/usc/t38/s1815/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fc%2F3%2FA","sourceRelease":"119-100","text":"$743; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1815/c/3/B","parentIdentifier":"/us/usc/t38/s1815/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fc%2F3%2FB","sourceRelease":"119-100","text":"the monthly amount payable under for the intermediate level of disability prescribed for purposes of that section.section 1805(b)(3) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s1815/c/4","parentIdentifier":"/us/usc/t38/s1815/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1815/c/4/A","parentIdentifier":"/us/usc/t38/s1815/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fc%2F4%2FA","sourceRelease":"119-100","text":"$1,272; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1815/c/4/B","parentIdentifier":"/us/usc/t38/s1815/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fc%2F4%2FB","sourceRelease":"119-100","text":"the monthly amount payable under for the highest level of disability prescribed for purposes of that section.section 1805(b)(3) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Indexing to Social Security Benefit Increases","label":"d .—Indexing to Social Security Benefit Increases","identifier":"/us/usc/t38/s1815/d","parentIdentifier":"/us/usc/t38/s1815","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1815%2Fd","sourceRelease":"119-100","text":"Amounts under paragraphs (1), (2)(A), (3)(A), and (4)(A) of subsection (c) shall be subject to adjustment from time to time under .section 5312 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
