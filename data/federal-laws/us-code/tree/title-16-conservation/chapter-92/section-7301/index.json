{"type":"section","nativeType":"section","number":"7301","heading":"Purpose","label":"7301 Purpose","identifier":"/us/usc/t16/s7301","parentIdentifier":"/us/usc/t16/ch92","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7301","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s7301/1","parentIdentifier":"/us/usc/t16/s7301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7301%2F1","sourceRelease":"119-100","text":"encourages ecological, economic, and social sustainability;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s7301/2","parentIdentifier":"/us/usc/t16/s7301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7301%2F2","sourceRelease":"119-100","text":"leverages local resources with national and private resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s7301/3","parentIdentifier":"/us/usc/t16/s7301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7301%2F3","sourceRelease":"119-100","text":"facilitates the reduction of wildfire management costs, including through reestablishing natural fire regimes and reducing the risk of uncharacteristic wildfire; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s7301/4","parentIdentifier":"/us/usc/t16/s7301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7301%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s7301/4/A","parentIdentifier":"/us/usc/t16/s7301/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7301%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s7301/4/A/i","parentIdentifier":"/us/usc/t16/s7301/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7301%2F4%2FA%2Fi","sourceRelease":"119-100","text":"achieve ecological and watershed health objectives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s7301/4/A/ii","parentIdentifier":"/us/usc/t16/s7301/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7301%2F4%2FA%2Fii","sourceRelease":"119-100","text":"affect wildfire activity and management costs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s7301/4/B","parentIdentifier":"/us/usc/t16/s7301/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7301%2F4%2FB","sourceRelease":"119-100","text":"the use of forest restoration byproducts can offset treatment costs while benefitting local rural economies and improving forest health.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
