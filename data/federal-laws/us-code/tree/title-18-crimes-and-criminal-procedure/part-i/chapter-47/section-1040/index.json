{"type":"section","nativeType":"section","number":"1040","heading":"Fraud in connection with major disaster or emergency benefits","label":"1040 Fraud in connection with major disaster or emergency benefits","identifier":"/us/usc/t18/s1040","parentIdentifier":"/us/usc/t18/ptI/ch47","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1040","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t18/s1040/a","parentIdentifier":"/us/usc/t18/s1040","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1040%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s1040/a/1","parentIdentifier":"/us/usc/t18/s1040/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1040%2Fa%2F1","sourceRelease":"119-100","text":"falsifies, conceals, or covers up by any trick, scheme, or device any material fact; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s1040/a/2","parentIdentifier":"/us/usc/t18/s1040/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1040%2Fa%2F2","sourceRelease":"119-100","text":"makes any materially false, fictitious, or fraudulent statement or representation, or makes or uses any false writing or document knowing the same to contain any materially false, fictitious, or fraudulent statement or representation,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t18/s1040/b","parentIdentifier":"/us/usc/t18/s1040","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1040%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s1040/b/1","parentIdentifier":"/us/usc/t18/s1040/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1040%2Fb%2F1","sourceRelease":"119-100","text":"the authorization, transportation, transmission, transfer, disbursement, or payment of the benefit is in or affects interstate or foreign commerce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s1040/b/2","parentIdentifier":"/us/usc/t18/s1040/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1040%2Fb%2F2","sourceRelease":"119-100","text":"the benefit is transported in the mail at any point in the authorization, transportation, transmission, transfer, disbursement, or payment of that benefit; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s1040/b/3","parentIdentifier":"/us/usc/t18/s1040/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1040%2Fb%2F3","sourceRelease":"119-100","text":"the benefit is a record, voucher, payment, money, or thing of value of the United States, or of any department or agency thereof.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t18/s1040/c","parentIdentifier":"/us/usc/t18/s1040","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1040%2Fc","sourceRelease":"119-100","text":"In this section, the term “benefit” means any record, voucher, payment, money or thing of value, good, service, right, or privilege provided by the United States, a State or local government, or other entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
