{"type":"section","nativeType":"section","number":"2576b","heading":"Subpart definitions","label":"2576b Subpart definitions","identifier":"/us/usc/t19/s2576b","parentIdentifier":"/us/usc/t19/ch13/schII/ptE/spt2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Approval procedure","label":"1 Approval procedure","identifier":"/us/usc/t19/s2576b/1","parentIdentifier":"/us/usc/t19/s2576b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F1","sourceRelease":"119-100","text":"The term “approval procedure” means any registration, notification, or other mandatory administrative procedure for granting permission for a good or service to be produced, marketed, or used for a stated purpose or under stated conditions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Conformity assessment procedure","label":"2 Conformity assessment procedure","identifier":"/us/usc/t19/s2576b/2","parentIdentifier":"/us/usc/t19/s2576b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F2","sourceRelease":"119-100","text":"The term “conformity assessment procedure” means any procedure used, directly or indirectly, to determine that a technical regulation or standard is fulfilled, including sampling, testing, inspection, evaluation, verification, monitoring, auditing, assurance of conformity, accreditation, registration, or approval used for such a purpose, but does not mean an approval procedure.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Objective","label":"3 Objective","identifier":"/us/usc/t19/s2576b/3","parentIdentifier":"/us/usc/t19/s2576b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s2576b/3/A","parentIdentifier":"/us/usc/t19/s2576b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F3%2FA","sourceRelease":"119-100","text":"safety,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s2576b/3/B","parentIdentifier":"/us/usc/t19/s2576b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F3%2FB","sourceRelease":"119-100","text":"protection of human, animal, or plant life or health, the environment or consumers, including matters relating to quality and identifiability of goods or services, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t19/s2576b/3/C","parentIdentifier":"/us/usc/t19/s2576b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F3%2FC","sourceRelease":"119-100","text":"sustainable development,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Service","label":"4 Service","identifier":"/us/usc/t19/s2576b/4","parentIdentifier":"/us/usc/t19/s2576b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F4","sourceRelease":"119-100","text":"The term “service” means a land transportation service or a telecommunications service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Standard","label":"5 Standard","identifier":"/us/usc/t19/s2576b/5","parentIdentifier":"/us/usc/t19/s2576b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s2576b/5/A","parentIdentifier":"/us/usc/t19/s2576b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F5%2FA","sourceRelease":"119-100","text":"characteristics for a good or a service,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s2576b/5/B","parentIdentifier":"/us/usc/t19/s2576b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F5%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s2576b/5/B/i","parentIdentifier":"/us/usc/t19/s2576b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F5%2FB%2Fi","sourceRelease":"119-100","text":"processes or production methods relating to such good, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s2576b/5/B/ii","parentIdentifier":"/us/usc/t19/s2576b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F5%2FB%2Fii","sourceRelease":"119-100","text":"operating methods relating to such service, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t19/s2576b/5/C","parentIdentifier":"/us/usc/t19/s2576b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F5%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s2576b/5/C/i","parentIdentifier":"/us/usc/t19/s2576b/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F5%2FC%2Fi","sourceRelease":"119-100","text":"a good or its related process or production methods, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s2576b/5/C/ii","parentIdentifier":"/us/usc/t19/s2576b/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F5%2FC%2Fii","sourceRelease":"119-100","text":"a service or its related operating methods,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Standards-related measure","label":"6 Standards-related measure","identifier":"/us/usc/t19/s2576b/6","parentIdentifier":"/us/usc/t19/s2576b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F6","sourceRelease":"119-100","text":"The term “standards-related measure” means a standard, technical regulation, or conformity assessment procedure.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Technical regulation","label":"7 Technical regulation","identifier":"/us/usc/t19/s2576b/7","parentIdentifier":"/us/usc/t19/s2576b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s2576b/7/A","parentIdentifier":"/us/usc/t19/s2576b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F7%2FA","sourceRelease":"119-100","text":"characteristics or their related processes and production methods for a good,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s2576b/7/B","parentIdentifier":"/us/usc/t19/s2576b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F7%2FB","sourceRelease":"119-100","text":"characteristics for a service or its related operating methods, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t19/s2576b/7/C","parentIdentifier":"/us/usc/t19/s2576b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F7%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s2576b/7/C/i","parentIdentifier":"/us/usc/t19/s2576b/7/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F7%2FC%2Fi","sourceRelease":"119-100","text":"a good or its related process or production method, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s2576b/7/C/ii","parentIdentifier":"/us/usc/t19/s2576b/7/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F7%2FC%2Fii","sourceRelease":"119-100","text":"a service or its related operating method,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Telecommunications service","label":"8 Telecommunications service","identifier":"/us/usc/t19/s2576b/8","parentIdentifier":"/us/usc/t19/s2576b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576b%2F8","sourceRelease":"119-100","text":"The term “telecommunications service” means a service provided by means of the transmission and reception of signals by any electromagnetic means, but does not mean the cable, broadcast, or other electromagnetic distribution of radio or television programming to the public generally.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
