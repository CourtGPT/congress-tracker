{"type":"section","nativeType":"section","number":"5332","heading":"Functions of Council","label":"5332 Functions of Council","identifier":"/us/usc/t7/s5332","parentIdentifier":"/us/usc/t7/ch84/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5332","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s5332/1","parentIdentifier":"/us/usc/t7/s5332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5332%2F1","sourceRelease":"119-100","text":"provide scientific and technical advice on the development and implementation of all components of the coordinated program and the comprehensive plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s5332/2","parentIdentifier":"/us/usc/t7/s5332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5332%2F2","sourceRelease":"119-100","text":"evaluate the scientific and technical quality of the comprehensive plan and the effectiveness of the coordinated program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s5332/3","parentIdentifier":"/us/usc/t7/s5332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5332%2F3","sourceRelease":"119-100","text":"recommend to the Secretaries, on an annual basis, means of enhancing the comprehensive plan and the coordinated program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s5332/4","parentIdentifier":"/us/usc/t7/s5332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5332%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s5332/4/A","parentIdentifier":"/us/usc/t7/s5332/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5332%2F4%2FA","sourceRelease":"119-100","text":"shall contain the components specified in paragraphs (2) and (3); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s5332/4/B","parentIdentifier":"/us/usc/t7/s5332/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5332%2F4%2FB","sourceRelease":"119-100","text":"shall be included in full in the biennial reports of the Secretaries to the President for transmittal to Congress under .section 5312(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
