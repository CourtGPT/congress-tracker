{"type":"section","nativeType":"section","number":"7438","heading":"Environmental and climate justice block grants","label":"7438 Environmental and climate justice block grants","identifier":"/us/usc/t42/s7438","parentIdentifier":"/us/usc/t42/ch85/schI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Appropriation","label":"a Appropriation","identifier":"/us/usc/t42/s7438/a","parentIdentifier":"/us/usc/t42/s7438","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s7438/a/1","parentIdentifier":"/us/usc/t42/s7438/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fa%2F1","sourceRelease":"119-100","text":"$2,800,000,000 to remain available until , to award grants for the activities described in subsection (b); andSeptember 30, 2026","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s7438/a/2","parentIdentifier":"/us/usc/t42/s7438/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fa%2F2","sourceRelease":"119-100","text":"$200,000,000 to remain available until , to provide technical assistance to eligible entities related to grants awarded under this section.September 30, 2026","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Grants","label":"b Grants","identifier":"/us/usc/t42/s7438/b","parentIdentifier":"/us/usc/t42/s7438","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s7438/b/1","parentIdentifier":"/us/usc/t42/s7438/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb%2F1","sourceRelease":"119-100","text":"The Administrator shall use amounts made available under subsection (a)(1) to award grants for periods of up to 3 years to eligible entities to carry out activities described in paragraph (2) that benefit disadvantaged communities, as defined by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible activities","label":"2 Eligible activities","identifier":"/us/usc/t42/s7438/b/2","parentIdentifier":"/us/usc/t42/s7438/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7438/b/2/A","parentIdentifier":"/us/usc/t42/s7438/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb%2F2%2FA","sourceRelease":"119-100","text":"community-led air and other pollution monitoring, prevention, and remediation, and investments in low- and zero-emission and resilient technologies and related infrastructure and workforce development that help reduce greenhouse gas emissions and other air pollutants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7438/b/2/B","parentIdentifier":"/us/usc/t42/s7438/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb%2F2%2FB","sourceRelease":"119-100","text":"mitigating climate and health risks from urban heat islands, extreme heat, wood heater emissions, and wildfire events;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s7438/b/2/C","parentIdentifier":"/us/usc/t42/s7438/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb%2F2%2FC","sourceRelease":"119-100","text":"climate resiliency and adaptation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s7438/b/2/D","parentIdentifier":"/us/usc/t42/s7438/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb%2F2%2FD","sourceRelease":"119-100","text":"reducing indoor toxics and indoor air pollution; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s7438/b/2/E","parentIdentifier":"/us/usc/t42/s7438/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb%2F2%2FE","sourceRelease":"119-100","text":"facilitating engagement of disadvantaged communities in State and Federal advisory groups, workshops, rulemakings, and other public processes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Eligible entities","label":"3 Eligible entities","identifier":"/us/usc/t42/s7438/b/3","parentIdentifier":"/us/usc/t42/s7438/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7438/b/3/A","parentIdentifier":"/us/usc/t42/s7438/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s7438/b/3/A/i","parentIdentifier":"/us/usc/t42/s7438/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb%2F3%2FA%2Fi","sourceRelease":"119-100","text":"an Indian tribe, a local government, or an institution of higher education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s7438/b/3/A/ii","parentIdentifier":"/us/usc/t42/s7438/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb%2F3%2FA%2Fii","sourceRelease":"119-100","text":"a community-based nonprofit organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7438/b/3/B","parentIdentifier":"/us/usc/t42/s7438/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb%2F3%2FB","sourceRelease":"119-100","text":"a community-based nonprofit organization; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s7438/b/3/C","parentIdentifier":"/us/usc/t42/s7438/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fb%2F3%2FC","sourceRelease":"119-100","text":"a partnership of community-based nonprofit organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Administrative costs","label":"c Administrative costs","identifier":"/us/usc/t42/s7438/c","parentIdentifier":"/us/usc/t42/s7438","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fc","sourceRelease":"119-100","text":"The Administrator shall reserve 7 percent of the amounts made available under subsection (a) for administrative costs to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definition of greenhouse gas","label":"d Definition of greenhouse gas","identifier":"/us/usc/t42/s7438/d","parentIdentifier":"/us/usc/t42/s7438","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7438%2Fd","sourceRelease":"119-100","text":"In this section, the term “greenhouse gas” means the air pollutants carbon dioxide, hydrofluorocarbons, methane, nitrous oxide, perfluorocarbons, and sulfur hexafluoride.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
