{"type":"section","nativeType":"section","number":"7804","heading":"Actions by States","label":"7804 Actions by States","identifier":"/us/usc/t15/s7804","parentIdentifier":"/us/usc/t15/ch104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThis chapter, referred to in subsec. (c), was in the original “this title” and was translated as reading “this Act”, meaning , to reflect the probable intent of Congress, because does not contain titles.Pub. L. 108–304Pub. L. 108–304"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s7804/a","parentIdentifier":"/us/usc/t15/s7804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Civil actions","label":"1 Civil actions","identifier":"/us/usc/t15/s7804/a/1","parentIdentifier":"/us/usc/t15/s7804/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7804/a/1/A","parentIdentifier":"/us/usc/t15/s7804/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fa%2F1%2FA","sourceRelease":"119-100","text":"enjoin that practice;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7804/a/1/B","parentIdentifier":"/us/usc/t15/s7804/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fa%2F1%2FB","sourceRelease":"119-100","text":"enforce compliance with this chapter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s7804/a/1/C","parentIdentifier":"/us/usc/t15/s7804/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fa%2F1%2FC","sourceRelease":"119-100","text":"obtain damage, restitution, or other compensation on behalf of residents of the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Notice","label":"2 Notice","identifier":"/us/usc/t15/s7804/a/2","parentIdentifier":"/us/usc/t15/s7804/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s7804/a/2/A","parentIdentifier":"/us/usc/t15/s7804/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s7804/a/2/A/i","parentIdentifier":"/us/usc/t15/s7804/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"written notice of that action; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s7804/a/2/A/ii","parentIdentifier":"/us/usc/t15/s7804/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"a copy of the complaint for that action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exemption","label":"B Exemption","identifier":"/us/usc/t15/s7804/a/2/B","parentIdentifier":"/us/usc/t15/s7804/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fa%2F2%2FB","sourceRelease":"119-100","text":"Subparagraph (A) shall not apply with respect to the filing of an action by an attorney general of a State under this subsection, if the attorney general determines that it is not feasible to provide the notice described in that subparagraph before filing of the action. In such case, the attorney general of a State shall provide notice and a copy of the complaint to the Commission at the same time as the attorney general files the action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Intervention","label":"b Intervention","identifier":"/us/usc/t15/s7804/b","parentIdentifier":"/us/usc/t15/s7804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s7804/b/1","parentIdentifier":"/us/usc/t15/s7804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fb%2F1","sourceRelease":"119-100","text":"On receiving notice under subsection (a)(2), the Commission shall have the right to intervene in the action that is the subject of the notice.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Effect of intervention","label":"2 Effect of intervention","identifier":"/us/usc/t15/s7804/b/2","parentIdentifier":"/us/usc/t15/s7804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7804/b/2/A","parentIdentifier":"/us/usc/t15/s7804/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fb%2F2%2FA","sourceRelease":"119-100","text":"to be heard with respect to any matter that arises in that action; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7804/b/2/B","parentIdentifier":"/us/usc/t15/s7804/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fb%2F2%2FB","sourceRelease":"119-100","text":"to file a petition for appeal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Construction","label":"c Construction","identifier":"/us/usc/t15/s7804/c","parentIdentifier":"/us/usc/t15/s7804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7804/c/1","parentIdentifier":"/us/usc/t15/s7804/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fc%2F1","sourceRelease":"119-100","text":"conduct investigations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7804/c/2","parentIdentifier":"/us/usc/t15/s7804/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fc%2F2","sourceRelease":"119-100","text":"administer oaths or affirmations; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s7804/c/3","parentIdentifier":"/us/usc/t15/s7804/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fc%2F3","sourceRelease":"119-100","text":"compel the attendance of witnesses or the production of documentary and other evidence.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Actions by the Commission","label":"d Actions by the Commission","identifier":"/us/usc/t15/s7804/d","parentIdentifier":"/us/usc/t15/s7804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fd","sourceRelease":"119-100","text":"In any case in which an action is instituted by or on behalf of the Commission for a violation of , no State may, during the pendency of that action, institute an action under subsection (a) against any defendant named in the complaint in that action.section 7802 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Venue","label":"e Venue","identifier":"/us/usc/t15/s7804/e","parentIdentifier":"/us/usc/t15/s7804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Fe","sourceRelease":"119-100","text":"Any action brought under subsection (a) may be brought in the district court of the United States that meets applicable requirements relating to venue under .section 1391 of title 28","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Service of process","label":"f Service of process","identifier":"/us/usc/t15/s7804/f","parentIdentifier":"/us/usc/t15/s7804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7804/f/1","parentIdentifier":"/us/usc/t15/s7804/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Ff%2F1","sourceRelease":"119-100","text":"is an inhabitant; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7804/f/2","parentIdentifier":"/us/usc/t15/s7804/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7804%2Ff%2F2","sourceRelease":"119-100","text":"may be found.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
