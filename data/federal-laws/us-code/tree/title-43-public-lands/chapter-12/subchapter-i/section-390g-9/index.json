ifier":"/us/usc/t43/s390g–9/b/3/A","parentIdentifier":"/us/usc/t43/s390g–9/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fb%2F3%2FA","sourceRelease":"119-100","text":"is authorized to receive water under State law; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s390g–9/b/3/B","parentIdentifier":"/us/usc/t43/s390g–9/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fb%2F3%2FB","sourceRelease":"119-100","text":"shares an aquifer with land located in the service area of the Reclamation project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Net water storage benefit","label":"4 Net water storage benefit","identifier":"/us/usc/t43/s390g–9/b/4","parentIdentifier":"/us/usc/t43/s390g–9/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s390g–9/b/4/A","parentIdentifier":"/us/usc/t43/s390g–9/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fb%2F4%2FA","sourceRelease":"119-100","text":"stored in 1 or more aquifers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s390g–9/b/4/B","parentIdentifier":"/us/usc/t43/s390g–9/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fb%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"typ