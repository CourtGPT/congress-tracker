parentIdentifier":"/us/usc/t12/s4718/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fa%2F1%2FB","sourceRelease":"119-100","text":"$104,000,000 for fiscal year 1996;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s4718/a/1/C","parentIdentifier":"/us/usc/t12/s4718/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fa%2F1%2FC","sourceRelease":"119-100","text":"$107,000,000 for fiscal year 1997; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t12/s4718/a/1/D","parentIdentifier":"/us/usc/t12/s4718/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fa%2F1%2FD","sourceRelease":"119-100","text":"$111,000,000 for fiscal year 1998;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Administrative expenses","label":"2 Administrative expenses","identifier":"/us/usc/t12/s4718/a/2","parentIdentifier":"/us/usc/t12/s4718/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t12/s4718/a/2/A","parentIdentifier":"/us/usc/t12/s4718/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fa%2F2%2FA","sourceRelease":"119-100","text":"Of amounts authorized to be appropriated to the Fund pursuant to this section, not more than $5,550,000 may be used by the Fund in each fiscal year to pay the administrative costs and expenses of the Fund. Costs associated with the training program established under and the technical assistance program established under shall not be considered to be administrative expenses for purposes of this paragraph.section 4708 of this titlesection 4707 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Calculations","label":"B Calculations","identifier":"/us/usc/t12/s4718/a/2/B","parentIdentifier":"/us/usc/t12/s4718/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fa%2F2%2FB","sourceRelease":"119-100","text":"The amounts referred to in paragraphs (3) and (4) shall be calculated after subtracting the amount referred to in subparagraph (A) of this paragraph from the total amount appropriated to the Fund in accordance with paragraph (1) in any fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Capitalization assistance","label":"3 Capitalization assistance","identifier":"/us/usc/t12/s4718/a/3","parentIdentifier":"/us/usc/t12/s4718/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fa%2F3","sourceRelease":"119-100","text":"Not more than 5 percent of the amounts authorized to be appropriated under paragraph (1) may be used as provided in .section 4712 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Availability for fundingsection 4713 of this title","label":"4 Availability for fundingsection 4713 of this title","identifier":"/us/usc/t12/s4718/a/4","parentIdentifier":"/us/usc/t12/s4718/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fa%2F4","sourceRelease":"119-100","text":"33⅓ percent of the amounts appropriated to the Fund for any fiscal year pursuant to the authorization in paragraph (1) shall be available for use in carrying out .section 4713 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Support of community development financial institutions","label":"5 Support of community development financial institutions","identifier":"/us/usc/t12/s4718/a/5","parentIdentifier":"/us/usc/t12/s4718/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fa%2F5","sourceRelease":"119-100","text":"The Administrator shall allocate funds authorized under this section, to the maximum extent practicable, for the support of community development financial institutions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Community Development Credit Union Revolving Loan Fund","label":"b Community Development Credit Union Revolving Loan Fund","identifier":"/us/usc/t12/s4718/b","parentIdentifier":"/us/usc/t12/s4718","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4718/b/1","parentIdentifier":"/us/usc/t12/s4718/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fb%2F1","sourceRelease":"119-100","text":"$4,000,000 for fiscal year 1995;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4718/b/2","parentIdentifier":"/us/usc/t12/s4718/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fb%2F2","sourceRelease":"119-100","text":"$2,000,000 for fiscal year 1996;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t12/s4718/b/3","parentIdentifier":"/us/usc/t12/s4718/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fb%2F3","sourceRelease":"119-100","text":"$2,000,000 for fiscal year 1997; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t12/s4718/b/4","parentIdentifier":"/us/usc/t12/s4718/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fb%2F4","sourceRelease":"119-100","text":"$2,000,000 for fiscal year 1998.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Budgetary treatment","label":"c Budgetary treatment","identifier":"/us/usc/t12/s4718/c","parentIdentifier":"/us/usc/t12/s4718","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4718%2Fc","sourceRelease":"119-100","text":"Amounts authorized to be appropriated under this section shall be subject to discretionary spending caps, as provided in section 665 of title 2, and therefore shall reduce by an equal amount funds made available for other discretionary spending programs.1See References in Text note below.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
