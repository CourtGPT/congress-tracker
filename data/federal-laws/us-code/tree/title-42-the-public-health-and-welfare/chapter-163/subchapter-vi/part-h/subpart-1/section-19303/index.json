{"type":"section","nativeType":"section","number":"19303","heading":"Clean energy technology transfer coordination","label":"19303 Clean energy technology transfer coordination","identifier":"/us/usc/t42/s19303","parentIdentifier":"/us/usc/t42/ch163/schVI/ptH/spt1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19303","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s19303/a","parentIdentifier":"/us/usc/t42/s19303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19303%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19303/a/1","parentIdentifier":"/us/usc/t42/s19303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19303%2Fa%2F1","sourceRelease":"119-100","text":"facilitate the sharing of information on best practices for successful operation of clean energy technology transfer programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19303/a/2","parentIdentifier":"/us/usc/t42/s19303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19303%2Fa%2F2","sourceRelease":"119-100","text":"coordinate resources and improve cooperation among clean energy technology transfer programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19303/a/3","parentIdentifier":"/us/usc/t42/s19303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19303%2Fa%2F3","sourceRele