dments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s400/3/C","parentIdentifier":"/us/usc/t33/s400/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs400%2F3%2FC","sourceRelease":"119-100","text":"the funding available in that fiscal year for each continuing authority program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Congressional notification","label":"4 Congressional notification","identifier":"/us/usc/t33/s400/4","parentIdentifier":"/us/usc/t33/s400","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs400%2F4","sourceRelease":"119-100","text":"On publication in the Federal Register under paragraphs (2) and (3), the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a copy of all information published under those paragraphs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
