{"type":"section","nativeType":"section","number":"2332h","heading":"Radiological dispersal devices","label":"2332h Radiological dispersal devices","identifier":"/us/usc/t18/s2332h","parentIdentifier":"/us/usc/t18/ptI/ch113B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Unlawful Conduct.—","label":"a Unlawful Conduct.—","identifier":"/us/usc/t18/s2332h/a","parentIdentifier":"/us/usc/t18/s2332h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t18/s2332h/a/1","parentIdentifier":"/us/usc/t18/s2332h/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s2332h/a/1/A","parentIdentifier":"/us/usc/t18/s2332h/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fa%2F1%2FA","sourceRelease":"119-100","text":"any weapon that is designed or intended to release radiation or radioactivity at a level dangerous to human life; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s2332h/a/1/B","parentIdentifier":"/us/usc/t18/s2332h/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fa%2F1%2FB","sourceRelease":"119-100","text":"any device or other object that is capable of and designed or intended to endanger human life through the release of radiation or radioactivity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Exception","label":"2 .—Exception","identifier":"/us/usc/t18/s2332h/a/2","parentIdentifier":"/us/usc/t18/s2332h/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s2332h/a/2/A","parentIdentifier":"/us/usc/t18/s2332h/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fa%2F2%2FA","sourceRelease":"119-100","text":"conduct by or under the authority of the United States or any department or agency thereof; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s2332h/a/2/B","parentIdentifier":"/us/usc/t18/s2332h/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fa%2F2%2FB","sourceRelease":"119-100","text":"conduct pursuant to the terms of a contract with the United States or any department or agency thereof.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Jurisdiction","label":"b .—Jurisdiction","identifier":"/us/usc/t18/s2332h/b","parentIdentifier":"/us/usc/t18/s2332h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2332h/b/1","parentIdentifier":"/us/usc/t18/s2332h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fb%2F1","sourceRelease":"119-100","text":"the offense occurs in or affects interstate or foreign commerce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2332h/b/2","parentIdentifier":"/us/usc/t18/s2332h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fb%2F2","sourceRelease":"119-100","text":"the offense occurs outside of the United States and is committed by a national of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s2332h/b/3","parentIdentifier":"/us/usc/t18/s2332h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fb%2F3","sourceRelease":"119-100","text":"the offense is committed against a national of the United States while the national is outside the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t18/s2332h/b/4","parentIdentifier":"/us/usc/t18/s2332h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fb%2F4","sourceRelease":"119-100","text":"the offense is committed against any property that is owned, leased, or used by the United States or by any department or agency of the United States, whether the property is within or outside the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t18/s2332h/b/5","parentIdentifier":"/us/usc/t18/s2332h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fb%2F5","sourceRelease":"119-100","text":"an offender aids or abets any person over whom jurisdiction exists under this subsection in committing an offense under this section or conspires with any person over whom jurisdiction exists under this subsection to commit an offense under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Criminal Penalties.—","label":"c Criminal Penalties.—","identifier":"/us/usc/t18/s2332h/c","parentIdentifier":"/us/usc/t18/s2332h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t18/s2332h/c/1","parentIdentifier":"/us/usc/t18/s2332h/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fc%2F1","sourceRelease":"119-100","text":"Any person who violates, or attempts or conspires to violate, subsection (a) shall be fined not more than $2,000,000 and shall be sentenced to a term of imprisonment not less than 25 years or to imprisonment for life.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Other circumstances","label":"2 .—Other circumstances","identifier":"/us/usc/t18/s2332h/c/2","parentIdentifier":"/us/usc/t18/s2332h/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fc%2F2","sourceRelease":"119-100","text":"Any person who, in the course of a violation of subsection (a), uses, attempts or conspires to use, or possesses and threatens to use, any item or items described in subsection (a), shall be fined not more than $2,000,000 and imprisoned for not less than 30 years or imprisoned for life.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Special circumstances","label":"3 .—Special circumstances","identifier":"/us/usc/t18/s2332h/c/3","parentIdentifier":"/us/usc/t18/s2332h/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2332h%2Fc%2F3","sourceRelease":"119-100","text":"If the death of another results from a person’s violation of subsection (a), the person shall be fined not more than $2,000,000 and punished by imprisonment for life.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
