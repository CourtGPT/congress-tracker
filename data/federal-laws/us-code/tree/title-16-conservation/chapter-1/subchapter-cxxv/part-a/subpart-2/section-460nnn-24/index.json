{"type":"section","nativeType":"section","number":"460nnn–24","heading":"Land acquisition authority","label":"460nnn–24 Land acquisition authority","identifier":"/us/usc/t16/s460nnn–24","parentIdentifier":"/us/usc/t16/ch1/schCXXV/ptA/spt2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Acquisition","label":"a Acquisition","identifier":"/us/usc/t16/s460nnn–24/a","parentIdentifier":"/us/usc/t16/s460nnn–24","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Acquisition authorized","label":"1 Acquisition authorized","identifier":"/us/usc/t16/s460nnn–24/a/1","parentIdentifier":"/us/usc/t16/s460nnn–24/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fa%2F1","sourceRelease":"119-100","text":"In addition to the land acquisitions authorized by part F, the Secretary may acquire other non-Federal lands and interests in lands located within the boundaries of the Cooperative Management and Protection Area or the Wilderness Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Acquisition methods","label":"2 Acquisition methods","identifier":"/us/usc/t16/s460nnn–24/a/2","parentIdentifier":"/us/usc/t16/s460nnn–24/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fa%2F2","sourceRelease":"119-100","text":"Lands may be acquired under this subsection only by voluntary exchange, donation, or purchase from willing sellers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Treatment of acquired lands","label":"b Treatment of acquired lands","identifier":"/us/usc/t16/s460nnn–24/b","parentIdentifier":"/us/usc/t16/s460nnn–24","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s460nnn–24/b/1","parentIdentifier":"/us/usc/t16/s460nnn–24/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460nnn–24/b/1/A","parentIdentifier":"/us/usc/t16/s460nnn–24/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fb%2F1%2FA","sourceRelease":"119-100","text":"become part of the Cooperative Management and Protection Area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460nnn–24/b/1/B","parentIdentifier":"/us/usc/t16/s460nnn–24/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fb%2F1%2FB","sourceRelease":"119-100","text":"be managed pursuant to the laws applicable to the Cooperative Management and Protection Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Lands within Wilderness Area","label":"2 Lands within Wilderness Area","identifier":"/us/usc/t16/s460nnn–24/b/2","parentIdentifier":"/us/usc/t16/s460nnn–24/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460nnn–24/b/2/A","parentIdentifier":"/us/usc/t16/s460nnn–24/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fb%2F2%2FA","sourceRelease":"119-100","text":"become part of the Wilderness Area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460nnn–24/b/2/B","parentIdentifier":"/us/usc/t16/s460nnn–24/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fb%2F2%2FB","sourceRelease":"119-100","text":"be managed pursuant to part B and the other laws applicable to the Wilderness Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Lands within wilderness study area","label":"3 Lands within wilderness study area","identifier":"/us/usc/t16/s460nnn–24/b/3","parentIdentifier":"/us/usc/t16/s460nnn–24/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460nnn–24/b/3/A","parentIdentifier":"/us/usc/t16/s460nnn–24/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fb%2F3%2FA","sourceRelease":"119-100","text":"become part of that wilderness study area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460nnn–24/b/3/B","parentIdentifier":"/us/usc/t16/s460nnn–24/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fb%2F3%2FB","sourceRelease":"119-100","text":"be managed pursuant to the laws applicable to that wilderness study area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Appraisal","label":"c Appraisal","identifier":"/us/usc/t16/s460nnn–24/c","parentIdentifier":"/us/usc/t16/s460nnn–24","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9324%2Fc","sourceRelease":"119-100","text":"In appraising non-Federal land, development rights, or conservation easements for possible acquisition under this section or , the Secretary shall disregard any adverse impacts on values resulting from the designation of the Cooperative Management and Protection Area or the Wilderness Area.section 460nnn–42 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
