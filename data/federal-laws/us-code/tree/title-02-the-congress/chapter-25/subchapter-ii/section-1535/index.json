{"type":"section","nativeType":"section","number":"1535","heading":"Least burdensome option or explanation required","label":"1535 Least burdensome option or explanation required","identifier":"/us/usc/t2/s1535","parentIdentifier":"/us/usc/t2/ch25/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1535","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t2/s1535/a","parentIdentifier":"/us/usc/t2/s1535","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1535%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s1535/a/1","parentIdentifier":"/us/usc/t2/s1535/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1535%2Fa%2F1","sourceRelease":"119-100","text":"State, local, and tribal governments, in the case of a rule containing a Federal intergovernmental mandate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s1535/a/2","parentIdentifier":"/us/usc/t2/s1535/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1535%2Fa%2F2","sourceRelease":"119-100","text":"the private sector, in the case of a rule containing a Federal private sector mandate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Exception","label":"b Exception","identifier":"/us/usc/t2/s1535/b","parentIdentifier":"/us/usc/t2/s1535","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1535%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s1535/b/1","parentIdentifier":"/us/usc/t2/s1535/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1535%2Fb%2F1","sourceRelease":"119-100","text":"the head of the affected agency publishes with the final rule an explanation of why the least costly, most cost-effective or least burdensome method of achieving the objectives of the rule was not adopted; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s1535/b/2","parentIdentifier":"/us/usc/t2/s1535/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1535%2Fb%2F2","sourceRelease":"119-100","text":"the provisions are inconsistent with law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"OMB certification","label":"c OMB certification","identifier":"/us/usc/t2/s1535/c","parentIdentifier":"/us/usc/t2/s1535","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1535%2Fc","sourceRelease":"119-100","text":"No later than 1 year after , the Director of the Office of Management and Budget shall certify to Congress, with a written explanation, agency compliance with this section and include in that certification agencies and rulemakings that fail to adequately comply with this section.March 22, 1995","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
