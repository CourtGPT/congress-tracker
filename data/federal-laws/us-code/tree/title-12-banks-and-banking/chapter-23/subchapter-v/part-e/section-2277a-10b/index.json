{"type":"section","nativeType":"section","number":"2277a–10b","heading":"Authority to regulate golden parachute and indemnification payments","label":"2277a–10b Authority to regulate golden parachute and indemnification payments","identifier":"/us/usc/t12/s2277a–10b","parentIdentifier":"/us/usc/t12/ch23/schV/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t12/s2277a–10b/a","parentIdentifier":"/us/usc/t12/s2277a–10b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Golden parachute payment","label":"1 Golden parachute payment","identifier":"/us/usc/t12/s2277a–10b/a/1","parentIdentifier":"/us/usc/t12/s2277a–10b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s2277a–10b/a/1/A","parentIdentifier":"/us/usc/t12/s2277a–10b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t12/s2277a–10b/a/1/A/i","parentIdentifier":"/us/usc/t12/s2277a–10b/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"is contingent on the termination of the party’s relationship with the institution; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t12/s2277a–10b/a/1/A/ii","parentIdentifier":"/us/usc/t12/s2277a–10b/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t12/s2277a–10b/a/1/A/ii/I","parentIdentifier":"/us/usc/t12/s2277a–10b/a/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F1%2FA%2Fii%2FI","sourceRelease":"119-100","text":"the institution is insolvent;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t12/s2277a–10b/a/1/A/ii/II","parentIdentifier":"/us/usc/t12/s2277a–10b/a/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F1%2FA%2Fii%2FII","sourceRelease":"119-100","text":"a conservator or receiver is appointed for the institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t12/s2277a–10b/a/1/A/ii/III","parentIdentifier":"/us/usc/t12/s2277a–10b/a/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F1%2FA%2Fii%2FIII","sourceRelease":"119-100","text":"the institution has been assigned by the Farm Credit Administration a composite CAMEL rating of 4 or 5 under the Farm Credit Administration Rating System, or an equivalent rating; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t12/s2277a–10b/a/1/A/ii/IV","parentIdentifier":"/us/usc/t12/s2277a–10b/a/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F1%2FA%2Fii%2FIV","sourceRelease":"119-100","text":"the Corporation otherwise determines that the institution is in a troubled condition (as defined in regulations issued by the Corporation); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s2277a–10b/a/1/B","parentIdentifier":"/us/usc/t12/s2277a–10b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F1%2FB","sourceRelease":"119-100","text":"includes a payment that would be a golden parachute payment but for the fact that the payment was made before the date referred to in subparagraph (A)(ii) if the payment was made in contemplation of the occurrence of an event described in any subclause of subparagraph (A); but","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s2277a–10b/a/1/C","parentIdentifier":"/us/usc/t12/s2277a–10b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t12/s2277a–10b/a/1/C/i","parentIdentifier":"/us/usc/t12/s2277a–10b/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F1%2FC%2Fi","sourceRelease":"119-100","text":"a payment made under a retirement plan that is qualified (or is intended to be qualified) under or other nondiscriminatory benefit plan;section 401 of title 26","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t12/s2277a–10b/a/1/C/ii","parentIdentifier":"/us/usc/t12/s2277a–10b/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F1%2FC%2Fii","sourceRelease":"119-100","text":"a payment made under a bona fide supplemental executive retirement plan, deferred compensation plan, or other arrangement that the Corporation determines, by regulation or order, to be permissible; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t12/s2277a–10b/a/1/C/iii","parentIdentifier":"/us/usc/t12/s2277a–10b/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"a payment made by reason of the death or disability of an institution-related party.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Indemnification payment","label":"2 Indemnification payment","identifier":"/us/usc/t12/s2277a–10b/a/2","parentIdentifier":"/us/usc/t12/s2277a–10b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s2277a–10b/a/2/A","parentIdentifier":"/us/usc/t12/s2277a–10b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F2%2FA","sourceRelease":"119-100","text":"is assessed a civil money penalty; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s2277a–10b/a/2/B","parentIdentifier":"/us/usc/t12/s2277a–10b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F2%2FB","sourceRelease":"119-100","text":"is removed or prohibited from participating in the conduct of the affairs of the institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Institution-related party","label":"3 Institution-related party","identifier":"/us/usc/t12/s2277a–10b/a/3","parentIdentifier":"/us/usc/t12/s2277a–10b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s2277a–10b/a/3/A","parentIdentifier":"/us/usc/t12/s2277a–10b/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F3%2FA","sourceRelease":"119-100","text":"a director, officer, employee, or agent for a Farm Credit System institution or any conservator or receiver of such an institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s2277a–10b/a/3/B","parentIdentifier":"/us/usc/t12/s2277a–10b/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F3%2FB","sourceRelease":"119-100","text":"a stockholder (other than another Farm Credit System institution), consultant, joint venture partner, or any other person determined by the Farm Credit Administration to be a participant in the conduct of the affairs of a Farm Credit System institution; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s2277a–10b/a/3/C","parentIdentifier":"/us/usc/t12/s2277a–10b/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F3%2FC","sourceRelease":"119-100","text":"an independent contractor (including any attorney, appraiser, or accountant) that knowingly or recklessly participates in any violation of any law or regulation, any breach of fiduciary duty, or any unsafe or unsound practice that caused or is likely to cause more than a minimal financial loss to, or a significant adverse effect on, the Farm Credit System institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Liability or legal expense","label":"4 Liability or legal expense","identifier":"/us/usc/t12/s2277a–10b/a/4","parentIdentifier":"/us/usc/t12/s2277a–10b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s2277a–10b/a/4/A","parentIdentifier":"/us/usc/t12/s2277a–10b/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F4%2FA","sourceRelease":"119-100","text":"a legal or other professional expense incurred in connection with any claim, proceeding, or action;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s2277a–10b/a/4/B","parentIdentifier":"/us/usc/t12/s2277a–10b/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F4%2FB","sourceRelease":"119-100","text":"the amount of, and any cost incurred in connection with, any settlement of any claim, proceeding, or action; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s2277a–10b/a/4/C","parentIdentifier":"/us/usc/t12/s2277a–10b/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F4%2FC","sourceRelease":"119-100","text":"the amount of, and any cost incurred in connection with, any judgment or penalty imposed with respect to any claim, proceeding, or action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Payment","label":"5 Payment","identifier":"/us/usc/t12/s2277a–10b/a/5","parentIdentifier":"/us/usc/t12/s2277a–10b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s2277a–10b/a/5/A","parentIdentifier":"/us/usc/t12/s2277a–10b/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F5%2FA","sourceRelease":"119-100","text":"a direct or indirect transfer of any funds or any asset; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s2277a–10b/a/5/B","parentIdentifier":"/us/usc/t12/s2277a–10b/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F5%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t12/s2277a–10b/a/5/B/i","parentIdentifier":"/us/usc/t12/s2277a–10b/a/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F5%2FB%2Fi","sourceRelease":"119-100","text":"the determination, after that date, of the liability for the payment of the amount; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t12/s2277a–10b/a/5/B/ii","parentIdentifier":"/us/usc/t12/s2277a–10b/a/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fa%2F5%2FB%2Fii","sourceRelease":"119-100","text":"the liquidation, after that date, of the amount of the payment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Prohibition","label":"b Prohibition","identifier":"/us/usc/t12/s2277a–10b/b","parentIdentifier":"/us/usc/t12/s2277a–10b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fb","sourceRelease":"119-100","text":"The Corporation may prohibit or limit, by regulation or order, any golden parachute payment or indemnification payment by a Farm Credit System institution (including any conservator or receiver of the Federal Agricultural Mortgage Corporation) in troubled condition (as defined in regulations issued by the Corporation).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Factors to be taken into account","label":"c Factors to be taken into account","identifier":"/us/usc/t12/s2277a–10b/c","parentIdentifier":"/us/usc/t12/s2277a–10b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s2277a–10b/c/1","parentIdentifier":"/us/usc/t12/s2277a–10b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fc%2F1","sourceRelease":"119-100","text":"whether there is a reasonable basis to believe that an institution-related party has committed any fraudulent act or omission, breach of trust or fiduciary duty, or insider abuse with regard to the Farm Credit System institution involved that has had a material effect on the financial condition of the institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s2277a–10b/c/2","parentIdentifier":"/us/usc/t12/s2277a–10b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fc%2F2","sourceRelease":"119-100","text":"whether there is a reasonable basis to believe that the institution-related party is substantially responsible for the insolvency of the Farm Credit System institution, the appointment of a conservator or receiver for the institution, or the institution’s troubled condition (as defined in regulations prescribed by the Corporation);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t12/s2277a–10b/c/3","parentIdentifier":"/us/usc/t12/s2277a–10b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fc%2F3","sourceRelease":"119-100","text":"whether there is a reasonable basis to believe that the institution-related party has materially violated any applicable law or regulation that has had a material effect on the financial condition of the institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t12/s2277a–10b/c/4","parentIdentifier":"/us/usc/t12/s2277a–10b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s2277a–10b/c/4/A","parentIdentifier":"/us/usc/t12/s2277a–10b/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fc%2F4%2FA","sourceRelease":"119-100","text":"section 215, 657, 1006, 1014, or 1344 of title 18; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s2277a–10b/c/4/B","parentIdentifier":"/us/usc/t12/s2277a–10b/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fc%2F4%2FB","sourceRelease":"119-100","text":"section 1341 or 1343 of title 18, affecting a Farm Credit System institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t12/s2277a–10b/c/5","parentIdentifier":"/us/usc/t12/s2277a–10b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fc%2F5","sourceRelease":"119-100","text":"whether the institution-related party was in a position of managerial or fiduciary responsibility; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t12/s2277a–10b/c/6","parentIdentifier":"/us/usc/t12/s2277a–10b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fc%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s2277a–10b/c/6/A","parentIdentifier":"/us/usc/t12/s2277a–10b/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fc%2F6%2FA","sourceRelease":"119-100","text":"the payment reasonably reflects compensation earned over the period of employment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s2277a–10b/c/6/B","parentIdentifier":"/us/usc/t12/s2277a–10b/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fc%2F6%2FB","sourceRelease":"119-100","text":"the compensation represents a reasonable payment for services rendered.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Certain payments prohibited","label":"d Certain payments prohibited","identifier":"/us/usc/t12/s2277a–10b/d","parentIdentifier":"/us/usc/t12/s2277a–10b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s2277a–10b/d/1","parentIdentifier":"/us/usc/t12/s2277a–10b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fd%2F1","sourceRelease":"119-100","text":"in contemplation of the insolvency of the institution or after the commission of an act of insolvency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s2277a–10b/d/2","parentIdentifier":"/us/usc/t12/s2277a–10b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s2277a–10b/d/2/A","parentIdentifier":"/us/usc/t12/s2277a–10b/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fd%2F2%2FA","sourceRelease":"119-100","text":"preventing the proper application of the assets of the institution to creditors; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s2277a–10b/d/2/B","parentIdentifier":"/us/usc/t12/s2277a–10b/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fd%2F2%2FB","sourceRelease":"119-100","text":"preferring 1 creditor over another creditor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Rule of construction","label":"e Rule of construction","identifier":"/us/usc/t12/s2277a–10b/e","parentIdentifier":"/us/usc/t12/s2277a–10b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s2277a–10b/e/1","parentIdentifier":"/us/usc/t12/s2277a–10b/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fe%2F1","sourceRelease":"119-100","text":"prohibits any Farm Credit System institution from purchasing any commercial insurance policy or fidelity bond, so long as the insurance policy or bond does not cover any legal or liability expense of an institution described in subsection (a)(2); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s2277a–10b/e/2","parentIdentifier":"/us/usc/t12/s2277a–10b/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2277a%E2%80%9310b%2Fe%2F2","sourceRelease":"119-100","text":"limits the powers, functions, or responsibilities of the Farm Credit Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
