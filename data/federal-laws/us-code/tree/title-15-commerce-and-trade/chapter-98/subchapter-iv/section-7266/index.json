{"type":"section","nativeType":"section","number":"7266","heading":"Enhanced review of periodic disclosures by issuers","label":"7266 Enhanced review of periodic disclosures by issuers","identifier":"/us/usc/t15/s7266","parentIdentifier":"/us/usc/t15/ch98/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7266","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Regular and systematic review","label":"a Regular and systematic review","identifier":"/us/usc/t15/s7266/a","parentIdentifier":"/us/usc/t15/s7266","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7266%2Fa","sourceRelease":"119-100","text":"The Commission shall review disclosures made by issuers reporting under (including reports filed on Form 10–K), and which have a class of securities listed on a national securities exchange or traded on an automated quotation facility of a national securities association, on a regular and systematic basis for the protection of investors. Such review shall include a review of an issuer’s financial statement.section 78m(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Review criteria","label":"b Review criteria","identifier":"/us/usc/t15/s7266/b","parentIdentifier":"/us/usc/t15/s7266","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7266%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7266/b/1","parentIdentifier":"/us/usc/t15/s7266/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7266%2Fb%2F1","sourceRelease":"119-100","text":"issuers that have issued material restatements of financial results;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7266/b/2","parentIdentifier":"/us/usc/t15/s7266/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7266%2Fb%2F2","sourceRelease":"119-100","text":"issuers that experience significant volatility in their stock price as compared to other issuers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s7266/b/3","parentIdentifier":"/us/usc/t15/s7266/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7266%2Fb%2F3","sourceRelease":"119-100","text":"issuers with the largest market capitalization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s7266/b/4","parentIdentifier":"/us/usc/t15/s7266/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7266%2Fb%2F4","sourceRelease":"119-100","text":"emerging companies with disparities in price to earning ratios;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s7266/b/5","parentIdentifier":"/us/usc/t15/s7266/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7266%2Fb%2F5","sourceRelease":"119-100","text":"issuers whose operations significantly affect any material sector of the economy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s7266/b/6","parentIdentifier":"/us/usc/t15/s7266/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7266%2Fb%2F6","sourceRelease":"119-100","text":"any other factors that the Commission may consider relevant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Minimum review period","label":"c Minimum review period","identifier":"/us/usc/t15/s7266/c","parentIdentifier":"/us/usc/t15/s7266","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7266%2Fc","sourceRelease":"119-100","text":"In no event shall an issuer required to file reports under section 78m(a) or 78(d) of this title be reviewed under this section less frequently than once every 3 years.o","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
