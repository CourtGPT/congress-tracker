{"type":"section","nativeType":"section","number":"3372","heading":"Monitoring mineral investments under Belt and Road Initiative of People’s Republic of China","label":"3372 Monitoring mineral investments under Belt and Road Initiative of People’s Republic of China","identifier":"/us/usc/t50/s3372","parentIdentifier":"/us/usc/t50/ch45/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Report required","label":"a Report required","identifier":"/us/usc/t50/s3372/a","parentIdentifier":"/us/usc/t50/s3372","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3372/a/1","parentIdentifier":"/us/usc/t50/s3372/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fa%2F1","sourceRelease":"119-100","text":"notable past mineral investments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3372/a/2","parentIdentifier":"/us/usc/t50/s3372/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fa%2F2","sourceRelease":"119-100","text":"whether and how such investments have increased the extent of control of minerals by the People’s Republic of China;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s3372/a/3","parentIdentifier":"/us/usc/t50/s3372/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fa%2F3","sourceRelease":"119-100","text":"any efforts by the People’s Republic of China to counter or interfere with the goals of the Energy Resource Governance Initiative of the Department of State; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t50/s3372/a/4","parentIdentifier":"/us/usc/t50/s3372/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fa%2F4","sourceRelease":"119-100","text":"the strategy of the People’s Republic of China with respect to mineral investments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Monitoring mechanism","label":"b Monitoring mechanism","identifier":"/us/usc/t50/s3372/b","parentIdentifier":"/us/usc/t50/s3372","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3372/b/1","parentIdentifier":"/us/usc/t50/s3372/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3372/b/1/A","parentIdentifier":"/us/usc/t50/s3372/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fb%2F1%2FA","sourceRelease":"119-100","text":"is increasing its concentration of extraction and processing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3372/b/1/B","parentIdentifier":"/us/usc/t50/s3372/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fb%2F1%2FB","sourceRelease":"119-100","text":"is acquiring significant mining and processing facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t50/s3372/b/1/C","parentIdentifier":"/us/usc/t50/s3372/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fb%2F1%2FC","sourceRelease":"119-100","text":"is maintaining or increasing export restrictions; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t50/s3372/b/1/D","parentIdentifier":"/us/usc/t50/s3372/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fb%2F1%2FD","sourceRelease":"119-100","text":"has achieved substantial control of the supply of minerals used within an industry or related minerals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3372/b/2","parentIdentifier":"/us/usc/t50/s3372/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fb%2F2","sourceRelease":"119-100","text":"there is a significant difference between domestic prices in the People’s Republic of China as compared to prices on international markets; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s3372/b/3","parentIdentifier":"/us/usc/t50/s3372/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fb%2F3","sourceRelease":"119-100","text":"there is a significant increase or volatility in price as a result of the Belt and Road Initiative of the People’s Republic of China.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Critical mineral evaluation","label":"c Critical mineral evaluation","identifier":"/us/usc/t50/s3372/c","parentIdentifier":"/us/usc/t50/s3372","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3372/c/1","parentIdentifier":"/us/usc/t50/s3372/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fc%2F1","sourceRelease":"119-100","text":"determine, in consultation with the Secretary of the Interior, the Secretary of Energy, the Secretary of Commerce, the Secretary of State, the Secretary of Defense, and the United States Trade Representative, whether the mineral is strategic and critical to the defense or national security of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3372/c/2","parentIdentifier":"/us/usc/t50/s3372/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fc%2F2","sourceRelease":"119-100","text":"make a recommendation to the Secretary of the Interior regarding the designation of the mineral under .section 1606(c) of title 30","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Annual updates","label":"d Annual updates","identifier":"/us/usc/t50/s3372/d","parentIdentifier":"/us/usc/t50/s3372","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fd","sourceRelease":"119-100","text":"The Director shall update the report required by subsection (a) and list required by subsection (b) not less frequently than annually.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Form","label":"e Form","identifier":"/us/usc/t50/s3372/e","parentIdentifier":"/us/usc/t50/s3372","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Fe","sourceRelease":"119-100","text":"Each report or list required by this section shall be submitted in unclassified form but may include a classified annex.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Appropriate congressional committees defined","label":"f Appropriate congressional committees defined","identifier":"/us/usc/t50/s3372/f","parentIdentifier":"/us/usc/t50/s3372","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3372/f/1","parentIdentifier":"/us/usc/t50/s3372/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Ff%2F1","sourceRelease":"119-100","text":"the Committee on Energy and Natural Resources, the Committee on Foreign Relations, the Committee on Armed Services, the Committee on Finance, the Committee on Homeland Security and Governmental Affairs, the Committee on Commerce, Science, and Transportation, and the Committee on Appropriations of the Senate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3372/f/2","parentIdentifier":"/us/usc/t50/s3372/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3372%2Ff%2F2","sourceRelease":"119-100","text":"the Committee on Energy and Commerce, the Committee on Foreign Affairs, the Committee on Armed Services, the Committee on Ways and Means, the Committee on Homeland Security, and the Committee on Appropriations of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
