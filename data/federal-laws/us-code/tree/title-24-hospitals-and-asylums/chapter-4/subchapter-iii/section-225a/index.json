{"type":"section","nativeType":"section","number":"225a","heading":"Definitions","label":"225a Definitions","identifier":"/us/usc/t24/s225a","parentIdentifier":"/us/usc/t24/ch4/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs225a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t24/s225a/1","parentIdentifier":"/us/usc/t24/s225a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs225a%2F1","sourceRelease":"119-100","text":"The term “Hospital” means the institution in the District of Columbia known as Saint Elizabeths Hospital operated on , by the Secretary of Health and Human Services.November 8, 1984","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t24/s225a/2","parentIdentifier":"/us/usc/t24/s225a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs225a%2F2","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Health and Human Services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t24/s225a/3","parentIdentifier":"/us/usc/t24/s225a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs225a%2F3","sourceRelease":"119-100","text":"The term “Mayor” means the Mayor of the District of Columbia.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t24/s225a/4","parentIdentifier":"/us/usc/t24/s225a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs225a%2F4","sourceRelease":"119-100","text":"The term “District” means the District of Columbia.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t24/s225a/5","parentIdentifier":"/us/usc/t24/s225a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs225a%2F5","sourceRelease":"119-100","text":"The term “Federal court consent decree” means the consent decree in Dixon v. Heckler, Civil Action No. 74–285.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t24/s225a/6","parentIdentifier":"/us/usc/t24/s225a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs225a%2F6","sourceRelease":"119-100","text":"The term “service coordination period” means a period beginning on , and terminating on .October 1, 1985October 1, 1987","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t24/s225a/7","parentIdentifier":"/us/usc/t24/s225a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs225a%2F7","sourceRelease":"119-100","text":"The term “financial transition period” means a period beginning on , and terminating on .October 1, 1985October 1, 1991","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t24/s225a/8","parentIdentifier":"/us/usc/t24/s225a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs225a%2F8","sourceRelease":"119-100","text":"The term “system implementation plan” means the plan for a comprehensive mental health system for the District of Columbia to be developed pursuant to this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t24/s225a/9","parentIdentifier":"/us/usc/t24/s225a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs225a%2F9","sourceRelease":"119-100","text":"The term “Council” means the Council of the District of Columbia.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
