{"type":"section","nativeType":"section","number":"10003","heading":"Definitions","label":"10003 Definitions","identifier":"/us/usc/t42/s10003","parentIdentifier":"/us/usc/t42/ch107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10003","sourceRelease":"119-100","text":null,"notes":["Executive Documents","Termination of Trust Territory of the Pacific IslandsFor termination of Trust Territory of the Pacific Islands, see note set out preceding , Territories and Insular Possessions.section 1681 of Title 48"],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s10003/1","parentIdentifier":"/us/usc/t42/s10003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10003%2F1","sourceRelease":"119-100","text":"“radiation” means ionizing and nonionizing radiation in amounts beyond normal background levels from sources such as medical and dental radiologic procedures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s10003/2","parentIdentifier":"/us/usc/t42/s10003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10003%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s10003/2/A","parentIdentifier":"/us/usc/t42/s10003/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10003%2F2%2FA","sourceRelease":"119-100","text":"the diagnosis of disease or other medical or dental conditions in humans (including diagnostic X-rays or nuclear medicine procedures); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s10003/2/B","parentIdentifier":"/us/usc/t42/s10003/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10003%2F2%2FB","sourceRelease":"119-100","text":"the cure, mitigation, treatment, or prevention of disease in humans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s10003/3","parentIdentifier":"/us/usc/t42/s10003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10003%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s10003/3/A","parentIdentifier":"/us/usc/t42/s10003/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10003%2F3%2FA","sourceRelease":"119-100","text":"diagnose disease or other medical or dental conditions (including diagnostic X-ray equipment); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s10003/3/B","parentIdentifier":"/us/usc/t42/s10003/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10003%2F3%2FB","sourceRelease":"119-100","text":"cure, mitigate, treat, or prevent disease in humans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s10003/4","parentIdentifier":"/us/usc/t42/s10003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10003%2F4","sourceRelease":"119-100","text":"“practitioner” means any licensed doctor of medicine, osteopathy, dentistry, podiatry, or chiropractic, who prescribes radiologic procedures for other persons;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s10003/5","parentIdentifier":"/us/usc/t42/s10003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10003%2F5","sourceRelease":"119-100","text":"“persons who administer radiologic procedures” means any person, other than a practitioner, who intentionally administers radiation to other persons for medical purposes, and includes medical radiologic technologists (including dental hygienists and assistants), radiation therapy technologists, and nuclear medicine technologists;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s10003/6","parentIdentifier":"/us/usc/t42/s10003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10003%2F6","sourceRelease":"119-100","text":"“Secretary” means the Secretary of Health and Human Services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s10003/7","parentIdentifier":"/us/usc/t42/s10003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10003%2F7","sourceRelease":"119-100","text":"“State” means the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, the Virgin Islands, Guam, American Samoa, and the Trust Territory of the Pacific Islands.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
