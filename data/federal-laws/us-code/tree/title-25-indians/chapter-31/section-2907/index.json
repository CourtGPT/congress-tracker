{"type":"section","nativeType":"section","number":"2907","heading":"Survey on Native American languages","label":"2907 Survey on Native American languages","identifier":"/us/usc/t25/s2907","parentIdentifier":"/us/usc/t25/ch31","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Change of NameCommittee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, .Jan. 9, 2023"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t25/s2907/a","parentIdentifier":"/us/usc/t25/s2907","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fa","sourceRelease":"119-100","text":"Not later than 18 months after , and every 5 years thereafter, the Secretary of Health and Human Services, acting through the Commissioner of the Administration for Native Americans (referred to in this section as the “Secretary”), shall undertake a survey of the use of all Native American languages in the United States.January 5, 2023","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Updates","label":"b Updates","identifier":"/us/usc/t25/s2907/b","parentIdentifier":"/us/usc/t25/s2907","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fb","sourceRelease":"119-100","text":"Prior to conducting each subsequent survey after the initial survey under subsection (a), the Secretary shall update the survey in accordance with this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Consultation required","label":"c Consultation required","identifier":"/us/usc/t25/s2907/c","parentIdentifier":"/us/usc/t25/s2907","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s2907/c/1","parentIdentifier":"/us/usc/t25/s2907/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fc%2F1","sourceRelease":"119-100","text":"in consultation with Indian tribes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s2907/c/2","parentIdentifier":"/us/usc/t25/s2907/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fc%2F2","sourceRelease":"119-100","text":"after considering feedback received from Native American language speakers and experts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Contents","label":"d Contents","identifier":"/us/usc/t25/s2907/d","parentIdentifier":"/us/usc/t25/s2907","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s2907/d/1","parentIdentifier":"/us/usc/t25/s2907/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fd%2F1","sourceRelease":"119-100","text":"information on which Native American languages are currently spoken;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s2907/d/2","parentIdentifier":"/us/usc/t25/s2907/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fd%2F2","sourceRelease":"119-100","text":"estimates of the number of speakers of each Native American language;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s2907/d/3","parentIdentifier":"/us/usc/t25/s2907/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fd%2F3","sourceRelease":"119-100","text":"any language usage statistics or information that the Secretary, in consultation with Indian tribes and Native American language speakers and experts, determines to be relevant and appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s2907/d/4","parentIdentifier":"/us/usc/t25/s2907/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fd%2F4","sourceRelease":"119-100","text":"information on the types of Native American language maintenance and revitalization projects and practices that are currently being carried out;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s2907/d/5","parentIdentifier":"/us/usc/t25/s2907/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fd%2F5","sourceRelease":"119-100","text":"information on any unmet Native American language resource needs of Indian tribes and Native American language communities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t25/s2907/d/6","parentIdentifier":"/us/usc/t25/s2907/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fd%2F6","sourceRelease":"119-100","text":"any other information that the Secretary, in consultation with Indian tribes and Native American language speakers and experts, determines to be necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Coordination","label":"e Coordination","identifier":"/us/usc/t25/s2907/e","parentIdentifier":"/us/usc/t25/s2907","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fe","sourceRelease":"119-100","text":"The Secretary may coordinate, and enter into cooperative agreements with, the Director of the Bureau of the Census for the purposes of carrying out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Outreach and engagement","label":"f Outreach and engagement","identifier":"/us/usc/t25/s2907/f","parentIdentifier":"/us/usc/t25/s2907","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s2907/f/1","parentIdentifier":"/us/usc/t25/s2907/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s2907/f/1/A","parentIdentifier":"/us/usc/t25/s2907/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Ff%2F1%2FA","sourceRelease":"119-100","text":"opportunities to provide input on the development and design of each survey under subsection (a), including information on the consultations required under subsection (c);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s2907/f/1/B","parentIdentifier":"/us/usc/t25/s2907/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Ff%2F1%2FB","sourceRelease":"119-100","text":"the goals and purpose of the surveys conducted under subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s2907/f/1/C","parentIdentifier":"/us/usc/t25/s2907/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Ff%2F1%2FC","sourceRelease":"119-100","text":"the benefits and importance of participation in surveys under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Grants, contracts, and cooperative agreements authorized","label":"2 Grants, contracts, and cooperative agreements authorized","identifier":"/us/usc/t25/s2907/f/2","parentIdentifier":"/us/usc/t25/s2907/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s2907/f/2/A","parentIdentifier":"/us/usc/t25/s2907/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Ff%2F2%2FA","sourceRelease":"119-100","text":"directly;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s2907/f/2/B","parentIdentifier":"/us/usc/t25/s2907/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Ff%2F2%2FB","sourceRelease":"119-100","text":"in partnership with the Bureau of the Census; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s2907/f/2/C","parentIdentifier":"/us/usc/t25/s2907/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Ff%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s2907/f/2/C/i","parentIdentifier":"/us/usc/t25/s2907/f/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Ff%2F2%2FC%2Fi","sourceRelease":"119-100","text":"Indian tribes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s2907/f/2/C/ii","parentIdentifier":"/us/usc/t25/s2907/f/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Ff%2F2%2FC%2Fii","sourceRelease":"119-100","text":"tribal organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t25/s2907/f/2/C/iii","parentIdentifier":"/us/usc/t25/s2907/f/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Ff%2F2%2FC%2Fiii","sourceRelease":"119-100","text":"nonprofit organizations that work with Indian tribes, Native American language programs, and Native American language communities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Limitation","label":"g Limitation","identifier":"/us/usc/t25/s2907/g","parentIdentifier":"/us/usc/t25/s2907","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s2907/g/1","parentIdentifier":"/us/usc/t25/s2907/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fg%2F1","sourceRelease":"119-100","text":"to participate in a survey under subsection (a); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s2907/g/2","parentIdentifier":"/us/usc/t25/s2907/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fg%2F2","sourceRelease":"119-100","text":"to provide specific or culturally sensitive information in completing such a survey.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Availability of survey materials and findings","label":"h Availability of survey materials and findings","identifier":"/us/usc/t25/s2907/h","parentIdentifier":"/us/usc/t25/s2907","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s2907/h/1","parentIdentifier":"/us/usc/t25/s2907/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fh%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s2907/h/1/A","parentIdentifier":"/us/usc/t25/s2907/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fh%2F1%2FA","sourceRelease":"119-100","text":"the feedback received under subsection (c) on the design of the survey;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s2907/h/1/B","parentIdentifier":"/us/usc/t25/s2907/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fh%2F1%2FB","sourceRelease":"119-100","text":"the form and content of the survey;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s2907/h/1/C","parentIdentifier":"/us/usc/t25/s2907/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fh%2F1%2FC","sourceRelease":"119-100","text":"the plan for deploying the survey to ensure a robust response; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s2907/h/1/D","parentIdentifier":"/us/usc/t25/s2907/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fh%2F1%2FD","sourceRelease":"119-100","text":"how the Secretary will ensure any survey enumeration efforts are culturally informed and appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Results","label":"2 Results","identifier":"/us/usc/t25/s2907/h/2","parentIdentifier":"/us/usc/t25/s2907/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fh%2F2","sourceRelease":"119-100","text":"Not later than 90 days after the date on which analysis of each survey under subsection (a) is completed, the Secretary shall submit to the Committee on Indian Affairs of the Senate and the Committees on Education and Labor and Natural Resources of the House of Representatives, and make publicly available, the results of the survey.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Authorization of appropriations","label":"i Authorization of appropriations","identifier":"/us/usc/t25/s2907/i","parentIdentifier":"/us/usc/t25/s2907","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s2907/i/1","parentIdentifier":"/us/usc/t25/s2907/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fi%2F1","sourceRelease":"119-100","text":"preceding a fiscal year during which a survey under subsection (a) is conducted; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s2907/i/2","parentIdentifier":"/us/usc/t25/s2907/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2907%2Fi%2F2","sourceRelease":"119-100","text":"during which a survey under that subsection is conducted.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
