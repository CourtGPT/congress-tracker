{"type":"section","nativeType":"section","number":"2319C","heading":"Illicit digital transmission services","label":"2319C Illicit digital transmission services","identifier":"/us/usc/t18/s2319C","parentIdentifier":"/us/usc/t18/ptI/ch113","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Definitions","label":"a .—Definitions","identifier":"/us/usc/t18/s2319C/a","parentIdentifier":"/us/usc/t18/s2319C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2319C/a/1","parentIdentifier":"/us/usc/t18/s2319C/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fa%2F1","sourceRelease":"119-100","text":"the terms “audiovisual work”, “computer program”, “copies”, “copyright owner”, “digital transmission”, “financial gain”, “motion picture”, “motion picture exhibition facility”, “perform”, “phonorecords”, “publicly” (with respect to performing a work), “sound recording”, and “transmit” have the meanings given those terms in ;section 101 of title 17","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2319C/a/2","parentIdentifier":"/us/usc/t18/s2319C/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fa%2F2","sourceRelease":"119-100","text":"the term “digital transmission service” means a service that has the primary purpose of publicly performing works by digital transmission;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s2319C/a/3","parentIdentifier":"/us/usc/t18/s2319C/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fa%2F3","sourceRelease":"119-100","text":"the terms “publicly perform” and “public performance” refer to the exclusive rights of a copyright owner under paragraphs (4) and (6) of section 106 (relating to exclusive rights in copyrighted works) of title 17, as limited by sections 107 through 122 of title 17; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t18/s2319C/a/4","parentIdentifier":"/us/usc/t18/s2319C/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s2319C/a/4/A","parentIdentifier":"/us/usc/t18/s2319C/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fa%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t18/s2319C/a/4/A/i","parentIdentifier":"/us/usc/t18/s2319C/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fa%2F4%2FA%2Fi","sourceRelease":"119-100","text":"the copyright owner has a reasonable expectation of commercial public performance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t18/s2319C/a/4/A/ii","parentIdentifier":"/us/usc/t18/s2319C/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fa%2F4%2FA%2Fii","sourceRelease":"119-100","text":"the copies or phonorecords of the work have not been commercially publicly performed in the United States by or with the authorization of the copyright owner; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s2319C/a/4/B","parentIdentifier":"/us/usc/t18/s2319C/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fa%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t18/s2319C/a/4/B/i","parentIdentifier":"/us/usc/t18/s2319C/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fa%2F4%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t18/s2319C/a/4/B/i/I","parentIdentifier":"/us/usc/t18/s2319C/a/4/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fa%2F4%2FB%2Fi%2FI","sourceRelease":"119-100","text":"has been made available for viewing in a motion picture exhibition facility; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t18/s2319C/a/4/B/i/II","parentIdentifier":"/us/usc/t18/s2319C/a/4/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fa%2F4%2FB%2Fi%2FII","sourceRelease":"119-100","text":"has not been made available in copies for sale to the general public in the United States by or with the authorization of the copyright owner in a format intended to permit viewing outside a motion picture exhibition facility; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t18/s2319C/a/4/B/ii","parentIdentifier":"/us/usc/t18/s2319C/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fa%2F4%2FB%2Fii","sourceRelease":"119-100","text":"had not been commercially publicly performed in the United States by or with the authorization of the copyright owner more than 24 hours before the unauthorized public performance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Prohibited Act","label":"b .—Prohibited Act","identifier":"/us/usc/t18/s2319C/b","parentIdentifier":"/us/usc/t18/s2319C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2319C/b/1","parentIdentifier":"/us/usc/t18/s2319C/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fb%2F1","sourceRelease":"119-100","text":"is primarily designed or provided for the purpose of publicly performing works protected under title 17 by means of a digital transmission without the authority of the copyright owner or the law;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2319C/b/2","parentIdentifier":"/us/usc/t18/s2319C/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fb%2F2","sourceRelease":"119-100","text":"has no commercially significant purpose or use other than to publicly perform works protected under title 17 by means of a digital transmission without the authority of the copyright owner or the law; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s2319C/b/3","parentIdentifier":"/us/usc/t18/s2319C/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fb%2F3","sourceRelease":"119-100","text":"is intentionally marketed by or at the direction of that person to promote its use in publicly performing works protected under title 17 by means of a digital transmission without the authority of the copyright owner or the law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Penalties","label":"c .—Penalties","identifier":"/us/usc/t18/s2319C/c","parentIdentifier":"/us/usc/t18/s2319C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2319C/c/1","parentIdentifier":"/us/usc/t18/s2319C/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fc%2F1","sourceRelease":"119-100","text":"fined under this title, imprisoned not more than 3 years, or both;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2319C/c/2","parentIdentifier":"/us/usc/t18/s2319C/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s2319C/c/2/A","parentIdentifier":"/us/usc/t18/s2319C/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the offense was committed in connection with 1 or more works being prepared for commercial public performance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s2319C/c/2/B","parentIdentifier":"/us/usc/t18/s2319C/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the person knew or should have known that the work was being prepared for commercial public performance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s2319C/c/3","parentIdentifier":"/us/usc/t18/s2319C/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fc%2F3","sourceRelease":"119-100","text":"fined under this title, imprisoned not more than 10 years, or both, if the offense is a second or subsequent offense under this section or section 2319(a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Rule of Construction","label":"d .—Rule of Construction","identifier":"/us/usc/t18/s2319C/d","parentIdentifier":"/us/usc/t18/s2319C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2319C/d/1","parentIdentifier":"/us/usc/t18/s2319C/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fd%2F1","sourceRelease":"119-100","text":"affect the interpretation of any other provision of civil copyright law, including the limitations of liability set forth in , or principles of secondary liability; orsection 512 of title 17","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2319C/d/2","parentIdentifier":"/us/usc/t18/s2319C/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2319C%2Fd%2F2","sourceRelease":"119-100","text":"prevent any Federal or State authority from enforcing cable theft or theft of service laws that are not subject to preemption under .section 301 of title 17","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
