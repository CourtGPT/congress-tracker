{"type":"section","nativeType":"section","number":"8932","heading":"Performance standard for the detection of highly fluorinated compounds","label":"8932 Performance standard for the detection of highly fluorinated compounds","identifier":"/us/usc/t15/s8932","parentIdentifier":"/us/usc/t15/ch115/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8932","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s8932/a","parentIdentifier":"/us/usc/t15/s8932","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8932%2Fa","sourceRelease":"119-100","text":"The Director, in consultation with the Administrator, shall establish a performance standard for the detection of highly fluorinated compounds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Emphasis","label":"b Emphasis","identifier":"/us/usc/t15/s8932/b","parentIdentifier":"/us/usc/t15/s8932","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8932%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s8932/b/1","parentIdentifier":"/us/usc/t15/s8932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8932%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8932/b/1/A","parentIdentifier":"/us/usc/t15/s8932/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8932%2Fb%2F1%2FA","sourceRelease":"119-100","text":"achieve limits of quantitation (as defined in the document of the United States Geological Survey entitled “Analytical Methods for Chemical Analysis of Geologic and Other Materials, U.S. Geological Survey” and dated 2002); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8932/b/1/B","parentIdentifier":"/us/usc/t15/s8932/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8932%2Fb%2F1%2FB","sourceRelease":"119-100","text":"are as sensitive as is feasible and practicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirement","label":"2 Requirement","identifier":"/us/usc/t15/s8932/b/2","parentIdentifier":"/us/usc/t15/s8932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8932%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8932/b/2/A","parentIdentifier":"/us/usc/t15/s8932/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8932%2Fb%2F2%2FA","sourceRelease":"119-100","text":"develop quality assurance and quality control measures to ensure accurate sampling and testing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8932/b/2/B","parentIdentifier":"/us/usc/t15/s8932/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8932%2Fb%2F2%2FB","sourceRelease":"119-100","text":"develop a training program with respect to the appropriate method of sample collection and analysis of highly fluorinated compounds; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s8932/b/2/C","parentIdentifier":"/us/usc/t15/s8932/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8932%2Fb%2F2%2FC","sourceRelease":"119-100","text":"coordinate as necessary with the Administrator, including, if appropriate, to develop methods to detect individual and different highly fluorinated compounds simultaneously.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
