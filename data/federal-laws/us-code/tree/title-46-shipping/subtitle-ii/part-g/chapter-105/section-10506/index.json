ldren":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t46/s10506/2/G","parentIdentifier":"/us/usc/t46/s10506/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10506%2F2%2FG","sourceRelease":"119-100","text":"purchasing insurance to provide any of the benefits specified in this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
