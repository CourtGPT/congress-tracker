{"type":"section","nativeType":"section","number":"8854","heading":"Department of Energy Quantum User Expansion for Science and Technology program","label":"8854 Department of Energy Quantum User Expansion for Science and Technology program","identifier":"/us/usc/t15/s8854","parentIdentifier":"/us/usc/t15/ch114/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s8854/a","parentIdentifier":"/us/usc/t15/s8854","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8854/a/1","parentIdentifier":"/us/usc/t15/s8854/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fa%2F1","sourceRelease":"119-100","text":"to enhance the United States quantum research enterprise;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8854/a/2","parentIdentifier":"/us/usc/t15/s8854/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fa%2F2","sourceRelease":"119-100","text":"to educate the future quantum computing workforce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8854/a/3","parentIdentifier":"/us/usc/t15/s8854/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fa%2F3","sourceRelease":"119-100","text":"to accelerate the advancement of United States quantum computing capabilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s8854/a/4","parentIdentifier":"/us/usc/t15/s8854/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fa%2F4","sourceRelease":"119-100","text":"to advance the relevant domestic supply chains, manufacturing processes, and associated simulations or modeling capabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Program","label":"b Program","identifier":"/us/usc/t15/s8854/b","parentIdentifier":"/us/usc/t15/s8854","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8854/b/1","parentIdentifier":"/us/usc/t15/s8854/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8854/b/1/A","parentIdentifier":"/us/usc/t15/s8854/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the Director of the National Science Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8854/b/1/B","parentIdentifier":"/us/usc/t15/s8854/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the Director of the National Institute of Standards and Technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s8854/b/1/C","parentIdentifier":"/us/usc/t15/s8854/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the Chair of the Subcommittee on Quantum Information Science of the National Science and Technology Council established under ; andsection 8813(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s8854/b/1/D","parentIdentifier":"/us/usc/t15/s8854/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fb%2F1%2FD","sourceRelease":"119-100","text":"the Chair of the Subcommittee on the Economic and Security Implications of Quantum Science;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8854/b/2","parentIdentifier":"/us/usc/t15/s8854/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fb%2F2","sourceRelease":"119-100","text":"provide researchers based within the United States with access to, and use of, United States quantum computing resources through a competitive, merit-reviewed process;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8854/b/3","parentIdentifier":"/us/usc/t15/s8854/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fb%2F3","sourceRelease":"119-100","text":"consider applications from the National Laboratories, multi-institutional collaborations, institutions of higher education, industry stakeholders, and any other entities that the Secretary determines are appropriate to provide national leadership on quantum computing related issues;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s8854/b/4","parentIdentifier":"/us/usc/t15/s8854/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fb%2F4","sourceRelease":"119-100","text":"coordinate with private sector stakeholders, the user community, and interagency partners on program development and best management practices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s8854/b/5","parentIdentifier":"/us/usc/t15/s8854/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fb%2F5","sourceRelease":"119-100","text":"to the extent practicable, balance user access to commercial prototypes available for use across a broad class of applications and Federal research prototypes that enable benchmarking a wider variety of early-stage devices.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Leveraging","label":"c Leveraging","identifier":"/us/usc/t15/s8854/c","parentIdentifier":"/us/usc/t15/s8854","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8854/c/1","parentIdentifier":"/us/usc/t15/s8854/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8854%2Fc%2F1","sourceRelease":"119-100","text":"the National Institute of 