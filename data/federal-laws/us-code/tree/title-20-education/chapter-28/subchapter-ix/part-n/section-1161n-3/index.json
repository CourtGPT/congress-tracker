{"type":"section","nativeType":"section","number":"1161n–3","heading":"Demonstration and innovation projects; training and resource centers; and research","label":"1161n–3 Demonstration and innovation projects; training and resource centers; and research","identifier":"/us/usc/t20/s1161n–3","parentIdentifier":"/us/usc/t20/ch28/schIX/ptN","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authorization","label":"a Authorization","identifier":"/us/usc/t20/s1161n–3/a","parentIdentifier":"/us/usc/t20/s1161n–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1161n–3/a/1","parentIdentifier":"/us/usc/t20/s1161n–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fa%2F1","sourceRelease":"119-100","text":"from the amounts available in each fiscal year under , for the conduct of demonstration projects designed to demonstrate or determine the effectiveness of innovative methods of cooperative education;section 1161n–1(a)(3) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1161n–3/a/2","parentIdentifier":"/us/usc/t20/s1161n–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161n–3/a/2/A","parentIdentifier":"/us/usc/t20/s1161n–3/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fa%2F2%2FA","sourceRelease":"119-100","text":"train personnel in the field of cooperative education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161n–3/a/2/B","parentIdentifier":"/us/usc/t20/s1161n–3/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fa%2F2%2FB","sourceRelease":"119-100","text":"improve materials used in cooperative education programs if such improvement is conducted in conjunction with other activities described in this paragraph;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161n–3/a/2/C","parentIdentifier":"/us/usc/t20/s1161n–3/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fa%2F2%2FC","sourceRelease":"119-100","text":"provide technical assistance to institutions of higher education to increase the potential of the institution to continue to conduct a cooperative education program without Federal assistance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1161n–3/a/2/D","parentIdentifier":"/us/usc/t20/s1161n–3/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fa%2F2%2FD","sourceRelease":"119-100","text":"encourage model cooperative education programs that furnish education and training in occupations in which there is a national need;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s1161n–3/a/2/E","parentIdentifier":"/us/usc/t20/s1161n–3/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fa%2F2%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1161n–3/a/2/E/i","parentIdentifier":"/us/usc/t20/s1161n–3/a/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fa%2F2%2FE%2Fi","sourceRelease":"119-100","text":"assist the institution that is not the institution carrying out the cooperative education program to develop and expand an existing program of cooperative education; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1161n–3/a/2/E/ii","parentIdentifier":"/us/usc/t20/s1161n–3/a/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fa%2F2%2FE%2Fii","sourceRelease":"119-100","text":"establish and improve or expand comprehensive cooperative education programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t20/s1161n–3/a/2/F","parentIdentifier":"/us/usc/t20/s1161n–3/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fa%2F2%2FF","sourceRelease":"119-100","text":"encourage model cooperative education programs in the fields of science and mathematics for women and minorities who are underrepresented in such fields; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s1161n–3/a/3","parentIdentifier":"/us/usc/t20/s1161n–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fa%2F3","sourceRelease":"119-100","text":"from the amounts available in each fiscal year under , for the conduct of research relating to cooperative education.section 1161n–1(a)(5) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Administrative provision","label":"b Administrative provision","identifier":"/us/usc/t20/s1161n–3/b","parentIdentifier":"/us/usc/t20/s1161n–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t20/s1161n–3/b/1","parentIdentifier":"/us/usc/t20/s1161n–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161n–3/b/1/A","parentIdentifier":"/us/usc/t20/s1161n–3/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fb%2F1%2FA","sourceRelease":"119-100","text":"make grants to or contracts with institutions of higher education or consortia of such institutions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161n–3/b/1/B","parentIdentifier":"/us/usc/t20/s1161n–3/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fb%2F1%2FB","sourceRelease":"119-100","text":"make grants to or contracts with other public or private nonprofit agencies or organizations, whenever such grants or contracts will contribute to the objectives of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitation","label":"2 Limitation","identifier":"/us/usc/t20/s1161n–3/b/2","parentIdentifier":"/us/usc/t20/s1161n–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Contracts with institutions of higher education","label":"A Contracts with institutions of higher education","identifier":"/us/usc/t20/s1161n–3/b/2/A","parentIdentifier":"/us/usc/t20/s1161n–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The Secretary may use not more than three percent of the amount appropriated to carry out this section in each fiscal year to enter into contracts described in paragraph (1)(A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Contracts with other agencies or organizations","label":"B Contracts with other agencies or organizations","identifier":"/us/usc/t20/s1161n–3/b/2/B","parentIdentifier":"/us/usc/t20/s1161n–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fb%2F2%2FB","sourceRelease":"119-100","text":"The Secretary may use not more than three percent of the amount appropriated to carry out this section in each fiscal year to enter into contracts described in paragraph (1)(B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Supplement not supplant","label":"c Supplement not supplant","identifier":"/us/usc/t20/s1161n–3/c","parentIdentifier":"/us/usc/t20/s1161n–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161n%E2%80%933%2Fc","sourceRelease":"119-100","text":"A recipient of a grant or contract under this section may use the funds provided only to supplement funds made available from non-Federal sources to carry out the activities supported by such grant or contract, and in no case to supplant such funds from non-Federal sources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
