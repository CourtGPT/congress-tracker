{"type":"section","nativeType":"section","number":"7512","heading":"Requirements of electronic merchant mariner credentialing system","label":"7512 Requirements of electronic merchant mariner credentialing system","identifier":"/us/usc/t46/s7512","parentIdentifier":"/us/usc/t46/stII/ptE/ch75","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Definition of Merchant Mariner Credential","label":"a .—Definition of Merchant Mariner Credential","identifier":"/us/usc/t46/s7512/a","parentIdentifier":"/us/usc/t46/s7512","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fa","sourceRelease":"119-100","text":"In this section, the term “merchant mariner credential” means a merchant mariner license, certificate, or document that the Secretary is authorized to issue pursuant to this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Necessary Considerations","label":"b .—Necessary Considerations","identifier":"/us/usc/t46/s7512/b","parentIdentifier":"/us/usc/t46/s7512","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s7512/b/1","parentIdentifier":"/us/usc/t46/s7512/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fb%2F1","sourceRelease":"119-100","text":"the electronic submission of the components of merchant mariner credential applications (such as sea service documentation, professional qualifications, course completion certificates, safety and suitability documents, and medical records) and course approval requests;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s7512/b/2","parentIdentifier":"/us/usc/t46/s7512/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s7512/b/2/A","parentIdentifier":"/us/usc/t46/s7512/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fb%2F2%2FA","sourceRelease":"119-100","text":"sea service verification documentation from employers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s7512/b/2/B","parentIdentifier":"/us/usc/t46/s7512/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fb%2F2%2FB","sourceRelease":"119-100","text":"course completion certificates from training providers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t46/s7512/b/2/C","parentIdentifier":"/us/usc/t46/s7512/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fb%2F2%2FC","sourceRelease":"119-100","text":"necessary documentation from other stakeholders; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s7512/b/3","parentIdentifier":"/us/usc/t46/s7512/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fb%2F3","sourceRelease":"119-100","text":"the electronic processing and evaluation of information for the issuance of merchant mariner credentials and course approvals, including the capability for the Secretary to complete remote evaluation of information submitted through the system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Access to Data","label":"c .—Access to Data","identifier":"/us/usc/t46/s7512/c","parentIdentifier":"/us/usc/t46/s7512","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s7512/c/1","parentIdentifier":"/us/usc/t46/s7512/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fc%2F1","sourceRelease":"119-100","text":"the total amount of sea service for individuals with a valid merchant mariner credential;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s7512/c/2","parentIdentifier":"/us/usc/t46/s7512/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fc%2F2","sourceRelease":"119-100","text":"the number of mariners with valid merchant mariner credentials for each rating, including the capability to filter data based on credential endorsements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s7512/c/3","parentIdentifier":"/us/usc/t46/s7512/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fc%2F3","sourceRelease":"119-100","text":"demographic information including age, gender, and region or address;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t46/s7512/c/4","parentIdentifier":"/us/usc/t46/s7512/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fc%2F4","sourceRelease":"119-100","text":"the estimated times for the Coast Guard to process merchant mariner credential applications, mariner medical certificates, and course approvals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t46/s7512/c/5","parentIdentifier":"/us/usc/t46/s7512/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fc%2F5","sourceRelease":"119-100","text":"the number of providers approved to provide training for purposes of this part and, for each such training provider, the number of classes taken by individuals with, or applying for, a merchant mariner credential; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t46/s7512/c/6","parentIdentifier":"/us/usc/t46/s7512/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fc%2F6","sourceRelease":"119-100","text":"if applicable, the branch of the uniformed services (as defined in ) and duty status of applicants for a merchant mariner credential.section 101(a) of title 10","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Privacy Requirements","label":"d .—Privacy Requirements","identifier":"/us/usc/t46/s7512/d","parentIdentifier":"/us/usc/t46/s7512","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs7512%2Fd","sourceRelease":"119-100","text":"The Secretary shall collect the information required under subsection (b) in a manner that protects the privacy rights of individuals who are the subjects of such information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
