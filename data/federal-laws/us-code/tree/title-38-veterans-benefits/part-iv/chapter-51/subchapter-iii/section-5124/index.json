{"type":"section","nativeType":"section","number":"5124","heading":"Acceptance of claimant’s statement as proof of relationship","label":"5124 Acceptance of claimant’s statement as proof of relationship","identifier":"/us/usc/t38/s5124","parentIdentifier":"/us/usc/t38/ptIV/ch51/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5124","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t38/s5124/a","parentIdentifier":"/us/usc/t38/s5124","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5124%2Fa","sourceRelease":"119-100","text":"For purposes of benefits under laws administered by the Secretary, the Secretary may accept the written statement of a claimant as proof of the existence of any relationship specified in subsection (b) for the purpose of acting on such individual’s claim for benefits.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t38/s5124/b","parentIdentifier":"/us/usc/t38/s5124","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5124%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s5124/b/1","parentIdentifier":"/us/usc/t38/s5124/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5124%2Fb%2F1","sourceRelease":"119-100","text":"Marriage.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s5124/b/2","parentIdentifier":"/us/usc/t38/s5124/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5124%2Fb%2F2","sourceRelease":"119-100","text":"Dissolution of a marriage.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s5124/b/3","parentIdentifier":"/us/usc/t38/s5124/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5124%2Fb%2F3","sourceRelease":"119-100","text":"Birth of a child.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s5124/b/4","parentIdentifier":"/us/usc/t38/s5124/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5124%2Fb%2F4","sourceRelease":"119-100","text":"Death of any family member.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t38/s5124/c","parentIdentifier":"/us/usc/t38/s5124","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5124%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s5124/c/1","parentIdentifier":"/us/usc/t38/s5124/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5124%2Fc%2F1","sourceRelease":"119-100","text":"the claimant does not reside within a State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s5124/c/2","parentIdentifier":"/us/usc/t38/s5124/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5124%2Fc%2F2","sourceRelease":"119-100","text":"the statement on its face raises a question as to its validity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s5124/c/3","parentIdentifier":"/us/usc/t38/s5124/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5124%2Fc%2F3","sourceRelease":"119-100","text":"there is conflicting information of record; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s5124/c/4","parentIdentifier":"/us/usc/t38/s5124/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5124%2Fc%2F4","sourceRelease":"119-100","text":"there is reasonable indication, in the statement or otherwise, of fraud or misrepresentation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
