  "bugs": {
    "url": "https://github.com/CourtGPT/congress-tracker/issues"
  },
  "homepage": "https://github.com/CourtGPT/congress-tracker#readme",
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}
