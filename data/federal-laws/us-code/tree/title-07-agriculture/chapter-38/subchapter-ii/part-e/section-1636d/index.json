{"type":"section","nativeType":"section","number":"1636d","heading":"Recordkeeping","label":"1636d Recordkeeping","identifier":"/us/usc/t7/s1636d","parentIdentifier":"/us/usc/t7/ch38/schII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t7/s1636d/a","parentIdentifier":"/us/usc/t7/s1636d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636d%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s1636d/a/1","parentIdentifier":"/us/usc/t7/s1636d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636d%2Fa%2F1","sourceRelease":"119-100","text":"the original contracts, agreements, receipts and other records associated with any transaction relating to the purchase, sale, pricing, transportation, delivery, weighing, slaughter, or carcass characteristics of all livestock; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s1636d/a/2","parentIdentifier":"/us/usc/t7/s1636d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636d%2Fa%2F2","sourceRelease":"119-100","text":"such records or other information as is necessary or appropriate to verify the accuracy of the information required to be reported under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitations","label":"b Limitations","identifier":"/us/usc/t7/s1636d/b","parentIdentifier":"/us/usc/t7/s1636d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s1636d/b/1","parentIdentifier":"/us/usc/t7/s1636d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636d%2Fb%2F1","sourceRelease":"119-100","text":"the information is not generally available or maintained by packers; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s1636d/b/2","parentIdentifier":"/us/usc/t7/s1636d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636d%2Fb%2F2","sourceRelease":"119-100","text":"the provision of the information would be unduly burdensome.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Purchases of cattle or swine","label":"c Purchases of cattle or swine","identifier":"/us/usc/t7/s1636d/c","parentIdentifier":"/us/usc/t7/s1636d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636d%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s1636d/c/1","parentIdentifier":"/us/usc/t7/s1636d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636d%2Fc%2F1","sourceRelease":"119-100","text":"before 10:00 a.m. Central Time;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s1636d/c/2","parentIdentifier":"/us/usc/t7/s1636d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636d%2Fc%2F2","sourceRelease":"119-100","text":"between 10:00 a.m. and 2:00 p.m. Central Time; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s1636d/c/3","parentIdentifier":"/us/usc/t7/s1636d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636d%2Fc%2F3","sourceRelease":"119-100","text":"after 2:00 p.m. Central Time.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
