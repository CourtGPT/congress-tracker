{"type":"section","nativeType":"section","number":"3151b","heading":"Veterinary services grant program","label":"3151b Veterinary services grant program","identifier":"/us/usc/t7/s3151b","parentIdentifier":"/us/usc/t7/ch64/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2018—Subsec. (d)(1)(F). , added subpar. (F).Pub. L. 115–334, § 7106(1)Subsec. (h). , designated existing provisions as par. (1), inserted heading, and added par. (2).Pub. L. 115–334, § 7106(2)"],"amendments":["Amendments2018—Subsec. (d)(1)(F). , added subpar. (F).Pub. L. 115–334, § 7106(1)Subsec. (h). , designated existing provisions as par. (1), inserted heading, and added par. (2).Pub. L. 115–334, § 7106(2)"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t7/s3151b/a","parentIdentifier":"/us/usc/t7/s3151b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Qualified entity","label":"1 Qualified entity","identifier":"/us/usc/t7/s3151b/a/1","parentIdentifier":"/us/usc/t7/s3151b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s3151b/a/1/A","parentIdentifier":"/us/usc/t7/s3151b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s3151b/a/1/A/i","parentIdentifier":"/us/usc/t7/s3151b/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"in a rural area, as defined in ; andsection 1991(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s3151b/a/1/A/ii","parentIdentifier":"/us/usc/t7/s3151b/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"in a veterinarian shortage situation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s3151b/a/1/B","parentIdentifier":"/us/usc/t7/s3151b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fa%2F1%2FB","sourceRelease":"119-100","text":"a State, national, allied, or regional veterinary organization or specialty board recognized by the American Veterinary Medical Association;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s3151b/a/1/C","parentIdentifier":"/us/usc/t7/s3151b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fa%2F1%2FC","sourceRelease":"119-100","text":"a college or school of veterinary medicine accredited by the American Veterinary Medical Association;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s3151b/a/1/D","parentIdentifier":"/us/usc/t7/s3151b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fa%2F1%2FD","sourceRelease":"119-100","text":"a university research foundation or veterinary medical foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s3151b/a/1/E","parentIdentifier":"/us/usc/t7/s3151b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fa%2F1%2FE","sourceRelease":"119-100","text":"a department of veterinary science or department of comparative medicine accredited by the Department of Education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t7/s3151b/a/1/F","parentIdentifier":"/us/usc/t7/s3151b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fa%2F1%2FF","sourceRelease":"119-100","text":"a State agricultural experiment station; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t7/s3151b/a/1/G","parentIdentifier":"/us/usc/t7/s3151b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fa%2F1%2FG","sourceRelease":"119-100","text":"a State, local, or tribal government agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Veterinarian shortage situation","label":"2 Veterinarian shortage situation","identifier":"/us/usc/t7/s3151b/a/2","parentIdentifier":"/us/usc/t7/s3151b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fa%2F2","sourceRelease":"119-100","text":"The term “veterinarian shortage situation” means a veterinarian shortage situation as determined by the Secretary under .section 3151a of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t7/s3151b/b","parentIdentifier":"/us/usc/t7/s3151b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Competitive grants","label":"1 Competitive grants","identifier":"/us/usc/t7/s3151b/b/1","parentIdentifier":"/us/usc/t7/s3151b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall carry out a program to make competitive grants to qualified entities that carry out programs or activities described in paragraph (2) for the purpose of developing, implementing, and sustaining veterinary services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligibility requirements","label":"2 Eligibility requirements","identifier":"/us/usc/t7/s3151b/b/2","parentIdentifier":"/us/usc/t7/s3151b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s3151b/b/2/A","parentIdentifier":"/us/usc/t7/s3151b/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fb%2F2%2FA","sourceRelease":"119-100","text":"substantially relieve veterinarian shortage situations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s3151b/b/2/B","parentIdentifier":"/us/usc/t7/s3151b/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fb%2F2%2FB","sourceRelease":"119-100","text":"support or facilitate private veterinary practices engaged in public health activities; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s3151b/b/2/C","parentIdentifier":"/us/usc/t7/s3151b/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fb%2F2%2FC","sourceRelease":"119-100","text":"support or facilitate the practices of veterinarians who are providing or have completed providing services under an agreement entered into with the Secretary under .section 3151a(a)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Award processes and preferences","label":"c Award processes and preferences","identifier":"/us/usc/t7/s3151b/c","parentIdentifier":"/us/usc/t7/s3151b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Application, evaluation, and input processes","label":"1 Application, evaluation, and input processes","identifier":"/us/usc/t7/s3151b/c/1","parentIdentifier":"/us/usc/t7/s3151b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s3151b/c/1/A","parentIdentifier":"/us/usc/t7/s3151b/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fc%2F1%2FA","sourceRelease":"119-100","text":"use an appropriate application and evaluation process, as determined by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s3151b/c/1/B","parentIdentifier":"/us/usc/t7/s3151b/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fc%2F1%2FB","sourceRelease":"119-100","text":"seek the input of interested persons.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Coordination preference","label":"2 Coordination preference","identifier":"/us/usc/t7/s3151b/c/2","parentIdentifier":"/us/usc/t7/s3151b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fc%2F2","sourceRelease":"119-100","text":"In selecting recipients of grants to be used for any of the purposes described in subsection (d)(1), the Secretary shall give a preference to qualified entities that provide documentation of coordination with other qualified entities, with respect to any such purpose.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Consideration of available funds","label":"3 Consideration of available funds","identifier":"/us/usc/t7/s3151b/c/3","parentIdentifier":"/us/usc/t7/s3151b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fc%2F3","sourceRelease":"119-100","text":"In selecting recipients of grants to be used for any of the purposes described in subsection (d), the Secretary shall take into consideration the amount of funds available for grants and the purposes for which the grant funds will be used.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Nature of grants","label":"4 Nature of grants","identifier":"/us/usc/t7/s3151b/c/4","parentIdentifier":"/us/usc/t7/s3151b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fc%2F4","sourceRelease":"119-100","text":"A grant awarded under this section shall be considered to be a competitive research, extension, or education grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Use of grants to relieve veterinarian shortage situations and support veterinary services","label":"d Use of grants to relieve veterinarian shortage situations and support veterinary services","identifier":"/us/usc/t7/s3151b/d","parentIdentifier":"/us/usc/t7/s3151b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s3151b/d/1","parentIdentifier":"/us/usc/t7/s3151b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s3151b/d/1/A","parentIdentifier":"/us/usc/t7/s3151b/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fd%2F1%2FA","sourceRelease":"119-100","text":"To promote recruitment (including for programs in secondary schools), placement, and retention of veterinarians, veterinary technicians, students of veterinary medicine, and students of veterinary technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s3151b/d/1/B","parentIdentifier":"/us/usc/t7/s3151b/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fd%2F1%2FB","sourceRelease":"119-100","text":"To allow veterinary students, veterinary interns, externs, fellows, and residents, and veterinary technician students to cover expenses (other than the types of expenses described in ) to attend training programs in food safety or food animal medicine.section 3151a(c)(5) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s3151b/d/1/C","parentIdentifier":"/us/usc/t7/s3151b/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fd%2F1%2FC","sourceRelease":"119-100","text":"To establish or expand accredited veterinary education programs (including faculty recruitment and retention), veterinary residency and fellowship programs, or veterinary internship and externship programs carried out in coordination with accredited colleges of veterinary medicine.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s3151b/d/1/D","parentIdentifier":"/us/usc/t7/s3151b/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fd%2F1%2FD","sourceRelease":"119-100","text":"To provide continuing education and extension, including veterinary telemedicine and other distance-based education, for veterinarians, veterinary technicians, and other health professionals needed to strengthen veterinary programs and enhance food safety.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s3151b/d/1/E","parentIdentifier":"/us/usc/t7/s3151b/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fd%2F1%2FE","sourceRelease":"119-100","text":"To provide technical assistance for the preparation of applications submitted to the Secretary for designation as a veterinarian shortage situation under this section or .section 3151a of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t7/s3151b/d/1/F","parentIdentifier":"/us/usc/t7/s3151b/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fd%2F1%2FF","sourceRelease":"119-100","text":"To expose students in grades 11 and 12 to education and career opportunities in food animal medicine.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Qualified entities operating veterinary clinics","label":"2 Qualified entities operating veterinary clinics","identifier":"/us/usc/t7/s3151b/d/2","parentIdentifier":"/us/usc/t7/s3151b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s3151b/d/2/A","parentIdentifier":"/us/usc/t7/s3151b/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fd%2F2%2FA","sourceRelease":"119-100","text":"equipping veterinary offices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s3151b/d/2/B","parentIdentifier":"/us/usc/t7/s3151b/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fd%2F2%2FB","sourceRelease":"119-100","text":"sharing in the reasonable overhead costs of such veterinary practices, as determined by the Secretary; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s3151b/d/2/C","parentIdentifier":"/us/usc/t7/s3151b/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fd%2F2%2FC","sourceRelease":"119-100","text":"establishing mobile veterinary facilities in which a portion of the facilities will address education or extension needs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Special requirements for certain grants","label":"e Special requirements for certain grants","identifier":"/us/usc/t7/s3151b/e","parentIdentifier":"/us/usc/t7/s3151b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Terms of service requirements","label":"1 Terms of service requirements","identifier":"/us/usc/t7/s3151b/e/1","parentIdentifier":"/us/usc/t7/s3151b/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s3151b/e/1/A","parentIdentifier":"/us/usc/t7/s3151b/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fe%2F1%2FA","sourceRelease":"119-100","text":"Funds provided through a grant made under this section to a qualified entity described in subsection (a)(1)(A) and used by such entity under subsection (d)(2) shall be subject to an agreement between the Secretary and such entity that includes a required term of service for such entity (including a qualified entity operating as an individual), as established by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Considerations","label":"B Considerations","identifier":"/us/usc/t7/s3151b/e/1/B","parentIdentifier":"/us/usc/t7/s3151b/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fe%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s3151b/e/1/B/i","parentIdentifier":"/us/usc/t7/s3151b/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fe%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the amount of the grant awarded; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s3151b/e/1/B/ii","parentIdentifier":"/us/usc/t7/s3151b/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fe%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the specific purpose of the grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Breach remedies","label":"2 Breach remedies","identifier":"/us/usc/t7/s3151b/e/2","parentIdentifier":"/us/usc/t7/s3151b/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s3151b/e/2/A","parentIdentifier":"/us/usc/t7/s3151b/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fe%2F2%2FA","sourceRelease":"119-100","text":"An agreement under paragraph (1) shall provide remedies for any breach of the agreement by the qualified entity referred to in paragraph (1)(A), including repayment or partial repayment of the grant funds, with interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Waiver","label":"B Waiver","identifier":"/us/usc/t7/s3151b/e/2/B","parentIdentifier":"/us/usc/t7/s3151b/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fe%2F2%2FB","sourceRelease":"119-100","text":"The Secretary may grant a waiver of the repayment obligation for breach of contract if the Secretary determines that such qualified entity demonstrates extreme hardship or extreme need.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Treatment of amounts recovered","label":"C Treatment of amounts recovered","identifier":"/us/usc/t7/s3151b/e/2/C","parentIdentifier":"/us/usc/t7/s3151b/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fe%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s3151b/e/2/C/i","parentIdentifier":"/us/usc/t7/s3151b/e/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fe%2F2%2FC%2Fi","sourceRelease":"119-100","text":"be credited to the account available to carry out this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s3151b/e/2/C/ii","parentIdentifier":"/us/usc/t7/s3151b/e/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fe%2F2%2FC%2Fii","sourceRelease":"119-100","text":"remain available until expended without further appropriation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Prohibition on use of grant funds for construction","label":"f Prohibition on use of grant funds for construction","identifier":"/us/usc/t7/s3151b/f","parentIdentifier":"/us/usc/t7/s3151b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s3151b/f/1","parentIdentifier":"/us/usc/t7/s3151b/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Ff%2F1","sourceRelease":"119-100","text":"to construct a new building or facility; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s3151b/f/2","parentIdentifier":"/us/usc/t7/s3151b/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Ff%2F2","sourceRelease":"119-100","text":"to acquire, expand, remodel, or alter an existing building or facility, including site grading and improvement and architect fees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Regulations","label":"g Regulations","identifier":"/us/usc/t7/s3151b/g","parentIdentifier":"/us/usc/t7/s3151b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fg","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary shall promulgate regulations to carry out this section.February 7, 2014","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Authorization of appropriations","label":"h Authorization of appropriations","identifier":"/us/usc/t7/s3151b/h","parentIdentifier":"/us/usc/t7/s3151b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s3151b/h/1","parentIdentifier":"/us/usc/t7/s3151b/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fh%2F1","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Secretary to carry out this section $10,000,000 for fiscal year 2014 and each fiscal year thereafter, to remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Priority","label":"2 Priority","identifier":"/us/usc/t7/s3151b/h/2","parentIdentifier":"/us/usc/t7/s3151b/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3151b%2Fh%2F2","sourceRelease":"119-100","text":"From amounts made available for grants under this section, the Secretary shall prioritize grant awards for programs or activities with a focus on the practice of food animal medicine.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
