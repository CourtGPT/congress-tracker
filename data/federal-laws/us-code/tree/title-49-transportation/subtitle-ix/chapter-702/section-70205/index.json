s70205/c/1/B/ii","parentIdentifier":"/us/usc/t49/s70205/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70205%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"participate in merit reviews of research proposals and peer reviews of research products; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t49/s70205/c/1/B/iii","parentIdentifier":"/us/usc/t49/s70205/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70205%2Fc%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"receive research results.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Research contracts and grants.—","label":"2 Research contracts and grants.—","identifier":"/us/usc/t49/s70205/c/2","parentIdentifier":"/us/usc/t49/s70205/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70205%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t49/s70205/c/2/A","parentIdentifier":"/us/usc/t49/s70205/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70205%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s70205/c/2/A/i","parentIdentifier":"/us/usc/t49/s70205/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70205%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"open competition; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading