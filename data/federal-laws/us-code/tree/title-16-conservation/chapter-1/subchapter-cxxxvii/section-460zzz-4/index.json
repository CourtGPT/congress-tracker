{"type":"section","nativeType":"section","number":"460zzz–4","heading":"Management of Conservation Area and Wilderness","label":"460zzz–4 Management of Conservation Area and Wilderness","identifier":"/us/usc/t16/s460zzz–4","parentIdentifier":"/us/usc/t16/ch1/schCXXXVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Withdrawal","label":"a Withdrawal","identifier":"/us/usc/t16/s460zzz–4/a","parentIdentifier":"/us/usc/t16/s460zzz–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460zzz–4/a/1","parentIdentifier":"/us/usc/t16/s460zzz–4/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fa%2F1","sourceRelease":"119-100","text":"all forms of entry, appropriation, or disposal under the public land laws;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460zzz–4/a/2","parentIdentifier":"/us/usc/t16/s460zzz–4/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fa%2F2","sourceRelease":"119-100","text":"location, entry, and patent under the mining laws; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s460zzz–4/a/3","parentIdentifier":"/us/usc/t16/s460zzz–4/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fa%2F3","sourceRelease":"119-100","text":"operation of the mineral leasing, mineral materials, and geothermal leasing laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Grazing","label":"b Grazing","identifier":"/us/usc/t16/s460zzz–4/b","parentIdentifier":"/us/usc/t16/s460zzz–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Grazing in Conservation Area","label":"1 Grazing in Conservation Area","identifier":"/us/usc/t16/s460zzz–4/b/1","parentIdentifier":"/us/usc/t16/s460zzz–4/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fb%2F1","sourceRelease":"119-100","text":"Except as provided in paragraph (2), the Secretary shall issue and administer any grazing leases or permits in the Conservation Area in accordance with the laws (including regulations) applicable to the issuance and administration of such leases and permits on other land under the jurisdiction of the Bureau of Land Management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Grazing in Wilderness","label":"2 Grazing in Wilderness","identifier":"/us/usc/t16/s460zzz–4/b/2","parentIdentifier":"/us/usc/t16/s460zzz–4/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460zzz–4/b/2/A","parentIdentifier":"/us/usc/t16/s460zzz–4/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fb%2F2%2FA","sourceRelease":"119-100","text":"subject to any reasonable regulations, policies, and practices that the Secretary determines to be necessary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460zzz–4/b/2/B","parentIdentifier":"/us/usc/t16/s460zzz–4/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460zzz–4/b/2/B/i","parentIdentifier":"/us/usc/t16/s460zzz–4/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"; andsection 1133(d)(4) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460zzz–4/b/2/B/ii","parentIdentifier":"/us/usc/t16/s460zzz–4/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the guidelines set forth in Appendix A of the report of the Committee on Interior and Insular Affairs of the House of Representatives accompanying H.R. 2570 of the 101st Congress (H. Rept. 101–405).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"No buffer zones","label":"c No buffer zones","identifier":"/us/usc/t16/s460zzz–4/c","parentIdentifier":"/us/usc/t16/s460zzz–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s460zzz–4/c/1","parentIdentifier":"/us/usc/t16/s460zzz–4/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fc%2F1","sourceRelease":"119-100","text":"Nothing in this subchapter creates a protective perimeter or buffer zone around the Conservation Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Activities outside Conservation Area","label":"2 Activities outside Conservation Area","identifier":"/us/usc/t16/s460zzz–4/c/2","parentIdentifier":"/us/usc/t16/s460zzz–4/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fc%2F2","sourceRelease":"119-100","text":"The fact that an activity or use on land outside the Conservation Area can be seen or heard within the Conservation Area shall not preclude the activity or use outside the boundary of the Conservation Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Acquisition of land","label":"d Acquisition of land","identifier":"/us/usc/t16/s460zzz–4/d","parentIdentifier":"/us/usc/t16/s460zzz–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s460zzz–4/d/1","parentIdentifier":"/us/usc/t16/s460zzz–4/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary may acquire non-Federal land within the boundaries of the Conservation Area or the Wilderness only through exchange, donation, or purchase from a willing seller.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Management","label":"2 Management","identifier":"/us/usc/t16/s460zzz–4/d/2","parentIdentifier":"/us/usc/t16/s460zzz–4/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460zzz–4/d/2/A","parentIdentifier":"/us/usc/t16/s460zzz–4/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fd%2F2%2FA","sourceRelease":"119-100","text":"become part of the Conservation Area and, if applicable, the Wilderness; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460zzz–4/d/2/B","parentIdentifier":"/us/usc/t16/s460zzz–4/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fd%2F2%2FB","sourceRelease":"119-100","text":"be managed in accordance with this subchapter and any other applicable laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Fire, insects, and diseases","label":"e Fire, insects, and diseases","identifier":"/us/usc/t16/s460zzz–4/e","parentIdentifier":"/us/usc/t16/s460zzz–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460zzz–4/e/1","parentIdentifier":"/us/usc/t16/s460zzz–4/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fe%2F1","sourceRelease":"119-100","text":"in the Wilderness, in accordance with ; andsection 1133(d)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460zzz–4/e/2","parentIdentifier":"/us/usc/t16/s460zzz–4/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fe%2F2","sourceRelease":"119-100","text":"except as provided in paragraph (1), in the Conservation Area in accordance with this subchapter and any other applicable laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Access","label":"f Access","identifier":"/us/usc/t16/s460zzz–4/f","parentIdentifier":"/us/usc/t16/s460zzz–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Ff","sourceRelease":"119-100","text":"The Secretary shall continue to provide private landowners adequate access to inholdings in the Conservation Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Invasive species and noxious weeds","label":"g Invasive species and noxious weeds","identifier":"/us/usc/t16/s460zzz–4/g","parentIdentifier":"/us/usc/t16/s460zzz–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fg","sourceRelease":"119-100","text":"In accordance with any applicable laws and subject to such terms and conditions as the Secretary determines to be desirable and appropriate, the Secretary may prescribe measures to control nonnative invasive plants and noxious weeds within the Conservation Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Water rights","label":"h Water rights","identifier":"/us/usc/t16/s460zzz–4/h","parentIdentifier":"/us/usc/t16/s460zzz–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Effect","label":"1 Effect","identifier":"/us/usc/t16/s460zzz–4/h/1","parentIdentifier":"/us/usc/t16/s460zzz–4/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460zzz–4/h/1/A","parentIdentifier":"/us/usc/t16/s460zzz–4/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F1%2FA","sourceRelease":"119-100","text":"affects the use or allocation, in existence on , of any water, water right, or interest in water;March 30, 2009","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460zzz–4/h/1/B","parentIdentifier":"/us/usc/t16/s460zzz–4/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F1%2FB","sourceRelease":"119-100","text":"affects any vested absolute or decreed conditional water right in existence on , including any water right held by the United States;March 30, 2009","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s460zzz–4/h/1/C","parentIdentifier":"/us/usc/t16/s460zzz–4/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F1%2FC","sourceRelease":"119-100","text":"affects any interstate water compact in existence on ;March 30, 2009","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s460zzz–4/h/1/D","parentIdentifier":"/us/usc/t16/s460zzz–4/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F1%2FD","sourceRelease":"119-100","text":"authorizes or imposes any new reserved Federal water rights; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s460zzz–4/h/1/E","parentIdentifier":"/us/usc/t16/s460zzz–4/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F1%2FE","sourceRelease":"119-100","text":"shall be considered to be a relinquishment or reduction of any water rights reserved or appropriated by the United States in the State on or before .March 30, 2009","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Wilderness water rights","label":"2 Wilderness water rights","identifier":"/us/usc/t16/s460zzz–4/h/2","parentIdentifier":"/us/usc/t16/s460zzz–4/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s460zzz–4/h/2/A","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FA","sourceRelease":"119-100","text":"The Secretary shall ensure that any water rights within the Wilderness required to fulfill the purposes of the Wilderness are secured in accordance with subparagraphs (B) through (G).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"State law","label":"B State law","identifier":"/us/usc/t16/s460zzz–4/h/2/B","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"Procedural requirements","label":"i Procedural requirements","identifier":"/us/usc/t16/s460zzz–4/h/2/B/i","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FB%2Fi","sourceRelease":"119-100","text":"Any water rights within the Wilderness for which the Secretary pursues adjudication shall be adjudicated, changed, and administered in accordance with the procedural requirements and priority system of State law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Establishment of water rights","label":"ii Establishment of water rights","identifier":"/us/usc/t16/s460zzz–4/h/2/B/ii","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":"In general","label":"I In general","identifier":"/us/usc/t16/s460zzz–4/h/2/B/ii/I","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FB%2Fii%2FI","sourceRelease":"119-100","text":"Except as provided in subclause (II), the purposes and other substantive characteristics of the water rights pursued under this paragraph shall be established in accordance with State law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":"Exception","label":"II Exception","identifier":"/us/usc/t16/s460zzz–4/h/2/B/ii/II","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FB%2Fii%2FII","sourceRelease":"119-100","text":"Notwithstanding subclause (I) and in accordance with this subchapter, the Secretary may appropriate and seek adjudication of water rights to maintain surface water levels and stream flows on and across the Wilderness to fulfill the purposes of the Wilderness.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Deadline","label":"C Deadline","identifier":"/us/usc/t16/s460zzz–4/h/2/C","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FC","sourceRelease":"119-100","text":"The Secretary shall promptly, but not earlier than January 2009, appropriate the water rights required to fulfill the purposes of the Wilderness.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Required determination","label":"D Required determination","identifier":"/us/usc/t16/s460zzz–4/h/2/D","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FD","sourceRelease":"119-100","text":"The Secretary shall not pursue adjudication for any instream flow water rights unless the Secretary makes a determination pursuant to subparagraph (E)(ii) or (F).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":"Cooperative enforcement","label":"E Cooperative enforcement","identifier":"/us/usc/t16/s460zzz–4/h/2/E","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t16/s460zzz–4/h/2/E/i","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FE%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s460zzz–4/h/2/E/i/I","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2/E/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FE%2Fi%2FI","sourceRelease":"119-100","text":"the Secretary determines, upon adjudication of the water rights by the Colorado Water Conservation Board, that the Board holds water rights sufficient in priority, amount, and timing to fulfill the purposes of the Wilderness; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s460zzz–4/h/2/E/i/II","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2/E/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FE%2Fi%2FII","sourceRelease":"119-100","text":"the Secretary has entered into a perpetual agreement with the Colorado Water Conservation Board to ensure the full exercise, protection, and enforcement of the State water rights within the Wilderness to reliably fulfill the purposes of the Wilderness.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Adjudication","label":"ii Adjudication","identifier":"/us/usc/t16/s460zzz–4/h/2/E/ii","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FE%2Fii","sourceRelease":"119-100","text":"If the Secretary determines that the provisions of clause (i) have not been met, the Secretary shall adjudicate and exercise any Federal water rights required to fulfill the purposes of the Wilderness in accordance with this paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":"Insufficient water rights","label":"F Insufficient water rights","identifier":"/us/usc/t16/s460zzz–4/h/2/F","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FF","sourceRelease":"119-100","text":"If the Colorado Water Conservation Board modifies the instream flow water rights obtained under subparagraph (E) to such a degree that the Secretary determines that water rights held by the State are insufficient to fulfill the purposes of the Wilderness, the Secretary shall adjudicate and exercise Federal water rights required to fulfill the purposes of the Wilderness in accordance with subparagraph (B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":"Failure to comply","label":"G Failure to comply","identifier":"/us/usc/t16/s460zzz–4/h/2/G","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FG","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460zzz–4/h/2/G/i","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FG%2Fi","sourceRelease":"119-100","text":"the State is not exercising its water rights consistent with subparagraph (E)(i)(I); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460zzz–4/h/2/G/ii","parentIdentifier":"/us/usc/t16/s460zzz–4/h/2/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F2%2FG%2Fii","sourceRelease":"119-100","text":"the agreement described in subparagraph (E)(i)(II) is not fulfilled or complied with sufficiently to fulfill the purposes of the Wilderness.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Water resource facility","label":"3 Water resource facility","identifier":"/us/usc/t16/s460zzz–4/h/3","parentIdentifier":"/us/usc/t16/s460zzz–4/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s460zzz–4/h/3/A","parentIdentifier":"/us/usc/t16/s460zzz–4/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F3%2FA","sourceRelease":"119-100","text":"Notwithstanding any other provision of law and subject to subparagraph (B), beginning on , neither the President nor any other officer, employee, or agent of the United States shall fund, assist, authorize, or issue a license or permit for the development of any new irrigation and pumping facility, reservoir, water conservation work, aqueduct, canal, ditch, pipeline, well, hydropower project, transmission, other ancillary facility, or other water, diversion, storage, or carriage structure in the Wilderness.March 30, 2009","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exception","label":"B Exception","identifier":"/us/usc/t16/s460zzz–4/h/3/B","parentIdentifier":"/us/usc/t16/s460zzz–4/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460zzz–4/h/3/B/i","parentIdentifier":"/us/usc/t16/s460zzz–4/h/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F3%2FB%2Fi","sourceRelease":"119-100","text":"; andsection 1133(d)(4) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460zzz–4/h/3/B/ii","parentIdentifier":"/us/usc/t16/s460zzz–4/h/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F3%2FB%2Fii","sourceRelease":"119-100","text":"the guidelines set forth in Appendix A of the report of the Committee on Interior and Insular Affairs of the House of Representatives accompanying H.R. 2570 of the 101st Congress (H. Rept. 101–405).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Conservation area water rights","label":"4 Conservation area water rights","identifier":"/us/usc/t16/s460zzz–4/h/4","parentIdentifier":"/us/usc/t16/s460zzz–4/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460zzz–4/h/4/A","parentIdentifier":"/us/usc/t16/s460zzz–4/h/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F4%2FA","sourceRelease":"119-100","text":"authorizes any Federal agency to appropriate or otherwise acquire any water right on the mainstem of the Gunnison River; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460zzz–4/h/4/B","parentIdentifier":"/us/usc/t16/s460zzz–4/h/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F4%2FB","sourceRelease":"119-100","text":"prevents the State from appropriating or acquiring, or requires the State to appropriate or acquire, an instream flow water right on the mainstem of the Gunnison River.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Wilderness boundaries along Gunnison River","label":"5 Wilderness boundaries along Gunnison River","identifier":"/us/usc/t16/s460zzz–4/h/5","parentIdentifier":"/us/usc/t16/s460zzz–4/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s460zzz–4/h/5/A","parentIdentifier":"/us/usc/t16/s460zzz–4/h/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F5%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460zzz–4/h/5/A/i","parentIdentifier":"/us/usc/t16/s460zzz–4/h/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F5%2FA%2Fi","sourceRelease":"119-100","text":"be located at the edge of the river; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460zzz–4/h/5/A/ii","parentIdentifier":"/us/usc/t16/s460zzz–4/h/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F5%2FA%2Fii","sourceRelease":"119-100","text":"change according to the river level.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exclusion from Wilderness","label":"B Exclusion from Wilderness","identifier":"/us/usc/t16/s460zzz–4/h/5/B","parentIdentifier":"/us/usc/t16/s460zzz–4/h/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fh%2F5%2FB","sourceRelease":"119-100","text":"Regardless of the level of the Gunnison River, no portion of the Gunnison River is included in the Wilderness.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Effect","label":"i Effect","identifier":"/us/usc/t16/s460zzz–4/i","parentIdentifier":"/us/usc/t16/s460zzz–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460zzz–4/i/1","parentIdentifier":"/us/usc/t16/s460zzz–4/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fi%2F1","sourceRelease":"119-100","text":"diminishes the jurisdiction of the State with respect to fish and wildlife in the State; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460zzz–4/i/2","parentIdentifier":"/us/usc/t16/s460zzz–4/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fi%2F2","sourceRelease":"119-100","text":"imposes any Federal water quality standard upstream of the Conservation Area or within the mainstem of the Gunnison River that is more restrictive than would be applicable had the Conservation Area not been established.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"j","heading":"Valid existing rights","label":"j Valid existing rights","identifier":"/us/usc/t16/s460zzz–4/j","parentIdentifier":"/us/usc/t16/s460zzz–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%934%2Fj","sourceRelease":"119-100","text":"The designation of the Conservation Area and Wilderness is subject to valid rights in existence on .March 30, 2009","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
