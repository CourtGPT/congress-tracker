{"type":"section","nativeType":"section","number":"1477","heading":"Reasonable measures; considerations","label":"1477 Reasonable measures; considerations","identifier":"/us/usc/t33/s1477","parentIdentifier":"/us/usc/t33/ch28","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1477","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t33/s1477/a","parentIdentifier":"/us/usc/t33/s1477","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1477%2Fa","sourceRelease":"119-100","text":"Measures directed or conducted under this chapter shall be proportionate to the damage, actual or threatened, to the coastline or related interests of the United States and may not go beyond what is reasonably necessary to prevent, mitigate, or eliminate that damage.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t33/s1477/b","parentIdentifier":"/us/usc/t33/s1477","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1477%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1477/b/1","parentIdentifier":"/us/usc/t33/s1477/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1477%2Fb%2F1","sourceRelease":"119-100","text":"the extent and probability of imminent damage if those measures are not taken;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1477/b/2","parentIdentifier":"/us/usc/t33/s1477/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1477%2Fb%2F2","sourceRelease":"119-100","text":"the likelihood of effectiveness of those measures; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s1477/b/3","parentIdentifier":"/us/usc/t33/s1477/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1477%2Fb%2F3","sourceRelease":"119-100","text":"the extent of the damage which may be caused by those measures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
