{"type":"section","nativeType":"section","number":"3710","heading":"Reserve student pre-commissioning assistance program","label":"3710 Reserve student pre-commissioning assistance program","identifier":"/us/usc/t14/s3710","parentIdentifier":"/us/usc/t14/stIII/ch37/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2018— renumbered as this section.Pub. L. 115–282section 709a of this title"],"amendments":["Amendments2018— renumbered as this section.Pub. L. 115–282section 709a of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t14/s3710/a","parentIdentifier":"/us/usc/t14/s3710","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s3710/a/1","parentIdentifier":"/us/usc/t14/s3710/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fa%2F1","sourceRelease":"119-100","text":"a baccalaureate degree in not more than 5 academic years; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s3710/a/2","parentIdentifier":"/us/usc/t14/s3710/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fa%2F2","sourceRelease":"119-100","text":"a post-baccalaureate degree.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t14/s3710/b","parentIdentifier":"/us/usc/t14/s3710","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s3710/b/1","parentIdentifier":"/us/usc/t14/s3710/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t14/s3710/b/1/A","parentIdentifier":"/us/usc/t14/s3710/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fb%2F1%2FA","sourceRelease":"119-100","text":"be enrolled on a full-time basis in a program of education referred to in subsection (a) at any institution of higher education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t14/s3710/b/1/B","parentIdentifier":"/us/usc/t14/s3710/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fb%2F1%2FB","sourceRelease":"119-100","text":"enter into a written agreement with the Coast Guard described in paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s3710/b/2","parentIdentifier":"/us/usc/t14/s3710/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t14/s3710/b/2/A","parentIdentifier":"/us/usc/t14/s3710/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fb%2F2%2FA","sourceRelease":"119-100","text":"to accept an appointment as a commissioned officer in the Coast Guard Reserve, if tendered;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t14/s3710/b/2/B","parentIdentifier":"/us/usc/t14/s3710/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fb%2F2%2FB","sourceRelease":"119-100","text":"to serve on active duty for up to five years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t14/s3710/b/2/C","parentIdentifier":"/us/usc/t14/s3710/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fb%2F2%2FC","sourceRelease":"119-100","text":"under such terms and conditions as shall be prescribed by the Secretary, to serve in the Coast Guard Reserve until the eighth anniversary of the date of the appointment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t14/s3710/c","parentIdentifier":"/us/usc/t14/s3710","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s3710/c/1","parentIdentifier":"/us/usc/t14/s3710/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fc%2F1","sourceRelease":"119-100","text":"Tuition and fees charged by the institution of higher education involved.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s3710/c/2","parentIdentifier":"/us/usc/t14/s3710/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fc%2F2","sourceRelease":"119-100","text":"The cost of books.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t14/s3710/c/3","parentIdentifier":"/us/usc/t14/s3710/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fc%2F3","sourceRelease":"119-100","text":"In the case of a program of education leading to a baccalaureate degree, laboratory expenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t14/s3710/c/4","parentIdentifier":"/us/usc/t14/s3710/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fc%2F4","sourceRelease":"119-100","text":"Such other expenses as are deemed appropriate by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t14/s3710/d","parentIdentifier":"/us/usc/t14/s3710","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fd","sourceRelease":"119-100","text":"The amount of financial assistance provided to a member under this section shall be prescribed by the Secretary, but may not exceed $25,000 for any academic year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":null,"label":"e","identifier":"/us/usc/t14/s3710/e","parentIdentifier":"/us/usc/t14/s3710","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fe","sourceRelease":"119-100","text":"Financial assistance may be provided to a member under this section for up to 5 consecutive academic years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":null,"label":"f","identifier":"/us/usc/t14/s3710/f","parentIdentifier":"/us/usc/t14/s3710","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s3710/f/1","parentIdentifier":"/us/usc/t14/s3710/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Ff%2F1","sourceRelease":"119-100","text":"completes the academic requirements of the program and refuses to accept an appointment as a commissioned officer in the Coast Guard Reserve when offered;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s3710/f/2","parentIdentifier":"/us/usc/t14/s3710/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Ff%2F2","sourceRelease":"119-100","text":"fails to complete the academic requirements of the institution of higher education involved; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t14/s3710/f/3","parentIdentifier":"/us/usc/t14/s3710/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Ff%2F3","sourceRelease":"119-100","text":"fails to maintain eligibility for an original appointment as a commissioned officer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":null,"label":"g","identifier":"/us/usc/t14/s3710/g","parentIdentifier":"/us/usc/t14/s3710","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s3710/g/1","parentIdentifier":"/us/usc/t14/s3710/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fg%2F1","sourceRelease":"119-100","text":"If a member requests to be released from the program and the request is accepted by the Secretary, or if the member fails because of misconduct to complete the period of active duty specified, or if the member fails to fulfill any term or condition of the written agreement required to be eligible for financial assistance under this section, the financial assistance shall be terminated. The Secretary may request the member to reimburse the United States in an amount that bears the same ratio to the total costs of the education provided to that member as the unserved portion of active duty bears to the total period of active duty the member agreed to serve. The Secretary shall have the option to order such reimbursement without first ordering the member to active duty. An obligation to reimburse the United States imposed under this paragraph is a debt owed to the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s3710/g/2","parentIdentifier":"/us/usc/t14/s3710/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fg%2F2","sourceRelease":"119-100","text":"The Secretary may waive the service obligated under subsection (f) of a member who becomes unqualified to serve on active duty due to a circumstance not within the control of that member or who is not physically qualified for appointment and who is determined to be unqualified for service as an enlisted member of the Coast Guard Reserve due to a physical or medical condition that was not the result of the member’s own misconduct or grossly negligent conduct.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t14/s3710/g/3","parentIdentifier":"/us/usc/t14/s3710/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fg%2F3","sourceRelease":"119-100","text":"A discharge in bankruptcy under title 11 that is entered less than 5 years after the termination of a written agreement entered into under subsection (b) does not discharge the individual signing the agreement from a debt arising under such agreement or under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":null,"label":"h","identifier":"/us/usc/t14/s3710/h","parentIdentifier":"/us/usc/t14/s3710","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs3710%2Fh","sourceRelease":"119-100","text":"As used in this section, the term “institution of higher education” has the meaning given that term in section 101 of the Higher Education Act of 1965 ().20 U.S.C. 1001","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
