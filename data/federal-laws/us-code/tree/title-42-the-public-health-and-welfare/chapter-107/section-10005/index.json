{"type":"section","nativeType":"section","number":"10005","heading":"Model statute","label":"10005 Model statute","identifier":"/us/usc/t42/s10005","parentIdentifier":"/us/usc/t42/ch107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10005","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s10005/1","parentIdentifier":"/us/usc/t42/s10005","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10005%2F1","sourceRelease":"119-100","text":"it shall be unlawful in a State for individuals to perform radiologic procedures unless such individuals are certified by the State to perform such procedures; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s10005/2","parentIdentifier":"/us/usc/t42/s10005","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10005%2F2","sourceRelease":"119-100","text":"any educational requirements for certification of individuals to perform radiologic procedures shall be limited to educational programs accredited by the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
