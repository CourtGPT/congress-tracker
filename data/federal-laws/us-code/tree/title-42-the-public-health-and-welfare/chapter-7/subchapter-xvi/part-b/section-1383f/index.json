{"type":"section","nativeType":"section","number":"1383f","heading":"Annual report on program","label":"1383f Annual report on program","identifier":"/us/usc/t42/s1383f","parentIdentifier":"/us/usc/t42/ch7/schXVI/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s1383f/a","parentIdentifier":"/us/usc/t42/s1383f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s1383f/a/1","parentIdentifier":"/us/usc/t42/s1383f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fa%2F1","sourceRelease":"119-100","text":"a comprehensive description of the program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s1383f/a/2","parentIdentifier":"/us/usc/t42/s1383f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fa%2F2","sourceRelease":"119-100","text":"historical and current data on allowances and denials, including number of applications and allowance rates for initial determinations, reconsideration determinations, administrative law judge hearings, appeals council reviews, and Federal court decisions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s1383f/a/3","parentIdentifier":"/us/usc/t42/s1383f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fa%2F3","sourceRelease":"119-100","text":"historical and current data on characteristics of recipients and program costs, by recipient group (aged, blind, disabled adults, and disabled children);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s1383f/a/4","parentIdentifier":"/us/usc/t42/s1383f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fa%2F4","sourceRelease":"119-100","text":"historical and current data on prior enrollment by recipients in public benefit programs, including State programs funded under part A of subchapter IV of this chapter and State general assistance programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s1383f/a/5","parentIdentifier":"/us/usc/t42/s1383f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fa%2F5","sourceRelease":"119-100","text":"projections of future number of recipients and program costs, through at least 25 years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s1383f/a/6","parentIdentifier":"/us/usc/t42/s1383f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fa%2F6","sourceRelease":"119-100","text":"number of redeterminations and continuing disability reviews, and the outcomes of such redeterminations and reviews;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s1383f/a/7","parentIdentifier":"/us/usc/t42/s1383f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fa%2F7","sourceRelease":"119-100","text":"data on the utilization of work incentives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s1383f/a/8","parentIdentifier":"/us/usc/t42/s1383f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fa%2F8","sourceRelease":"119-100","text":"detailed information on administrative and other program operation costs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t42/s1383f/a/9","parentIdentifier":"/us/usc/t42/s1383f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fa%2F9","sourceRelease":"119-100","text":"summaries of relevant research undertaken by the Social Security Administration, or by other researchers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t42/s1383f/a/10","parentIdentifier":"/us/usc/t42/s1383f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fa%2F10","sourceRelease":"119-100","text":"State supplementation program operations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t42/s1383f/a/11","parentIdentifier":"/us/usc/t42/s1383f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fa%2F11","sourceRelease":"119-100","text":"a historical summary of statutory changes to this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t42/s1383f/a/12","parentIdentifier":"/us/usc/t42/s1383f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fa%2F12","sourceRelease":"119-100","text":"such other information as the Commissioner deems useful.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Views of individual members of Social Security Advisory Board","label":"b Views of individual members of Social Security Advisory Board","identifier":"/us/usc/t42/s1383f/b","parentIdentifier":"/us/usc/t42/s1383f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1383f%2Fb","sourceRelease":"119-100","text":"Each member of the Social Security Advisory Board shall be permitted to provide an individual report, or a joint report if agreed, of views of the program under this subchapter, to be included in the annual report required under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
