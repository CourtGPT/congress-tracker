{"type":"section","nativeType":"section","number":"19341","heading":"Applied laboratories infrastructure restoration and modernization","label":"19341 Applied laboratories infrastructure restoration and modernization","identifier":"/us/usc/t42/s19341","parentIdentifier":"/us/usc/t42/ch163/schVI/ptJ","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definition of National Laboratory.","label":"a Definition of National Laboratory.","identifier":"/us/usc/t42/s19341/a","parentIdentifier":"/us/usc/t42/s19341","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19341/a/1","parentIdentifier":"/us/usc/t42/s19341/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fa%2F1","sourceRelease":"119-100","text":"the National Renewable Energy Laboratory;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19341/a/2","parentIdentifier":"/us/usc/t42/s19341/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fa%2F2","sourceRelease":"119-100","text":"the National Energy Technology Laboratory;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19341/a/3","parentIdentifier":"/us/usc/t42/s19341/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fa%2F3","sourceRelease":"119-100","text":"the Idaho National Laboratory;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s19341/a/4","parentIdentifier":"/us/usc/t42/s19341/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fa%2F4","sourceRelease":"119-100","text":"the Savannah River National Laboratory;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s19341/a/5","parentIdentifier":"/us/usc/t42/s19341/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fa%2F5","sourceRelease":"119-100","text":"the Sandia National Laboratories;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s19341/a/6","parentIdentifier":"/us/usc/t42/s19341/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fa%2F6","sourceRelease":"119-100","text":"the Los Alamos National Laboratory; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s19341/a/7","parentIdentifier":"/us/usc/t42/s19341/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fa%2F7","sourceRelease":"119-100","text":"the Lawrence Livermore National Laboratory.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Restoration and modernization projects","label":"b Restoration and modernization projects","identifier":"/us/usc/t42/s19341/b","parentIdentifier":"/us/usc/t42/s19341","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s19341/b/1","parentIdentifier":"/us/usc/t42/s19341/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall fund projects described in paragraph (2) as needed to address the deferred maintenance, critical infrastructure needs, and modernization of National Laboratories.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Projects described","label":"2 Projects described","identifier":"/us/usc/t42/s19341/b/2","parentIdentifier":"/us/usc/t42/s19341/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19341/b/2/A","parentIdentifier":"/us/usc/t42/s19341/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb%2F2%2FA","sourceRelease":"119-100","text":"priority deferred maintenance projects at National Laboratories, including facilities sustainment for, upgrade of, and construction of research laboratories, administrative and support buildings, utilities, roads, power plants, and any other critical infrastructure; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19341/b/2/B","parentIdentifier":"/us/usc/t42/s19341/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s19341/b/2/B/i","parentIdentifier":"/us/usc/t42/s19341/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"to support existing and emerging science missions with new and specialized requirements for world-leading scientific user facilities and computing capabilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s19341/b/2/B/ii","parentIdentifier":"/us/usc/t42/s19341/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"to maintain safe, efficient, reliable, and environmentally responsible operations, including pilot projects to demonstrate net-zero emissions with resilient operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Approach","label":"3 Approach","identifier":"/us/usc/t42/s19341/b/3","parentIdentifier":"/us/usc/t42/s19341/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19341/b/3/A","parentIdentifier":"/us/usc/t42/s19341/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb%2F3%2FA","sourceRelease":"119-100","text":"capital line items;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19341/b/3/B","parentIdentifier":"/us/usc/t42/s19341/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb%2F3%2FB","sourceRelease":"119-100","text":"minor construction projects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s19341/b/3/C","parentIdentifier":"/us/usc/t42/s19341/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb%2F3%2FC","sourceRelease":"119-100","text":"energy savings performance contracts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s19341/b/3/D","parentIdentifier":"/us/usc/t42/s19341/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb%2F3%2FD","sourceRelease":"119-100","text":"utility energy service contracts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s19341/b/3/E","parentIdentifier":"/us/usc/t42/s19341/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb%2F3%2FE","sourceRelease":"119-100","text":"alternative financing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s19341/b/3/F","parentIdentifier":"/us/usc/t42/s19341/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fb%2F3%2FF","sourceRelease":"119-100","text":"expense funding.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Submission to Congress","label":"c Submission to Congress","identifier":"/us/usc/t42/s19341/c","parentIdentifier":"/us/usc/t42/s19341","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fc","sourceRelease":"119-100","text":"For each fiscal year through fiscal year 2027, at the same time as the annual budget submission of the President, the Secretary shall submit to the Committee on Appropriations and the Committee on Energy and Natural Resources of the Senate and the Committee on Appropriations and the Committee on Science, Space, and Technology of the House of Representatives a list of projects for which the Secretary will provide funding under this section, including a description of each project and the funding profile for the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s19341/d","parentIdentifier":"/us/usc/t42/s19341","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19341/d/1","parentIdentifier":"/us/usc/t42/s19341/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fd%2F1","sourceRelease":"119-100","text":"$640,000,000 is authorized to be appropriated for projects at National Laboratories described in paragraphs (1) through (4) of subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19341/d/2","parentIdentifier":"/us/usc/t42/s19341/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19341%2Fd%2F2","sourceRelease":"119-100","text":"$160,000,000 is authorized to be appropriated for projects at National Laboratories described in paragraphs (5) through (7) of that subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
