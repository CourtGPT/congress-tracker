uld be reasonably expected to be introduced into commerce in the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s360bbb–7/a/3/B/ii","parentIdentifier":"/us/usc/t21/s360bbb–7/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%937%2Fa%2F3%2FB%2Fii","sourceRelease":"119-100","text":"such drug has been or is being imported into the United States or may reasonably be expected to be offered for import into the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Manner of notification","label":"b Manner of notification","identifier":"/us/usc/t21/s360bbb–7/b","parentIdentifier":"/us/usc/t21/s360bbb–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%937%2Fb","sourceRelease":"119-100","text":"Notification under this section shall be made in such manner and by such means as the Secretary may specify by regulation or guidance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Savings clause","label":"c Savings clause","identifier":"/us/usc/t21/s360bbb–7/c","parentIdentifier":"/us/usc/t21/s360bbb–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%937%2Fc","sourceRelease":"119-100","text":"Nothing in this section shall be construed as limiting any other authority of the Secretary to require notifications related to a drug under any other provision of this chapter or the Public Health Service Act [ et seq.].42 U.S.C. 201","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definition","label":"d Definition","identifier":"/us/usc/t21/s360bbb–7/d","parentIdentifier":"/us/usc/t21/s360bbb–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%937%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s360bbb–7/d/1","parentIdentifier":"/us/usc/t21/s360bbb–7/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%937%2Fd%2F1","sourceRelease":"119-100","text":"a person who is required to register under section 360 or 381(s) of this title;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s360bbb–7/d/2","parentIdentifier":"/us/usc/t21/s360bbb–7/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%937%2Fd%2F2","sourceRelease":"119-100","text":"a wholesale distributor of a drug product; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t21/s360bbb–7/d/3","parentIdentifier":"/us/usc/t21/s360bbb–7/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%937%2Fd%2F3","sourceRelease":"119-100","text":"any other person that distributes drugs except a person that distributes drugs exclusively for retail sale.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
