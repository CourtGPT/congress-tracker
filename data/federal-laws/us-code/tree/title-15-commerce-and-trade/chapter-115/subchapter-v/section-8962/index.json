{"type":"section","nativeType":"section","number":"8962","heading":"PFAS research and development","label":"8962 PFAS research and development","identifier":"/us/usc/t15/s8962","parentIdentifier":"/us/usc/t15/ch115/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8962","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s8962/a","parentIdentifier":"/us/usc/t15/s8962","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8962%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8962/a/1","parentIdentifier":"/us/usc/t15/s8962/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8962%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8962/a/1/A","parentIdentifier":"/us/usc/t15/s8962/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8962%2Fa%2F1%2FA","sourceRelease":"119-100","text":"further examine the effects of perfluoroalkyl and polyfluoroalkyl substances on human health and the environment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8962/a/1/B","parentIdentifier":"/us/usc/t15/s8962/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8962%2Fa%2F1%2FB","sourceRelease":"119-100","text":"make publicly available information relating to the findings under subparagraph (A);","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8962/a/2","parentIdentifier":"/us/usc/t15/s8962/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8962%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8962/a/2/A","parentIdentifier":"/us/usc/t15/s8962/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8962%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the potential for human exposure to the substances or classes of substances;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8962/a/2/B","parentIdentifier":"/us/usc/t15/s8962/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8962%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the potential toxicity of the substances or classes of substances; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s8962/a/2/C","parentIdentifier":"/us/usc/t15/s8962/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8962%2Fa%2F2%2FC","sourceRelease":"119-100","text":"information available about the substances or classes of substances;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8962/a/3","parentIdentifier":"/us/usc/t15/s8962/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8962%2Fa%2F3","sourceRelease":"119-100","text":"develop new tools to characterize and identify perfluoroalkyl and polyfluoroalkyl substances in the environment, including in drinking water, wastewater, surface water, groundwater, solids, and the air;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s8962/a/4","parentIdentifier":"/us/usc/t15/s8962/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8962%2Fa%2F4","sourceRelease":"119-100","text":"evaluate approaches for the remediation of contamination by perfluoroalkyl and polyfluoroalkyl substances in the environment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s8962/a/5","parentIdentifier":"/us/usc/t15/s8962/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8962%2Fa%2F5","sourceRelease":"119-100","text":"develop and implement new tools and materials to communicate with the public about perfluoroalkyl and polyfluoroalkyl substances.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Funding","label":"b Funding","identifier":"/us/usc/t15/s8962/b","parentIdentifier":"/us/usc/t15/s8962","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8962%2Fb","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Administrator to carry out this section $15,000,000 for each of fiscal years 2020 through 2024.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
