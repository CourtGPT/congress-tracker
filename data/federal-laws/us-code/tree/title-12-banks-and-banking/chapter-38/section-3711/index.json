ouse.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3711%2F4","sourceRelease":"119-100","text":"necessary out-of-pocket costs incurred by the foreclosure commissioner to record documents; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t12/s3711/5","parentIdentifier":"/us/usc/t12/s3711","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3711%2F5","sourceRelease":"119-100","text":"a commission for the foreclosure commissioner for the conduct of the foreclosure to the extent authorized by regulations issued by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
