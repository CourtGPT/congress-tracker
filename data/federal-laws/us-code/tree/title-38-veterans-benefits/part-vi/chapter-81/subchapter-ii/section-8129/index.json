{"type":"section","nativeType":"section","number":"8129","heading":"Preference for offerors employing veterans","label":"8129 Preference for offerors employing veterans","identifier":"/us/usc/t38/s8129","parentIdentifier":"/us/usc/t38/ptVI/ch81/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8129","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Preference","label":"a .—Preference","identifier":"/us/usc/t38/s8129/a","parentIdentifier":"/us/usc/t38/s8129","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8129%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s8129/a/1","parentIdentifier":"/us/usc/t38/s8129/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8129%2Fa%2F1","sourceRelease":"119-100","text":"In awarding a contract for the procurement of goods or services, the Secretary may give a preference to offerors that employ veterans on a full-time basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s8129/a/2","parentIdentifier":"/us/usc/t38/s8129/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8129%2Fa%2F2","sourceRelease":"119-100","text":"The Secretary shall determine such preference based on the percentage of the full-time employees of the offeror who are veterans.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Enforcement Penalties for Misrepresentation","label":"b .—Enforcement Penalties for Misrepresentation","identifier":"/us/usc/t38/s8129/b","parentIdentifier":"/us/usc/t38/s8129","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8129%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s8129/b/1","parentIdentifier":"/us/usc/t38/s8129/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8129%2Fb%2F1","sourceRelease":"119-100","text":"Any offeror that is determined by the Secretary to have willfully and intentionally misrepresented the veteran status of the employees of the offeror for purposes of subsection (a) may be debarred from contracting with the Department for a period of not less than five years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s8129/b/2","parentIdentifier":"/us/usc/t38/s8129/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8129%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s8129/b/2/A","parentIdentifier":"/us/usc/t38/s8129/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8129%2Fb%2F2%2FA","sourceRelease":"119-100","text":"commence debarment action against the offeror by not later than 30 days after determining that the offeror willfully and intentionally misrepresented the veteran status of the employees of the offeror as described in paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s8129/b/2/B","parentIdentifier":"/us/usc/t38/s8129/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8129%2Fb%2F2%2FB","sourceRelease":"119-100","text":"complete debarment actions against such offeror by not later than 90 days after such determination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s8129/b/3","parentIdentifier":"/us/usc/t38/s8129/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8129%2Fb%2F3","sourceRelease":"119-100","text":"The debarment of an offeror under paragraph (1) includes the debarment of all principals in the offeror for a period of not less than five years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
