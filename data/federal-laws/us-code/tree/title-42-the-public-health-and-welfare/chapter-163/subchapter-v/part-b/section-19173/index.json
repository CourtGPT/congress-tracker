{"type":"section","nativeType":"section","number":"19173","heading":"Opportunities for online education","label":"19173 Opportunities for online education","identifier":"/us/usc/t42/s19173","parentIdentifier":"/us/usc/t42/ch163/schV/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s19173/a","parentIdentifier":"/us/usc/t42/s19173","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fa","sourceRelease":"119-100","text":"The Director shall make competitive awards to institutions of higher education or nonprofit organizations (or a consortium thereof, which may include a private sector partner) to conduct research on online STEM education courses for rural communities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Research areas","label":"b Research areas","identifier":"/us/usc/t42/s19173/b","parentIdentifier":"/us/usc/t42/s19173","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19173/b/1","parentIdentifier":"/us/usc/t42/s19173/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fb%2F1","sourceRelease":"119-100","text":"evaluating the learning and achievement of rural students in prekindergarten through grade 12 in STEM subjects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19173/b/2","parentIdentifier":"/us/usc/t42/s19173/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fb%2F2","sourceRelease":"119-100","text":"understanding how computer-based and online professional development courses and mentor experiences can be integrated to meet the needs of educators, principals, and other school leaders of rural students in prekindergarten through grade 12;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19173/b/3","parentIdentifier":"/us/usc/t42/s19173/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fb%2F3","sourceRelease":"119-100","text":"combining computer-based and online STEM education and training with mentoring and other applied learning arrangements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s19173/b/4","parentIdentifier":"/us/usc/t42/s19173/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fb%2F4","sourceRelease":"119-100","text":"leveraging online programs to supplement STEM studies for rural students that need physical and academic accommodation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s19173/b/5","parentIdentifier":"/us/usc/t42/s19173/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fb%2F5","sourceRelease":"119-100","text":"any other activity the Director determines will accomplish the goals of this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Evaluations","label":"c Evaluations","identifier":"/us/usc/t42/s19173/c","parentIdentifier":"/us/usc/t42/s19173","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fc","sourceRelease":"119-100","text":"All proposals for awards under this section shall include an evaluation plan that includes the use of outcome-oriented measures to assess the impact and efficacy of the award. Each recipient of an award under this subsection shall include results from these evaluative activities in annual and final projects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Accountability and dissemination","label":"d Accountability and dissemination","identifier":"/us/usc/t42/s19173/d","parentIdentifier":"/us/usc/t42/s19173","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Evaluation required","label":"1 Evaluation required","identifier":"/us/usc/t42/s19173/d/1","parentIdentifier":"/us/usc/t42/s19173/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19173/d/1/A","parentIdentifier":"/us/usc/t42/s19173/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fd%2F1%2FA","sourceRelease":"119-100","text":"use a common set of benchmarks and tools to assess the results of research conducted under such awards and identify best practices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19173/d/1/B","parentIdentifier":"/us/usc/t42/s19173/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fd%2F1%2FB","sourceRelease":"119-100","text":"to the extent practicable, integrate findings from activities carried out pursuant to research conducted under this section, with respect to the pursuit of careers and degrees in STEM, with those activities carried out pursuant to other research on serving rural students and communities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report on evaluations","label":"2 Report on evaluations","identifier":"/us/usc/t42/s19173/d/2","parentIdentifier":"/us/usc/t42/s19173/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19173/d/2/A","parentIdentifier":"/us/usc/t42/s19173/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fd%2F2%2FA","sourceRelease":"119-100","text":"the results of the evaluation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19173/d/2/B","parentIdentifier":"/us/usc/t42/s19173/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fd%2F2%2FB","sourceRelease":"119-100","text":"any recommendations for administrative and legislative action that could optimize the effectiveness of the awards made under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Coordination","label":"e Coordination","identifier":"/us/usc/t42/s19173/e","parentIdentifier":"/us/usc/t42/s19173","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19173%2Fe","sourceRelease":"119-100","text":"In carrying out this section, the Director shall, for purposes of enhancing program effectiveness and avoiding duplication of activities, consult, cooperate, and coordinate with the programs and policies of other relevant Federal agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
