us/usc/t25/s1665n/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1665n%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the effects of loss of cultural identity and the development of scientific data on those effects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s1665n/a/2","parentIdentifier":"/us/usc/t25/s1665n/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1665n%2Fa%2F2","sourceRelease":"119-100","text":"the interrelationship and interdependence of behavioral health problems with alcoholism and other substance abuse, suicide, homicides, other injuries, and the incidence of family violence; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s1665n/a/3","parentIdentifier":"/us/usc/t25/s1665n/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1665n%2Fa%2F3","sourceRelease":"119-100","text":"the development of models of prevention techniques.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Emphasis","label":"b Emphasis","identifier":"/us/usc/t25/s1665n/b","parentIdentifier":"/us/usc/t25/s1665n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1665n%2Fb","sourceRelease":"119-100","text":"The effect of the interrelationships and interdependencies referred to in subsection (a)(2) on children, and the development of prevention techniques under subsection (a)(3) applicable to children, shall be emphasized.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
