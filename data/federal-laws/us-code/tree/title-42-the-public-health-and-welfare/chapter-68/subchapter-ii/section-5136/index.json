sc%2Ft42%2Fs5136%2Fd%2F1%2FB","sourceRelease":"119-100","text":"subject to paragraph (3), in each State, not less than 1 percent of census tracts that are assigned high individual risk ratings.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Risk ratings","label":"2 Risk ratings","identifier":"/us/usc/t42/s5136/d/2","parentIdentifier":"/us/usc/t42/s5136/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s5136/d/2/A","parentIdentifier":"/us/usc/t42/s5136/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s5136/d/2/A/i","parentIdentifier":"/us/usc/t42/s5136/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s5136/d/2/A/i/I","parentIdentifier":"/us/usc/t42/s5136/d/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fd%2F2%2FA%2Fi%2FI","sourceRelease":"119-100","text":"loss to population equivalence;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s5136/d/2/A/i/II","parentIdentifier":"/us/usc/t42/s5136/d/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fd%2F2%2FA%2Fi%2FII","sourceRelease":"119-100","text":"building value; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t42/s5136/d/2/A/i/III","parentIdentifier":"/us/usc/t42/s5136/d/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fd%2F2%2FA%2Fi%2FIII","sourceRelease":"119-100","text":"agriculture value;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s5136/d/2/A/ii","parentIdentifier":"/us/usc/t42/s5136/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":"high social vulnerability ratings and low community resilience ratings; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s5136/d/2/A/iii","parentIdentifier":"/us/usc/t42/s5136/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fd%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"any other elements determined by the President; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s5136/d/2/B","parentIdentifier":"/us/usc/t42/s5136/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fd%2F2%2FB","sourceRelease":"119-100","text":"reflect the principal natural hazard risks identified for the respective census tracts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Geographic balance","label":"3 Geographic balance","identifier":"/us/usc/t42/s5136/d/3","parentIdentifier":"/us/usc/t42/s5136/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s5136/d/3/A","parentIdentifier":"/us/usc/t42/s5136/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fd%2F3%2FA","sourceRelease":"119-100","text":"for the purpose of achieving geographic balance, when applicable, the President shall consider making designations in coastal, inland, urban, suburban, and rural areas; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s5136/d/3/B","parentIdentifier":"/us/usc/t42/s5136/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fd%2F3%2FB","sourceRelease":"119-100","text":"the President shall include census tracts on Tribal lands located within a State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Duration","label":"4 Duration","identifier":"/us/usc/t42/s5136/d/4","parentIdentifier":"/us/usc/t42/s5136/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fd%2F4","sourceRelease":"119-100","text":"The designation of a community disaster resilience zone under paragraph (1) shall be effective for a period of not less than 5 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Review and update","label":"e Review and update","identifier":"/us/usc/t42/s5136/e","parentIdentifier":"/us/usc/t42/s5136","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s5136/e/1","parentIdentifier":"/us/usc/t42/s5136/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s5136/e/1/A","parentIdentifier":"/us/usc/t42/s5136/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F1%2FA","sourceRelease":"119-100","text":"review the underlying methodology of the product; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s5136/e/1/B","parentIdentifier":"/us/usc/t42/s5136/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F1%2FB","sourceRelease":"119-100","text":"receive public input on the methodology and data used for the product;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s5136/e/2","parentIdentifier":"/us/usc/t42/s5136/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s5136/e/2/A","parentIdentifier":"/us/usc/t42/s5136/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F2%2FA","sourceRelease":"119-100","text":"the most recent census tract data;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s5136/e/2/B","parentIdentifier":"/us/usc/t42/s5136/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F2%2FB","sourceRelease":"119-100","text":"data from the American Community Survey of the Bureau of the Census, a successor survey, a similar survey, or another data source, including data by census tract on housing characteristics and income;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s5136/e/2/C","parentIdentifier":"/us/usc/t42/s5136/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F2%2FC","sourceRelease":"119-100","text":"information relating to development, improvements, and hazard mitigation measures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s5136/e/2/D","parentIdentifier":"/us/usc/t42/s5136/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F2%2FD","sourceRelease":"119-100","text":"data that assesses past and future loss exposure, including analysis on the effects of a changing climate on future loss exposure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s5136/e/2/E","parentIdentifier":"/us/usc/t42/s5136/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F2%2FE","sourceRelease":"119-100","text":"data from the Resilience Analysis and Planning Tool of the Federal Emergency Management Agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s5136/e/2/F","parentIdentifier":"/us/usc/t42/s5136/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F2%2FF","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s5136/e/2/F/i","parentIdentifier":"/us/usc/t42/s5136/e/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F2%2FF%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s5136/e/2/F/i/I","parentIdentifier":"/us/usc/t42/s5136/e/2/F/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F2%2FF%2Fi%2FI","sourceRelease":"119-100","text":"natural hazard loss exposure, including population equivalence, buildings, infrastructure, and agriculture; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s5136/e/2/F/i/II","parentIdentifier":"/us/usc/t42/s5136/e/2/F/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F2%2FF%2Fi%2FII","sourceRelease":"119-100","text":"social vulnerability; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s5136/e/2/F/ii","parentIdentifier":"/us/usc/t42/s5136/e/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F2%2FF%2Fii","sourceRelease":"119-100","text":"low levels of community resilience;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s5136/e/3","parentIdentifier":"/us/usc/t42/s5136/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F3","sourceRelease":"119-100","text":"make publicly available any changes in methodology or data used to inform an update to a product maintained under subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s5136/e/4","parentIdentifier":"/us/usc/t42/s5136/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fe%2F4","sourceRelease":"119-100","text":"update and enhance the products maintained under subsection (b), as necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Natural hazard risk assessment insights","label":"f Natural hazard risk assessment insights","identifier":"/us/usc/t42/s5136/f","parentIdentifier":"/us/usc/t42/s5136","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s5136/f/1","parentIdentifier":"/us/usc/t42/s5136/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Ff%2F1","sourceRelease":"119-100","text":"the Administrator of the Federal Emergency Management Agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s5136/f/2","parentIdentifier":"/us/usc/t42/s5136/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Ff%2F2","sourceRelease":"119-100","text":"the Secretary of Agriculture and the Chief of the Forest Service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s5136/f/3","parentIdentifier":"/us/usc/t42/s5136/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Ff%2F3","sourceRelease":"119-100","text":"the Secretary of Commerce, the Administrator of the National Oceanic and Atmospheric Administration, the Director of the Bureau of the Census, and the Director of the National Institute of Standards and Technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s5136/f/4","parentIdentifier":"/us/usc/t42/s5136/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Ff%2F4","sourceRelease":"119-100","text":"the Secretary of Defense and the Commanding Officer of the United States Army Corps of Engineers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s5136/f/5","parentIdentifier":"/us/usc/t42/s5136/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Ff%2F5","sourceRelease":"119-100","text":"the Administrator of the Environmental Protection Agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s5136/f/6","parentIdentifier":"/us/usc/t42/s5136/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Ff%2F6","sourceRelease":"119-100","text":"the Secretary of the Interior and the Director of the United States Geological Survey;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s5136/f/7","parentIdentifier":"/us/usc/t42/s5136/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Ff%2F7","sourceRelease":"119-100","text":"the Secretary of Housing and Urban Development; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s5136/f/8","parentIdentifier":"/us/usc/t42/s5136/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Ff%2F8","sourceRelease":"119-100","text":"the Director of the Federal Housing Finance Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Community disaster resilience zone","label":"g Community disaster resilience zone","identifier":"/us/usc/t42/s5136/g","parentIdentifier":"/us/usc/t42/s5136","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fg","sourceRelease":"119-100","text":"With respect to financial assistance provided under to perform a resilience or mitigation project within, or that primarily benefits, a community disaster resilience zone, the President may increase the amount of the Federal share described under to not more than 90 percent of the total cost of the resilience or mitigation project.section 5133(i) of this titlesection 5133(h) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Resilience or mitigation project planning assistance","label":"h Resilience or mitigation project planning assistance","identifier":"/us/usc/t42/s5136/h","parentIdentifier":"/us/usc/t42/s5136","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s5136/h/1","parentIdentifier":"/us/usc/t42/s5136/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fh%2F1","sourceRelease":"119-100","text":"The President may provide financial, technical, or other assistance under this subchapter to an eligible entity that plans to perform a resilience or mitigation project within, or that primarily benefits, a community disaster resilience zone.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Purpose","label":"2 Purpose","identifier":"/us/usc/t42/s5136/h/2","parentIdentifier":"/us/usc/t42/s5136/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fh%2F2","sourceRelease":"119-100","text":"The purpose of assistance provided under paragraph (1) shall be to carry out activities in preparation for a resilience or mitigation project or seek an evaluation and certification under subsection (i)(2) for a resilience or mitigation project before the date on which permanent work of the resilience or mitigation project begins.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Application","label":"3 Application","identifier":"/us/usc/t42/s5136/h/3","parentIdentifier":"/us/usc/t42/s5136/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fh%2F3","sourceRelease":"119-100","text":"If required by the President, an eligible entity seeking assistance under paragraph (1) shall submit an application in accordance with subsection (i)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Funding","label":"4 Funding","identifier":"/us/usc/t42/s5136/h/4","parentIdentifier":"/us/usc/t42/s5136/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fh%2F4","sourceRelease":"119-100","text":"In providing assistance under paragraph (1), the President may use amounts set aside under .section 5133(i) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Community disaster resilience zone project applications","label":"i Community disaster resilience zone project applications","identifier":"/us/usc/t42/s5136/i","parentIdentifier":"/us/usc/t42/s5136","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s5136/i/1","parentIdentifier":"/us/usc/t42/s5136/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F1","sourceRelease":"119-100","text":"If required by the President or other Federal law, an eligible entity shall submit to the President an application at such time, in such manner, and containing or accompanied by such information as the President may reasonably require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Evaluation and certification","label":"2 Evaluation and certification","identifier":"/us/usc/t42/s5136/i/2","parentIdentifier":"/us/usc/t42/s5136/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s5136/i/2/A","parentIdentifier":"/us/usc/t42/s5136/i/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s5136/i/2/A/i","parentIdentifier":"/us/usc/t42/s5136/i/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F2%2FA%2Fi","sourceRelease":"119-100","text":"is designed to reduce injuries, loss of life, and damage and destruction of property, such as damage to critical services and facilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s5136/i/2/A/ii","parentIdentifier":"/us/usc/t42/s5136/i/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F2%2FA%2Fii","sourceRelease":"119-100","text":"substantially reduces the risk of, or increases resilience to, future damage, hardship, loss, or suffering.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Certification","label":"B Certification","identifier":"/us/usc/t42/s5136/i/2/B","parentIdentifier":"/us/usc/t42/s5136/i/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F2%2FB","sourceRelease":"119-100","text":"If the President determines that an application submitted under paragraph (1) meets the criteria described in subparagraph (A), the President shall certify the proposed resilience or mitigation project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Effect of certification","label":"C Effect of certification","identifier":"/us/usc/t42/s5136/i/2/C","parentIdentifier":"/us/usc/t42/s5136/i/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F2%2FC","sourceRelease":"119-100","text":"The certification of a proposed resilience or mitigation project under subparagraph (B) shall not be construed to exempt the resilience or mitigation project from the requirements of any other law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Projects causing displacement","label":"3 Projects causing displacement","identifier":"/us/usc/t42/s5136/i/3","parentIdentifier":"/us/usc/t42/s5136/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s5136/i/3/A","parentIdentifier":"/us/usc/t42/s5136/i/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s5136/i/3/A/i","parentIdentifier":"/us/usc/t42/s5136/i/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F3%2FA%2Fi","sourceRelease":"119-100","text":"of a comparable size;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s5136/i/3/A/ii","parentIdentifier":"/us/usc/t42/s5136/i/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F3%2FA%2Fii","sourceRelease":"119-100","text":"located in the same local community or a community with reduced hazard risk; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s5136/i/3/A/iii","parentIdentifier":"/us/usc/t42/s5136/i/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"offered under similar costs, conditions, and terms;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s5136/i/3/B","parentIdentifier":"/us/usc/t42/s5136/i/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s5136/i/3/B/i","parentIdentifier":"/us/usc/t42/s5136/i/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F3%2FB%2Fi","sourceRelease":"119-100","text":"are deed restricted in perpetuity to preclude future property uses not relating to mitigation or resilience; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s5136/i/3/B/ii","parentIdentifier":"/us/usc/t42/s5136/i/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F3%2FB%2Fii","sourceRelease":"119-100","text":"are the result of a voluntary decision by the resident; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s5136/i/3/C","parentIdentifier":"/us/usc/t42/s5136/i/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5136%2Fi%2F3%2FC","sourceRelease":"119-100","text":"plan for robust public participation in the resilience or mitigation project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
