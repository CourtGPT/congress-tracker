{"type":"section","nativeType":"section","number":"1808","heading":"Annual asylum fee","label":"1808 Annual asylum fee","identifier":"/us/usc/t8/s1808","parentIdentifier":"/us/usc/t8/ch16","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1808","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Fee authorized","label":"a Fee authorized","identifier":"/us/usc/t8/s1808/a","parentIdentifier":"/us/usc/t8/s1808","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1808%2Fa","sourceRelease":"119-100","text":"In addition to any other fee authorized by law, for each calendar year that an alien’s application for asylum remains pending, the Secretary of Homeland Security or the Attorney General, as applicable, shall require the payment of a fee, equal to the amount specified in subsection (b), by such alien.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Amount specified","label":"b Amount specified","identifier":"/us/usc/t8/s1808/b","parentIdentifier":"/us/usc/t8/s1808","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1808%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Initial amount","label":"1 Initial amount","identifier":"/us/usc/t8/s1808/b/1","parentIdentifier":"/us/usc/t8/s1808/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1808%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1808/b/1/A","parentIdentifier":"/us/usc/t8/s1808/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1808%2Fb%2F1%2FA","sourceRelease":"119-100","text":"$100; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1808/b/1/B","parentIdentifier":"/us/usc/t8/s1808/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1808%2Fb%2F1%2FB","sourceRelease":"119-100","text":"such amount as the Secretary of Homeland Security may establish, by rule.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Annual adjustments for inflation","label":"2 Annual adjustments for inflation","identifier":"/us/usc/t8/s1808/b/2","parentIdentifier":"/us/usc/t8/s1808/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1808%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1808/b/2/A","parentIdentifier":"/us/usc/t8/s1808/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1808%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the amount of the fee required under this subsection for the most recently concluded fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1808/b/2/B","parentIdentifier":"/us/usc/t8/s1808/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1808%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the product resulting from the multiplication of the amount referred to in subparagraph (A) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded down to the nearest dollar.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Disposition of annual asylum fees","label":"c Disposition of annual asylum fees","identifier":"/us/usc/t8/s1808/c","parentIdentifier":"/us/usc/t8/s1808","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1808%2Fc","sourceRelease":"119-100","text":"All of the fees collected pursuant to this section shall be deposited into the general fund of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"No fee waiver","label":"d No fee waiver","identifier":"/us/usc/t8/s1808/d","parentIdentifier":"/us/usc/t8/s1808","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1808%2Fd","sourceRelease":"119-100","text":"Fees required to be paid under this section shall not be waived or reduced.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
