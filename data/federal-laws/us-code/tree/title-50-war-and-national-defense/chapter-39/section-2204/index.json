{"type":"section","nativeType":"section","number":"2204","heading":"Definitions","label":"2204 Definitions","identifier":"/us/usc/t50/s2204","parentIdentifier":"/us/usc/t50/ch39","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2204","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2204/1","parentIdentifier":"/us/usc/t50/s2204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2204%2F1","sourceRelease":"119-100","text":"the term “appropriate congressional committees” means the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives, or, where required by law for certain reporting purposes, the Select Committee on Intelligence of the Senate and the Select Committee on Intelligence of the House of Representatives;1So in original. Probably should be preceded by “Permanent”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2204/2","parentIdentifier":"/us/usc/t50/s2204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2204%2F2","sourceRelease":"119-100","text":"the term “enemy” means any country, government, group, or person that has been engaged in hostilities, whether or not lawfully authorized, with the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s2204/3","parentIdentifier":"/us/usc/t50/s2204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2204%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s2204/3/A","parentIdentifier":"/us/usc/t50/s2204/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2204%2F3%2FA","sourceRelease":"119-100","text":"any natural person;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s2204/3/B","parentIdentifier":"/us/usc/t50/s2204/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2204%2F3%2FB","sourceRelease":"119-100","text":"any corporation, partnership, or other legal entity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t50/s2204/3/C","parentIdentifier":"/us/usc/t50/s2204/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2204%2F3%2FC","sourceRelease":"119-100","text":"any organization, association, or group; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t50/s2204/4","parentIdentifier":"/us/usc/t50/s2204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2204%2F4","sourceRelease":"119-100","text":"the term “spoils of war” means enemy movable property lawfully captured, seized, confiscated, or found which has become United States property in accordance with the laws of war.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
