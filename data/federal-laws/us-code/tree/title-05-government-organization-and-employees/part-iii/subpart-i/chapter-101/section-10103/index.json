{"type":"section","nativeType":"section","number":"10103","heading":"Career paths","label":"10103 Career paths","identifier":"/us/usc/t5/s10103","parentIdentifier":"/us/usc/t5/ptIII/sptI/ch101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10103","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextSection 844 of the Homeland Security Act of 2002, referred to in subsec. (b), is classified to , Domestic Security.section 414 of Title 6"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t5/s10103/a","parentIdentifier":"/us/usc/t5/s10103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10103%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s10103/a/1","parentIdentifier":"/us/usc/t5/s10103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10103%2Fa%2F1","sourceRelease":"119-100","text":"ensure that appropriate career paths for personnel of the Agency are identified, including the education, training, experience, and assignments necessary for career progression within the Agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s10103/a/2","parentIdentifier":"/us/usc/t5/s10103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10103%2Fa%2F2","sourceRelease":"119-100","text":"publish information on the career paths described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Education, Training, and Experience","label":"b .—Education, Training, and Experience","identifier":"/us/usc/t5/s10103/b","parentIdentifier":"/us/usc/t5/s10103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10103%2Fb","sourceRelease":"119-100","text":"The Administrator shall ensure that all personnel of the Agency are provided the opportunity to acquire the education, training, and experience necessary to qualify for promotion within the Agency, including, as appropriate, the opportunity to participate in the Rotation Program established under section 844 of the Homeland Security Act of 2002.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Policy","label":"c .—Policy","identifier":"/us/usc/t5/s10103/c","parentIdentifier":"/us/usc/t5/s10103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10103%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s10103/c/1","parentIdentifier":"/us/usc/t5/s10103/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10103%2Fc%2F1","sourceRelease":"119-100","text":"the need for such personnel to serve in career enhancing positions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s10103/c/2","parentIdentifier":"/us/usc/t5/s10103/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10103%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s10103/c/2/A","parentIdentifier":"/us/usc/t5/s10103/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10103%2Fc%2F2%2FA","sourceRelease":"119-100","text":"to carry out the duties of that position; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s10103/c/2/B","parentIdentifier":"/us/usc/t5/s10103/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10103%2Fc%2F2%2FB","sourceRelease":"119-100","text":"for responsibility and accountability for actions taken in that position.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
