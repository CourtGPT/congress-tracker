{"type":"section","nativeType":"section","number":"19105","heading":"Assistant Director","label":"19105 Assistant Director","identifier":"/us/usc/t42/s19105","parentIdentifier":"/us/usc/t42/ch163/schIII/ptG","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s19105/a","parentIdentifier":"/us/usc/t42/s19105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fa","sourceRelease":"119-100","text":"The Director shall appoint an Assistant Director responsible for the management of the Directorate established under this part, in the same manner as other Assistant Directors of the Foundation are appointed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Qualifications","label":"b Qualifications","identifier":"/us/usc/t42/s19105/b","parentIdentifier":"/us/usc/t42/s19105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19105/b/1","parentIdentifier":"/us/usc/t42/s19105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fb%2F1","sourceRelease":"119-100","text":"advise the Director on all matters pertaining to use-inspired and translational research, development, and commercialization at the Foundation, including partnership with the private sector and other users of Foundation funded research; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19105/b/2","parentIdentifier":"/us/usc/t42/s19105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fb%2F2","sourceRelease":"119-100","text":"develop and implement the necessary policies and procedures to promote a culture of use-inspired and translational research within the Directorate and across the Foundation and carry out the responsibilities under subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Responsibilities","label":"c Responsibilities","identifier":"/us/usc/t42/s19105/c","parentIdentifier":"/us/usc/t42/s19105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19105/c/1","parentIdentifier":"/us/usc/t42/s19105/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fc%2F1","sourceRelease":"119-100","text":"advising the Director on all matters pertaining to use-inspired and translational research and development activities at the Foundation, including effective practices for convergence research, and the potential impact of Foundation research on United States societal, national and geostrategic challenges;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19105/c/2","parentIdentifier":"/us/usc/t42/s19105/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19105/c/2/A","parentIdentifier":"/us/usc/t42/s19105/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fc%2F2%2FA","sourceRelease":"119-100","text":"among the offices, directorates, and divisions within the Foundation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19105/c/2/B","parentIdentifier":"/us/usc/t42/s19105/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fc%2F2%2FB","sourceRelease":"119-100","text":"between the Foundation and stakeholders in academia, the private sector, including non-profit entities, labor organizations, Federal or State agencies, and international entities, as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19105/c/3","parentIdentifier":"/us/usc/t42/s19105/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fc%2F3","sourceRelease":"119-100","text":"ensuring that the activities carried out under this part do not substantially and unnecessarily duplicate activities supported by other parts of the Foundation or other relevant Federal agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s19105/c/4","parentIdentifier":"/us/usc/t42/s19105/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fc%2F4","sourceRelease":"119-100","text":"approving all new programs within the Directorate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s19105/c/5","parentIdentifier":"/us/usc/t42/s19105/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fc%2F5","sourceRelease":"119-100","text":"developing and testing diverse merit-review models and mechanisms for selecting and providing awards for use-inspired and translational research and development at different scales, from individual investigator awards to large multi-institution collaborations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s19105/c/6","parentIdentifier":"/us/usc/t42/s19105/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fc%2F6","sourceRelease":"119-100","text":"assessing the success of programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s19105/c/7","parentIdentifier":"/us/usc/t42/s19105/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fc%2F7","sourceRelease":"119-100","text":"administering awards to achieve the purposes described in ; andsection 19102 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s19105/c/8","parentIdentifier":"/us/usc/t42/s19105/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fc%2F8","sourceRelease":"119-100","text":"performing other such duties pertaining to the purposes in as are required by the Director.section 19102 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Relationship to the Director","label":"d Relationship to the Director","identifier":"/us/usc/t42/s19105/d","parentIdentifier":"/us/usc/t42/s19105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fd","sourceRelease":"119-100","text":"The Assistant Director shall report to the Director.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Relationship to other programs","label":"e Relationship to other programs","identifier":"/us/usc/t42/s19105/e","parentIdentifier":"/us/usc/t42/s19105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19105%2Fe","sourceRelease":"119-100","text":"No other directorate within the Foundation shall report to the Assistant Director.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
