gainst the employee in an amount that is not more than $250.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t5/s9204/b/4","parentIdentifier":"/us/usc/t5/s9204/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9204%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s9204/b/4/A","parentIdentifier":"/us/usc/t5/s9204/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9204%2Fb%2F4%2FA","sourceRelease":"119-100","text":"suspension of the employee for a period of more than 7 days; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s9204/b/4/B","parentIdentifier":"/us/usc/t5/s9204/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9204%2Fb%2F4%2FB","sourceRelease":"119-100","text":"a civil penalty against the employee in an amount that is not more than $500.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t5/s9204/b/5","parentIdentifier":"/us/usc/t5/s9204/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9204%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s9204/b/5/A","parentIdentifier":"/us/usc/t5/s9204/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9204%2Fb%2F5%2FA","sourceRelease":"119-100","text":"suspension of the employee for a period of more than 7 days; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s9204/b/5/B","parentIdentifier":"/us/usc/t5/s9204/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9204%2Fb%2F5%2FB","sourceRelease":"119-100","text":"a civil penalty against the employee in an amount that is not more than $1,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
