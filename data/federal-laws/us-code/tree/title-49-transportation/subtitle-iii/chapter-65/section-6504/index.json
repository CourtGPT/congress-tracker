clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s6504/b/3/A/i","parentIdentifier":"/us/usc/t49/s6504/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6504%2Fb%2F3%2FA%2Fi","sourceRelease":"119-100","text":"a proposal for those modifications; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s6504/b/3/A/ii","parentIdentifier":"/us/usc/t49/s6504/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6504%2Fb%2F3%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t49/s6504/b/3/A/ii/I","parentIdentifier":"/us/usc/t49/s6504/b/3/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6504%2Fb%2F3%2FA%2Fii%2FI","sourceRelease":"119-100","text":"incorporated into the Unified Regulatory Agenda; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t49/s6504/b/3/A/ii/II","parentIdentifier":"/us/usc/t49/s6504/b/3/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6504%2Fb%2F3%2FA%2Fii%2FII","sourceRelease":"119-100","text":"adopted into existing regulations as soon as practicable; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s6504/b/3/B","parentIdentifier":"/us/usc/t49/s6504/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6504%2Fb%2F3%2FB","sourceRelease":"119-100","text":"if modifications are determined not to be required under paragraph (2), develop a description of 