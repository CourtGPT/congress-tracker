rl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381c%2Fb%2F7%2FB","sourceRelease":"119-100","text":"off-highway vehicle areas designated by law; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s410aaa–81c/b/7/C","parentIdentifier":"/us/usc/t16/s410aaa–81c/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381c%2Fb%2F7%2FC","sourceRelease":"119-100","text":"administratively designated open areas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Exceptions","label":"c Exceptions","identifier":"/us/usc/t16/s410aaa–81c/c","parentIdentifier":"/us/usc/t16/s410aaa–81c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381c%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Authorization by Secretary","label":"1 Authorization by Secretary","identifier":"/us/usc/t16/s410aaa–81c/c/1","parentIdentifier":"/us/usc/t16/s410aaa–81c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381c%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410aaa–81c/c/1/A","parentIdentifier":"/us/usc/t16/s410aaa–81c/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381c%2Fc%2F1%2FA","sourceRelease":"119-100","text":"a right-of-way application for a renewable energy development project or associated energy transport facility on acquired land or donated land was submitted to the Bureau of Land Management on or before ; orDecember 1, 2009","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410aaa–81c/c/1/B","parentIdentifier":"/us/usc/t16/s410aaa–81c/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381c%2Fc%2F1%2FB","sourceRelease":"119-100","text":"after the completion and consideration of an analysis under the National Environmental Policy Act of 1969 ( et seq.), the Secretary has determined that proposed use is in the public interest.42 U.S.C. 4321","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Conditions","label":"2 Conditions","identifier":"/us/usc/t16/s410aaa–81c/c/2","parentIdentifier":"/us/usc/t16/s410aaa–81c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381c%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s410aaa–81c/c/2/A","parentIdentifier":"/us/usc/t16/s410aaa–81c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381c%2Fc%2F2%2FA","sourceRelease":"119-100","text":"If the Secretary grants an exception to the prohibition under paragraph (1), the Secretary shall require the permittee to donate private land of comparable value located within the Conservation Area to the United States to mitigate the use.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Approval","label":"B Approval","identifier":"/us/usc/t16/s410aaa–81c/c/2/B","parentIdentifier":"/us/usc/t16/s410aaa–81c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381c%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s410aaa–81c/c/2/B/i","parentIdentifier":"/us/usc/t16/s410aaa–81c/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381c%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"consultation, to the maximum extent practicable, with the donor of the private land proposed for nonconservation uses; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s410aaa–81c/c/2/B/ii","parentIdentifier":"/us/usc/t16/s410aaa–81c/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381c%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"an opportunity for public comment regarding the donation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Existing agreements","label":"d Existing agreements","identifier":"/us/usc/t16/s410aaa–81c/d","parentIdentifier":"/us/usc/t16/s410aaa–81c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381c%2Fd","sourceRelease":"119-100","text":"Nothing in this section affects permitted or prohibited uses of donated land or acquired land in the Conservation Area established in any easements, deed restrictions, memoranda of understanding, or other agreements in existence on .March 12, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Deed restrictions","label":"e Deed restrictions","identifier":"/us/usc/t16/s410aaa–81c/e","parentIdentifier":"/us/usc/t16/s410aaa–81c","sourceUrl":"https://uscode.ho