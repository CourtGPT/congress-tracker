{"type":"section","nativeType":"section","number":"677","heading":"Sense of Congress","label":"677 Sense of Congress","identifier":"/us/usc/t6/s677","parentIdentifier":"/us/usc/t6/ch1/schXVIII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s677/1","parentIdentifier":"/us/usc/t6/s677","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677%2F1","sourceRelease":"119-100","text":"the purpose of this part is to authorize the Secretary to declare that a significant incident has occurred and to establish the authorities that are provided under the declaration to respond to and recover from the significant incident; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s677/2","parentIdentifier":"/us/usc/t6/s677","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677%2F2","sourceRelease":"119-100","text":"the authorities established under this part are intended to enable the Secretary to provide voluntary assistance to non-Federal entities impacted by a significant incident.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
