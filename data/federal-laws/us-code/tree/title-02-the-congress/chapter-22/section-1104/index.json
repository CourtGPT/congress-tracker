{"type":"section","nativeType":"section","number":"1104","heading":"Purposes and authority of Center","label":"1104 Purposes and authority of Center","identifier":"/us/usc/t2/s1104","parentIdentifier":"/us/usc/t2/ch22","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purposes of Center","label":"a Purposes of Center","identifier":"/us/usc/t2/s1104/a","parentIdentifier":"/us/usc/t2/s1104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s1104/a/1","parentIdentifier":"/us/usc/t2/s1104/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fa%2F1","sourceRelease":"119-100","text":"to increase awareness of the importance of public service, to foster among the youth of the United States greater recognition and understanding of the role of public service in the development of the United States, and to promote public service as a career choice;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s1104/a/2","parentIdentifier":"/us/usc/t2/s1104/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fa%2F2","sourceRelease":"119-100","text":"to provide training and development opportunities for State and local elected government officials and employees of State and local governments in order to assist such officials and employees to become more effective and more efficient in performing their public duties and develop their potential for accepting increased public service opportunities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t2/s1104/a/3","parentIdentifier":"/us/usc/t2/s1104/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fa%2F3","sourceRelease":"119-100","text":"to provide training and development opportunities for those employees of Members of the Congress who perform key roles in helping Members of Congress serve the people of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Authority of Center","label":"b Authority of Center","identifier":"/us/usc/t2/s1104/b","parentIdentifier":"/us/usc/t2/s1104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s1104/b/1","parentIdentifier":"/us/usc/t2/s1104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t2/s1104/b/1/A","parentIdentifier":"/us/usc/t2/s1104/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fb%2F1%2FA","sourceRelease":"119-100","text":"to improve the attitude of students toward public service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t2/s1104/b/1/B","parentIdentifier":"/us/usc/t2/s1104/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fb%2F1%2FB","sourceRelease":"119-100","text":"to encourage students to consider public service as a career goal;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t2/s1104/b/1/C","parentIdentifier":"/us/usc/t2/s1104/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fb%2F1%2FC","sourceRelease":"119-100","text":"to create a better understanding of the important role that people in public service have played in the growth and development of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t2/s1104/b/1/D","parentIdentifier":"/us/usc/t2/s1104/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fb%2F1%2FD","sourceRelease":"119-100","text":"to foster a sense of civic responsibility among the youth of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s1104/b/2","parentIdentifier":"/us/usc/t2/s1104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t2/s1104/b/2/A","parentIdentifier":"/us/usc/t2/s1104/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fb%2F2%2FA","sourceRelease":"119-100","text":"to enhance skills and abilities of public service employees and elected officials at the State and local levels of government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t2/s1104/b/2/B","parentIdentifier":"/us/usc/t2/s1104/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fb%2F2%2FB","sourceRelease":"119-100","text":"to make such officials more productive and effective in the performance of their duties; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t2/s1104/b/2/C","parentIdentifier":"/us/usc/t2/s1104/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fb%2F2%2FC","sourceRelease":"119-100","text":"to help prepare such employees and officials to assume greater responsibilities in the field of public service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t2/s1104/b/3","parentIdentifier":"/us/usc/t2/s1104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fb%2F3","sourceRelease":"119-100","text":"The development and implementation of congressional staff training programs designed to equip congressional staff personnel to perform their duties more effectively and efficiently.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t2/s1104/b/4","parentIdentifier":"/us/usc/t2/s1104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fb%2F4","sourceRelease":"119-100","text":"The development and implementation of media and telecommunications production capabilities to assist the Center in expanding the reach of its programs throughout the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t2/s1104/b/5","parentIdentifier":"/us/usc/t2/s1104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fb%2F5","sourceRelease":"119-100","text":"The establishment of library and research facilities for the collection and compilation of research materials for use in carrying out the programs of the Center.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Program priorities","label":"c Program priorities","identifier":"/us/usc/t2/s1104/c","parentIdentifier":"/us/usc/t2/s1104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1104%2Fc","sourceRelease":"119-100","text":"The Board of Trustees shall determine the priority of the programs to be carried out under this chapter and the amount of funds to be allocated for such programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
