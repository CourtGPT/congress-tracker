{"type":"section","nativeType":"section","number":"2357c","heading":"Purposes and authority","label":"2357c Purposes and authority","identifier":"/us/usc/t50/s2357c","parentIdentifier":"/us/usc/t50/ch40/schIV–A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purposes","label":"a Purposes","identifier":"/us/usc/t50/s2357c/a","parentIdentifier":"/us/usc/t50/s2357c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t50/s2357c/a/1","parentIdentifier":"/us/usc/t50/s2357c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s2357c/a/1/A","parentIdentifier":"/us/usc/t50/s2357c/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fa%2F1%2FA","sourceRelease":"119-100","text":"to exercise continuing responsibility for coordinating worldwide United States nonproliferation and threat reduction efforts to ensure that they effectively implement United States policy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s2357c/a/1/B","parentIdentifier":"/us/usc/t50/s2357c/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fa%2F1%2FB","sourceRelease":"119-100","text":"to enhance the ability of participating departments and agencies to anticipate growing nonproliferation areas of concern.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Program monitoring and coordination","label":"2 Program monitoring and coordination","identifier":"/us/usc/t50/s2357c/a/2","parentIdentifier":"/us/usc/t50/s2357c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s2357c/a/2/A","parentIdentifier":"/us/usc/t50/s2357c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fa%2F2%2FA","sourceRelease":"119-100","text":"United States nonproliferation and threat reduction efforts, and particularly such efforts in the independent states of the former Soviet Union; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s2357c/a/2/B","parentIdentifier":"/us/usc/t50/s2357c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fa%2F2%2FB","sourceRelease":"119-100","text":"coordinating the implementation of United States policy with respect to such efforts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Authority","label":"b Authority","identifier":"/us/usc/t50/s2357c/b","parentIdentifier":"/us/usc/t50/s2357c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2357c/b/1","parentIdentifier":"/us/usc/t50/s2357c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fb%2F1","sourceRelease":"119-100","text":"establish such subcommittees and working groups as it deems necessary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2357c/b/2","parentIdentifier":"/us/usc/t50/s2357c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fb%2F2","sourceRelease":"119-100","text":"direct the preparation of analyses on issues and problems relating to coordination within and among United States departments and agencies on nonproliferation and threat reduction efforts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s2357c/b/3","parentIdentifier":"/us/usc/t50/s2357c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fb%2F3","sourceRelease":"119-100","text":"direct the preparation of analyses on issues and problems relating to coordination between the United States public and private sectors on nonproliferation and threat reduction efforts, including coordination between public and private spending on nonproliferation and threat reduction programs and coordination between public spending and private investment in defense conversion activities of the independent states of the former Soviet Union;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t50/s2357c/b/4","parentIdentifier":"/us/usc/t50/s2357c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fb%2F4","sourceRelease":"119-100","text":"provide guidance on arrangements that will coordinate, deconflict, and maximize the utility of United States public spending on nonproliferation and threat reduction programs, and particularly such efforts in the independent states of the former Soviet Union;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t50/s2357c/b/5","parentIdentifier":"/us/usc/t50/s2357c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fb%2F5","sourceRelease":"119-100","text":"encourage companies and nongovernmental organizations involved in nonproliferation efforts of the independent states of the former Soviet Union or other countries of concern to voluntarily report these efforts to it;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t50/s2357c/b/6","parentIdentifier":"/us/usc/t50/s2357c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fb%2F6","sourceRelease":"119-100","text":"direct the preparation of analyses on issues and problems relating to the coordination between the United States and other countries with respect to nonproliferation efforts, and particularly such efforts in the independent states of the former Soviet Union; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t50/s2357c/b/7","parentIdentifier":"/us/usc/t50/s2357c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2357c%2Fb%2F7","sourceRelease":"119-100","text":"consider, and make recommendations to the President with respect to, proposals for such new legislation or regulations relating to United States nonproliferation efforts as may be necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
