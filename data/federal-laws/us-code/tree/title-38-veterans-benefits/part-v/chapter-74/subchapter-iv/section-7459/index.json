{"type":"section","nativeType":"section","number":"7459","heading":"Nursing staff: special rules for overtime duty","label":"7459 Nursing staff: special rules for overtime duty","identifier":"/us/usc/t38/s7459","parentIdentifier":"/us/usc/t38/ptV/ch74/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Limitation","label":"a .—Limitation","identifier":"/us/usc/t38/s7459/a","parentIdentifier":"/us/usc/t38/s7459","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fa","sourceRelease":"119-100","text":"Except as provided in subsection (c), the Secretary may not require nursing staff to work more than 40 hours (or 24 hours if such staff is covered under ) in an administrative work week or more than eight consecutive hours (or 12 hours if such staff is covered under section 7456 or 7456A of this title).section 7456 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Voluntary Overtime","label":"b .—Voluntary Overtime","identifier":"/us/usc/t38/s7459/b","parentIdentifier":"/us/usc/t38/s7459","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s7459/b/1","parentIdentifier":"/us/usc/t38/s7459/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fb%2F1","sourceRelease":"119-100","text":"Nursing staff may on a voluntary basis elect to work hours otherwise prohibited by subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s7459/b/2","parentIdentifier":"/us/usc/t38/s7459/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s7459/b/2/A","parentIdentifier":"/us/usc/t38/s7459/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fb%2F2%2FA","sourceRelease":"119-100","text":"to discriminate (within the meaning of section 704(a) of the Civil Rights Act of 1964 ()) against the staff;42 U.S.C. 2000e–3(a)","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s7459/b/2/B","parentIdentifier":"/us/usc/t38/s7459/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fb%2F2%2FB","sourceRelease":"119-100","text":"to dismiss or discharge the staff; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s7459/b/2/C","parentIdentifier":"/us/usc/t38/s7459/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fb%2F2%2FC","sourceRelease":"119-100","text":"for any other adverse personnel action against the staff.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Overtime Under Emergency Circumstances","label":"c .—Overtime Under Emergency Circumstances","identifier":"/us/usc/t38/s7459/c","parentIdentifier":"/us/usc/t38/s7459","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s7459/c/1","parentIdentifier":"/us/usc/t38/s7459/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s7459/c/1/A","parentIdentifier":"/us/usc/t38/s7459/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the work is a consequence of an emergency that could not have been reasonably anticipated;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s7459/c/1/B","parentIdentifier":"/us/usc/t38/s7459/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fc%2F1%2FB","sourceRelease":"119-100","text":"the emergency is non-recurring and is not caused by or aggravated by the inattention of the Secretary or lack of reasonable contingency planning by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s7459/c/1/C","parentIdentifier":"/us/usc/t38/s7459/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fc%2F1%2FC","sourceRelease":"119-100","text":"the Secretary has exhausted all good faith, reasonable attempts to obtain voluntary workers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t38/s7459/c/1/D","parentIdentifier":"/us/usc/t38/s7459/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fc%2F1%2FD","sourceRelease":"119-100","text":"the nurse staff have critical skills and expertise that are required for the work; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t38/s7459/c/1/E","parentIdentifier":"/us/usc/t38/s7459/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fc%2F1%2FE","sourceRelease":"119-100","text":"the work involves work for which the standard of care for a patient assignment requires continuity of care through completion of a case, treatment, or procedure.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s7459/c/2","parentIdentifier":"/us/usc/t38/s7459/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fc%2F2","sourceRelease":"119-100","text":"Nursing staff may not be required to work hours under this subsection after the requirement for a direct role by the staff in responding to medical needs resulting from the emergency ends.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Nursing Staff Defined","label":"d .—Nursing Staff Defined","identifier":"/us/usc/t38/s7459/d","parentIdentifier":"/us/usc/t38/s7459","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s7459/d/1","parentIdentifier":"/us/usc/t38/s7459/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fd%2F1","sourceRelease":"119-100","text":"A registered nurse.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s7459/d/2","parentIdentifier":"/us/usc/t38/s7459/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fd%2F2","sourceRelease":"119-100","text":"A licensed practical or vocational nurse.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s7459/d/3","parentIdentifier":"/us/usc/t38/s7459/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fd%2F3","sourceRelease":"119-100","text":"A nurse assistant appointed under this chapter or title 5.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s7459/d/4","parentIdentifier":"/us/usc/t38/s7459/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7459%2Fd%2F4","sourceRelease":"119-100","text":"Any other nurse position designated by the Secretary for purposes of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
