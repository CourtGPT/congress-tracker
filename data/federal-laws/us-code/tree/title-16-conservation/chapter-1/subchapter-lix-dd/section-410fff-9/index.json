{"type":"section","nativeType":"section","number":"410fff–9","heading":"Study of lands within and adjacent to Curecanti National Recreation Area","label":"410fff–9 Study of lands within and adjacent to Curecanti National Recreation Area","identifier":"/us/usc/t16/s410fff–9","parentIdentifier":"/us/usc/t16/ch1/schLIX–DD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s410fff–9/a","parentIdentifier":"/us/usc/t16/s410fff–9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fa","sourceRelease":"119-100","text":"Not later than 3 years after , the Secretary, acting through the Director of the National Park Service, shall conduct a study concerning land protection and open space within and adjacent to the area administered as the Curecanti National Recreation Area.October 21, 1999","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purpose of study","label":"b Purpose of study","identifier":"/us/usc/t16/s410fff–9/b","parentIdentifier":"/us/usc/t16/s410fff–9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410fff–9/b/1","parentIdentifier":"/us/usc/t16/s410fff–9/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fb%2F1","sourceRelease":"119-100","text":"assess the natural, cultural, recreational and scenic resource value and character of the land within and surrounding the Curecanti National Recreation Area (including open vistas, wildlife habitat, and other public benefits);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410fff–9/b/2","parentIdentifier":"/us/usc/t16/s410fff–9/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fb%2F2","sourceRelease":"119-100","text":"identify practicable alternatives that protect the resource value and character of the land within and surrounding the Curecanti National Recreation Area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s410fff–9/b/3","parentIdentifier":"/us/usc/t16/s410fff–9/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fb%2F3","sourceRelease":"119-100","text":"recommend a variety of economically feasible and viable tools to achieve the purposes described in paragraphs (1) and (2); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s410fff–9/b/4","parentIdentifier":"/us/usc/t16/s410fff–9/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fb%2F4","sourceRelease":"119-100","text":"estimate the costs of implementing the approaches recommended by the study.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Submission of report","label":"c Submission of report","identifier":"/us/usc/t16/s410fff–9/c","parentIdentifier":"/us/usc/t16/s410fff–9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410fff–9/c/1","parentIdentifier":"/us/usc/t16/s410fff–9/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fc%2F1","sourceRelease":"119-100","text":"contains the findings of the study required by subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410fff–9/c/2","parentIdentifier":"/us/usc/t16/s410fff–9/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fc%2F2","sourceRelease":"119-100","text":"makes recommendations to Congress with respect to the findings of the study required by subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s410fff–9/c/3","parentIdentifier":"/us/usc/t16/s410fff–9/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fc%2F3","sourceRelease":"119-100","text":"makes recommendations to Congress regarding action that may be taken with respect to the land described in the report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Acquisition of additional land and interests in land","label":"d Acquisition of additional land and interests in land","identifier":"/us/usc/t16/s410fff–9/d","parentIdentifier":"/us/usc/t16/s410fff–9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s410fff–9/d/1","parentIdentifier":"/us/usc/t16/s410fff–9/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fd%2F1","sourceRelease":"119-100","text":"Prior to the completion of the study required by subsection (a), the Secretary may acquire certain private land or interests in land as depicted on the Map entitled “Proposed Additions to the Curecanti National Recreation Area”, dated 01/25/99, totaling approximately 1,065 acres and entitled “Hall and Fitti properties”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Method of acquisition","label":"2 Method of acquisition","identifier":"/us/usc/t16/s410fff–9/d/2","parentIdentifier":"/us/usc/t16/s410fff–9/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s410fff–9/d/2/A","parentIdentifier":"/us/usc/t16/s410fff–9/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s410fff–9/d/2/A/i","parentIdentifier":"/us/usc/t16/s410fff–9/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":"donation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s410fff–9/d/2/A/ii","parentIdentifier":"/us/usc/t16/s410fff–9/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":"purchase with donated or appropriated funds; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s410fff–9/d/2/A/iii","parentIdentifier":"/us/usc/t16/s410fff–9/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fd%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"exchange.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Consent","label":"B Consent","identifier":"/us/usc/t16/s410fff–9/d/2/B","parentIdentifier":"/us/usc/t16/s410fff–9/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fd%2F2%2FB","sourceRelease":"119-100","text":"No land or interest in land may be acquired without the consent of the owner of the land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Boundary revisions following acquisition","label":"C Boundary revisions following acquisition","identifier":"/us/usc/t16/s410fff–9/d/2/C","parentIdentifier":"/us/usc/t16/s410fff–9/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fd%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s410fff–9/d/2/C/i","parentIdentifier":"/us/usc/t16/s410fff–9/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fd%2F2%2FC%2Fi","sourceRelease":"119-100","text":"revise the boundary of the Curecanti National Recreation Area to include newly-acquired land; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s410fff–9/d/2/C/ii","parentIdentifier":"/us/usc/t16/s410fff–9/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410fff%E2%80%939%2Fd%2F2%2FC%2Fii","sourceRelease":"119-100","text":"administer newly-acquired land according to applicable laws (including regulations).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
