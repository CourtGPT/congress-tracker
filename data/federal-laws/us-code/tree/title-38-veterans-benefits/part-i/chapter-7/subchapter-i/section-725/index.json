{"type":"section","nativeType":"section","number":"725","heading":"Annual performance plan for political appointees","label":"725 Annual performance plan for political appointees","identifier":"/us/usc/t38/s725","parentIdentifier":"/us/usc/t38/ptI/ch7/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs725","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t38/s725/a","parentIdentifier":"/us/usc/t38/s725","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs725%2Fa","sourceRelease":"119-100","text":"The Secretary shall conduct an annual performance plan for each political appointee of the Department that is similar to the annual performance plan conducted for an employee of the Department who is appointed as a career appointee (as that term is defined in ) within the Senior Executive Service at the Department.section 3132(a) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Elements of Plan","label":"b .—Elements of Plan","identifier":"/us/usc/t38/s725/b","parentIdentifier":"/us/usc/t38/s725","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs725%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s725/b/1","parentIdentifier":"/us/usc/t38/s725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs725%2Fb%2F1","sourceRelease":"119-100","text":"Recruiting, selecting, and retaining well-qualified individuals for employment at the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s725/b/2","parentIdentifier":"/us/usc/t38/s725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs725%2Fb%2F2","sourceRelease":"119-100","text":"Engaging and motivating employees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s725/b/3","parentIdentifier":"/us/usc/t38/s725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs725%2Fb%2F3","sourceRelease":"119-100","text":"Training and developing employees and preparing those employees for future leadership roles within the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s725/b/4","parentIdentifier":"/us/usc/t38/s725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs725%2Fb%2F4","sourceRelease":"119-100","text":"Holding each employee of the Department that is a manager accountable for addressing issues relating to performance, in particular issues relating to the performance of employees that report to the manager.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Definition of Political Appointee","label":"c .—Definition of Political Appointee","identifier":"/us/usc/t38/s725/c","parentIdentifier":"/us/usc/t38/s725","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs725%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s725/c/1","parentIdentifier":"/us/usc/t38/s725/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs725%2Fc%2F1","sourceRelease":"119-100","text":"a position which has been excepted from the competitive service by reason of its confidential, policy-determining, policy-making, or policy-advocating character; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s725/c/2","parentIdentifier":"/us/usc/t38/s725/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs725%2Fc%2F2","sourceRelease":"119-100","text":"a position in the Senior Executive Service as a noncareer appointee (as such term is defined in ).section 3132(a) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
