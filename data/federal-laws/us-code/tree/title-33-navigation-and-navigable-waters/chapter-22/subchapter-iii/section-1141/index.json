{"type":"section","nativeType":"section","number":"1141","heading":"Definitions","label":"1141 Definitions","identifier":"/us/usc/t33/s1141","parentIdentifier":"/us/usc/t33/ch22/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1141","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Young Fishermen’s Development Act, and not as part of titles I and II of which comprise this chapter.Pub. L. 89–454"],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Sea Grant Institution","label":"1 Sea Grant Institution","identifier":"/us/usc/t33/s1141/1","parentIdentifier":"/us/usc/t33/s1141","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1141%2F1","sourceRelease":"119-100","text":"The term “Sea Grant Institution” means a sea grant college or sea grant institute, as those terms are defined in .section 1122 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Tribal organization","label":"2 Tribal organization","identifier":"/us/usc/t33/s1141/2","parentIdentifier":"/us/usc/t33/s1141","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1141%2F2","sourceRelease":"119-100","text":"The term “Tribal organization” has the meaning given the term “tribal organization” in .section 5304 of title 25","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Young fisherman","label":"3 Young fisherman","identifier":"/us/usc/t33/s1141/3","parentIdentifier":"/us/usc/t33/s1141","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1141%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1141/3/A","parentIdentifier":"/us/usc/t33/s1141/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1141%2F3%2FA","sourceRelease":"119-100","text":"desires to participate in the commercial fisheries of the United States, including the Great Lakes fisheries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1141/3/B","parentIdentifier":"/us/usc/t33/s1141/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1141%2F3%2FB","sourceRelease":"119-100","text":"has worked as a captain, crew member, or deckhand on a commercial fishing vessel for not more than 10 years of cumulative service; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s1141/3/C","parentIdentifier":"/us/usc/t33/s1141/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1141%2F3%2FC","sourceRelease":"119-100","text":"is a beginning commercial fisherman.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
