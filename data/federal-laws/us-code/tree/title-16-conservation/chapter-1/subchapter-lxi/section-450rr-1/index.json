ndments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t16/s450rr–1/d","parentIdentifier":"/us/usc/t16/s450rr–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs450rr%E2%80%931%2Fd","sourceRelease":"119-100","text":"“Secretary” means the Secretary of State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
