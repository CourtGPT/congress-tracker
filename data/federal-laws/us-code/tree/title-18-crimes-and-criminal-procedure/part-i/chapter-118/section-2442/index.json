{"type":"section","nativeType":"section","number":"2442","heading":"Recruitment or use of child soldiers","label":"2442 Recruitment or use of child soldiers","identifier":"/us/usc/t18/s2442","parentIdentifier":"/us/usc/t18/ptI/ch118","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Offense","label":"a .—Offense","identifier":"/us/usc/t18/s2442/a","parentIdentifier":"/us/usc/t18/s2442","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2442/a/1","parentIdentifier":"/us/usc/t18/s2442/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fa%2F1","sourceRelease":"119-100","text":"recruits, enlists, or conscripts a person to serve while such person is under 15 years of age in an armed force or group; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2442/a/2","parentIdentifier":"/us/usc/t18/s2442/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fa%2F2","sourceRelease":"119-100","text":"uses a person under 15 years of age to participate actively in hostilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Penalty","label":"b .—Penalty","identifier":"/us/usc/t18/s2442/b","parentIdentifier":"/us/usc/t18/s2442","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fb","sourceRelease":"119-100","text":"Whoever violates, or attempts or conspires to violate, subsection (a) shall be fined under this title or imprisoned not more than 20 years, or both and, if death of any person results, shall be fined under this title and imprisoned for any term of years or for life.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Jurisdiction","label":"c .—Jurisdiction","identifier":"/us/usc/t18/s2442/c","parentIdentifier":"/us/usc/t18/s2442","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2442/c/1","parentIdentifier":"/us/usc/t18/s2442/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fc%2F1","sourceRelease":"119-100","text":"the alleged offender is a national of the United States (as defined in section 101(a)(22) of the Immigration and Nationality Act ()) or an alien lawfully admitted for permanent residence in the United States (as defined in section 101(a)(20) of such Act ();8 U.S.C. 1101(a)(22)8 U.S.C. 1101(a)(20)1So in original. An additional closing parenthesis probably should precede the semicolon.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2442/c/2","parentIdentifier":"/us/usc/t18/s2442/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fc%2F2","sourceRelease":"119-100","text":"the alleged offender is a stateless person whose habitual residence is in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s2442/c/3","parentIdentifier":"/us/usc/t18/s2442/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fc%2F3","sourceRelease":"119-100","text":"the alleged offender is present in the United States, irrespective of the nationality of the alleged offender; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t18/s2442/c/4","parentIdentifier":"/us/usc/t18/s2442/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fc%2F4","sourceRelease":"119-100","text":"the offense occurs in whole or in part within the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Definitions","label":"d .—Definitions","identifier":"/us/usc/t18/s2442/d","parentIdentifier":"/us/usc/t18/s2442","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Participate actively in hostilities","label":"1 .—Participate actively in hostilities","identifier":"/us/usc/t18/s2442/d/1","parentIdentifier":"/us/usc/t18/s2442/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s2442/d/1/A","parentIdentifier":"/us/usc/t18/s2442/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fd%2F1%2FA","sourceRelease":"119-100","text":"combat or military activities related to combat, including sabotage and serving as a decoy, a courier, or at a military checkpoint; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s2442/d/1/B","parentIdentifier":"/us/usc/t18/s2442/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fd%2F1%2FB","sourceRelease":"119-100","text":"direct support functions related to combat, including transporting supplies or providing other services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Armed force or group","label":"2 .—Armed force or group","identifier":"/us/usc/t18/s2442/d/2","parentIdentifier":"/us/usc/t18/s2442/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2442%2Fd%2F2","sourceRelease":"119-100","text":"The term “armed force or group” means any army, militia, or other military organization, whether or not it is state-sponsored, excluding any group assembled solely for nonviolent political association.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
