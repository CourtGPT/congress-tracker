{"type":"section","nativeType":"section","number":"2101","heading":"Findings","label":"2101 Findings","identifier":"/us/usc/t21/s2101","parentIdentifier":"/us/usc/t21/ch26","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2101","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s2101/1","parentIdentifier":"/us/usc/t21/s2101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2101%2F1","sourceRelease":"119-100","text":"the safety and integrity of the United States food supply are vital to public health, to public confidence in the food supply, and to the success of the food sector of the Nation’s economy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s2101/2","parentIdentifier":"/us/usc/t21/s2101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2101%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s2101/2/A","parentIdentifier":"/us/usc/t21/s2101/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2101%2F2%2FA","sourceRelease":"119-100","text":"have contributed to a loss of public confidence in food safety; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s2101/2/B","parentIdentifier":"/us/usc/t21/s2101/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2101%2F2%2FB","sourceRelease":"119-100","text":"have caused significant economic losses to manufacturers and producers not responsible for contaminated food items;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t21/s2101/3","parentIdentifier":"/us/usc/t21/s2101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2101%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s2101/3/A","parentIdentifier":"/us/usc/t21/s2101/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2101%2F3%2FA","sourceRelease":"119-100","text":"emerging pathogens and other contaminants and the ability to detect all forms of contamination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s2101/3/B","parentIdentifier":"/us/usc/t21/s2101/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2101%2F3%2FB","sourceRelease":"119-100","text":"an increasing volume of imported food from a wide variety of countries; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t21/s2101/3/C","parentIdentifier":"/us/usc/t21/s2101/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2101%2F3%2FC","sourceRelease":"119-100","text":"a shortage of adequate resources for monitoring and inspection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t21/s2101/4","parentIdentifier":"/us/usc/t21/s2101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2101%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s2101/4/A","parentIdentifier":"/us/usc/t21/s2101/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2101%2F4%2FA","sourceRelease":"119-100","text":"from 2003 to 2007, the value of food imports has increased from $45,600,000,000 to $64,000,000,000; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s2101/4/B","parentIdentifier":"/us/usc/t21/s2101/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2101%2F4%2FB","sourceRelease":"119-100","text":"imported food accounts for 13 percent of the average American diet including 31 percent of fruits, juices, and nuts, 9.5 percent of red meat, and 78.6 percent of fish and shellfish; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t21/s2101/5","parentIdentifier":"/us/usc/t21/s2101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2101%2F5","sourceRelease":"119-100","text":"the number of full-time equivalent Food and Drug Administration employees conducting inspections has decreased from 2003 to 2007.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
