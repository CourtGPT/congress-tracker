A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fa%2F2%2FA%2Fvi","sourceRelease":"119-100","text":"speaker fees; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t20/s1228c/a/2/A/vii","parentIdentifier":"/us/usc/t20/s1228c/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fa%2F2%2FA%2Fvii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t20/s1228c/a/2/A/vii/I","parentIdentifier":"/us/usc/t20/s1228c/a/2/A/vii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fa%2F2%2FA%2Fvii%2FI","sourceRelease":"119-100","text":"the preparation of nonscholastic educational program materials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t20/s1228c/a/2/A/vii/II","parentIdentifier":"/us/usc/t20/s1228c/a/2/A/vii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fa%2F2%2FA%2Fvii%2FII","sourceRelease":"119-100","text":"the provision of financial assistance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t20/s1228c/a/2/A/vii/III","parentIdentifier":"/us/usc/t20/s1228c/a/2/A/vii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fa%2F2%2FA%2Fvii%2FIII","sourceRelease":"119-100","text":"mailing list rental or other recruitment activity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t20/s1228c/a/2/A/vii/IV","parentIdentifier":"/us/usc/t20/s1228c/a/2/A/vii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fa%2F2%2FA%2Fvii%2FIV","sourceRelease":"119-100","text":"administrative salaries and consulting fees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1228c/a/2/B","parentIdentifier":"/us/usc/t20/s1228c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the identity of the organization or business providing each of the features described in clauses (i) through (vii) of subparagraph (A); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1228c/a/2/C","parentIdentifier":"/us/usc/t20/s1228c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fa%2F2%2FC","sourceRelease":"119-100","text":"the nature of any relationship of any board member, officer, or employee of the educational organization to any organization or business described in subparagraph (B), including the salary or other compensation paid by such organization or business to such board member, officer, or employee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Nondiscriminatory enrollment and service policy","label":"b Nondiscriminatory enrollment and service policy","identifier":"/us/usc/t20/s1228c/b","parentIdentifier":"/us/usc/t20/s1228c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1228c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":