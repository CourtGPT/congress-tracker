{"type":"section","nativeType":"section","number":"6366","heading":"Eligibility for leave recipients","label":"6366 Eligibility for leave recipients","identifier":"/us/usc/t5/s6366","parentIdentifier":"/us/usc/t5/ptIII/sptE/ch63/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s6366/a","parentIdentifier":"/us/usc/t5/s6366","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6366/a/1","parentIdentifier":"/us/usc/t5/s6366/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fa%2F1","sourceRelease":"119-100","text":"experiences a medical emergency and submits an application pursuant to section 6367(a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6366/a/2","parentIdentifier":"/us/usc/t5/s6366/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s6366/a/2/A","parentIdentifier":"/us/usc/t5/s6366/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fa%2F2%2FA","sourceRelease":"119-100","text":"contributes the minimum number of hours as required under subsection (b) of accrued or accumulated annual leave to the leave bank of the employing agency of such employee, in the leave year (beginning in and including any part of a leave year in which such leave bank is established) that such employee submits an application to be a leave recipient under section 6367(a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s6366/a/2/B","parentIdentifier":"/us/usc/t5/s6366/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fa%2F2%2FB","sourceRelease":"119-100","text":"such contribution is made before such employee submits an application under section 6367(a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s6366/b","parentIdentifier":"/us/usc/t5/s6366","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6366/b/1","parentIdentifier":"/us/usc/t5/s6366/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s6366/b/1/A","parentIdentifier":"/us/usc/t5/s6366/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fb%2F1%2FA","sourceRelease":"119-100","text":"for less than 3 years of service and contributes a minimum of 4 hours;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s6366/b/1/B","parentIdentifier":"/us/usc/t5/s6366/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fb%2F1%2FB","sourceRelease":"119-100","text":"for between 3 years and less than 15 years of service and contributes a minimum of 6 hours; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s6366/b/1/C","parentIdentifier":"/us/usc/t5/s6366/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fb%2F1%2FC","sourceRelease":"119-100","text":"for 15 years or more of service and contributes a minimum of 8 hours.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6366/b/2","parentIdentifier":"/us/usc/t5/s6366/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s6366/b/2/A","parentIdentifier":"/us/usc/t5/s6366/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fb%2F2%2FA","sourceRelease":"119-100","text":"reduce the minimum number of hours required under paragraph (1) for any leave year, if such Board determines there is a surplus of leave in the leave bank; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s6366/b/2/B","parentIdentifier":"/us/usc/t5/s6366/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fb%2F2%2FB","sourceRelease":"119-100","text":"increase the number of minimum hours required under paragraph (1) for the succeeding leave year, in any leave year in which the Board determines there is a shortage of leave in the leave bank.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t5/s6366/c","parentIdentifier":"/us/usc/t5/s6366","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fc","sourceRelease":"119-100","text":"An employee shall meet the requirements of subsection (a)(2)(A) if such employee contributes the minimum number of hours as required under subsection (b) of accrued or accumulated annual leave to the leave bank with which such employee submits an application to be a leave recipient under section 6367(a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t5/s6366/d","parentIdentifier":"/us/usc/t5/s6366","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6366%2Fd","sourceRelease":"119-100","text":"The provisions of subsection (a) may not be construed to limit the amount of the voluntary contribution of annual leave to a leave bank, which does not exceed the limitations of section 6365(b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
