{"type":"section","nativeType":"section","number":"6123","heading":"Acceleration of depleted uranium manufacturing processes","label":"6123 Acceleration of depleted uranium manufacturing processes","identifier":"/us/usc/t10/s6123","parentIdentifier":"/us/usc/t10/stA/ptVI/sptB/ch602/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6123","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsProvisions similar to those in this section were contained in , which was set out as a note under , War and National Defense, prior to repeal by .section 3121 of Pub. L. 117–263section 2532 of Title 50Pub. L. 119–60, § 3111(b)(11)"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Acceleration of Manufacturing","label":"a .—Acceleration of Manufacturing","identifier":"/us/usc/t10/s6123/a","parentIdentifier":"/us/usc/t10/s6123","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6123%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6123/a/1","parentIdentifier":"/us/usc/t10/s6123/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6123%2Fa%2F1","sourceRelease":"119-100","text":"demonstrates bulk cold hearth melting of depleted uranium alloys to augment existing capabilities on an operational basis for war reserve components;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6123/a/2","parentIdentifier":"/us/usc/t10/s6123/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6123%2Fa%2F2","sourceRelease":"119-100","text":"manufactures, on a repeatable and ongoing basis, war reserve depleted uranium alloy components using net shape casting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s6123/a/3","parentIdentifier":"/us/usc/t10/s6123/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6123%2Fa%2F3","sourceRelease":"119-100","text":"demonstrates, if possible, a production facility to conduct routine operations for manufacturing depleted uranium alloy components outside of the current perimeter security fencing of the Y-12 National Security Complex, Oak Ridge, Tennessee; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s6123/a/4","parentIdentifier":"/us/usc/t10/s6123/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6123%2Fa%2F4","sourceRelease":"119-100","text":"has available high purity depleted uranium for the production of war reserve components.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Annual Briefing","label":"b .—Annual Briefing","identifier":"/us/usc/t10/s6123/b","parentIdentifier":"/us/usc/t10/s6123","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6123%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6123/b/1","parentIdentifier":"/us/usc/t10/s6123/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6123%2Fb%2F1","sourceRelease":"119-100","text":"progress made in carrying out subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6123/b/2","parentIdentifier":"/us/usc/t10/s6123/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6123%2Fb%2F2","sourceRelease":"119-100","text":"the cost of activities conducted under such subsection during the preceding fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s6123/b/3","parentIdentifier":"/us/usc/t10/s6123/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6123%2Fb%2F3","sourceRelease":"119-100","text":"the ability of the nuclear security enterprise to convert depleted uranium fluoride hexafluoride to depleted uranium tetrafluoride.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
