{"type":"section","nativeType":"section","number":"7671i","heading":"Nonessential products containing chlorofluorocarbons","label":"7671i Nonessential products containing chlorofluorocarbons","identifier":"/us/usc/t42/s7671i","parentIdentifier":"/us/usc/t42/ch85/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Regulations","label":"a Regulations","identifier":"/us/usc/t42/s7671i/a","parentIdentifier":"/us/usc/t42/s7671i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fa","sourceRelease":"119-100","text":"The Administrator shall promulgate regulations to carry out the requirements of this section within 1 year after .November 15, 1990","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Nonessential products","label":"b Nonessential products","identifier":"/us/usc/t42/s7671i/b","parentIdentifier":"/us/usc/t42/s7671i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s7671i/b/1","parentIdentifier":"/us/usc/t42/s7671i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fb%2F1","sourceRelease":"119-100","text":"chlorofluorocarbon-propelled plastic party streamers and noise horns,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s7671i/b/2","parentIdentifier":"/us/usc/t42/s7671i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fb%2F2","sourceRelease":"119-100","text":"chlorofluorocarbon-containing cleaning fluids for noncommercial electronic and photographic equipment, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s7671i/b/3","parentIdentifier":"/us/usc/t42/s7671i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7671i/b/3/A","parentIdentifier":"/us/usc/t42/s7671i/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fb%2F3%2FA","sourceRelease":"119-100","text":"to release class I substances into the environment (including any release occurring during manufacture, use, storage, or disposal), and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7671i/b/3/B","parentIdentifier":"/us/usc/t42/s7671i/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fb%2F3%2FB","sourceRelease":"119-100","text":"to be nonessential.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Effective date","label":"c Effective date","identifier":"/us/usc/t42/s7671i/c","parentIdentifier":"/us/usc/t42/s7671i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fc","sourceRelease":"119-100","text":"Effective 24 months after , it shall be unlawful for any person to sell or distribute, or offer for sale or distribution, in interstate commerce any nonessential product to which regulations under subsection (a) implementing subsection (b) are applicable.November 15, 1990","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Other products","label":"d Other products","identifier":"/us/usc/t42/s7671i/d","parentIdentifier":"/us/usc/t42/s7671i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s7671i/d/1","parentIdentifier":"/us/usc/t42/s7671i/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7671i/d/1/A","parentIdentifier":"/us/usc/t42/s7671i/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fd%2F1%2FA","sourceRelease":"119-100","text":"any aerosol product or other pressurized dispenser which contains a class II substance; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7671i/d/1/B","parentIdentifier":"/us/usc/t42/s7671i/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fd%2F1%2FB","sourceRelease":"119-100","text":"any plastic foam product which contains, or is manufactured with, a class II substance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s7671i/d/2","parentIdentifier":"/us/usc/t42/s7671i/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7671i/d/2/A","parentIdentifier":"/us/usc/t42/s7671i/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fd%2F2%2FA","sourceRelease":"119-100","text":"the use of the aerosol product or pressurized dispenser is determined by the Administrator to be essential as a result of flammability or worker safety concerns, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7671i/d/2/B","parentIdentifier":"/us/usc/t42/s7671i/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fd%2F2%2FB","sourceRelease":"119-100","text":"the only available alternative to use of a class II substance is use of a class I substance which legally could be substituted for such class II substance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s7671i/d/3","parentIdentifier":"/us/usc/t42/s7671i/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7671i/d/3/A","parentIdentifier":"/us/usc/t42/s7671i/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fd%2F3%2FA","sourceRelease":"119-100","text":"a foam insulation product, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7671i/d/3/B","parentIdentifier":"/us/usc/t42/s7671i/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fd%2F3%2FB","sourceRelease":"119-100","text":"an integral skin, rigid, or semi-rigid foam utilized to provide for motor vehicle safety in accordance with Federal Motor Vehicle Safety Standards where no adequate substitute substance (other than a class I or class II substance) is practicable for effectively meeting such Standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Medical devices","label":"e Medical devices","identifier":"/us/usc/t42/s7671i/e","parentIdentifier":"/us/usc/t42/s7671i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7671i%2Fe","sourceRelease":"119-100","text":"Nothing in this section shall apply to any medical device as defined in .section 7671(8) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
