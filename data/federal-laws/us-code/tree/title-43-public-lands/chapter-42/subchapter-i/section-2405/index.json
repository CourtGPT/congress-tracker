{"type":"section","nativeType":"section","number":"2405","heading":"Feasibility studies","label":"2405 Feasibility studies","identifier":"/us/usc/t43/s2405","parentIdentifier":"/us/usc/t43/ch42/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t43/s2405/a","parentIdentifier":"/us/usc/t43/s2405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2405/a/1","parentIdentifier":"/us/usc/t43/s2405/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fa%2F1","sourceRelease":"119-100","text":"in cooperation with a non-Federal project entity, carry out a study to determine the feasibility of the proposed rural water supply project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2405/a/2","parentIdentifier":"/us/usc/t43/s2405/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2405/a/2/A","parentIdentifier":"/us/usc/t43/s2405/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fa%2F2%2FA","sourceRelease":"119-100","text":"developed by the non-Federal project entity, with or without support from the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2405/a/2/B","parentIdentifier":"/us/usc/t43/s2405/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fa%2F2%2FB","sourceRelease":"119-100","text":"submitted to the Secretary by the non-Federal project entity; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s2405/a/3","parentIdentifier":"/us/usc/t43/s2405/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2405/a/3/A","parentIdentifier":"/us/usc/t43/s2405/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fa%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s2405/a/3/A/i","parentIdentifier":"/us/usc/t43/s2405/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fa%2F3%2FA%2Fi","sourceRelease":"119-100","text":"the non-Federal entity is qualified to complete the feasibility study in accordance with the criteria promulgated under subsection (d); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s2405/a/3/A/ii","parentIdentifier":"/us/usc/t43/s2405/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fa%2F3%2FA%2Fii","sourceRelease":"119-100","text":"using the non-Federal project entity to conduct the feasibility study is a cost-effective alternative for completing the appraisal investigation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2405/a/3/B","parentIdentifier":"/us/usc/t43/s2405/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fa%2F3%2FB","sourceRelease":"119-100","text":"if the Secretary determines not to provide a grant to, or enter into a cooperative agreement with, a non-Federal project entity under subparagraph (A), provide to the non-Federal project entity notice of the determination, including an explanation of the reason for the determination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Review of non-Federal feasibility studies","label":"b Review of non-Federal feasibility studies","identifier":"/us/usc/t43/s2405/b","parentIdentifier":"/us/usc/t43/s2405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s2405/b/1","parentIdentifier":"/us/usc/t43/s2405/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2405/b/1/A","parentIdentifier":"/us/usc/t43/s2405/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fb%2F1%2FA","sourceRelease":"119-100","text":"in accordance with the feasibility factors described in subsection (c) and the criteria promulgated under subsection (d), assess the completeness of the feasibility study; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2405/b/1/B","parentIdentifier":"/us/usc/t43/s2405/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fb%2F1%2FB","sourceRelease":"119-100","text":"if the Secretary determines that a feasibility study is not complete, notify the non-Federal entity of the determination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Revisions","label":"2 Revisions","identifier":"/us/usc/t43/s2405/b/2","parentIdentifier":"/us/usc/t43/s2405/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fb%2F2","sourceRelease":"119-100","text":"If the Secretary determines under paragraph (1)(B) that a feasibility study is not complete, the non-Federal entity shall pay any costs associated with revising the feasibility study.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Feasibility factors","label":"c Feasibility factors","identifier":"/us/usc/t43/s2405/c","parentIdentifier":"/us/usc/t43/s2405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2405/c/1","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F1","sourceRelease":"119-100","text":"near- and long-term water demand in the area to be served by the rural water supply project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2405/c/2","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F2","sourceRelease":"119-100","text":"advancement of public health and safety of any existing rural water supply project and other benefits of the proposed rural water supply project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s2405/c/3","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F3","sourceRelease":"119-100","text":"alternative new water supplies in the study area, including any opportunities to treat and use low-quality water, nonpotable water, water reuse-based supplies, and brackish and saline waters through innovative and economically viable treatment technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t43/s2405/c/4","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F4","sourceRelease":"119-100","text":"environmental quality and source water protection issues related to the rural water supply project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t43/s2405/c/5","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2405/c/5/A","parentIdentifier":"/us/usc/t43/s2405/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F5%2FA","sourceRelease":"119-100","text":"nonstructural approaches to reduce the need for the project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2405/c/5/B","parentIdentifier":"/us/usc/t43/s2405/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F5%2FB","sourceRelease":"119-100","text":"demonstration technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t43/s2405/c/6","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F6","sourceRelease":"119-100","text":"the extent to which the project and alternatives take advantage of economic incentives and the use of market-based mechanisms;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t43/s2405/c/7","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2405/c/7/A","parentIdentifier":"/us/usc/t43/s2405/c/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F7%2FA","sourceRelease":"119-100","text":"the construction costs and projected operations, maintenance, and replacement costs of all alternatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2405/c/7/B","parentIdentifier":"/us/usc/t43/s2405/c/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F7%2FB","sourceRelease":"119-100","text":"the economic feasibility and lowest cost method of obtaining the desired results of each alternative, taking into account the Federal cost-share;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t43/s2405/c/8","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F8","sourceRelease":"119-100","text":"the availability of guaranteed loans for a proposed rural water supply project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t43/s2405/c/9","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F9","sourceRelease":"119-100","text":"the financial capability of the non-Federal project entity to pay the non-Federal project entity’s proportionate share of the design and construction costs and 100 percent of operations, maintenance, and replacement costs, including the allocation of costs to each non-Federal project entity in the case of multiple entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t43/s2405/c/10","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F10","sourceRelease":"119-100","text":"whether the non-Federal project entity has developed an operations, management, and replacement plan to assist the non-Federal project entity in establishing rates and fees for beneficiaries of the rural water supply project that includes a schedule identifying the annual operations, maintenance, and replacement costs that should be allocated to each non-Federal entity participating in the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t43/s2405/c/11","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F11","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2405/c/11/A","parentIdentifier":"/us/usc/t43/s2405/c/11","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F11%2FA","sourceRelease":"119-100","text":"the non-Federal project entity administrative organization that would implement construction, operations, maintenance, and replacement activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2405/c/11/B","parentIdentifier":"/us/usc/t43/s2405/c/11","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F11%2FB","sourceRelease":"119-100","text":"the fiscal, administrative, and operational controls to be implemented to manage the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t43/s2405/c/12","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F12","sourceRelease":"119-100","text":"the extent to which assistance for rural water supply is available under other Federal authorities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"13","heading":null,"label":"13","identifier":"/us/usc/t43/s2405/c/13","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F13","sourceRelease":"119-100","text":"the engineering, environmental, and economic activities to be undertaken to carry out the proposed rural water supply project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"14","heading":null,"label":"14","identifier":"/us/usc/t43/s2405/c/14","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F14","sourceRelease":"119-100","text":"the extent to which the project involves partnerships with other State, local, or tribal governments or Federal entities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"15","heading":null,"label":"15","identifier":"/us/usc/t43/s2405/c/15","parentIdentifier":"/us/usc/t43/s2405/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fc%2F15","sourceRelease":"119-100","text":"in the case of a project intended for Indian tribes and tribal organizations, the extent to which the project addresses the goal of economic self-sufficiency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Feasibility study criteria","label":"d Feasibility study criteria","identifier":"/us/usc/t43/s2405/d","parentIdentifier":"/us/usc/t43/s2405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s2405/d/1","parentIdentifier":"/us/usc/t43/s2405/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fd%2F1","sourceRelease":"119-100","text":"Not later than 18 months after , the Secretary shall promulgate criteria (including the feasibility factors listed under subsection (c)) under which the feasibility studies shall be assessed for completeness and appropriateness.December 22, 2006","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Inclusions","label":"2 Inclusions","identifier":"/us/usc/t43/s2405/d/2","parentIdentifier":"/us/usc/t43/s2405/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fd%2F2","sourceRelease":"119-100","text":"The Secretary shall include in the criteria promulgated under paragraph (1) methods to scale the level of effort needed to complete the feasibility assessment relative to the total size and cost of the proposed rural water supply project and reduce total costs to non-Federal entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Feasibility report","label":"e Feasibility report","identifier":"/us/usc/t43/s2405/e","parentIdentifier":"/us/usc/t43/s2405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general1So in original. No par. (2) has been enacted.1","label":"1 In general1So in original. No par. (2) has been enacted.1","identifier":"/us/usc/t43/s2405/e/1","parentIdentifier":"/us/usc/t43/s2405/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2405/e/1/A","parentIdentifier":"/us/usc/t43/s2405/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s2405/e/1/A/i","parentIdentifier":"/us/usc/t43/s2405/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s2405/e/1/A/i/I","parentIdentifier":"/us/usc/t43/s2405/e/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1%2FA%2Fi%2FI","sourceRelease":"119-100","text":"whether the rural water supply project should be authorized for construction; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s2405/e/1/A/i/II","parentIdentifier":"/us/usc/t43/s2405/e/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1%2FA%2Fi%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t43/s2405/e/1/A/i/II/aa","parentIdentifier":"/us/usc/t43/s2405/e/1/A/i/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1%2FA%2Fi%2FII%2Faa","sourceRelease":"119-100","text":"at least 25 percent of the total construction costs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t43/s2405/e/1/A/i/II/bb","parentIdentifier":"/us/usc/t43/s2405/e/1/A/i/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1%2FA%2Fi%2FII%2Fbb","sourceRelease":"119-100","text":"determined based on an analysis of the capability-to-pay information considered under subsections (c)(9) and (f); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s2405/e/1/A/ii","parentIdentifier":"/us/usc/t43/s2405/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s2405/e/1/A/ii/I","parentIdentifier":"/us/usc/t43/s2405/e/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1%2FA%2Fii%2FI","sourceRelease":"119-100","text":"what amount of grants, loan guarantees, or combination of grants and loan guarantees should be used to provide the Federal cost share;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s2405/e/1/A/ii/II","parentIdentifier":"/us/usc/t43/s2405/e/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1%2FA%2Fii%2FII","sourceRelease":"119-100","text":"a schedule that identifies the annual operations, maintenance, and replacement costs that should be allocated to each non-Federal entity participating in the rural water supply project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t43/s2405/e/1/A/ii/III","parentIdentifier":"/us/usc/t43/s2405/e/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1%2FA%2Fii%2FIII","sourceRelease":"119-100","text":"an assessment of the financial capability of each non-Federal entity participating in the rural water supply project to pay the allocated annual operation, maintenance, and replacement costs for the rural water supply project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2405/e/1/B","parentIdentifier":"/us/usc/t43/s2405/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1%2FB","sourceRelease":"119-100","text":"submit the report to the Committee on Energy and Natural Resources of the Senate and the Committee on Resources of the House of Representatives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t43/s2405/e/1/C","parentIdentifier":"/us/usc/t43/s2405/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1%2FC","sourceRelease":"119-100","text":"make the report publicly available, along with associated study documents; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t43/s2405/e/1/D","parentIdentifier":"/us/usc/t43/s2405/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fe%2F1%2FD","sourceRelease":"119-100","text":"publish in the Federal Register a notice of the availability of the results.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Capability-to-pay","label":"f Capability-to-pay","identifier":"/us/usc/t43/s2405/f","parentIdentifier":"/us/usc/t43/s2405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s2405/f/1","parentIdentifier":"/us/usc/t43/s2405/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2405/f/1/A","parentIdentifier":"/us/usc/t43/s2405/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff%2F1%2FA","sourceRelease":"119-100","text":"consider the financial capability of any non-Federal project entities participating in the rural water supply project to pay 25 percent or more of the capital construction costs of the rural water supply project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2405/f/1/B","parentIdentifier":"/us/usc/t43/s2405/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff%2F1%2FB","sourceRelease":"119-100","text":"recommend an appropriate Federal share and non-Federal share of the capital construction costs, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Factors","label":"2 Factors","identifier":"/us/usc/t43/s2405/f/2","parentIdentifier":"/us/usc/t43/s2405/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2405/f/2/A","parentIdentifier":"/us/usc/t43/s2405/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff%2F2%2FA","sourceRelease":"119-100","text":"per capita income;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2405/f/2/B","parentIdentifier":"/us/usc/t43/s2405/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff%2F2%2FB","sourceRelease":"119-100","text":"median household income;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t43/s2405/f/2/C","parentIdentifier":"/us/usc/t43/s2405/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff%2F2%2FC","sourceRelease":"119-100","text":"the poverty rate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t43/s2405/f/2/D","parentIdentifier":"/us/usc/t43/s2405/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff%2F2%2FD","sourceRelease":"119-100","text":"the ability of the non-Federal project entity to raise tax revenues or assess fees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t43/s2405/f/2/E","parentIdentifier":"/us/usc/t43/s2405/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff%2F2%2FE","sourceRelease":"119-100","text":"the strength of the balance sheet of the non-Federal project entity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t43/s2405/f/2/F","parentIdentifier":"/us/usc/t43/s2405/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff%2F2%2FF","sourceRelease":"119-100","text":"the existing cost of water in the region.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Indian tribes","label":"3 Indian tribes","identifier":"/us/usc/t43/s2405/f/3","parentIdentifier":"/us/usc/t43/s2405/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2405/f/3/A","parentIdentifier":"/us/usc/t43/s2405/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff%2F3%2FA","sourceRelease":"119-100","text":"the costs allocated to the beneficiaries; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2405/f/3/B","parentIdentifier":"/us/usc/t43/s2405/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Ff%2F3%2FB","sourceRelease":"119-100","text":"an appropriate portion of the costs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Cost-sharing requirement","label":"g Cost-sharing requirement","identifier":"/us/usc/t43/s2405/g","parentIdentifier":"/us/usc/t43/s2405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s2405/g/1","parentIdentifier":"/us/usc/t43/s2405/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fg%2F1","sourceRelease":"119-100","text":"Except as otherwise provided in this subsection, the Federal share of the cost of a feasibility study carried out under this section shall not exceed 50 percent of the study costs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Form","label":"2 Form","identifier":"/us/usc/t43/s2405/g/2","parentIdentifier":"/us/usc/t43/s2405/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fg%2F2","sourceRelease":"119-100","text":"The non-Federal share under paragraph (1) may be in the form of any in-kind services that the Secretary determines would contribute substantially toward the conduct and completion of the study.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Financial hardship","label":"3 Financial hardship","identifier":"/us/usc/t43/s2405/g/3","parentIdentifier":"/us/usc/t43/s2405/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fg%2F3","sourceRelease":"119-100","text":"The Secretary may increase the Federal share of the costs of a feasibility study if the Secretary determines, based on a demonstration of financial hardship, that the non-Federal participant is unable to contribute at least 50 percent of the costs of the study.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Larger communities","label":"4 Larger communities","identifier":"/us/usc/t43/s2405/g/4","parentIdentifier":"/us/usc/t43/s2405/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fg%2F4","sourceRelease":"119-100","text":"In conducting a feasibility study of a rural water supply system that includes a community with a population in excess of 50,000 inhabitants, the Secretary may require the non-Federal project entity to pay more than 50 percent of the costs of the study.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Consultation and cooperation","label":"h Consultation and cooperation","identifier":"/us/usc/t43/s2405/h","parentIdentifier":"/us/usc/t43/s2405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2405%2Fh","sourceRelease":"119-100","text":"In addition to the non-Federal project entity, the Secretary shall consult and cooperate with appropriate Federal, State, tribal, regional, and local authorities during the conduct of each feasibility assessment and development of the feasibility report conducted under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
