{"type":"section","nativeType":"section","number":"4953","heading":"Tax on excess contributions to black lung benefit trusts","label":"4953 Tax on excess contributions to black lung benefit trusts","identifier":"/us/usc/t26/s4953","parentIdentifier":"/us/usc/t26/stD/ch42/schB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4953","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Tax imposed","label":"a Tax imposed","identifier":"/us/usc/t26/s4953/a","parentIdentifier":"/us/usc/t26/s4953","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4953%2Fa","sourceRelease":"119-100","text":"There is hereby imposed for each taxable year a tax in an amount equal to 5 percent of the amount of the excess contributions made by a person to or under a trust or trusts described in section 501(c)(21). The tax imposed by this subsection shall be paid by the person making the excess contribution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Excess contribution","label":"b Excess contribution","identifier":"/us/usc/t26/s4953/b","parentIdentifier":"/us/usc/t26/s4953","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4953%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s4953/b/1","parentIdentifier":"/us/usc/t26/s4953/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4953%2Fb%2F1","sourceRelease":"119-100","text":"the amount by which the amount contributed for the taxable year to a trust or trusts described in section 501(c)(21) exceeds the amount of the deduction allowable to such person for such contributions for the taxable year under section 192, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s4953/b/2","parentIdentifier":"/us/usc/t26/s4953/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4953%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s4953/b/2/A","parentIdentifier":"/us/usc/t26/s4953/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4953%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the excess of the maximum amount allowable as a deduction under section 192 for the taxable year over the amount contributed to the trust or trusts for the taxable year, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s4953/b/2/B","parentIdentifier":"/us/usc/t26/s4953/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4953%2Fb%2F2%2FB","sourceRelease":"119-100","text":"amounts distributed from the trust to the contributor which were excess contributions for the preceding taxable year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Treatment of withdrawal of excess contributions","label":"c Treatment of withdrawal of excess contributions","identifier":"/us/usc/t26/s4953/c","parentIdentifier":"/us/usc/t26/s4953","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4953%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s4953/c/1","parentIdentifier":"/us/usc/t26/s4953/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4953%2Fc%2F1","sourceRelease":"119-100","text":"an act of self-dealing (within the meaning of section 4951),","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s4953/c/2","parentIdentifier":"/us/usc/t26/s4953/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4953%2Fc%2F2","sourceRelease":"119-100","text":"a taxable expenditure (within the meaning of section 4952), or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t26/s4953/c/3","parentIdentifier":"/us/usc/t26/s4953/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4953%2Fc%2F3","sourceRelease":"119-100","text":"an act contrary to the purposes for which the trust is exempt from taxation under section 501(a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
