{"type":"section","nativeType":"section","number":"410cc–23","heading":"Agreements and technical assistance","label":"410cc–23 Agreements and technical assistance","identifier":"/us/usc/t16/s410cc–23","parentIdentifier":"/us/usc/t16/ch1/schLIX–A/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cc%E2%80%9323","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Interpretative exhibits or programs","label":"a Interpretative exhibits or programs","identifier":"/us/usc/t16/s410cc–23/a","parentIdentifier":"/us/usc/t16/s410cc–23","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cc%E2%80%9323%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410cc–23/a/1","parentIdentifier":"/us/usc/t16/s410cc–23/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cc%E2%80%9323%2Fa%2F1","sourceRelease":"119-100","text":"the public may have access to such property at specified, reasonable times for purposes of viewing such property or the exhibits or attending the programs established by the Secretary under this subsection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410cc–23/a/2","parentIdentifier":"/us/usc/t16/s410cc–23/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cc%E2%80%9323%2Fa%2F2","sourceRelease":"119-100","text":"the Secretary may make such minor improvements to such property as the Secretary deems necessary to enhance the public use and enjoyment of such property, exhibits, and programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Request for assistance","label":"b Request for assistance","identifier":"/us/usc/t16/s410cc–23/b","parentIdentifier":"/us/usc/t16/s410cc–23","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cc%E2%80%9323%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410cc–23/b/1","parentIdentifier":"/us/usc/t16/s410cc–23/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cc%E2%80%9323%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410cc–23/b/1/A","parentIdentifier":"/us/usc/t16/s410cc–23/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cc%E2%80%9323%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the city of Lowell to assist the city in establishing regulations or laws consistent with the standards and criteria established pursuant to ; andsection 410cc–32(e) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410cc–23/b/1/B","parentIdentifier":"/us/usc/t16/s410cc–23/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cc%E2%80%9323%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the Commission to assist the Commission in establishing the index and the standards and criteria required by .section 410cc–32 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410cc–23/b/2","parentIdentifier":"/us/usc/t16/s410cc–23/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410cc%E2%80%9323%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary may provide to any owner of property within the park or preservation district, the Commission, the Commonwealth of Massachusetts, the city of Lowell, and any other Federal entity or any institution such technical assistance as the Secretary considers appropriate to carry out the purpose of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
