{"type":"section","nativeType":"section","number":"6703","heading":"National culvert removal, replacement, and restoration grant program","label":"6703 National culvert removal, replacement, and restoration grant program","identifier":"/us/usc/t49/s6703","parentIdentifier":"/us/usc/t49/stIII/ch67","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Definitions","label":"a .—Definitions","identifier":"/us/usc/t49/s6703/a","parentIdentifier":"/us/usc/t49/s6703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Director","label":"1 .—Director","identifier":"/us/usc/t49/s6703/a/1","parentIdentifier":"/us/usc/t49/s6703/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fa%2F1","sourceRelease":"119-100","text":"The term “Director” means the Director of the United States Fish and Wildlife Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Indian tribe","label":"2 .—Indian tribe","identifier":"/us/usc/t49/s6703/a/2","parentIdentifier":"/us/usc/t49/s6703/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fa%2F2","sourceRelease":"119-100","text":"The term “Indian Tribe” has the meaning given the term in section 4 of the Indian Self-Determination and Education Assistance Act ().25 U.S.C. 5304","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Program","label":"3 .—Program","identifier":"/us/usc/t49/s6703/a/3","parentIdentifier":"/us/usc/t49/s6703/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fa%2F3","sourceRelease":"119-100","text":"The term “program” means the annual competitive grant program established under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Secretary","label":"4 .—Secretary","identifier":"/us/usc/t49/s6703/a/4","parentIdentifier":"/us/usc/t49/s6703/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fa%2F4","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Transportation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":".—Undersecretary","label":"5 .—Undersecretary","identifier":"/us/usc/t49/s6703/a/5","parentIdentifier":"/us/usc/t49/s6703/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fa%2F5","sourceRelease":"119-100","text":"The term “Undersecretary” means the Undersecretary of Commerce for Oceans and Atmosphere.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Establishment","label":"b .—Establishment","identifier":"/us/usc/t49/s6703/b","parentIdentifier":"/us/usc/t49/s6703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s6703/b/1","parentIdentifier":"/us/usc/t49/s6703/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fb%2F1","sourceRelease":"119-100","text":"would meaningfully improve or restore fish passage for anadromous fish; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s6703/b/2","parentIdentifier":"/us/usc/t49/s6703/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s6703/b/2/A","parentIdentifier":"/us/usc/t49/s6703/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fb%2F2%2FA","sourceRelease":"119-100","text":"infrastructure to facilitate fish passage around or over the weir; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s6703/b/2/B","parentIdentifier":"/us/usc/t49/s6703/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fb%2F2%2FB","sourceRelease":"119-100","text":"weir improvements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Eligible Entities","label":"c .—Eligible Entities","identifier":"/us/usc/t49/s6703/c","parentIdentifier":"/us/usc/t49/s6703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s6703/c/1","parentIdentifier":"/us/usc/t49/s6703/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fc%2F1","sourceRelease":"119-100","text":"a State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s6703/c/2","parentIdentifier":"/us/usc/t49/s6703/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fc%2F2","sourceRelease":"119-100","text":"a unit of local government; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s6703/c/3","parentIdentifier":"/us/usc/t49/s6703/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fc%2F3","sourceRelease":"119-100","text":"an Indian Tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Grant Selection Process","label":"d .—Grant Selection Process","identifier":"/us/usc/t49/s6703/d","parentIdentifier":"/us/usc/t49/s6703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fd","sourceRelease":"119-100","text":"The Secretary, in consultation with the Undersecretary and the Director, shall establish a process for determining criteria for awarding grants under the program, subject to subsection (e).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Prioritization","label":"e .—Prioritization","identifier":"/us/usc/t49/s6703/e","parentIdentifier":"/us/usc/t49/s6703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s6703/e/1","parentIdentifier":"/us/usc/t49/s6703/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s6703/e/1/A","parentIdentifier":"/us/usc/t49/s6703/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fe%2F1%2FA","sourceRelease":"119-100","text":"anadromous fish stocks listed as an endangered species or a threatened species under section 4 of the Endangered Species Act of 1973 ();16 U.S.C. 1533","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s6703/e/1/B","parentIdentifier":"/us/usc/t49/s6703/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fe%2F1%2FB","sourceRelease":"119-100","text":"anadromous fish stocks identified by the Undersecretary or the Director that could reasonably become listed as an endangered species or a threatened species under that section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s6703/e/1/C","parentIdentifier":"/us/usc/t49/s6703/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fe%2F1%2FC","sourceRelease":"119-100","text":"anadromous fish stocks identified by the Undersecretary or the Director as prey for endangered species, threatened species, or protected species, including Southern resident orcas (Orcinus orcas); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t49/s6703/e/1/D","parentIdentifier":"/us/usc/t49/s6703/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fe%2F1%2FD","sourceRelease":"119-100","text":"anadromous fish stocks identified by the Undersecretary or the Director as climate resilient stocks; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s6703/e/2","parentIdentifier":"/us/usc/t49/s6703/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fe%2F2","sourceRelease":"119-100","text":"projects that would open up more than 200 meters of upstream habitat before the end of the natural habitat.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Federal Share","label":"f .—Federal Share","identifier":"/us/usc/t49/s6703/f","parentIdentifier":"/us/usc/t49/s6703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Ff","sourceRelease":"119-100","text":"The Federal share of the cost of a project carried out with a grant to a State or a unit of local government under the program shall be not more than 80 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":".—Technical Assistance","label":"g .—Technical Assistance","identifier":"/us/usc/t49/s6703/g","parentIdentifier":"/us/usc/t49/s6703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fg","sourceRelease":"119-100","text":"The Secretary, in consultation with the Undersecretary and the Director, shall develop a process to provide technical assistance to Indian Tribes and underserved communities to assist in the project design and grant process and procedures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":".—Administrative Expenses","label":"h .—Administrative Expenses","identifier":"/us/usc/t49/s6703/h","parentIdentifier":"/us/usc/t49/s6703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fh","sourceRelease":"119-100","text":"Of the amounts made available for each fiscal year to carry out the program, the Secretary, the Undersecretary, and the Director may use not more than 2 percent to pay the administrative expenses necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"i","heading":".—Authorization of Appropriations","label":"i .—Authorization of Appropriations","identifier":"/us/usc/t49/s6703/i","parentIdentifier":"/us/usc/t49/s6703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6703%2Fi","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out the program $800,000,000 for each of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
