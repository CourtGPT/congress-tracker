,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Revolving fund","label":"b Revolving fund","identifier":"/us/usc/t2/s1824a/b","parentIdentifier":"/us/usc/t2/s1824a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1824a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t2/s1824a/b/1","parentIdentifier":"/us/usc/t2/s1824a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1824a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t2/s1824a/b/1/A","parentIdentifier":"/us/usc/t2/s1824a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1824a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"proceeds from the sale of recyclable materials under the program established under this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t2/s1824a/b/1/B","parentIdentifier":"/us/usc/t2/s1824a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1824a%2Fb%2F1%2FB","sourceRelease":"119-100","text":"such amounts as may be appropriated under law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Use of fund","label":"2 Use of fund","identifier":"/us/usc/t2/s1824a/b/2","parentIdentifier":"/us/usc/t2/s1824a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1824a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"childre