%2Ft33%2Fs598c%2Fd%2F3","sourceRelease":"119-100","text":"It is the sense of Congress that, for the purpose of constructing and maintaining a project for hurricane and storm damage risk reduction, the minimum estate necessary for easements may not exceed the life of the project nor be less than 50 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Savings clause","label":"e Savings clause","identifier":"/us/usc/t33/s598c/e","parentIdentifier":"/us/usc/t33/s598c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs598c%2Fe","sourceRelease":"119-100","text":"Nothing in this section may be construed to affect the requirements of .section 2213(d) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
