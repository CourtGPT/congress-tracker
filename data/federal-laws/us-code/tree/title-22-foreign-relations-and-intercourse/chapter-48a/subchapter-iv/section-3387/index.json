{"type":"section","nativeType":"section","number":"3387","heading":"Funding","label":"3387 Funding","identifier":"/us/usc/t22/s3387","parentIdentifier":"/us/usc/t22/ch48A/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3387","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authorization of appropriations","label":"a Authorization of appropriations","identifier":"/us/usc/t22/s3387/a","parentIdentifier":"/us/usc/t22/s3387","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3387%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s3387/a/1","parentIdentifier":"/us/usc/t22/s3387/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3387%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s3387/a/1/A","parentIdentifier":"/us/usc/t22/s3387/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3387%2Fa%2F1%2FA","sourceRelease":"119-100","text":"$500,000 should be used to launch the Taiwan Fellowship Program through a competitive cooperative agreement with an appropriate implementing partner;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s3387/a/1/B","parentIdentifier":"/us/usc/t22/s3387/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3387%2Fa%2F1%2FB","sourceRelease":"119-100","text":"$2,300,000 should be used to fund a cooperative agreement with an appropriate implementing partner; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s3387/a/1/C","parentIdentifier":"/us/usc/t22/s3387/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3387%2Fa%2F1%2FC","sourceRelease":"119-100","text":"$100,000 should be used for management expenses of the American Institute in Taiwan related to the management of the Taiwan Fellowship Program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s3387/a/2","parentIdentifier":"/us/usc/t22/s3387/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3387%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s3387/a/2/A","parentIdentifier":"/us/usc/t22/s3387/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3387%2Fa%2F2%2FA","sourceRelease":"119-100","text":"$2,300,000 should be used for a cooperative agreement to the appropriate implementing partner; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s3387/a/2/B","parentIdentifier":"/us/usc/t22/s3387/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3387%2Fa%2F2%2FB","sourceRelease":"119-100","text":"$100,000 should be used for management expenses of the American Institute in Taiwan related to the management of the Taiwan Fellowship Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Private sources","label":"b Private sources","identifier":"/us/usc/t22/s3387/b","parentIdentifier":"/us/usc/t22/s3387","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3387%2Fb","sourceRelease":"119-100","text":"The implementing partner selected to implement the Taiwan Fellowship Program may accept, use, and dispose of gifts or donations of services or property in carrying out such program, subject to the review and approval of the American Institute in Taiwan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
