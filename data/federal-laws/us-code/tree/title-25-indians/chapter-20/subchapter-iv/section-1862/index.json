{"type":"section","nativeType":"section","number":"1862","heading":"Tribally controlled postsecondary career and technical institutions program","label":"1862 Tribally controlled postsecondary career and technical institutions program","identifier":"/us/usc/t25/s1862","parentIdentifier":"/us/usc/t25/ch20/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t25/s1862/a","parentIdentifier":"/us/usc/t25/s1862","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s1862/a/1","parentIdentifier":"/us/usc/t25/s1862/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fa%2F1","sourceRelease":"119-100","text":"subject to subsection (b), select two tribally controlled postsecondary career and technical institutions to receive assistance under this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s1862/a/2","parentIdentifier":"/us/usc/t25/s1862/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fa%2F2","sourceRelease":"119-100","text":"provide funding to the selected tribally controlled postsecondary career and technical institutions to pay the costs (including institutional support costs) of operating postsecondary career and technical education programs for Indian students at the tribally controlled postsecondary career and technical institutions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Selection of certain institutions","label":"b Selection of certain institutions","identifier":"/us/usc/t25/s1862/b","parentIdentifier":"/us/usc/t25/s1862","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Requirement","label":"1 Requirement","identifier":"/us/usc/t25/s1862/b/1","parentIdentifier":"/us/usc/t25/s1862/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fb%2F1","sourceRelease":"119-100","text":"For each fiscal year during which the Secretary determines that a tribally controlled postsecondary career and technical institution described in paragraph (2) meets the definition referred to in , the Secretary shall select that tribally controlled postsecondary career and technical institution under subsection (a)(1) to receive funding under this section.section 1861 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Institutions","label":"2 Institutions","identifier":"/us/usc/t25/s1862/b/2","parentIdentifier":"/us/usc/t25/s1862/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1862/b/2/A","parentIdentifier":"/us/usc/t25/s1862/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the United Tribes Technical College; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1862/b/2/B","parentIdentifier":"/us/usc/t25/s1862/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the Navajo Technical College.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Method of payment","label":"c Method of payment","identifier":"/us/usc/t25/s1862/c","parentIdentifier":"/us/usc/t25/s1862","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fc","sourceRelease":"119-100","text":"For each applicable fiscal year, the Secretary shall provide funding under this section to each tribally controlled postsecondary career and technical institution selected for the fiscal year under subsection (a)(1) in a lump sum payment for the fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Distribution","label":"d Distribution","identifier":"/us/usc/t25/s1862/d","parentIdentifier":"/us/usc/t25/s1862","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s1862/d/1","parentIdentifier":"/us/usc/t25/s1862/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1862/d/1/A","parentIdentifier":"/us/usc/t25/s1862/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the total amount appropriated for the tribally controlled postsecondary career and technical institution for fiscal year 2006; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1862/d/1/B","parentIdentifier":"/us/usc/t25/s1862/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fd%2F1%2FB","sourceRelease":"119-100","text":"the total amount appropriated for the tribally controlled postsecondary career and technical institution for fiscal year 2008.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Excess amounts","label":"2 Excess amounts","identifier":"/us/usc/t25/s1862/d/2","parentIdentifier":"/us/usc/t25/s1862/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1862/d/2/A","parentIdentifier":"/us/usc/t25/s1862/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fd%2F2%2FA","sourceRelease":"119-100","text":"dividing the excess amount by the aggregate Indian student count (as defined in ) of such institutions for the prior academic year; andsection 2327(h) of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1862/d/2/B","parentIdentifier":"/us/usc/t25/s1862/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1862%2Fd%2F2%2FB","sourceRelease":"119-100","text":"multiplying the quotient described in subparagraph (A) by the Indian student count of each such institution for the prior academic year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
