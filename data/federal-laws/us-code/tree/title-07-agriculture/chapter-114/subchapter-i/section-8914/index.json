 this titleDec. 20, 2018"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t7/s8914/a","parentIdentifier":"/us/usc/t7/s8914","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Animal","label":"1 Animal","identifier":"/us/usc/t7/s8914/a/1","parentIdentifier":"/us/usc/t7/s8914/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F1","sourceRelease":"119-100","text":"The term “animal” has the meaning given the term in .section 8302 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Disease or pest of concern","label":"2 Disease or pest of concern","identifier":"/us/usc/t7/s8914/a/2","parentIdentifier":"/us/usc/t7/s8914/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s8914/a/2/A","parentIdentifier":"/us/usc/t7/s8914/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s8914/a/2/A/i","parentIdentifier":"/us/usc/t7/s8914/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8914%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"a transboundary disease; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{