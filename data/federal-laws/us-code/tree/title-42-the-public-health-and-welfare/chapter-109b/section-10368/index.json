{"type":"section","nativeType":"section","number":"10368","heading":"National water availability and use assessment program","label":"10368 National water availability and use assessment program","identifier":"/us/usc/t42/s10368","parentIdentifier":"/us/usc/t42/ch109B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t42/s10368/a","parentIdentifier":"/us/usc/t42/s10368","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s10368/a/1","parentIdentifier":"/us/usc/t42/s10368/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fa%2F1","sourceRelease":"119-100","text":"to provide a more accurate assessment of the status of the water resources of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s10368/a/2","parentIdentifier":"/us/usc/t42/s10368/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fa%2F2","sourceRelease":"119-100","text":"to assist in the determination of the quantity of water that is available for beneficial uses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s10368/a/3","parentIdentifier":"/us/usc/t42/s10368/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fa%2F3","sourceRelease":"119-100","text":"to assist in the determination of the quality of the water resources of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s10368/a/4","parentIdentifier":"/us/usc/t42/s10368/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fa%2F4","sourceRelease":"119-100","text":"to identify long-term trends in water availability;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s10368/a/5","parentIdentifier":"/us/usc/t42/s10368/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fa%2F5","sourceRelease":"119-100","text":"to use each long-term trend described in paragraph (4) to provide a more accurate assessment of the change in the availability of water in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s10368/a/6","parentIdentifier":"/us/usc/t42/s10368/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fa%2F6","sourceRelease":"119-100","text":"to develop the basis for an improved ability to forecast the availability of water for future economic, energy production, and environmental uses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Program elements","label":"b Program elements","identifier":"/us/usc/t42/s10368/b","parentIdentifier":"/us/usc/t42/s10368","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Water use","label":"1 Water use","identifier":"/us/usc/t42/s10368/b/1","parentIdentifier":"/us/usc/t42/s10368/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s10368/b/1/A","parentIdentifier":"/us/usc/t42/s10368/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the maintenance of a comprehensive national water use inventory to enhance the level of understanding with respect to the effects of spatial and temporal patterns of water use on the availability and sustainable use of water resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s10368/b/1/B","parentIdentifier":"/us/usc/t42/s10368/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the incorporation of water use science principles, with an emphasis on applied research and statistical estimation techniques in the assessment of water use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s10368/b/1/C","parentIdentifier":"/us/usc/t42/s10368/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the integration of any dataset maintained by any other Federal or State agency into the dataset maintained by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s10368/b/1/D","parentIdentifier":"/us/usc/t42/s10368/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F1%2FD","sourceRelease":"119-100","text":"a focus on the scientific integration of any data relating to water use, water flow, or water quality to generate relevant information relating to the impact of human activity on water and ecological resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Water availability","label":"2 Water availability","identifier":"/us/usc/t42/s10368/b/2","parentIdentifier":"/us/usc/t42/s10368/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s10368/b/2/A","parentIdentifier":"/us/usc/t42/s10368/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s10368/b/2/A/i","parentIdentifier":"/us/usc/t42/s10368/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"surface water indicators, such as streamflow and surface water storage measures (including lakes, reservoirs, perennial snowfields, and glaciers);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s10368/b/2/A/ii","parentIdentifier":"/us/usc/t42/s10368/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s10368/b/2/A/ii/I","parentIdentifier":"/us/usc/t42/s10368/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FA%2Fii%2FI","sourceRelease":"119-100","text":"natural recharge;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s10368/b/2/A/ii/II","parentIdentifier":"/us/usc/t42/s10368/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FA%2Fii%2FII","sourceRelease":"119-100","text":"withdrawals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t42/s10368/b/2/A/ii/III","parentIdentifier":"/us/usc/t42/s10368/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FA%2Fii%2FIII","sourceRelease":"119-100","text":"saltwater intrusion;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t42/s10368/b/2/A/ii/IV","parentIdentifier":"/us/usc/t42/s10368/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FA%2Fii%2FIV","sourceRelease":"119-100","text":"mine dewatering;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t42/s10368/b/2/A/ii/V","parentIdentifier":"/us/usc/t42/s10368/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FA%2Fii%2FV","sourceRelease":"119-100","text":"land drainage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VI","heading":null,"label":"VI","identifier":"/us/usc/t42/s10368/b/2/A/ii/VI","parentIdentifier":"/us/usc/t42/s10368/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FA%2Fii%2FVI","sourceRelease":"119-100","text":"artificial recharge; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VII","heading":null,"label":"VII","identifier":"/us/usc/t42/s10368/b/2/A/ii/VII","parentIdentifier":"/us/usc/t42/s10368/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FA%2Fii%2FVII","sourceRelease":"119-100","text":"other relevant factors, as determined by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s10368/b/2/A/iii","parentIdentifier":"/us/usc/t42/s10368/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"impaired surface water and groundwater supplies that are known, accessible, and used to meet ongoing water demands;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s10368/b/2/B","parentIdentifier":"/us/usc/t42/s10368/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s10368/b/2/B/i","parentIdentifier":"/us/usc/t42/s10368/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"is comprised of maps, reports, and other forms of interpreted data;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s10368/b/2/B/ii","parentIdentifier":"/us/usc/t42/s10368/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"provides electronic access to the archived data of the national database; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s10368/b/2/B/iii","parentIdentifier":"/us/usc/t42/s10368/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"provides for real-time data collection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s10368/b/2/C","parentIdentifier":"/us/usc/t42/s10368/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fb%2F2%2FC","sourceRelease":"119-100","text":"developing and applying predictive modeling tools that integrate groundwater, surface water, and ecological systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Grant program","label":"c Grant program","identifier":"/us/usc/t42/s10368/c","parentIdentifier":"/us/usc/t42/s10368","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Authority of Secretary","label":"1 Authority of Secretary","identifier":"/us/usc/t42/s10368/c/1","parentIdentifier":"/us/usc/t42/s10368/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s10368/c/1/A","parentIdentifier":"/us/usc/t42/s10368/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fc%2F1%2FA","sourceRelease":"119-100","text":"developing water use and availability datasets that are integrated with each appropriate dataset developed or maintained by the Secretary; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s10368/c/1/B","parentIdentifier":"/us/usc/t42/s10368/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fc%2F1%2FB","sourceRelease":"119-100","text":"integrating any water use or water availability dataset of the State water resource agency into each appropriate dataset developed or maintained by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Criteria","label":"2 Criteria","identifier":"/us/usc/t42/s10368/c/2","parentIdentifier":"/us/usc/t42/s10368/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s10368/c/2/A","parentIdentifier":"/us/usc/t42/s10368/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fc%2F2%2FA","sourceRelease":"119-100","text":"is in compliance with each quality and conformity standard established by the Secretary to ensure that the data will be capable of integration with any national dataset; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s10368/c/2/B","parentIdentifier":"/us/usc/t42/s10368/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fc%2F2%2FB","sourceRelease":"119-100","text":"will enhance the ability of the officials of the State or the State water resource agency to carry out each water management and regulatory responsibility of the officials of the State in accordance with each applicable law of the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Maximum amount","label":"3 Maximum amount","identifier":"/us/usc/t42/s10368/c/3","parentIdentifier":"/us/usc/t42/s10368/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fc%2F3","sourceRelease":"119-100","text":"The amount of a grant provided to a State water resource agency under paragraph (1) shall be an amount not more than $250,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Report","label":"d Report","identifier":"/us/usc/t42/s10368/d","parentIdentifier":"/us/usc/t42/s10368","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s10368/d/1","parentIdentifier":"/us/usc/t42/s10368/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s10368/d/1/A","parentIdentifier":"/us/usc/t42/s10368/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fd%2F1%2FA","sourceRelease":"119-100","text":"historic trends and annual updates of river basin inflows and outflows;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s10368/d/1/B","parentIdentifier":"/us/usc/t42/s10368/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fd%2F1%2FB","sourceRelease":"119-100","text":"surface water storage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s10368/d/1/C","parentIdentifier":"/us/usc/t42/s10368/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fd%2F1%2FC","sourceRelease":"119-100","text":"groundwater reserves; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s10368/d/1/D","parentIdentifier":"/us/usc/t42/s10368/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fd%2F1%2FD","sourceRelease":"119-100","text":"estimates of undeveloped potential resources (including saline and brackish water and wastewater);","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s10368/d/2","parentIdentifier":"/us/usc/t42/s10368/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fd%2F2","sourceRelease":"119-100","text":"significant trends affecting water availability, including each documented or projected impact to the availability of water as a result of global climate change;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s10368/d/3","parentIdentifier":"/us/usc/t42/s10368/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s10368/d/3/A","parentIdentifier":"/us/usc/t42/s10368/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fd%2F3%2FA","sourceRelease":"119-100","text":"the agricultural sector;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s10368/d/3/B","parentIdentifier":"/us/usc/t42/s10368/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fd%2F3%2FB","sourceRelease":"119-100","text":"municipalities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s10368/d/3/C","parentIdentifier":"/us/usc/t42/s10368/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10368%2Fd%2F3%2FC","sourceRelease":"119-100","text":"the industrial sector;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42