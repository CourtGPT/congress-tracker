{"type":"section","nativeType":"section","number":"460mmm–5","heading":"Maps and legal descriptions","label":"460mmm–5 Maps and legal descriptions","identifier":"/us/usc/t16/s460mmm–5","parentIdentifier":"/us/usc/t16/ch1/schCXXIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460mmm%E2%80%935","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s460mmm–5/a","parentIdentifier":"/us/usc/t16/s460mmm–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460mmm%E2%80%935%2Fa","sourceRelease":"119-100","text":"As soon as practicable after , the Secretary shall submit to Congress a copy of the Map and a legal description of the Conservation Area and of the Wilderness.October 24, 2000","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Force and effect","label":"b Force and effect","identifier":"/us/usc/t16/s460mmm–5/b","parentIdentifier":"/us/usc/t16/s460mmm–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460mmm%E2%80%935%2Fb","sourceRelease":"119-100","text":"The Map and legal descriptions shall have the same force and effect as if included in this subchapter, except that the Secretary may correct clerical and typographical errors in the Map and the legal descriptions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Public availability","label":"c Public availability","identifier":"/us/usc/t16/s460mmm–5/c","parentIdentifier":"/us/usc/t16/s460mmm–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460mmm%E2%80%935%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460mmm–5/c/1","parentIdentifier":"/us/usc/t16/s460mmm–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460mmm%E2%80%935%2Fc%2F1","sourceRelease":"119-100","text":"the Office of the Director of the Bureau of Land Management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460mmm–5/c/2","parentIdentifier":"/us/usc/t16/s460mmm–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460mmm%E2%80%935%2Fc%2F2","sourceRelease":"119-100","text":"the Grand Junction District Office of the Bureau of Land Management in Colorado;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s460mmm–5/c/3","parentIdentifier":"/us/usc/t16/s460mmm–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460mmm%E2%80%935%2Fc%2F3","sourceRelease":"119-100","text":"the appropriate office of the Bureau of Land Management in Colorado, if the Grand Junction District Office is not deemed the appropriate office; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s460mmm–5/c/4","parentIdentifier":"/us/usc/t16/s460mmm–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460mmm%E2%80%935%2Fc%2F4","sourceRelease":"119-100","text":"the appropriate office of the Bureau of Land Management in Utah.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Map controlling","label":"d Map controlling","identifier":"/us/usc/t16/s460mmm–5/d","parentIdentifier":"/us/usc/t16/s460mmm–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460mmm%E2%80%935%2Fd","sourceRelease":"119-100","text":"Subject to section 460mmm–4()(3) of this title, in the case of a discrepancy between the Map and the descriptions, the Map shall control.l1So in original. Probably should be section “460mmm–4()(5)”.1l","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
