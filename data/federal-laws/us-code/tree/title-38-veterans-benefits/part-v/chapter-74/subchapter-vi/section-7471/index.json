{"type":"section","nativeType":"section","number":"7471","heading":"Designation of Regional Medical Education Centers","label":"7471 Designation of Regional Medical Education Centers","identifier":"/us/usc/t38/s7471","parentIdentifier":"/us/usc/t38/ptV/ch74/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7471","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsProvisions similar to those in this section were contained in prior to the repeal of that section as part of the complete revision of chapter 73 of this title by .section 4121 of this titlePub. L. 102–40"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t38/s7471/a","parentIdentifier":"/us/usc/t38/s7471","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7471%2Fa","sourceRelease":"119-100","text":"In carrying out the Secretary’s functions under with regard to the training of health personnel, the Secretary shall implement a program under which the Secretary shall designate as Regional Medical Education Centers such Department hospitals as the Secretary determines appropriate to carry out the provisions of this subchapter.section 7302 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t38/s7471/b","parentIdentifier":"/us/usc/t38/s7471","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7471%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s7471/b/1","parentIdentifier":"/us/usc/t38/s7471/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7471%2Fb%2F1","sourceRelease":"119-100","text":"The teaching of newly developed medical skills and the use of newly developed medical technologies and equipment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s7471/b/2","parentIdentifier":"/us/usc/t38/s7471/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7471%2Fb%2F2","sourceRelease":"119-100","text":"Advanced clinical instruction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s7471/b/3","parentIdentifier":"/us/usc/t38/s7471/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7471%2Fb%2F3","sourceRelease":"119-100","text":"The opportunity for conducting clinical investigations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s7471/b/4","parentIdentifier":"/us/usc/t38/s7471/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7471%2Fb%2F4","sourceRelease":"119-100","text":"Clinical demonstrations in the use of new types of health personnel and in the better use of the skills of existing health personnel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t38/s7471/b/5","parentIdentifier":"/us/usc/t38/s7471/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7471%2Fb%2F5","sourceRelease":"119-100","text":"Routine verification of basic medical skills and, where determined necessary, remediation of any deficiency in such skills.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
