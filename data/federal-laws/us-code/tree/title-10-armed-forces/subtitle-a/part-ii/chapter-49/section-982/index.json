{"type":"section","nativeType":"section","number":"982","heading":"Members: service on State and local juries","label":"982 Members: service on State and local juries","identifier":"/us/usc/t10/s982","parentIdentifier":"/us/usc/t10/stA/ptII/ch49","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs982","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t10/s982/a","parentIdentifier":"/us/usc/t10/s982","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs982%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s982/a/1","parentIdentifier":"/us/usc/t10/s982/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs982%2Fa%2F1","sourceRelease":"119-100","text":"would unreasonably interfere with the performance of the member’s military duties; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s982/a/2","parentIdentifier":"/us/usc/t10/s982/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs982%2Fa%2F2","sourceRelease":"119-100","text":"would adversely affect the readiness of the unit, command, or activity to which the member is assigned.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t10/s982/b","parentIdentifier":"/us/usc/t10/s982","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs982%2Fb","sourceRelease":"119-100","text":"A determination by the Secretary concerned under this section is conclusive.