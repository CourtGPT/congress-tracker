{"type":"section","nativeType":"section","number":"8003","heading":"Statement of policy","label":"8003 Statement of policy","identifier":"/us/usc/t16/s8003","parentIdentifier":"/us/usc/t16/ch99","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s8003/1","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F1","sourceRelease":"119-100","text":"to take action to curtail the global trade in seafood and seafood products derived from IUU fishing, including its links to forced labor and transnational organized illegal activity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s8003/2","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F2","sourceRelease":"119-100","text":"to develop holistic diplomatic, military, law enforcement, economic, and capacity-building tools to counter IUU fishing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s8003/3","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8003/3/A","parentIdentifier":"/us/usc/t16/s8003/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F3%2FA","sourceRelease":"119-100","text":"to increase local, national, and regional level capacities to counter IUU fishing through the engagement of law enforcement and security forces;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8003/3/B","parentIdentifier":"/us/usc/t16/s8003/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F3%2FB","sourceRelease":"119-100","text":"to enhance port capacity and security, including by supporting other countries in working toward the adoption and implementation of the Port State Measures Agreement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8003/3/C","parentIdentifier":"/us/usc/t16/s8003/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F3%2FC","sourceRelease":"119-100","text":"to combat corruption and increase transparency and traceability in fisheries management and trade;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s8003/3/D","parentIdentifier":"/us/usc/t16/s8003/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F3%2FD","sourceRelease":"119-100","text":"to enhance information sharing within and across governments and multilateral organizations through the development and use of agreed standards for information sharing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s8003/3/E","parentIdentifier":"/us/usc/t16/s8003/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F3%2FE","sourceRelease":"119-100","text":"to support effective, science-based fisheries management regimes that promote legal and safe fisheries and act as a deterrent to IUU fishing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s8003/4","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F4","sourceRelease":"119-100","text":"to promote global maritime security through improved capacity and technological assistance to support improved maritime domain awareness;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s8003/5","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F5","sourceRelease":"119-100","text":"to engage with priority flag states to encourage the use of high quality vessel tracking technologies where existing enforcement tools are lacking;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s8003/6","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F6","sourceRelease":"119-100","text":"to engage with multilateral organizations working on fisheries issues, including Regional Fisheries Management Organizations and the Food and Agriculture Organization of the United Nations, to combat and deter IUU fishing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t16/s8003/7","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F7","sourceRelease":"119-100","text":"to advance information sharing across governments and multilateral organizations in areas that cross multiple jurisdictions, through the development and use of an agreed standard for information sharing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t16/s8003/8","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F8","sourceRelease":"119-100","text":"to continue to use existing and future trade agreements to combat IUU fishing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t16/s8003/9","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F9","sourceRelease":"119-100","text":"to employ appropriate assets and resources of the United States Government in a coordinated manner to disrupt the illicit networks involved in IUU fishing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t16/s8003/10","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F10","sourceRelease":"119-100","text":"to continue to declassify and make available, as appropriate and practicable, technologies developed by the United States Government that can be used to help counter IUU fishing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t16/s8003/11","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F11","sourceRelease":"119-100","text":"to recognize the ties of IUU fishing to transnational organized illegal activity, including human trafficking and illegal trade in narcotics and arms, and as applicable, to focus on illicit activity in a coordinated, cross-cutting manner;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t16/s8003/12","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F12","sourceRelease":"119-100","text":"to recognize and respond to poor working conditions, labor abuses, and other violent crimes in the fishing industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"13","heading":null,"label":"13","identifier":"/us/usc/t16/s8003/13","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F13","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8003/13/A","parentIdentifier":"/us/usc/t16/s8003/13","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F13%2FA","sourceRelease":"119-100","text":"a deterrent to IUU fishing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8003/13/B","parentIdentifier":"/us/usc/t16/s8003/13","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F13%2FB","sourceRelease":"119-100","text":"an approach for strengthening fisheries management and food security; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"14","heading":null,"label":"14","identifier":"/us/usc/t16/s8003/14","parentIdentifier":"/us/usc/t16/s8003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8003%2F14","sourceRelease":"119-100","text":"to promote technological investment and innovation to combat IUU fishing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
