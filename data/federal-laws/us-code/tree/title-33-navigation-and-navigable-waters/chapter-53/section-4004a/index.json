/t33/s4004a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F3%2FF","sourceRelease":"119-100","text":"ensure that the plan is technically sound and cost-effective;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t33/s4004a/c/3/G","parentIdentifier":"/us/usc/t33/s4004a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F3%2FG","sourceRelease":"119-100","text":"utilize existing research, assessments, reports, and program activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t33/s4004a/c/3/H","parentIdentifier":"/us/usc/t33/s4004a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F3%2FH","sourceRelease":"119-100","text":"publish a summary of the proposed plan in the Federal Register at least 180 days prior to submitting the completed plan to Congress; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t33/s4004a/c/3/I","parentIdentifier":"/us/usc/t33/s4004a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F3%2FI","sourceRelease":"119-100","text":"after submitting the completed plan to Congress, provide biennial progress reports on the activities toward achieving the objectives of the plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
