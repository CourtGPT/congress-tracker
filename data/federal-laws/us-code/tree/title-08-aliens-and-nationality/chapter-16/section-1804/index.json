{"type":"section","nativeType":"section","number":"1804","heading":"Immigration parole fee","label":"1804 Immigration parole fee","identifier":"/us/usc/t8/s1804","parentIdentifier":"/us/usc/t8/ch16","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t8/s1804/a","parentIdentifier":"/us/usc/t8/s1804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fa","sourceRelease":"119-100","text":"Except as provided under subsection (b), the Secretary of Homeland Security shall require the payment of a fee, equal to the amount specified in this section and in addition to any other fee authorized by law, by any alien who is paroled into the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Exceptions","label":"b Exceptions","identifier":"/us/usc/t8/s1804/b","parentIdentifier":"/us/usc/t8/s1804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t8/s1804/b/1","parentIdentifier":"/us/usc/t8/s1804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1804/b/1/A","parentIdentifier":"/us/usc/t8/s1804/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the alien has a medical emergency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1804/b/1/B","parentIdentifier":"/us/usc/t8/s1804/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t8/s1804/b/1/B/i","parentIdentifier":"/us/usc/t8/s1804/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the alien cannot obtain necessary treatment in the foreign state in which the alien is residing; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t8/s1804/b/1/B/ii","parentIdentifier":"/us/usc/t8/s1804/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the medical emergency is life-threatening and there is insufficient time for the alien to be admitted to the United States through the normal visa process;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t8/s1804/b/2","parentIdentifier":"/us/usc/t8/s1804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1804/b/2/A","parentIdentifier":"/us/usc/t8/s1804/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the alien is the parent or legal guardian of an alien described in paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1804/b/2/B","parentIdentifier":"/us/usc/t8/s1804/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the alien described in paragraph (1) is a minor;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t8/s1804/b/3","parentIdentifier":"/us/usc/t8/s1804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1804/b/3/A","parentIdentifier":"/us/usc/t8/s1804/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the alien is needed in the United States to donate an organ or other tissue for transplant; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1804/b/3/B","parentIdentifier":"/us/usc/t8/s1804/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F3%2FB","sourceRelease":"119-100","text":"there is insufficient time for the alien to be admitted to the United States through the normal visa process;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t8/s1804/b/4","parentIdentifier":"/us/usc/t8/s1804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1804/b/4/A","parentIdentifier":"/us/usc/t8/s1804/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F4%2FA","sourceRelease":"119-100","text":"the alien has a close family member in the United States whose death is imminent; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1804/b/4/B","parentIdentifier":"/us/usc/t8/s1804/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F4%2FB","sourceRelease":"119-100","text":"the alien could not arrive in the United States in time to see such family member alive if the alien were to be admitted to the United States through the normal visa process;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t8/s1804/b/5","parentIdentifier":"/us/usc/t8/s1804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1804/b/5/A","parentIdentifier":"/us/usc/t8/s1804/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F5%2FA","sourceRelease":"119-100","text":"the alien is seeking to attend the funeral of a close family member; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1804/b/5/B","parentIdentifier":"/us/usc/t8/s1804/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F5%2FB","sourceRelease":"119-100","text":"the alien could not arrive in the United States in time to attend such funeral if the alien were to be admitted to the United States through the normal visa process;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t8/s1804/b/6","parentIdentifier":"/us/usc/t8/s1804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1804/b/6/A","parentIdentifier":"/us/usc/t8/s1804/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F6%2FA","sourceRelease":"119-100","text":"who has an urgent medical condition;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1804/b/6/B","parentIdentifier":"/us/usc/t8/s1804/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F6%2FB","sourceRelease":"119-100","text":"who is in the legal custody of the petitioner for a final adoption-related visa; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t8/s1804/b/6/C","parentIdentifier":"/us/usc/t8/s1804/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F6%2FC","sourceRelease":"119-100","text":"whose medical treatment is required before the expected award of a final adoption-related visa;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t8/s1804/b/7","parentIdentifier":"/us/usc/t8/s1804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1804/b/7/A","parentIdentifier":"/us/usc/t8/s1804/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F7%2FA","sourceRelease":"119-100","text":"is a lawful applicant for adjustment of status under ; andsection 1255 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1804/b/7/B","parentIdentifier":"/us/usc/t8/s1804/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F7%2FB","sourceRelease":"119-100","text":"is returning to the United States after temporary travel abroad;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t8/s1804/b/8","parentIdentifier":"/us/usc/t8/s1804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1804/b/8/A","parentIdentifier":"/us/usc/t8/s1804/b/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F8%2FA","sourceRelease":"119-100","text":"has been returned to a contiguous country pursuant to ; andsection 1225(b)(2)(C) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1804/b/8/B","parentIdentifier":"/us/usc/t8/s1804/b/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F8%2FB","sourceRelease":"119-100","text":"is being paroled into the United States to allow the alien to attend the alien’s immigration hearing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t8/s1804/b/9","parentIdentifier":"/us/usc/t8/s1804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F9","sourceRelease":"119-100","text":"the alien has been granted the status of Cuban and Haitian entrant (as defined in section 501(e) of the Refugee Education Assistance Act of 1980 (; note); orPublic Law 96–4228 U.S.C. 1522","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t8/s1804/b/10","parentIdentifier":"/us/usc/t8/s1804/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F10","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1804/b/10/A","parentIdentifier":"/us/usc/t8/s1804/b/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F10%2FA","sourceRelease":"119-100","text":"who has assisted or will assist the United States Government in a law enforcement matter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1804/b/10/B","parentIdentifier":"/us/usc/t8/s1804/b/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F10%2FB","sourceRelease":"119-100","text":"whose presence is required by the United States Government in furtherance of such law enforcement matter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t8/s1804/b/10/C","parentIdentifier":"/us/usc/t8/s1804/b/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F10%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t8/s1804/b/10/C/i","parentIdentifier":"/us/usc/t8/s1804/b/10/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F10%2FC%2Fi","sourceRelease":"119-100","text":"who is inadmissible or does not satisfy the eligibility requirements for admission as a nonimmigrant; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t8/s1804/b/10/C/ii","parentIdentifier":"/us/usc/t8/s1804/b/10/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fb%2F10%2FC%2Fii","sourceRelease":"119-100","text":"for which there is insufficient time for the alien to be admitted to the United States through the normal visa process.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Initial amount","label":"c Initial amount","identifier":"/us/usc/t8/s1804/c","parentIdentifier":"/us/usc/t8/s1804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t8/s1804/c/1","parentIdentifier":"/us/usc/t8/s1804/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fc%2F1","sourceRelease":"119-100","text":"$1,000; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t8/s1804/c/2","parentIdentifier":"/us/usc/t8/s1804/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fc%2F2","sourceRelease":"119-100","text":"such amount as the Secretary of Homeland Security may establish, by rule.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Annual adjustments for inflation","label":"d Annual adjustments for inflation","identifier":"/us/usc/t8/s1804/d","parentIdentifier":"/us/usc/t8/s1804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t8/s1804/d/1","parentIdentifier":"/us/usc/t8/s1804/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fd%2F1","sourceRelease":"119-100","text":"the amount of the fee required under this subsection for the most recently concluded fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t8/s1804/d/2","parentIdentifier":"/us/usc/t8/s1804/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fd%2F2","sourceRelease":"119-100","text":"the product resulting from the multiplication of the amount referred to in paragraph (1) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded to the next lowest multiple of $10.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Disposition of fees collected from aliens granted parole","label":"e Disposition of fees collected from aliens granted parole","identifier":"/us/usc/t8/s1804/e","parentIdentifier":"/us/usc/t8/s1804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Fe","sourceRelease":"119-100","text":"All of the fees collected pursuant to this section shall be deposited into the general fund of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"No fee waiver","label":"f No fee waiver","identifier":"/us/usc/t8/s1804/f","parentIdentifier":"/us/usc/t8/s1804","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1804%2Ff","sourceRelease":"119-100","text":"Except as provided in subsection (b), fees required to be paid under this section shall not be waived or reduced.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
