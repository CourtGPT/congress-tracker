{"type":"section","nativeType":"section","number":"822","heading":"Assessment of global catastrophic risk","label":"822 Assessment of global catastrophic risk","identifier":"/us/usc/t6/s822","parentIdentifier":"/us/usc/t6/ch2/schII/ptF","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs822","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t6/s822/a","parentIdentifier":"/us/usc/t6/s822","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs822%2Fa","sourceRelease":"119-100","text":"The Secretary and the Administrator shall coordinate an assessment of global catastrophic risk.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Coordination","label":"b Coordination","identifier":"/us/usc/t6/s822/b","parentIdentifier":"/us/usc/t6/s822","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs822%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s822/b/1","parentIdentifier":"/us/usc/t6/s822/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs822%2Fb%2F1","sourceRelease":"119-100","text":"the Assistant to the President for National Security Affairs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s822/b/2","parentIdentifier":"/us/usc/t6/s822/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs822%2Fb%2F2","sourceRelease":"119-100","text":"the Director of the Office of Science and Technology Policy;","notes":[],"amendments":[],"e