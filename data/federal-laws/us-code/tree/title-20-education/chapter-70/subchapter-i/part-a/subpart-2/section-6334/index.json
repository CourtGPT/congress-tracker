scode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s6334/a/1/A/i","parentIdentifier":"/us/usc/t20/s6334/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"6,500; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s6334/a/1/A/ii","parentIdentifier":"/us/usc/t20/s6334/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"15 percent of the total number of children aged 5 through 17 in the agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s6334/a/1/B","parentIdentifier":"/us/usc/t20/s6334/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s6334/a/1/B/i","parentIdentifier":"/us/usc/t20/s6334/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"0.25 percent of the total amount allocated to States under this section for fiscal year 2001, plus 0.35 percent of the total amount allocated to States under this section in excess of the amount allocated for fiscal year 2001; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s6334/a/1/B/ii","parentIdentifier":"/us/usc/t20/s6334/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t20/s6334/a/1/B/ii/I","parentIdentifier":"/us/usc/t20/s6334/a/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F1%2FB%2Fii%2FI","sourceRelease":"119-100","text":"the amount calculated under clause (i); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t20/s6334/a/1/B/ii/II","parentIdentifier":"/us/usc/t20/s6334/a/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F1%2FB%2Fii%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t20/s6334/a/1/B/ii/II/aa","parentIdentifier":"/us/usc/t20/s6334/a/1/B/ii/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F1%2FB%2Fii%2FII%2Faa","sourceRelease":"119-100","text":"$340,000; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t20/s6334/a/1/B/ii/II/bb","parentIdentifier":"/us/usc/t20/s6334/a/1/B/ii/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F1%2FB%2Fii%2FII%2Fbb","sourceRelease":"119-100","text":"the number of children in such State counted for purposes of this section in that fiscal year multiplied by 150 percent of the national average per-pupil payment made with funds available under this section for that year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Determination","label":"2 Determination","identifier":"/us/usc/t20/s6334/a/2","parentIdentifier":"/us/usc/t20/s6334/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s6334/a/2/A","parentIdentifier":"/us/usc/t20/s6334/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the number of children counted under for that fiscal year; andsection 6333(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s6334/a/2/B","parentIdentifier":"/us/usc/t20/s6334/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the amount in for each State except the Commonwealth of Puerto Rico, and the amount in for the Commonwealth of Puerto Rico.section 6333(a)(1)(B) of this titlesection 6333(a)(4) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Amount","label":"3 Amount","identifier":"/us/usc/t20/s6334/a/3","parentIdentifier":"/us/usc/t20/s6334/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F3","sourceRelease":"119-100","text":"The amount of the additional grant for which an eligible local educational agency or county is eligible under this section for any fiscal year shall be an amount which bears the same ratio to the amount available to carry out this section for that fiscal year as the product determined under paragraph (2) for such local educational agency for that fiscal year bears to the sum of such products for all local educational agencies in the United States for that fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Local allocations","label":"4 Local allocations","identifier":"/us/usc/t20/s6334/a/4","parentIdentifier":"/us/usc/t20/s6334/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s6334/a/4/A","parentIdentifier":"/us/usc/t20/s6334/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F4%2FA","sourceRelease":"119-100","text":"Grant amounts under this section shall be determined in accordance with section 6333(a)(2), (3), and (4) of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s6334/a/4/B","parentIdentifier":"/us/usc/t20/s6334/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fa%2F4%2FB","sourceRelease":"119-100","text":"For any fiscal year for which the Secretary allocates funds under this section on the basis of counties, a State may reserve not more than 2 percent of its allocation under this section to make grants to local educational agencies that meet the criteria of paragraph (1)(A)(i) or (ii) and are in ineligible counties that do not meet these criteria.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Small States","label":"b Small States","identifier":"/us/usc/t20/s6334/b","parentIdentifier":"/us/usc/t20/s6334","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s6334/b/1","parentIdentifier":"/us/usc/t20/s6334/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fb%2F1","sourceRelease":"119-100","text":"in accordance with paragraphs (2) and (4) of subsection (a); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s6334/b/2","parentIdentifier":"/us/usc/t20/s6334/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6334%2Fb%2F2","sourceRelease":"119-100","text":"based on their respective concentrations and numbers of children counted under , except that only those local educational agencies with concentrations or numbers of children counted under that exceed the statewide average percentage of such children or the statewide average number of such children shall receive any funds on the basis of this paragraph.section 6333(c) of this titlesection 6333(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
