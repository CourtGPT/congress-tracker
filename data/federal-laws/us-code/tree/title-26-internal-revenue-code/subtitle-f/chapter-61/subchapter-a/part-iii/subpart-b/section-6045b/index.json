furnished to holders of specified securities or their nominees","identifier":"/us/usc/t26/s6045B/c","parentIdentifier":"/us/usc/t26/s6045B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6045B%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s6045B/c/1","parentIdentifier":"/us/usc/t26/s6045B/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6045B%2Fc%2F1","sourceRelease":"119-100","text":"the name, address, and phone number of the information contact of the person required to make such return,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s6045B/c/2","parentIdentifier":"/us/usc/t26/s6045B/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6045B%2Fc%2F2","sourceRelease":"119-100","text":"the information required to be shown on such return with respect to such security, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t26/s6045B/c/3","parentIdentifier":"/us/usc/t26/s6045B/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6045B%2Fc%2F3","sourceRelease":"119-100","text":"such other information as the Secretary may prescribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Specified security","label":"d Specified security","identifier":"/us/usc/t26/s6045B/d","parentIdentifier":"/us/usc/t26/s6045B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6045B%2Fd","sourceRelease":"119-100","text":"For purposes of this section, the term “specified security” has the meaning given such term by section 6045(g)(3)(B). No return shall be required under this section with respect to actions described in subsection (a) with respect to a specified security which occur before the applicable date (as defined in section 6045(g)(3)(C)) with respect to such security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Public reporting in lieu of return","label":"e Public reporting in lieu of return","identifier":"/us/usc/t26/s6045B/e","parentIdentifier":"/us/usc/t26/s6045B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6045B%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s6045B/e/1","parentIdentifier":"/us/usc/t26/s6045B/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6045B%2Fe%2F1","sourceRelease":"119-100","text":"the name, address, phone number, and email address of the information contact of such person, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s6045B/e/2","parentIdentifier":"/us/usc/t26/s6045B/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6045B%2Fe%2F2","sourceRelease":"119-100","text":"the information described in paragraphs (1), (2), and (3) of subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
