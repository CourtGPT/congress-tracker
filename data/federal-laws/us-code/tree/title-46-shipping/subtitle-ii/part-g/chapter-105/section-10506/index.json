{"type":"section","nativeType":"section","number":"10506","heading":"Trusts","label":"10506 Trusts","identifier":"/us/usc/t46/s10506","parentIdentifier":"/us/usc/t46/stII/ptG/ch105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10506","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevised sectionSource section (U.S. Code)1050646:599Section 10506 permits deductions to be made from wages of seamen on coastwise voyages if the deductions are to be used for the benefit of the seamen or their families."],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s10506/1","parentIdentifier":"/us/usc/t46/s10506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10506%2F1","sourceRelease":"119-100","text":"the deductions are paid into a trust fund established only for the benefit of seamen employed by that employer, and the families and dependents of those seamen (or of those seamen, families, and dependents jointly with other seamen employed by other employers, and the families and dependents of the other seamen); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s10506/2","parentIdentifier":"/us/usc/t46/s10506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10506%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s10506/2/A","parentIdentifier":"/us/usc/t46/s10506/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10506%2F2%2FA","sourceRelease":"119-100","text":"medical or hospital care, or both.","notes":[],"amendments":[],"effectiveDate":null,"chi