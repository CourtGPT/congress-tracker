{"type":"section","nativeType":"section","number":"13233","heading":"Data acquisition program","label":"13233 Data acquisition program","identifier":"/us/usc/t42/s13233","parentIdentifier":"/us/usc/t42/ch134/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13233","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t42/s13233/a","parentIdentifier":"/us/usc/t42/s13233","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13233%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13233/a/1","parentIdentifier":"/us/usc/t42/s13233/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13233%2Fa%2F1","sourceRelease":"119-100","text":"identification of the number and types of motor vehicle trips made daily and miles driven per trip, including commuting, business, and recreational trips;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13233/a/2","parentIdentifier":"/us/usc/t42/s13233/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13233%2Fa%2F2","sourceRelease":"119-100","text":"the projections of the Secretary as to the most likely combination of alternative fueled vehicle use and other forms of transit, including rail and other forms of mass transit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13233/a/3","parentIdentifier":"/us/usc/t42/s13233/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13233%2Fa%2F3","sourceRelease":"119-100","text":"cost, performance, environmental, energy, and safety data on alternative fuels and alternative fueled vehicles; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s13233/a/4","parentIdentifier":"/us/usc/t42/s13233/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13233%2Fa%2F4","sourceRelease":"119-100","text":"other appropriate demographic information and consumer preferences.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t42/s13233/b","parentIdentifier":"/us/usc/t42/s13233","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13233%2Fb","sourceRelease":"119-100","text":"The Secretary shall consult with interested parties, including other appropriate Federal agencies, manufacturers, public utilities, owners and operators of fleets of light duty motor vehicles, and State or local governmental entities, to determine the types of data to be collected and analyzed under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
