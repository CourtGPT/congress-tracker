{"type":"section","nativeType":"section","number":"276c–7","heading":"Internships of United States nationals at international organizations","label":"276c–7 Internships of United States nationals at international organizations","identifier":"/us/usc/t22/s276c–7","parentIdentifier":"/us/usc/t22/ch7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%937","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","DefinitionsFor definitions of “Secretary”, “appropriate congressional committees”, and “Department” as used in this section, see , set out as a note under .section 6002 of Pub. L. 118–31section 2651 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s276c–7/a","parentIdentifier":"/us/usc/t22/s276c–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%937%2Fa","sourceRelease":"119-100","text":"The Secretary is authorized to bolster efforts to increase the number of United States citizens representative of the American people occupying positions in the United Nations system, agencies, and commissions, and in other international organizations, including by awarding grants to educational institutions and students.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report","label":"b Report","identifier":"/us/usc/t22/s276c–7/b","parentIdentifier":"/us/usc/t22/s276c–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%937%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s276c–7/b/1","parentIdentifier":"/us/usc/t22/s276c–7/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%937%2Fb%2F1","sourceRelease":"119-100","text":"the number of United States citizens who are involved in internship programs at international organizations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s276c–7/b/2","parentIdentifier":"/us/usc/t22/s276c–7/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%937%2Fb%2F2","sourceRelease":"119-100","text":"the distribution of the individuals described in paragraph (1) among various international organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s276c–7/b/3","parentIdentifier":"/us/usc/t22/s276c–7/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%937%2Fb%2F3","sourceRelease":"119-100","text":"grants, programs, and other activities that are being utilized to recruit and fund United States citizens to participate in internship programs at international organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Eligibility","label":"c Eligibility","identifier":"/us/usc/t22/s276c–7/c","parentIdentifier":"/us/usc/t22/s276c–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%937%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s276c–7/c/1","parentIdentifier":"/us/usc/t22/s276c–7/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%937%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s276c–7/c/1/A","parentIdentifier":"/us/usc/t22/s276c–7/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%937%2Fc%2F1%2FA","sourceRelease":"119-100","text":"an institution of higher education; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s276c–7/c/1/B","parentIdentifier":"/us/usc/t22/s276c–7/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%937%2Fc%2F1%2FB","sourceRelease":"119-100","text":"an institution of higher education based outside the United States, as determined by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s276c–7/c/2","parentIdentifier":"/us/usc/t22/s276c–7/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%937%2Fc%2F2","sourceRelease":"119-100","text":"is a citizen of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t22/s276c–7/d","parentIdentifier":"/us/usc/t22/s276c–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%937%2Fd","sourceRelease":"119-100","text":"There is authorized to be appropriated $1,500,000 for the Department for fiscal year 2024 to carry out the grant program authorized under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
