":"119-100","text":"Reduce the prevalence of dental caries to no more than 35 percent of children by age 8.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"21","heading":null,"label":"21","identifier":"/us/usc/t42/s11702/b/21","parentIdentifier":"/us/usc/t42/s11702/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11702%2Fb%2F21","sourceRelease":"119-100","text":"Reduce untreated dental caries so that the proportion of children with untreated caries (in permanent or primary teeth) is no more than 20 percent among children age 6 through 8 and no more than 15 percent among adolescents age 15.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"22","heading":null,"label":"22","identifier":"/us/usc/t42/s11702/b/22","parentIdentifier":"/us/usc/t42/s11702/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11702%2Fb%2F22","sourceRelease":"119-100","text":"Reduce edentulism to no more than 20 percent in people age 65 and older.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"23","heading":null,"label":"23","identifier":"/us/usc/t42/s11702/b/23","parentIdentifier":"/us/usc/t42/s11702/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11702%2Fb%2F23","sourceRelease":"119-100","text":"Increase moderate daily physical activity to at least 30 percent of the population.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"24","heading":null,"label":"24","identifier":"/us/usc/t42/s11702/b/24","parentIdentifier":"/us/usc/t42/s11702/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11702%2Fb%2F24","sourceRelease":"119-100","text":"Reduce sedentary lifestyles to no more than 15 percent of the population.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"25","heading":null,"label":"25","identifier":"/us/usc/t42/s11702/b/25","parentIdentifier":"/us/usc/t42/s11702/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11702%2Fb%2F25","sourceRelease":"119-100","text":"Reduce overweight to a prevalence of no more than 20 percent of the population.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"26","heading":null,"label":"26","identifier":"/us/usc/t42/s11702/b/26","parentIdentifier":"/us/usc/t42/s11702/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11702%2Fb%2F26","sourceRelease":"119-100","text":"Reduce dietary fat intake to an average of 30 percent of calories or less.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"27","heading":null,"label":"27","identifier":"/us/usc/t42/s11702/b/27","parentIdentifier":"/us/usc/t42/s11702/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11702%2Fb%2F27","sourceRelease":"119-100","text":"Increase to at least 75 percent the proportion of primary care providers who provide nutrition assessment and counseling or referral to qualified nutritionists or dieticians.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"28","heading":null,"label":"28","identifier":"/us/usc/t42/s11702/b/28","parentIdentifier":"/us/usc/t42/s11702/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11702%2Fb%2F28","sourceRelease":"119-100","text":"Reduce cigarette smoking prevalence to no more than 15 percent of adults.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"29","heading":null,"label":"29","identifier":"/us/usc/t42/s11702/b/29","parentIdentifier":"/us/usc/t42/s11702/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11702%2Fb%2F29","sourceRelease":"119-100","text":"Reduce initiation of smoking to no more than 15 percent by age 20.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"30","heading":null,"label":"30","identifier":"/us/usc/t42/s11702/b/30","parentIdentifier":"/us/usc/t42/s11702/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11702%2Fb%2F30","sourceRelease":"119-100","text":"Reduce alcohol-related motor vehicle crash deaths to no more than 8.5 per 100,000 adjusted for age.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"31","heading":null,"label":"31","identifier":"/us/usc/t42/s11702/b/31","parentIdentifier":"/us/usc/t42/s11702/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11702%2Fb%2F31","sourceRelease":"119-100","text":"Reduce alcohol use by school children age 12 to 17 to less than 13 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"32","heading":null,"label":"32","identifier":"/us/usc/t42/s11702/b/32","parentIdentifier":"/us/usc/t42/s11702/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11702%2Fb%2F32","sourceRelease":"119-100","text":"Reduce marijuana use by youth age 18 to 25 to less than 8 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"33","heading":null,"label":"33","identifier":"/us/usc/t42/s11702/b/33","parentIdentifier":"/us/usc/t42/s11702/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11702%2Fb%2F33","sourceRelease":"119-100","text":"Reduce cocaine use by youth aged 18 to 25 to less than 3 percent.1So in original. Proba