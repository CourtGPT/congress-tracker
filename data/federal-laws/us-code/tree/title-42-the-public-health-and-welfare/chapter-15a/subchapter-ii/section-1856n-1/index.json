{"type":"section","nativeType":"section","number":"1856n–1","heading":"Reciprocal agreements with liability coverage","label":"1856n–1 Reciprocal agreements with liability coverage","identifier":"/us/usc/t42/s1856n–1","parentIdentifier":"/us/usc/t42/ch15A/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1856n%E2%80%931","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsA prior was renumbered section 5 and is classified to section 1856 of this title.section 4 of Pub. L. 100–428o"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Protection from liability for foreign firefighters and foreign fire organizations","label":"a Protection from liability for foreign firefighters and foreign fire organizations","identifier":"/us/usc/t42/s1856n–1/a","parentIdentifier":"/us/usc/t42/s1856n–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1856n%E2%80%931%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s1856n–1/a/1","parentIdentifier":"/us/usc/t42/s1856n–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1856n%E2%80%931%2Fa%2F1","sourceRelease":"119-100","text":"a foreign firefighter shall be considered to be an employee of the United States for purposes of tort liability while the foreign firefighter is acting within the scope of an official duty under the agreement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s1856n–1/a/2","parentIdentifier":"/us/usc/t42/s1856n–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1856n%E2%80%931%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s1856n–1/a/2/A","parentIdentifier":"/us/usc/t42/s1856n–1/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1856n%E2%80%931%2Fa%2F2%2FA","sourceRelease":"119-100","text":"against the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s1856n–1/a/2/B","parentIdentifier":"/us/usc/t42/s1856n–1/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1856n%E2%80%931%2Fa%2F2%2FB","sourceRelease":"119-100","text":"as if the act or omission were the act or omission of an employee of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Protection from liability for Federal firefighters and the Federal Government","label":"b Protection from liability for Federal firefighters and the Federal Government","identifier":"/us/usc/t42/s1856n–1/b","parentIdentifier":"/us/usc/t42/s1856n–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1856n%E2%80%931%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s1856n–1/b/1","parentIdentifier":"/us/usc/t42/s1856n–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1856n%E2%80%931%2Fb%2F1","sourceRelease":"119-100","text":"to assume any and all liability for any legal action brought against the Federal firefighter for an act or omission of the Federal firefighter while acting within the scope of an official duty under the agreement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s1856n–1/b/2","parentIdentifier":"/us/usc/t42/s1856n–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1856n%E2%80%931%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s1856n–1/b/2/A","parentIdentifier":"/us/usc/t42/s1856n–1/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1856n%E2%80%931%2Fb%2F2%2FA","sourceRelease":"119-100","text":"an act or omission of the Federal firefighter in the performance of an official duty under the agreement; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s1856n–1/b/2/B","parentIdentifier":"/us/usc/t42/s1856n–1/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1856n%E2%80%931%2Fb%2F2%2FB","sourceRelease":"119-100","text":"any other act, omission, or occurrence for which the United States or the legal organization associated with the Federal firefighter is legally responsible under the laws applicable to the foreign fire organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
