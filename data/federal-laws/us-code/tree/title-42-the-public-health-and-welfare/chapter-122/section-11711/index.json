tifier":"/us/usc/t42/s11711/7/A/i","parentIdentifier":"/us/usc/t42/s11711/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F7%2FA%2Fi","sourceRelease":"119-100","text":"E Ola Mau;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s11711/7/A/ii","parentIdentifier":"/us/usc/t42/s11711/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F7%2FA%2Fii","sourceRelease":"119-100","text":"the Office of Hawaiian Affairs of the State of Hawaii;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s11711/7/A/iii","parentIdentifier":"/us/usc/t42/s11711/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F7%2FA%2Fiii","sourceRelease":"119-100","text":"Alu Like Inc.;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s11711/7/A/iv","parentIdentifier":"/us/usc/t42/s11711/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F7%2FA%2Fiv","sourceRelease":"119-100","text":"the University of Hawaii;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s11711/7/A/v","parentIdentifier":"/us/usc/t42/s11711/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F7%2FA%2Fv","sourceRelease":"119-100","text":"the Office of Hawaiian Health of the Hawaii State Department of Health;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s11711/7/A/vi","parentIdentifier":"/us/usc/t42/s11711/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F7%2FA%2Fvi","sourceRelease":"119-100","text":"Ho’ola Lahui Hawaii, or a health care system serving the islands of Kaua’i and Ni’ihau, and which may be composed of as many health care centers as are necessary to meet the health care needs of the Native Hawaiians of those islands;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t42/s11711/7/A/vii","parentIdentifier":"/us/usc/t42/s11711/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F7%2FA%2Fvii","sourceRelease":"119-100","text":"Ke Ola Mamo, or a health care system serving the island of O’ahu, and which may be composed of as many health care centers as are necessary to meet the health care needs of the Native Hawaiians of that island;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t42/s11711/7/A/viii","parentIdentifier":"/us/usc/t42/s11711/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F7%2FA%2Fviii","sourceRelease":"119-100","text":"Na Pu’uwai or a health care system serving the islands of Moloka’i and Lana’i, and which may be composed of as many health care centers as are necessary to meet the health care needs of the Native Hawaiians of those islands;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ix","heading":null,"label":"ix","identifier":"/us/usc/t42/s11711/7/A/ix","parentIdentifier":"/us/usc/t42/s11711/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F7%2FA%2Fix","sourceRelease":"119-100","text":"Hui No Ke Ola Pono, or a health care system serving the island of Maui, and which may be composed of as many health care centers as are necessary to meet the health care needs of the Native Hawaiians of that island;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"x","heading":null,"label":"x","identifier":"/us/usc/t42/s11711/7/A/x","parentIdentifier":"/us/usc/t42/s11711/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F7%2FA%2Fx","sourceRelease":"119-100","text":"Hui Malama Ola Ha’Oiwi or a health care system serving the island of Hawaii, and which may be composed of as many health care centers as are necessary to meet the health care needs of the Native Hawaiians of that island; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xi","heading":null,"label":"xi","identifier":"/us/usc/t42/s11711/7/A/xi","parentIdentifier":"/us/usc/t42/s11711/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F7%2FA%2Fxi","sourceRelease":"119-100","text":"such other member organizations as the Board of Papa Ola Lokahi may admit from time to time, based upon satisfactory demonstration of a record of contribution to the health and well-being of Native Hawaiians, and upon satisfactory development of a mission statement in relation to this chapter, including clearly defined goals and objectives, a 5-year action plan outlining the contributions that each organization will make in carrying out the policy of this chapter, and an estimated budget.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s11711/7/B","parentIdentifier":"/us/usc/t42/s11711/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F7%2FB","sourceRelease":"119-100","text":"Such term does not include any such organization identified in subparagraph (A) if the Secretary determines that such organization has not developed a mission statement with clearly defined goals and objectives for the contributions the organization will make to the Native Hawaiian health care systems, and an action plan for carrying out those goals and objectives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Primary health services","label":"8 Primary health services","identifier":"/us/usc/t42/s11711/8","parentIdentifier":"/us/usc/t42/s11711","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s11711/8/A","parentIdentifier":"/us/usc/t42/s11711/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F8%2FA","sourceRelease":"119-100","text":"services of physicians, physicians’ assistants, nurse practitioners, and other health professionals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s11711/8/B","parentIdentifier":"/us/usc/t42/s11711/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F8%2FB","sourceRelease":"119-100","text":"diagnostic laboratory and radiologic services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s11711/8/C","parentIdentifier":"/us/usc/t42/s11711/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F8%2FC","sourceRelease":"119-100","text":"preventive health services (including children’s eye and ear examinations to determine the need for vision and hearing correction, perinatal services, well child services, and family planning services);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s11711/8/D","parentIdentifier":"/us/usc/t42/s11711/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F8%2FD","sourceRelease":"119-100","text":"emergency medical services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s11711/8/E","parentIdentifier":"/us/usc/t42/s11711/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F8%2FE","sourceRelease":"119-100","text":"transportation services as required for adequate patient care;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s11711/8/F","parentIdentifier":"/us/usc/t42/s11711/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F8%2FF","sourceRelease":"119-100","text":"preventive dental services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s11711/8/G","parentIdentifier":"/us/usc/t42/s11711/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F8%2FG","sourceRelease":"119-100","text":"pharmaceutical services, as may be appropriate for particular health centers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":"Secretary","label":"9 Secretary","identifier":"/us/usc/t42/s11711/9","parentIdentifier":"/us/usc/t42/s11711","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F9","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Health and Human Services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":"Traditional Native Hawaiian healer","label":"10 Traditional Native Hawaiian healer","identifier":"/us/usc/t42/s11711/10","parentIdentifier":"/us/usc/t42/s11711","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F10","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s11711/10/A","parentIdentifier":"/us/usc/t42/s11711/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F10%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s11711/10/A/i","parentIdentifier":"/us/usc/t42/s11711/10/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F10%2FA%2Fi","sourceRelease":"119-100","text":"is of Hawaiian ancestry, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s11711/10/A/ii","parentIdentifier":"/us/usc/t42/s11711/10/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F10%2FA%2Fii","sourceRelease":"119-100","text":"has the knowledge, skills, and experience in direct personal health care of individuals, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s11711/10/B","parentIdentifier":"/us/usc/t42/s11711/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F10%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s11711/10/B/i","parentIdentifier":"/us/usc/t42/s11711/10/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F10%2FB%2Fi","sourceRelease":"119-100","text":"direct practical association with Native Hawaiian elders, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s11711/10/B/ii","parentIdentifier":"/us/usc/t42/s11711/10/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11711%2F10%2FB%2Fii","sourceRelease":"119-100","text":"oral traditions transmitted from generation to generation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
