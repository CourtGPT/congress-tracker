{"type":"section","nativeType":"section","number":"4723","heading":"Annual report by Select Committee on Ethics","label":"4723 Annual report by Select Committee on Ethics","identifier":"/us/usc/t2/s4723","parentIdentifier":"/us/usc/t2/ch47/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs4723","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to prior to editorial reclassification and renumbering as this section.section 72a–1i of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s4723/1","parentIdentifier":"/us/usc/t2/s4723","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs4723%2F1","sourceRelease":"119-100","text":"The number of alleged violations of Senate rules received from any source, including the number raised by a Senator or staff of the committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s4723/2","parentIdentifier":"/us/usc/t2/s4723","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs4723%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t2/s4723/2/A","parentIdentifier":"/us/usc/t2/s4723/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs4723%2F2%2FA","sourceRelease":"119-100","text":"for lack of subject matter jurisdiction or, in which, even if the allegations in the complaint are true, no violation of Senate rules would exist; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t2/s4723/2/B","parentIdentifier":"/us/usc/t2/s4723/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs4723%2F2%2FB","sourceRelease":"119-100","text":"because they failed to provide sufficient facts as to any material violation of the Senate rules beyond mere allegation or assertion.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t2/s4723/3","parentIdentifier":"/us/usc/t2/s4723","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs4723%2F3","sourceRelease":"119-100","text":"The number of alleged violations in which the committee staff conducted a preliminary inquiry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t2/s4723/4","parentIdentifier":"/us/usc/t2/s4723","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs4723%2F4","sourceRelease":"119-100","text":"The number of alleged violations that resulted in an adjudicatory review.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t2/s4723/5","parentIdentifier":"/us/usc/t2/s4723","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs4723%2F5","sourceRelease":"119-100","text":"The number of alleged violations that the committee dismissed for lack of substantial merit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t2/s4723/6","parentIdentifier":"/us/usc/t2/s4723","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs4723%2F6","sourceRelease":"119-100","text":"The number of private letters of admonition or public letters of admonition issued.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t2/s4723/7","parentIdentifier":"/us/usc/t2/s4723","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs4723%2F7","sourceRelease":"119-100","text":"The number of matters resulting in a disciplinary sanction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t2/s4723/8","parentIdentifier":"/us/usc/t2/s4723","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs4723%2F8","sourceRelease":"119-100","text":"Any other information deemed by the committee to be appropriate to describe its activities in the preceding year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
