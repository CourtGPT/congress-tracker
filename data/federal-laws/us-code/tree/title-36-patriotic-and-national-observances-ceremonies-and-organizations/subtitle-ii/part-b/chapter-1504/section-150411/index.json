{"type":"section","nativeType":"section","number":"150411","heading":"Records and inspection","label":"150411 Records and inspection","identifier":"/us/usc/t36/s150411","parentIdentifier":"/us/usc/t36/stII/ptB/ch1504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150411","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Records","label":"a .—Records","identifier":"/us/usc/t36/s150411/a","parentIdentifier":"/us/usc/t36/s150411","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150411%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t36/s150411/a/1","parentIdentifier":"/us/usc/t36/s150411/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150411%2Fa%2F1","sourceRelease":"119-100","text":"correct and complete books and records of accounts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t36/s150411/a/2","parentIdentifier":"/us/usc/t36/s150411/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150411%2Fa%2F2","sourceRelease":"119-100","text":"minutes of any proceeding of the corporation involving any member of the corporation, the board of directors, or any committee having authority under the board of directors; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t36/s150411/a/3","parentIdentifier":"/us/usc/t36/s150411/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150411%2Fa%2F3","sourceRelease":"119-100","text":"at the principal office of the corporation, a record of the names and addresses of all members of the corporation having the right to vote.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Inspection","label":"b .—Inspection","identifier":"/us/usc/t36/s150411/b","parentIdentifier":"/us/usc/t36/s150411","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150411%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t36/s150411/b/1","parentIdentifier":"/us/usc/t36/s150411/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150411%2Fb%2F1","sourceRelease":"119-100","text":"All books and records of the corporation may be inspected by any member having the right to vote, or by any agent or attorney of such a member, for any proper purpose, at any reasonable time.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Effect","label":"2 .—Effect","identifier":"/us/usc/t36/s150411/b/2","parentIdentifier":"/us/usc/t36/s150411/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150411%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t36/s150411/b/2/A","parentIdentifier":"/us/usc/t36/s150411/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150411%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the laws of the jurisdiction under which the corporation is incorporated; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t36/s150411/b/2/B","parentIdentifier":"/us/usc/t36/s150411/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150411%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the laws of those jurisdictions within the United States and its territories within which the corporation carries out activities in furtherance of the purposes of the corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
