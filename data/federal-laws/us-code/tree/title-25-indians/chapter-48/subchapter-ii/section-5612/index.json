{"type":"section","nativeType":"section","number":"5612","heading":"Establishment of demonstration project; selection of participating Indian tribes","label":"5612 Establishment of demonstration project; selection of participating Indian tribes","identifier":"/us/usc/t25/s5612","parentIdentifier":"/us/usc/t25/ch48/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t25/s5612/a","parentIdentifier":"/us/usc/t25/s5612","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish and carry out an Indian trust asset management demonstration project, in accordance with this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Selection of participating Indian tribes","label":"b Selection of participating Indian tribes","identifier":"/us/usc/t25/s5612/b","parentIdentifier":"/us/usc/t25/s5612","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s5612/b/1","parentIdentifier":"/us/usc/t25/s5612/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s5612/b/1/A","parentIdentifier":"/us/usc/t25/s5612/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the Indian tribe submits to the Secretary an application under subsection (c); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s5612/b/1/B","parentIdentifier":"/us/usc/t25/s5612/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the Secretary approves the application of the Indian tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Notice","label":"2 Notice","identifier":"/us/usc/t25/s5612/b/2","parentIdentifier":"/us/usc/t25/s5612/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t25/s5612/b/2/A","parentIdentifier":"/us/usc/t25/s5612/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The Secretary shall provide a written notice to each Indian tribe approved to participate in the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Contents","label":"B Contents","identifier":"/us/usc/t25/s5612/b/2/B","parentIdentifier":"/us/usc/t25/s5612/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s5612/b/2/B/i","parentIdentifier":"/us/usc/t25/s5612/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"a statement that the application of the Indian tribe has been approved by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s5612/b/2/B/ii","parentIdentifier":"/us/usc/t25/s5612/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"a requirement that the Indian tribe shall submit to the Secretary a proposed Indian trust asset management plan in accordance with .section 5613 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Application","label":"c Application","identifier":"/us/usc/t25/s5612/c","parentIdentifier":"/us/usc/t25/s5612","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s5612/c/1","parentIdentifier":"/us/usc/t25/s5612/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fc%2F1","sourceRelease":"119-100","text":"To be eligible to participate in the project, an Indian tribe shall submit to the Secretary a written application in accordance with paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t25/s5612/c/2","parentIdentifier":"/us/usc/t25/s5612/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s5612/c/2/A","parentIdentifier":"/us/usc/t25/s5612/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fc%2F2%2FA","sourceRelease":"119-100","text":"includes a copy of a resolution or other appropriate action by the governing body of the Indian tribe, as determined by the Secretary, in support of or authorizing the application;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s5612/c/2/B","parentIdentifier":"/us/usc/t25/s5612/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fc%2F2%2FB","sourceRelease":"119-100","text":"is received by the Secretary after ; andJune 22, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s5612/c/2/C","parentIdentifier":"/us/usc/t25/s5612/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fc%2F2%2FC","sourceRelease":"119-100","text":"states that the Indian tribe is requesting to participate in the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Duration","label":"d Duration","identifier":"/us/usc/t25/s5612/d","parentIdentifier":"/us/usc/t25/s5612","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s5612/d/1","parentIdentifier":"/us/usc/t25/s5612/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fd%2F1","sourceRelease":"119-100","text":"shall remain in effect for a period of 10 years after ; butJune 22, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s5612/d/2","parentIdentifier":"/us/usc/t25/s5612/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5612%2Fd%2F2","sourceRelease":"119-100","text":"may be extended at the discretion of the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
