{"type":"section","nativeType":"section","number":"331","heading":"Evaluation of projects within an operational right-of-way","label":"331 Evaluation of projects within an operational right-of-way","identifier":"/us/usc/t23/s331","parentIdentifier":"/us/usc/t23/ch3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , see , set out as an Effective Date of 2021 Amendment note under .Oct. 1, 2021section 10003 of Pub. L. 117–58section 101 of this title"],"amendments":["Effective DateSection effective , see , set out as an Effective Date of 2021 Amendment note under .Oct. 1, 2021section 10003 of Pub. L. 117–58section 101 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions.—","label":"a Definitions.—","identifier":"/us/usc/t23/s331/a","parentIdentifier":"/us/usc/t23/s331","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible project or activity.—","label":"1 Eligible project or activity.—","identifier":"/us/usc/t23/s331/a/1","parentIdentifier":"/us/usc/t23/s331/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t23/s331/a/1/A","parentIdentifier":"/us/usc/t23/s331/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t23/s331/a/1/A/i","parentIdentifier":"/us/usc/t23/s331/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t23/s331/a/1/A/i/I","parentIdentifier":"/us/usc/t23/s331/a/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F1%2FA%2Fi%2FI","sourceRelease":"119-100","text":"eligible for assistance under this title; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t23/s331/a/1/A/i/II","parentIdentifier":"/us/usc/t23/s331/a/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F1%2FA%2Fi%2FII","sourceRelease":"119-100","text":"administered as if made available under this title;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t23/s331/a/1/A/ii","parentIdentifier":"/us/usc/t23/s331/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t23/s331/a/1/A/ii/I","parentIdentifier":"/us/usc/t23/s331/a/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F1%2FA%2Fii%2FI","sourceRelease":"119-100","text":"a preventive maintenance, preservation, or highway safety improvement project (as defined in section 148(a)); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t23/s331/a/1/A/ii/II","parentIdentifier":"/us/usc/t23/s331/a/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F1%2FA%2Fii%2FII","sourceRelease":"119-100","text":"a new turn lane that the State advises in writing to the Secretary would assist public safety; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t23/s331/a/1/A/iii","parentIdentifier":"/us/usc/t23/s331/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F1%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t23/s331/a/1/A/iii/I","parentIdentifier":"/us/usc/t23/s331/a/1/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F1%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"is classified as a categorical exclusion under section 771.117 of title 23, Code of Federal Regulations (or successor regulations); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t23/s331/a/1/A/iii/II","parentIdentifier":"/us/usc/t23/s331/a/1/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F1%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"if the project or activity does not receive assistance described in clause (i) would be considered a categorical exclusion if the project or activity received assistance described in clause (i).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Exclusion","label":"B .—Exclusion","identifier":"/us/usc/t23/s331/a/1/B","parentIdentifier":"/us/usc/t23/s331/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F1%2FB","sourceRelease":"119-100","text":"The term “eligible project or activity” does not include a project to create a new travel lane.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Preliminary evaluation","label":"2 .—Preliminary evaluation","identifier":"/us/usc/t23/s331/a/2","parentIdentifier":"/us/usc/t23/s331/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F2","sourceRelease":"119-100","text":"The term “preliminary evaluation”, with respect to an application described in subsection (b)(1), means an evaluation that is customary or practicable for the relevant agency to complete within a 45-day period for similar applications.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Relevant agency","label":"3 .—Relevant agency","identifier":"/us/usc/t23/s331/a/3","parentIdentifier":"/us/usc/t23/s331/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fa%2F3","sourceRelease":"119-100","text":"The term “relevant agency” means a Federal agency, other than the Federal Highway Administration, with responsibility for review of an application from a State for a permit, approval, or jurisdictional determination for an eligible project or activity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Action Required.—","label":"b Action Required.—","identifier":"/us/usc/t23/s331/b","parentIdentifier":"/us/usc/t23/s331","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t23/s331/b/1","parentIdentifier":"/us/usc/t23/s331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t23/s331/b/1/A","parentIdentifier":"/us/usc/t23/s331/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fb%2F1%2FA","sourceRelease":"119-100","text":"make at least a preliminary evaluation of the application; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t23/s331/b/1/B","parentIdentifier":"/us/usc/t23/s331/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fb%2F1%2FB","sourceRelease":"119-100","text":"notify the State of the results of the preliminary evaluation under subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Extension","label":"2 .—Extension","identifier":"/us/usc/t23/s331/b/2","parentIdentifier":"/us/usc/t23/s331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fb%2F2","sourceRelease":"119-100","text":"The head of the relevant agency may extend the review period under paragraph (1) by not more than 30 days if the head of the relevant agency provides to the State written notice that includes an explanation of the need for the extension.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Failure to act","label":"3 .—Failure to act","identifier":"/us/usc/t23/s331/b/3","parentIdentifier":"/us/usc/t23/s331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t23/s331/b/3/A","parentIdentifier":"/us/usc/t23/s331/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fb%2F3%2FA","sourceRelease":"119-100","text":"not later than 30 days after the date of the missed deadline, submit to the State, the Committee on Environment and Public Works of the Senate, and the Committee on Transportation and Infrastructure of the House of Representatives a report that describes why the deadline was missed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t23/s331/b/3/B","parentIdentifier":"/us/usc/t23/s331/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs331%2Fb%2F3%2FB","sourceRelease":"119-100","text":"not later than 14 days after the date on which a report is submitted under subparagraph (A), make publicly available, including on the internet, a copy of that report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
