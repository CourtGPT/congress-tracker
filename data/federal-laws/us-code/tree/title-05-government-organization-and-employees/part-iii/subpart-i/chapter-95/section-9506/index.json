{"type":"section","nativeType":"section","number":"9506","heading":"Limited appointments to career reserved Senior Executive Service positions","label":"9506 Limited appointments to career reserved Senior Executive Service positions","identifier":"/us/usc/t5/s9506","parentIdentifier":"/us/usc/t5/ptIII/sptI/ch95","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9506","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s9506/a","parentIdentifier":"/us/usc/t5/s9506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9506%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s9506/a/1","parentIdentifier":"/us/usc/t5/s9506/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9506%2Fa%2F1","sourceRelease":"119-100","text":"a career appointee; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s9506/a/2","parentIdentifier":"/us/usc/t5/s9506/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9506%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s9506/a/2/A","parentIdentifier":"/us/usc/t5/s9506/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9506%2Fa%2F2%2FA","sourceRelease":"119-100","text":"who, immediately upon entering the career reserved position, was serving under a career or career-conditional appointment outside the Senior Executive Service; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s9506/a/2/B","parentIdentifier":"/us/usc/t5/s9506/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9506%2Fa%2F2%2FB","sourceRelease":"119-100","text":"whose limited emergency or limited term appointment is approved in advance by the Office of Personnel Management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s9506/b","parentIdentifier":"/us/usc/t5/s9506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9506%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s9506/b/1","parentIdentifier":"/us/usc/t5/s9506/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9506%2Fb%2F1","sourceRelease":"119-100","text":"The number of positions described under subsection (a) which are filled by an appointee as described under paragraph (2) of such subsection may not exceed 10 percent of the total number of Senior Executive Service positions in the Internal Revenue Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s9506/b/2","parentIdentifier":"/us/usc/t5/s9506/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9506%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s9506/b/2/A","parentIdentifier":"/us/usc/t5/s9506/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9506%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the term of an appointee described under subsection (a)(2) may be for any period not to exceed 3 years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s9506/b/2/B","parentIdentifier":"/us/usc/t5/s9506/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9506%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t5/s9506/b/2/B/i","parentIdentifier":"/us/usc/t5/s9506/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9506%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"two such terms; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t5/s9506/b/2/B/ii","parentIdentifier":"/us/usc/t5/s9506/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9506%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"two such terms in addition to any unexpired term applicable at the time of appointment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
