{"type":"section","nativeType":"section","number":"183a","heading":"Oral history of the House of Representatives","label":"183a Oral history of the House of Representatives","identifier":"/us/usc/t2/s183a","parentIdentifier":"/us/usc/t2/ch5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs183a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t2/s183a/a","parentIdentifier":"/us/usc/t2/s183a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs183a%2Fa","sourceRelease":"119-100","text":"The Librarian of Congress shall accept for deposit, preserve, maintain, and make accessible an oral history of the House of Representatives, as told by its Members and former Members, compiled and updated (on a voluntary or contract basis) by the United States Association of Former Members of Congress or other private organization. In carrying out this section, the Librarian of Congress may enlist the voluntary aid or assistance of such organization, or may contract with it for such services as may be necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Definition of oral history","label":"b Definition of oral history","identifier":"/us/usc/t2/s183a/b","parentIdentifier":"/us/usc/t2/s183a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs183a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s183a/b/1","parentIdentifier":"/us/usc/t2/s183a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs183a%2Fb%2F1","sourceRelease":"119-100","text":"Interviews.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s183a/b/2","parentIdentifier":"/us/usc/t2/s183a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs183a%2Fb%2F2","sourceRelease":"119-100","text":"Transcripts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t2/s183a/b/3","parentIdentifier":"/us/usc/t2/s183a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs183a%2Fb%2F3","sourceRelease":"119-100","text":"Audio recordings.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t2/s183a/b/4","parentIdentifier":"/us/usc/t2/s183a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs183a%2Fb%2F4","sourceRelease":"119-100","text":"Video recordings.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t2/s183a/b/5","parentIdentifier":"/us/usc/t2/s183a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs183a%2Fb%2F5","sourceRelease":"119-100","text":"Such other form or means as may be suitable for the recording and preservation of such information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
