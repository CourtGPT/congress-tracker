{"type":"section","nativeType":"section","number":"2265A","heading":"Repeat offenders","label":"2265A Repeat offenders","identifier":"/us/usc/t18/s2265A","parentIdentifier":"/us/usc/t18/ptI/ch110A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2265A","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2013—Subsec. (b)(1)(B). inserted “or tribal” after “State”.Pub. L. 113–4"],"amendments":["Amendments2013—Subsec. (b)(1)(B). inserted “or tribal” after “State”.Pub. L. 113–4"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Maximum Term of Imprisonment","label":"a .—Maximum Term of Imprisonment","identifier":"/us/usc/t18/s2265A/a","parentIdentifier":"/us/usc/t18/s2265A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2265A%2Fa","sourceRelease":"119-100","text":"The maximum term of imprisonment for a violation of this chapter after a prior domestic violence or stalking offense shall be twice the term otherwise provided under this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Definition","label":"b .—Definition","identifier":"/us/usc/t18/s2265A/b","parentIdentifier":"/us/usc/t18/s2265A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2265A%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2265A/b/1","parentIdentifier":"/us/usc/t18/s2265A/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2265A%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s2265A/b/1/A","parentIdentifier":"/us/usc/t18/s2265A/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2265A%2Fb%2F1%2FA","sourceRelease":"119-100","text":"under section 2261, 2261A, or 2262 of this chapter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s2265A/b/1/B","parentIdentifier":"/us/usc/t18/s2265A/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2265A%2Fb%2F1%2FB","sourceRelease":"119-100","text":"under State or tribal law for an offense consisting of conduct that would have been an offense under a section referred to in subparagraph (A) if the conduct had occurred within the special maritime and territorial jurisdiction of the United States, or in interstate or foreign commerce; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2265A/b/2","parentIdentifier":"/us/usc/t18/s2265A/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2265A%2Fb%2F2","sourceRelease":"119-100","text":"the term “State” means a State of the United States, the District of Columbia, or any commonwealth, territory, or possession of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
