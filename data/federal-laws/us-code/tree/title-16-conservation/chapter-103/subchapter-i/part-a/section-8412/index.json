{"type":"section","nativeType":"section","number":"8412","heading":"Identifying opportunities for recreation","label":"8412 Identifying opportunities for recreation","identifier":"/us/usc/t16/s8412","parentIdentifier":"/us/usc/t16/ch103/schI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8412","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection is comprised of . Subsec. (c) of amended , National Park Service and Related Programs.section 112 of Pub. L. 118–234section 112 of Pub. L. 118–234section 200103 of Title 54"],"amendments":["CodificationSection is comprised of . Subsec. (c) of amended , National Park Service and Related Programs.section 112 of Pub. L. 118–234section 112 of Pub. L. 118–234section 200103 of Title 54"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Inventory and assessments","label":"a Inventory and assessments","identifier":"/us/usc/t16/s8412/a","parentIdentifier":"/us/usc/t16/s8412","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8412%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s8412/a/1","parentIdentifier":"/us/usc/t16/s8412/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8412%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8412/a/1/A","parentIdentifier":"/us/usc/t16/s8412/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8412%2Fa%2F1%2FA","sourceRelease":"119-100","text":"conduct an inventory and assessment of recreation resources for Federal recreational lands and waters;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8412/a/1/B","parentIdentifier":"/us/usc/t16/s8412/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8412%2Fa%2F1%2FB","sourceRelease":"119-100","text":"develop the inventory and assessment with support from public comment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8412/a/1/C","parentIdentifier":"/us/usc/t16/s8412/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8412%2Fa%2F1%2FC","sourceRelease":"119-100","text":"update the inventory and assessment as the Secretary concerned determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Unique recreation values","label":"2 Unique recreation values","identifier":"/us/usc/t16/s8412/a/2","parentIdentifier":"/us/usc/t16/s8412/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8412%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8412/a/2/A","parentIdentifier":"/us/usc/t16/s8412/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8412%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8412/a/2/A/i","parentIdentifier":"/us/usc/t16/s8412/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8412%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":