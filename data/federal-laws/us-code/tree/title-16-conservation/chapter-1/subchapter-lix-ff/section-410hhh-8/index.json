{"type":"section","nativeType":"section","number":"410hhh–8","heading":"Advisory Council","label":"410hhh–8 Advisory Council","identifier":"/us/usc/t16/s410hhh–8","parentIdentifier":"/us/usc/t16/ch1/schLIX–FF","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2022—Subsec. (d). substituted “chapter 10 of title 5” for “the Federal Advisory Committee Act (5 U.S.C. App.)”.Pub. L. 117–286"],"amendments":["Amendments2022—Subsec. (d). substituted “chapter 10 of title 5” for “the Federal Advisory Committee Act (5 U.S.C. App.)”.Pub. L. 117–286"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t16/s410hhh–8/a","parentIdentifier":"/us/usc/t16/s410hhh–8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish an advisory council to be known as the “Great Sand Dunes National Park Advisory Council”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties","label":"b Duties","identifier":"/us/usc/t16/s410hhh–8/b","parentIdentifier":"/us/usc/t16/s410hhh–8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Fb","sourceRelease":"119-100","text":"The Advisory Council shall advise the Secretary with respect to the preparation and implementation of a management plan for the national park and the preserve.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Members","label":"c Members","identifier":"/us/usc/t16/s410hhh–8/c","parentIdentifier":"/us/usc/t16/s410hhh–8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410hhh–8/c/1","parentIdentifier":"/us/usc/t16/s410hhh–8/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Fc%2F1","sourceRelease":"119-100","text":"One member of, or nominated by, the Alamosa County Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410hhh–8/c/2","parentIdentifier":"/us/usc/t16/s410hhh–8/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Fc%2F2","sourceRelease":"119-100","text":"One member of, or nominated by, the Saguache County Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s410hhh–8/c/3","parentIdentifier":"/us/usc/t16/s410hhh–8/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Fc%2F3","sourceRelease":"119-100","text":"One member of, or nominated by, the Friends of the Dunes Organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s410hhh–8/c/4","parentIdentifier":"/us/usc/t16/s410hhh–8/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410hhh–8/c/4/A","parentIdentifier":"/us/usc/t16/s410hhh–8/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Fc%2F4%2FA","sourceRelease":"119-100","text":"the purposes for which the national park and the preserve are established; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410hhh–8/c/4/B","parentIdentifier":"/us/usc/t16/s410hhh–8/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Fc%2F4%2FB","sourceRelease":"119-100","text":"the interests of persons that will be affected by the planning and management of the national park and the preserve.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Applicable law","label":"d Applicable law","identifier":"/us/usc/t16/s410hhh–8/d","parentIdentifier":"/us/usc/t16/s410hhh–8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Fd","sourceRelease":"119-100","text":"The Advisory Council shall function in accordance with chapter 10 of title 5 and other applicable laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Vacancy","label":"e Vacancy","identifier":"/us/usc/t16/s410hhh–8/e","parentIdentifier":"/us/usc/t16/s410hhh–8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Fe","sourceRelease":"119-100","text":"A vacancy on the Advisory Council shall be filled in the same manner as the original appointment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Chairperson","label":"f Chairperson","identifier":"/us/usc/t16/s410hhh–8/f","parentIdentifier":"/us/usc/t16/s410hhh–8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Ff","sourceRelease":"119-100","text":"The Advisory Council shall elect a chairperson and shall establish such rules and procedures as it deems necessary or desirable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"No compensation","label":"g No compensation","identifier":"/us/usc/t16/s410hhh–8/g","parentIdentifier":"/us/usc/t16/s410hhh–8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Fg","sourceRelease":"119-100","text":"Members of the Advisory Council shall serve without compensation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Termination","label":"h Termination","identifier":"/us/usc/t16/s410hhh–8/h","parentIdentifier":"/us/usc/t16/s410hhh–8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%938%2Fh","sourceRelease":"119-100","text":"The Advisory Council shall terminate upon the completion of the management plan for the national park and preserve.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
