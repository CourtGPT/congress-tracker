{"type":"section","nativeType":"section","number":"4692","heading":"Suspension of liquidation","label":"4692 Suspension of liquidation","identifier":"/us/usc/t19/s4692","parentIdentifier":"/us/usc/t19/ch29/schVI/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4692","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t19/s4692/a","parentIdentifier":"/us/usc/t19/s4692","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4692%2Fa","sourceRelease":"119-100","text":"If the United States files a request pursuant to article 31–A.4.2 of Annex 31–A of the USMCA, the Trade Representative may direct the Secretary of the Treasury to suspend liquidation for unliquidated entries of goods from such covered facility until such time as the Trade Representative notifies the Secretary that a condition described in subsection (b) has been met.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Resumption of liquidation","label":"b Resumption of liquidation","identifier":"/us/usc/t19/s4692/b","parentIdentifier":"/us/usc/t19/s4692","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4692%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4692/b/1","parentIdentifier":"/us/usc/t19/s4692/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4692%2Fb%2F1","sourceRelease":"119-100","text":"The rapid response labor panel has determined that there is no denial of rights at the covered facility within the meaning of such terms under Annex 31–A of the USMCA.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4692/b/2","parentIdentifier":"/us/usc/t19/s4692/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4692%2Fb%2F2","sourceRelease":"119-100","text":"A course of remediation for denial of rights has been agreed to and has been completed in accordance with the agreed-upon time.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s4692/b/3","parentIdentifier":"/us/usc/t19/s4692/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4692%2Fb%2F3","sourceRelease":"119-100","text":"The denial of rights has been otherwise remedied.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
