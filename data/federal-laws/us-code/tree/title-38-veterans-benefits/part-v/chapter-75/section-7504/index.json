{"type":"section","nativeType":"section","number":"7504","heading":"Agreement","label":"7504 Agreement","identifier":"/us/usc/t38/s7504","parentIdentifier":"/us/usc/t38/ptV/ch75","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7504","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s7504/1","parentIdentifier":"/us/usc/t38/s7504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7504%2F1","sourceRelease":"119-100","text":"the Secretary’s agreement to provide the participant with financial assistance as authorized under this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s7504/2","parentIdentifier":"/us/usc/t38/s7504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7504%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s7504/2/A","parentIdentifier":"/us/usc/t38/s7504/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7504%2F2%2FA","sourceRelease":"119-100","text":"to accept such financial assistance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s7504/2/B","parentIdentifier":"/us/usc/t38/s7504/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7504%2F2%2FB","sourceRelease":"119-100","text":"to maintain enrollment and attendance in the program of study described in ;section 7501(a)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s7504/2/C","parentIdentifier":"/us/usc/t38/s7504/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7504%2F2%2FC","sourceRelease":"119-100","text":"while enrolled in such program, to maintain an acceptable level of academic standing (as determined by the educational institution offering such program under regulations prescribed by the Secretary); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t38/s7504/2/D","parentIdentifier":"/us/usc/t38/s7504/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7504%2F2%2FD","sourceRelease":"119-100","text":"after completion of the program, to serve as a full-time employee in the Department for a period of three years, to be served within the first six years after the participant has completed such program and received a degree or certificate described in ; andsection 7501(a)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s7504/3","parentIdentifier":"/us/usc/t38/s7504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7504%2F3","sourceRelease":"119-100","text":"any other terms and conditions that the Secretary considers appropriate for carrying out this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
