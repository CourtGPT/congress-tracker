{"type":"section","nativeType":"section","number":"1079c","heading":"Provisional coverage for emerging services and supplies","label":"1079c Provisional coverage for emerging services and supplies","identifier":"/us/usc/t10/s1079c","parentIdentifier":"/us/usc/t10/stA/ptII/ch55","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Provisional Coverage","label":"a .—Provisional Coverage","identifier":"/us/usc/t10/s1079c/a","parentIdentifier":"/us/usc/t10/s1079c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fa","sourceRelease":"119-100","text":"In carrying out the TRICARE program, including pursuant to , the Secretary of Defense, acting through the Assistant Secretary of Defense for Health Affairs, may provide provisional coverage for the provision of a service or supply if the Secretary determines that such service or supply is widely recognized in the United States as being safe and effective.section 1079(a)(12) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Consideration of Evidence","label":"b .—Consideration of Evidence","identifier":"/us/usc/t10/s1079c/b","parentIdentifier":"/us/usc/t10/s1079c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1079c/b/1","parentIdentifier":"/us/usc/t10/s1079c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fb%2F1","sourceRelease":"119-100","text":"clinical trials published in refereed medical literature;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1079c/b/2","parentIdentifier":"/us/usc/t10/s1079c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fb%2F2","sourceRelease":"119-100","text":"formal technology assessments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s1079c/b/3","parentIdentifier":"/us/usc/t10/s1079c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fb%2F3","sourceRelease":"119-100","text":"the positions of national medical policy organizations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s1079c/b/4","parentIdentifier":"/us/usc/t10/s1079c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fb%2F4","sourceRelease":"119-100","text":"national professional associations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s1079c/b/5","parentIdentifier":"/us/usc/t10/s1079c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fb%2F5","sourceRelease":"119-100","text":"national expert opinion organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t10/s1079c/b/6","parentIdentifier":"/us/usc/t10/s1079c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fb%2F6","sourceRelease":"119-100","text":"such other validated evidence as the Secretary considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Independent Evaluation","label":"c .—Independent Evaluation","identifier":"/us/usc/t10/s1079c/c","parentIdentifier":"/us/usc/t10/s1079c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fc","sourceRelease":"119-100","text":"In making a determination under subsection (a), the Secretary may arrange for an evaluation from the Institute of Medicine of the National Academies or such other independent entity as the Secretary selects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Duration and Terms of Coverage","label":"d .—Duration and Terms of Coverage","identifier":"/us/usc/t10/s1079c/d","parentIdentifier":"/us/usc/t10/s1079c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1079c/d/1","parentIdentifier":"/us/usc/t10/s1079c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fd%2F1","sourceRelease":"119-100","text":"Provisional coverage under subsection (a) for a service or supply may be in effect for not longer than a total of five years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1079c/d/2","parentIdentifier":"/us/usc/t10/s1079c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fd%2F2","sourceRelease":"119-100","text":"Prior to the expiration of provisional coverage of a service or supply, the Secretary shall determine the coverage, if any, that will follow such provisional coverage and take appropriate action to implement such determination. If the Secretary determines that the implementation of such determination regarding coverage requires legislative action, the Secretary shall make a timely recommendation to Congress regarding such legislative action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s1079c/d/3","parentIdentifier":"/us/usc/t10/s1079c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s1079c/d/3/A","parentIdentifier":"/us/usc/t10/s1079c/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fd%2F3%2FA","sourceRelease":"119-100","text":"terminate the provisional coverage under subsection (a) of a service or supply, regardless of whether such termination is before the end of the period described in paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s1079c/d/3/B","parentIdentifier":"/us/usc/t10/s1079c/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fd%2F3%2FB","sourceRelease":"119-100","text":"establish or disestablish terms and conditions for such coverage; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s1079c/d/3/C","parentIdentifier":"/us/usc/t10/s1079c/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fd%2F3%2FC","sourceRelease":"119-100","text":"take any other action with respect to such coverage.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Public Notice","label":"e .—Public Notice","identifier":"/us/usc/t10/s1079c/e","parentIdentifier":"/us/usc/t10/s1079c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Fe","sourceRelease":"119-100","text":"The Secretary shall promptly publish on a publicly accessible Internet website of the TRICARE program a notice for each service or supply that receives provisional coverage under subsection (a), including any terms and conditions for such coverage.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Finality of Determinations","label":"f .—Finality of Determinations","identifier":"/us/usc/t10/s1079c/f","parentIdentifier":"/us/usc/t10/s1079c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1079c%2Ff","sourceRelease":"119-100","text":"Any determination to approve or disapprove a service or supply under subsection (a) and any action made under subsection (d)(3) shall be final.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
