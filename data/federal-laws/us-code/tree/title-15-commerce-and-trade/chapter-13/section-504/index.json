{"type":"section","nativeType":"section","number":"504","heading":"Powers of Foundation","label":"504 Powers of Foundation","identifier":"/us/usc/t15/s504","parentIdentifier":"/us/usc/t15/ch13","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs504","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t15/s504/a","parentIdentifier":"/us/usc/t15/s504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs504%2Fa","sourceRelease":"119-100","text":"Shall have perpetual succession;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t15/s504/b","parentIdentifier":"/us/usc/t15/s504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs504%2Fb","sourceRelease":"119-100","text":"May sue and be sued;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t15/s504/c","parentIdentifier":"/us/usc/t15/s504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs504%2Fc","sourceRelease":"119-100","text":"May adopt a corporate seal and alter it at pleasure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t15/s504/d","parentIdentifier":"/us/usc/t15/s504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs504%2Fd","sourceRelease":"119-100","text":"May adopt and alter bylaws;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":null,"label":"e","identifier":"/us/usc/t15/s504/e","parentIdentifier":"/us/usc/t15/s504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs504%2Fe","sourceRelease":"119-100","text":"May appoint officers and agents;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":null,"label":"f","identifier":"/us/usc/t15/s504/f","parentIdentifier":"/us/usc/t15/s504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs504%2Ff","sourceRelease":"119-100","text":"May acquire by purchase, devise, bequest, gift, or otherwise, and hold, encumber, convey, or otherwise dispose of, such real and personal property as may be necessary or appropriate for its corporate purposes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":null,"label":"g","identifier":"/us/usc/t15/s504/g","parentIdentifier":"/us/usc/t15/s504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs504%2Fg","sourceRelease":"119-100","text":"May invest and reinvest the principal and interest of its funds; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":null,"label":"h","identifier":"/us/usc/t15/s504/h","parentIdentifier":"/us/usc/t15/s504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs504%2Fh","sourceRelease":"119-100","text":"Generally, may do any and all lawful acts necessary or appropriate to carry out the purposes for which the corporation is created.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
