{"type":"section","nativeType":"section","number":"80r","heading":"Findings","label":"80r Findings","identifier":"/us/usc/t20/s80r","parentIdentifier":"/us/usc/t20/ch3/schXIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Short Title, , , provided that:Pub. L. 108–184, § 1117 Stat. 2676Dec. 16, 2003“This Act [enacting this subchapter] may be cited as the ‘National Museum of African American History and Culture Act’.”"],"amendments":["Short Title, , , provided that:Pub. L. 108–184, § 1117 Stat. 2676Dec. 16, 2003“This Act [enacting this subchapter] may be cited as the ‘National Museum of African American History and Culture Act’.”"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s80r/1","parentIdentifier":"/us/usc/t20/s80r","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%2F1","sourceRelease":"119-100","text":"since its founding, the United States has grown into a symbol of democracy and freedom around the world, and the legacy of African Americans is rooted in the very fabric of the democracy and freedom of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s80r/2","parentIdentifier":"/us/usc/t20/s80r","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s80r/2/A","parentIdentifier":"/us/usc/t20/s80r/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%2F2%2FA","sourceRelease":"119-100","text":"is devoted to the documentation of African American life, art, history, and culture; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s80r/2/B","parentIdentifier":"/us/usc/t20/s80r/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s80r/2/B/i","parentIdentifier":"/us/usc/t20/s80r/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the period of slavery;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s80r/2/B/ii","parentIdentifier":"/us/usc/t20/s80r/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the era of Reconstruction;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t20/s80r/2/B/iii","parentIdentifier":"/us/usc/t20/s80r/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"the Harlem renaissance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t20/s80r/2/B/iv","parentIdentifier":"/us/usc/t20/s80r/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"the civil rights movement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t20/s80r/2/B/v","parentIdentifier":"/us/usc/t20/s80r/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%2F2%2FB%2Fv","sourceRelease":"119-100","text":"other periods associated with African American life, art, history, and culture; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s80r/3","parentIdentifier":"/us/usc/t20/s80r","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%2F3","sourceRelease":"119-100","text":"a National Museum of African American History and Culture would be dedicated to the collection, preservation, research, and exhibition of African American historical and cultural material reflecting the breadth and depth of the experiences of individuals of African descent living in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
