{"type":"section","nativeType":"section","number":"2576","heading":"General","label":"2576 General","identifier":"/us/usc/t19/s2576","parentIdentifier":"/us/usc/t19/ch13/schII/ptE/spt2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"No bar to engaging in standards activity","label":"a No bar to engaging in standards activity","identifier":"/us/usc/t19/s2576/a","parentIdentifier":"/us/usc/t19/s2576","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s2576/a/1","parentIdentifier":"/us/usc/t19/s2576/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576%2Fa%2F1","sourceRelease":"119-100","text":"to prohibit a Federal agency from engaging in activity related to standards-related measures, including any such measure relating to safety, the protection of human, animal, or plant life or health, the environment or consumers; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s2576/a/2","parentIdentifier":"/us/usc/t19/s2576/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2576%2Fa%2F2","sourceRelease":"119-100","text":"to limit the authority of a Federal agency to determine the level it considers appropriate of safety or of protection of human, animal, or plant life or health, the environment or consumers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Exclusion","label":"