{"type":"section","nativeType":"section","number":"44734","heading":"Training of flight attendants","label":"44734 Training of flight attendants","identifier":"/us/usc/t49/s44734","parentIdentifier":"/us/usc/t49/stVII/ptA/sptiii/ch447","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44734","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2016—Subsec. (a)(4). added par. (4).Pub. L. 114–190"],"amendments":["Amendments2016—Subsec. (a)(4). added par. (4).Pub. L. 114–190"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Training Required","label":"a .—Training Required","identifier":"/us/usc/t49/s44734/a","parentIdentifier":"/us/usc/t49/s44734","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44734%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s44734/a/1","parentIdentifier":"/us/usc/t49/s44734/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44734%2Fa%2F1","sourceRelease":"119-100","text":"serving alcohol to passengers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s44734/a/2","parentIdentifier":"/us/usc/t49/s44734/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44734%2Fa%2F2","sourceRelease":"119-100","text":"recognizing intoxicated passengers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s44734/a/3","parentIdentifier":"/us/usc/t49/s44734/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44734%2Fa%2F3","sourceRelease":"119-100","text":"dealing with disruptive passengers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s44734/a/4","parentIdentifier":"/us/usc/t49/s44734/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44734%2Fa%2F4","sourceRelease":"119-100","text":"recognizing and responding to potential human trafficking victims.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Situational Training","label":"b .—Situational Training","identifier":"/us/usc/t49/s44734/b","parentIdentifier":"/us/usc/t49/s44734","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44734%2Fb","sourceRelease":"119-100","text":"In carrying out the training required under subsection (a), each air carrier shall provide to flight attendants situational training on the proper method for dealing with intoxicated passengers who act in a belligerent manner.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Definitions","label":"c .—Definitions","identifier":"/us/usc/t49/s44734/c","parentIdentifier":"/us/usc/t49/s44734","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44734%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Air carrier","label":"1 .—Air carrier","identifier":"/us/usc/t49/s44734/c/1","parentIdentifier":"/us/usc/t49/s44734/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44734%2Fc%2F1","sourceRelease":"119-100","text":"The term “air carrier” means a person, including a commercial enterprise, that has been issued an air carrier operating certificate under section 44705.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Flight attendant","label":"2 .—Flight attendant","identifier":"/us/usc/t49/s44734/c/2","parentIdentifier":"/us/usc/t49/s44734/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44734%2Fc%2F2","sourceRelease":"119-100","text":"The term “flight attendant” has the meaning given that term in section 44728(g).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
