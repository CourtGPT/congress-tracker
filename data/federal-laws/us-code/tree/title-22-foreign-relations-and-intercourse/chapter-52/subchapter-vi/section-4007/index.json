{"type":"section","nativeType":"section","number":"4007","heading":"Retirement for expiration of time in class","label":"4007 Retirement for expiration of time in class","identifier":"/us/usc/t22/s4007","parentIdentifier":"/us/usc/t22/ch52/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Maximum time","label":"a Maximum time","identifier":"/us/usc/t22/s4007/a","parentIdentifier":"/us/usc/t22/s4007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4007/a/1","parentIdentifier":"/us/usc/t22/s4007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s4007/a/1/A","parentIdentifier":"/us/usc/t22/s4007/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fa%2F1%2FA","sourceRelease":"119-100","text":"career members of the Senior Foreign Service,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s4007/a/1/B","parentIdentifier":"/us/usc/t22/s4007/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fa%2F1%2FB","sourceRelease":"119-100","text":"Foreign Service officers, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s4007/a/1/C","parentIdentifier":"/us/usc/t22/s4007/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fa%2F1%2FC","sourceRelease":"119-100","text":"other career members of the Service who are in such occupational categories as may be designated by the Secretary and who are assigned to salary classes in the Foreign Service Schedule to which Foreign Service officers may also be assigned.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4007/a/2","parentIdentifier":"/us/usc/t22/s4007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fa%2F2","sourceRelease":"119-100","text":"Maximum time in class limitations under this subsection (which may not be less than 3 years for career members of the Senior Foreign Service) may apply with respect to the time a member may remain in a single salary class or in a combination of salary classes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s4007/a/3","parentIdentifier":"/us/usc/t22/s4007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s4007/a/3/A","parentIdentifier":"/us/usc/t22/s4007/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fa%2F3%2FA","sourceRelease":"119-100","text":"the period which the member would have been permitted to remain in class but for the decrease in maximum time in class, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s4007/a/3/B","parentIdentifier":"/us/usc/t22/s4007/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fa%2F3%2FB","sourceRelease":"119-100","text":"such minimum period as the Secretary determines is necessary to provide members of the Service who are in the same category and salary class as that member a reasonable opportunity to be promoted into the next higher class or combination of classes, as the case may be.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limited career extension","label":"b Limited career extension","identifier":"/us/usc/t22/s4007/b","parentIdentifier":"/us/usc/t22/s4007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4007/b/1","parentIdentifier":"/us/usc/t22/s4007/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fb%2F1","sourceRelease":"119-100","text":"after they have attained the highest salary class for their respective occupational categories, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4007/b/2","parentIdentifier":"/us/usc/t22/s4007/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fb%2F2","sourceRelease":"119-100","text":"in the case of members of the Senior Foreign Service, while they are in salary classes designated by the Secretary,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Members subject to retirement; reception of retirement benefits","label":"c Members subject to retirement; reception of retirement benefits","identifier":"/us/usc/t22/s4007/c","parentIdentifier":"/us/usc/t22/s4007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4007/c/1","parentIdentifier":"/us/usc/t22/s4007/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fc%2F1","sourceRelease":"119-100","text":"whose maximum time in class under subsection (a) expires and who is not promoted to a higher class or combination of classes, as the case may be, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4007/c/2","parentIdentifier":"/us/usc/t22/s4007/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fc%2F2","sourceRelease":"119-100","text":"whose limited career extension under subsection (b) expires and is not renewed,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Extensions","label":"d Extensions","identifier":"/us/usc/t22/s4007/d","parentIdentifier":"/us/usc/t22/s4007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4007/d/1","parentIdentifier":"/us/usc/t22/s4007/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fd%2F1","sourceRelease":"119-100","text":"the career appointment of a member of the Service whose maximum time in class under subsection (a) expires, or whose limited career extension under subsection (b) expires, while that member is occupying a position to which he or she was appointed by the President, by and with the advice and consent of the Senate, shall be extended until the appointment to that position is terminated; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4007/d/2","parentIdentifier":"/us/usc/t22/s4007/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4007%2Fd%2F2","sourceRelease":"119-100","text":"if the Secretary determines it to be in the public interest, the Secretary may extend temporarily the career appointment of a career member of the Service whose maximum time in class or limited career extension expires, but in no case may any extension under this paragraph exceed one year and such extensions may be granted only in special circumstances.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
