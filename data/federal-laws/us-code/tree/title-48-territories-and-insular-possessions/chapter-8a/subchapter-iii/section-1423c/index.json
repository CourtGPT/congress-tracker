{"type":"section","nativeType":"section","number":"1423c","heading":"Privileges of members","label":"1423c Privileges of members","identifier":"/us/usc/t48/s1423c","parentIdentifier":"/us/usc/t48/ch8A/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1423c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t48/s1423c/a","parentIdentifier":"/us/usc/t48/s1423c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1423c%2Fa","sourceRelease":"119-100","text":"The members of the legislature shall, in all cases except treason, felony, or breach of the peace, be privileged from arrest during their attendance at the legislature and in going to and returning from the same.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t48/s1423c/b","parentIdentifier":"/us/usc/t48/s1423c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1423c%2Fb","sourceRelease":"119-100","text":"No member of the legislature shall be held to answer before any tribunal other than the legislature itself for any speech or debate in the legislature.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
