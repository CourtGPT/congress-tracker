{"type":"section","nativeType":"section","number":"5332","heading":"GAO audit of Council","label":"5332 GAO audit of Council","identifier":"/us/usc/t12/s5332","parentIdentifier":"/us/usc/t12/ch53/schI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5332","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authority to audit","label":"a Authority to audit","identifier":"/us/usc/t12/s5332/a","parentIdentifier":"/us/usc/t12/s5332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5332%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s5332/a/1","parentIdentifier":"/us/usc/t12/s5332/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5332%2Fa%2F1","sourceRelease":"119-100","text":"the Council; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s5332/a/2","parentIdentifier":"/us/usc/t12/s5332/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5332%2Fa%2F2","sourceRelease":"119-100","text":"any person or entity acting on behalf of or under the authority of the Council, to the extent that such activities relate to work for the Council by such person or entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Access to information","label":"b Access to information","identifier":"/us/usc/t12/s5332/b","parentIdentifier":"/us/usc/t12/s5332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5332%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t12/s5332/b/1","parentIdentifier":"/us/usc/t12/s5332/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5332%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s5332/b/1/A","parentIdentifier":"/us/usc/t12/s5332/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5332%2Fb%2F1%2FA","sourceRelease":"119-100","text":"any records or other information under the control of or used by the Council;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s5332/b/1/B","parentIdentifier":"/us/usc/t12/s5332/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5332%2Fb%2F1%2FB","sourceRelease":"119-100","text":"any records or other information under the control of a person or entity acting on behalf of or under the authority of the Council, to the extent that such records or other information is relevant to an audit under subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s5332/b/1/C","parentIdentifier":"/us/usc/t12/s5332/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5332%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the officers, directors, employees, financial advisors, staff, working groups, and agents and representatives of the Council (as related to the activities on behalf of the Council of such agent or representative), at such reasonable times as the Comptroller General may request.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Copies","label":"2 Copies","identifier":"/us/usc/t12/s5332/b/2","parentIdentifier":"/us/usc/t12/s5332/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5332%2Fb%2F2","sourceRelease":"119-100","text":"The Comptroller General may make and retain copies of such books, accounts, and other records, access to which is granted under this section, as the Comptroller General considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
