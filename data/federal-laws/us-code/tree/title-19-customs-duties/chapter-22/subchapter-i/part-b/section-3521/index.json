l":"ii","identifier":"/us/usc/t19/s3521/c/1/A/ii","parentIdentifier":"/us/usc/t19/s3521/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3521%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"consults with the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Rate of duty described","label":"B Rate of duty described","identifier":"/us/usc/t19/s3521/c/1/B","parentIdentifier":"/us/usc/t19/s3521/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3521%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s3521/c/1/B/i","parentIdentifier":"/us/usc/t19/s3521/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3521%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the rate of duty set forth for such article in the base rate of duty column of Schedule XX, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s3521/c/1/B/ii","parentIdentifier":"/us/usc/t19/s3521/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3521%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the rate of duty set forth for such article in the bound rate of duty column of Schedule XX.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Termination of increased duties","label":"2 Termination of increased duties","identifier":"/us/usc/t19/s3521/c/2","parentIdentifier":"/us/usc/t19/s3521/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3521%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s3521/c/2/A","parentIdentifier":"/us/usc/t19/s3521/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3521%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the date set out in such proclamation of termination, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s3521/c/2/B","parentIdentifier":"/us/usc/t19/s3521/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3521%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the date the WTO Agreement enters into force with respect to the foreign country with respect to which the determination under paragraph (1) was made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Publication of determination and termination","label":"3 Publication of determination and termination","identifier":"/us/usc/t19/s3521/c/3","parentIdentifier":"/us/usc/t19/s3521/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3521%2Fc%2F3","sourceRelease":"119-100","text":"The President shall publish in the Federal Register notice of a determination made under paragraph (1) and a termination occurring by reason of paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Adjustments to certain column 2 rates of duty","label":"d Adjustments to certain column 2 rates of duty","identifier":"/us/usc/t19/s3521/d","parentIdentifier":"/us/usc/t19/s3521","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2F