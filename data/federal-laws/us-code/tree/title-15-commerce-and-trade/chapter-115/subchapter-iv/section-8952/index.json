{"type":"section","nativeType":"section","number":"8952","heading":"Research and coordination plan for enhanced response on emerging contaminants","label":"8952 Research and coordination plan for enhanced response on emerging contaminants","identifier":"/us/usc/t15/s8952","parentIdentifier":"/us/usc/t15/ch115/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s8952/a","parentIdentifier":"/us/usc/t15/s8952","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8952/a/1","parentIdentifier":"/us/usc/t15/s8952/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8952/a/1/A","parentIdentifier":"/us/usc/t15/s8952/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fa%2F1%2FA","sourceRelease":"119-100","text":"to identify, monitor, and assist in the development of treatment methods for emerging contaminants; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8952/a/1/B","parentIdentifier":"/us/usc/t15/s8952/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fa%2F1%2FB","sourceRelease":"119-100","text":"to assist States in responding to the human health risks posed by contaminants of emerging concern; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8952/a/2","parentIdentifier":"/us/usc/t15/s8952/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fa%2F2","sourceRelease":"119-100","text":"in collaboration with owners and operators of public water systems, States, and other interested stakeholders, establish a strategic plan for improving the Federal efforts referred to in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Interagency Working Group on emerging contaminants","label":"b Interagency Working Group on emerging contaminants","identifier":"/us/usc/t15/s8952/b","parentIdentifier":"/us/usc/t15/s8952","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s8952/b/1","parentIdentifier":"/us/usc/t15/s8952/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fb%2F1","sourceRelease":"119-100","text":"Not later than 180 days after , the Administrator and the Secretary of Health and Human Services shall jointly establish a Working Group to coordinate the activities of the Federal Government to identify and analyze the public health effects of drinking water contaminants of emerging concern.December 20, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Membership","label":"2 Membership","identifier":"/us/usc/t15/s8952/b/2","parentIdentifier":"/us/usc/t15/s8952/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8952/b/2/A","parentIdentifier":"/us/usc/t15/s8952/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The Environmental Protection Agency, appointed by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8952/b/2/B","parentIdentifier":"/us/usc/t15/s8952/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s8952/b/2/B/i","parentIdentifier":"/us/usc/t15/s8952/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"The National Institutes of Health.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s8952/b/2/B/ii","parentIdentifier":"/us/usc/t15/s8952/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"The Centers for Disease Control and Prevention.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s8952/b/2/B/iii","parentIdentifier":"/us/usc/t15/s8952/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"The Agency for Toxic Substances and Disease Registry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s8952/b/2/C","parentIdentifier":"/us/usc/t15/s8952/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fb%2F2%2FC","sourceRelease":"119-100","text":"The United States Geological Survey, appointed by the Secretary of the Interior.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s8952/b/2/D","parentIdentifier":"/us/usc/t15/s8952/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fb%2F2%2FD","sourceRelease":"119-100","text":"Any other Federal agency the assistance of which the Administrator determines to be necessary to carry out this subsection, appointed by the head of the respective agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Existing working group","label":"3 Existing working group","identifier":"/us/usc/t15/s8952/b/3","parentIdentifier":"/us/usc/t15/s8952/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fb%2F3","sourceRelease":"119-100","text":"The Administrator may expand or modify the duties of an existing working group to perform the duties of the Working Group under this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"National Emerging Contaminant Research Initiative","label":"c National Emerging Contaminant Research Initiative","identifier":"/us/usc/t15/s8952/c","parentIdentifier":"/us/usc/t15/s8952","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Federal research strategy","label":"1 Federal research strategy","identifier":"/us/usc/t15/s8952/c/1","parentIdentifier":"/us/usc/t15/s8952/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s8952/c/1/A","parentIdentifier":"/us/usc/t15/s8952/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s8952/c/1/A/i","parentIdentifier":"/us/usc/t15/s8952/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"use the Federal research strategy to improve the identification, analysis, monitoring, and treatment methods of contaminants of emerging concern; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s8952/c/1/A/ii","parentIdentifier":"/us/usc/t15/s8952/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"develop any necessary program, policy, or budget to support the implementation of the Federal research strategy, including mechanisms for joint agency review of research proposals, for interagency cofunding of research activities, and for information sharing across agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Research on emerging contaminants","label":"B Research on emerging contaminants","identifier":"/us/usc/t15/s8952/c/1/B","parentIdentifier":"/us/usc/t15/s8952/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s8952/c/1/B/i","parentIdentifier":"/us/usc/t15/s8952/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"take into consideration consensus conclusions from peer-reviewed, pertinent research on emerging contaminants; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s8952/c/1/B/ii","parentIdentifier":"/us/usc/t15/s8952/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"in consultation with the Administrator, identify priority emerging contaminants for research emphasis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Federal participation","label":"C Federal participation","identifier":"/us/usc/t15/s8952/c/1/C","parentIdentifier":"/us/usc/t15/s8952/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s8952/c/1/C/i","parentIdentifier":"/us/usc/t15/s8952/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FC%2Fi","sourceRelease":"119-100","text":"the National Science Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s8952/c/1/C/ii","parentIdentifier":"/us/usc/t15/s8952/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FC%2Fii","sourceRelease":"119-100","text":"the National Institutes of Health;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s8952/c/1/C/iii","parentIdentifier":"/us/usc/t15/s8952/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"the Environmental Protection Agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t15/s8952/c/1/C/iv","parentIdentifier":"/us/usc/t15/s8952/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FC%2Fiv","sourceRelease":"119-100","text":"the National Institute of Standards and Technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t15/s8952/c/1/C/v","parentIdentifier":"/us/usc/t15/s8952/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FC%2Fv","sourceRelease":"119-100","text":"the United States Geological Survey; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t15/s8952/c/1/C/vi","parentIdentifier":"/us/usc/t15/s8952/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FC%2Fvi","sourceRelease":"119-100","text":"any other Federal agency that contributes to research in water quality, environmental exposures, and public health, as determined by the Director.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Participation from additional entities","label":"D Participation from additional entities","identifier":"/us/usc/t15/s8952/c/1/D","parentIdentifier":"/us/usc/t15/s8952/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F1%2FD","sourceRelease":"119-100","text":"In carrying out subparagraph (A), the Director shall consult with nongovernmental organizations, State and local governments, and science and research institutions determined by the Director to have scientific or material interest in the National Emerging Contaminant Research Initiative.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Implementation of research recommendations","label":"2 Implementation of research recommendations","identifier":"/us/usc/t15/s8952/c/2","parentIdentifier":"/us/usc/t15/s8952/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s8952/c/2/A","parentIdentifier":"/us/usc/t15/s8952/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s8952/c/2/A/i","parentIdentifier":"/us/usc/t15/s8952/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"issue a solicitation for research proposals consistent with the Federal research strategy and that agency’s mission; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s8952/c/2/A/ii","parentIdentifier":"/us/usc/t15/s8952/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":"make grants to applicants that submit research proposals consistent with the Federal research strategy and in accordance with subparagraph (B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Selection of research proposals","label":"B Selection of research proposals","identifier":"/us/usc/t15/s8952/c/2/B","parentIdentifier":"/us/usc/t15/s8952/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F2%2FB","sourceRelease":"119-100","text":"The head of each agency described in paragraph (1)(C) shall select research proposals to receive grants under this paragraph on the basis of merit, using criteria identified by the head of each such agency, including the likelihood that the proposed research will result in significant progress toward achieving the objectives identified in the Federal research strategy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Eligible entities","label":"C Eligible entities","identifier":"/us/usc/t15/s8952/c/2/C","parentIdentifier":"/us/usc/t15/s8952/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s8952/c/2/C/i","parentIdentifier":"/us/usc/t15/s8952/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F2%2FC%2Fi","sourceRelease":"119-100","text":"State and local agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s8952/c/2/C/ii","parentIdentifier":"/us/usc/t15/s8952/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F2%2FC%2Fii","sourceRelease":"119-100","text":"public institutions, including public institutions of higher education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s8952/c/2/C/iii","parentIdentifier":"/us/usc/t15/s8952/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F2%2FC%2Fiii","sourceRelease":"119-100","text":"private corporations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t15/s8952/c/2/C/iv","parentIdentifier":"/us/usc/t15/s8952/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fc%2F2%2FC%2Fiv","sourceRelease":"119-100","text":"nonprofit organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Federal technical assistance and support for States","label":"d Federal technical assistance and support for States","identifier":"/us/usc/t15/s8952/d","parentIdentifier":"/us/usc/t15/s8952","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Study","label":"1 Study","identifier":"/us/usc/t15/s8952/d/1","parentIdentifier":"/us/usc/t15/s8952/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s8952/d/1/A","parentIdentifier":"/us/usc/t15/s8952/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F1%2FA","sourceRelease":"119-100","text":"Not later than 1 year after , the Administrator shall conduct a study on actions the Administrator can take to increase technical assistance and support for States with respect to emerging contaminants in drinking water samples.December 20, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Contents of study","label":"B Contents of study","identifier":"/us/usc/t15/s8952/d/1/B","parentIdentifier":"/us/usc/t15/s8952/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s8952/d/1/B/i","parentIdentifier":"/us/usc/t15/s8952/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F1%2FB%2Fi","sourceRelease":"119-100","text":"methods and effective treatment options to increase technical assistance and support with respect to emerging contaminants to States, including identifying opportunities for States to improve communication with various audiences about the risks associated with emerging contaminants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s8952/d/1/B/ii","parentIdentifier":"/us/usc/t15/s8952/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F1%2FB%2Fii","sourceRelease":"119-100","text":"means to facilitate access to qualified contract testing laboratory facilities that conduct analyses for emerging contaminants; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s8952/d/1/B/iii","parentIdentifier":"/us/usc/t15/s8952/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"actions to be carried out at existing Federal laboratory facilities, including the research facilities of the Administrator, to provide technical assistance and support for States that require testing facilities for emerging contaminants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Availability of analytical resources","label":"C Availability of analytical resources","identifier":"/us/usc/t15/s8952/d/1/C","parentIdentifier":"/us/usc/t15/s8952/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s8952/d/1/C/i","parentIdentifier":"/us/usc/t15/s8952/d/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F1%2FC%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s8952/d/1/C/i/I","parentIdentifier":"/us/usc/t15/s8952/d/1/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F1%2FC%2Fi%2FI","sourceRelease":"119-100","text":"Federal and non-Federal laboratory capacity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t15/s8952/d/1/C/i/II","parentIdentifier":"/us/usc/t15/s8952/d/1/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F1%2FC%2Fi%2FII","sourceRelease":"119-100","text":"validated methods to detect and analyze contaminants; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s8952/d/1/C/ii","parentIdentifier":"/us/usc/t15/s8952/d/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F1%2FC%2Fii","sourceRelease":"119-100","text":"other factors determined to be appropriate by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report","label":"2 Report","identifier":"/us/usc/t15/s8952/d/2","parentIdentifier":"/us/usc/t15/s8952/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F2","sourceRelease":"119-100","text":"Not later than 18 months after , the Administrator shall submit to Congress a report describing the results of the study described in paragraph (1).December 20, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Program to provide Federal assistance to States","label":"3 Program to provide Federal assistance to States","identifier":"/us/usc/t15/s8952/d/3","parentIdentifier":"/us/usc/t15/s8952/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s8952/d/3/A","parentIdentifier":"/us/usc/t15/s8952/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FA","sourceRelease":"119-100","text":"Not later than 3 years after , based on the findings in the report described in paragraph (2), the Administrator shall develop a program to provide technical assistance and support to eligible States for the testing and analysis of emerging contaminants.December 20, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Application","label":"B Application","identifier":"/us/usc/t15/s8952/d/3/B","parentIdentifier":"/us/usc/t15/s8952/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t15/s8952/d/3/B/i","parentIdentifier":"/us/usc/t15/s8952/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fi","sourceRelease":"119-100","text":"To be eligible for technical assistance and support under this paragraph, a State shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Criteria","label":"ii Criteria","identifier":"/us/usc/t15/s8952/d/3/B/ii","parentIdentifier":"/us/usc/t15/s8952/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s8952/d/3/B/ii/I","parentIdentifier":"/us/usc/t15/s8952/d/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fii%2FI","sourceRelease":"119-100","text":"the laboratory facilities available to the State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t15/s8952/d/3/B/ii/II","parentIdentifier":"/us/usc/t15/s8952/d/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fii%2FII","sourceRelease":"119-100","text":"the availability and applicability of existing analytical methodologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t15/s8952/d/3/B/ii/III","parentIdentifier":"/us/usc/t15/s8952/d/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fii%2FIII","sourceRelease":"119-100","text":"the potency and severity of the emerging contaminant, if known; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t15/s8952/d/3/B/ii/IV","parentIdentifier":"/us/usc/t15/s8952/d/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fii%2FIV","sourceRelease":"119-100","text":"the prevalence and magnitude of the emerging contaminant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":"Prioritization","label":"iii Prioritization","identifier":"/us/usc/t15/s8952/d/3/B/iii","parentIdentifier":"/us/usc/t15/s8952/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s8952/d/3/B/iii/I","parentIdentifier":"/us/usc/t15/s8952/d/3/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fiii%2FI","sourceRelease":"119-100","text":"shall give priority to States with affected areas primarily in financially distressed communities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t15/s8952/d/3/B/iii/II","parentIdentifier":"/us/usc/t15/s8952/d/3/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fiii%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t15/s8952/d/3/B/iii/II/aa","parentIdentifier":"/us/usc/t15/s8952/d/3/B/iii/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fiii%2FII%2Faa","sourceRelease":"119-100","text":"waive the application process in an emergency situation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t15/s8952/d/3/B/iii/II/bb","parentIdentifier":"/us/usc/t15/s8952/d/3/B/iii/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fiii%2FII%2Fbb","sourceRelease":"119-100","text":"require an abbreviated application process for the continuation of work specified in a previously approved application that continues to meet the criteria described in clause (ii); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t15/s8952/d/3/B/iii/III","parentIdentifier":"/us/usc/t15/s8952/d/3/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fiii%2FIII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t15/s8952/d/3/B/iii/III/aa","parentIdentifier":"/us/usc/t15/s8952/d/3/B/iii/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fiii%2FIII%2Faa","sourceRelease":"119-100","text":"Federal and non-Federal laboratory capacity available to the State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t15/s8952/d/3/B/iii/III/bb","parentIdentifier":"/us/usc/t15/s8952/d/3/B/iii/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fiii%2FIII%2Fbb","sourceRelease":"119-100","text":"analytical resources available to the State; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"cc","heading":null,"label":"cc","identifier":"/us/usc/t15/s8952/d/3/B/iii/III/cc","parentIdentifier":"/us/usc/t15/s8952/d/3/B/iii/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FB%2Fiii%2FIII%2Fcc","sourceRelease":"119-100","text":"other types of technical assistance available to the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Database of available resources","label":"C Database of available resources","identifier":"/us/usc/t15/s8952/d/3/C","parentIdentifier":"/us/usc/t15/s8952/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s8952/d/3/C/i","parentIdentifier":"/us/usc/t15/s8952/d/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s8952/d/3/C/i/I","parentIdentifier":"/us/usc/t15/s8952/d/3/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC%2Fi%2FI","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t15/s8952/d/3/C/i/I/aa","parentIdentifier":"/us/usc/t15/s8952/d/3/C/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC%2Fi%2FI%2Faa","sourceRelease":"119-100","text":"drinking water and wastewater utilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t15/s8952/d/3/C/i/I/bb","parentIdentifier":"/us/usc/t15/s8952/d/3/C/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC%2Fi%2FI%2Fbb","sourceRelease":"119-100","text":"laboratories;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"cc","heading":null,"label":"cc","identifier":"/us/usc/t15/s8952/d/3/C/i/I/cc","parentIdentifier":"/us/usc/t15/s8952/d/3/C/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC%2Fi%2FI%2Fcc","sourceRelease":"119-100","text":"Federal and State emergency responders;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"dd","heading":null,"label":"dd","identifier":"/us/usc/t15/s8952/d/3/C/i/I/dd","parentIdentifier":"/us/usc/t15/s8952/d/3/C/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC%2Fi%2FI%2Fdd","sourceRelease":"119-100","text":"State primacy agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"ee","heading":null,"label":"ee","identifier":"/us/usc/t15/s8952/d/3/C/i/I/ee","parentIdentifier":"/us/usc/t15/s8952/d/3/C/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC%2Fi%2FI%2Fee","sourceRelease":"119-100","text":"public health agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"ff","heading":null,"label":"ff","identifier":"/us/usc/t15/s8952/d/3/C/i/I/ff","parentIdentifier":"/us/usc/t15/s8952/d/3/C/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC%2Fi%2FI%2Fff","sourceRelease":"119-100","text":"water associations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t15/s8952/d/3/C/i/II","parentIdentifier":"/us/usc/t15/s8952/d/3/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC%2Fi%2FII","sourceRelease":"119-100","text":"searchable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t15/s8952/d/3/C/i/III","parentIdentifier":"/us/usc/t15/s8952/d/3/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC%2Fi%2FIII","sourceRelease":"119-100","text":"accessible through the website of the Administrator; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s8952/d/3/C/ii","parentIdentifier":"/us/usc/t15/s8952/d/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s8952/d/3/C/ii/I","parentIdentifier":"/us/usc/t15/s8952/d/3/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC%2Fii%2FI","sourceRelease":"119-100","text":"qualified contract testing laboratory facilities that conduct analyses for emerging contaminants; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t15/s8952/d/3/C/ii/II","parentIdentifier":"/us/usc/t15/s8952/d/3/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FC%2Fii%2FII","sourceRelease":"119-100","text":"the resources available in Federal laboratory facilities to test for emerging contaminants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Water contaminant information tool","label":"D Water contaminant information tool","identifier":"/us/usc/t15/s8952/d/3/D","parentIdentifier":"/us/usc/t15/s8952/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F3%2FD","sourceRelease":"119-100","text":"The Administrator shall integrate the database established under subparagraph (C) into the Water Contaminant Information Tool of the Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Funding","label":"4 Funding","identifier":"/us/usc/t15/s8952/d/4","parentIdentifier":"/us/usc/t15/s8952/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fd%2F4","sourceRelease":"119-100","text":"Of the amounts available to the Administrator, the Administrator may use not more than $15,000,000 in a fiscal year to carry out this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Report","label":"e Report","identifier":"/us/usc/t15/s8952/e","parentIdentifier":"/us/usc/t15/s8952","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Fe","sourceRelease":"119-100","text":"Not less frequently than once every 2 years until 2029, the Administrator shall submit to Congress a report that describes the progress made in carrying out this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Effect","label":"f Effect","identifier":"/us/usc/t15/s8952/f","parentIdentifier":"/us/usc/t15/s8952","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8952%2Ff","sourceRelease":"119-100","text":"Nothing in this section modifies any obligation of a State, local government, or Indian Tribe with respect to treatment methods for, or testing or monitoring of, drinking water.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
