{"type":"section","nativeType":"section","number":"3611","heading":"Office of Tribal Justice Support","label":"3611 Office of Tribal Justice Support","identifier":"/us/usc/t25/s3611","parentIdentifier":"/us/usc/t25/ch38/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t25/s3611/a","parentIdentifier":"/us/usc/t25/s3611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fa","sourceRelease":"119-100","text":"There is hereby established within the Bureau the Office of Tribal Justice Support. The purpose of the Office shall be to further the development, operation, and enhancement of tribal justice systems and Courts of Indian Offenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Transfer of existing functions and personnel","label":"b Transfer of existing functions and personnel","identifier":"/us/usc/t25/s3611/b","parentIdentifier":"/us/usc/t25/s3611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fb","sourceRelease":"119-100","text":"All functions performed before , by the Branch of Judicial Services of the Bureau and all personnel assigned to such Branch as of , are hereby transferred to the Office of Tribal Justice Support. Any reference in any law, regulation, executive order, reorganization plan, or delegation of authority to the Branch of Judicial Services is deemed to be a reference to the Office of Tribal Justice Support.December 3, 1993December 3, 1993","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Functions","label":"c Functions","identifier":"/us/usc/t25/s3611/c","parentIdentifier":"/us/usc/t25/s3611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s3611/c/1","parentIdentifier":"/us/usc/t25/s3611/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fc%2F1","sourceRelease":"119-100","text":"Provide funds to Indian tribes and tribal organizations for the development, enhancement, and continuing operation of tribal justice systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s3611/c/2","parentIdentifier":"/us/usc/t25/s3611/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fc%2F2","sourceRelease":"119-100","text":"Provide technical assistance and training, including programs of continuing education and training for personnel of Courts of Indian Offenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s3611/c/3","parentIdentifier":"/us/usc/t25/s3611/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fc%2F3","sourceRelease":"119-100","text":"Study and conduct research concerning the operation of tribal justice systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s3611/c/4","parentIdentifier":"/us/usc/t25/s3611/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fc%2F4","sourceRelease":"119-100","text":"Promote cooperation and coordination among tribal justice systems and the Federal and State judiciary systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s3611/c/5","parentIdentifier":"/us/usc/t25/s3611/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fc%2F5","sourceRelease":"119-100","text":"Oversee the continuing operations of the Courts of Indian Offenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t25/s3611/c/6","parentIdentifier":"/us/usc/t25/s3611/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fc%2F6","sourceRelease":"119-100","text":"Provide funds to Indian tribes and tribal organizations for the continuation and enhancement of traditional tribal judicial practices.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"No imposition of standards","label":"d No imposition of standards","identifier":"/us/usc/t25/s3611/d","parentIdentifier":"/us/usc/t25/s3611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fd","sourceRelease":"119-100","text":"Nothing in this chapter shall be deemed or construed to authorize the Office to impose justice standards on Indian tribes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Assistance to tribes","label":"e Assistance to tribes","identifier":"/us/usc/t25/s3611/e","parentIdentifier":"/us/usc/t25/s3611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s3611/e/1","parentIdentifier":"/us/usc/t25/s3611/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3611/e/1/A","parentIdentifier":"/us/usc/t25/s3611/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fe%2F1%2FA","sourceRelease":"119-100","text":"tribal codes and rules of procedure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3611/e/1/B","parentIdentifier":"/us/usc/t25/s3611/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fe%2F1%2FB","sourceRelease":"119-100","text":"tribal court administrative procedures and court records management systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s3611/e/1/C","parentIdentifier":"/us/usc/t25/s3611/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fe%2F1%2FC","sourceRelease":"119-100","text":"methods of reducing case delays;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s3611/e/1/D","parentIdentifier":"/us/usc/t25/s3611/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fe%2F1%2FD","sourceRelease":"119-100","text":"methods of alternative dispute resolution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t25/s3611/e/1/E","parentIdentifier":"/us/usc/t25/s3611/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fe%2F1%2FE","sourceRelease":"119-100","text":"tribal standards for judicial administration and conduct; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t25/s3611/e/1/F","parentIdentifier":"/us/usc/t25/s3611/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fe%2F1%2FF","sourceRelease":"119-100","text":"long-range plans for the enhancement of tribal justice systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s3611/e/2","parentIdentifier":"/us/usc/t25/s3611/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Fe%2F2","sourceRelease":"119-100","text":"Technical assistance and training provided pursuant to paragraph (1) may be provided through direct services, by contract with independent entities, or through grants to Indian tribes or tribal organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Information clearinghouse on tribal justice systems","label":"f Information clearinghouse on tribal justice systems","identifier":"/us/usc/t25/s3611/f","parentIdentifier":"/us/usc/t25/s3611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3611%2Ff","sourceRelease":"119-100","text":"The Office shall maintain an information clearinghouse (which shall include an electronic data base) on tribal justice systems and Courts of Indian Offenses, including (but not limited to) information on staffing, funding, model tribal codes, tribal justice activities, and tribal judicial decisions. The Office shall take such actions as may be necessary to ensure the confidentiality of records and other matters involving privacy rights.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
