{"type":"section","nativeType":"section","number":"1302","heading":"Wastewater efficiency grant pilot program","label":"1302 Wastewater efficiency grant pilot program","identifier":"/us/usc/t33/s1302","parentIdentifier":"/us/usc/t33/ch26/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t33/s1302/a","parentIdentifier":"/us/usc/t33/s1302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fa","sourceRelease":"119-100","text":"Subject to the availability of appropriations, the Administrator shall establish a wastewater efficiency grant pilot program (referred to in this section as the “pilot program”) to award grants to owners or operators of publicly owned treatment works to carry out projects that create or improve waste-to-energy systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Selection","label":"b Selection","identifier":"/us/usc/t33/s1302/b","parentIdentifier":"/us/usc/t33/s1302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Applications","label":"1 Applications","identifier":"/us/usc/t33/s1302/b/1","parentIdentifier":"/us/usc/t33/s1302/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fb%2F1","sourceRelease":"119-100","text":"To be eligible to receive a grant under the pilot program, an owner or operator of a treatment works shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Number of recipients","label":"2 Number of recipients","identifier":"/us/usc/t33/s1302/b/2","parentIdentifier":"/us/usc/t33/s1302/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fb%2F2","sourceRelease":"119-100","text":"The Administrator shall select not more than 15 recipients of grants under the pilot program from applications submitted under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Use of funds","label":"c Use of funds","identifier":"/us/usc/t33/s1302/c","parentIdentifier":"/us/usc/t33/s1302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s1302/c/1","parentIdentifier":"/us/usc/t33/s1302/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1302/c/1/A","parentIdentifier":"/us/usc/t33/s1302/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fc%2F1%2FA","sourceRelease":"119-100","text":"sludge collection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1302/c/1/B","parentIdentifier":"/us/usc/t33/s1302/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fc%2F1%2FB","sourceRelease":"119-100","text":"installation of anaerobic digesters;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s1302/c/1/C","parentIdentifier":"/us/usc/t33/s1302/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fc%2F1%2FC","sourceRelease":"119-100","text":"methane capture;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t33/s1302/c/1/D","parentIdentifier":"/us/usc/t33/s1302/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fc%2F1%2FD","sourceRelease":"119-100","text":"methane transfer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t33/s1302/c/1/E","parentIdentifier":"/us/usc/t33/s1302/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fc%2F1%2FE","sourceRelease":"119-100","text":"facility upgrades and retrofits necessary to create or improve waste-to-energy systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t33/s1302/c/1/F","parentIdentifier":"/us/usc/t33/s1302/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fc%2F1%2FF","sourceRelease":"119-100","text":"other new and emerging, but proven, technologies that transform waste to energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitation","label":"2 Limitation","identifier":"/us/usc/t33/s1302/c/2","parentIdentifier":"/us/usc/t33/s1302/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fc%2F2","sourceRelease":"119-100","text":"A grant to a recipient under the pilot program shall be not more than $4,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Reports","label":"d Reports","identifier":"/us/usc/t33/s1302/d","parentIdentifier":"/us/usc/t33/s1302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Report to the Administrator","label":"1 Report to the Administrator","identifier":"/us/usc/t33/s1302/d/1","parentIdentifier":"/us/usc/t33/s1302/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fd%2F1","sourceRelease":"119-100","text":"Not later than 2 years after receiving a grant under the pilot program and each year thereafter for which amounts are made available for the pilot program under subsection (e), the recipient of the grant shall submit to the Administrator a report describing the impact of that project on the communities within 3 miles of the treatment works.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report to Congress","label":"2 Report to Congress","identifier":"/us/usc/t33/s1302/d/2","parentIdentifier":"/us/usc/t33/s1302/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1302/d/2/A","parentIdentifier":"/us/usc/t33/s1302/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fd%2F2%2FA","sourceRelease":"119-100","text":"the applications received by the Administrator for grants under the pilot program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1302/d/2/B","parentIdentifier":"/us/usc/t33/s1302/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fd%2F2%2FB","sourceRelease":"119-100","text":"the projects for which grants were awarded under the pilot program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t33/s1302/e","parentIdentifier":"/us/usc/t33/s1302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s1302/e/1","parentIdentifier":"/us/usc/t33/s1302/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fe%2F1","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out the pilot program $20,000,000 for each of fiscal years 2022 through 2026, to remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitation on use of funds","label":"2 Limitation on use of funds","identifier":"/us/usc/t33/s1302/e/2","parentIdentifier":"/us/usc/t33/s1302/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302%2Fe%2F2","sourceRelease":"119-100","text":"Of the amounts made available for grants under paragraph (1), not more than 2 percent may be used to pay the administrative costs of the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
