{"type":"section","nativeType":"section","number":"11302","heading":"Manner of making entries","label":"11302 Manner of making entries","identifier":"/us/usc/t46/s11302","parentIdentifier":"/us/usc/t46/stII/ptG/ch113","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11302","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevised sectionSource section (U.S. Code)1130246:202Section 11302 describes the manner in which entries shall be made in the logbook, specifying when they shall be made, who shall sign them, and requiring that they shall be dated."],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s11302/1","parentIdentifier":"/us/usc/t46/s11302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11302%2F1","sourceRelease":"119-100","text":"shall be made as soon as possible after the occurrence;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s11302/2","parentIdentifier":"/us/usc/t46/s11302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11302%2F2","sourceRelease":"119-100","text":"if not made on the day of the occurrence, shall be dated and state the date of the occurrence;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s11302/3","parentIdentifier":"/us/usc/t46/s11302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11302%2F3","sourceRelease":"119-100","text":"if the entry is about an occurrence happening before the vessel’s arrival at the final port of discharge, shall be made not later than 24 hours after the arrival;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t46/s11302/4","parentIdentifier":"/us/usc/t46/s11302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11302%2F4","sourceRelease":"119-100","text":"shall be signed by the master; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t46/s11302/5","parentIdentifier":"/us/usc/t46/s11302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11302%2F5","sourceRelease":"119-100","text":"shall be signed by the chief mate or another seaman.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
