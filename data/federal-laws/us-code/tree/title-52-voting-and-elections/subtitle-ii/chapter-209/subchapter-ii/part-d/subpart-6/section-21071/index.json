{"type":"section","nativeType":"section","number":"21071","heading":"National Student and Parent Mock Election","label":"21071 National Student and Parent Mock Election","identifier":"/us/usc/t52/s21071","parentIdentifier":"/us/usc/t52/stII/ch209/schII/ptD/spt6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21071","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to , The Public Health and Welfare, prior to editorial reclassification and renumbering as this section.section 15471 of Title 42"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t52/s21071/a","parentIdentifier":"/us/usc/t52/s21071","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21071%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t52/s21071/a/1","parentIdentifier":"/us/usc/t52/s21071/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21071%2Fa%2F1","sourceRelease":"119-100","text":"include simulated national elections at least 5 days before the actual election that permit participation by students and parents from each of the 50 States in the United States, its territories, the District of Columbia, and United States schools overseas; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t52/s21071/a/2","parentIdentifier":"/us/usc/t52/s21071/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21071%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t52/s21071/a/2/A","parentIdentifier":"/us/usc/t52/s21071/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21071%2Fa%2F2%2FA","sourceRelease":"119-100","text":"school forums and local cable call-in shows on the national issues to be voted upon in an “issues forum”;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t52/s21071/a/2/B","parentIdentifier":"/us/usc/t52/s21071/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21071%2Fa%2F2%2FB","sourceRelease":"119-100","text":"speeches and debates before students and parents by local candidates or stand-ins for such candidates;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t52/s21071/a/2/C","parentIdentifier":"/us/usc/t52/s21071/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21071%2Fa%2F2%2FC","sourceRelease":"119-100","text":"quiz team competitions, mock press conferences, and speech writing competitions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t52/s21071/a/2/D","parentIdentifier":"/us/usc/t52/s21071/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21071%2Fa%2F2%2FD","sourceRelease":"119-100","text":"weekly meetings to follow the course of the campaign; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t52/s21071/a/2/E","parentIdentifier":"/us/usc/t52/s21071/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21071%2Fa%2F2%2FE","sourceRelease":"119-100","text":"school and neighborhood campaigns to increase voter turnout, including newsletters, posters, telephone chains, and transportation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirement","label":"b Requirement","identifier":"/us/usc/t52/s21071/b","parentIdentifier":"/us/usc/t52/s21071","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft52%2Fs21071%2Fb","sourceRelease":"119-100","text":"The National Student and Parent Mock Election shall present awards to outstanding student and parent mock election projects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
