{"type":"section","nativeType":"section","number":"4106","heading":"Funding and additional authorities","label":"4106 Funding and additional authorities","identifier":"/us/usc/t33/s4106","parentIdentifier":"/us/usc/t33/ch54","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4106","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Funding","label":"a Funding","identifier":"/us/usc/t33/s4106/a","parentIdentifier":"/us/usc/t33/s4106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4106%2Fa","sourceRelease":"119-100","text":"The Administrator shall carry out this chapter using existing amounts appropriated or otherwise made available to the Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Additional authorities","label":"b Additional authorities","identifier":"/us/usc/t33/s4106/b","parentIdentifier":"/us/usc/t33/s4106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4106%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s4106/b/1","parentIdentifier":"/us/usc/t33/s4106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4106%2Fb%2F1","sourceRelease":"119-100","text":"enter into contracts, cooperative agreements, and other transactions with any domestic or foreign government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s4106/b/2","parentIdentifier":"/us/usc/t33/s4106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4106%2Fb%2F2","sourceRelease":"119-100","text":"notwithstanding , accept donations and voluntary and uncompensated services;section 1342 of title 31","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s4106/b/3","parentIdentifier":"/us/usc/t33/s4106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4106%2Fb%2F3","sourceRelease":"119-100","text":"accept funds from other Federal departments and agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s4106/b/4","parentIdentifier":"/us/usc/t33/s4106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4106%2Fb%2F4","sourceRelease":"119-100","text":"utilize the National Oceanographic Partnership Program established under chapter 665 of title 10 to accept funds from other Federal departments and agencies, to accept donations, and to enter into contracts and award grants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t33/s4106/b/5","parentIdentifier":"/us/usc/t33/s4106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4106%2Fb%2F5","sourceRelease":"119-100","text":"under an agreement entered into under paragraph (1), transfer funds appropriated to carry our this chapter to any organization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t33/s4106/b/6","parentIdentifier":"/us/usc/t33/s4106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4106%2Fb%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{