{"type":"section","nativeType":"section","number":"931","heading":"Prohibition on purchase, ownership, or possession of body armor by violent felons","label":"931 Prohibition on purchase, ownership, or possession of body armor by violent felons","identifier":"/us/usc/t18/s931","parentIdentifier":"/us/usc/t18/ptI/ch44","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs931","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t18/s931/a","parentIdentifier":"/us/usc/t18/s931","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs931%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s931/a/1","parentIdentifier":"/us/usc/t18/s931/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs931%2Fa%2F1","sourceRelease":"119-100","text":"a crime of violence (as defined in section 16); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s931/a/2","parentIdentifier":"/us/usc/t18/s931/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs931%2Fa%2F2","sourceRelease":"119-100","text":"an offense under State law that would constitute a crime of violence under paragraph (1) if it occurred within the special maritime and territorial jurisdiction of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Affirmative Defense.—","label":"b Affirmative Defense.—","identifier":"/us/usc/t18/s931/b","parentIdentifier":"/us/usc/t18/s931","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs931%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t18/s931/b/1","parentIdentifier":"/us/usc/t18/s931/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs931%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s931/b/1/A","parentIdentifier":"/us/usc/t18/s931/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs931%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the defendant obtained prior written certification from his or her employer that the defendant’s purchase, use, or possession of body armor was necessary for the safe performance of lawful business activity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s931/b/1/B","parentIdentifier":"/us/usc/t18/s931/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs931%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the use and possession by the defendant were limited to the course of such performance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Employer","label":"2 .—Employer","identifier":"/us/usc/t18/s931/b/2","parentIdentifier":"/us/usc/t18/s931/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs931%2Fb%2F2","sourceRelease":"119-100","text":"In this subsection, the term “employer” means any other individual employed by the defendant’s business that supervises defendant’s activity. If that defendant has no supervisor, prior written certification is acceptable from any other employee of the business.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
