{"type":"section","nativeType":"section","number":"5704","heading":"Guidelines for responding to cases of missing or murdered Indians","label":"5704 Guidelines for responding to cases of missing or murdered Indians","identifier":"/us/usc/t25/s5704","parentIdentifier":"/us/usc/t25/ch49","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t25/s5704/a","parentIdentifier":"/us/usc/t25/s5704","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s5704/a/1","parentIdentifier":"/us/usc/t25/s5704/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fa%2F1","sourceRelease":"119-100","text":"guidelines on inter-jurisdictional cooperation among law enforcement agencies at the Tribal, Federal, State, and local levels, including inter-jurisdictional enforcement of protection orders and detailing specific responsibilities of each law enforcement agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s5704/a/2","parentIdentifier":"/us/usc/t25/s5704/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fa%2F2","sourceRelease":"119-100","text":"best practices in conducting searches for missing persons on and off Indian land;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s5704/a/3","parentIdentifier":"/us/usc/t25/s5704/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fa%2F3","sourceRelease":"119-100","text":"standards on the collection, reporting, and analysis of data and information on missing persons and unidentified human remains, and information on culturally appropriate identification and handling of human remains identified as Indian, including guidance stating that all appropriate information related to missing or murdered Indians be entered in a timely manner into applicable databases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s5704/a/4","parentIdentifier":"/us/usc/t25/s5704/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fa%2F4","sourceRelease":"119-100","text":"guidance on which law enforcement agency is responsible for inputting information into appropriate databases under paragraph (3) if the Tribal law enforcement agency does not have access to those appropriate databases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s5704/a/5","parentIdentifier":"/us/usc/t25/s5704/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fa%2F5","sourceRelease":"119-100","text":"guidelines on improving law enforcement agency response rates and follow-up responses to cases of missing or murdered Indians; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t25/s5704/a/6","parentIdentifier":"/us/usc/t25/s5704/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fa%2F6","sourceRelease":"119-100","text":"guidelines on ensuring access to culturally appropriate victim services for victims and their families.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Consultation","label":"b Consultation","identifier":"/us/usc/t25/s5704/b","parentIdentifier":"/us/usc/t25/s5704","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s5704/b/1","parentIdentifier":"/us/usc/t25/s5704/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fb%2F1","sourceRelease":"119-100","text":"the Department of Justice;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s5704/b/2","parentIdentifier":"/us/usc/t25/s5704/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fb%2F2","sourceRelease":"119-100","text":"the Federal Bureau of Investigation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s5704/b/3","parentIdentifier":"/us/usc/t25/s5704/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fb%2F3","sourceRelease":"119-100","text":"the Department of the Interior;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s5704/b/4","parentIdentifier":"/us/usc/t25/s5704/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fb%2F4","sourceRelease":"119-100","text":"the Bureau of Indian Affairs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s5704/b/5","parentIdentifier":"/us/usc/t25/s5704/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fb%2F5","sourceRelease":"119-100","text":"Tribal, State, and local law enforcement agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t25/s5704/b/6","parentIdentifier":"/us/usc/t25/s5704/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fb%2F6","sourceRelease":"119-100","text":"medical examiners;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t25/s5704/b/7","parentIdentifier":"/us/usc/t25/s5704/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fb%2F7","sourceRelease":"119-100","text":"coroners;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t25/s5704/b/8","parentIdentifier":"/us/usc/t25/s5704/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fb%2F8","sourceRelease":"119-100","text":"Tribal, State, and local organizations that provide victim services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t25/s5704/b/9","parentIdentifier":"/us/usc/t25/s5704/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fb%2F9","sourceRelease":"119-100","text":"national, regional, or urban Indian organizations with relevant expertise.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Compliance","label":"c Compliance","identifier":"/us/usc/t25/s5704/c","parentIdentifier":"/us/usc/t25/s5704","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s5704/c/1","parentIdentifier":"/us/usc/t25/s5704/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fc%2F1","sourceRelease":"119-100","text":"Not later than 1 year after , the United States attorneys shall implement, by incorporating into office policies and procedures, the guidelines developed under subsection (a).October 10, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Modification","label":"2 Modification","identifier":"/us/usc/t25/s5704/c/2","parentIdentifier":"/us/usc/t25/s5704/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fc%2F2","sourceRelease":"119-100","text":"Each Federal law enforcement agency shall modify the guidelines, policies, and protocols of the agency to incorporate the guidelines developed under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Determination","label":"3 Determination","identifier":"/us/usc/t25/s5704/c/3","parentIdentifier":"/us/usc/t25/s5704/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fc%2F3","sourceRelease":"119-100","text":"Not later than the end of each fiscal year beginning after the date the guidelines are established under this section and incorporated under this subsection, upon the request of a Tribal, State, or local law enforcement agency, the Attorney General shall determine whether the Tribal, State, or local law enforcement agency seeking recognition of compliance has incorporated guidelines into their respective guidelines, policies, and protocols.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Accountability","label":"d Accountability","identifier":"/us/usc/t25/s5704/d","parentIdentifier":"/us/usc/t25/s5704","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s5704/d/1","parentIdentifier":"/us/usc/t25/s5704/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fd%2F1","sourceRelease":"119-100","text":"disclose and publish, including on the website of the Department of Justice, the name of each Tribal, State, or local law enforcement agency that the Attorney General has determined has incorporated guidelines in accordance with subsection (c)(3);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s5704/d/2","parentIdentifier":"/us/usc/t25/s5704/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fd%2F2","sourceRelease":"119-100","text":"disclose and publish, including on the website of the Department of Justice, the name of each Tribal, State, or local law enforcement agency that has requested a determination in accordance with subsection (c)(3) that is pending;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s5704/d/3","parentIdentifier":"/us/usc/t25/s5704/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fd%2F3","sourceRelease":"119-100","text":"collect the guidelines into a resource of examples and best practices that can be used by other law enforcement agencies seeking to create and implement such guidelines.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Training and technical assistance","label":"e Training and technical assistance","identifier":"/us/usc/t25/s5704/e","parentIdentifier":"/us/usc/t25/s5704","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s5704/e/1","parentIdentifier":"/us/usc/t25/s5704/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fe%2F1","sourceRelease":"119-100","text":"implementing the guidelines developed under subsection (a) or developing and implementing locally specific guidelines or protocols for responding to cases of missing or murdered Indians; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s5704/e/2","parentIdentifier":"/us/usc/t25/s5704/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Fe%2F2","sourceRelease":"119-100","text":"using the National Missing and Unidentified Persons System and accessing program services that will assist Indian Tribes with responding to cases of missing or murdered Indians.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Guidelines from Indian Tribes","label":"f Guidelines from Indian Tribes","identifier":"/us/usc/t25/s5704/f","parentIdentifier":"/us/usc/t25/s5704","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s5704/f/1","parentIdentifier":"/us/usc/t25/s5704/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Ff%2F1","sourceRelease":"119-100","text":"Indian Tribes may submit their own guidelines to respond to cases of missing or murdered Indians to the Attorney General.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Publication","label":"2 Publication","identifier":"/us/usc/t25/s5704/f/2","parentIdentifier":"/us/usc/t25/s5704/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5704%2Ff%2F2","sourceRelease":"119-100","text":"Upon receipt of any guidelines from an Indian Tribe, the Attorney General shall publish the guidelines on the website of the Department of Justice in 1 centralized location to make the guidelines available as a resource to any Federal agency, State, or Tribal government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
