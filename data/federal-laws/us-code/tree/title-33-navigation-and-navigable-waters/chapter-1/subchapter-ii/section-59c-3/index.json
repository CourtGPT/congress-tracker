land).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Applicability of Federal law","label":"2 Applicability of Federal law","identifier":"/us/usc/t33/s59c–3/b/2","parentIdentifier":"/us/usc/t33/s59c–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs59c%E2%80%933%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s59c–3/b/2/A","parentIdentifier":"/us/usc/t33/s59c–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs59c%E2%80%933%2Fb%2F2%2FA","sourceRelease":"119-100","text":"sections 401 and 403 of this title;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s59c–3/b/2/B","parentIdentifier":"/us/usc/t33/s59c–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs59c%E2%80%933%2Fb%2F2%2FB","sourceRelease":"119-100","text":";section 1344 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s59c–3/b/2/C","parentIdentifier":"/us/usc/t33/s59c–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs59c%E2%80%933%2Fb%2F2%2FC","sourceRelease":"119-100","text":"the National Environmental Policy Act of 1969 ( et seq.).42 U.S.C. 4321","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Expiration date","label":"c Expiration date","identifier":"/us/usc/t33/s59c–3/c","parentIdentifier":"/us/usc/t33/s59c–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2