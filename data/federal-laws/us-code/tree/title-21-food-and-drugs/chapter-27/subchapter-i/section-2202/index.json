{"type":"section","nativeType":"section","number":"2202","heading":"National Agriculture and Food Defense Strategy","label":"2202 National Agriculture and Food Defense Strategy","identifier":"/us/usc/t21/s2202","parentIdentifier":"/us/usc/t21/ch27/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe Secretary, referred to in subsec. (b)(3), probably means the Secretary of Health and Human Services."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Development and submission of strategy","label":"a Development and submission of strategy","identifier":"/us/usc/t21/s2202/a","parentIdentifier":"/us/usc/t21/s2202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t21/s2202/a/1","parentIdentifier":"/us/usc/t21/s2202/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fa%2F1","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary of Health and Human Services and the Secretary of Agriculture, in coordination with the Secretary of Homeland Security, shall prepare and transmit to the relevant committees of Congress, and make publicly available on the Internet Web sites of the Department of Health and Human Services and the Department of Agriculture, the National Agriculture and Food Defense Strategy.January 4, 2011","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Implementation plan","label":"2 Implementation plan","identifier":"/us/usc/t21/s2202/a/2","parentIdentifier":"/us/usc/t21/s2202/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fa%2F2","sourceRelease":"119-100","text":"The strategy shall include an implementation plan for use by the Secretaries described under paragraph (1) in carrying out the strategy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Research","label":"3 Research","identifier":"/us/usc/t21/s2202/a/3","parentIdentifier":"/us/usc/t21/s2202/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fa%2F3","sourceRelease":"119-100","text":"The strategy shall include a coordinated research agenda for use by the Secretaries described under paragraph (1) in conducting research to support the goals and activities described in paragraphs (1) and (2) of subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Revisions","label":"4 Revisions","identifier":"/us/usc/t21/s2202/a/4","parentIdentifier":"/us/usc/t21/s2202/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fa%2F4","sourceRelease":"119-100","text":"Not later than 4 years after the date on which the strategy is submitted to the relevant committees of Congress under paragraph (1), and not less frequently than every 4 years thereafter, the Secretary of Health and Human Services and the Secretary of Agriculture, in coordination with the Secretary of Homeland Security, shall revise and submit to the relevant committees of Congress the strategy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Consistency with existing plans","label":"5 Consistency with existing plans","identifier":"/us/usc/t21/s2202/a/5","parentIdentifier":"/us/usc/t21/s2202/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s2202/a/5/A","parentIdentifier":"/us/usc/t21/s2202/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fa%2F5%2FA","sourceRelease":"119-100","text":"the National Incident Management System;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s2202/a/5/B","parentIdentifier":"/us/usc/t21/s2202/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fa%2F5%2FB","sourceRelease":"119-100","text":"the National Response Framework;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t21/s2202/a/5/C","parentIdentifier":"/us/usc/t21/s2202/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fa%2F5%2FC","sourceRelease":"119-100","text":"the National Infrastructure Protection Plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t21/s2202/a/5/D","parentIdentifier":"/us/usc/t21/s2202/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fa%2F5%2FD","sourceRelease":"119-100","text":"the National Preparedness Goals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t21/s2202/a/5/E","parentIdentifier":"/us/usc/t21/s2202/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fa%2F5%2FE","sourceRelease":"119-100","text":"other relevant national strategies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Components","label":"b Components","identifier":"/us/usc/t21/s2202/b","parentIdentifier":"/us/usc/t21/s2202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t21/s2202/b/1","parentIdentifier":"/us/usc/t21/s2202/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s2202/b/1/A","parentIdentifier":"/us/usc/t21/s2202/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F1%2FA","sourceRelease":"119-100","text":"to achieve each goal described in paragraph (2); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s2202/b/1/B","parentIdentifier":"/us/usc/t21/s2202/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F1%2FB","sourceRelease":"119-100","text":"to evaluate the progress made by Federal, State, local, and tribal governments towards the achievement of each goal described in paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Goals","label":"2 Goals","identifier":"/us/usc/t21/s2202/b/2","parentIdentifier":"/us/usc/t21/s2202/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Preparedness goal","label":"A Preparedness goal","identifier":"/us/usc/t21/s2202/b/2/A","parentIdentifier":"/us/usc/t21/s2202/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s2202/b/2/A/i","parentIdentifier":"/us/usc/t21/s2202/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"conducting vulnerability assessments of the agriculture and food system;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s2202/b/2/A/ii","parentIdentifier":"/us/usc/t21/s2202/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"mitigating vulnerabilities of the system;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t21/s2202/b/2/A/iii","parentIdentifier":"/us/usc/t21/s2202/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"improving communication and training relating to the system;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t21/s2202/b/2/A/iv","parentIdentifier":"/us/usc/t21/s2202/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"developing and conducting exercises to test decontamination and disposal plans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t21/s2202/b/2/A/v","parentIdentifier":"/us/usc/t21/s2202/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FA%2Fv","sourceRelease":"119-100","text":"developing modeling tools to improve event consequence assessment and decision support; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t21/s2202/b/2/A/vi","parentIdentifier":"/us/usc/t21/s2202/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FA%2Fvi","sourceRelease":"119-100","text":"preparing risk communication tools and enhancing public awareness through outreach.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Detection goal","label":"B Detection goal","identifier":"/us/usc/t21/s2202/b/2/B","parentIdentifier":"/us/usc/t21/s2202/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s2202/b/2/B/i","parentIdentifier":"/us/usc/t21/s2202/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"identifying contamination in food products at the earliest possible time; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s2202/b/2/B/ii","parentIdentifier":"/us/usc/t21/s2202/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"conducting surveillance to prevent the spread of diseases.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Emergency response goal","label":"C Emergency response goal","identifier":"/us/usc/t21/s2202/b/2/C","parentIdentifier":"/us/usc/t21/s2202/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s2202/b/2/C/i","parentIdentifier":"/us/usc/t21/s2202/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FC%2Fi","sourceRelease":"119-100","text":"immediately investigating animal disease outbreaks and suspected food contamination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s2202/b/2/C/ii","parentIdentifier":"/us/usc/t21/s2202/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FC%2Fii","sourceRelease":"119-100","text":"preventing additional human illnesses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t21/s2202/b/2/C/iii","parentIdentifier":"/us/usc/t21/s2202/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FC%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t21/s2202/b/2/C/iii/I","parentIdentifier":"/us/usc/t21/s2202/b/2/C/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FC%2Fiii%2FI","sourceRelease":"119-100","text":"the Federal Government; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t21/s2202/b/2/C/iii/II","parentIdentifier":"/us/usc/t21/s2202/b/2/C/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FC%2Fiii%2FII","sourceRelease":"119-100","text":"State, local, and tribal governments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t21/s2202/b/2/C/iv","parentIdentifier":"/us/usc/t21/s2202/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FC%2Fiv","sourceRelease":"119-100","text":"designing, developing, and evaluating training and exercises carried out under agriculture and food defense plans; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t21/s2202/b/2/C/v","parentIdentifier":"/us/usc/t21/s2202/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FC%2Fv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t21/s2202/b/2/C/v/I","parentIdentifier":"/us/usc/t21/s2202/b/2/C/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FC%2Fv%2FI","sourceRelease":"119-100","text":"the Federal Government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t21/s2202/b/2/C/v/II","parentIdentifier":"/us/usc/t21/s2202/b/2/C/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FC%2Fv%2FII","sourceRelease":"119-100","text":"State, local, and tribal governments; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t21/s2202/b/2/C/v/III","parentIdentifier":"/us/usc/t21/s2202/b/2/C/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FC%2Fv%2FIII","sourceRelease":"119-100","text":"the private sector.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Recovery goal","label":"D Recovery goal","identifier":"/us/usc/t21/s2202/b/2/D","parentIdentifier":"/us/usc/t21/s2202/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s2202/b/2/D/i","parentIdentifier":"/us/usc/t21/s2202/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FD%2Fi","sourceRelease":"119-100","text":"working with the private sector to develop business recovery plans to rapidly resume agriculture, food production, and international trade;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s2202/b/2/D/ii","parentIdentifier":"/us/usc/t21/s2202/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FD%2Fii","sourceRelease":"119-100","text":"conducting exercises of the plans described in subparagraph (C) with the goal of long-term recovery results;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t21/s2202/b/2/D/iii","parentIdentifier":"/us/usc/t21/s2202/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FD%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t21/s2202/b/2/D/iii/I","parentIdentifier":"/us/usc/t21/s2202/b/2/D/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FD%2Fiii%2FI","sourceRelease":"119-100","text":"contaminated agriculture and food products; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t21/s2202/b/2/D/iii/II","parentIdentifier":"/us/usc/t21/s2202/b/2/D/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FD%2Fiii%2FII","sourceRelease":"119-100","text":"infected plants and animals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t21/s2202/b/2/D/iv","parentIdentifier":"/us/usc/t21/s2202/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F2%2FD%2Fiv","sourceRelease":"119-100","text":"decontaminating and restoring areas affected by an agriculture or food emergency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Evaluation","label":"3 Evaluation","identifier":"/us/usc/t21/s2202/b/3","parentIdentifier":"/us/usc/t21/s2202/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s2202/b/3/A","parentIdentifier":"/us/usc/t21/s2202/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F3%2FA","sourceRelease":"119-100","text":"develop metrics to measure progress for the evaluation process described in paragraph (1)(B); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s2202/b/3/B","parentIdentifier":"/us/usc/t21/s2202/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fb%2F3%2FB","sourceRelease":"119-100","text":"report on the progress measured in subparagraph (A) as part of the National Agriculture and Food Defense strategy described in subsection (a)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Limited distribution","label":"c Limited distribution","identifier":"/us/usc/t21/s2202/c","parentIdentifier":"/us/usc/t21/s2202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2202%2Fc","sourceRelease":"119-100","text":"In the interest of national security, the Secretary of Health and Human Services and the Secretary of Agriculture, in coordination with the Secretary of Homeland Security, may determine the manner and format in which the National Agriculture and Food Defense strategy established under this section is made publicly available on the Internet Web sites of the Department of Health and Human Services, the Department of Homeland Security, and the Department of Agriculture, as described in subsection (a)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
