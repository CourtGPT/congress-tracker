{"type":"section","nativeType":"section","number":"460rrr–5","heading":"Administration of Natural Area","label":"460rrr–5 Administration of Natural Area","identifier":"/us/usc/t16/s460rrr–5","parentIdentifier":"/us/usc/t16/ch1/schCXXIX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s460rrr–5/a","parentIdentifier":"/us/usc/t16/s460rrr–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460rrr–5/a/1","parentIdentifier":"/us/usc/t16/s460rrr–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460rrr–5/a/1/A","parentIdentifier":"/us/usc/t16/s460rrr–5/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the laws (including regulations) applicable to public land; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460rrr–5/a/1/B","parentIdentifier":"/us/usc/t16/s460rrr–5/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the management plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460rrr–5/a/2","parentIdentifier":"/us/usc/t16/s460rrr–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460rrr–5/a/2/A","parentIdentifier":"/us/usc/t16/s460rrr–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the conservation, restoration, and protection of the natural, historic, scientific, scenic, wildlife, and recreational resources of the Natural Area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460rrr–5/a/2/B","parentIdentifier":"/us/usc/t16/s460rrr–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the continued use of the Natural Area for purposes of education, scientific study, and limited public recreation in a manner that does not substantially impair the purposes for which the Natural Area is established;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s460rrr–5/a/2/C","parentIdentifier":"/us/usc/t16/s460rrr–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fa%2F2%2FC","sourceRelease":"119-100","text":"the protection of the wildlife habitat of the Natural Area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s460rrr–5/a/2/D","parentIdentifier":"/us/usc/t16/s460rrr–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fa%2F2%2FD","sourceRelease":"119-100","text":"a prohibition on the construction of water storage facilities in the Natural Area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s460rrr–5/a/2/E","parentIdentifier":"/us/usc/t16/s460rrr–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fa%2F2%2FE","sourceRelease":"119-100","text":"the reduction in the use of or removal of roads in the Natural Area and, to the maximum extent practicable, the reduction in or prohibition against the use of motorized vehicles in the Natural Area (including the removal of roads and a prohibition against motorized use on Federal land in the area on the western side of the Rio Grande River from Lobatos Bridge south to the New Mexico State line).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Changes in streamflow","label":"b Changes in streamflow","identifier":"/us/usc/t16/s460rrr–5/b","parentIdentifier":"/us/usc/t16/s460rrr–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fb","sourceRelease":"119-100","text":"The Secretary is encouraged to negotiate with the State of Colorado, the Rio Grande Water Conservation District, and affected water users in the State to determine if changes in the streamflow that are beneficial to the Natural Area may be accommodated.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Private land","label":"c Private land","identifier":"/us/usc/t16/s460rrr–5/c","parentIdentifier":"/us/usc/t16/s460rrr–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fc","sourceRelease":"119-100","text":"The management plan prepared under shall apply to private land in the Natural Area only to the extent that the private landowner agrees in writing to be bound by the management plan.section 460rrr–4(b)(2)(A) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Withdrawal","label":"d Withdrawal","identifier":"/us/usc/t16/s460rrr–5/d","parentIdentifier":"/us/usc/t16/s460rrr–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460rrr–5/d/1","parentIdentifier":"/us/usc/t16/s460rrr–5/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fd%2F1","sourceRelease":"119-100","text":"all forms of entry, appropriation, or disposal under the public land laws;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460rrr–5/d/2","parentIdentifier":"/us/usc/t16/s460rrr–5/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fd%2F2","sourceRelease":"119-100","text":"location, entry, and patent under the mining laws; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s460rrr–5/d/3","parentIdentifier":"/us/usc/t16/s460rrr–5/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fd%2F3","sourceRelease":"119-100","text":"disposition under the mineral leasing laws (including geothermal leasing laws).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Acquisition of land","label":"e Acquisition of land","identifier":"/us/usc/t16/s460rrr–5/e","parentIdentifier":"/us/usc/t16/s460rrr–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s460rrr–5/e/1","parentIdentifier":"/us/usc/t16/s460rrr–5/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fe%2F1","sourceRelease":"119-100","text":"The Secretary may acquire from willing sellers by purchase, exchange, or donation land or an interest in land in the Natural Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Administration","label":"2 Administration","identifier":"/us/usc/t16/s460rrr–5/e/2","parentIdentifier":"/us/usc/t16/s460rrr–5/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Fe%2F2","sourceRelease":"119-100","text":"Any land or interest in land acquired under paragraph (1) shall be administered in accordance with the management plan and this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Applicable law","label":"f Applicable law","identifier":"/us/usc/t16/s460rrr–5/f","parentIdentifier":"/us/usc/t16/s460rrr–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%935%2Ff","sourceRelease":"119-100","text":"shall not apply to the Natural Area.Section 1276(d)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
