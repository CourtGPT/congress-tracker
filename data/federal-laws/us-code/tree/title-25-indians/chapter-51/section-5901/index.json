ndments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Leasehold mortgage","label":"7 Leasehold mortgage","identifier":"/us/usc/t25/s5901/7","parentIdentifier":"/us/usc/t25/s5901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5901%2F7","sourceRelease":"119-100","text":"The term “leasehold mortgage” means a mortgage, deed of trust, or other instrument that pledges the leasehold interest of a lessee as security for a debt or other obligation owed by the lessee to a lender or other mortgagee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Mortgage package","label":"8 Mortgage package","identifier":"/us/usc/t25/s5901/8","parentIdentifier":"/us/usc/t25/s5901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5901%2F8","sourceRelease":"119-100","text":"The term “mortgage package” means a proposed residential leasehold mortgage, business leasehold mortgage, land mortgage, or right-of-way document submitted to an applicable Bureau office under .section 5902(a)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":"Relevant Federal agency","label":"9 Relevant Federal agency","identifier":"/us/usc/t25/s5901/9","parentIdentifier":"/us/usc/t25/s5901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5901%2F9","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s5901/9/A","parentIdentifier":"/us/usc/t25/s5901/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5901%2F9%2FA","sourceRelease":"119-100","text":"The Department of Agriculture.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s5901/9/B","parentIdentifier":"/us/usc/t25/s5901/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5901%2F9%2FB","sourceRelease":"119-100","text":"The Department of Housing and Urban Development.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s5901/9/C","parentIdentifier":"/us/usc/t25/s5901/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5901%2F9%2FC","sourceRelease":"119-100","text":"The Department of Veterans Affairs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":"Right-of-way document","label":"10 Right-of-way document","identifier":"/us/usc/t25/s5901/10","parentIdentifier":"/us/usc/t25/s5901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5901%2F10","sourceRelease":"119-100","text":"The term “right-of-way document” has the meaning given the term in section 169.2 of title 25, Code of Federal Regulations (as in effect on ).May 4, 2026","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":"Subsequent certified title status report","label":"11 Subsequent certified title status report","identifier":"/us/usc/t25/s5901/11","parentIdentifier":"/us/usc/t25/s5901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5901%2F11","sourceRelease":"119-100","text":"The term “subsequent certified title status report” means the title status report needed to identify any liens against a residential, business, or land lease on Indian land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
