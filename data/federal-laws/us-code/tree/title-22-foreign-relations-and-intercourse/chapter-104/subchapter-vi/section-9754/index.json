{"type":"section","nativeType":"section","number":"9754","heading":"Restriction on export of covered articles and services to certain security forces of Venezuela","label":"9754 Restriction on export of covered articles and services to certain security forces of Venezuela","identifier":"/us/usc/t22/s9754","parentIdentifier":"/us/usc/t22/ch104/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Short title","label":"a Short title","identifier":"/us/usc/t22/s9754/a","parentIdentifier":"/us/usc/t22/s9754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fa","sourceRelease":"119-100","text":"This section may be cited as the “Venezuela Arms Restriction Act”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Definitions","label":"b Definitions","identifier":"/us/usc/t22/s9754/b","parentIdentifier":"/us/usc/t22/s9754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Appropriate congressional committees","label":"1 Appropriate congressional committees","identifier":"/us/usc/t22/s9754/b/1","parentIdentifier":"/us/usc/t22/s9754/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9754/b/1/A","parentIdentifier":"/us/usc/t22/s9754/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the Committee on Foreign Relations of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9754/b/1/B","parentIdentifier":"/us/usc/t22/s9754/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the Committee on Banking, Housing, and Urban Affairs of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9754/b/1/C","parentIdentifier":"/us/usc/t22/s9754/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the Committee on Foreign Affairs of the House of Representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s9754/b/1/D","parentIdentifier":"/us/usc/t22/s9754/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F1%2FD","sourceRelease":"119-100","text":"the Committee on Financial Services of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Covered article or service","label":"2 Covered article or service","identifier":"/us/usc/t22/s9754/b/2","parentIdentifier":"/us/usc/t22/s9754/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9754/b/2/A","parentIdentifier":"/us/usc/t22/s9754/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s9754/b/2/A/i","parentIdentifier":"/us/usc/t22/s9754/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"a defense article or defense service (as such terms are defined in ); andsection 2794 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s9754/b/2/A/ii","parentIdentifier":"/us/usc/t22/s9754/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"any article included on the Commerce Control List set forth in Supplement No. 1 to part 774 of the Export Administration Regulations under subchapter C of chapter VII of title 15, Code of Federal Regulations, and controlled for crime control purposes, if the end user is likely to use the article to violate the human rights of the citizens of Venezuela; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9754/b/2/B","parentIdentifier":"/us/usc/t22/s9754/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s9754/b/2/B/i","parentIdentifier":"/us/usc/t22/s9754/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"any defense article or defense service of the type described in ; andsection 2794 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s9754/b/2/B/ii","parentIdentifier":"/us/usc/t22/s9754/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"any article of the type included on the Commerce Control List set forth in Supplement No. 1 to part 774 of the Export Administration Regulations and controlled for crime control purposes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Foreign person","label":"3 Foreign person","identifier":"/us/usc/t22/s9754/b/3","parentIdentifier":"/us/usc/t22/s9754/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F3","sourceRelease":"119-100","text":"The term “foreign person” means a person that is not a United States person.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Person","label":"4 Person","identifier":"/us/usc/t22/s9754/b/4","parentIdentifier":"/us/usc/t22/s9754/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F4","sourceRelease":"119-100","text":"The term “person” means an individual or entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Security forces of Venezuela","label":"5 Security forces of Venezuela","identifier":"/us/usc/t22/s9754/b/5","parentIdentifier":"/us/usc/t22/s9754/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9754/b/5/A","parentIdentifier":"/us/usc/t22/s9754/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F5%2FA","sourceRelease":"119-100","text":"the Bolivarian National Armed Forces, including the Bolivarian National Guard;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9754/b/5/B","parentIdentifier":"/us/usc/t22/s9754/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F5%2FB","sourceRelease":"119-100","text":"the Bolivarian National Intelligence Service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9754/b/5/C","parentIdentifier":"/us/usc/t22/s9754/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F5%2FC","sourceRelease":"119-100","text":"the Bolivarian National Police; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s9754/b/5/D","parentIdentifier":"/us/usc/t22/s9754/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F5%2FD","sourceRelease":"119-100","text":"the Bureau for Scientific, Criminal and Forensic Investigations of the Ministry of Interior, Justice, and Peace.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"United States person","label":"6 United States person","identifier":"/us/usc/t22/s9754/b/6","parentIdentifier":"/us/usc/t22/s9754/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9754/b/6/A","parentIdentifier":"/us/usc/t22/s9754/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F6%2FA","sourceRelease":"119-100","text":"a United States citizen or an alien lawfully admitted for permanent residence to the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9754/b/6/B","parentIdentifier":"/us/usc/t22/s9754/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fb%2F6%2FB","sourceRelease":"119-100","text":"an entity organized under the laws of the United States or of any jurisdiction within the United States, including a foreign branch of such an entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Restriction on export of covered articles and services to certain security forces of Venezuela","label":"c Restriction on export of covered articles and services to certain security forces of Venezuela","identifier":"/us/usc/t22/s9754/c","parentIdentifier":"/us/usc/t22/s9754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s9754/c/1","parentIdentifier":"/us/usc/t22/s9754/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fc%2F1","sourceRelease":"119-100","text":"Notwithstanding any other provision of law, covered articles or services may not be exported from the United States to any element of the security forces of the Maduro regime.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Determination","label":"2 Determination","identifier":"/us/usc/t22/s9754/c/2","parentIdentifier":"/us/usc/t22/s9754/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9754/c/2/A","parentIdentifier":"/us/usc/t22/s9754/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fc%2F2%2FA","sourceRelease":"119-100","text":"determine, using such information that is available to the Secretary of State, whether any covered article or service has been transferred since July 2017 to the security forces of Venezuela without a license or other authorization as required by law; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9754/c/2/B","parentIdentifier":"/us/usc/t22/s9754/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fc%2F2%2FB","sourceRelease":"119-100","text":"submit such determination in writing to the appropriate congressional committees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Report","label":"d Report","identifier":"/us/usc/t22/s9754/d","parentIdentifier":"/us/usc/t22/s9754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s9754/d/1","parentIdentifier":"/us/usc/t22/s9754/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fd%2F1","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary of State, in consultation with the Secretary of Commerce, as appropriate, shall submit a report to the appropriate congressional committees regarding the transfer by foreign persons of covered articles or services to elements of the security forces of Venezuela that are under the authority of the Maduro regime.December 20, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Matters to be included","label":"2 Matters to be included","identifier":"/us/usc/t22/s9754/d/2","parentIdentifier":"/us/usc/t22/s9754/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9754/d/2/A","parentIdentifier":"/us/usc/t22/s9754/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fd%2F2%2FA","sourceRelease":"119-100","text":"a list of all significant transfers by foreign persons of covered articles or services to such elements of the security forces of Venezuela since July 2017;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9754/d/2/B","parentIdentifier":"/us/usc/t22/s9754/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fd%2F2%2FB","sourceRelease":"119-100","text":"a list of all foreign persons who maintain an existing defense relationship with such elements of the security forces of Venezuela; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9754/d/2/C","parentIdentifier":"/us/usc/t22/s9754/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fd%2F2%2FC","sourceRelease":"119-100","text":"any known use of covered articles or services by such elements of the security forces of Venezuela or associated forces, including paramilitary groups, that have coordinated with such security forces to assault, intimidate, or murder political activists, protesters, dissidents, and other civil society leaders, including Juan Guaidó.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Sunset","label":"e Sunset","identifier":"/us/usc/t22/s9754/e","parentIdentifier":"/us/usc/t22/s9754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9754/e/1","parentIdentifier":"/us/usc/t22/s9754/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fe%2F1","sourceRelease":"119-100","text":"the date that is 3 years after ; orDecember 20, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9754/e/2","parentIdentifier":"/us/usc/t22/s9754/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9754%2Fe%2F2","sourceRelease":"119-100","text":"the date on which the President certifies to the appropriate congressional committees that the Government of Venezuela has returned to a democratic form of government with respect for the essential elements of representative democracy as set forth in Article 3 of the Inter-American Democratic Charter, adopted by the Organization of American States in Lima on .September 11, 2001","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
