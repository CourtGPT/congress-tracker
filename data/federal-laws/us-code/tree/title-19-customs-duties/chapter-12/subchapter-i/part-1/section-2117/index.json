{"type":"section","nativeType":"section","number":"2117","heading":"International safeguard procedures","label":"2117 International safeguard procedures","identifier":"/us/usc/t19/s2117","parentIdentifier":"/us/usc/t19/ch12/schI/pt1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2117","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Harmonization, reduction, or elimination of barriers and distortions affecting international trade; use of temporary measures","label":"a Harmonization, reduction, or elimination of barriers and distortions affecting international trade; use of temporary measures","identifier":"/us/usc/t19/s2117/a","parentIdentifier":"/us/usc/t19/s2117","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2117%2Fa","sourceRelease":"119-100","text":"A principal United States negotiating objective under shall be to obtain internationally agreed upon rules and procedures, in the context of the harmonization, reduction, or elimination of barriers to, and other distortions of, international trade, which permit the use of temporary measures to ease adjustment to changes occurring in competitive conditions in the domestic markets of the parties to an agreement resulting from such negotiations due to the expansion of international trade.section 2112 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Permissible provisions","label":"b Permissible provisions","identifier":"/us/usc/t19/s2117/b","parentIdentifier":"/us/usc/t19/s2117","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2117%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s2117/b/1","parentIdentifier":"/us/usc/t19/s2117/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2117%2Fb%2F1","sourceRelease":"119-100","text":"notification of affected exporting countries,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s2117/b/2","parentIdentifier":"/us/usc/t19/s2117/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2117%2Fb%2F2","sourceRelease":"119-100","text":"international consultations,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s2117/b/3","parentIdentifier":"/us/usc/t19/s2117/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2117%2Fb%2F3","sourceRelease":"119-100","text":"international review of changes in trade flows,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t19/s2117/b/4","parentIdentifier":"/us/usc/t19/s2117/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2117%2Fb%2F4","sourceRelease":"119-100","text":"making adjustments in trade flows as the result of such changes, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t19/s2117/b/5","parentIdentifier":"/us/usc/t19/s2117/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2117%2Fb%2F5","sourceRelease":"119-100","text":"international mediation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s2117/b/A","parentIdentifier":"/us/usc/t19/s2117/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2117%2Fb%2FA","sourceRelease":"119-100","text":"exclude, under specified conditions, the parties thereto from compensation obligations and retaliation, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s2117/b/B","parentIdentifier":"/us/usc/t19/s2117/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2117%2Fb%2FB","sourceRelease":"119-100","text":"permit domestic public procedures through which interested parties have the right to participate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
