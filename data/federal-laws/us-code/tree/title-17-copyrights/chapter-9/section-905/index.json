{"type":"section","nativeType":"section","number":"905","heading":"Exclusive rights in mask works","label":"905 Exclusive rights in mask works","identifier":"/us/usc/t17/s905","parentIdentifier":"/us/usc/t17/ch9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft17%2Fs905","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t17/s905/1","parentIdentifier":"/us/usc/t17/s905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft17%2Fs905%2F1","sourceRelease":"119-100","text":"to reproduce the mask work by optical, electronic, or any other means;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t17/s905/2","parentIdentifier":"/us/usc/t17/s905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft17%2Fs905%2F2","sourceRelease":"119-100","text":"to import or distribute a semiconductor chip product in which the mask work is embodied; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t17/s905/3","parentIdentifier":"/us/usc/t17/s905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft17%2Fs905%2F3","sourceRelease":"119-100","text":"to induce or knowingly to cause another person to do any of the acts described in paragraphs (1) and (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
