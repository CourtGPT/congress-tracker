{"type":"section","nativeType":"section","number":"7033","heading":"Availability of agency information technology funds","label":"7033 Availability of agency information technology funds","identifier":"/us/usc/t7/s7033","parentIdentifier":"/us/usc/t7/ch98/schX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7033","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Reservation of funds","label":"a Reservation of funds","identifier":"/us/usc/t7/s7033/a","parentIdentifier":"/us/usc/t7/s7033","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7033%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7033/a/1","parentIdentifier":"/us/usc/t7/s7033/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7033%2Fa%2F1","sourceRelease":"119-100","text":"For fiscal year 2001, $3,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7033/a/2","parentIdentifier":"/us/usc/t7/s7033/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7033%2Fa%2F2","sourceRelease":"119-100","text":"For each subsequent fiscal year, $2,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Time for reservation","label":"b Time for reservation","identifier":"/us/usc/t7/s7033/b","parentIdentifier":"/us/usc/t7/s7033","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7033%2Fb","sourceRelease":"119-100","text":"The Secretary shall notify Congress of the amount to be reserved under subsection (a) for a fiscal year not later than December 1 of that fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Use of funds","label":"c Use of funds","identifier":"/us/usc/t7/s7033/c","parentIdentifier":"/us/usc/t7/s7033","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7033%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t7/s7033/c/1","parentIdentifier":"/us/usc/t7/s7033/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7033%2Fc%2F1","sourceRelease":"119-100","text":"Funds reserved under subsection (a) shall be used to establish the Internet-based system required under and to expand the system as required by .section 7031 of this titlesection 7032 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Maintenance","label":"2 Maintenance","identifier":"/us/usc/t7/s7033/c/2","parentIdentifier":"/us/usc/t7/s7033/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7033%2Fc%2F2","sourceRelease":"119-100","text":"Once the system is established and operational, reserved amounts shall be used for maintenance and improvement of the system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Return of funds","label":"d Return of funds","identifier":"/us/usc/t7/s7033/d","parentIdentifier":"/us/usc/t7/s7033","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7033%2Fd","sourceRelease":"119-100","text":"Funds reserved under subsection (a) and unobligated at the end of the fiscal year shall be returned to the agency from which the funds were reserved, to remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
