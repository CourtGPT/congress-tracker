{"type":"section","nativeType":"section","number":"1814","heading":"Miscellaneous provisions","label":"1814 Miscellaneous provisions","identifier":"/us/usc/t25/s1814","parentIdentifier":"/us/usc/t25/ch20/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1814","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Eligibility of Navajo Tribe","label":"a Eligibility of Navajo Tribe","identifier":"/us/usc/t25/s1814/a","parentIdentifier":"/us/usc/t25/s1814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1814%2Fa","sourceRelease":"119-100","text":"The Navajo Tribe shall not be eligible to participate under the provisions of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Discriminatory practices prohibited","label":"b Discriminatory practices prohibited","identifier":"/us/usc/t25/s1814/b","parentIdentifier":"/us/usc/t25/s1814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1814%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s1814/b/1","parentIdentifier":"/us/usc/t25/s1814/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1814%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall not provide any funds to any institution which denies admission to any Indian student because such individual is not a member of a specific Indian tribe, or which denies admission to any Indian student because such individual is a member of a specific tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s1814/b/2","parentIdentifier":"/us/usc/t25/s1814/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1814%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary shall take steps to recover any unexpended and unobligated funds provided under this subchapter held by an institution determined to be in violation of paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
