.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10462a%2Fe%2F1%2FA","sourceRelease":"119-100","text":"a description of the process that the eligible entity uses for service of protection orders at the time of submission of the application;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s10462a/e/1/B","parentIdentifier":"/us/usc/t34/s10462a/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10462a%2Fe%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s10462a/e/1/B/i","parentIdentifier":"/us/usc/t34/s10462a/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10462a%2Fe%2F1%2FB%2Fi","sourceRelease":"119-100","text":"successful service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s10462a/e/1/B/ii","parentIdentifier":"/us/usc/t34/s10462a/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10462a%2Fe%2F1%2FB%2Fii","sourceRelease":"119-100","text":"enforcement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s10462a/e/1/C","parentIdentifier":"/us/usc/t34/s10462a/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10462a%2Fe%2F1%2FC","sourceRelease":"119-100","text":"an initial list of the entities serving as the partners of the eligible entity described in subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":