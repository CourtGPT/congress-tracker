agraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s25E/b/1/A","parentIdentifier":"/us/usc/t26/s25E/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s25E/b/1/A/i","parentIdentifier":"/us/usc/t26/s25E/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the modified adjusted gross income of the taxpayer for such taxable year, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s25E/b/1/A/ii","parentIdentifier":"/us/usc/t26/s25E/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the modified adjusted gross income of the taxpayer for the preceding taxable year, exceeds","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s25E/b/1/B","parentIdentifier":"/us/usc/t26/s25E/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the threshold amount.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Threshold amount","label":"2 Threshold amount","identifier":"/us/usc/t26/s25E/b/2","parentIdentifier":"/us/usc/t26/s25E/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s25E/b/2/A","parentIdentifier":"/us/usc/t26/s25E/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fb%2F2%2FA","sourceRelease":"119-100","text":"in the case of a joint return or a surviving spouse (as defined in section 2(a)), $150,000,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s25E/b/2/B","parentIdentifier":"/us/usc/t26/s25E/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fb%2F2%2FB","sourceRelease":"119-100","text":"in the case of a head of household (as defined in section 2(b)), $112,500, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t26/s25E/b/2/C","parentIdentifier":"/us/usc/t26/s25E/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fb%2F2%2FC","sourceRelease":"119-100","text":"in the case of a taxpayer not described in subparagraph (A) or (B), $75,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Modified adjusted gross income","label":"3 Modified adjusted gross income","identifier":"/us/usc/t26/s25E/b/3","parentIdentifier":"/us/usc/t26/s25E/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fb%2F3","sourceRelease":"119-100","text":"For purposes of this subsection, the term “modified adjusted gross income” means adjusted gross income increased by any amount excluded from gross income under section 911, 931, or 933.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Definitions","label":"c Definitions","identifier":"/us/usc/t26/s25E/c","parentIdentifier":"/us/usc/t26/s25E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Previously-owned clean vehicle","label":"1 Previously-owned clean vehicle","identifier":"/us/usc/t26/s25E/c/1","parentIdentifier":"/us/usc/t26/s25E/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s25E/c/1/A","parentIdentifier":"/us/usc/t26/s25E/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the model year of which is at least 2 years earlier than the calendar year in which the taxpayer acquires such vehicle,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s25E/c/1/B","parentIdentifier":"/us/usc/t26/s25E/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F1%2FB","sourceRelease":"119-100","text":"the original use of which commences with a person other than the taxpayer,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t26/s25E/c/1/C","parentIdentifier":"/us/usc/t26/s25E/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F1%2FC","sourceRelease":"119-100","text":"which is acquired by the taxpayer in a qualified sale, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t26/s25E/c/1/D","parentIdentifier":"/us/usc/t26/s25E/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F1%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s25E/c/1/D/i","parentIdentifier":"/us/usc/t26/s25E/c/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F1%2FD%2Fi","sourceRelease":"119-100","text":"meets the requirements of subparagraphs (C), (D), (E), (F), and (H) (except for clause (iv) thereof) of section 30D(d)(1), or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s25E/c/1/D/ii","parentIdentifier":"/us/usc/t26/s25E/c/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F1%2FD%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t26/s25E/c/1/D/ii/I","parentIdentifier":"/us/usc/t26/s25E/c/1/D/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F1%2FD%2Fii%2FI","sourceRelease":"119-100","text":"satisfies the requirements under subparagraphs (A) and (B) of section 30B(b)(3), and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t26/s25E/c/1/D/ii/II","parentIdentifier":"/us/usc/t26/s25E/c/1/D/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F1%2FD%2Fii%2FII","sourceRelease":"119-100","text":"has a gross vehicle weight rating of less than 14,000 pounds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Qualified sale","label":"2 Qualified sale","identifier":"/us/usc/t26/s25E/c/2","parentIdentifier":"/us/usc/t26/s25E/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s25E/c/2/A","parentIdentifier":"/us/usc/t26/s25E/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F2%2FA","sourceRelease":"119-100","text":"by a dealer (as defined in section 30D(g)(8)),","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s25E/c/2/B","parentIdentifier":"/us/usc/t26/s25E/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F2%2FB","sourceRelease":"119-100","text":"for a sale price which does not exceed $25,000, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t26/s25E/c/2/C","parentIdentifier":"/us/usc/t26/s25E/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F2%2FC","sourceRelease":"119-100","text":"which is the first transfer since the date of the enactment of this section to a qualified buyer other than the person with whom the original use of such vehicle commenced.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Qualified buyer","label":"3 Qualified buyer","identifier":"/us/usc/t26/s25E/c/3","parentIdentifier":"/us/usc/t26/s25E/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s25E/c/3/A","parentIdentifier":"/us/usc/t26/s25E/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F3%2FA","sourceRelease":"119-100","text":"who is an individual,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s25E/c/3/B","parentIdentifier":"/us/usc/t26/s25E/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F3%2FB","sourceRelease":"119-100","text":"who purchases such vehicle for use and not for resale,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t26/s25E/c/3/C","parentIdentifier":"/us/usc/t26/s25E/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F3%2FC","sourceRelease":"119-100","text":"with respect to whom no deduction is allowable with respect to another taxpayer under section 151, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t26/s25E/c/3/D","parentIdentifier":"/us/usc/t26/s25E/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F3%2FD","sourceRelease":"119-100","text":"who has not been allowed a credit under this section for any sale during the 3-year period ending on the date of the sale of such vehicle.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Motor vehicle; capacity","label":"4 Motor vehicle; capacity","identifier":"/us/usc/t26/s25E/c/4","parentIdentifier":"/us/usc/t26/s25E/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fc%2F4","sourceRelease":"119-100","text":"The terms “motor vehicle” and “capacity” have the meaning given such terms in paragraphs (2) and (4) of section 30D(d), respectively.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"VIN number requirement","label":"d VIN number requirement","identifier":"/us/usc/t26/s25E/d","parentIdentifier":"/us/usc/t26/s25E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fd","sourceRelease":"119-100","text":"No credit shall be allowed under subsection (a) with respect to any vehicle unless the taxpayer includes the vehicle identification number of such vehicle on the return of tax for the taxable year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Application of certain rules","label":"e Application of certain rules","identifier":"/us/usc/t26/s25E/e","parentIdentifier":"/us/usc/t26/s25E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fe","sourceRelease":"119-100","text":"For purposes of this section, rules similar to the rules of section 30D(f) (without regard to paragraph (10) or (11) thereof) shall apply for purposes of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Transfer of credit","label":"f Transfer of credit","identifier":"/us/usc/t26/s25E/f","parentIdentifier":"/us/usc/t26/s25E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Ff","sourceRelease":"119-100","text":"Rules similar to the rules of section 30D(g) shall apply.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Termination","label":"g Termination","identifier":"/us/usc/t26/s25E/g","parentIdentifier":"/us/usc/t26/s25E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs25E%2Fg","sourceRelease":"119-100","text":"No credit shall be allowed under this section with respect to any vehicle acquired after .September 30, 2025","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
