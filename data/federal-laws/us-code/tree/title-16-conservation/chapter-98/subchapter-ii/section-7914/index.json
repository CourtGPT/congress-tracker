{"type":"section","nativeType":"section","number":"7914","heading":"Shooting ranges","label":"7914 Shooting ranges","identifier":"/us/usc/t16/s7914","parentIdentifier":"/us/usc/t16/ch98/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7914","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s7914/a","parentIdentifier":"/us/usc/t16/s7914","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7914%2Fa","sourceRelease":"119-100","text":"Except as provided in subsection (b), the Secretary concerned may, in accordance with this section and other applicable law, lease or permit the use of Federal land for a shooting range.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Exception","label":"b Exception","identifier":"/us/usc/t16/s7914/b","parentIdentifier":"/us/usc/t16/s7914","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7914%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s7914/b/1","parentIdentifier":"/us/usc/t16/s7914/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7914%2Fb%2F1","sourceRelease":"119-100","text":"a component of the National Landscape Conservation System;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s7914/b/2","parentIdentifier":"/us/usc/t16/s7914/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7914%2Fb%2F2","sourceRelease":"119-100","text":"a component of the National