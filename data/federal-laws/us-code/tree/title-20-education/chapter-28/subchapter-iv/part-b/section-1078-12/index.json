10801 et seq.) of subchapter I of chapter 114 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under and Tables.Pub. L. 99–319100 Stat. 478section 10801 of Title 42May 23, 1986"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purpose","label":"a Purpose","identifier":"/us/usc/t20/s1078–12/a","parentIdentifier":"/us/usc/t20/s1078–12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fa","sourceRelease":"119-100","text":"The purpose of this section is to encourage qualified individuals to enter and continue employment as civil legal assistance attorneys.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Definitions","label":"b Definitions","identifier":"/us/usc/t20/s1078–12/b","parentIdentifier":"/us/usc/t20/s1078–12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Civil legal assistance attorney","label":"1 Civil legal assistance attorney","identifier":"/us/usc/t20/s1078–12/b/1","parentIdentifier":"/us/usc/t20/s1078–12/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1078–12/b/1/A","parentIdentifier":"/us/usc/t20/s1078–12/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1078%E2%80%9312%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"claus