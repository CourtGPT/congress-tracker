ntIdentifier":"/us/usc/t5/s1402/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs1402%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s1402/b/1/A","parentIdentifier":"/us/usc/t5/s1402/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs1402%2Fb%2F1%2FA","sourceRelease":"119-100","text":"are the property of the agency or are available to the agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s1402/b/1/B","parentIdentifier":"/us/usc/t5/s1402/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs1402%2Fb%2F1%2FB","sourceRelease":"119-100","text":"relate to programs and operations with respect to which that agency Chief Human Capital Officer has responsibilities under this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s1402/b/2","parentIdentifier":"/us/usc/t5/s1402/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs1402%2Fb%2F2","sourceRelease":"119-100","text":"may request such information or assistance as may be necessary for carrying out the duties and responsibilities provided by this chapter from any Federal, State, or local governmental entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
