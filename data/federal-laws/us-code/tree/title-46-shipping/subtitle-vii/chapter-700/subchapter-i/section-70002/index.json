{"type":"section","nativeType":"section","number":"70002","heading":"Special powers","label":"70002 Special powers","identifier":"/us/usc/t46/s70002","parentIdentifier":"/us/usc/t46/stVII/ch700/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70002","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2021—Par. (2). inserted “or 70022” after “section 70021”.Pub. L. 116–283"],"amendments":["Amendments2021—Par. (2). inserted “or 70022” after “section 70021”.Pub. L. 116–283"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s70002/1","parentIdentifier":"/us/usc/t46/s70002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70002%2F1","sourceRelease":"119-100","text":"the Secretary has reasonable cause to believe such vessel does not comply with any regulation issued under section 70034 or any other applicable law or treaty;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s70002/2","parentIdentifier":"/us/usc/t46/s70002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70002%2F2","sourceRelease":"119-100","text":"the Secretary determines such vessel does not satisfy the conditions for port entry set forth in section 70021 or 70022 of this title; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s70002/3","parentIdentifier":"/us/usc/t46/s70002","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs70002%2F3","sourceRelease":"119-100","text":"by reason of weather, visibility, sea conditions, port congestion, other hazardous circumstances, or the condition of such vessel, the Secretary is satisfied such direction is justified in the interest of safety.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
