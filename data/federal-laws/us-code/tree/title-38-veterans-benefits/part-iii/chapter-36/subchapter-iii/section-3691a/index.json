{"type":"section","nativeType":"section","number":"3691A","heading":"Withdrawal or leave of absence from certain education","label":"3691A Withdrawal or leave of absence from certain education","identifier":"/us/usc/t38/s3691A","parentIdentifier":"/us/usc/t38/ptIII/ch36/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t38/s3691A/a","parentIdentifier":"/us/usc/t38/s3691A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s3691A/a/1","parentIdentifier":"/us/usc/t38/s3691A/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fa%2F1","sourceRelease":"119-100","text":"A covered member may, after receiving orders to enter a period of covered service, withdraw or take a leave of absence from covered education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s3691A/a/2","parentIdentifier":"/us/usc/t38/s3691A/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s3691A/a/2/A","parentIdentifier":"/us/usc/t38/s3691A/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fa%2F2%2FA","sourceRelease":"119-100","text":"The institution concerned may not take any adverse action against a covered member on the basis that such covered member withdraws or takes a leave of absence under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s3691A/a/2/B","parentIdentifier":"/us/usc/t38/s3691A/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t38/s3691A/a/2/B/i","parentIdentifier":"/us/usc/t38/s3691A/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"The assignment of a failing grade to a covered member for covered education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t38/s3691A/a/2/B/ii","parentIdentifier":"/us/usc/t38/s3691A/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"The reduction of the grade point average of a covered member for covered education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t38/s3691A/a/2/B/iii","parentIdentifier":"/us/usc/t38/s3691A/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fa%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"The characterization of any absence of a covered member from covered education as unexcused.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t38/s3691A/a/2/B/iv","parentIdentifier":"/us/usc/t38/s3691A/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fa%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"The assessment of any financial penalty against a covered member.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Withdrawal","label":"b .—Withdrawal","identifier":"/us/usc/t38/s3691A/b","parentIdentifier":"/us/usc/t38/s3691A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fb","sourceRelease":"119-100","text":"If a covered member withdraws from covered education under subsection (a), the institution concerned shall refund all tuition and fees (including payments for housing) for the academic term from which the covered member withdraws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Leave of Absence","label":"c .—Leave of Absence","identifier":"/us/usc/t38/s3691A/c","parentIdentifier":"/us/usc/t38/s3691A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s3691A/c/1","parentIdentifier":"/us/usc/t38/s3691A/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fc%2F1","sourceRelease":"119-100","text":"assign a grade of “incomplete” (or equivalent) to the covered member for covered education for the academic term from which the covered member takes such leave of absence; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s3691A/c/2","parentIdentifier":"/us/usc/t38/s3691A/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fc%2F2","sourceRelease":"119-100","text":"to the extent practicable, permit the covered member, upon completion of the period covered service, to complete such academic term.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Definitions","label":"d .—Definitions","identifier":"/us/usc/t38/s3691A/d","parentIdentifier":"/us/usc/t38/s3691A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s3691A/d/1","parentIdentifier":"/us/usc/t38/s3691A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s3691A/d/1/A","parentIdentifier":"/us/usc/t38/s3691A/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fd%2F1%2FA","sourceRelease":"119-100","text":"at an institution of higher education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s3691A/d/1/B","parentIdentifier":"/us/usc/t38/s3691A/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fd%2F1%2FB","sourceRelease":"119-100","text":"paid for with educational assistance furnished under a law administered by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s3691A/d/2","parentIdentifier":"/us/usc/t38/s3691A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fd%2F2","sourceRelease":"119-100","text":"The term “covered member” means a member of the Armed Forces (including the reserve components) enrolled in covered education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s3691A/d/3","parentIdentifier":"/us/usc/t38/s3691A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s3691A/d/3/A","parentIdentifier":"/us/usc/t38/s3691A/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fd%2F3%2FA","sourceRelease":"119-100","text":"active service or inactive-duty training, as such terms are defined in ; orsection 101 of title 10","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s3691A/d/3/B","parentIdentifier":"/us/usc/t38/s3691A/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fd%2F3%2FB","sourceRelease":"119-100","text":"State active duty, as defined in .section 4303 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s3691A/d/4","parentIdentifier":"/us/usc/t38/s3691A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fd%2F4","sourceRelease":"119-100","text":"The term “institution concerned” means, with respect to a covered member, the institution of higher education where the covered member is enrolled in covered education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t38/s3691A/d/5","parentIdentifier":"/us/usc/t38/s3691A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fd%2F5","sourceRelease":"119-100","text":"The term “institution of higher education” has the meaning given such term in section 101 of the Higher Education Act of 1965 ().20 U.S.C. 1001","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t38/s3691A/d/6","parentIdentifier":"/us/usc/t38/s3691A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3691A%2Fd%2F6","sourceRelease":"119-100","text":"The term “period of covered service” means the period beginning on the date on which a covered member enters covered service and ending on the date on which the covered member is released from covered service or dies while in covered service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
