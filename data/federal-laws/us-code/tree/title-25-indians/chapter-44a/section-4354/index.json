{"type":"section","nativeType":"section","number":"4354","heading":"Native American tourism and branding enhancement","label":"4354 Native American tourism and branding enhancement","identifier":"/us/usc/t25/s4354","parentIdentifier":"/us/usc/t25/ch44A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t25/s4354/a","parentIdentifier":"/us/usc/t25/s4354","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4354/a/1","parentIdentifier":"/us/usc/t25/s4354/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fa%2F1","sourceRelease":"119-100","text":"take actions that help empower Indian tribes, tribal organizations, and Native Hawaiian organizations to showcase the heritage, foods, traditions, history, and continuing vitality of Native American communities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4354/a/2","parentIdentifier":"/us/usc/t25/s4354/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s4354/a/2/A","parentIdentifier":"/us/usc/t25/s4354/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fa%2F2%2FA","sourceRelease":"119-100","text":"to identify and enhance or maintain traditions and cultural features that are important to sustain the distinctiveness of the local Native American community; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s4354/a/2/B","parentIdentifier":"/us/usc/t25/s4354/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fa%2F2%2FB","sourceRelease":"119-100","text":"to provide visitor experiences that are authentic and respectful;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s4354/a/3","parentIdentifier":"/us/usc/t25/s4354/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fa%2F3","sourceRelease":"119-100","text":"provide assistance to interpret the connections between the indigenous peoples of the United States and the national identity of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s4354/a/4","parentIdentifier":"/us/usc/t25/s4354/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fa%2F4","sourceRelease":"119-100","text":"enhance efforts to promote understanding and respect for diverse cultures and subcultures in the United States and the relevance of those cultures to the national brand of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s4354/a/5","parentIdentifier":"/us/usc/t25/s4354/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fa%2F5","sourceRelease":"119-100","text":"enter into appropriate memoranda of understanding and establish public-private partnerships to ensure that arriving domestic travelers at airports and arriving international visitors at ports of entry are welcomed in a manner that both showcases and respects the diversity of Native American communities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Grants","label":"b Grants","identifier":"/us/usc/t25/s4354/b","parentIdentifier":"/us/usc/t25/s4354","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4354/b/1","parentIdentifier":"/us/usc/t25/s4354/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fb%2F1","sourceRelease":"119-100","text":"to support the efforts of Indian tribes, tribal organizations, and Native Hawaiian organizations to tell the story of Native Americans as the First Peoples of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4354/b/2","parentIdentifier":"/us/usc/t25/s4354/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fb%2F2","sourceRelease":"119-100","text":"to use the arts and humanities to help revitalize Native communities, promote economic development, increase livability, and present the uniqueness of the United States to visitors in a way that celebrates the diversity of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s4354/b/3","parentIdentifier":"/us/usc/t25/s4354/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fb%2F3","sourceRelease":"119-100","text":"to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Smithsonian","label":"c Smithsonian","identifier":"/us/usc/t25/s4354/c","parentIdentifier":"/us/usc/t25/s4354","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4354/c/1","parentIdentifier":"/us/usc/t25/s4354/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fc%2F1","sourceRelease":"119-100","text":"to share collections, exhibitions, interpretive materials, and educational strategies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4354/c/2","parentIdentifier":"/us/usc/t25/s4354/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4354%2Fc%2F2","sourceRelease":"119-100","text":"to conduct joint research and collaborative projects that would support tourism efforts for Indian tribes, tribal organizations, and Native Hawaiian organizations and carry out the intent of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
