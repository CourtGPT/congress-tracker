{"type":"section","nativeType":"section","number":"9712","heading":"Support for efforts at the United Nations on the humanitarian crisis in Venezuela","label":"9712 Support for efforts at the United Nations on the humanitarian crisis in Venezuela","identifier":"/us/usc/t22/s9712","parentIdentifier":"/us/usc/t22/ch104/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9712","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Sense of Congress","label":"a Sense of Congress","identifier":"/us/usc/t22/s9712/a","parentIdentifier":"/us/usc/t22/s9712","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9712%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9712/a/1","parentIdentifier":"/us/usc/t22/s9712/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9712%2Fa%2F1","sourceRelease":"119-100","text":"the extent and impact of the shortages of food, medicine, and medical supplies in Venezuela;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9712/a/2","parentIdentifier":"/us/usc/t22/s9712/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9712%2Fa%2F2","sourceRelease":"119-100","text":"basic health indicators in Venezuela, such as maternal and child mortality rates and the prevalence and treatment of communicable diseases; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s9712/a/3","parentIdentifier":"/us/usc/t22/s9712/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9712%2Fa%2F3","sourceRelease":"119-100","text":"the efforts needed to resolve the shortages identified in paragraph (1) and to improve the health indicators referred to in paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"United Nations Resident Coordinator","label":"b United Nations Resident Coordinator","identifier":"/us/usc/t22/s9712/b","parentIdentifier":"/us/usc/t22/s9712","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9712%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9712/b/1","parentIdentifier":"/us/usc/t22/s9712/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9712%2Fb%2F1","sourceRelease":"119-100","text":"contributes to Venezuela’s long-term recovery; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9712/b/2","parentIdentifier":"/us/usc/t22/s9712/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9712%2Fb%2F2","sourceRelease":"119-100","text":"advances humanitarian efforts in Venezuela and for Venezuelans residing in neighboring countries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
