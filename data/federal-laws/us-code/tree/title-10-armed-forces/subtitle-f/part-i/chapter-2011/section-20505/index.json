{"type":"section","nativeType":"section","number":"20505","heading":"Officer considered for removal: voluntary retirement or discharge","label":"20505 Officer considered for removal: voluntary retirement or discharge","identifier":"/us/usc/t10/s20505","parentIdentifier":"/us/usc/t10/stF/ptI/ch2011","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20505","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t10/s20505/a","parentIdentifier":"/us/usc/t10/s20505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20505%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s20505/a/1","parentIdentifier":"/us/usc/t10/s20505/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20505%2Fa%2F1","sourceRelease":"119-100","text":"for voluntary retirement, if the officer is qualified for retirement; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s20505/a/2","parentIdentifier":"/us/usc/t10/s20505/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20505%2Fa%2F2","sourceRelease":"119-100","text":"for discharge in accordance with subsection (b)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Retirement or Discharge","label":"b .—Retirement or Discharge","identifier":"/us/usc/t10/s20505/b","parentIdentifier":"/us/usc/t10/s20505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20505%2Fb","sourceRelease":"119-100