{"type":"section","nativeType":"section","number":"1183","heading":"Over-the-road bus exercises","label":"1183 Over-the-road bus exercises","identifier":"/us/usc/t6/s1183","parentIdentifier":"/us/usc/t6/ch4/schIV/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t6/s1183/a","parentIdentifier":"/us/usc/t6/s1183","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish a program for conducting security exercises for over-the-road bus transportation for the purpose of assessing and improving the capabilities of entities described in subsection (b) to prevent, prepare for, mitigate, respond to, and recover from acts of terrorism.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Covered entities","label":"b Covered entities","identifier":"/us/usc/t6/s1183/b","parentIdentifier":"/us/usc/t6/s1183","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s1183/b/1","parentIdentifier":"/us/usc/t6/s1183/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fb%2F1","sourceRelease":"119-100","text":"Federal, State, and local agencies and tribal governments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s1183/b/2","parentIdentifier":"/us/usc/t6/s1183/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fb%2F2","sourceRelease":"119-100","text":"over-the-road bus operators and over-the-road bus terminal owners and operators;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s1183/b/3","parentIdentifier":"/us/usc/t6/s1183/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fb%2F3","sourceRelease":"119-100","text":"governmental and nongovernmental emergency response providers and law enforcement agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s1183/b/4","parentIdentifier":"/us/usc/t6/s1183/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fb%2F4","sourceRelease":"119-100","text":"any other organization or entity that the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Requirements","label":"c Requirements","identifier":"/us/usc/t6/s1183/c","parentIdentifier":"/us/usc/t6/s1183","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s1183/c/1","parentIdentifier":"/us/usc/t6/s1183/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F1","sourceRelease":"119-100","text":"consolidates existing security exercises for over-the-road bus operators and terminals administered by the Department and the Department of Transportation, as jointly determined by the Secretary and the Secretary of Transportation, unless the Secretary waives this consolidation requirement, as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s1183/c/2","parentIdentifier":"/us/usc/t6/s1183/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s1183/c/2/A","parentIdentifier":"/us/usc/t6/s1183/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F2%2FA","sourceRelease":"119-100","text":"scaled and tailored to the needs of the over-the-road bus operators and terminals, including addressing the needs of the elderly and individuals with disabilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s1183/c/2/B","parentIdentifier":"/us/usc/t6/s1183/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F2%2FB","sourceRelease":"119-100","text":"live, in the case of the most at-risk facilities to a terrorist attack;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s1183/c/2/C","parentIdentifier":"/us/usc/t6/s1183/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F2%2FC","sourceRelease":"119-100","text":"coordinated with appropriate officials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s1183/c/2/D","parentIdentifier":"/us/usc/t6/s1183/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F2%2FD","sourceRelease":"119-100","text":"as realistic as practicable and based on current risk assessments, including credible threats, vulnerabilities, and consequences;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t6/s1183/c/2/E","parentIdentifier":"/us/usc/t6/s1183/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F2%2FE","sourceRelease":"119-100","text":"inclusive, as appropriate, of over-the-road bus frontline employees; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t6/s1183/c/2/F","parentIdentifier":"/us/usc/t6/s1183/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F2%2FF","sourceRelease":"119-100","text":"consistent with the National Incident Management System, the National Response Plan, the National Infrastructure Protection Plan, the National Preparedness Guidance, the National Preparedness Goal, and other such national initiatives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s1183/c/3","parentIdentifier":"/us/usc/t6/s1183/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s1183/c/3/A","parentIdentifier":"/us/usc/t6/s1183/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F3%2FA","sourceRelease":"119-100","text":"evaluated by the Secretary against clear and consistent performance measures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s1183/c/3/B","parentIdentifier":"/us/usc/t6/s1183/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F3%2FB","sourceRelease":"119-100","text":"assessed by the Secretary to identify best practices, which shall be shared, as appropriate, with operators providing over-the-road bus transportation, nonprofit employee organizations that represent over-the-road bus employees, Federal, State, local, and tribal officials, governmental and nongovernmental emergency response providers, and law enforcement personnel; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s1183/c/3/C","parentIdentifier":"/us/usc/t6/s1183/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F3%2FC","sourceRelease":"119-100","text":"used to develop recommendations, as appropriate, provided to over-the-road bus operators and terminal owners and operators on remedial action to be taken in response to lessons learned;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s1183/c/4","parentIdentifier":"/us/usc/t6/s1183/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F4","sourceRelease":"119-100","text":"allows for proper advanced notification of communities and local governments in which exercises are held, as appropriate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s1183/c/5","parentIdentifier":"/us/usc/t6/s1183/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fc%2F5","sourceRelease":"119-100","text":"assists State, local, and tribal governments and over-the-road bus operators and terminal owners and operators in designing, implementing, and evaluating additional exercises that conform to the requirements of paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"National Exercise Program","label":"d National Exercise Program","identifier":"/us/usc/t6/s1183/d","parentIdentifier":"/us/usc/t6/s1183","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1183%2Fd","sourceRelease":"119-100","text":"The Secretary shall ensure that the exercise program developed under subsection (c) is consistent with the National Exercise Program established under .section 748 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
