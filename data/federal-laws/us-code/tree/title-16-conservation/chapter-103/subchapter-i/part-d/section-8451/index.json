{"type":"section","nativeType":"section","number":"8451","heading":"Connect our parks","label":"8451 Connect our parks","identifier":"/us/usc/t16/s8451","parentIdentifier":"/us/usc/t16/ch103/schI/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t16/s8451/a","parentIdentifier":"/us/usc/t16/s8451","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Appropriate committees of Congress","label":"1 Appropriate committees of Congress","identifier":"/us/usc/t16/s8451/a/1","parentIdentifier":"/us/usc/t16/s8451/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8451/a/1/A","parentIdentifier":"/us/usc/t16/s8451/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the Committee on Energy and Natural Resources of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8451/a/1/B","parentIdentifier":"/us/usc/t16/s8451/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the Committee on Commerce, Science, and Transportation of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8451/a/1/C","parentIdentifier":"/us/usc/t16/s8451/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fa%2F1%2FC","sourceRelease":"119-100","text":"the Committee on Natural Resources of the House of Representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s8451/a/1/D","parentIdentifier":"/us/usc/t16/s8451/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fa%2F1%2FD","sourceRelease":"119-100","text":"the Committee on Energy and Commerce of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Broadband internet access service","label":"2 Broadband internet access service","identifier":"/us/usc/t16/s8451/a/2","parentIdentifier":"/us/usc/t16/s8451/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fa%2F2","sourceRelease":"119-100","text":"The term “broadband internet access service” has the meaning given the term in section 8.1(b) of title 47, Code of Federal Regulations (or a successor regulation).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Cellular service","label":"3 Cellular service","identifier":"/us/usc/t16/s8451/a/3","parentIdentifier":"/us/usc/t16/s8451/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fa%2F3","sourceRelease":"119-100","text":"The term “cellular service” has the meaning given the term in section 22.99 of title 47, Code of Federal Regulations (or a successor regulation).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"National Park","label":"4 National Park","identifier":"/us/usc/t16/s8451/a/4","parentIdentifier":"/us/usc/t16/s8451/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fa%2F4","sourceRelease":"119-100","text":"The term “National Park” means a unit of the National Park System.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Secretary","label":"5 Secretary","identifier":"/us/usc/t16/s8451/a/5","parentIdentifier":"/us/usc/t16/s8451/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fa%2F5","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of the Interior, acting through the Director of the National Park Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Assessment","label":"b Assessment","identifier":"/us/usc/t16/s8451/b","parentIdentifier":"/us/usc/t16/s8451","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s8451/b/1","parentIdentifier":"/us/usc/t16/s8451/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8451/b/1/A","parentIdentifier":"/us/usc/t16/s8451/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F1%2FA","sourceRelease":"119-100","text":"locations in National Parks in which there is the greatest need for broadband internet access service, based on the considerations described in paragraph (2)(A); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8451/b/1/B","parentIdentifier":"/us/usc/t16/s8451/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F1%2FB","sourceRelease":"119-100","text":"areas in National Parks in which there is the greatest need for cellular service, based on the considerations described in paragraph (2)(B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Considerations","label":"2 Considerations","identifier":"/us/usc/t16/s8451/b/2","parentIdentifier":"/us/usc/t16/s8451/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Broadband internet access service","label":"A Broadband internet access service","identifier":"/us/usc/t16/s8451/b/2/A","parentIdentifier":"/us/usc/t16/s8451/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8451/b/2/A/i","parentIdentifier":"/us/usc/t16/s8451/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"housing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8451/b/2/A/ii","parentIdentifier":"/us/usc/t16/s8451/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"administrative facilities and related structures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s8451/b/2/A/iii","parentIdentifier":"/us/usc/t16/s8451/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"lodging;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s8451/b/2/A/iv","parentIdentifier":"/us/usc/t16/s8451/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"developed campgrounds; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t16/s8451/b/2/A/v","parentIdentifier":"/us/usc/t16/s8451/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F2%2FA%2Fv","sourceRelease":"119-100","text":"any other location within the National Park in which broadband internet access service is determined to be necessary by the superintendent of the National Park.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Cellular service","label":"B Cellular service","identifier":"/us/usc/t16/s8451/b/2/B","parentIdentifier":"/us/usc/t16/s8451/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8451/b/2/B/i","parentIdentifier":"/us/usc/t16/s8451/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the access of the public to emergency services and traveler information technologies; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8451/b/2/B/ii","parentIdentifier":"/us/usc/t16/s8451/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the communications capabilities of National Park Service employees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Report","label":"3 Report","identifier":"/us/usc/t16/s8451/b/3","parentIdentifier":"/us/usc/t16/s8451/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fb%2F3","sourceRelease":"119-100","text":"On completion of the assessment under paragraph (1), the Secretary shall submit to the appropriate committees of Congress, and make available on the website of the Department of the Interior, a report describing the results of the assessment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Plan","label":"c Plan","identifier":"/us/usc/t16/s8451/c","parentIdentifier":"/us/usc/t16/s8451","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s8451/c/1","parentIdentifier":"/us/usc/t16/s8451/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8451/c/1/A","parentIdentifier":"/us/usc/t16/s8451/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F1%2FA","sourceRelease":"119-100","text":"to install broadband internet access service infrastructure in certain locations in National Parks; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8451/c/1/B","parentIdentifier":"/us/usc/t16/s8451/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F1%2FB","sourceRelease":"119-100","text":"to install cellular service equipment and infrastructure in certain areas of National Parks.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Consultation","label":"2 Consultation","identifier":"/us/usc/t16/s8451/c/2","parentIdentifier":"/us/usc/t16/s8451/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8451/c/2/A","parentIdentifier":"/us/usc/t16/s8451/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F2%2FA","sourceRelease":"119-100","text":"affected Indian Tribes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8451/c/2/B","parentIdentifier":"/us/usc/t16/s8451/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F2%2FB","sourceRelease":"119-100","text":"local stakeholders that the superintendent of the applicable National Park determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Requirements","label":"3 Requirements","identifier":"/us/usc/t16/s8451/c/3","parentIdentifier":"/us/usc/t16/s8451/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8451/c/3/A","parentIdentifier":"/us/usc/t16/s8451/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8451/c/3/A/i","parentIdentifier":"/us/usc/t16/s8451/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FA%2Fi","sourceRelease":"119-100","text":"National Park viewsheds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8451/c/3/A/ii","parentIdentifier":"/us/usc/t16/s8451/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FA%2Fii","sourceRelease":"119-100","text":"cultural and natural resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s8451/c/3/A/iii","parentIdentifier":"/us/usc/t16/s8451/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"the visitor experience;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s8451/c/3/A/iv","parentIdentifier":"/us/usc/t16/s8451/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FA%2Fiv","sourceRelease":"119-100","text":"historic properties and the viewsheds of historic properties; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t16/s8451/c/3/A/v","parentIdentifier":"/us/usc/t16/s8451/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FA%2Fv","sourceRelease":"119-100","text":"other resources or values of the National Park.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8451/c/3/B","parentIdentifier":"/us/usc/t16/s8451/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8451/c/3/B/i","parentIdentifier":"/us/usc/t16/s8451/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":"previously disturbed or developed areas; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8451/c/3/B/ii","parentIdentifier":"/us/usc/t16/s8451/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":"areas zoned for uses that would support the infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8451/c/3/C","parentIdentifier":"/us/usc/t16/s8451/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8451/c/3/C/i","parentIdentifier":"/us/usc/t16/s8451/c/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FC%2Fi","sourceRelease":"119-100","text":"to install broadband internet access service or cellular service equipment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8451/c/3/C/ii","parentIdentifier":"/us/usc/t16/s8451/c/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FC%2Fii","sourceRelease":"119-100","text":"to provide broadband internet access service or cellular service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s8451/c/3/D","parentIdentifier":"/us/usc/t16/s8451/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FD","sourceRelease":"119-100","text":"be technology neutral; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s8451/c/3/E","parentIdentifier":"/us/usc/t16/s8451/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8451/c/3/E/i","parentIdentifier":"/us/usc/t16/s8451/c/3/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FE%2Fi","sourceRelease":"119-100","text":"a 100–Mbps downstream transmission capacity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8451/c/3/E/ii","parentIdentifier":"/us/usc/t16/s8451/c/3/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F3%2FE%2Fii","sourceRelease":"119-100","text":"a 20–Mbps upstream transmission capacity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Limitation","label":"4 Limitation","identifier":"/us/usc/t16/s8451/c/4","parentIdentifier":"/us/usc/t16/s8451/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8451%2Fc%2F4","sourceRelease":"119-100","text":"Notwithstanding paragraph (1), a plan developed under that paragraph shall not be required to address broadband internet access service or cellular service in any National Park with respect to which the superintendent of the National Park determines that there is adequate access to broadband internet access service or cellular service, as applicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
