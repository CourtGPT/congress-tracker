{"type":"section","nativeType":"section","number":"677b","heading":"Declaration","label":"677b Declaration","identifier":"/us/usc/t6/s677b","parentIdentifier":"/us/usc/t6/ch1/schXVIII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t6/s677b/a","parentIdentifier":"/us/usc/t6/s677b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Declaration","label":"1 Declaration","identifier":"/us/usc/t6/s677b/a/1","parentIdentifier":"/us/usc/t6/s677b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s677b/a/1/A","parentIdentifier":"/us/usc/t6/s677b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s677b/a/1/A/i","parentIdentifier":"/us/usc/t6/s677b/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"has occurred; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s677b/a/1/A/ii","parentIdentifier":"/us/usc/t6/s677b/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"is likely to occur imminently; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s677b/a/1/B","parentIdentifier":"/us/usc/t6/s677b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fa%2F1%2FB","sourceRelease":"119-100","text":"otherwise available resources, other than the Fund, are likely insufficient to respond effectively to, or to mitigate effectively, the specific significant incident described in subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Prohibition on delegation","label":"2 Prohibition on delegation","identifier":"/us/usc/t6/s677b/a/2","parentIdentifier":"/us/usc/t6/s677b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fa%2F2","sourceRelease":"119-100","text":"The Secretary may not delegate the authority provided to the Secretary under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Asset response activities","label":"b Asset response activities","identifier":"/us/usc/t6/s677b/b","parentIdentifier":"/us/usc/t6/s677b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s677b/b/1","parentIdentifier":"/us/usc/t6/s677b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fb%2F1","sourceRelease":"119-100","text":"the asset response activities of each Federal agency in response to the specific significant incident associated with the declaration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s677b/b/2","parentIdentifier":"/us/usc/t6/s677b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s677b/b/2/A","parentIdentifier":"/us/usc/t6/s677b/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fb%2F2%2FA","sourceRelease":"119-100","text":"public and private entities and State and local governments with respect to the asset response activities of those entities and governments; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s677b/b/2/B","parentIdentifier":"/us/usc/t6/s677b/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fb%2F2%2FB","sourceRelease":"119-100","text":"Federal, State, local, and Tribal law enforcement agencies with respect to investigations and threat response activities of those law enforcement agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s677b/b/3","parentIdentifier":"/us/usc/t6/s677b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fb%2F3","sourceRelease":"119-100","text":"Federal, State, local, and Tribal emergency management and response agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duration","label":"c Duration","identifier":"/us/usc/t6/s677b/c","parentIdentifier":"/us/usc/t6/s677b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s677b/c/1","parentIdentifier":"/us/usc/t6/s677b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fc%2F1","sourceRelease":"119-100","text":"a determination by the Secretary that the declaration is no longer necessary; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s677b/c/2","parentIdentifier":"/us/usc/t6/s677b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fc%2F2","sourceRelease":"119-100","text":"the expiration of the 120-day period beginning on the date on which the Secretary makes the declaration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Renewal","label":"d Renewal","identifier":"/us/usc/t6/s677b/d","parentIdentifier":"/us/usc/t6/s677b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fd","sourceRelease":"119-100","text":"The Secretary, without delegation, may renew a declaration as necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Publication","label":"e Publication","identifier":"/us/usc/t6/s677b/e","parentIdentifier":"/us/usc/t6/s677b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s677b/e/1","parentIdentifier":"/us/usc/t6/s677b/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fe%2F1","sourceRelease":"119-100","text":"Not later than 72 hours after a declaration or a renewal, the Secretary shall publish the declaration or renewal in the Federal Register.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Prohibition","label":"2 Prohibition","identifier":"/us/usc/t6/s677b/e/2","parentIdentifier":"/us/usc/t6/s677b/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Fe%2F2","sourceRelease":"119-100","text":"A declaration or renewal published under paragraph (1) may not include the name of any affected individual or private company.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Advance actions","label":"f Advance actions","identifier":"/us/usc/t6/s677b/f","parentIdentifier":"/us/usc/t6/s677b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s677b/f/1","parentIdentifier":"/us/usc/t6/s677b/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s677b/f/1/A","parentIdentifier":"/us/usc/t6/s677b/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Ff%2F1%2FA","sourceRelease":"119-100","text":"shall assess the resources available to respond to a potential declaration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s677b/f/1/B","parentIdentifier":"/us/usc/t6/s677b/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Ff%2F1%2FB","sourceRelease":"119-100","text":"may take actions before and while a declaration is in effect to arrange or procure additional resources for asset response activities or technical assistance the Secretary determines necessary, which may include entering into standby contracts with private entities for cybersecurity services or incident responders in the event of a declaration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Expenditure of funds","label":"2 Expenditure of funds","identifier":"/us/usc/t6/s677b/f/2","parentIdentifier":"/us/usc/t6/s677b/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677b%2Ff%2F2","sourceRelease":"119-100","text":"Any expenditure from the Fund for the purpose of paragraph (1)(B) shall be made from amounts available in the Fund, and amounts available in the Fund shall be in addition to any other appropriations available to the Cybersecurity and Infrastructure Security Agency for such purpose.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
