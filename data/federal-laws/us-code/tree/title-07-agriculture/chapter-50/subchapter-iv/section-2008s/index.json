,"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t7/s2008s/a","parentIdentifier":"/us/usc/t7/s2008s","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Indian tribe","label":"1 Indian tribe","identifier":"/us/usc/t7/s2008s/a/1","parentIdentifier":"/us/usc/t7/s2008s/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F1","sourceRelease":"119-100","text":"The term “Indian tribe” has the meaning given the term in .section 5304 of title 25","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Microentrepreneur","label":"2 Microentrepreneur","identifier":"/us/usc/t7/s2008s/a/2","parentIdentifier":"/us/usc/t7/s2008s/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F2","sourceRelease":"119-100","text":"The term “microentrepreneur” means an owner and operator, or prospective owner and operator, of a rural microenterprise who is unable to obtain sufficient training, technical assistance, or credit other than under this section, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Microenterprise development organization","label":"3 Microenterprise development organization","identifier":"/us/usc/t7/s2008s/a/3","parentIdentifier":"/us/usc/t7/s2008s/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2008s/a/3/A","parentIdentifier":"/us/usc/t7/s2008s/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s2008s/a/3/A/i","parentIdentifier":"/us/usc/t7/s2008s/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F3%2FA%2Fi","sourceRelease":"119-100","text":"a nonprofit entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s2008s/a/3/A/ii","parentIdentifier":"/us/usc/t7/s2008s/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F3%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s2008s/a/3/A/ii/I","parentIdentifier":"/us/usc/t7/s2008s/a/3/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F3%2FA%2Fii%2FI","sourceRelease":"119-100","text":"no microenterprise development organization serves the Indian tribe; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s2008s/a/3/A/ii/II","parentIdentifier":"/us/usc/t7/s2008s/a/3/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F3%2FA%2Fii%2FII","sourceRelease":"119-100","text":"no rural microentrepreneur assistance program exists under the jurisdiction of the Indian tribe; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s2008s/a/3/A/iii","parentIdentifier":"/us/usc/t7/s2008s/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"a public institution of higher education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2008s/a/3/B","parentIdentifier":"/us/usc/t7/s2008s/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F3%2FB","sourceRelease":"119-100","text":"provides training and technical assistance to rural microentrepreneurs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s2008s/a/3/C","parentIdentifier":"/us/usc/t7/s2008s/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F3%2FC","sourceRelease":"119-100","text":"facilitates access to capital or another service described in subsection (b) for rural microenterprises; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s2008s/a/3/D","parentIdentifier":"/us/usc/t7/s2008s/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F3%2FD","sourceRelease":"119-100","text":"has a demonstrated record of delivering services to rural microentrepreneurs, or an effective plan to develop a program to deliver services to rural microentrepreneurs, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Microloan","label":"4 Microloan","identifier":"/us/usc/t7/s2008s/a/4","parentIdentifier":"/us/usc/t7/s2008s/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F4","sourceRelease":"119-100","text":"The term “microloan” means a business loan of not more than $50,000 that is provided to a rural microenterprise.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Program","label":"5 Program","identifier":"/us/usc/t7/s2008s/a/5","parentIdentifier":"/us/usc/t7/s2008s/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F5","sourceRelease":"119-100","text":"The term “program” means the rural microentrepreneur assistance program established under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Rural microenterprise","label":"6 Rural microenterprise","identifier":"/us/usc/t7/s2008s/a/6","parentIdentifier":"/us/usc/t7/s2008s/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2008s/a/6/A","parentIdentifier":"/us/usc/t7/s2008s/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F6%2FA","sourceRelease":"119-100","text":"a sole proprietorship located in a rural area; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2008s/a/6/B","parentIdentifier":"/us/usc/t7/s2008s/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fa%2F6%2FB","sourceRelease":"119-100","text":"a business entity with not more than 10 full-time-equivalent employees located in a rural area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Rural microentrepreneur assistance program","label":"b Rural microentrepreneur assistance program","identifier":"/us/usc/t7/s2008s/b","parentIdentifier":"/us/usc/t7/s2008s","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t7/s2008s/b/1","parentIdentifier":"/us/usc/t7/s2008s/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall establish a rural microentrepreneur assistance program to provide loans and grants to support microentrepreneurs in the development and ongoing success of rural microenterprises.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Purpose","label":"2 Purpose","identifier":"/us/usc/t7/s2008s/b/2","parentIdentifier":"/us/usc/t7/s2008s/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2008s/b/2/A","parentIdentifier":"/us/usc/t7/s2008s/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the skills necessary to establish new rural microenterprises; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2008s/b/2/B","parentIdentifier":"/us/usc/t7/s2008s/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F2%2FB","sourceRelease":"119-100","text":"continuing technical and financial assistance related to the successful operation of rural microenterprises.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Loans","label":"3 Loans","identifier":"/us/usc/t7/s2008s/b/3","parentIdentifier":"/us/usc/t7/s2008s/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s2008s/b/3/A","parentIdentifier":"/us/usc/t7/s2008s/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F3%2FA","sourceRelease":"119-100","text":"The Secretary shall make loans to microenterprise development organizations for the purpose of providing fixed interest rate microloans to microentrepreneurs for startup and growing rural microenterprises.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Loan terms","label":"B Loan terms","identifier":"/us/usc/t7/s2008s/b/3/B","parentIdentifier":"/us/usc/t7/s2008s/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s2008s/b/3/B/i","parentIdentifier":"/us/usc/t7/s2008s/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"be for a term not to exceed 20 years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s2008s/b/3/B/ii","parentIdentifier":"/us/usc/t7/s2008s/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"bear an annual interest rate of at least 1 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Loan loss reserve fund","label":"C Loan loss reserve fund","identifier":"/us/usc/t7/s2008s/b/3/C","parentIdentifier":"/us/usc/t7/s2008s/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s2008s/b/3/C/i","parentIdentifier":"/us/usc/t7/s2008s/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F3%2FC%2Fi","sourceRelease":"119-100","text":"establish a loan loss reserve fund; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s2008s/b/3/C/ii","parentIdentifier":"/us/usc/t7/s2008s/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F3%2FC%2Fii","sourceRelease":"119-100","text":"maintain the reserve fund in an amount equal to at least 5 percent of the outstanding balance of such loans owed by the microenterprise development organization, until all obligations owed to the Secretary under this paragraph are repaid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Deferral of interest and principal","label":"D Deferral of interest and principal","identifier":"/us/usc/t7/s2008s/b/3/D","parentIdentifier":"/us/usc/t7/s2008s/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F3%2FD","sourceRelease":"119-100","text":"The Secretary may permit the deferral of payments on principal and interest due on a loan to a microenterprise development organization made under this paragraph for a 2-year period beginning on the date the loan is made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Grants","label":"4 Grants","identifier":"/us/usc/t7/s2008s/b/4","parentIdentifier":"/us/usc/t7/s2008s/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Grants to support rural microenterprise development","label":"A Grants to support rural microenterprise development","identifier":"/us/usc/t7/s2008s/b/4/A","parentIdentifier":"/us/usc/t7/s2008s/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t7/s2008s/b/4/A/i","parentIdentifier":"/us/usc/t7/s2008s/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s2008s/b/4/A/i/I","parentIdentifier":"/us/usc/t7/s2008s/b/4/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FA%2Fi%2FI","sourceRelease":"119-100","text":"provide training, operational support, business planning, and market development assistance, and other related services to rural microentrepreneurs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s2008s/b/4/A/i/II","parentIdentifier":"/us/usc/t7/s2008s/b/4/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FA%2Fi%2FII","sourceRelease":"119-100","text":"carry out such other projects and activities as the Secretary determines appropriate to further the purposes of the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Selection","label":"ii Selection","identifier":"/us/usc/t7/s2008s/b/4/A/ii","parentIdentifier":"/us/usc/t7/s2008s/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s2008s/b/4/A/ii/I","parentIdentifier":"/us/usc/t7/s2008s/b/4/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FA%2Fii%2FI","sourceRelease":"119-100","text":"place an emphasis on microenterprise development organizations that serve microentrepreneurs that are located in rural areas that have suffered significant outward migration, as determined by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s2008s/b/4/A/ii/II","parentIdentifier":"/us/usc/t7/s2008s/b/4/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FA%2Fii%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t7/s2008s/b/4/A/ii/II/aa","parentIdentifier":"/us/usc/t7/s2008s/b/4/A/ii/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FA%2Fii%2FII%2Faa","sourceRelease":"119-100","text":"of varying sizes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t7/s2008s/b/4/A/ii/II/bb","parentIdentifier":"/us/usc/t7/s2008s/b/4/A/ii/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FA%2Fii%2FII%2Fbb","sourceRelease":"119-100","text":"that serve racially and ethnically diverse populations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Grants to assist microentrepreneurs","label":"B Grants to assist microentrepreneurs","identifier":"/us/usc/t7/s2008s/b/4/B","parentIdentifier":"/us/usc/t7/s2008s/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t7/s2008s/b/4/B/i","parentIdentifier":"/us/usc/t7/s2008s/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s2008s/b/4/B/i/I","parentIdentifier":"/us/usc/t7/s2008s/b/4/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FB%2Fi%2FI","sourceRelease":"119-100","text":"received a loan from the microenterprise development organization under paragraph (3); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s2008s/b/4/B/i/II","parentIdentifier":"/us/usc/t7/s2008s/b/4/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FB%2Fi%2FII","sourceRelease":"119-100","text":"are seeking a loan from the microenterprise development organization under paragraph (3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Amount of grant","label":"ii Amount of grant","identifier":"/us/usc/t7/s2008s/b/4/B/ii","parentIdentifier":"/us/usc/t7/s2008s/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s2008s/b/4/B/ii/I","parentIdentifier":"/us/usc/t7/s2008s/b/4/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FB%2Fii%2FI","sourceRelease":"119-100","text":"satisfactory performance by the microenterprise development organization under this section, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s2008s/b/4/B/ii/II","parentIdentifier":"/us/usc/t7/s2008s/b/4/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FB%2Fii%2FII","sourceRelease":"119-100","text":"the availability of funding.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Administrative expenses","label":"C Administrative expenses","identifier":"/us/usc/t7/s2008s/b/4/C","parentIdentifier":"/us/usc/t7/s2008s/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fb%2F4%2FC","sourceRelease":"119-100","text":"Not more than 10 percent of a grant received by a microenterprise development organization for a fiscal year under this paragraph may be used to pay administrative expenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Administration","label":"c Administration","identifier":"/us/usc/t7/s2008s/c","parentIdentifier":"/us/usc/t7/s2008s","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Cost share","label":"1 Cost share","identifier":"/us/usc/t7/s2008s/c/1","parentIdentifier":"/us/usc/t7/s2008s/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Federal share","label":"A Federal share","identifier":"/us/usc/t7/s2008s/c/1/A","parentIdentifier":"/us/usc/t7/s2008s/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fc%2F1%2FA","sourceRelease":"119-100","text":"Subject to subparagraph (B), the Federal share of the cost of a project funded under this section shall not exceed 75 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Matching requirement","label":"B Matching requirement","identifier":"/us/usc/t7/s2008s/c/1/B","parentIdentifier":"/us/usc/t7/s2008s/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fc%2F1%2FB","sourceRelease":"119-100","text":"As a condition of any grant made under this subparagraph, the Secretary shall require the microenterprise development organization to match not less than 15 percent of the total amount of the grant in the form of matching funds, indirect costs, or in-kind goods or services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Form of non-Federal share","label":"C Form of non-Federal share","identifier":"/us/usc/t7/s2008s/c/1/C","parentIdentifier":"/us/usc/t7/s2008s/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fc%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s2008s/c/1/C/i","parentIdentifier":"/us/usc/t7/s2008s/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fc%2F1%2FC%2Fi","sourceRelease":"119-100","text":"in cash (including through fees, grants (including community development block grants), and gifts); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s2008s/c/1/C/ii","parentIdentifier":"/us/usc/t7/s2008s/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fc%2F1%2FC%2Fii","sourceRelease":"119-100","text":"in the form of in-kind contributions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Oversight","label":"2 Oversight","identifier":"/us/usc/t7/s2008s/c/2","parentIdentifier":"/us/usc/t7/s2008s/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fc%2F2","sourceRelease":"119-100","text":"At a minimum, not later than December 1 of each fiscal year, a microenterprise development organization that receives a loan or grant under this section shall provide to the Secretary such information as the Secretary may require to ensure that assistance provided under this section is used for the purposes for which the loan or grant was made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t7/s2008s/d","parentIdentifier":"/us/usc/t7/s2008s","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008s%2Fd","sourceRelease":"119-100","text":"There are authorized to be appropriated to carry out this section $20,000,000 for each of fiscal years 2019 through 2023.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
