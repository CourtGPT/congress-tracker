ildren":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s3921/c/3/D","parentIdentifier":"/us/usc/t16/s3921/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3921%2Fc%2F3%2FD","sourceRelease":"119-100","text":"outdoor recreation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s3921/c/3/E","parentIdentifier":"/us/usc/t16/s3921/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3921%2Fc%2F3%2FE","sourceRelease":"119-100","text":"other areas or concerns the Secretary considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
