{"type":"section","nativeType":"section","number":"44302a","heading":"Temporary insurance","label":"44302a Temporary insurance","identifier":"/us/usc/t49/s44302a","parentIdentifier":"/us/usc/t49/stVII/ptA/sptiii/ch443","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44302a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t49/s44302a/a","parentIdentifier":"/us/usc/t49/s44302a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44302a%2Fa","sourceRelease":"119-100","text":"The Secretary may provide insurance or reinsurance under this section to or for an air carrier for 1 coverage period not to exceed 90 days. Except as otherwise provided in this section, such insurance or reinsurance shall be subject to the requirements of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Restrictions","label":"b .—Restrictions","identifier":"/us/usc/t49/s44302a/b","parentIdentifier":"/us/usc/t49/s44302a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44302a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s44302a/b/1","parentIdentifier":"/us/usc/t49/s44302a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44302a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s44302a/b/1/A","parentIdentifier":"/us/usc/t49/s44302a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44302a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"notice under the policy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s44302a/b/1/B","parentIdentifier":"/us/usc/t49/s44302a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44302a%2Fb%2F1%2FB","sourceRelease":"119-100","text":"an endorsement to the policy; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s44302a/b/1/C","parentIdentifier":"/us/usc/t49/s44302a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44302a%2Fb%2F1%2FC","sourceRelease":"119-100","text":"an automatic termination provision in the policy or any endorsement thereto; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s44302a/b/2","parentIdentifier":"/us/usc/t49/s44302a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44302a%2Fb%2F2","sourceRelease":"119-100","text":"may cover hull, comprehensive, and third party liability risks.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Premium","label":"c .—Premium","identifier":"/us/usc/t49/s44302a/c","parentIdentifier":"/us/usc/t49/s44302a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44302a%2Fc","sourceRelease":"119-100","text":"A premium for insurance or reinsurance provided under this section shall be calculated based on a prorated amount equivalent to the premium that was in effect under the terminated insurance carrier policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Approval","label":"d .—Approval","identifier":"/us/usc/t49/s44302a/d","parentIdentifier":"/us/usc/t49/s44302a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44302a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s44302a/d/1","parentIdentifier":"/us/usc/t49/s44302a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44302a%2Fd%2F1","sourceRelease":"119-100","text":"shall be exempt from the requirements of section 44302(c); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s44302a/d/2","parentIdentifier":"/us/usc/t49/s44302a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44302a%2Fd%2F2","sourceRelease":"119-100","text":"may provide coverage to the extent allowed under section 44303, as determined by the Secretary, notwithstanding any determination by the President in subsection (a)(1) of such section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
