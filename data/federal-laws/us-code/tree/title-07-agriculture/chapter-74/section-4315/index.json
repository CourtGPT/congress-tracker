{"type":"section","nativeType":"section","number":"4315","heading":"Certification of organizations; applicable criteria and considerations","label":"4315 Certification of organizations; applicable criteria and considerations","identifier":"/us/usc/t7/s4315","parentIdentifier":"/us/usc/t7/ch74","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4315","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s4315/1","parentIdentifier":"/us/usc/t7/s4315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4315%2F1","sourceRelease":"119-100","text":"geographic territory covered by the organization’s active membership;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s4315/2","parentIdentifier":"/us/usc/t7/s4315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4315%2F2","sourceRelease":"119-100","text":"nature and size of the organization’s active membership, the proportion of such active membership accounted for by producers and importers, and information as to the volume of production by State or the volume of importation by country accounted for by the organization’s producer and importer members;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s4315/3","parentIdentifier":"/us/usc/t7/s4315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4315%2F3","sourceRelease":"119-100","text":"the extent to which the producer and importer membership of such organization is represented in setting the organization’s policies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s4315/4","parentIdentifier":"/us/usc/t7/s4315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4315%2F4","sourceRelease":"119-100","text":"evidence of stability and permanency of the organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s4315/5","parentIdentifier":"/us/usc/t7/s4315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4315%2F5","sourceRelease":"119-100","text":"sources from which the organization’s operating funds are derived;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s4315/6","parentIdentifier":"/us/usc/t7/s4315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4315%2F6","sourceRelease":"119-100","text":"functions of the organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t7/s4315/7","parentIdentifier":"/us/usc/t7/s4315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4315%2F7","sourceRelease":"119-100","text":"whether the majority of the governing board of the organization is composed of producers and importers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t7/s4315/8","parentIdentifier":"/us/usc/t7/s4315","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4315%2F8","sourceRelease":"119-100","text":"the organization’s ability and willingness to further the aims and objectives of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
