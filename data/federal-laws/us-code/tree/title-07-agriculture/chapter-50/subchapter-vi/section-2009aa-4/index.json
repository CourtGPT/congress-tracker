{"type":"section","nativeType":"section","number":"2009aa–4","heading":"Local development districts; certification and administrative expenses","label":"2009aa–4 Local development districts; certification and administrative expenses","identifier":"/us/usc/t7/s2009aa–4","parentIdentifier":"/us/usc/t7/ch50/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2018—Subsec. (a)(1)(B)(iv). realigned margins.Pub. L. 115–3342002—Subsec. (b)(1). substituted “Authority shall” for “Authority may”.Pub. L. 107–171"],"amendments":["Amendments2018—Subsec. (a)(1)(B)(iv). realigned margins.Pub. L. 115–3342002—Subsec. (b)(1). substituted “Authority shall” for “Authority may”.Pub. L. 107–171"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definition of local development district","label":"a Definition of local development district","identifier":"/us/usc/t7/s2009aa–4/a","parentIdentifier":"/us/usc/t7/s2009aa–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2009aa–4/a/1","parentIdentifier":"/us/usc/t7/s2009aa–4/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2009aa–4/a/1/A","parentIdentifier":"/us/usc/t7/s2009aa–4/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F1%2FA","sourceRelease":"119-100","text":"a planning district in existence on , that is recognized by the Economic Development Administration of the Department of Commerce; orDecember 21, 2000","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2009aa–4/a/1/B","parentIdentifier":"/us/usc/t7/s2009aa–4/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s2009aa–4/a/1/B/i","parentIdentifier":"/us/usc/t7/s2009aa–4/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"organized and operated in a manner that ensures broad-based community participation and an effective opportunity for other nonprofit groups to contribute to the development and implementation of programs in the region;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s2009aa–4/a/1/B/ii","parentIdentifier":"/us/usc/t7/s2009aa–4/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"governed by a policy board with at least a simple majority of members consisting of elected officials or employees of a general purpose unit of local government who have been appointed to represent the government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s2009aa–4/a/1/B/iii","parentIdentifier":"/us/usc/t7/s2009aa–4/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F1%2FB%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s2009aa–4/a/1/B/iii/I","parentIdentifier":"/us/usc/t7/s2009aa–4/a/1/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F1%2FB%2Fiii%2FI","sourceRelease":"119-100","text":"by the Governor of each State in which the entity is located; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s2009aa–4/a/1/B/iii/II","parentIdentifier":"/us/usc/t7/s2009aa–4/a/1/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F1%2FB%2Fiii%2FII","sourceRelease":"119-100","text":"by the State officer designated by the appropriate State law to make the certification; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s2009aa–4/a/1/B/iv","parentIdentifier":"/us/usc/t7/s2009aa–4/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F1%2FB%2Fiv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s2009aa–4/a/1/B/iv/I","parentIdentifier":"/us/usc/t7/s2009aa–4/a/1/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F1%2FB%2Fiv%2FI","sourceRelease":"119-100","text":"a nonprofit incorporated body organized or chartered under the law of the State in which the entity is located;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s2009aa–4/a/1/B/iv/II","parentIdentifier":"/us/usc/t7/s2009aa–4/a/1/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F1%2FB%2Fiv%2FII","sourceRelease":"119-100","text":"a nonprofit agency or instrumentality of a State or local government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t7/s2009aa–4/a/1/B/iv/III","parentIdentifier":"/us/usc/t7/s2009aa–4/a/1/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F1%2FB%2Fiv%2FIII","sourceRelease":"119-100","text":"a public organization established before , under State law for creation of multi-jurisdictional, area-wide planning organizations; orDecember 21, 2000","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t7/s2009aa–4/a/1/B/iv/IV","parentIdentifier":"/us/usc/t7/s2009aa–4/a/1/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F1%2FB%2Fiv%2FIV","sourceRelease":"119-100","text":"a nonprofit association or combination of bodies, agencies, and instrumentalities described in subclauses (I) through (III); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2009aa–4/a/2","parentIdentifier":"/us/usc/t7/s2009aa–4/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2009aa–4/a/2/A","parentIdentifier":"/us/usc/t7/s2009aa–4/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F2%2FA","sourceRelease":"119-100","text":"inappropriately used Federal grant funds from any Federal source; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2009aa–4/a/2/B","parentIdentifier":"/us/usc/t7/s2009aa–4/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fa%2F2%2FB","sourceRelease":"119-100","text":"appointed an officer who, during the period in which another entity inappropriately used Federal grant funds from any Federal source, was an officer of the other entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Grants to local development districts","label":"b Grants to local development districts","identifier":"/us/usc/t7/s2009aa–4/b","parentIdentifier":"/us/usc/t7/s2009aa–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s2009aa–4/b/1","parentIdentifier":"/us/usc/t7/s2009aa–4/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fb%2F1","sourceRelease":"119-100","text":"The Authority shall make grants for administrative expenses under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Conditions for grants","label":"2 Conditions for grants","identifier":"/us/usc/t7/s2009aa–4/b/2","parentIdentifier":"/us/usc/t7/s2009aa–4/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Maximum amount","label":"A Maximum amount","identifier":"/us/usc/t7/s2009aa–4/b/2/A","parentIdentifier":"/us/usc/t7/s2009aa–4/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The amount of any grant awarded under paragraph (1) shall not exceed 80 percent of the administrative expenses of the local development district receiving the grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Maximum period","label":"B Maximum period","identifier":"/us/usc/t7/s2009aa–4/b/2/B","parentIdentifier":"/us/usc/t7/s2009aa–4/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fb%2F2%2FB","sourceRelease":"119-100","text":"No grant described in paragraph (1) shall be awarded to a State agency certified as a local development district for a period greater than 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Local share","label":"C Local share","identifier":"/us/usc/t7/s2009aa–4/b/2/C","parentIdentifier":"/us/usc/t7/s2009aa–4/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fb%2F2%2FC","sourceRelease":"119-100","text":"The contributions of a local development district for administrative expenses may be in cash or in kind, fairly evaluated, including space, equipment, and services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duties of local development districts","label":"c Duties of local development districts","identifier":"/us/usc/t7/s2009aa–4/c","parentIdentifier":"/us/usc/t7/s2009aa–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2009aa–4/c/1","parentIdentifier":"/us/usc/t7/s2009aa–4/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fc%2F1","sourceRelease":"119-100","text":"operate as a lead organization serving multicounty areas in the region at the local level; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2009aa–4/c/2","parentIdentifier":"/us/usc/t7/s2009aa–4/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2009aa–4/c/2/A","parentIdentifier":"/us/usc/t7/s2009aa–4/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fc%2F2%2FA","sourceRelease":"119-100","text":"are involved in multijurisdictional planning;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2009aa–4/c/2/B","parentIdentifier":"/us/usc/t7/s2009aa–4/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fc%2F2%2FB","sourceRelease":"119-100","text":"provide technical assistance to local jurisdictions and potential grantees; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s2009aa–4/c/2/C","parentIdentifier":"/us/usc/t7/s2009aa–4/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%934%2Fc%2F2%2FC","sourceRelease":"119-100","text":"provide leadership and civic development assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
