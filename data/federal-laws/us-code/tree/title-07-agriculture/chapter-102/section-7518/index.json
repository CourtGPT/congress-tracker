l,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s7518/b/2/E","parentIdentifier":"/us/usc/t7/s7518/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fb%2F2%2FE","sourceRelease":"119-100","text":"the Commonwealth of Puerto Rico;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t7/s7518/b/2/F","parentIdentifier":"/us/usc/t7/s7518/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fb%2F2%2FF","sourceRelease":"119-100","text":"the Federated States of Micronesia;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t7/s7518/b/2/G","parentIdentifier":"/us/usc/t7/s7518/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fb%2F2%2FG","sourceRelease":"119-100","text":"Guam;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t7/s7518/b/2/H","parentIdentifier":"/us/usc/t7/s7518/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fb%2F2%2FH","sourceRelease":"119-100","text":"the Republic of the Marshall Islands;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s7518/b/2/I","parentIdentifier":"/us/usc/t7/s7518/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fb%2F2%2FI","sourceRelease":"119-100","text":"the Republic of Palau; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t7/s7518/b/2/J","parentIdentifier":"/us/usc/t7/s7518/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fb%2F2%2FJ","sourceRelease":"119-100","text":"the United States Virgin Islands.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Establishment","label":"c Establishment","identifier":"/us/usc/t7/s7518/c","parentIdentifier":"/us/usc/t7/s7518","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fc","sourceRelease":"119-100","text":"The Secretary shall distribute funds to the agricultural department or agency of each eligible State for the competitive distribution of subgrants to eligible entities to increase the quantity and quality of locally grown food in food insecure communities, including through small-scale gardening, herding, and livestock operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Distribution of funds","label":"d Distribution of funds","identifier":"/us/usc/t7/s7518/d","parentIdentifier":"/us/usc/t7/s7518","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s7518/d/1","parentIdentifier":"/us/usc/t7/s7518/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7518/d/1/A","parentIdentifier":"/us/usc/t7/s7518/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fd%2F1%2FA","sourceRelease":"119-100","text":"40 percent to the State of Alaska;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7518/d/1/B","parentIdentifier":"/us/usc/t7/s7518/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fd%2F1%2FB","sourceRelease":"119-100","text":"40 percent to the State of Hawaii; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s7518/d/1/C","parentIdentifier":"/us/usc/t7/s7518/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fd%2F1%2FC","sourceRelease":"119-100","text":"2.5 percent to each eligible State described in any of subparagraphs (C) through (J) of subsection (b)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Carryover of funds","label":"2 Carryover of funds","identifier":"/us/usc/t7/s7518/d/2","parentIdentifier":"/us/usc/t7/s7518/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fd%2F2","sourceRelease":"119-100","text":"Funds distributed under paragraph (1) shall remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Administrative funds","label":"3 Administrative funds","identifier":"/us/usc/t7/s7518/d/3","parentIdentifier":"/us/usc/t7/s7518/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7518/d/3/A","parentIdentifier":"/us/usc/t7/s7518/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fd%2F3%2FA","sourceRelease":"119-100","text":"to administer the competition for providing subgrants to eligible entities in that eligible State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7518/d/3/B","parentIdentifier":"/us/usc/t7/s7518/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fd%2F3%2FB","sourceRelease":"119-100","text":"to provide oversight of the subgrant recipients in that eligible State; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s7518/d/3/C","parentIdentifier":"/us/usc/t7/s7518/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fd%2F3%2FC","sourceRelease":"119-100","text":"to collect data and submit a report to the Secretary under subsection (f)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Subgrants to eligible entities","label":"e Subgrants to eligible entities","identifier":"/us/usc/t7/s7518/e","parentIdentifier":"/us/usc/t7/s7518","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Amount of subgrants","label":"1 Amount of subgrants","identifier":"/us/usc/t7/s7518/e/1","parentIdentifier":"/us/usc/t7/s7518/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s7518/e/1/A","parentIdentifier":"/us/usc/t7/s7518/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s7518/e/1/A/i","parentIdentifier":"/us/usc/t7/s7518/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F1%2FA%2Fi","sourceRelease":"119-100","text":"in the case of an eligible entity that is an individual, not greater than $5,000 per year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s7518/e/1/A/ii","parentIdentifier":"/us/usc/t7/s7518/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F1%2FA%2Fii","sourceRelease":"119-100","text":"in the case of an eligible entity described in any of clauses (ii) through (v) of subsection (b)(1)(A), not greater than $10,000 per year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Matching requirement","label":"B Matching requirement","identifier":"/us/usc/t7/s7518/e/1/B","parentIdentifier":"/us/usc/t7/s7518/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F1%2FB","sourceRelease":"119-100","text":"As a condition of receiving a subgrant under this section, an eligible entity shall provide funds equal to 10 percent of the amount received by the eligible entity under the subgrant, to be derived from non-Federal sources. A State may waive the matching requirement for an individual who otherwise meets the requirements to receive a subgrant by the eligible State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Project period","label":"C Project period","identifier":"/us/usc/t7/s7518/e/1/C","parentIdentifier":"/us/usc/t7/s7518/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F1%2FC","sourceRelease":"119-100","text":"Funds received by an eligible entity that is awarded a subgrant under this section shall remain available for expenditure not later than 3 years after the date the funds are received.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Priority","label":"2 Priority","identifier":"/us/usc/t7/s7518/e/2","parentIdentifier":"/us/usc/t7/s7518/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7518/e/2/A","parentIdentifier":"/us/usc/t7/s7518/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F2%2FA","sourceRelease":"119-100","text":"has not previously received a subgrant under this section; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7518/e/2/B","parentIdentifier":"/us/usc/t7/s7518/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F2%2FB","sourceRelease":"119-100","text":"is located in a community or region in that eligible State with the highest degree of food insecurity, as determined by the agricultural department or agency of the eligible State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Projects","label":"3 Projects","identifier":"/us/usc/t7/s7518/e/3","parentIdentifier":"/us/usc/t7/s7518/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F3","sourceRelease":"119-100","text":"An eligible State may provide subgrants to 2 or more eligible entities to carry out the same project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Use of subgrant funds by eligible entities","label":"4 Use of subgrant funds by eligible entities","identifier":"/us/usc/t7/s7518/e/4","parentIdentifier":"/us/usc/t7/s7518/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7518/e/4/A","parentIdentifier":"/us/usc/t7/s7518/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FA","sourceRelease":"119-100","text":"purchasing gardening tools or equipment, soil, soil amendments, seeds, plants, animals, canning equipment, refrigeration, or other items necessary to grow and store food;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7518/e/4/B","parentIdentifier":"/us/usc/t7/s7518/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FB","sourceRelease":"119-100","text":"purchasing or building composting units;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s7518/e/4/C","parentIdentifier":"/us/usc/t7/s7518/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FC","sourceRelease":"119-100","text":"purchasing or building towers designed to grow leafy green vegetables;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s7518/e/4/D","parentIdentifier":"/us/usc/t7/s7518/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FD","sourceRelease":"119-100","text":"expanding an area under cultivation or engaging in other activities necessary to be eligible to receive funding under the environmental quality incentives program established under chapter 4 of subtitle D of title XII of the Food Security Act of 1985 ( et seq.) for a high tunnel;16 U.S.C. 3839aa","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s7518/e/4/E","parentIdentifier":"/us/usc/t7/s7518/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FE","sourceRelease":"119-100","text":"engaging in an activity that extends the growing season;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t7/s7518/e/4/F","parentIdentifier":"/us/usc/t7/s7518/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FF","sourceRelease":"119-100","text":"starting or expanding hydroponic and aeroponic farming of any scale;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t7/s7518/e/4/G","parentIdentifier":"/us/usc/t7/s7518/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FG","sourceRelease":"119-100","text":"building, buying, erecting, or repairing fencing for livestock, poultry, or reindeer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t7/s7518/e/4/H","parentIdentifier":"/us/usc/t7/s7518/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FH","sourceRelease":"119-100","text":"purchasing and equipping a slaughter and processing facility approved by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s7518/e/4/I","parentIdentifier":"/us/usc/t7/s7518/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FI","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s7518/e/4/I/i","parentIdentifier":"/us/usc/t7/s7518/e/4/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FI%2Fi","sourceRelease":"119-100","text":"a State cooperative extension service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s7518/e/4/I/ii","parentIdentifier":"/us/usc/t7/s7518/e/4/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FI%2Fii","sourceRelease":"119-100","text":"a land-grant college or university (as defined in );section 3103 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s7518/e/4/I/iii","parentIdentifier":"/us/usc/t7/s7518/e/4/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FI%2Fiii","sourceRelease":"119-100","text":"a Tribal College or University (as defined in );section 1059c(b) of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s7518/e/4/I/iv","parentIdentifier":"/us/usc/t7/s7518/e/4/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FI%2Fiv","sourceRelease":"119-100","text":"an Alaska Native-serving institution or a Native Hawaiian-serving institution (as such terms are defined in ); orsection 1059d(b) of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t7/s7518/e/4/I/v","parentIdentifier":"/us/usc/t7/s7518/e/4/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FI%2Fv","sourceRelease":"119-100","text":"a Federal or State agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t7/s7518/e/4/J","parentIdentifier":"/us/usc/t7/s7518/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FJ","sourceRelease":"119-100","text":"paying for shipping of purchased items relating to growing or raising food for local consumption or purchase;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"K","heading":null,"label":"K","identifier":"/us/usc/t7/s7518/e/4/K","parentIdentifier":"/us/usc/t7/s7518/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FK","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s7518/e/4/K/i","parentIdentifier":"/us/usc/t7/s7518/e/4/K","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FK%2Fi","sourceRelease":"119-100","text":"the sale of food commodities, specialty crops, and meats that are grown by the eligible entity for sale in the local community; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s7518/e/4/K/ii","parentIdentifier":"/us/usc/t7/s7518/e/4/K","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FK%2Fii","sourceRelease":"119-100","text":"increasing the availability of fresh, locally grown, and nutritious food; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"L","heading":null,"label":"L","identifier":"/us/usc/t7/s7518/e/4/L","parentIdentifier":"/us/usc/t7/s7518/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F4%2FL","sourceRelease":"119-100","text":"engaging in other activities relating to increasing food security (including subsistence), as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Eligibility for other financial assistance","label":"5 Eligibility for other financial assistance","identifier":"/us/usc/t7/s7518/e/5","parentIdentifier":"/us/usc/t7/s7518/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fe%2F5","sourceRelease":"119-100","text":"An eligible entity shall not be ineligible to receive financial assistance under another program administered by the Secretary as a result of receiving a subgrant under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Reporting requirement","label":"f Reporting requirement","identifier":"/us/usc/t7/s7518/f","parentIdentifier":"/us/usc/t7/s7518","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Subgrant recipients","label":"1 Subgrant recipients","identifier":"/us/usc/t7/s7518/f/1","parentIdentifier":"/us/usc/t7/s7518/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7518/f/1/A","parentIdentifier":"/us/usc/t7/s7518/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Ff%2F1%2FA","sourceRelease":"119-100","text":"not later than 60 days after the end of the project funded by the subgrant; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7518/f/1/B","parentIdentifier":"/us/usc/t7/s7518/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Ff%2F1%2FB","sourceRelease":"119-100","text":"that describes the use of the subgrants by eligible entities, the quantity of food grown through small-scale gardening, herding, and livestock operations, and the number of food insecure individuals fed as a result of the subgrant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report to the Secretary","label":"2 Report to the Secretary","identifier":"/us/usc/t7/s7518/f/2","parentIdentifier":"/us/usc/t7/s7518/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Ff%2F2","sourceRelease":"119-100","text":"Not later than 120 days after the date on which an eligible State receives a report from each eligible entity in that State under paragraph (1), the eligible State shall submit to the Secretary a report that describes, in the aggregate, the information and data contained in the reports received from those eligible entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Funding","label":"g Funding","identifier":"/us/usc/t7/s7518/g","parentIdentifier":"/us/usc/t7/s7518","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Authorization of appropriations","label":"1 Authorization of appropriations","identifier":"/us/usc/t7/s7518/g/1","parentIdentifier":"/us/usc/t7/s7518/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fg%2F1","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary to carry out this section $10,000,000 for fiscal year 2019 and each fiscal year thereafter, to remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Appropriations in advance","label":"2 Appropriations in advance","identifier":"/us/usc/t7/s7518/g/2","parentIdentifier":"/us/usc/t7/s7518/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7518%2Fg%2F2","sourceRelease":"119-100","text":"Only funds appropriated under paragraph (1) in advance specifically to carry out this section shall be available to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
