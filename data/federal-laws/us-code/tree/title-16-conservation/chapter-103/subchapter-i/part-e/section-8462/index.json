{"type":"section","nativeType":"section","number":"8462","heading":"Parking and restroom opportunities for Federal recreational lands and waters","label":"8462 Parking and restroom opportunities for Federal recreational lands and waters","identifier":"/us/usc/t16/s8462","parentIdentifier":"/us/usc/t16/ch103/schI/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Parking opportunities","label":"a Parking opportunities","identifier":"/us/usc/t16/s8462/a","parentIdentifier":"/us/usc/t16/s8462","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s8462/a/1","parentIdentifier":"/us/usc/t16/s8462/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8462/a/1/A","parentIdentifier":"/us/usc/t16/s8462/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fa%2F1%2FA","sourceRelease":"119-100","text":"in accordance with existing laws and applicable land use plans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8462/a/1/B","parentIdentifier":"/us/usc/t16/s8462/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fa%2F1%2FB","sourceRelease":"119-100","text":"in a manner that minimizes any increase in maintenance obligations on Federal recreational lands and waters; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8462/a/1/C","parentIdentifier":"/us/usc/t16/s8462/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fa%2F1%2FC","sourceRelease":"119-100","text":"in a manner that does not impact wildlife habitat that is critical to the mission of a Federal agency responsible for managing Federal recreational lands and waters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Authority","label":"2 Authority","identifier":"/us/usc/t16/s8462/a/2","parentIdentifier":"/us/usc/t16/s8462/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8462/a/2/A","parentIdentifier":"/us/usc/t16/s8462/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fa%2F2%2FA","sourceRelease":"119-100","text":"enter into a public-private partnership for parking opportunities on non-Federal land;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8462/a/2/B","parentIdentifier":"/us/usc/t16/s8462/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fa%2F2%2FB","sourceRelease":"119-100","text":"enter into contracts or agreements with State, Tribal, or local governments for parking opportunities using non-Federal lands and resources; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8462/a/2/C","parentIdentifier":"/us/usc/t16/s8462/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fa%2F2%2FC","sourceRelease":"119-100","text":"provide alternative transportation systems for a unit of Federal recreational lands and waters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Restroom opportunities","label":"b Restroom opportunities","identifier":"/us/usc/t16/s8462/b","parentIdentifier":"/us/usc/t16/s8462","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s8462/b/1","parentIdentifier":"/us/usc/t16/s8462/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fb%2F1","sourceRelease":"119-100","text":"The Secretaries shall seek to increase and improve the function, cleanliness, and availability of restroom facilities for persons recreating on Federal recreational lands and waters, including by entering into partnerships with non-Federal partners, including State, Tribal, and local governments and volunteer organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report","label":"2 Report","identifier":"/us/usc/t16/s8462/b/2","parentIdentifier":"/us/usc/t16/s8462/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8462/b/2/A","parentIdentifier":"/us/usc/t16/s8462/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fb%2F2%2FA","sourceRelease":"119-100","text":"challenges to maintaining or improving the function, cleanliness, and availability of restroom facilities on Federal recreational lands and waters;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8462/b/2/B","parentIdentifier":"/us/usc/t16/s8462/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the current state of restroom facilities on Federal recreational lands and waters and the effect restroom facilities have on visitor experiences; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8462/b/2/C","parentIdentifier":"/us/usc/t16/s8462/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8462%2Fb%2F2%2FC","sourceRelease":"119-100","text":"policy recommendations that suggest innovative new models or partnerships to increase or improve the function, cleanliness, and availability of restroom facilities for persons recreating on Federal recreational lands and waters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
