{"type":"section","nativeType":"section","number":"215a–3","heading":"Mergers and consolidations with subsidiaries and nonbank affiliates","label":"215a–3 Mergers and consolidations with subsidiaries and nonbank affiliates","identifier":"/us/usc/t12/s215a–3","parentIdentifier":"/us/usc/t12/ch2/schXVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs215a%E2%80%933","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t12/s215a–3/a","parentIdentifier":"/us/usc/t12/s215a–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs215a%E2%80%933%2Fa","sourceRelease":"119-100","text":"Upon the approval of the Comptroller, a national bank may merge with one or more of its nonbank subsidiaries or affiliates.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Scope","label":"b Scope","identifier":"/us/usc/t12/s215a–3/b","parentIdentifier":"/us/usc/t12/s215a–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs215a%E2%80%933%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s215a–3/b/1","parentIdentifier":"/us/usc/t12/s215a–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs215a%E2%80%933%2Fb%2F1","sourceRelease":"119-100","text":"to affect the applicability of ; orsection 1828(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s215a–3/b/2","parentIdentifier":"/us/usc/t12/s215a–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs215a%E2%80%933%2Fb%2F2","sourceRelease":"119-100","text":"to grant a national bank any power or authority that is not permissible for a national bank under other applicable provisions of law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Regulations","label":"c Regulations","identifier":"/us/usc/t12/s215a–3/c","parentIdentifier":"/us/usc/t12/s215a–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs215a%E2%80%933%2Fc","sourceRelease":"119-100","text":"The Comptroller shall promulgate regulations to implement this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
