{"type":"section","nativeType":"section","number":"19057","heading":"Food-energy-water research","label":"19057 Food-energy-water research","identifier":"/us/usc/t42/s19057","parentIdentifier":"/us/usc/t42/ch163/schIII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19057","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19057/1","parentIdentifier":"/us/usc/t42/s19057","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19057%2F1","sourceRelease":"119-100","text":"support research to significantly advance our understanding of the food-energy-water system through quantitative and computational modeling, including support for relevant cyberinfrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19057/2","parentIdentifier":"/us/usc/t42/s19057","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19057%2F2","sourceRelease":"119-100","text":"develop real-time, cyber-enabled interfaces that improve understanding of the behavior of food-energy-water systems and increase decision support capability;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19057/3","parentIdentifier":"/us/usc/t42/s19057","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19057%2F3","sourceRelease":"119-100","text":"support research that will lead to innovative solutions to critical food-energy-water system problems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s19057/4","parentIdentifier":"/us/usc/t42/s19057","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19057%2F4","sourceRelease":"119-100","text":"grow the scientific workforce capable of studying and managing the food-energy-water system, through education and other professional development.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
