{"type":"section","nativeType":"section","number":"1423d","heading":"Commission appointments; compensation, travel expenses, and claims","label":"1423d Commission appointments; compensation, travel expenses, and claims","identifier":"/us/usc/t16/s1423d","parentIdentifier":"/us/usc/t16/ch31/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Appointment of United States commissioners","label":"a Appointment of United States commissioners","identifier":"/us/usc/t16/s1423d/a","parentIdentifier":"/us/usc/t16/s1423d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Appointment","label":"1 Appointment","identifier":"/us/usc/t16/s1423d/a/1","parentIdentifier":"/us/usc/t16/s1423d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1423d/a/1/A","parentIdentifier":"/us/usc/t16/s1423d/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1423d/a/1/B","parentIdentifier":"/us/usc/t16/s1423d/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the Secretary of State; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s1423d/a/1/C","parentIdentifier":"/us/usc/t16/s1423d/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F1%2FC","sourceRelease":"119-100","text":"the Alaska Nanuuq Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Qualifications","label":"2 Qualifications","identifier":"/us/usc/t16/s1423d/a/2","parentIdentifier":"/us/usc/t16/s1423d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1423d/a/2/A","parentIdentifier":"/us/usc/t16/s1423d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F2%2FA","sourceRelease":"119-100","text":"1 United States commissioner shall be an official of the Federal Government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1423d/a/2/B","parentIdentifier":"/us/usc/t16/s1423d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F2%2FB","sourceRelease":"119-100","text":"1 United States commissioner shall be a representative of the Native people of Alaska, and, in particular, the Native people for whom polar bears are an integral part of their culture; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s1423d/a/2/C","parentIdentifier":"/us/usc/t16/s1423d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F2%2FC","sourceRelease":"119-100","text":"both commissioners shall be knowledgeable of, or have expertise in, polar bears.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Service and term","label":"3 Service and term","identifier":"/us/usc/t16/s1423d/a/3","parentIdentifier":"/us/usc/t16/s1423d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1423d/a/3/A","parentIdentifier":"/us/usc/t16/s1423d/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F3%2FA","sourceRelease":"119-100","text":"at the pleasure of the President; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1423d/a/3/B","parentIdentifier":"/us/usc/t16/s1423d/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F3%2FB","sourceRelease":"119-100","text":"for an initial 4-year term and such additional terms as the President shall determine.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Vacancies","label":"4 Vacancies","identifier":"/us/usc/t16/s1423d/a/4","parentIdentifier":"/us/usc/t16/s1423d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s1423d/a/4/A","parentIdentifier":"/us/usc/t16/s1423d/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F4%2FA","sourceRelease":"119-100","text":"Any individual appointed to fill a vacancy occurring before the expiration of any term of office of a United States commissioner shall be appointed for the remainder of that term.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Manner","label":"B Manner","identifier":"/us/usc/t16/s1423d/a/4/B","parentIdentifier":"/us/usc/t16/s1423d/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fa%2F4%2FB","sourceRelease":"119-100","text":"Any vacancy on the Commission shall be filled in the same manner as the original appointment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Alternate commissioners","label":"b Alternate commissioners","identifier":"/us/usc/t16/s1423d/b","parentIdentifier":"/us/usc/t16/s1423d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s1423d/b/1","parentIdentifier":"/us/usc/t16/s1423d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary, in consultation with the Secretary of State and the Alaska Nanuuq Commission, shall designate an alternate commissioner for each member of the United States section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Duties","label":"2 Duties","identifier":"/us/usc/t16/s1423d/b/2","parentIdentifier":"/us/usc/t16/s1423d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fb%2F2","sourceRelease":"119-100","text":"In the absence of a United States commissioner, an alternate commissioner may exercise all functions of the United States commissioner at any meetings of the Commission or of the United States section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Reappointment","label":"3 Reappointment","identifier":"/us/usc/t16/s1423d/b/3","parentIdentifier":"/us/usc/t16/s1423d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1423d/b/3/A","parentIdentifier":"/us/usc/t16/s1423d/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fb%2F3%2FA","sourceRelease":"119-100","text":"shall be eligible for reappointment by the President; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1423d/b/3/B","parentIdentifier":"/us/usc/t16/s1423d/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fb%2F3%2FB","sourceRelease":"119-100","text":"may attend all meetings of the United States section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duties","label":"c Duties","identifier":"/us/usc/t16/s1423d/c","parentIdentifier":"/us/usc/t16/s1423d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fc","sourceRelease":"119-100","text":"The members of the United States section may carry out the functions and responsibilities described in article 8 of the Agreement in accordance with this subchapter and the Agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Compensation and expenses","label":"d Compensation and expenses","identifier":"/us/usc/t16/s1423d/d","parentIdentifier":"/us/usc/t16/s1423d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Compensation","label":"1 Compensation","identifier":"/us/usc/t16/s1423d/d/1","parentIdentifier":"/us/usc/t16/s1423d/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fd%2F1","sourceRelease":"119-100","text":"A member of the United States section shall serve without compensation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Travel expenses","label":"2 Travel expenses","identifier":"/us/usc/t16/s1423d/d/2","parentIdentifier":"/us/usc/t16/s1423d/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fd%2F2","sourceRelease":"119-100","text":"A member of the United States section shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for an employee of an agency under subchapter I of chapter 57 of title 5 while away from the home or regular place of business of the member in the performance of the duties of the United States-Russia Polar Bear Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Agency designation","label":"e Agency designation","identifier":"/us/usc/t16/s1423d/e","parentIdentifier":"/us/usc/t16/s1423d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1423d%2Fe","sourceRelease":"119-100","text":"The United States section shall, for the purpose of title 28 relating to claims against the United States and tort claims procedure, be considered to be a Federal agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
