"Description of activities","label":"B Description of activities","identifier":"/us/usc/t16/s6591e/a/1/B","parentIdentifier":"/us/usc/t16/s6591e/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s6591e/a/1/B/i","parentIdentifier":"/us/usc/t16/s6591e/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"manual cutting and removal of juniper trees, pinyon pine trees, other associated conifers, or other nonnative or invasive vegetation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s6591e/a/1/B/ii","parentIdentifier":"/us/usc/t16/s6591e/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"mechanical mastication, cutting, or mowing, mechanical piling and burning, chaining, broadcast burning, or yarding;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s6591e/a/1/B/iii","parentIdentifier":"/us/usc/t16/s6591e/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"removal of cheat grass, medusa head rye, or other nonnative, invasive vegetation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s6591e/a/1/B/iv","parentIdentifier":"/us/usc/t16/s6591e/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"collection and seeding or planting of native vegetation using a manual, mechanical, or aerial method;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t16/s6591e/a/1/B/v","parentIdentifier":"/us/usc/t16/s6591e/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FB%2Fv","sourceRelease":"119-100","text":"seeding of nonnative, noninvasive, ruderal vegetation only for the purpose of emergency stabilization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t16/s6591e/a/1/B/vi","parentIdentifier":"/us/usc/t16/s6591e/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FB%2Fvi","sourceRelease":"119-100","text":"targeted use of an herbicide, subject to the condition that the use shall be in accordance with applicable legal requirements, Federal agency procedures, and land use plans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t16/s6591e/a/1/B/vii","parentIdentifier":"/us/usc/t16/s6591e/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FB%2Fvii","sourceRelease":"119-100","text":"targeted livestock grazing to mitigate hazardous fuels and control noxious and invasive weeds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t16/s6591e/a/1/B/viii","parentIdentifier":"/us/usc/t16/s6591e/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FB%2Fviii","sourceRelease":"119-100","text":"temporary removal of wild horses or burros in the area in which the activity is being carried out to ensure treatment objectives are met;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ix","heading":null,"label":"ix","identifier":"/us/usc/t16/s6591e/a/1/B/ix","parentIdentifier":"/us/usc/t16/s6591e/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FB%2Fix","sourceRelease":"119-100","text":"in coordination with the affected permit holder, modification or adjustment of permissible usage under an annual plan of use of a grazing permit issued by the Secretary concerned to achieve restoration treatment objectives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"x","heading":null,"label":"x","identifier":"/us/usc/t16/s6591e/a/1/B/x","parentIdentifier":"/us/usc/t16/s6591e/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FB%2Fx","sourceRelease":"119-100","text":"installation of new, or modification of existing, fencing or water sources intended to control use or improve wildlife habitat; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xi","heading":null,"label":"xi","identifier":"/us/usc/t16/s6591e/a/1/B/xi","parentIdentifier":"/us/usc/t16/s6591e/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FB%2Fxi","sourceRelease":"119-100","text":"necessary maintenance of, repairs to, rehabilitation of, or reconstruction of an existing permanent road or construction of temporary roads to accomplish the activities described in this subparagraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Exclusions","label":"C Exclusions","identifier":"/us/usc/t16/s6591e/a/1/C","parentIdentifier":"/us/usc/t16/s6591e/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s6591e/a/1/C/i","parentIdentifier":"/us/usc/t16/s6591e/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FC%2Fi","sourceRelease":"119-100","text":"any activity conducted in a wilderness area or wilderness study area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s6591e/a/1/C/ii","parentIdentifier":"/us/usc/t16/s6591e/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FC%2Fii","sourceRelease":"119-100","text":"any activity for the construction of a permanent road or permanent trail;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s6591e/a/1/C/iii","parentIdentifier":"/us/usc/t16/s6591e/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"any activity conducted on Federal land on which, by Act of Congress or Presidential proclamation, the removal of vegetation is restricted or prohibited;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s6591e/a/1/C/iv","parentIdentifier":"/us/usc/t16/s6591e/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FC%2Fiv","sourceRelease":"119-100","text":"any activity conducted in an area in which activities under subparagraph (B) would be inconsistent with the applicable land and resource management plan; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t16/s6591e/a/1/C/v","parentIdentifier":"/us/usc/t16/s6591e/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FC%2Fv","sourceRelease":"119-100","text":"any activity conducted in an inventoried roadless area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Secretary concerned","label":"2 Secretary concerned","identifier":"/us/usc/t16/s6591e/a/2","parentIdentifier":"/us/usc/t16/s6591e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6591e/a/2/A","parentIdentifier":"/us/usc/t16/s6591e/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the Secretary of Agriculture, with respect to National Forest System land; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6591e/a/2/B","parentIdentifier":"/us/usc/t16/s6591e/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the Secretary of the Interior, with respect to public land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Temporary road","label":"3 Temporary road","identifier":"/us/usc/t16/s6591e/a/3","parentIdentifier":"/us/usc/t16/s6591e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6591e/a/3/A","parentIdentifier":"/us/usc/t16/s6591e/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s6591e/a/3/A/i","parentIdentifier":"/us/usc/t16/s6591e/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F3%2FA%2Fi","sourceRelease":"119-100","text":"by a contract, permit, lease, other written authorization; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s6591e/a/3/A/ii","parentIdentifier":"/us/usc/t16/s6591e/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F3%2FA%2Fii","sourceRelease":"119-100","text":"pursuant to an emergency operation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6591e/a/3/B","parentIdentifier":"/us/usc/t16/s6591e/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F3%2FB","sourceRelease":"119-100","text":"not intended to be part of the permanent transportation system of a Federal department or agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6591e/a/3/C","parentIdentifier":"/us/usc/t16/s6591e/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F3%2FC","sourceRelease":"119-100","text":"not necessary for long-term resource management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s6591e/a/3/D","parentIdentifier":"/us/usc/t16/s6591e/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F3%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s6591e/a/3/D/i","parentIdentifier":"/us/usc/t16/s6591e/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F3%2FD%2Fi","sourceRelease":"119-100","text":"safety;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s6591e/a/3/D/ii","parentIdentifier":"/us/usc/t16/s6591e/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F3%2FD%2Fii","sourceRelease":"119-100","text":"the cost of transportation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s6591e/a/3/D/iii","parentIdentifier":"/us/usc/t16/s6591e/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F3%2FD%2Fiii","sourceRelease":"119-100","text":"impacts to land and resources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s6591e/a/3/E","parentIdentifier":"/us/usc/t16/s6591e/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F3%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s6591e/a/3/E/i","parentIdentifier":"/us/usc/t16/s6591e/a/3/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F3%2FE%2Fi","sourceRelease":"119-100","text":"erosion; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s6591e/a/3/E/ii","parentIdentifier":"/us/usc/t16/s6591e/a/3/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F3%2FE%2Fii","sourceRelease":"119-100","text":"the introduction or spread of invasive species.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Categorical exclusion","label":"b Categorical exclusion","identifier":"/us/usc/t16/s6591e/b","parentIdentifier":"/us/usc/t16/s6591e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s6591e/b/1","parentIdentifier":"/us/usc/t16/s6591e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fb%2F1","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary concerned shall develop a categorical exclusion (as defined in section 1508.4 of title 40, Code of Federal Regulations (or a successor regulation)) for covered vegetation management activities carried out to protect, restore, or improve habitat for greater sage-grouse or mule deer.December 20, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Administration","label":"2 Administration","identifier":"/us/usc/t16/s6591e/b/2","parentIdentifier":"/us/usc/t16/s6591e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6591e/b/2/A","parentIdentifier":"/us/usc/t16/s6591e/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fb%2F2%2FA","sourceRelease":"119-100","text":"comply with the National Environmental Policy Act of 1969 ( et seq.);42 U.S.C. 4321","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6591e/b/2/B","parentIdentifier":"/us/usc/t16/s6591e/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fb%2F2%2FB","sourceRelease":"119-100","text":"with respect to National Forest System land, apply the extraordinary circumstances procedures under section 220.6 of title 36, Code of Federal Regulations (or successor regulations), in determining whether to use the categorical exclusion;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6591e/b/2/C","parentIdentifier":"/us/usc/t16/s6591e/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fb%2F2%2FC","sourceRelease":"119-100","text":"with respect to public land, apply the extraordinary circumstances procedures under section 46.215 of title 43, Code of Federal Regulations (or successor regulations), in determining whether to use the categorical exclusion; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s6591e/b/2/D","parentIdentifier":"/us/usc/t16/s6591e/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fb%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s6591e/b/2/D/i","parentIdentifier":"/us/usc/t16/s6591e/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fb%2F2%2FD%2Fi","sourceRelease":"119-100","text":"the relative efficacy of landscape-scale habitat projects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s6591e/b/2/D/ii","parentIdentifier":"/us/usc/t16/s6591e/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fb%2F2%2FD%2Fii","sourceRelease":"119-100","text":"the likelihood of continued declines in the populations of greater sage-grouse and mule deer in the absence of landscape-scale vegetation management; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s6591e/b/2/D/iii","parentIdentifier":"/us/usc/t16/s6591e/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fb%2F2%2FD%2Fiii","sourceRelease":"119-100","text":"the need for habitat restoration activities after wildfire or other natural disturbances.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Implementation of covered vegetative management activities within the range of greater sage-grouse and mule deer","label":"c Implementation of covered vegetative management activities within the range of greater sage-grouse and mule deer","identifier":"/us/usc/t16/s6591e/c","parentIdentifier":"/us/usc/t16/s6591e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fc","sourceRelease":"119-100","text":"If the categorical exclusion developed under subsection (b) is used to implement a covered vegetative management activity in an area within the range of both greater sage-grouse and mule deer, the covered vegetative management activity shall protect, restore, or improve habitat concurrently for both greater sage-grouse and mule deer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Long-term monitoring and maintenance","label":"d Long-term monitoring and maintenance","identifier":"/us/usc/t16/s6591e/d","parentIdentifier":"/us/usc/t16/s6591e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fd","sourceRelease":"119-100","text":"Before commencing any covered vegetation management activity that is covered by the categorical exclusion under subsection (b), the Secretary concerned shall develop a long-term monitoring and maintenance plan, covering at least the 20-year period beginning on the date of commencement, to ensure that management of the treated area does not degrade the habitat gains secured by the covered vegetation management activity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Disposal of vegetative material","label":"e Disposal of vegetative material","identifier":"/us/usc/t16/s6591e/e","parentIdentifier":"/us/usc/t16/s6591e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s6591e/e/1","parentIdentifier":"/us/usc/t16/s6591e/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6591e/e/1/A","parentIdentifier":"/us/usc/t16/s6591e/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fe%2F1%2FA","sourceRelease":"119-100","text":"fuel wood; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6591e/e/1/B","parentIdentifier":"/us/usc/t16/s6591e/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fe%2F1%2FB","sourceRelease":"119-100","text":"other products; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6591e/e/2","parentIdentifier":"/us/usc/t16/s6591e/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fe%2F2","sourceRelease":"119-100","text":"piled or burned, or both.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Treatment for temporary roads","label":"f Treatment for temporary roads","identifier":"/us/usc/t16/s6591e/f","parentIdentifier":"/us/usc/t16/s6591e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","native