{"type":"section","nativeType":"section","number":"9141","heading":"Air transportation payroll support program extension","label":"9141 Air transportation payroll support program extension","identifier":"/us/usc/t15/s9141","parentIdentifier":"/us/usc/t15/ch116/schIII/ptG","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the American Rescue Plan Act of 2021, and not as part of the CARES Act which in part comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t15/s9141/a","parentIdentifier":"/us/usc/t15/s9141","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9141/a/1","parentIdentifier":"/us/usc/t15/s9141/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F1","sourceRelease":"119-100","text":"the term “catering functions” means preparation, assembly, or both, of food, beverages, provisions and related supplies for delivery, and the delivery of such items, directly to aircraft or to a location on or near airport property for subsequent delivery to aircraft;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9141/a/2","parentIdentifier":"/us/usc/t15/s9141/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9141/a/2/A","parentIdentifier":"/us/usc/t15/s9141/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9141/a/2/A/i","parentIdentifier":"/us/usc/t15/s9141/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"catering functions; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9141/a/2/A/ii","parentIdentifier":"/us/usc/t15/s9141/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"functions on the property of an airport that are directly related to the air transportation of persons, property, or mail, including the loading and unloading of property on aircraft, assistance to passengers under part 382 of title 14, Code of Federal Regulations, security, airport ticketing and check-in functions, ground-handling of aircraft, or aircraft cleaning and sanitization functions and waste removal; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9141/a/2/B","parentIdentifier":"/us/usc/t15/s9141/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F2%2FB","sourceRelease":"119-100","text":"a subcontractor that performs such functions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s9141/a/3","parentIdentifier":"/us/usc/t15/s9141/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F3","sourceRelease":"119-100","text":"the term “employee” means an individual, other than a corporate officer, who is employed by an air carrier or a contractor;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s9141/a/4","parentIdentifier":"/us/usc/t15/s9141/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9141/a/4/A","parentIdentifier":"/us/usc/t15/s9141/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FA","sourceRelease":"119-100","text":"received financial assistance pursuant ;1section 9092(a)(1) of this titleSo in original. Probably should be followed by “to”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9141/a/4/B","parentIdentifier":"/us/usc/t15/s9141/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FB","sourceRelease":"119-100","text":"provides air transportation as of ;March 31, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9141/a/4/C","parentIdentifier":"/us/usc/t15/s9141/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FC","sourceRelease":"119-100","text":"has not conducted involuntary furloughs or reduced pay rates or benefits between , and the date on which the air carrier makes a certification to the Secretary pursuant to subparagraph (D); andMarch 31, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s9141/a/4/D","parentIdentifier":"/us/usc/t15/s9141/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9141/a/4/D/i","parentIdentifier":"/us/usc/t15/s9141/a/4/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FD%2Fi","sourceRelease":"119-100","text":"refrain from conducting involuntary furloughs or reducing pay rates or benefits until , or the date on which assistance provided under this section is exhausted, whichever is later;September 30, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9141/a/4/D/ii","parentIdentifier":"/us/usc/t15/s9141/a/4/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FD%2Fii","sourceRelease":"119-100","text":"refrain from purchasing an equity security of the air carrier or the parent company of the air carrier that is listed on a national securities exchange through ;September 30, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s9141/a/4/D/iii","parentIdentifier":"/us/usc/t15/s9141/a/4/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FD%2Fiii","sourceRelease":"119-100","text":"refrain from paying dividends, or making other capital distributions, with respect to common stock (or equivalent interest) of such air carrier through ;September 30, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t15/s9141/a/4/D/iv","parentIdentifier":"/us/usc/t15/s9141/a/4/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FD%2Fiv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s9141/a/4/D/iv/I","parentIdentifier":"/us/usc/t15/s9141/a/4/D/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FD%2Fiv%2FI","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t15/s9141/a/4/D/iv/I/aa","parentIdentifier":"/us/usc/t15/s9141/a/4/D/iv/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FD%2Fiv%2FI%2Faa","sourceRelease":"119-100","text":"total compensation that exceeds, during any 12 consecutive months of such 2-year period, the total compensation received by the officer or employee from the air carrier in calendar year 2019; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t15/s9141/a/4/D/iv/I/bb","parentIdentifier":"/us/usc/t15/s9141/a/4/D/iv/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FD%2Fiv%2FI%2Fbb","sourceRelease":"119-100","text":"severance pay or other benefits upon termination of employment with the air carrier which exceeds twice the maximum total compensation received by the officer or employee from the air carrier in calendar year 2019; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t15/s9141/a/4/D/iv/II","parentIdentifier":"/us/usc/t15/s9141/a/4/D/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FD%2Fiv%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t15/s9141/a/4/D/iv/II/aa","parentIdentifier":"/us/usc/t15/s9141/a/4/D/iv/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FD%2Fiv%2FII%2Faa","sourceRelease":"119-100","text":"$3,000,000; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t15/s9141/a/4/D/iv/II/bb","parentIdentifier":"/us/usc/t15/s9141/a/4/D/iv/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F4%2FD%2Fiv%2FII%2Fbb","sourceRelease":"119-100","text":"50 percent of the excess over $3,000,000 of the total compensation received by the officer or employee from the air carrier in calendar year 2019.2So in original. The period probably should be a semicolon.2","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s9141/a/5","parentIdentifier":"/us/usc/t15/s9141/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9141/a/5/A","parentIdentifier":"/us/usc/t15/s9141/a/5","so