{"type":"section","nativeType":"section","number":"2924","heading":"Child development center employees","label":"2924 Child development center employees","identifier":"/us/usc/t14/s2924","parentIdentifier":"/us/usc/t14/stII/ch29/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2018— renumbered as this section.Pub. L. 115–282section 554 of this title"],"amendments":["Amendments2018— renumbered as this section.Pub. L. 115–282section 554 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Training.—","label":"a Training.—","identifier":"/us/usc/t14/s2924/a","parentIdentifier":"/us/usc/t14/s2924","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t14/s2924/a/1","parentIdentifier":"/us/usc/t14/s2924/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fa%2F1","sourceRelease":"119-100","text":"The Commandant shall establish a training program for Coast Guard child development center employees and satisfactory completion of the training program shall be a condition of employment for each employee of a Coast Guard child development center.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Timing for new hires","label":"2 .—Timing for new hires","identifier":"/us/usc/t14/s2924/a/2","parentIdentifier":"/us/usc/t14/s2924/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fa%2F2","sourceRelease":"119-100","text":"The Commandant shall require each employee of a Coast Guard child development center to complete the training program established under paragraph (1) not later than 6 months after the date on which the employee is hired.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Minimum requirements","label":"3 .—Minimum requirements","identifier":"/us/usc/t14/s2924/a/3","parentIdentifier":"/us/usc/t14/s2924/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t14/s2924/a/3/A","parentIdentifier":"/us/usc/t14/s2924/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fa%2F3%2FA","sourceRelease":"119-100","text":"early childhood development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t14/s2924/a/3/B","parentIdentifier":"/us/usc/t14/s2924/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fa%2F3%2FB","sourceRelease":"119-100","text":"activities and disciplinary techniques appropriate to children of different ages;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t14/s2924/a/3/C","parentIdentifier":"/us/usc/t14/s2924/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fa%2F3%2FC","sourceRelease":"119-100","text":"child abuse and neglect prevention and detection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t14/s2924/a/3/D","parentIdentifier":"/us/usc/t14/s2924/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fa%2F3%2FD","sourceRelease":"119-100","text":"cardiopulmonary resuscitation and other emergency medical procedures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Use of department of defense programs","label":"4 .—Use of department of defense programs","identifier":"/us/usc/t14/s2924/a/4","parentIdentifier":"/us/usc/t14/s2924/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fa%2F4","sourceRelease":"119-100","text":"The Commandant may use Department of Defense training programs, on a reimbursable or nonreimbursable basis, for purposes of this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Training and Curriculum Specialists.—","label":"b Training and Curriculum Specialists.—","identifier":"/us/usc/t14/s2924/b","parentIdentifier":"/us/usc/t14/s2924","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Specialist required","label":"1 .—Specialist required","identifier":"/us/usc/t14/s2924/b/1","parentIdentifier":"/us/usc/t14/s2924/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fb%2F1","sourceRelease":"119-100","text":"The Commandant shall require that at least 1 employee at each Coast Guard child development center be a specialist in training and curriculum development with appropriate credentials and experience.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Duties","label":"2 .—Duties","identifier":"/us/usc/t14/s2924/b/2","parentIdentifier":"/us/usc/t14/s2924/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t14/s2924/b/2/A","parentIdentifier":"/us/usc/t14/s2924/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fb%2F2%2FA","sourceRelease":"119-100","text":"special teaching activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t14/s2924/b/2/B","parentIdentifier":"/us/usc/t14/s2924/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fb%2F2%2FB","sourceRelease":"119-100","text":"daily oversight and instruction of other child care employees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t14/s2924/b/2/C","parentIdentifier":"/us/usc/t14/s2924/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fb%2F2%2FC","sourceRelease":"119-100","text":"daily assistance in the preparation of lesson plans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t14/s2924/b/2/D","parentIdentifier":"/us/usc/t14/s2924/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fb%2F2%2FD","sourceRelease":"119-100","text":"assisting with child abuse and neglect prevention and detection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t14/s2924/b/2/E","parentIdentifier":"/us/usc/t14/s2924/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fb%2F2%2FE","sourceRelease":"119-100","text":"advising the director of the center on the performance of the other child care employees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Competitive service","label":"3 .—Competitive service","identifier":"/us/usc/t14/s2924/b/3","parentIdentifier":"/us/usc/t14/s2924/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs2924%2Fb%2F3","sourceRelease":"119-100","text":"Each specialist described in paragraph (1) shall be an employee in a competitive service position.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
