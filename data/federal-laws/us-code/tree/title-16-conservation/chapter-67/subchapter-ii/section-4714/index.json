{"type":"section","nativeType":"section","number":"4714","heading":"Ballast water management demonstration program","label":"4714 Ballast water management demonstration program","identifier":"/us/usc/t16/s4714","parentIdentifier":"/us/usc/t16/ch67/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"“Technologies and practices” defined","label":"a “Technologies and practices” defined","identifier":"/us/usc/t16/s4714/a","parentIdentifier":"/us/usc/t16/s4714","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s4714/a/1","parentIdentifier":"/us/usc/t16/s4714/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s4714/a/1/A","parentIdentifier":"/us/usc/t16/s4714/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fa%2F1%2FA","sourceRelease":"119-100","text":"on existing vessels or incorporated in new vessel designs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s4714/a/1/B","parentIdentifier":"/us/usc/t16/s4714/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fa%2F1%2FB","sourceRelease":"119-100","text":"on existing land-based ballast water treatment facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s4714/a/2","parentIdentifier":"/us/usc/t16/s4714/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fa%2F2","sourceRelease":"119-100","text":"may be designed into new water treatment facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s4714/a/3","parentIdentifier":"/us/usc/t16/s4714/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fa%2F3","sourceRelease":"119-100","text":"are operationally practical;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s4714/a/4","parentIdentifier":"/us/usc/t16/s4714/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fa%2F4","sourceRelease":"119-100","text":"are safe for a vessel and crew;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s4714/a/5","parentIdentifier":"/us/usc/t16/s4714/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fa%2F5","sourceRelease":"119-100","text":"are environmentally sound;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s4714/a/6","parentIdentifier":"/us/usc/t16/s4714/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fa%2F6","sourceRelease":"119-100","text":"are cost-effective;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t16/s4714/a/7","parentIdentifier":"/us/usc/t16/s4714/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fa%2F7","sourceRelease":"119-100","text":"a vessel operator is capable of monitoring; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t16/s4714/a/8","parentIdentifier":"/us/usc/t16/s4714/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fa%2F8","sourceRelease":"119-100","text":"are effective against a broad range of aquatic nuisance species.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Demonstration program","label":"b Demonstration program","identifier":"/us/usc/t16/s4714/b","parentIdentifier":"/us/usc/t16/s4714","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s4714/b/1","parentIdentifier":"/us/usc/t16/s4714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F1","sourceRelease":"119-100","text":"During the 18-month period beginning on the date that funds are made available by appropriations pursuant to , the Secretary of the Interior and the Secretary of Commerce, with the concurrence of and in cooperation with the Secretary, shall conduct a ballast water management demonstration program to demonstrate technologies and practices to prevent aquatic nonindigenous species from being introduced into and spread through ballast water in the Great Lakes and other waters of the United States.section 4741(e) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Location","label":"2 Location","identifier":"/us/usc/t16/s4714/b/2","parentIdentifier":"/us/usc/t16/s4714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F2","sourceRelease":"119-100","text":"The installation and construction of the technologies and practices used in the demonstration program conducted under this subsection shall be performed in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Vessel selection","label":"3 Vessel selection","identifier":"/us/usc/t16/s4714/b/3","parentIdentifier":"/us/usc/t16/s4714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s4714/b/3/A","parentIdentifier":"/us/usc/t16/s4714/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s4714/b/3/A/i","parentIdentifier":"/us/usc/t16/s4714/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3%2FA%2Fi","sourceRelease":"119-100","text":"are approved by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s4714/b/3/A/ii","parentIdentifier":"/us/usc/t16/s4714/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3%2FA%2Fii","sourceRelease":"119-100","text":"have ballast water systems conducive to testing aboard-vessel or land-based technologies and practices applicable to a significant number of merchant vessels; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s4714/b/3/A/iii","parentIdentifier":"/us/usc/t16/s4714/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s4714/b/3/A/iii/I","parentIdentifier":"/us/usc/t16/s4714/b/3/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"publicly or privately owned; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s4714/b/3/A/iii/II","parentIdentifier":"/us/usc/t16/s4714/b/3/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"in active use for trade or other cargo shipment purposes during the demonstration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s4714/b/3/B","parentIdentifier":"/us/usc/t16/s4714/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s4714/b/3/B/i","parentIdentifier":"/us/usc/t16/s4714/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"first, to vessels documented under chapter 121 of title 46;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s4714/b/3/B/ii","parentIdentifier":"/us/usc/t16/s4714/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"second, to vessels that are a majority owned by citizens of the United States, as determined by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s4714/b/3/B/iii","parentIdentifier":"/us/usc/t16/s4714/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"third, to any other vessels that regularly call on ports in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s4714/b/3/C","parentIdentifier":"/us/usc/t16/s4714/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s4714/b/3/C/i","parentIdentifier":"/us/usc/t16/s4714/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3%2FC%2Fi","sourceRelease":"119-100","text":"call on ports in the United States and on the Great Lakes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s4714/b/3/C/ii","parentIdentifier":"/us/usc/t16/s4714/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F3%2FC%2Fii","sourceRelease":"119-100","text":"are operated along major coasts of the United States and inland waterways, including the San Francisco Bay and Chesapeake Bay.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Selection of technologies and practices","label":"4 Selection of technologies and practices","identifier":"/us/usc/t16/s4714/b/4","parentIdentifier":"/us/usc/t16/s4714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F4","sourceRelease":"119-100","text":"In selecting technologies and practices for demonstration under this subsection, the Secretary of the Interior and the Secretary of Commerce shall give priority consideration to technologies and practices identified as promising by the National Research Council Marine Board of the National Academy of Sciences in its report on ships’ ballast water operations issued in July 1996.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Report","label":"5 Report","identifier":"/us/usc/t16/s4714/b/5","parentIdentifier":"/us/usc/t16/s4714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fb%2F5","sourceRelease":"119-100","text":"Not later than 3 years after , the Secretary of the Interior and the Secretary of Commerce shall prepare and submit a report to the Congress on the demonstration program conducted pursuant to this section. The report shall include findings and recommendations of the Secretary of the Interior and the Secretary of Commerce concerning technologies and practices.October 26, 1996","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorities; consultation and cooperation with International Maritime Organization and Task Force","label":"c Authorities; consultation and cooperation with International Maritime Organization and Task Force","identifier":"/us/usc/t16/s4714/c","parentIdentifier":"/us/usc/t16/s4714","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Authorities","label":"1 Authorities","identifier":"/us/usc/t16/s4714/c/1","parentIdentifier":"/us/usc/t16/s4714/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s4714/c/1/A","parentIdentifier":"/us/usc/t16/s4714/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fc%2F1%2FA","sourceRelease":"119-100","text":"enter into cooperative agreements with appropriate officials of other agencies of the Federal Government, agencies of States and political subdivisions thereof, and private entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s4714/c/1/B","parentIdentifier":"/us/usc/t16/s4714/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fc%2F1%2FB","sourceRelease":"119-100","text":"accept funds, facilities, equipment, or personnel from other Federal agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s4714/c/1/C","parentIdentifier":"/us/usc/t16/s4714/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fc%2F1%2FC","sourceRelease":"119-100","text":"accept donations of property and services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Consultation and cooperation","label":"2 Consultation and cooperation","identifier":"/us/usc/t16/s4714/c/2","parentIdentifier":"/us/usc/t16/s4714/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4714%2Fc%2F2","sourceRelease":"119-100","text":"The Secretary of the Interior shall consult and cooperate with the International Maritime Organization and the Task Force in carrying out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
