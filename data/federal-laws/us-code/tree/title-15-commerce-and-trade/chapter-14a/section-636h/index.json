ov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs636h%2Fb%2F1","sourceRelease":"119-100","text":"creating, maintaining, and implementing the comprehensive disaster response plan of the Administration described in ;section 636g of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s636h/b/2","parentIdentifier":"/us/usc/t15/s636h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs636h%2Fb%2F2","sourceRelease":"119-100","text":"ensuring there are in-service and pre-service training procedures for the disaster response staff of the Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s636h/b/3","parentIdentifier":"/us/usc/t15/s636h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs636h%2Fb%2F3","sourceRelease":"119-100","text":"coordinating and directing the training exercises of the Administration relating to disasters, including disaster simulation exercises and disaster exercises coordinated with other government departments and agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s636h/b/4","parentIdentifier":"/us/usc/t15/s636h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs636h%2Fb%2F4","sourceRelease":"119-100","text":"other responsibilities relevant to disaster planning and readiness, as determined by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Coordination","label":"c Coordination","identifier":"/us/usc/t15/s636h/c","parentIdentifier":"/us/usc/t15/s636h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs636h%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s636h/c/1","parentIdentifier":"/us/usc/t15/s636h/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs636h%2Fc%2F1","sourceRelease":"119-100","text":"the Office of Disaster Assistance of the Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s636h/c/2","parentIdentifier":"/us/usc/t15/s636h/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs636h%2Fc%2F2","sourceRelease":"119-100","text":"the Administrator of the Federal Emergency Management Agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s636h/c/3","parentIdentifier":"/us/usc/t15/s636h/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs636h%2Fc%2F3","sourceRelease":"119-100","text":"other Federal, State, and local disaster planning offices, as necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Resources","label":"d Resources","identifier":"/us/usc/t15/s636h/d","parentIdentifier":"/us/usc/t15/s636h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs636h%2Fd","sourceRelease":"119-100","text":"The Administrator shall ensure that the individual assigned the disaster planning function of the Administration has adequate resources to carry out the duties under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e