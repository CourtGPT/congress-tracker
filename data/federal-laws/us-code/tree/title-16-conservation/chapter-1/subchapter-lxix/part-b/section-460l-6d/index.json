bparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s460l–6d/a/3/A","parentIdentifier":"/us/usc/t16/s460l–6d/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F3%2FA","sourceRelease":"119-100","text":"The Secretary concerned shall establish a de minimis use authorization for certain filming or still photography activities that meets the requirements described in subparagraph (F).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Policy","label":"B Policy","identifier":"/us/usc/t16/s460l–6d/a/3/B","parentIdentifier":"/us/usc/t16/s460l–6d/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460l–6d/a/3/B/i","parentIdentifier":"/us/usc/t16/s460l–6d/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F3%2FB%2Fi","sourceRelease":"119-100","text":"may require a de minimis use authorization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460l–6d/a/3/B/ii","parentIdentifier":"/us/usc/t16/s460l–6d/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936d%2Fa%2F3%2FB%2Fii","sourceRelease":"119-100","text":"shall not require a permit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"No fee","label":"C No fee","identifier":"/us/usc/t16/s460l–6d/a/3/C","parentIdentifier":"/us/usc/t16/s460l–6d/a/3","sourceUrl":"ht