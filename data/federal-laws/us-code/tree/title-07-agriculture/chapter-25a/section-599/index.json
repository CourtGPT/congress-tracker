{"type":"section","nativeType":"section","number":"599","heading":"Definitions","label":"599 Definitions","identifier":"/us/usc/t7/s599","parentIdentifier":"/us/usc/t7/ch25A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs599","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s599/1","parentIdentifier":"/us/usc/t7/s599","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs599%2F1","sourceRelease":"119-100","text":"The term “person” includes individuals, partnerships, corporations, and associations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s599/2","parentIdentifier":"/us/usc/t7/s599","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs599%2F2","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Agriculture.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s599/3","parentIdentifier":"/us/usc/t7/s599","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs599%2F3","sourceRelease":"119-100","text":"Except as provided herein, the term “foreign commerce” means commerce between any State, or the District of Columbia, and any place outside of the United States or its possessions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s599/4","parentIdentifier":"/us/usc/t7/s599","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs599%2F4","sourceRelease":"119-100","text":"The term “grapes” means vinifera species table grapes, European type, whether or not they have been in storage.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s599/5","parentIdentifier":"/us/usc/t7/s599","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs599%2F5","sourceRelease":"119-100","text":"The term “plums” means both European and Japanese type, whether or not they have been in storage, but does not mean Italian-type prunes, nor damson-type plums.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
