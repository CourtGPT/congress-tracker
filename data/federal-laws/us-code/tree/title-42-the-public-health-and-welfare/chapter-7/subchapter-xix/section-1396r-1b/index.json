ns","identifier":"/us/usc/t42/s1396r–1b/b","parentIdentifier":"/us/usc/t42/s1396r–1b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Presumptive eligibility period","label":"1 Presumptive eligibility period","identifier":"/us/usc/t42/s1396r–1b/b/1","parentIdentifier":"/us/usc/t42/s1396r–1b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s1396r–1b/b/1/A","parentIdentifier":"/us/usc/t42/s1396r–1b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fb%2F1%2FA","sourceRelease":"119-100","text":"begins with the date on which a qualified entity determines, on the basis of preliminary information, that the individual is described in ; andsection 1396a(aa) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s1396r–1b/b/1/B","parentIdentifier":"/us/usc/t42/s1396r–1b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s1396r–1b/b/1/B/i","parentIdentifier":"/us/usc/t42/s1396r–1b/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the day on which a determination is made with respect to the eligibility of such individual for services under the State plan; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s1396r–1b/b/1/B/ii","parentIdentifier":"/us/usc/t42/s1396r–1b/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"in the case of such an individual who does not file an application by the last day of the month following the month during which the entity makes the determination referred to in subparagraph (A), such last day.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Qualified entity","label":"2 Qualified entity","identifier":"/us/usc/t42/s1396r–1b/b/2","parentIdentifier":"/us/usc/t42/s1396r–1b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s1396r–1b/b/2/A","parentIdentifier":"/us/usc/t42/s1396r–1b/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s1396r–1b/b/2/A/i","parentIdentifier":"/us/usc/t42/s1396r–1b/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"is eligible for payments under a State plan approved under this subchapter; and","notes":[],"amendments":[],"effectiveDate":nu