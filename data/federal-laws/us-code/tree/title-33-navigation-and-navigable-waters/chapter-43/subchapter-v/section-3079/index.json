{"type":"section","nativeType":"section","number":"3079","heading":"Student pre-commissioning education assistance program","label":"3079 Student pre-commissioning education assistance program","identifier":"/us/usc/t33/s3079","parentIdentifier":"/us/usc/t33/ch43/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authority to provide financial assistance","label":"a Authority to provide financial assistance","identifier":"/us/usc/t33/s3079/a","parentIdentifier":"/us/usc/t33/s3079","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s3079/a/1","parentIdentifier":"/us/usc/t33/s3079/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fa%2F1","sourceRelease":"119-100","text":"a baccalaureate degree in not more than five academic years; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s3079/a/2","parentIdentifier":"/us/usc/t33/s3079/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fa%2F2","sourceRelease":"119-100","text":"a postbaccalaureate degree.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Eligible persons","label":"b Eligible persons","identifier":"/us/usc/t33/s3079/b","parentIdentifier":"/us/usc/t33/s3079","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s3079/b/1","parentIdentifier":"/us/usc/t33/s3079/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s3079/b/1/A","parentIdentifier":"/us/usc/t33/s3079/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fb%2F1%2FA","sourceRelease":"119-100","text":"is enrolled on a full-time basis in a program of education referred to in subsection (a) at any educational institution described in such subsection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s3079/b/1/B","parentIdentifier":"/us/usc/t33/s3079/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fb%2F1%2FB","sourceRelease":"119-100","text":"meets all of the requirements for acceptance into the commissioned officer corps of the Administration except for the completion of a baccalaureate degree; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s3079/b/1/C","parentIdentifier":"/us/usc/t33/s3079/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fb%2F1%2FC","sourceRelease":"119-100","text":"enters into a written agreement with the Secretary described in paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Agreement","label":"2 Agreement","identifier":"/us/usc/t33/s3079/b/2","parentIdentifier":"/us/usc/t33/s3079/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s3079/b/2/A","parentIdentifier":"/us/usc/t33/s3079/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fb%2F2%2FA","sourceRelease":"119-100","text":"agrees to accept an appointment as an officer, if tendered; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s3079/b/2/B","parentIdentifier":"/us/usc/t33/s3079/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s3079/b/2/B/i","parentIdentifier":"/us/usc/t33/s3079/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"up to three years if the person received less than three years of assistance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s3079/b/2/B/ii","parentIdentifier":"/us/usc/t33/s3079/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"up to five years if the person received at least three years of assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Qualifying expenses","label":"c Qualifying expenses","identifier":"/us/usc/t33/s3079/c","parentIdentifier":"/us/usc/t33/s3079","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s3079/c/1","parentIdentifier":"/us/usc/t33/s3079/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fc%2F1","sourceRelease":"119-100","text":"Tuition and fees charged by the educational institution involved.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s3079/c/2","parentIdentifier":"/us/usc/t33/s3079/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fc%2F2","sourceRelease":"119-100","text":"The cost of educational materials.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s3079/c/3","parentIdentifier":"/us/usc/t33/s3079/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fc%2F3","sourceRelease":"119-100","text":"In the case of a program of education leading to a baccalaureate degree, laboratory expenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s3079/c/4","parentIdentifier":"/us/usc/t33/s3079/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fc%2F4","sourceRelease":"119-100","text":"Such other expenses as the Secretary considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Limitation on amount","label":"d Limitation on amount","identifier":"/us/usc/t33/s3079/d","parentIdentifier":"/us/usc/t33/s3079","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fd","sourceRelease":"119-100","text":"The Secretary shall prescribe the amount of financial assistance provided to a person under subsection (a), which may not exceed the amount specified in , for each year of obligated service that a person agrees to serve in an agreement described in subsection (b)(2).section 2173(e)(2) of title 10","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Duration of assistance","label":"e Duration of assistance","identifier":"/us/usc/t33/s3079/e","parentIdentifier":"/us/usc/t33/s3079","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fe","sourceRelease":"119-100","text":"Financial assistance may be provided to a person under subsection (a) for not more than five consecutive academic years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Subsistence allowance","label":"f Subsistence allowance","identifier":"/us/usc/t33/s3079/f","parentIdentifier":"/us/usc/t33/s3079","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s3079/f/1","parentIdentifier":"/us/usc/t33/s3079/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Ff%2F1","sourceRelease":"119-100","text":"A person who receives financial assistance under subsection (a) shall be entitled to a monthly subsistence allowance at a rate prescribed under paragraph (2) for the duration of the period for which the person receives such financial assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Determination of amount","label":"2 Determination of amount","identifier":"/us/usc/t33/s3079/f/2","parentIdentifier":"/us/usc/t33/s3079/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Ff%2F2","sourceRelease":"119-100","text":"The Secretary shall prescribe monthly rates for subsistence allowance provided under paragraph (1), which shall be equal to the amount specified in .section 2144(a) of title 10","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Initial clothing allowance","label":"g Initial clothing allowance","identifier":"/us/usc/t33/s3079/g","parentIdentifier":"/us/usc/t33/s3079","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Training","label":"1 Training","identifier":"/us/usc/t33/s3079/g/1","parentIdentifier":"/us/usc/t33/s3079/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fg%2F1","sourceRelease":"119-100","text":"The Secretary may prescribe a sum which shall be credited to each person who receives financial assistance under subsection (a) to cover the cost of the person’s initial clothing and equipment issue.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Appointment","label":"2 Appointment","identifier":"/us/usc/t33/s3079/g/2","parentIdentifier":"/us/usc/t33/s3079/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fg%2F2","sourceRelease":"119-100","text":"Upon completion of the program of education for which a person receives financial assistance under subsection (a) and acceptance of appointment in the commissioned officer corps of the Administration, the person may be issued a subsequent clothing allowance equivalent to that normally provided to a newly appointed officer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Termination of financial assistance","label":"h Termination of financial assistance","identifier":"/us/usc/t33/s3079/h","parentIdentifier":"/us/usc/t33/s3079","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s3079/h/1","parentIdentifier":"/us/usc/t33/s3079/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fh%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s3079/h/1/A","parentIdentifier":"/us/usc/t33/s3079/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fh%2F1%2FA","sourceRelease":"119-100","text":"the Secretary accepts a request by the person to be released from an agreement described in subsection (b)(2);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s3079/h/1/B","parentIdentifier":"/us/usc/t33/s3079/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fh%2F1%2FB","sourceRelease":"119-100","text":"the misconduct of the person results in a failure to complete the period of active duty required under the agreement; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s3079/h/1/C","parentIdentifier":"/us/usc/t33/s3079/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fh%2F1%2FC","sourceRelease":"119-100","text":"the person fails to fulfill any term or condition of the agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Reimbursement","label":"2 Reimbursement","identifier":"/us/usc/t33/s3079/h/2","parentIdentifier":"/us/usc/t33/s3079/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fh%2F2","sourceRelease":"119-100","text":"The Secretary may require a person who receives assistance described in subsection (c), (f), or (g) under an agreement entered into under subsection (b)(1)(C) to reimburse the Secretary in an amount that bears the same ratio to the total costs of the assistance provided to that person as the unserved portion of active duty bears to the total period of active duty the officer agreed to serve under the agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Waiver","label":"3 Waiver","identifier":"/us/usc/t33/s3079/h/3","parentIdentifier":"/us/usc/t33/s3079/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fh%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s3079/h/3/A","parentIdentifier":"/us/usc/t33/s3079/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fh%2F3%2FA","sourceRelease":"119-100","text":"becomes unqualified to serve on active duty in the commissioned officer corps of the Administration because of a circumstance not within the control of that person; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s3079/h/3/B","parentIdentifier":"/us/usc/t33/s3079/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fh%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s3079/h/3/B/i","parentIdentifier":"/us/usc/t33/s3079/h/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fh%2F3%2FB%2Fi","sourceRelease":"119-100","text":"not physically qualified for appointment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s3079/h/3/B/ii","parentIdentifier":"/us/usc/t33/s3079/h/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fh%2F3%2FB%2Fii","sourceRelease":"119-100","text":"determined to be unqualified for service in the commissioned officer corps of the Administration because of a physical or medical condition that was not the result of the person’s own misconduct or grossly negligent conduct.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Obligation as debt to United States","label":"4 Obligation as debt to United States","identifier":"/us/usc/t33/s3079/h/4","parentIdentifier":"/us/usc/t33/s3079/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fh%2F4","sourceRelease":"119-100","text":"An obligation to reimburse the Secretary imposed under paragraph (2) is, for all purposes, a debt owed to the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Discharge in bankruptcy","label":"5 Discharge in bankruptcy","identifier":"/us/usc/t33/s3079/h/5","parentIdentifier":"/us/usc/t33/s3079/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fh%2F5","sourceRelease":"119-100","text":"A discharge in bankruptcy under title 11 that is entered less than five years after the termination of a written agreement entered into under subsection (b)(1)(C) does not discharge the person signing the agreement from a debt arising under such agreement or under paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Regulations","label":"i Regulations","identifier":"/us/usc/t33/s3079/i","parentIdentifier":"/us/usc/t33/s3079","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fi","sourceRelease":"119-100","text":"The Secretary may prescribe such regulations and orders as the Secretary considers appropriate to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"j","heading":"Concurrent completion of service obligations","label":"j Concurrent completion of service obligations","identifier":"/us/usc/t33/s3079/j","parentIdentifier":"/us/usc/t33/s3079","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3079%2Fj","sourceRelease":"119-100","text":"A service obligation under this section may be completed concurrently with a service obligation under .section 3006 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
