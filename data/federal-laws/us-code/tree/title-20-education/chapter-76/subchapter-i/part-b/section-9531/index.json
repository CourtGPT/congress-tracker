{"type":"section","nativeType":"section","number":"9531","heading":"Establishment","label":"9531 Establishment","identifier":"/us/usc/t20/s9531","parentIdentifier":"/us/usc/t20/ch76/schI/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9531","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t20/s9531/a","parentIdentifier":"/us/usc/t20/s9531","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9531%2Fa","sourceRelease":"119-100","text":"There is established in the Institute a National Center for Education Research (in this part referred to as the “Research Center”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Mission","label":"b Mission","identifier":"/us/usc/t20/s9531/b","parentIdentifier":"/us/usc/t20/s9531","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9531%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s9531/b/1","parentIdentifier":"/us/usc/t20/s9531/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9531%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s9531/b/1/A","parentIdentifier":"/us/usc/t20/s9531/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9531%2Fb%2F1%2FA","sourceRelease":"119-100","text":"ensure that all children have access to a high-quality education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s9531/b/1/B","parentIdentifier":"/us/usc/t20/s9531/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9531%2Fb%2F1%2FB","sourceRelease":"119-100","text":"improve student academic achievement, including through the use of educational technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s9531/b/1/C","parentIdentifier":"/us/usc/t20/s9531/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9531%2Fb%2F1%2FC","sourceRelease":"119-100","text":"close the achievement gap between high-performing and low-performing students through the improvement of teaching and learning of reading, writing, mathematics, science, and other academic subjects; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s9531/b/1/D","parentIdentifier":"/us/usc/t20/s9531/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9531%2Fb%2F1%2FD","sourceRelease":"119-100","text":"improve access to, and opportunity for, postsecondary education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s9531/b/2","parentIdentifier":"/us/usc/t20/s9531/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9531%2Fb%2F2","sourceRelease":"119-100","text":"to support the synthesis and, as appropriate, the integration of education research;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s9531/b/3","parentIdentifier":"/us/usc/t20/s9531/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9531%2Fb%2F3","sourceRelease":"119-100","text":"to promote quality and integrity through the use of accepted practices of scientific inquiry to obtain knowledge and understanding of the validity of education theories, practices, or conditions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s9531/b/4","parentIdentifier":"/us/usc/t20/s9531/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9531%2Fb%2F4","sourceRelease":"119-100","text":"to promote scientifically valid research findings that can provide the basis for improving academic instruction and lifelong learning.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
