{"type":"section","nativeType":"section","number":"1741a","heading":"Special Envoy for Hostage Affairs","label":"1741a Special Envoy for Hostage Affairs","identifier":"/us/usc/t22/s1741a","parentIdentifier":"/us/usc/t22/ch23/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2022—Subsec. (d). added subsec. (d).Pub. L. 117–263"],"amendments":["Amendments2022—Subsec. (d). added subsec. (d).Pub. L. 117–263"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t22/s1741a/a","parentIdentifier":"/us/usc/t22/s1741a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fa","sourceRelease":"119-100","text":"There shall be a Special Presidential Envoy for Hostage Affairs, who shall be appointed by the President, by and with the advice and consent of the Senate, and shall report to the Secretary of State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Rank","label":"b Rank","identifier":"/us/usc/t22/s1741a/b","parentIdentifier":"/us/usc/t22/s1741a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fb","sourceRelease":"119-100","text":"The Special Envoy shall have the rank and status of ambassador.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Responsibilities","label":"c Responsibilities","identifier":"/us/usc/t22/s1741a/c","parentIdentifier":"/us/usc/t22/s1741a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s1741a/c/1","parentIdentifier":"/us/usc/t22/s1741a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fc%2F1","sourceRelease":"119-100","text":"lead diplomatic engagement on United States hostage policy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s1741a/c/2","parentIdentifier":"/us/usc/t22/s1741a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fc%2F2","sourceRelease":"119-100","text":"coordinate all diplomatic engagements and strategy in support of hostage recovery efforts, in coordination with the Hostage Recovery Fusion Cell and consistent with policy guidance communicated through the Hostage Response Group;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s1741a/c/3","parentIdentifier":"/us/usc/t22/s1741a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fc%2F3","sourceRelease":"119-100","text":"in coordination with the Hostage Recovery Fusion Cell as appropriate, coordinate diplomatic engagements regarding cases in which a foreign government has detained a United States national and the United States Government regards such detention as unlawful or wrongful;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s1741a/c/4","parentIdentifier":"/us/usc/t22/s1741a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fc%2F4","sourceRelease":"119-100","text":"provide senior representation from the Special Envoy’s office to the Hostage Recovery Fusion Cell established under and the Hostage Response Group established under ; andsection 1741b of this titlesection 1741c of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s1741a/c/5","parentIdentifier":"/us/usc/t22/s1741a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fc%2F5","sourceRelease":"119-100","text":"ensure that families of United States nationals unlawfully or wrongly detained abroad receive updated information about developments in cases and government policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Family Engagement Coordinator","label":"d Family Engagement Coordinator","identifier":"/us/usc/t22/s1741a/d","parentIdentifier":"/us/usc/t22/s1741a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s1741a/d/1","parentIdentifier":"/us/usc/t22/s1741a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s1741a/d/1/A","parentIdentifier":"/us/usc/t22/s1741a/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fd%2F1%2FA","sourceRelease":"119-100","text":"any interaction by executive branch officials with any family member of such United States national occurs in a coordinated fashion;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s1741a/d/1/B","parentIdentifier":"/us/usc/t22/s1741a/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fd%2F1%2FB","sourceRelease":"119-100","text":"such family member receives consistent and accurate information from the United States Government; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s1741a/d/1/C","parentIdentifier":"/us/usc/t22/s1741a/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fd%2F1%2FC","sourceRelease":"119-100","text":"appropriate coordination with the Family Engagement Coordinator described in ; andsection 1741b(c)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s1741a/d/2","parentIdentifier":"/us/usc/t22/s1741a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741a%2Fd%2F2","sourceRelease":"119-100","text":"for a United States national held hostage abroad, that any engagement with a family member is coordinated with, consistent with, and not duplicative of the efforts of the Family Engagement Coordinator described in .section 1741b(c)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
