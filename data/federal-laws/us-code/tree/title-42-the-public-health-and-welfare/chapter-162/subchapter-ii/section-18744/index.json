{"type":"section","nativeType":"section","number":"18744","heading":"21st Century Energy Workforce Advisory Board","label":"18744 21st Century Energy Workforce Advisory Board","identifier":"/us/usc/t42/s18744","parentIdentifier":"/us/usc/t42/ch162/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Wage Rate RequirementsFor provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of , including authority of Secretary of Labor, see .Pub. L. 117–58section 18851 of this title"],"amendments":["Wage Rate RequirementsFor provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of , including authority of Secretary of Labor, see .Pub. L. 117–58section 18851 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t42/s18744/a","parentIdentifier":"/us/usc/t42/s18744","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18744/a/1","parentIdentifier":"/us/usc/t42/s18744/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fa%2F1","sourceRelease":"119-100","text":"meets the current and future industry and labor needs of the energy sector;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18744/a/2","parentIdentifier":"/us/usc/t42/s18744/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fa%2F2","sourceRelease":"119-100","text":"provides opportunities for students to become qualified for placement in traditional energy sector and emerging energy sector jobs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18744/a/3","parentIdentifier":"/us/usc/t42/s18744/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fa%2F3","sourceRelease":"119-100","text":"identifies areas in which the Department can effectively utilize the technical expertise of the Department to support the workforce activities of other Federal agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18744/a/4","parentIdentifier":"/us/usc/t42/s18744/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fa%2F4","sourceRelease":"119-100","text":"strengthens and engages the workforce training programs of the Department and the National Laboratories in carrying out the Equity in Energy Initiative of the Department and other Department workforce priorities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s18744/a/5","parentIdentifier":"/us/usc/t42/s18744/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fa%2F5","sourceRelease":"119-100","text":"develops plans to support and retrain displaced and unemployed energy sector workers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s18744/a/6","parentIdentifier":"/us/usc/t42/s18744/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fa%2F6","sourceRelease":"119-100","text":"prioritizes education and job training for underrepresented groups, including racial and ethnic minorities, Indian Tribes, women, veterans, and socioeconomically disadvantaged individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Membership","label":"b Membership","identifier":"/us/usc/t42/s18744/b","parentIdentifier":"/us/usc/t42/s18744","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18744/b/1","parentIdentifier":"/us/usc/t42/s18744/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fb%2F1","sourceRelease":"119-100","text":"The Board shall be composed of not fewer than 10 and not more than 15 members, with the initial members of the Board to be appointed by the Secretary not later than 1 year after .November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirement","label":"2 Requirement","identifier":"/us/usc/t42/s18744/b/2","parentIdentifier":"/us/usc/t42/s18744/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fb%2F2","sourceRelease":"119-100","text":"The Board shall include not fewer than 1 representative of a labor organization with significant energy experience who has been nominated by a national labor federation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Qualifications","label":"3 Qualifications","identifier":"/us/usc/t42/s18744/b/3","parentIdentifier":"/us/usc/t42/s18744/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18744/b/3/A","parentIdentifier":"/us/usc/t42/s18744/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the field of economics or workforce development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18744/b/3/B","parentIdentifier":"/us/usc/t42/s18744/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fb%2F3%2FB","sourceRelease":"119-100","text":"relevant traditional energy industries or emerging energy industries, including energy efficiency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18744/b/3/C","parentIdentifier":"/us/usc/t42/s18744/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fb%2F3%2FC","sourceRelease":"119-100","text":"secondary or postsecondary education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s18744/b/3/D","parentIdentifier":"/us/usc/t42/s18744/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fb%2F3%2FD","sourceRelease":"119-100","text":"energy workforce development or apprenticeship programs of States or units of local government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s18744/b/3/E","parentIdentifier":"/us/usc/t42/s18744/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fb%2F3%2FE","sourceRelease":"119-100","text":"relevant organized labor organizations; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s18744/b/3/F","parentIdentifier":"/us/usc/t42/s18744/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fb%2F3%2FF","sourceRelease":"119-100","text":"bringing underrepresented groups, including racial and ethnic minorities, women, veterans, and socioeconomically disadvantaged individuals, into the workforce.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Advisory Board review and recommendations","label":"c Advisory Board review and recommendations","identifier":"/us/usc/t42/s18744/c","parentIdentifier":"/us/usc/t42/s18744","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Determination by Board","label":"1 Determination by Board","identifier":"/us/usc/t42/s18744/c/1","parentIdentifier":"/us/usc/t42/s18744/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18744/c/1/A","parentIdentifier":"/us/usc/t42/s18744/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F1%2FA","sourceRelease":"119-100","text":"determine whether there are opportunities to more effectively and efficiently use the capabilities of the Department in the development of a skilled energy workforce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18744/c/1/B","parentIdentifier":"/us/usc/t42/s18744/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F1%2FB","sourceRelease":"119-100","text":"identify ways in which the Department could work with other relevant Federal agencies, States, units of local government, institutions of higher education, labor organizations, Indian Tribes and tribal organizations, and industry in the development of a skilled energy workforce, subject to applicable law;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18744/c/1/C","parentIdentifier":"/us/usc/t42/s18744/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18744/c/1/C/i","parentIdentifier":"/us/usc/t42/s18744/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F1%2FC%2Fi","sourceRelease":"119-100","text":"increase outreach to minority-serving institutions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18744/c/1/C/ii","parentIdentifier":"/us/usc/t42/s18744/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F1%2FC%2Fii","sourceRelease":"119-100","text":"make resources available to increase the number of skilled minorities and women trained to go into the energy and energy-related manufacturing sectors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s18744/c/1/C/iii","parentIdentifier":"/us/usc/t42/s18744/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"increase outreach to displaced and unemployed energy sector workers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s18744/c/1/C/iv","parentIdentifier":"/us/usc/t42/s18744/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F1%2FC%2Fiv","sourceRelease":"119-100","text":"make resources available to provide training to displaced and unemployed energy sector workers to reenter the energy workforce; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s18744/c/1/D","parentIdentifier":"/us/usc/t42/s18744/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F1%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18744/c/1/D/i","parentIdentifier":"/us/usc/t42/s18744/c/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F1%2FD%2Fi","sourceRelease":"119-100","text":"identify the energy sectors in greatest need of workforce training; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18744/c/1/D/ii","parentIdentifier":"/us/usc/t42/s18744/c/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F1%2FD%2Fii","sourceRelease":"119-100","text":"in consultation with the Secretary of Labor, develop recommendations for the skills necessary to develop a workforce trained to work in those energy sectors.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Required analysis","label":"2 Required analysis","identifier":"/us/usc/t42/s18744/c/2","parentIdentifier":"/us/usc/t42/s18744/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18744/c/2/A","parentIdentifier":"/us/usc/t42/s18744/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F2%2FA","sourceRelease":"119-100","text":"existing Department-directed support; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18744/c/2/B","parentIdentifier":"/us/usc/t42/s18744/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F2%2FB","sourceRelease":"119-100","text":"existing energy workforce training programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Report","label":"3 Report","identifier":"/us/usc/t42/s18744/c/3","parentIdentifier":"/us/usc/t42/s18744/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s18744/c/3/A","parentIdentifier":"/us/usc/t42/s18744/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18744/c/3/A/i","parentIdentifier":"/us/usc/t42/s18744/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FA%2Fi","sourceRelease":"119-100","text":"the findings of the Board; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18744/c/3/A/ii","parentIdentifier":"/us/usc/t42/s18744/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FA%2Fii","sourceRelease":"119-100","text":"the proposed energy workforce strategy of the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Response of the Secretary","label":"B Response of the Secretary","identifier":"/us/usc/t42/s18744/c/3/B","parentIdentifier":"/us/usc/t42/s18744/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18744/c/3/B/i","parentIdentifier":"/us/usc/t42/s18744/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s18744/c/3/B/i/I","parentIdentifier":"/us/usc/t42/s18744/c/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FB%2Fi%2FI","sourceRelease":"119-100","text":"describes whether the Secretary approves or disapproves of each recommendation of the Board under subparagraph (A); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s18744/c/3/B/i/II","parentIdentifier":"/us/usc/t42/s18744/c/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FB%2Fi%2FII","sourceRelease":"119-100","text":"if the Secretary approves of a recommendation, provides an implementation plan for the recommendation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18744/c/3/B/ii","parentIdentifier":"/us/usc/t42/s18744/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s18744/c/3/B/ii/I","parentIdentifier":"/us/usc/t42/s18744/c/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FB%2Fii%2FI","sourceRelease":"119-100","text":"the report of the Board under subparagraph (A); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s18744/c/3/B/ii/II","parentIdentifier":"/us/usc/t42/s18744/c/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FB%2Fii%2FII","sourceRelease":"119-100","text":"the response of the Secretary under clause (i).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Public availability of report","label":"C Public availability of report","identifier":"/us/usc/t42/s18744/c/3/C","parentIdentifier":"/us/usc/t42/s18744/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t42/s18744/c/3/C/i","parentIdentifier":"/us/usc/t42/s18744/c/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FC%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s18744/c/3/C/i/I","parentIdentifier":"/us/usc/t42/s18744/c/3/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FC%2Fi%2FI","sourceRelease":"119-100","text":"the date on which the Board receives the response of the Secretary under subparagraph (B)(i); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s18744/c/3/C/i/II","parentIdentifier":"/us/usc/t42/s18744/c/3/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FC%2Fi%2FII","sourceRelease":"119-100","text":"the date that is 90 days after the date on which the Board submitted the report to the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Requirement","label":"ii Requirement","identifier":"/us/usc/t42/s18744/c/3/C/ii","parentIdentifier":"/us/usc/t42/s18744/c/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fc%2F3%2FC%2Fii","sourceRelease":"119-100","text":"If the Board has received a response to a report from the Secretary under subparagraph (B)(i), the Board shall make that response publicly available with the applicable report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Report by the Secretary","label":"d Report by the Secretary","identifier":"/us/usc/t42/s18744/d","parentIdentifier":"/us/usc/t42/s18744","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18744/d/1","parentIdentifier":"/us/usc/t42/s18744/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fd%2F1","sourceRelease":"119-100","text":"describes the effectiveness and accomplishments of the Board during the applicable term;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18744/d/2","parentIdentifier":"/us/usc/t42/s18744/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fd%2F2","sourceRelease":"119-100","text":"contains a determination of the Secretary as to whether the Board should be renewed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18744/d/3","parentIdentifier":"/us/usc/t42/s18744/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fd%2F3","sourceRelease":"119-100","text":"if the Secretary determines that the Board should be renewed, any recommendations as to whether and how the scope and functions of the Board should be modified.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Outreach to minority-serving institutions, veterans, and displaced and unemployed energy workers","label":"e Outreach to minority-serving institutions, veterans, and displaced and unemployed energy workers","identifier":"/us/usc/t42/s18744/e","parentIdentifier":"/us/usc/t42/s18744","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18744/e/1","parentIdentifier":"/us/usc/t42/s18744/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fe%2F1","sourceRelease":"119-100","text":"give special consideration to increasing outreach to minority-serving institutions, veterans, and displaced and unemployed energy workers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18744/e/2","parentIdentifier":"/us/usc/t42/s18744/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18744/e/2/A","parentIdentifier":"/us/usc/t42/s18744/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fe%2F2%2FA","sourceRelease":"119-100","text":"minority-serving institutions, with the objective of increasing the number of skilled minorities and women trained to go into the energy and manufacturing sectors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18744/e/2/B","parentIdentifier":"/us/usc/t42/s18744/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fe%2F2%2FB","sourceRelease":"119-100","text":"institutions that serve veterans, with the objective of increasing the number veterans in the energy industry by ensuring that veterans have the credentials and training necessary to secure careers in the energy industry; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18744/e/2/C","parentIdentifier":"/us/usc/t42/s18744/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fe%2F2%2FC","sourceRelease":"119-100","text":"institutions that serve displaced and unemployed energy workers to increase the number of individuals trained for jobs in the energy industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18744/e/3","parentIdentifier":"/us/usc/t42/s18744/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fe%2F3","sourceRelease":"119-100","text":"encourage the energy industry to improve the opportunities for students of minority-serving institutions, veterans, and displaced and unemployed energy workers to participate in internships, preapprenticeships, apprenticeships, and cooperative work-study programs in the energy industry; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18744/e/4","parentIdentifier":"/us/usc/t42/s18744/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Fe%2F4","sourceRelease":"119-100","text":"work with the National Laboratories to increase the participation of underrepresented groups, veterans, and displaced and unemployed energy workers in internships, fellowships, training programs, and employment at the National Laboratories.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Term","label":"f Term","identifier":"/us/usc/t42/s18744/f","parentIdentifier":"/us/usc/t42/s18744","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18744/f/1","parentIdentifier":"/us/usc/t42/s18744/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Ff%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2), the Board shall terminate on .September 30, 2026","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Extensions","label":"2 Extensions","identifier":"/us/usc/t42/s18744/f/2","parentIdentifier":"/us/usc/t42/s18744/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18744%2Ff%2F2","sourceRelease":"119-100","text":"The Secretary may renew the Board for 1 or more 5-year periods by submitting, not later than the date described in subsection (d), a report described in that subsection that contains a determination by the Secretary that the Board should be renewed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
