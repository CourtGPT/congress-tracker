{"type":"section","nativeType":"section","number":"1097d","heading":"TRICARE program: notice of change to benefits","label":"1097d TRICARE program: notice of change to benefits","identifier":"/us/usc/t10/s1097d","parentIdentifier":"/us/usc/t10/stA/ptII/ch55","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1097d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Provision of Notice","label":"a .—Provision of Notice","identifier":"/us/usc/t10/s1097d/a","parentIdentifier":"/us/usc/t10/s1097d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1097d%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1097d/a/1","parentIdentifier":"/us/usc/t10/s1097d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1097d%2Fa%2F1","sourceRelease":"119-100","text":"If the Secretary makes a significant change to any benefits provided by the TRICARE program to covered beneficiaries, the Secretary shall provide individuals described in paragraph (2) with notice explaining such changes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1097d/a/2","parentIdentifier":"/us/usc/t10/s1097d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1097d%2Fa%2F2","sourceRelease":"119-100","text":"The individuals described by this paragraph are covered beneficiaries participating in the TRICARE program who may be affected by a significant change covered by a notification under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s1097d/a/3","parentIdentifier":"/us/usc/t10/s1097d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1097d%2Fa%2F3","sourceRelease":"119-100","text":"The Secretary shall provide notice under paragraph (1) through electronic means.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Timing of Notice","label":"b .—Timing of Notice","identifier":"/us/usc/t10/s1097d/b","parentIdentifier":"/us/usc/t10/s1097d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1097d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1097d/b/1","parentIdentifier":"/us/usc/t10/s1097d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1097d%2Fb%2F1","sourceRelease":"119-100","text":"The date that the Secretary determines would afford individuals described in paragraph (2) of such subsection adequate time to understand the change covered by the notification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1097d/b/2","parentIdentifier":"/us/usc/t10/s1097d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1097d%2Fb%2F2","sourceRelease":"119-100","text":"The date that is 90 days before the date on which the change covered by the notification becomes effective.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s1097d/b/3","parentIdentifier":"/us/usc/t10/s1097d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1097d%2Fb%2F3","sourceRelease":"119-100","text":"The effective date of a significant change that is required by law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Significant Change Defined","label":"c .—Significant Change Defined","identifier":"/us/usc/t10/s1097d/c","parentIdentifier":"/us/usc/t10/s1097d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1097d%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1097d/c/1","parentIdentifier":"/us/usc/t10/s1097d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1097d%2Fc%2F1","sourceRelease":"119-100","text":"in the structure of the TRICARE program or the benefits provided under the TRICARE program (not including the addition of new services or benefits); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1097d/c/2","parentIdentifier":"/us/usc/t10/s1097d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1097d%2Fc%2F2","sourceRelease":"119-100","text":"in beneficiary cost-share rates of more than 20 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
