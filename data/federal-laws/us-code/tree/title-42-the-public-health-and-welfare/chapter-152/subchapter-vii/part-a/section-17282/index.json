pe":"subparagraph","number":"A","heading":"Inclusions","label":"A Inclusions","identifier":"/us/usc/t42/s17282/a/3/A","parentIdentifier":"/us/usc/t42/s17282/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F3%2FA","sourceRelease":"119-100","text":"The term “ocean energy” includes current, wave, and tidal energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exclusion","label":"B Exclusion","identifier":"/us/usc/t42/s17282/a/3/B","parentIdentifier":"/us/usc/t42/s17282/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F3%2FB","sourceRelease":"119-100","text":"The term “ocean energy” excludes thermal energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Renewable energy project","label":"4 Renewable energy project","identifier":"/us/usc/t42/s17282/a/4","parentIdentifier":"/us/usc/t42/s17282/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17282/a/4/A","parentIdentifier":"/us/usc/t42/s17282/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F4%2FA","sourceRelease":"119-100","text":"for the commercial generation of electricity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17282/a/4/B","parentIdentifier":"/us/usc/t42/s17282/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17282/a/4/B/i","parentIdentifier":"/us/usc/t42/s17282/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F4%2FB%2Fi","sourceRelease":"119-100","text":"solar, wind, or geothermal energy or ocean energy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17282/a/4/B/ii","parentIdentifier":"/us/usc/t42/s17282/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F4%2FB%2Fii","sourceRelease":"119-100","text":"biomass (as defined in );section 15852(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s17282/a/4/B/iii","parentIdentifier":"/us/usc/t42/s17282/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F4%2FB%2Fiii","sourceRelease":"119-100","text":"landfill gas; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s17282/a/4/B/iv","parentIdentifier":"/us/usc/t42/s17282/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F4%2FB%2Fiv","sourceRelease":"119-100","text":"Alaska small hydroelectric power.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Renewable energy construction grants","label":"b Renewable energy construction grants","identifier":"/us/usc/t42/s17282/b","parentIdentifier":"/us/usc/t42/s17282","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17282/b/1","parentIdentifier":"/us/usc/t42/s17282/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall use amounts appropriated under this section to make grants for use in carrying out renewable energy projects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Criteria","label":"2 Criteria","identifier":"/us/usc/t42/s17282/b/2","parentIdentifier":"/us/usc/t42/s17282/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fb%2F2","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary shall set forth criteria for use in awarding grants under this section.December 19, 2007","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Application","label":"3 Application","identifier":"/us/usc/t42/s17282/b/3","parentIdentifier":"/us/usc/t42/s17282/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17282/b/3/A","parentIdentifier":"/us/usc/t42/s17282/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fb%2F3%2FA","sourceRelease":"119-100","text":"all laborers and mechanics employed by contractors or subcontractors during construction, alteration, or repair that is financed, in whole or in part, by a grant under this section shall be paid wages at rates not less than those prevailing on similar construction in the locality, as determined by the Secretary of Labor in accordance with sections 3141–3144, 3146, and 3147 of title 40; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17282/b/3/B","parentIdentifier":"/us/usc/t42/s17282/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fb%2F3%2FB","sourceRelease":"119-100","text":"the Secretary of Labor shall, with respect to the labor standards described in this paragraph, have the authority and functions set forth in Reorganization Plan Numbered 14 of 1950 (5 U.S.C. App.) and .section 3145 of title 40","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Non-Federal share","label":"4 Non-Federal share","identifier":"/us/usc/t42/s17282/b/4","parentIdentifier":"/us/usc/t42/s17282/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fb%2F4","sourceRelease":"119-100","text":"Each eligible applicant that receives a grant under this subsection shall contribute to the total cost of the renewable energy project constructed by the eligible applicant an amount not less than 50 percent of the total cost of the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t42/s17282/c","parentIdentifier":"/us/usc/t42/s17282","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fc","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Fund such sums as are necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
