{"type":"section","nativeType":"section","number":"18611","heading":"Sense of Congress on accelerating energy innovation","label":"18611 Sense of Congress on accelerating energy innovation","identifier":"/us/usc/t42/s18611","parentIdentifier":"/us/usc/t42/ch161/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18611","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18611/1","parentIdentifier":"/us/usc/t42/s18611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18611%2F1","sourceRelease":"119-100","text":"although important progress has been made in cost reduction and deployment of clean energy technologies, accelerating clean energy innovation will help meet critical competitiveness, energy security, and environmental goals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18611/2","parentIdentifier":"/us/usc/t42/s18611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18611%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18611/2/A","parentIdentifier":"/us/usc/t42/s18611/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18611%2F2%2FA","sourceRelease":"119-100","text":"supporting existing research and development programs at the Department and the world-class National Laboratories;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18611/2/B","parentIdentifier":"/us/usc/t42/s18611/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18611%2F2%2FB","sourceRelease":"119-100","text":"exploring and developing new pathways for innovators, investors, and decision-makers to leverage the resources of the Department for addressing the challenges and comparative strengths of geographic regions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18611/2/C","parentIdentifier":"/us/usc/t42/s18611/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18611%2F2%2FC","sourceRelease":"119-100","text":"recognizing the financial constraints of the Department, regularly reviewing clean energy programs to ensure that taxpayer investments are maximized;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18611/3","parentIdentifier":"/us/usc/t42/s18611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18611%2F3","sourceRelease":"119-100","text":"the energy supply, demand, policies, markets, and resource options of the United States vary by geographic region;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18611/4","parentIdentifier":"/us/usc/t42/s18611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18611%2F4","sourceRelease":"119-100","text":"a regional approach to innovation can bridge the gaps between local talent, institutions, and industries to identify opportunities and convert United States investment into domestic companies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s18611/5","parentIdentifier":"/us/usc/t42/s18611","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18611%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18611/5/A","parentIdentifier":"/us/usc/t42/s18611/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18611%2F5%2FA","sourceRelease":"119-100","text":"provide clean, affordable, and reliable energy for everyone;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18611/5/B","parentIdentifier":"/us/usc/t42/s18611/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18611%2F5%2FB","sourceRelease":"119-100","text":"promote economic growth;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18611/5/C","parentIdentifier":"/us/usc/t42/s18611/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18611%2F5%2FC","sourceRelease":"119-100","text":"are critical for energy security; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s18611/5/D","parentIdentifier":"/us/usc/t42/s18611/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18611%2F5%2FD","sourceRelease":"119-100","text":"are sustainable without government support.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
