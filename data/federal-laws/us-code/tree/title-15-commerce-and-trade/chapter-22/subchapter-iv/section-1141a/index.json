{"type":"section","nativeType":"section","number":"1141a","heading":"International applications based on United States applications or registrations","label":"1141a International applications based on United States applications or registrations","identifier":"/us/usc/t15/s1141a","parentIdentifier":"/us/usc/t15/ch22/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1141a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s1141a/a","parentIdentifier":"/us/usc/t15/s1141a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1141a%2Fa","sourceRelease":"119-100","text":"The owner of a basic application pending before the United States Patent and Trademark Office, or the owner of a basic registration granted by the United States Patent and Trademark Office may file an international application by submitting to the United States Patent and Trademark Office a written application in such form, together with such fees, as may be prescribed by the Director.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Qualified owners","label":"b Qualified owners","identifier":"/us/usc/t15/s1141a/b","parentIdentifier":"/us/usc/t15/s1141a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1141a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s1141a/b/1","parentIdentifier":"/us/usc/t15/s1141a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1141a%2Fb%2F1","sourceRelease":"119-100","text":"be a national of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s1141a/b/2","parentIdentifier":"/us/usc/t15/s1141a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1141a%2Fb%2F2","sourceRelease":"119-100","text":"be domiciled in the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s1141a/b/3","parentIdentifier":"/us/usc/t15/s1141a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1141a%2Fb%2F3","sourceRelease":"119-100","text":"have a real and effective industrial or commercial establishment in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
