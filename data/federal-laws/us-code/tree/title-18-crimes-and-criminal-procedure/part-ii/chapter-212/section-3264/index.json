{"type":"section","nativeType":"section","number":"3264","heading":"Limitation on removal","label":"3264 Limitation on removal","identifier":"/us/usc/t18/s3264","parentIdentifier":"/us/usc/t18/ptII/ch212","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3264","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe Federal Rules of Criminal Procedure, referred to in subsec. (b)(3), are set out in the Appendix to this title."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t18/s3264/a","parentIdentifier":"/us/usc/t18/s3264","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3264%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s3264/a/1","parentIdentifier":"/us/usc/t18/s3264/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3264%2Fa%2F1","sourceRelease":"119-100","text":"to the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s3264/a/2","parentIdentifier":"/us/usc/t18/s3264/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3264%2Fa%2F2","sourceRelease":"119-100","text":"to any foreign country other than a country in which such person is believed to have violated section 3261(a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t18/s3264/b","parentIdentifier":"/us/usc/t18/s3264","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3264%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s3264/b/1","parentIdentifier":"/us/usc/t18/s3264/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3264%2Fb%2F1","sourceRelease":"119-100","text":"a Federal magistrate judge orders the person to be removed to the United States to be present at a detention hearing held pursuant to section 3142(f);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s3264/b/2","parentIdentifier":"/us/usc/t18/s3264/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3264%2Fb%2F2","sourceRelease":"119-100","text":"a Federal magistrate judge orders the detention of the person before trial pursuant to section 3142(e), in which case the person shall be promptly removed to the United States for purposes of such detention;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s3264/b/3","parentIdentifier":"/us/usc/t18/s3264/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3264%2Fb%2F3","sourceRelease":"119-100","text":"the person is entitled to, and does not waive, a preliminary examination under the Federal Rules of Criminal Procedure, in which case the person shall be removed to the United States in time for such examination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t18/s3264/b/4","parentIdentifier":"/us/usc/t18/s3264/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3264%2Fb%2F4","sourceRelease":"119-100","text":"a Federal magistrate judge otherwise orders the person to be removed to the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t18/s3264/b/5","parentIdentifier":"/us/usc/t18/s3264/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3264%2Fb%2F5","sourceRelease":"119-100","text":"the Secretary of Defense determines that military necessity requires that the limitations in subsection (a) be waived, in which case the person shall be removed to the nearest United States military installation outside the United States adequate to detain the person and to facilitate the initial appearance described in section 3265(a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
