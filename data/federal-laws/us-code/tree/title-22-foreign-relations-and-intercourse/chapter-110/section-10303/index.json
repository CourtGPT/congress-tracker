{"type":"section","nativeType":"section","number":"10303","heading":"Cybersecurity recruitment and retention","label":"10303 Cybersecurity recruitment and retention","identifier":"/us/usc/t22/s10303","parentIdentifier":"/us/usc/t22/ch110","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","DefinitionsFor definitions of “Department”, “Secretary”, and “appropriate congressional committees” as used in this section, see , set out as a note under .section 9002 of Pub. L. 117–263section 2651 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Sense of Congress","label":"a Sense of Congress","identifier":"/us/usc/t22/s10303/a","parentIdentifier":"/us/usc/t22/s10303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10303/a/1","parentIdentifier":"/us/usc/t22/s10303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fa%2F1","sourceRelease":"119-100","text":"the cybersecurity effectiveness of the Department; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10303/a/2","parentIdentifier":"/us/usc/t22/s10303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fa%2F2","sourceRelease":"119-100","text":"the ability of foreign service officers to engage with foreign audiences on cybersecurity matters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Technology talent acquisition","label":"b Technology talent acquisition","identifier":"/us/usc/t22/s10303/b","parentIdentifier":"/us/usc/t22/s10303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t22/s10303/b/1","parentIdentifier":"/us/usc/t22/s10303/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall establish positions within the Bureau of Global Talent Management that are solely dedicated to the recruitment and retention of Department personnel with backgrounds in cybersecurity, engineering, data science, application development, artificial intelligence, critical and emerging technology, and technology and digital policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Goals","label":"2 Goals","identifier":"/us/usc/t22/s10303/b/2","parentIdentifier":"/us/usc/t22/s10303/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10303/b/2/A","parentIdentifier":"/us/usc/t22/s10303/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fb%2F2%2FA","sourceRelease":"119-100","text":"to fulfill the critical need of the Department to recruit and retain employees for cybersecurity, digital, and technology positions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10303/b/2/B","parentIdentifier":"/us/usc/t22/s10303/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fb%2F2%2FB","sourceRelease":"119-100","text":"to actively recruit relevant candidates from academic institutions, the private sector, and related industries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10303/b/2/C","parentIdentifier":"/us/usc/t22/s10303/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fb%2F2%2FC","sourceRelease":"119-100","text":"to work with the Office of Personnel Management and the United States Digital Service to develop and implement best strategies for recruiting and retaining technology talent; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s10303/b/2/D","parentIdentifier":"/us/usc/t22/s10303/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fb%2F2%2FD","sourceRelease":"119-100","text":"to inform and train supervisors at the Department on the use of the authorities listed in subsection (c)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Implementation plan","label":"3 Implementation plan","identifier":"/us/usc/t22/s10303/b/3","parentIdentifier":"/us/usc/t22/s10303/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fb%2F3","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary shall submit a plan to the appropriate congressional committees that describes how the objectives and goals set forth in paragraphs (1) and (2) will be implemented.December 23, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Authorization of appropriations","label":"4 Authorization of appropriations","identifier":"/us/usc/t22/s10303/b/4","parentIdentifier":"/us/usc/t22/s10303/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fb%2F4","sourceRelease":"119-100","text":"There is authorized to be appropriated $750,000 for each of the fiscal years 2023 through 2027 to carry out this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Annual report on hiring authorities","label":"c Annual report on hiring authorities","identifier":"/us/usc/t22/s10303/c","parentIdentifier":"/us/usc/t22/s10303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10303/c/1","parentIdentifier":"/us/usc/t22/s10303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fc%2F1","sourceRelease":"119-100","text":"a list of the hiring authorities available to the Department to recruit and retain personnel with backgrounds in cybersecurity, engineering, data science, application development, artificial intelligence, critical and emerging technology, and technology and digital policy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10303/c/2","parentIdentifier":"/us/usc/t22/s10303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fc%2F2","sourceRelease":"119-100","text":"a list of which hiring authorities described in paragraph (1) have been used during the previous 5 years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s10303/c/3","parentIdentifier":"/us/usc/t22/s10303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fc%2F3","sourceRelease":"119-100","text":"the number of employees in qualified positions hired, aggregated by position and grade level or pay band;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s10303/c/4","parentIdentifier":"/us/usc/t22/s10303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fc%2F4","sourceRelease":"119-100","text":"the number of employees who have been placed in qualified positions, aggregated by bureau and offices within the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s10303/c/5","parentIdentifier":"/us/usc/t22/s10303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fc%2F5","sourceRelease":"119-100","text":"the rate of attrition of individuals who begin the hiring process and do not complete the process and a description of the reasons for such attrition;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s10303/c/6","parentIdentifier":"/us/usc/t22/s10303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fc%2F6","sourceRelease":"119-100","text":"the number of individuals who are interviewed by subject matter experts and the number of individuals who are not interviewed by subject matter experts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t22/s10303/c/7","parentIdentifier":"/us/usc/t22/s10303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fc%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10303/c/7/A","parentIdentifier":"/us/usc/t22/s10303/c/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fc%2F7%2FA","sourceRelease":"119-100","text":"reducing the attrition rate referred to in paragraph (5) by 5 percent each year;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10303/c/7/B","parentIdentifier":"/us/usc/t22/s10303/c/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fc%2F7%2FB","sourceRelease":"119-100","text":"additional hiring authorities needed to acquire needed technology talent;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10303/c/7/C","parentIdentifier":"/us/usc/t22/s10303/c/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fc%2F7%2FC","sourceRelease":"119-100","text":"hiring personnel to hold public trust positions until such personnel can obtain the necessary security clearance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s10303/c/7/D","parentIdentifier":"/us/usc/t22/s10303/c/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fc%2F7%2FD","sourceRelease":"119-100","text":"informing and training supervisors within the Department on the use of the authorities listed in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Incentive pay for cybersecurity professionals","label":"d Incentive pay for cybersecurity professionals","identifier":"/us/usc/t22/s10303/d","parentIdentifier":"/us/usc/t22/s10303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10303/d/1","parentIdentifier":"/us/usc/t22/s10303/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fd%2F1","sourceRelease":"119-100","text":"include computer programming languages within the Recruitment Language Program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10303/d/2","parentIdentifier":"/us/usc/t22/s10303/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fd%2F2","sourceRelease":"119-100","text":"provide appropriate language incentive pay.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Report","label":"e Report","identifier":"/us/usc/t22/s10303/e","parentIdentifier":"/us/usc/t22/s10303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10303/e/1","parentIdentifier":"/us/usc/t22/s10303/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fe%2F1","sourceRelease":"119-100","text":"the computer programming languages included within the Recruitment Language Program and the language incentive pay rate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10303/e/2","parentIdentifier":"/us/usc/t22/s10303/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10303%2Fe%2F2","sourceRelease":"119-100","text":"the number of individuals benefitting from the inclusion of such computer programming languages in the Recruitment Language Program and language incentive pay.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
