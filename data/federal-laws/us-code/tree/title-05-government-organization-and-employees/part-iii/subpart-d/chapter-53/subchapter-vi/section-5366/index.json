{"type":"section","nativeType":"section","number":"5366","heading":"Appeals","label":"5366 Appeals","identifier":"/us/usc/t5/s5366","parentIdentifier":"/us/usc/t5/ptIII/sptD/ch53/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5366","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s5366/a","parentIdentifier":"/us/usc/t5/s5366","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5366%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s5366/a/1","parentIdentifier":"/us/usc/t5/s5366/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5366%2Fa%2F1","sourceRelease":"119-100","text":"In the case of the termination of any benefits available to an employee under this subchapter on the grounds such employee declined a reasonable offer of a position the grade or pay of which was equal to or greater than his retained grade or pay, such termination may be appealed to the Office of Personnel Management under procedures prescribed by the Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s5366/a/2","parentIdentifier":"/us/usc/t5/s5366/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5366%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s5366/a/2/A","parentIdentifier":"/us/usc/t5/s5366/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5366%2Fa%2F2%2FA","sourceRelease":"119-100","text":"under section 5112(b) or 5346(c) of this title, or otherwise, any reclassification of a position; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s5366/a/2/B","parentIdentifier":"/us/usc/t5/s5366/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5366%2Fa%2F2%2FB","sourceRelease":"119-100","text":"under procedures prescribed by the Office of Personnel Management, any reduction-in-force action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s5366/b","parentIdentifier":"/us/usc/t5/s5366","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5366%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s5366/b/1","parentIdentifier":"/us/usc/t5/s5366/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5366%2Fb%2F1","sourceRelease":"119-100","text":"any action which is the basis of an individual’s entitlement to benefits under this subchapter, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s5366/b/2","parentIdentifier":"/us/usc/t5/s5366/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5366%2Fb%2F2","sourceRelease":"119-100","text":"any termination of any such benefits under this subchapter,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
