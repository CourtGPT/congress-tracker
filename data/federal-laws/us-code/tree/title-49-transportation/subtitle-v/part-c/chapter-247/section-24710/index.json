{"type":"section","nativeType":"section","number":"24710","heading":"Long-distance routes","label":"24710 Long-distance routes","identifier":"/us/usc/t49/s24710","parentIdentifier":"/us/usc/t49/stV/ptC/ch247","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextSection 207 of the Passenger Rail Investment and Improvement Act of 2008, referred to in subsecs. (a) and (b), is , which is set out in a note under .section 207 of Pub. L. 110–432section 24101 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Annual Evaluation","label":"a .—Annual Evaluation","identifier":"/us/usc/t49/s24710/a","parentIdentifier":"/us/usc/t49/s24710","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s24710/a/1","parentIdentifier":"/us/usc/t49/s24710/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fa%2F1","sourceRelease":"119-100","text":"evaluate annually the financial and operating performance of each long-distance passenger rail route operated by Amtrak; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s24710/a/2","parentIdentifier":"/us/usc/t49/s24710/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fa%2F2","sourceRelease":"119-100","text":"rank the overall performance of such routes for 2008 and identify each long-distance passenger rail route operated by Amtrak in 2008 according to its overall performance as belonging to the best performing third of such routes, the second best performing third of such routes, or the worst performing third of such routes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Performance Improvement Plan","label":"b .—Performance Improvement Plan","identifier":"/us/usc/t49/s24710/b","parentIdentifier":"/us/usc/t49/s24710","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s24710/b/1","parentIdentifier":"/us/usc/t49/s24710/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fb%2F1","sourceRelease":"119-100","text":"on-time performance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s24710/b/2","parentIdentifier":"/us/usc/t49/s24710/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fb%2F2","sourceRelease":"119-100","text":"scheduling, frequency, routes, and stops;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s24710/b/3","parentIdentifier":"/us/usc/t49/s24710/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fb%2F3","sourceRelease":"119-100","text":"the feasibility of restructuring service into connected corridor service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s24710/b/4","parentIdentifier":"/us/usc/t49/s24710/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fb%2F4","sourceRelease":"119-100","text":"performance-related equipment changes and capital improvements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t49/s24710/b/5","parentIdentifier":"/us/usc/t49/s24710/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fb%2F5","sourceRelease":"119-100","text":"on-board amenities and service, including food, first class, and sleeping car service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t49/s24710/b/6","parentIdentifier":"/us/usc/t49/s24710/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fb%2F6","sourceRelease":"119-100","text":"State or other non-Federal financial contributions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t49/s24710/b/7","parentIdentifier":"/us/usc/t49/s24710/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fb%2F7","sourceRelease":"119-100","text":"improving financial performance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t49/s24710/b/8","parentIdentifier":"/us/usc/t49/s24710/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fb%2F8","sourceRelease":"119-100","text":"anticipated Federal funding of operating and capital costs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t49/s24710/b/9","parentIdentifier":"/us/usc/t49/s24710/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fb%2F9","sourceRelease":"119-100","text":"other aspects of Amtrak’s long-distance passenger rail routes that affect the financial, competitive, and functional performance of service on Amtrak’s long-distance passenger rail routes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Implementation","label":"c .—Implementation","identifier":"/us/usc/t49/s24710/c","parentIdentifier":"/us/usc/t49/s24710","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s24710/c/1","parentIdentifier":"/us/usc/t49/s24710/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fc%2F1","sourceRelease":"119-100","text":"beginning in fiscal year 2010 for those routes identified as being in the worst performing third under subsection (a)(2);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s24710/c/2","parentIdentifier":"/us/usc/t49/s24710/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fc%2F2","sourceRelease":"119-100","text":"beginning in fiscal year 2011 for those routes identified as being in the second best performing third under subsection (a)(2); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s24710/c/3","parentIdentifier":"/us/usc/t49/s24710/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fc%2F3","sourceRelease":"119-100","text":"beginning in fiscal year 2012 for those routes identified as being in the best performing third under subsection (a)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Enforcement","label":"d .—Enforcement","identifier":"/us/usc/t49/s24710/d","parentIdentifier":"/us/usc/t49/s24710","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s24710/d/1","parentIdentifier":"/us/usc/t49/s24710/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fd%2F1","sourceRelease":"119-100","text":"shall notify Amtrak, the Inspector General of the Department of Transportation, the Committee on Transportation and Infrastructure of the House of Representatives, and the Committee on Commerce, Science, and Transportation of the Senate of its determination under this subsection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s24710/d/2","parentIdentifier":"/us/usc/t49/s24710/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fd%2F2","sourceRelease":"119-100","text":"shall provide Amtrak with an opportunity for a hearing with respect to that determination; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s24710/d/3","parentIdentifier":"/us/usc/t49/s24710/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs24710%2Fd%2F3","sourceRelease":"119-100","text":"may withhold appropriated funds otherwise available to Amtrak for the operation of a route or routes from among the worst performing third of routes currently served by Amtrak on which Amtrak is not making reasonable progress, other than funds made available for passenger safety or security measures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
