{"type":"section","nativeType":"section","number":"6821","heading":"Establishment","label":"6821 Establishment","identifier":"/us/usc/t22/s6821","parentIdentifier":"/us/usc/t22/ch76/schII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Negotiations for establishment of Trust Fund","label":"a Negotiations for establishment of Trust Fund","identifier":"/us/usc/t22/s6821/a","parentIdentifier":"/us/usc/t22/s6821","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s6821/a/1","parentIdentifier":"/us/usc/t22/s6821/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821%2Fa%2F1","sourceRelease":"119-100","text":"the World Bank AIDS Trust Fund (in this subchapter referred to as the “Trust Fund”) in accordance with the provisions of this part; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s6821/a/2","parentIdentifier":"/us/usc/t22/s6821/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821%2Fa%2F2","sourceRelease":"119-100","text":"the Advisory Board to the Trust Fund in accordance with .section 6824 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purpose","label":"b Purpose","identifier":"/us/usc/t22/s6821/b","parentIdentifier":"/us/usc/t22/s6821","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s6821/b/1","parentIdentifier":"/us/usc/t22/s6821/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821%2Fb%2F1","sourceRelease":"119-100","text":"assist in the prevention and eradication of HIV/AIDS and the care and treatment of individuals infected with HIV/AIDS; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s6821/b/2","parentIdentifier":"/us/usc/t22/s6821/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821%2Fb%2F2","sourceRelease":"119-100","text":"provide support for the establishment of programs that provide health care and primary and secondary education for children orphaned by the HIV/AIDS epidemic.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Composition","label":"c Composition","identifier":"/us/usc/t22/s6821/c","parentIdentifier":"/us/usc/t22/s6821","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s6821/c/1","parentIdentifier":"/us/usc/t22/s6821/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821%2Fc%2F1","sourceRelease":"119-100","text":"The Trust Fund should be governed by a Board of Trustees, which should be composed of representatives of the participating donor countries to the Trust Fund. Individuals appointed to the Board should have demonstrated knowledge and experience in the fields of public health, epidemiology, health care (including delivery systems), and development.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"United States representation","label":"2 United States representation","identifier":"/us/usc/t22/s6821/c/2","parentIdentifier":"/us/usc/t22/s6821/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t22/s6821/c/2/A","parentIdentifier":"/us/usc/t22/s6821/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821%2Fc%2F2%2FA","sourceRelease":"119-100","text":"Upon the effective date of this paragraph, there shall be a United States member of the Board of Trustees, who shall be appointed by the President, by and with the advice and consent of the Senate, and who shall have the qualifications described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Effective and termination dates","label":"B Effective and termination dates","identifier":"/us/usc/t22/s6821/c/2/B","parentIdentifier":"/us/usc/t22/s6821/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"Effective date","label":"i Effective date","identifier":"/us/usc/t22/s6821/c/2/B/i","parentIdentifier":"/us/usc/t22/s6821/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"This paragraph shall take effect upon the date the Secretary of the Treasury certifies to Congress that an agreement establishing the Trust Fund and providing for a United States member of the Board of Trustees is in effect.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Termination date","label":"ii Termination date","identifier":"/us/usc/t22/s6821/c/2/B/ii","parentIdentifier":"/us/usc/t22/s6821/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6821%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"The position established by subparagraph (A) is abolished upon the date of termination of the Trust Fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
