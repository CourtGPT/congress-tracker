{"type":"section","nativeType":"section","number":"3154","heading":"Special impact areas","label":"3154 Special impact areas","identifier":"/us/usc/t42/s3154","parentIdentifier":"/us/usc/t42/ch38/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s3154/a","parentIdentifier":"/us/usc/t42/s3154","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154%2Fa","sourceRelease":"119-100","text":"On the application of an eligible recipient that is determined by the Secretary to be unable to comply with the requirements of , the Secretary may waive, in whole or in part, the requirements of and designate the area represented by the recipient as a special impact area.section 3162 of this titlesection 3162 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Conditions","label":"b Conditions","identifier":"/us/usc/t42/s3154/b","parentIdentifier":"/us/usc/t42/s3154","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s3154/b/1","parentIdentifier":"/us/usc/t42/s3154/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154%2Fb%2F1","sourceRelease":"119-100","text":"the project will fulfill a pressing need of the area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s3154/b/2","parentIdentifier":"/us/usc/t42/s3154/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s3154/b/2/A","parentIdentifier":"/us/usc/t42/s3154/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154%2Fb%2F2%2FA","sourceRelease":"119-100","text":"be useful in alleviating or preventing conditions of excessive unemployment or underemployment; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s3154/b/2/B","parentIdentifier":"/us/usc/t42/s3154/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154%2Fb%2F2%2FB","sourceRelease":"119-100","text":"assist in providing useful employment opportunities for the unemployed or underemployed residents in the area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Notification","label":"c Notification","identifier":"/us/usc/t42/s3154/c","parentIdentifier":"/us/usc/t42/s3154","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154%2Fc","sourceRelease":"119-100","text":"At the time of the designation under subsection (a), the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a written notice of the designation, including a justification for the designation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
