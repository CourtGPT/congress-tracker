om any country unless that country has certified that such ivory was derived from legal sources; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s4223/5","parentIdentifier":"/us/usc/t16/s4223","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4223%2F5","sourceRelease":"119-100","text":"to import raw or worked ivory from a country for which a moratorium is in effect under .section 4222 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
