{"type":"section","nativeType":"section","number":"2062","heading":"Dental care","label":"2062 Dental care","identifier":"/us/usc/t38/s2062","parentIdentifier":"/us/usc/t38/ptII/ch20/schVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t38/s2062/a","parentIdentifier":"/us/usc/t38/s2062","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s2062/a/1","parentIdentifier":"/us/usc/t38/s2062/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062%2Fa%2F1","sourceRelease":"119-100","text":"the dental services and treatment are necessary for the veteran to successfully gain or regain employment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s2062/a/2","parentIdentifier":"/us/usc/t38/s2062/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062%2Fa%2F2","sourceRelease":"119-100","text":"the dental services and treatment are necessary to alleviate pain; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s2062/a/3","parentIdentifier":"/us/usc/t38/s2062/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062%2Fa%2F3","sourceRelease":"119-100","text":"the dental services and treatment are necessary for treatment of moderate, severe, or severe and complicated gingival and periodontal pathology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Eligible Veterans","label":"b .—Eligible Veterans","identifier":"/us/usc/t38/s2062/b","parentIdentifier":"/us/usc/t38/s2062","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s2062/b/1","parentIdentifier":"/us/usc/t38/s2062/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062%2Fb%2F1","sourceRelease":"119-100","text":"who is enrolled for care under ; andsection 1705(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s2062/b/2","parentIdentifier":"/us/usc/t38/s2062/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s2062/b/2/A","parentIdentifier":"/us/usc/t38/s2062/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062%2Fb%2F2%2FA","sourceRelease":"119-100","text":"A domiciliary under .section 1710 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s2062/b/2/B","parentIdentifier":"/us/usc/t38/s2062/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062%2Fb%2F2%2FB","sourceRelease":"119-100","text":"A therapeutic residence under .section 2032 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s2062/b/2/C","parentIdentifier":"/us/usc/t38/s2062/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062%2Fb%2F2%2FC","sourceRelease":"119-100","text":"Community residential care coordinated by the Secretary under .section 1730 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t38/s2062/b/2/D","parentIdentifier":"/us/usc/t38/s2062/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062%2Fb%2F2%2FD","sourceRelease":"119-100","text":"A setting for which the Secretary provides funds for a grant and per diem provider.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s2062/b/3","parentIdentifier":"/us/usc/t38/s2062/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062%2Fb%2F3","sourceRelease":"119-100","text":"For purposes of paragraph (2), in determining whether a veteran has received treatment for a period of 60 consecutive days, the Secretary may disregard breaks in the continuity of treatment for which the veteran is not responsible.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Limitation","label":"c .—Limitation","identifier":"/us/usc/t38/s2062/c","parentIdentifier":"/us/usc/t38/s2062","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2062%2Fc","sourceRelease":"119-100","text":"Dental benefits provided by reason of this section shall be a one-time course of dental care provided in the same manner as the dental benefits provided to a newly discharged veteran.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
