{"type":"section","nativeType":"section","number":"398","heading":"Military information support operations in information environment","label":"398 Military information support operations in information environment","identifier":"/us/usc/t10/s398","parentIdentifier":"/us/usc/t10/stA/ptI/ch19","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationAnother section 398 was renumbered .section 398a of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Congressional Notification Requirement","label":"a .—Congressional Notification Requirement","identifier":"/us/usc/t10/s398/a","parentIdentifier":"/us/usc/t10/s398","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s398/a/1","parentIdentifier":"/us/usc/t10/s398/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fa%2F1","sourceRelease":"119-100","text":"Not later than 48 hours after the execution of any new military information support operation plan (in this section referred to as a “MISO plan”) approved by the commander of a combatant command, or any change in scope of any existing MISO plan, including any underlying MISO supporting plan, the Secretary of Defense shall promptly submit to the congressional defense committees notice in writing of such approval or execution of change in scope.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s398/a/2","parentIdentifier":"/us/usc/t10/s398/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s398/a/2/A","parentIdentifier":"/us/usc/t10/s398/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fa%2F2%2FA","sourceRelease":"119-100","text":"A description of the military information support operation program (in this section referred to as a “MISO program”) supported by the MISO plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s398/a/2/B","parentIdentifier":"/us/usc/t10/s398/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fa%2F2%2FB","sourceRelease":"119-100","text":"A description of the objectives of the MISO plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s398/a/2/C","parentIdentifier":"/us/usc/t10/s398/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fa%2F2%2FC","sourceRelease":"119-100","text":"A description of the intended target audience for military information support operation activities under the MISO plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s398/a/2/D","parentIdentifier":"/us/usc/t10/s398/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fa%2F2%2FD","sourceRelease":"119-100","text":"A description of the tactics, techniques, and procedures to be used in executing the MISO plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t10/s398/a/2/E","parentIdentifier":"/us/usc/t10/s398/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fa%2F2%2FE","sourceRelease":"119-100","text":"A description of the personnel engaged in supporting or facilitating the operation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t10/s398/a/2/F","parentIdentifier":"/us/usc/t10/s398/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fa%2F2%2FF","sourceRelease":"119-100","text":"The amount of funding anticipated to be obligated and expended to execute the MISO plan during the current and subsequent fiscal years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t10/s398/a/2/G","parentIdentifier":"/us/usc/t10/s398/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fa%2F2%2FG","sourceRelease":"119-100","text":"The expected duration and desired outcome of the MISO plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t10/s398/a/2/H","parentIdentifier":"/us/usc/t10/s398/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fa%2F2%2FH","sourceRelease":"119-100","text":"Any other elements the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s398/a/3","parentIdentifier":"/us/usc/t10/s398/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fa%2F3","sourceRelease":"119-100","text":"To the maximum extent practicable, the Secretary shall ensure that the congressional defense committees are notified promptly of any unauthorized disclosure of a clandestine military support operation covered by this section. A notification under this subsection may be verbal or written, but in the event of a verbal notification, the Secretary shall provide a written notification by not later than 48 hours after the provision of the verbal notification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Annual Report","label":"b .—Annual Report","identifier":"/us/usc/t10/s398/b","parentIdentifier":"/us/usc/t10/s398","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s398/b/1","parentIdentifier":"/us/usc/t10/s398/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fb%2F1","sourceRelease":"119-100","text":"A list of each MISO program and the combatant command responsible for the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s398/b/2","parentIdentifier":"/us/usc/t10/s398/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s398/b/2/A","parentIdentifier":"/us/usc/t10/s398/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fb%2F2%2FA","sourceRelease":"119-100","text":"a description of the plan and any supporting plans, including the objectives for the plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s398/b/2/B","parentIdentifier":"/us/usc/t10/s398/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fb%2F2%2FB","sourceRelease":"119-100","text":"a description of the intended target audience for the activities carried out under the plan and the means of distribution; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s398/b/2/C","parentIdentifier":"/us/usc/t10/s398/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fb%2F2%2FC","sourceRelease":"119-100","text":"the cost of executing the plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Prohibition on Clandestine Operations Designed to Influence Opinions and Politics in United States","label":"c .—Prohibition on Clandestine Operations Designed to Influence Opinions and Politics in United States","identifier":"/us/usc/t10/s398/c","parentIdentifier":"/us/usc/t10/s398","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s398/c/1","parentIdentifier":"/us/usc/t10/s398/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fc%2F1","sourceRelease":"119-100","text":"any political process taking place in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s398/c/2","parentIdentifier":"/us/usc/t10/s398/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fc%2F2","sourceRelease":"119-100","text":"the opinions of United States persons;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s398/c/3","parentIdentifier":"/us/usc/t10/s398/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fc%2F3","sourceRelease":"119-100","text":"United States policies; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s398/c/4","parentIdentifier":"/us/usc/t10/s398/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs398%2Fc%2F4","sourceRelease":"119-100","text":"media produced by United States entities for United States persons.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
