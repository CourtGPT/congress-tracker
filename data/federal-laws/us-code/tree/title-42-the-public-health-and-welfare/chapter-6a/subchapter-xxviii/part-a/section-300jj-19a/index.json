":"/us/usc/t42/s300jj–19a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F2%2FJ","sourceRelease":"119-100","text":"public and private entities engaged in the evaluation of health information technology performance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"K","heading":null,"label":"K","identifier":"/us/usc/t42/s300jj–19a/a/2/K","parentIdentifier":"/us/usc/t42/s300jj–19a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F2%2FK","sourceRelease":"119-100","text":"quality organizations, including the consensus based entity described in ;section 1395aaa of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"L","heading":null,"label":"L","identifier":"/us/usc/t42/s300jj–19a/a/2/L","parentIdentifier":"/us/usc/t42/s300jj–19a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F2%2FL","sourceRelease":"119-100","text":"experts in human factors engineering and the measurement of user-centered design; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"M","heading":null,"label":"M","identifier":"/us/usc/t42/s300jj–19a/a/2/M","parentIdentifier":"/us/usc/t42/s300jj–19a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F2%2FM","sourceRelease":"119-100","text":"other entities or individuals, as the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Considerations for reporting criteria","label":"3 Considerations for reporting criteria","identifier":"/us/usc/t42/s300jj–19a/a/3","parentIdentifier":"/us/usc/t42/s300jj–19a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300jj–19a/a/3/A","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300jj–19a/a/3/A/i","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FA%2Fi","sourceRelease":"119-100","text":"security;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300jj–19a/a/3/A/ii","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FA%2Fii","sourceRelease":"119-100","text":"usability and user-centered design;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s300jj–19a/a/3/A/iii","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"interoperability;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s300jj–19a/a/3/A/iv","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FA%2Fiv","sourceRelease":"119-100","text":"conformance to certification testing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s300jj–19a/a/3/A/v","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FA%2Fv","sourceRelease":"119-100","text":"other categories, as appropriate to measure the performance of electronic health record technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300jj–19a/a/3/B","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300jj–19a/a/3/B/i","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FB%2Fi","sourceRelease":"119-100","text":"enabling the user to order and view the results of laboratory tests, imaging tests, and other diagnostic tests;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300jj–19a/a/3/B/ii","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FB%2Fii","sourceRelease":"119-100","text":"submitting, editing, and retrieving data from registries such as clinician-led clinical data registries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s300jj–19a/a/3/B/iii","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"accessing and exchanging information and data from and through health information exchanges;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s300jj–19a/a/3/B/iv","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FB%2Fiv","sourceRelease":"119-100","text":"accessing and exchanging information and data from medical devices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s300jj–19a/a/3/B/v","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FB%2Fv","sourceRelease":"119-100","text":"accessing and exchanging information and data held by Federal, State, and local agencies and other applicable entities useful to a health care provider or other applicable user in the furtherance of patient care;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s300jj–19a/a/3/B/vi","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FB%2Fvi","sourceRelease":"119-100","text":"accessing and exchanging information from other health care providers or applicable users;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t42/s300jj–19a/a/3/B/vii","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FB%2Fvii","sourceRelease":"119-100","text":"accessing and exchanging patient generated information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t42/s300jj–19a/a/3/B/viii","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FB%2Fviii","sourceRelease":"119-100","text":"providing the patient or an authorized designee with a complete copy of their health information from an electronic record in a computable format;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ix","heading":null,"label":"ix","identifier":"/us/usc/t42/s300jj–19a/a/3/B/ix","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FB%2Fix","sourceRelease":"119-100","text":"providing accurate patient information for the correct patient, including exchanging such information, and avoiding the duplication of patients records; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"x","heading":null,"label":"x","identifier":"/us/usc/t42/s300jj–19a/a/3/B/x","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FB%2Fx","sourceRelease":"119-100","text":"other categories regarding performance, accessibility, as the Secretary determines appropriate; and1So in original. Probably should be “performance or accessibility,”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300jj–19a/a/3/C","parentIdentifier":"/us/usc/t42/s300jj–19a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F3%2FC","sourceRelease":"119-100","text":"shall be designed to ensure that small and startup health information technology developers are not unduly disadvantaged by the reporting criteria.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Modifications","label":"4 Modifications","identifier":"/us/usc/t42/s300jj–19a/a/4","parentIdentifier":"/us/usc/t42/s300jj–19a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fa%2F4","sourceRelease":"119-100","text":"After the reporting criteria have been developed under paragraph (3), the Secretary may convene stakeholders and conduct a public comment period for the purpose of modifying the reporting criteria developed under such paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Participation","label":"b Participation","identifier":"/us/usc/t42/s300jj–19a/b","parentIdentifier":"/us/usc/t42/s300jj–19a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fb","sourceRelease":"119-100","text":"As a condition of maintaining certification under , a developer of certified electronic health records shall submit to an appropriate recipient of a grant, contract, or agreement under subsection (c)(1) responses to the criteria developed under subsection (a), with respect to all certified technology offered by such developer.section 300jj–11(c)(5)(D) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Reporting program","label":"c Reporting program","identifier":"/us/usc/t42/s300jj–19a/c","parentIdentifier":"/us/usc/t42/s300jj–19a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s300jj–19a/c/1","parentIdentifier":"/us/usc/t42/s300jj–19a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F1","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary shall award grants, contracts, or agreements to independent entities on a competitive basis to support the convening of stakeholders as described in subsection (a)(2), collect the information required to be reported in accordance with the criteria established as described subsection (a)(3), and develop and implement a process in accordance with paragraph (5) and report such information to the Secretary.December 13, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Applications","label":"2 Applications","identifier":"/us/usc/t42/s300jj–19a/c/2","parentIdentifier":"/us/usc/t42/s300jj–19a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300jj–19a/c/2/A","parentIdentifier":"/us/usc/t42/s300jj–19a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the proposed method for reviewing and summarizing information gathered based on reporting criteria established under subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300jj–19a/c/2/B","parentIdentifier":"/us/usc/t42/s300jj–19a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F2%2FB","sourceRelease":"119-100","text":"if applicable, the intended focus on a specific subset of certified electronic health record technology users, such as health care providers, including primary care, specialty care, and care provided in rural settings; hospitals and hospital systems; and patients, consumers, and patients and consumer advocates;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300jj–19a/c/2/C","parentIdentifier":"/us/usc/t42/s300jj–19a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F2%2FC","sourceRelease":"119-100","text":"the plan for widely distributing reports described in paragraph (6);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s300jj–19a/c/2/D","parentIdentifier":"/us/usc/t42/s300jj–19a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F2%2FD","sourceRelease":"119-100","text":"the period for which the grant, contract, or agreement is requested, which may be up to 2 years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s300jj–19a/c/2/E","parentIdentifier":"/us/usc/t42/s300jj–19a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F2%2FE","sourceRelease":"119-100","text":"the budget for reporting program participation, and whether the eligible independent entity intends to continue participation after the period of the grant, contract, or agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Considerations for independent entities","label":"3 Considerations for independent entities","identifier":"/us/usc/t42/s300jj–19a/c/3","parentIdentifier":"/us/usc/t42/s300jj–19a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300jj–19a/c/3/A","parentIdentifier":"/us/usc/t42/s300jj–19a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F3%2FA","sourceRelease":"119-100","text":"health care providers, including primary care, specialty care, and care provided in rural settings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300jj–19a/c/3/B","parentIdentifier":"/us/usc/t42/s300jj–19a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F3%2FB","sourceRelease":"119-100","text":"hospitals and hospital systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300jj–19a/c/3/C","parentIdentifier":"/us/usc/t42/s300jj–19a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F3%2FC","sourceRelease":"119-100","text":"patients, consumers, and patient and consumer advocates.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Limitations","label":"4 Limitations","identifier":"/us/usc/t42/s300jj–19a/c/4","parentIdentifier":"/us/usc/t42/s300jj–19a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Assessment and redetermination","label":"A Assessment and redetermination","identifier":"/us/usc/t42/s300jj–19a/c/4/A","parentIdentifier":"/us/usc/t42/s300jj–19a/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300jj–19a/c/4/A/i","parentIdentifier":"/us/usc/t42/s300jj–19a/c/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F4%2FA%2Fi","sourceRelease":"119-100","text":"assess performance of the recipients of the grants, contracts, and agreements under paragraph (1) based on quality and usability of reports described in paragraph (6); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300jj–19a/c/4/A/ii","parentIdentifier":"/us/usc/t42/s300jj–19a/c/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F4%2FA%2Fii","sourceRelease":"119-100","text":"re-determine grants, contracts, and agreements as necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Prohibitions on participation","label":"B Prohibitions on participation","identifier":"/us/usc/t42/s300jj–19a/c/4/B","parentIdentifier":"/us/usc/t42/s300jj–19a/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300jj–19a/c/4/B/i","parentIdentifier":"/us/usc/t42/s300jj–19a/c/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F4%2FB%2Fi","sourceRelease":"119-100","text":"a proprietor of certified health information technology or a business affiliate of such a proprietor;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300jj–19a/c/4/B/ii","parentIdentifier":"/us/usc/t42/s300jj–19a/c/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F4%2FB%2Fii","sourceRelease":"119-100","text":"a developer of certified health information technology; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s300jj–19a/c/4/B/iii","parentIdentifier":"/us/usc/t42/s300jj–19a/c/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F4%2FB%2Fiii","sourceRelease":"119-100","text":"a State or local government agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Feedback","label":"5 Feedback","identifier":"/us/usc/t42/s300jj–19a/c/5","parentIdentifier":"/us/usc/t42/s300jj–19a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300jj–19a/c/5/A","parentIdentifier":"/us/usc/t42/s300jj–19a/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F5%2FA","sourceRelease":"119-100","text":"health care providers, patients, and other users of certified electronic health record technology; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300jj–19a/c/5/B","parentIdentifier":"/us/usc/t42/s300jj–19a/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F5%2FB","sourceRelease":"119-100","text":"developers of certified electronic health record technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Reports","label":"6 Reports","identifier":"/us/usc/t42/s300jj–19a/c/6","parentIdentifier":"/us/usc/t42/s300jj–19a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Development of reports","label":"A Development of reports","identifier":"/us/usc/t42/s300jj–19a/c/6/A","parentIdentifier":"/us/usc/t42/s300jj–19a/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F6%2FA","sourceRelease":"119-100","text":"Each recipient of a grant, contract, or agreement under paragraph (1) shall report on the information reported to such recipient pursuant to subsection (a) and the user feedback collected under paragraph (5) by preparing summary reports and detailed reports of such information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Distribution of reports","label":"B Distribution of reports","identifier":"/us/usc/t42/s300jj–19a/c/6/B","parentIdentifier":"/us/usc/t42/s300jj–19a/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fc%2F6%2FB","sourceRelease":"119-100","text":"Each recipient of a grant, contract, or agreement under paragraph (1) shall submit the reports prepared under subparagraph (A) to the Secretary for public distribution in accordance with subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Publication","label":"d Publication","identifier":"/us/usc/t42/s300jj–19a/d","parentIdentifier":"/us/usc/t42/s300jj–19a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300jj–19a/d/1","parentIdentifier":"/us/usc/t42/s300jj–19a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fd%2F1","sourceRelease":"119-100","text":"the reporting criteria developed under subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300jj–19a/d/2","parentIdentifier":"/us/usc/t42/s300jj–19a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fd%2F2","sourceRelease":"119-100","text":"the summary and detailed reports under subsection (c)(6).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Review","label":"e Review","identifier":"/us/usc/t42/s300jj–19a/e","parentIdentifier":"/us/usc/t42/s300jj–19a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Fe","sourceRelease":"119-100","text":"Each recipient of a grant, contract, or agreement under paragraph (1) shall develop and implement a process through which participating electronic health record technology developers may review and recommend changes to the reports created under subsection (c)(6) for products developed by such developer prior to the publication of such report under subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Additional resources","label":"f Additional resources","identifier":"/us/usc/t42/s300jj–19a/f","parentIdentifier":"/us/usc/t42/s300jj–19a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9319a%2Ff","sourceRelease":"119-100","text":"The Secretary may provide additional resources on the Internet website of the Office of the National Coordinator to better inform consumers of health information technology. Such reports may be carried out through partnerships with private organizations with appropriate expertise.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
