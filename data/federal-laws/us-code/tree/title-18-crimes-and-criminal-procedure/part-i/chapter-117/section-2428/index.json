{"type":"section","nativeType":"section","number":"2428","heading":"Forfeitures","label":"2428 Forfeitures","identifier":"/us/usc/t18/s2428","parentIdentifier":"/us/usc/t18/ptI/ch117","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2428","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t18/s2428/a","parentIdentifier":"/us/usc/t18/s2428","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2428%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2428/a/1","parentIdentifier":"/us/usc/t18/s2428/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2428%2Fa%2F1","sourceRelease":"119-100","text":"such person’s interest in any property, real or personal, that was used or intended to be used to commit or to facilitate the commission of such violation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2428/a/2","parentIdentifier":"/us/usc/t18/s2428/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2428%2Fa%2F2","sourceRelease":"119-100","text":"any property, real or personal, constituting or derived from any proceeds that such person obtained, directly or indirectly, as a result of such violation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Property Subject to Forfeiture.—","label":"b Property Subject to Forfeiture.—","identifier":"/us/usc/t18/s2428/b","parentIdentifier":"/us/usc/t18/s2428","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2428%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t18/s2428/b/1","parentIdentifier":"/us/usc/t18/s2428/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2428%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s2428/b/1/A","parentIdentifier":"/us/usc/t18/s2428/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2428%2Fb%2F1%2FA","sourceRelease":"119-100","text":"Any property, real or personal, used or intended to be used to commit or to facilitate the commission of any violation of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s2428/b/1/B","parentIdentifier":"/us/usc/t18/s2428/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2428%2Fb%2F1%2FB","sourceRelease":"119-100","text":"Any property, real or personal, that constitutes or is derived from proceeds traceable to any violation of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Applicability of chapter 46","label":"2 .—Applicability of chapter 46","identifier":"/us/usc/t18/s2428/b/2","parentIdentifier":"/us/usc/t18/s2428/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2428%2Fb%2F2","sourceRelease":"119-100","text":"The provisions of chapter 46 of this title relating to civil forfeitures shall apply to any seizure or civil forfeiture under this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
