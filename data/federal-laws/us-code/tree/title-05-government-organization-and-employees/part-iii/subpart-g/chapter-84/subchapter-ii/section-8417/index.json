{"type":"section","nativeType":"section","number":"8417","heading":"Survivor reduction for a former spouse","label":"8417 Survivor reduction for a former spouse","identifier":"/us/usc/t5/s8417","parentIdentifier":"/us/usc/t5/ptIII/sptG/ch84/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8417","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s8417/a","parentIdentifier":"/us/usc/t5/s8417","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8417%2Fa","sourceRelease":"119-100","text":"If an employee or Member has a former spouse who is entitled to a survivor annuity as provided in section 8445, the reduction described in section 8419(a) shall be made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s8417/b","parentIdentifier":"/us/usc/t5/s8417","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8417%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s8417/b/1","parentIdentifier":"/us/usc/t5/s8417/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8417%2Fb%2F1","sourceRelease":"119-100","text":"An employee or Member who has a former spouse may elect, under procedures prescribed by the Office, a reduction in the annuity of the employee or Member under section 8419(a) in order to provide a survivor annuity for such former spouse under section 8445.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s8417/b/2","parentIdentifier":"/us/usc/t5/s8417/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8417%2Fb%2F2","sourceRelease":"119-100","text":"An election under this subsection shall be made at the time of retirement or, if the marriage is dissolved after the date of retirement, within 2 years after the date on which the marriage of the former spouse to the employee or Member is so dissolved.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s8417/b/3","parentIdentifier":"/us/usc/t5/s8417/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8417%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s8417/b/3/A","parentIdentifier":"/us/usc/t5/s8417/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8417%2Fb%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t5/s8417/b/3/A/i","parentIdentifier":"/us/usc/t5/s8417/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8417%2Fb%2F3%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t5/s8417/b/3/A/i/I","parentIdentifier":"/us/usc/t5/s8417/b/3/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8417%2Fb%2F3%2FA%2Fi%2FI","sourceRelease":"119-100","text":"any court order or decree referred to in section 8445(a) which was issued before the date of such election; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t5/s8417/b/3/A/i/II","parentIdentifier":"/us/usc/t5/s8417/b/3/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8417%2Fb%2F3%2FA%2Fi%2FII","sourceRelease":"119-100","text":"any agreement referred to in such section 8445(a) which was entered into before such date; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t5/s8417/b/3/A/ii","parentIdentifier":"/us/usc/t5/s8417/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8417%2Fb%2F3%2FA%2Fii","sourceRelease":"119-100","text":"would cause the total of survivor annuities payable under sections 8442 and 8445, respectively, based on the service of the employee or Member to exceed the amount which would be payable to a widow or widower of such employee or Member under such section 8442 (determined without regard to any reduction to provide for an annuity under such section 8445); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s8417/b/3/B","parentIdentifier":"/us/usc/t5/s8417/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8417%2Fb%2F3%2FB","sourceRelease":"119-100","text":"shall not be effective, in the case of an employee or Member who is then married, unless it is made with the spouse’s written consent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
