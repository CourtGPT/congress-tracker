{"type":"section","nativeType":"section","number":"4041","heading":"Enforcement by the Attorney General","label":"4041 Enforcement by the Attorney General","identifier":"/us/usc/t50/s4041","parentIdentifier":"/us/usc/t50/ch50/schVIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4041","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to section 597 of the former Appendix to this title prior to editorial reclassification and renumbering as this section."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Civil action","label":"a Civil action","identifier":"/us/usc/t50/s4041/a","parentIdentifier":"/us/usc/t50/s4041","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4041%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s4041/a/1","parentIdentifier":"/us/usc/t50/s4041/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4041%2Fa%2F1","sourceRelease":"119-100","text":"engages in a pattern or practice of violating this chapter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s4041/a/2","parentIdentifier":"/us/usc/t50/s4041/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4041%2Fa%2F2","sourceRelease":"119-100","text":"engages in a violation of this chapter that raises an issue of significant public importance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Relief","label":"b Relief","identifier":"/us/usc/t50/s4041/b","parentIdentifier":"/us/usc/t50/s4041","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4041%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s4041/b/1","parentIdentifier":"/us/usc/t50/s4041/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4041%2Fb%2F1","sourceRelease":"119-100","text":"grant any appropriate equitable or declaratory relief with respect to the violation of this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s4041/b/2","parentIdentifier":"/us/usc/t50/s4041/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4041%2Fb%2F2","sourceRelease":"119-100","text":"award all other appropriate relief, including monetary damages, to any person aggrieved by the violation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s4041/b/3","parentIdentifier":"/us/usc/t50/s4041/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4041%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s4041/b/3/A","parentIdentifier":"/us/usc/t50/s4041/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4041%2Fb%2F3%2FA","sourceRelease":"119-100","text":"in an amount not exceeding $55,000 for a first violation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s4041/b/3/B","parentIdentifier":"/us/usc/t50/s4041/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4041%2Fb%2F3%2FB","sourceRelease":"119-100","text":"in an amount not exceeding $110,000 for any subsequent violation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Intervention","label":"c Intervention","identifier":"/us/usc/t50/s4041/c","parentIdentifier":"/us/usc/t50/s4041","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4041%2Fc","sourceRelease":"119-100","text":"Upon timely application, a person aggrieved by a violation of this chapter with respect to which the civil action is commenced may intervene in such action, and may obtain such appropriate relief as the person could obtain in a civil action under with respect to that violation, along with costs and a reasonable attorney fee.section 4042 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
