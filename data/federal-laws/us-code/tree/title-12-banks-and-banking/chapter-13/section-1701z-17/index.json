ch on the default risk of such mortgages; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t12/s1701z–17/b/1/E","parentIdentifier":"/us/usc/t12/s1701z–17/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1701z%E2%80%9317%2Fb%2F1%2FE","sourceRelease":"119-100","text":"the availability of certified or accredited home energy rating services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report to Congress","label":"2 Report to Congress","identifier":"/us/usc/t12/s1701z–17/b/2","parentIdentifier":"/us/usc/t12/s1701z–17/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1701z%E2%80%9317%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s1701z–17/b/2/A","parentIdentifier":"/us/usc/t12/s1701z–17/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1701z%E2%80%9317%2Fb%2F2%2FA","sourceRelease":"119-100","text":"summarizes the recommendations developed under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s1701z–17/b/2/B","parentIdentifier":"/us/usc/t12/s1701z–17/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs1701z%E2%80%9317%2Fb%2F2%2FB","sourceRelease":"119-100","text":"includes any recommendations for statutory, regulatory, or administrative changes that the Secretary deems necessary to institute such recommendations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subse