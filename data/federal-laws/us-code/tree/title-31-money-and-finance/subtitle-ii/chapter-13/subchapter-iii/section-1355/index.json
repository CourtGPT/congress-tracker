{"type":"section","nativeType":"section","number":"1355","heading":"Prohibition on use of funds for portraits","label":"1355 Prohibition on use of funds for portraits","identifier":"/us/usc/t31/s1355","parentIdentifier":"/us/usc/t31/stII/ch13/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs1355","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t31/s1355/a","parentIdentifier":"/us/usc/t31/s1355","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs1355%2Fa","sourceRelease":"119-100","text":"No funds appropriated or otherwise made available to the Federal Government may be used to pay for the painting of a portrait of an officer or employee of the Federal Government, including the President, the Vice President, a Member of Congress, the head of an executive agency, or the head of an office of the legislative branch.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t31/s1355/b","parentIdentifier":"/us/usc/t31/s1355","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs1355%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t31/s1355/b/1","parentIdentifier":"/us/usc/t31/s1355/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs1355%2Fb%2F1","sourceRelease":"119-100","text":"the term “executive agency” has the meaning given the term in ; andsection 133 of title 41","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t31/s1355/b/2","parentIdentifier":"/us/usc/t31/s1355/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs1355%2Fb%2F2","sourceRelease":"119-100","text":"the term “Member of Congress” includes a Delegate or Resident Commissioner to Congress.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
