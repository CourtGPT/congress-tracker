{"type":"section","nativeType":"section","number":"20405","heading":"Force shaping authority","label":"20405 Force shaping authority","identifier":"/us/usc/t10/s20405","parentIdentifier":"/us/usc/t10/stF/ptI/ch2009","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20405","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Authority","label":"a .—Authority","identifier":"/us/usc/t10/s20405/a","parentIdentifier":"/us/usc/t10/s20405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20405%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s20405/a/1","parentIdentifier":"/us/usc/t10/s20405/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20405%2Fa%2F1","sourceRelease":"119-100","text":"discharge an officer described in subsection (b); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s20405/a/2","parentIdentifier":"/us/usc/t10/s20405/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20405%2Fa%2F2","sourceRelease":"119-100","text":"involuntarily release such an officer from sustained duty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Covered Officers.—","label":"b Covered Officers.—","identifier":"/us/usc/t10/s20405/b","parentIdentifier":"/us/usc/t10/s20405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20405%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s20405/b/1","parentIdentifier":"/us/usc/t10/s20405/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20405%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s20405/b/1/A","parentIdentifier":"/us/usc/t10/s20405/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20405%2Fb%2F1%2FA","sourceRelease":"119-100","text":"has completed not more than six years of service as a commissioned officer in the armed forces; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s20405/b/1/B","parentIdentifier":"/us/usc/t10/s20405/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20405%2Fb%2F1%2FB","sourceRelease":"119-100","text":"has completed more than six years of service as a commissioned officer in the armed forces, but has not completed the minimum service obligation applicable to that officer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s20405/b/2","parentIdentifier":"/us/usc/t10/s20405/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20405%2Fb%2F2","sourceRelease":"119-100","text":"In this subsection, the term “minimum service obligation”, with respect to a member of the Space Force, means the initial period of required active duty service applicable to the member, together with any additional period of required active duty service incurred by that member during the member’s initial period of required active duty service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Regulations","label":"c .—Regulations","identifier":"/us/usc/t10/s20405/c","parentIdentifier":"/us/usc/t10/s20405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20405%2Fc","sourceRelease":"119-100","text":"The Secretary of the Air Force shall prescribe regulations for the exercise of the Secretary’s authority under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
