{"type":"section","nativeType":"section","number":"4808","heading":"National Pork Board","label":"4808 National Pork Board","identifier":"/us/usc/t7/s4808","parentIdentifier":"/us/usc/t7/ch79","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , see , set out as a note under .Jan. 1, 1986section 1631 of Pub. L. 99–198section 4801 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t7/s4808/a","parentIdentifier":"/us/usc/t7/s4808","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s4808/a/1","parentIdentifier":"/us/usc/t7/s4808/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fa%2F1","sourceRelease":"119-100","text":"The order shall provide for the establishment and appointment by the Secretary of a 15-member National Pork Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s4808/a/2","parentIdentifier":"/us/usc/t7/s4808/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fa%2F2","sourceRelease":"119-100","text":"The Board shall consist of producers representing at least 12 States and importers appointed by the Secretary from nominations submitted under .1section 4806(g) of this titleSo in original. Two pars. (2) have been enacted.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s4808/a/2","parentIdentifier":"/us/usc/t7/s4808/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fa%2F2","sourceRelease":"119-100","text":"The Board shall consist of producers or importers appointed by the Secretary from nominations submitted under .1section 4806(g) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s4808/a/3","parentIdentifier":"/us/usc/t7/s4808/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fa%2F3","sourceRelease":"119-100","text":"A member of the Board shall serve for a 3-year term, with no such member serving more than two consecutive 3-year terms, except that initial appointments to the Board shall be staggered with an equal number of members appointed, to the maximum extent possible, to 1-year, 2-year, and 3-year terms, except that the term of a member of the Board shall continue until the successor of such member, if any, is appointed in accordance with paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s4808/a/4","parentIdentifier":"/us/usc/t7/s4808/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fa%2F4","sourceRelease":"119-100","text":"The Board shall select its President by a majority vote.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s4808/a/5","parentIdentifier":"/us/usc/t7/s4808/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s4808/a/5/A","parentIdentifier":"/us/usc/t7/s4808/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fa%2F5%2FA","sourceRelease":"119-100","text":"A majority of the members of the Board shall constitute a quorum at a meeting of the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s4808/a/5/B","parentIdentifier":"/us/usc/t7/s4808/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fa%2F5%2FB","sourceRelease":"119-100","text":"A majority of votes cast at a meeting at which a quorum is present shall determine a motion or election.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s4808/a/6","parentIdentifier":"/us/usc/t7/s4808/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fa%2F6","sourceRelease":"119-100","text":"A member of the Board shall serve without compensation, but shall be reimbursed by the Board from assessments collected under for reasonable expenses incurred in performing duties as a member of the Board.section 4809 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t7/s4808/b","parentIdentifier":"/us/usc/t7/s4808","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s4808/b/1","parentIdentifier":"/us/usc/t7/s4808/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s4808/b/1/A","parentIdentifier":"/us/usc/t7/s4808/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F1%2FA","sourceRelease":"119-100","text":"develop, at the initiative of the Board or other person, proposals for promotion, research, and consumer information plans and projects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s4808/b/1/B","parentIdentifier":"/us/usc/t7/s4808/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F1%2FB","sourceRelease":"119-100","text":"submit such plans and projects to the Secretary for approval;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s4808/b/1/C","parentIdentifier":"/us/usc/t7/s4808/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F1%2FC","sourceRelease":"119-100","text":"administer the order, in accordance with the order and this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s4808/b/1/D","parentIdentifier":"/us/usc/t7/s4808/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F1%2FD","sourceRelease":"119-100","text":"prescribe such rules as are necessary to carry out such order;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s4808/b/1/E","parentIdentifier":"/us/usc/t7/s4808/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F1%2FE","sourceRelease":"119-100","text":"receive, investigate, and report to the Secretary complaints of violations of such order;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t7/s4808/b/1/F","parentIdentifier":"/us/usc/t7/s4808/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F1%2FF","sourceRelease":"119-100","text":"make recommendations to the Secretary with respect to amendments to such order; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t7/s4808/b/1/G","parentIdentifier":"/us/usc/t7/s4808/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F1%2FG","sourceRelease":"119-100","text":"employ a staff and conduct routine business.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s4808/b/2","parentIdentifier":"/us/usc/t7/s4808/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s4808/b/2/A","parentIdentifier":"/us/usc/t7/s4808/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F2%2FA","sourceRelease":"119-100","text":"any promotion, research or consumer information plan or project to be conducted by the Board directly or by way of contract or agreement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s4808/b/2/B","parentIdentifier":"/us/usc/t7/s4808/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the budgets, plans, or projects for which State associations are to receive funds pursuant to .section 4809(c)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s4808/b/3","parentIdentifier":"/us/usc/t7/s4808/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F3","sourceRelease":"119-100","text":"No plan, project, or budget referred to in paragraph (1) or (2) may become effective unless approved by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s4808/b/4","parentIdentifier":"/us/usc/t7/s4808/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s4808/b/4/A","parentIdentifier":"/us/usc/t7/s4808/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s4808/b/4/A/i","parentIdentifier":"/us/usc/t7/s4808/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F4%2FA%2Fi","sourceRelease":"119-100","text":"the development and conduct of activities authorized under an order; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s4808/b/4/A/ii","parentIdentifier":"/us/usc/t7/s4808/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F4%2FA%2Fii","sourceRelease":"119-100","text":"the payment of the cost thereof with funds collected through assessments under such order.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s4808/b/4/B","parentIdentifier":"/us/usc/t7/s4808/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s4808/b/4/B/i","parentIdentifier":"/us/usc/t7/s4808/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F4%2FB%2Fi","sourceRelease":"119-100","text":"the contracting party develop and submit to the Board a plan or project, together with a budget or budgets that include the estimated cost to be incurred under such plan or project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s4808/b/4/B/ii","parentIdentifier":"/us/usc/t7/s4808/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F4%2FB%2Fii","sourceRelease":"119-100","text":"such plan or project become effective on the approval of the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s4808/b/4/B/iii","parentIdentifier":"/us/usc/t7/s4808/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F4%2FB%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s4808/b/4/B/iii/I","parentIdentifier":"/us/usc/t7/s4808/b/4/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F4%2FB%2Fiii%2FI","sourceRelease":"119-100","text":"keep accurate records of all relevant transactions of the party;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s4808/b/4/B/iii/II","parentIdentifier":"/us/usc/t7/s4808/b/4/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F4%2FB%2Fiii%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t7/s4808/b/4/B/iii/II/aa","parentIdentifier":"/us/usc/t7/s4808/b/4/B/iii/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F4%2FB%2Fiii%2FII%2Faa","sourceRelease":"119-100","text":"relevant activities the party has conducted; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t7/s4808/b/4/B/iii/II/bb","parentIdentifier":"/us/usc/t7/s4808/b/4/B/iii/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F4%2FB%2Fiii%2FII%2Fbb","sourceRelease":"119-100","text":"an accounting for funds received and expended under such contract; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t7/s4808/b/4/B/iii/III","parentIdentifier":"/us/usc/t7/s4808/b/4/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4808%2Fb%2F4%2FB%2Fiii%2FIII","sourceRelease":"119-100","text":"make such other reports as the Secretary or Board may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}]}
