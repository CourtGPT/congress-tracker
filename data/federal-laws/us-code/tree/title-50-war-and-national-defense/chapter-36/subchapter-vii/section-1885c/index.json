{"type":"section","nativeType":"section","number":"1885c","heading":"Reporting","label":"1885c Reporting","identifier":"/us/usc/t50/s1885c","parentIdentifier":"/us/usc/t50/ch36/schVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs1885c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Semiannual report","label":"a Semiannual report","identifier":"/us/usc/t50/s1885c/a","parentIdentifier":"/us/usc/t50/s1885c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs1885c%2Fa","sourceRelease":"119-100","text":"Not less frequently than once every 6 months, the Attorney General shall, in a manner consistent with national security, the Rules of the House of Representatives, the Standing Rules of the Senate, and Senate Resolution 400 of the 94th Congress or any successor Senate resolution, fully inform the congressional intelligence committees, the Committee on the Judiciary of the Senate, and the Committee on the Judiciary of the House of Representatives concerning the implementation of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Content","label":"b Content","identifier":"/us/usc/t50/s1885c/b","parentIdentifier":"/us/usc/t50/s1885c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs1885c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s1885c/b/1","parentIdentifier":"/us/usc/t50/s1885c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs1885c%2Fb%2F1","sourceRelease":"119-100","text":"any certifications made under ;section 1885a of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s1885c/b/2","parentIdentifier":"/us/usc/t50/s1885c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs1885c%2Fb%2F2","sourceRelease":"119-100","text":"a description of the judicial review of the certifications made under ; andsection 1885a of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s1885c/b/3","parentIdentifier":"/us/usc/t50/s1885c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs1885c%2Fb%2F3","sourceRelease":"119-100","text":"any actions taken to enforce the provisions of .section 1885b of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
