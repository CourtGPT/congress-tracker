{"type":"section","nativeType":"section","number":"10103","heading":"Reports to Congress","label":"10103 Reports to Congress","identifier":"/us/usc/t22/s10103","parentIdentifier":"/us/usc/t22/ch108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly set out in a note under .section 2656 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s10103/a","parentIdentifier":"/us/usc/t22/s10103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10103/a/1","parentIdentifier":"/us/usc/t22/s10103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fa%2F1","sourceRelease":"119-100","text":"a list of each foreign person with respect to which the President imposed sanctions pursuant to during the year preceding the submission of the report;section 10102 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10103/a/2","parentIdentifier":"/us/usc/t22/s10103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fa%2F2","sourceRelease":"119-100","text":"a description of the type of sanctions imposed with respect to each such person;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s10103/a/3","parentIdentifier":"/us/usc/t22/s10103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10103/a/3/A","parentIdentifier":"/us/usc/t22/s10103/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fa%2F3%2FA","sourceRelease":"119-100","text":"imposed sanctions under during that year; andsection 10102(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10103/a/3/B","parentIdentifier":"/us/usc/t22/s10103/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fa%2F3%2FB","sourceRelease":"119-100","text":"terminated sanctions under during that year;section 10102(g) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s10103/a/4","parentIdentifier":"/us/usc/t22/s10103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fa%2F4","sourceRelease":"119-100","text":"the dates on which such sanctions were imposed or terminated, as the case may be;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s10103/a/5","parentIdentifier":"/us/usc/t22/s10103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fa%2F5","sourceRelease":"119-100","text":"the reasons for imposing or terminating such sanctions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s10103/a/6","parentIdentifier":"/us/usc/t22/s10103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fa%2F6","sourceRelease":"119-100","text":"a description of the efforts of the President to encourage the governments of other countries to impose sanctions that are similar to the sanctions authorized by .section 10102 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Dates for submission","label":"b Dates for submission","identifier":"/us/usc/t22/s10103/b","parentIdentifier":"/us/usc/t22/s10103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Initial report","label":"1 Initial report","identifier":"/us/usc/t22/s10103/b/1","parentIdentifier":"/us/usc/t22/s10103/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fb%2F1","sourceRelease":"119-100","text":"The President shall submit the initial report under subsection (a) not later than 120 days after .December 23, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Subsequent reports","label":"2 Subsequent reports","identifier":"/us/usc/t22/s10103/b/2","parentIdentifier":"/us/usc/t22/s10103/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t22/s10103/b/2/A","parentIdentifier":"/us/usc/t22/s10103/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s10103/b/2/A/i","parentIdentifier":"/us/usc/t22/s10103/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the calendar year in which the initial report is submitted if the initial report is submitted before December 10 of that calendar year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s10103/b/2/A/ii","parentIdentifier":"/us/usc/t22/s10103/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"each calendar year thereafter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Congressional statement","label":"B Congressional statement","identifier":"/us/usc/t22/s10103/b/2/B","parentIdentifier":"/us/usc/t22/s10103/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fb%2F2%2FB","sourceRelease":"119-100","text":"Congress notes that December 10 of each calendar year has been recognized in the United States and internationally since 1950 as “Human Rights Day”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Form of report","label":"c Form of report","identifier":"/us/usc/t22/s10103/c","parentIdentifier":"/us/usc/t22/s10103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s10103/c/1","parentIdentifier":"/us/usc/t22/s10103/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fc%2F1","sourceRelease":"119-100","text":"Each report required by subsection (a) shall be submitted in unclassified form, but may include a classified annex.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Exception","label":"2 Exception","identifier":"/us/usc/t22/s10103/c/2","parentIdentifier":"/us/usc/t22/s10103/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10103/c/2/A","parentIdentifier":"/us/usc/t22/s10103/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fc%2F2%2FA","sourceRelease":"119-100","text":"determines that it is vital for the national security interests of the United States to do so;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10103/c/2/B","parentIdentifier":"/us/usc/t22/s10103/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fc%2F2%2FB","sourceRelease":"119-100","text":"uses the annex in a manner consistent with congressional intent and the purposes of this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10103/c/2/C","parentIdentifier":"/us/usc/t22/s10103/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fc%2F2%2FC","sourceRelease":"119-100","text":"not later than 15 days before submitting the name in a classified annex, provides to the appropriate congressional committees notice of, and a justification for, including the name in the classified annex despite any publicly available credible information indicating that the person engaged in an activity described in .section 10102(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Public availability","label":"d Public availability","identifier":"/us/usc/t22/s10103/d","parentIdentifier":"/us/usc/t22/s10103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s10103/d/1","parentIdentifier":"/us/usc/t22/s10103/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fd%2F1","sourceRelease":"119-100","text":"The unclassified portion of the report required by subsection (a) shall be made available to the public, including through publication in the Federal Register.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Nonapplicability of confidentiality requirement with respect to visa records","label":"2 Nonapplicability of confidentiality requirement with respect to visa records","identifier":"/us/usc/t22/s10103/d/2","parentIdentifier":"/us/usc/t22/s10103/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fd%2F2","sourceRelease":"119-100","text":"The President shall publish the list required by subsection (a)(1) without regard to the requirements of with respect to confidentiality of records pertaining to the issuance or refusal of visas or permits to enter the United States.section 1202(f) of title 8","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Appropriate congressional committees defined","label":"e Appropriate congressional committees defined","identifier":"/us/usc/t22/s10103/e","parentIdentifier":"/us/usc/t22/s10103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10103/e/1","parentIdentifier":"/us/usc/t22/s10103/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fe%2F1","sourceRelease":"119-100","text":"the Committee on Appropriations, the Committee on Banking, Housing, and Urban Affairs, the Committee on Foreign Relations, and the Committee on the Judiciary of the Senate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10103/e/2","parentIdentifier":"/us/usc/t22/s10103/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10103%2Fe%2F2","sourceRelease":"119-100","text":"the Committee on Appropriations, the Committee on Financial Services, the Committee on Foreign Affairs, and the Committee on the Judiciary of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
