{"type":"section","nativeType":"section","number":"19052","heading":"Research ethics","label":"19052 Research ethics","identifier":"/us/usc/t42/s19052","parentIdentifier":"/us/usc/t42/ch163/schIII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Sense of Congress","label":"a Sense of Congress","identifier":"/us/usc/t42/s19052/a","parentIdentifier":"/us/usc/t42/s19052","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19052/a/1","parentIdentifier":"/us/usc/t42/s19052/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fa%2F1","sourceRelease":"119-100","text":"a number of emerging areas of research have potential ethical, social, safety, and security implications that might be apparent as early as the basic research stage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19052/a/2","parentIdentifier":"/us/usc/t42/s19052/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fa%2F2","sourceRelease":"119-100","text":"the incorporation of ethical, social, safety, and security considerations into the research design and review process for Federal awards, may help mitigate potential harms before they happen;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19052/a/3","parentIdentifier":"/us/usc/t42/s19052/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fa%2F3","sourceRelease":"119-100","text":"the Foundation’s agreement with the National Academies to conduct a study and make recommendations with respect to governance of research in emerging technologies is a positive step toward accomplishing this goal; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s19052/a/4","parentIdentifier":"/us/usc/t42/s19052/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fa%2F4","sourceRelease":"119-100","text":"the Foundation should continue to work with stakeholders to promote best practices for governance of research in emerging technologies at every stage of research.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Incorporation of ethics considerations","label":"b Incorporation of ethics considerations","identifier":"/us/usc/t42/s19052/b","parentIdentifier":"/us/usc/t42/s19052","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19052/b/1","parentIdentifier":"/us/usc/t42/s19052/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19052/b/1/A","parentIdentifier":"/us/usc/t42/s19052/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fb%2F1%2FA","sourceRelease":"119-100","text":"any readily foreseeable or quantifiable risks to society, including how the research could enable products, technologies, or other outcomes that could intentionally or unintentionally cause significant societal harm; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19052/b/1/B","parentIdentifier":"/us/usc/t42/s19052/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fb%2F1%2FB","sourceRelease":"119-100","text":"an assertion that no readily foreseeable potential ethical, social, safety, or security implications are apparent;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19052/b/2","parentIdentifier":"/us/usc/t42/s19052/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fb%2F2","sourceRelease":"119-100","text":"how technical or social solutions can mitigate such risks and, as appropriate, a plan to implement such mitigation measures; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19052/b/3","parentIdentifier":"/us/usc/t42/s19052/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fb%2F3","sourceRelease":"119-100","text":"how partnerships and collaborations in the research can help mitigate potential harm and amplify potential societal benefits.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Guidance","label":"c Guidance","identifier":"/us/usc/t42/s19052/c","parentIdentifier":"/us/usc/t42/s19052","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fc","sourceRelease":"119-100","text":"The Director shall solicit stakeholder input to develop clear guidance on what constitutes a readily foreseeable or quantifiable risk as described in subsection (b)(1), and to the extent practicable harmonize this policy with existing ethical policies or related requirements for human subjects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Research","label":"d Research","identifier":"/us/usc/t42/s19052/d","parentIdentifier":"/us/usc/t42/s19052","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19052/d/1","parentIdentifier":"/us/usc/t42/s19052/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fd%2F1","sourceRelease":"119-100","text":"research to assess the potential ethical and societal implications of Foundation-supported research and products or technologies enabled by such research, including the benefits and risks identified pursuant to subsection (b)(1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19052/d/2","parentIdentifier":"/us/usc/t42/s19052/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fd%2F2","sourceRelease":"119-100","text":"the development and verification of approaches to proactively mitigate foreseeable risks to society, including the technical and social solutions identified pursuant to subsection (b)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Annual report","label":"e Annual report","identifier":"/us/usc/t42/s19052/e","parentIdentifier":"/us/usc/t42/s19052","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19052%2Fe","sourceRelease":"119-100","text":"The Director shall encourage recipients to update their consideration of potential risks and benefits as appropriate as part of the annual reports required by all awardees under the award terms and conditions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
