{"type":"section","nativeType":"section","number":"138a","heading":"National Laboratory Accreditation Program","label":"138a National Laboratory Accreditation Program","identifier":"/us/usc/t7/s138a","parentIdentifier":"/us/usc/t7/ch6A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment of Program","label":"a Establishment of Program","identifier":"/us/usc/t7/s138a/a","parentIdentifier":"/us/usc/t7/s138a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fa","sourceRelease":"119-100","text":"The Secretary shall administer a National Laboratory Accreditation Program under which laboratories that request accreditation and conduct residue testing of agricultural products, or that make claims to the public or buyers of agricultural products concerning chemical residue levels on agricultural products, shall be determined to meet certain minimum quality and reliability standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Standards","label":"b Standards","identifier":"/us/usc/t7/s138a/b","parentIdentifier":"/us/usc/t7/s138a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s138a/b/1","parentIdentifier":"/us/usc/t7/s138a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fb%2F1","sourceRelease":"119-100","text":"standards applicable to laboratories;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s138a/b/2","parentIdentifier":"/us/usc/t7/s138a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fb%2F2","sourceRelease":"119-100","text":"qualifications for directors and other personnel; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s138a/b/3","parentIdentifier":"/us/usc/t7/s138a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fb%2F3","sourceRelease":"119-100","text":"standards and procedures for quality assurance programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Accrediting bodies","label":"c Accrediting bodies","identifier":"/us/usc/t7/s138a/c","parentIdentifier":"/us/usc/t7/s138a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s138a/c/1","parentIdentifier":"/us/usc/t7/s138a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fc%2F1","sourceRelease":"119-100","text":"oversee and review the performance of any accrediting body acting on behalf of the Secretary to ensure that such accrediting body is in compliance with the requirements of the certification program under this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s138a/c/2","parentIdentifier":"/us/usc/t7/s138a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fc%2F2","sourceRelease":"119-100","text":"have the right to obtain from an accrediting body acting on behalf of the Secretary and from any laboratory that may be certified by such a body all records and materials that may be necessary for the oversight and review required by paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Requirements","label":"d Requirements","identifier":"/us/usc/t7/s138a/d","parentIdentifier":"/us/usc/t7/s138a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s138a/d/1","parentIdentifier":"/us/usc/t7/s138a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fd%2F1","sourceRelease":"119-100","text":"prepare and submit an application for accreditation to the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s138a/d/2","parentIdentifier":"/us/usc/t7/s138a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fd%2F2","sourceRelease":"119-100","text":"comply with such terms and conditions as are determined necessary by the Secretary and the Secretary of Health and Human Services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Exceptions","label":"e Exceptions","identifier":"/us/usc/t7/s138a/e","parentIdentifier":"/us/usc/t7/s138a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s138a/e/1","parentIdentifier":"/us/usc/t7/s138a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fe%2F1","sourceRelease":"119-100","text":"a laboratory operated by a government agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s138a/e/2","parentIdentifier":"/us/usc/t7/s138a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fe%2F2","sourceRelease":"119-100","text":"a laboratory operated by a corporation that only performs analysis of residues on agricultural products for such corporation or any wholly owned subsidiary of such corporation and does not make claims to the public or buyers based on such analysis;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s138a/e/3","parentIdentifier":"/us/usc/t7/s138a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fe%2F3","sourceRelease":"119-100","text":"a laboratory operated by a partnership that only performs analysis of residues on agricultural products for the partners of such partnership and does not make claims to the public or buyers based on such analysis; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s138a/e/4","parentIdentifier":"/us/usc/t7/s138a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs138a%2Fe%2F4","sourceRelease":"119-100","text":"a laboratory not operated for commercial purposes that performs pesticide chemical residue analysis on agricultural products for research or quality control for the internal use of a person who is initiating the analysis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
