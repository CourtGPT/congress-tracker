{"type":"section","nativeType":"section","number":"4588","heading":"Exemption from disclosure","label":"4588 Exemption from disclosure","identifier":"/us/usc/t50/s4588","parentIdentifier":"/us/usc/t50/ch55/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4588","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t50/s4588/a","parentIdentifier":"/us/usc/t50/s4588","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4588%2Fa","sourceRelease":"119-100","text":"Except as provided in subsection (b), any information or documentary material filed with the Secretary or the Secretary’s designee pursuant to this subchapter shall be exempt from disclosure under , and no such information or documentary material may be made public.section 552(b)(3) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Exceptions","label":"b Exceptions","identifier":"/us/usc/t50/s4588/b","parentIdentifier":"/us/usc/t50/s4588","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4588%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s4588/b/1","parentIdentifier":"/us/usc/t50/s4588/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4588%2Fb%2F1","sourceRelease":"119-100","text":"Information relevant to any administrative or judicial action or proceeding.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s4588/b/2","parentIdentifier":"/us/usc/t50/s4588/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4588%2Fb%2F2","sourceRelease":"119-100","text":"Information to Congress or any duly authorized committee or subcommittee of Congress.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s4588/b/3","parentIdentifier":"/us/usc/t50/s4588/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4588%2Fb%2F3","sourceRelease":"119-100","text":"Information important to the national security analysis or actions of the Secretary to any domestic governmental entity, or to any foreign governmental entity of a United States ally or partner, under the exclusive direction and authorization of the Secretary, only to the extent necessary for national security purposes, and subject to appropriate confidentiality and classification requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t50/s4588/b/4","parentIdentifier":"/us/usc/t50/s4588/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4588%2Fb%2F4","sourceRelease":"119-100","text":"Identity of a covered foreign person in the public database described in .section 4585 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t50/s4588/b/5","parentIdentifier":"/us/usc/t50/s4588/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4588%2Fb%2F5","sourceRelease":"119-100","text":"Information that the parties have consented to be disclosed to third parties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t50/s4588/b/6","parentIdentifier":"/us/usc/t50/s4588/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4588%2Fb%2F6","sourceRelease":"119-100","text":"Information gathered by the Secretary or the Secretary’s designee where the disclosure is determined to be in the national security interest, which may include publication of anonymized data.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
