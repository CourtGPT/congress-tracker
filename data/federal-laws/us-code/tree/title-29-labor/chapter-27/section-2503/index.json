{"type":"section","nativeType":"section","number":"2503","heading":"Technical assistance","label":"2503 Technical assistance","identifier":"/us/usc/t29/s2503","parentIdentifier":"/us/usc/t29/ch27","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2503","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t29/s2503/a","parentIdentifier":"/us/usc/t29/s2503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2503%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s2503/a/1","parentIdentifier":"/us/usc/t29/s2503/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2503%2Fa%2F1","sourceRelease":"119-100","text":"developing outreach and orientation sessions to recruit women into the employers’ apprenticeable occupations and nontraditional occupations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s2503/a/2","parentIdentifier":"/us/usc/t29/s2503/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2503%2Fa%2F2","sourceRelease":"119-100","text":"developing preapprenticeable occupations or nontraditional skills training to prepare women for apprenticeable occupations or nontraditional occupations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t29/s2503/a/3","parentIdentifier":"/us/usc/t29/s2503/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2503%2Fa%2F3","sourceRelease":"119-100","text":"providing ongoing orientations for employers, unions, and workers on creating a successful environment for women in apprenticeable occupations or nontraditional occupations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t29/s2503/a/4","parentIdentifier":"/us/usc/t29/s2503/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2503%2Fa%2F4","sourceRelease":"119-100","text":"setting up support groups and facilitating networks for women in nontraditional occupations on or off the job site to improve their retention;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t29/s2503/a/5","parentIdentifier":"/us/usc/t29/s2503/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2503%2Fa%2F5","sourceRelease":"119-100","text":"setting up a local computerized data base referral system to maintain a current list of tradeswomen who are available for work;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t29/s2503/a/6","parentIdentifier":"/us/usc/t29/s2503/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2503%2Fa%2F6","sourceRelease":"119-100","text":"serving as a liaison between tradeswomen and employers and tradeswomen and labor unions to address workplace issues related to gender; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t29/s2503/a/7","parentIdentifier":"/us/usc/t29/s2503/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2503%2Fa%2F7","sourceRelease":"119-100","text":"conducting exit interviews with tradeswomen to evaluate their on-the-job experience and to assess the effectiveness of the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Selection of employer and labor unions","label":"b Selection of employer and labor unions","identifier":"/us/usc/t29/s2503/b","parentIdentifier":"/us/usc/t29/s2503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2503%2Fb","sourceRelease":"119-100","text":"The Secretary shall select a total of 50 employers or labor unions to receive technical assistance provided with grants made under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
