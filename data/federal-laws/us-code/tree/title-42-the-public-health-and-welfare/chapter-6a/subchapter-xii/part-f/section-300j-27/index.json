etion of the Secretary, or establish through a grant award or contract, a lead exposure registry to collect data on the lead exposure of residents of a City on a voluntary basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Advisory Committee","label":"c Advisory Committee","identifier":"/us/usc/t42/s300j–27/c","parentIdentifier":"/us/usc/t42/s300j–27","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Membership","label":"1 Membership","identifier":"/us/usc/t42/s300j–27/c/1","parentIdentifier":"/us/usc/t42/s300j–27/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s300j–27/c/1/A","parentIdentifier":"/us/usc/t42/s300j–27/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300j–27/c/1/A/i","parentIdentifier":"/us/usc/t42/s300j–27/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"an epidemiologist;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300j–27/c/1/A/ii","parentIdentifier":"/us/usc/t42/s300j–27/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"a toxicologist;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s300j–27/c/1/A/iii","parentIdentifier":"/us/usc/t42/s300j–27/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"a mental health professional;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s300j–27/c/1/A/iv","parentIdentifier":"/us/usc/t42/s300j–27/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F1%2FA%2Fiv","sourceRelease":"119-100","text":"a pediatrician;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s300j–27/c/1/A/v","parentIdentifier":"/us/usc/t42/s300j–27/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F1%2FA%2Fv","sourceRelease":"119-100","text":"an early childhood education expert;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s300j–27/c/1/A/vi","parentIdentifier":"/us/usc/t42/s300j–27/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F1%2FA%2Fvi","sourceRelease":"119-100","text":"a special education expert;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t42/s300j–27/c/1/A/vii","parentIdentifier":"/us/usc/t42/s300j–27/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F1%2FA%2Fvii","sourceRelease":"119-100","text":"a dietician; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t42/s300j–27/c/1/A/viii","parentIdentifier":"/us/usc/t42/s300j–27/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F1%2FA%2Fviii","sourceRelease":"119-100","text":"an environmental health expert.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Requirements","label":"B Requirements","identifier":"/us/usc/t42/s300j–27/c/1/B","parentIdentifier":"/us/usc/t42/s300j–27/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F1%2FB","sourceRelease":"119-100","text":"Membership in the Committee shall not exceed 15 members and not less than ½ of the members shall be Federal members.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Chair","label":"2 Chair","identifier":"/us/usc/t42/s300j–27/c/2","parentIdentifier":"/us/usc/t42/s300j–27/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F2","sourceRelease":"119-100","text":"The Secretary shall designate a chair from among the Federal members appointed to the Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Terms","label":"3 Terms","identifier":"/us/usc/t42/s300j–27/c/3","parentIdentifier":"/us/usc/t42/s300j–27/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F3","sourceRelease":"119-100","text":"Members of the Committee shall serve for a term of not more than 3 years and the Secretary may reappoint members for consecutive terms.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Application of FACA","label":"4 Application of FACA","identifier":"/us/usc/t42/s300j–27/c/4","parentIdentifier":"/us/usc/t42/s300j–27/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F4","sourceRelease":"119-100","text":"The Committee shall be subject to the Federal Advisory Committee Act (5 U.S.C. App.).1See References in Text note below.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Responsibilities","label":"5 Responsibilities","identifier":"/us/usc/t42/s300j–27/c/5","parentIdentifier":"/us/usc/t42/s300j–27/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–27/c/5/A","parentIdentifier":"/us/usc/t42/s300j–27/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F5%2FA","sourceRelease":"119-100","text":"review the Federal programs and services available to individuals and communities exposed to lead;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–27/c/5/B","parentIdentifier":"/us/usc/t42/s300j–27/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F5%2FB","sourceRelease":"119-100","text":"review current research on lead poisoning to identify additional research needs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300j–27/c/5/C","parentIdentifier":"/us/usc/t42/s300j–27/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F5%2FC","sourceRelease":"119-100","text":"review and identify best practices, or the need for best practices, regarding lead screening and the prevention of lead poisoning;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s300j–27/c/5/D","parentIdentifier":"/us/usc/t42/s300j–27/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F5%2FD","sourceRelease":"119-100","text":"identify effective services, including services relating to healthcare, education, and nutrition for individuals and communities affected by lead exposure and lead poisoning, including in consultation with, as appropriate, the lead exposure registry as established in subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s300j–27/c/5/E","parentIdentifier":"/us/usc/t42/s300j–27/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F5%2FE","sourceRelease":"119-100","text":"undertake any other review or activities that the Secretary determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Report","label":"6 Report","identifier":"/us/usc/t42/s300j–27/c/6","parentIdentifier":"/us/usc/t42/s300j–27/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–27/c/6/A","parentIdentifier":"/us/usc/t42/s300j–27/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F6%2FA","sourceRelease":"119-100","text":"an evaluation of the effectiveness of the Federal programs and services available to individuals and communities exposed to lead;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–27/c/6/B","parentIdentifier":"/us/usc/t42/s300j–27/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F6%2FB","sourceRelease":"119-100","text":"an evaluation of additional lead poisoning research needs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300j–27/c/6/C","parentIdentifier":"/us/usc/t42/s300j–27/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F6%2FC","sourceRelease":"119-100","text":"an assessment of any effective screening methods or best practices used or developed to prevent or screen for lead poisoning;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s300j–27/c/6/D","parentIdentifier":"/us/usc/t42/s300j–27/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F6%2FD","sourceRelease":"119-100","text":"input and recommendations for improved access to effective services relating to health care, education, or nutrition for individuals and communities impacted by lead exposure; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s300j–27/c/6/E","parentIdentifier":"/us/usc/t42/s300j–27/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fc%2F6%2FE","sourceRelease":"119-100","text":"any other recommendations for communities affected by lead exposure, as appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s300j–27/d","parentIdentifier":"/us/usc/t42/s300j–27","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300j–27/d/1","parentIdentifier":"/us/usc/t42/s300j–27/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fd%2F1","sourceRelease":"119-100","text":"$17,500,000 to carry out subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300j–27/d/2","parentIdentifier":"/us/usc/t42/s300j–27/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9327%2Fd%2F2","sourceRelease":"119-100","text":"$2,500,000 to carry out subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
