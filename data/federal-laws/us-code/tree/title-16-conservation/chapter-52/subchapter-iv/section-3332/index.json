{"type":"section","nativeType":"section","number":"3332","heading":"State program for reduction of overall fishing capacity","label":"3332 State program for reduction of overall fishing capacity","identifier":"/us/usc/t16/s3332","parentIdentifier":"/us/usc/t16/ch52/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3332","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s3332/1","parentIdentifier":"/us/usc/t16/s3332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3332%2F1","sourceRelease":"119-100","text":"provide incentives for early retirement of licenses, or early sale of vessels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s3332/2","parentIdentifier":"/us/usc/t16/s3332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3332%2F2","sourceRelease":"119-100","text":"set aside specific allocations of funds for each gear type to achieve the specific fleet reductions provided for in the program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s3332/3","parentIdentifier":"/us/usc/t16/s3332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3332%2F3","sourceRelease":"119-100","text":"obtain an effective and expeditious reduction in the overall fishing capacity of and the number of vessels and licenses in the non-Indian commercial and charter salmon fishing fleets in the Washington conservation area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s3332/4","parentIdentifier":"/us/usc/t16/s3332","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3332%2F4","sourceRelease":"119-100","text":"provide State funding for 25 per centum of the total cost of the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
