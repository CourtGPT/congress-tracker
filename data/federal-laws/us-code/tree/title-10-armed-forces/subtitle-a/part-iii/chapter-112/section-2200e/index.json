{"type":"section","nativeType":"section","number":"2200e","heading":"Definitions","label":"2200e Definitions","identifier":"/us/usc/t10/s2200e","parentIdentifier":"/us/usc/t10/stA/ptIII/ch112","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2200e","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2017— amended section generally. Prior to amendment, section defined “information assurance”, “institution of higher education”, and “Center of Academic Excellence in Information Assurance Education”.Pub. L. 115–91"],"amendments":["Amendments2017— amended section generally. Prior to amendment, section defined “information assurance”, “institution of higher education”, and “Center of Academic Excellence in Information Assurance Education”.Pub. L. 115–91"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2200e/1","parentIdentifier":"/us/usc/t10/s2200e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2200e%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2200e/1/A","parentIdentifier":"/us/usc/t10/s2200e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2200e%2F1%2FA","sourceRelease":"119-100","text":"Offensive cyber operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2200e/1/B","parentIdentifier":"/us/usc/t10/s2200e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2200e%2F1%2FB","sourceRelease":"119-100","text":"Defensive cyber operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s2200e/1/C","parentIdentifier":"/us/usc/t10/s2200e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2200e%2F1%2FC","sourceRelease":"119-100","text":"Department of Defense information network operations and defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s2200e/1/D","parentIdentifier":"/us/usc/t10/s2200e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2200e%2F1%2FD","sourceRelease":"119-100","text":"Any other information technology that the Secretary of Defense considers to be related to the cyber activities of the Department of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2200e/2","parentIdentifier":"/us/usc/t10/s2200e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2200e%2F2","sourceRelease":"119-100","text":"The term “institution of higher education” has the meaning given the term in section 101 of the Higher Education Act of 1965 ().20 U.S.C. 1001","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2200e/3","parentIdentifier":"/us/usc/t10/s2200e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2200e%2F3","sourceRelease":"119-100","text":"The term “Center of Academic Excellence in Cyber Education” means an institution of higher education that is designated by the Director of the National Security Agency as a Center of Academic Excellence in Cyber Education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
