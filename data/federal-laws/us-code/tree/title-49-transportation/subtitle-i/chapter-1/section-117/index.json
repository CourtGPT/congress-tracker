{"type":"section","nativeType":"section","number":"117","heading":"Council on Credit and Finance","label":"117 Council on Credit and Finance","identifier":"/us/usc/t49/s117","parentIdentifier":"/us/usc/t49/stI/ch1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , see , set out as an Effective Date of 2015 Amendment note under , Government Organization and Employees.Oct. 1, 2015section 1003 of Pub. L. 114–94section 5313 of Title 5"],"amendments":["Effective DateSection effective , see , set out as an Effective Date of 2015 Amendment note under , Government Organization and Employees.Oct. 1, 2015section 1003 of Pub. L. 114–94section 5313 of Title 5"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t49/s117/a","parentIdentifier":"/us/usc/t49/s117","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117%2Fa","sourceRelease":"119-100","text":"The Secretary of Transportation shall establish a Council on Credit and Finance in accordance with this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Membership.—","label":"b Membership.—","identifier":"/us/usc/t49/s117/b","parentIdentifier":"/us/usc/t49/s117","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s117/b/1","parentIdentifier":"/us/usc/t49/s117/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117%2Fb%2F1","sourceRelease":"119-100","text":null,"