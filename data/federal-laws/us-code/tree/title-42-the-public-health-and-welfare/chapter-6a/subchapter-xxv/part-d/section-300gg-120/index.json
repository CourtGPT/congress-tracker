{"type":"section","nativeType":"section","number":"300gg–120","heading":"Reporting on pharmacy benefits and drug costs","label":"300gg–120 Reporting on pharmacy benefits and drug costs","identifier":"/us/usc/t42/s300gg–120","parentIdentifier":"/us/usc/t42/ch6A/schXXV/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s300gg–120/a","parentIdentifier":"/us/usc/t42/s300gg–120","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300gg–120/a/1","parentIdentifier":"/us/usc/t42/s300gg–120/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F1","sourceRelease":"119-100","text":"The beginning and end dates of the plan year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300gg–120/a/2","parentIdentifier":"/us/usc/t42/s300gg–120/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F2","sourceRelease":"119-100","text":"The number of enrollees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300gg–120/a/3","parentIdentifier":"/us/usc/t42/s300gg–120/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F3","sourceRelease":"119-100","text":"Each State in which the plan or coverage is offered.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s300gg–120/a/4","parentIdentifier":"/us/usc/t42/s300gg–120/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F4","sourceRelease":"119-100","text":"The 50 brand prescription drugs most frequently dispensed by pharmacies for claims paid by the plan or coverage, and the total number of paid claims for each such drug.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s300gg–120/a/5","parentIdentifier":"/us/usc/t42/s300gg–120/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F5","sourceRelease":"119-100","text":"The 50 most costly prescription drugs with respect to the plan or coverage by total annual spending, and the annual amount spent by the plan or coverage for each such drug.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s300gg–120/a/6","parentIdentifier":"/us/usc/t42/s300gg–120/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F6","sourceRelease":"119-100","text":"The 50 prescription drugs with the greatest increase in plan expenditures over the plan year preceding the plan year that is the subject of the report, and, for each such drug, the change in amounts expended by the plan or coverage in each such plan year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s300gg–120/a/7","parentIdentifier":"/us/usc/t42/s300gg–120/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300gg–120/a/7/A","parentIdentifier":"/us/usc/t42/s300gg–120/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F7%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300gg–120/a/7/A/i","parentIdentifier":"/us/usc/t42/s300gg–120/a/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F7%2FA%2Fi","sourceRelease":"119-100","text":"hospital costs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300gg–120/a/7/A/ii","parentIdentifier":"/us/usc/t42/s300gg–120/a/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F7%2FA%2Fii","sourceRelease":"119-100","text":"health care provider and clinical service costs, for primary care and specialty care separately;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s300gg–120/a/7/A/iii","parentIdentifier":"/us/usc/t42/s300gg–120/a/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F7%2FA%2Fiii","sourceRelease":"119-100","text":"costs for prescription drugs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s300gg–120/a/7/A/iv","parentIdentifier":"/us/usc/t42/s300gg–120/a/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F7%2FA%2Fiv","sourceRelease":"119-100","text":"other medical costs, including wellness services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300gg–120/a/7/B","parentIdentifier":"/us/usc/t42/s300gg–120/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F7%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300gg–120/a/7/B/i","parentIdentifier":"/us/usc/t42/s300gg–120/a/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F7%2FB%2Fi","sourceRelease":"119-100","text":"the health plan or coverage; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300gg–120/a/7/B/ii","parentIdentifier":"/us/usc/t42/s300gg–120/a/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F7%2FB%2Fii","sourceRelease":"119-100","text":"the enrollees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s300gg–120/a/8","parentIdentifier":"/us/usc/t42/s300gg–120/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300gg–120/a/8/A","parentIdentifier":"/us/usc/t42/s300gg–120/a/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F8%2FA","sourceRelease":"119-100","text":"paid by employers on behalf of enrollees, as applicable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300gg–120/a/8/B","parentIdentifier":"/us/usc/t42/s300gg–120/a/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F8%2FB","sourceRelease":"119-100","text":"paid by enrollees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t42/s300gg–120/a/9","parentIdentifier":"/us/usc/t42/s300gg–120/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F9","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300gg–120/a/9/A","parentIdentifier":"/us/usc/t42/s300gg–120/a/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F9%2FA","sourceRelease":"119-100","text":"the amounts so paid for each therapeutic class of drugs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300gg–120/a/9/B","parentIdentifier":"/us/usc/t42/s300gg–120/a/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F9%2FB","sourceRelease":"119-100","text":"the amounts so paid for each of the 25 drugs that yielded the highest amount of rebates and other remuneration under the plan or coverage from drug manufacturers during the plan year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t42/s300gg–120/a/10","parentIdentifier":"/us/usc/t42/s300gg–120/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fa%2F10","sourceRelease":"119-100","text":"Any reduction in premiums and out-of-pocket costs associated with rebates, fees, or other remuneration described in paragraph (9).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report","label":"b Report","identifier":"/us/usc/t42/s300gg–120/b","parentIdentifier":"/us/usc/t42/s300gg–120","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fb","sourceRelease":"119-100","text":"Not later than 18 months after the date on which the first report is required under subsection (a) and biannually thereafter, the Secretary, acting through the Assistant Secretary of Planning and Evaluation and in coordination with the Inspector General of the Department of Health and Human Services, shall make available on the internet website of the Department of Health and Human Services a report on prescription drug reimbursements under group health plans and group and individual health insurance coverage, prescription drug pricing trends, and the role of prescription drug costs in contributing to premium increases or decreases under such plans or coverage, aggregated in such a way as no drug or plan specific information will be made public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Privacy protections","label":"c Privacy protections","identifier":"/us/usc/t42/s300gg–120/c","parentIdentifier":"/us/usc/t42/s300gg–120","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300gg%E2%80%93120%2Fc","sourceRelease":"119-100","text":"No confidential or trade secret information submitted to the Secretary under subsection (a) shall be included in the report under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
