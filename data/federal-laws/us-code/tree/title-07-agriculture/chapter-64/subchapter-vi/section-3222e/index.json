{"type":"section","nativeType":"section","number":"3222e","heading":"New beginning for tribal students","label":"3222e New beginning for tribal students","identifier":"/us/usc/t7/s3222e","parentIdentifier":"/us/usc/t7/ch64/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t7/s3222e/a","parentIdentifier":"/us/usc/t7/s3222e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Indian tribe","label":"1 Indian tribe","identifier":"/us/usc/t7/s3222e/a/1","parentIdentifier":"/us/usc/t7/s3222e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fa%2F1","sourceRelease":"119-100","text":"The term “Indian tribe” has the meaning given such term in ).section 5304 of title 251So in original. The closing parenthesis probably should not appear.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Land-grant college or university","label":"2 Land-grant college or university","identifier":"/us/usc/t7/s3222e/a/2","parentIdentifier":"/us/usc/t7/s3222e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fa%2F2","sourceRelease":"119-100","text":"The term “land-grant college or university” includes a 1994 Institution (as defined in section 532 of the Equity in Educational Land-Grant Status Act of 1994 (; note)).Public Law 103–3827 U.S.C. 301","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Tribal student","label":"3 Tribal student","identifier":"/us/usc/t7/s3222e/a/3","parentIdentifier":"/us/usc/t7/s3222e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fa%2F3","sourceRelease":"119-100","text":"The term “Tribal student” means a student at a land-grant college or university that is a member of an Indian tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"New beginning initiative","label":"b New beginning initiative","identifier":"/us/usc/t7/s3222e/b","parentIdentifier":"/us/usc/t7/s3222e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Authorization","label":"1 Authorization","identifier":"/us/usc/t7/s3222e/b/1","parentIdentifier":"/us/usc/t7/s3222e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary may make competitive grants to land-grant colleges and universities to provide identifiable support specifically targeted for Tribal students.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Application","label":"2 Application","identifier":"/us/usc/t7/s3222e/b/2","parentIdentifier":"/us/usc/t7/s3222e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb%2F2","sourceRelease":"119-100","text":"A land-grant college or university that desires to receive a grant under this section shall submit an application to the Secretary at such time, in such manner, and accompanied by such information as the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Use of funds","label":"3 Use of funds","identifier":"/us/usc/t7/s3222e/b/3","parentIdentifier":"/us/usc/t7/s3222e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s3222e/b/3/A","parentIdentifier":"/us/usc/t7/s3222e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb%2F3%2FA","sourceRelease":"119-100","text":"recruiting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s3222e/b/3/B","parentIdentifier":"/us/usc/t7/s3222e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb%2F3%2FB","sourceRelease":"119-100","text":"tuition and related fees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s3222e/b/3/C","parentIdentifier":"/us/usc/t7/s3222e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb%2F3%2FC","sourceRelease":"119-100","text":"experiential learning; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s3222e/b/3/D","parentIdentifier":"/us/usc/t7/s3222e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb%2F3%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s3222e/b/3/D/i","parentIdentifier":"/us/usc/t7/s3222e/b/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb%2F3%2FD%2Fi","sourceRelease":"119-100","text":"tutoring;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s3222e/b/3/D/ii","parentIdentifier":"/us/usc/t7/s3222e/b/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb%2F3%2FD%2Fii","sourceRelease":"119-100","text":"counseling;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s3222e/b/3/D/iii","parentIdentifier":"/us/usc/t7/s3222e/b/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb%2F3%2FD%2Fiii","sourceRelease":"119-100","text":"academic advising; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s3222e/b/3/D/iv","parentIdentifier":"/us/usc/t7/s3222e/b/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb%2F3%2FD%2Fiv","sourceRelease":"119-100","text":"other student services that would increase the retention and graduation rate of Tribal students enrolled at the land-grant college or university, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Matching funds","label":"4 Matching funds","identifier":"/us/usc/t7/s3222e/b/4","parentIdentifier":"/us/usc/t7/s3222e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb%2F4","sourceRelease":"119-100","text":"A land-grant college or university that receives a grant under this section shall provide matching funds toward the cost of carrying out the activities described in this section in an amount equal to not less than 100 percent of the grant award.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Maximum amount per state","label":"5 Maximum amount per state","identifier":"/us/usc/t7/s3222e/b/5","parentIdentifier":"/us/usc/t7/s3222e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fb%2F5","sourceRelease":"119-100","text":"No State shall receive, through grants made under this section to land-grant colleges and universities located in the State, more than $500,000 per year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Report","label":"c Report","identifier":"/us/usc/t7/s3222e/c","parentIdentifier":"/us/usc/t7/s3222e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fc","sourceRelease":"119-100","text":"Not later than 3 years after , the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry and the Committee on Indian Affairs of the Senate a report that includes an itemized list of grant funds distributed under this section, including the specific form of assistance provided under subsection (b)(3), and the number of Tribal students assisted and the graduation rate of Tribal students at land-grant colleges and universities receiving grants under this section.December 20, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriation","label":"d Authorization of appropriation","identifier":"/us/usc/t7/s3222e/d","parentIdentifier":"/us/usc/t7/s3222e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3222e%2Fd","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2019 through 2023.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
