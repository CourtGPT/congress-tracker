{"type":"section","nativeType":"section","number":"7657","heading":"Senior Scientific Research Service","label":"7657 Senior Scientific Research Service","identifier":"/us/usc/t7/s7657","parentIdentifier":"/us/usc/t7/ch103/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe General Schedule, referred to in subsecs. (b)(2)(C), (4)(A)(iv), (B), (d)(2)(A), and (f)(1)(A), is set out under , Government Organization and Employees.section 5332 of Title 5Level I of the Executive Schedule, referred to in subsec. (d)(2)(B), is set out in , Government Organization and Employees.section 5312 of Title 5"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t7/s7657/a","parentIdentifier":"/us/usc/t7/s7657","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fa","sourceRelease":"119-100","text":"There is established in the Department of Agriculture the Senior Scientific Research Service (referred to in this section as the “Service”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Members","label":"b Members","identifier":"/us/usc/t7/s7657/b","parentIdentifier":"/us/usc/t7/s7657","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s7657/b/1","parentIdentifier":"/us/usc/t7/s7657/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F1","sourceRelease":"119-100","text":"Subject to paragraphs (2) through (4), the Secretary shall appoint the members of the Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Qualifications","label":"2 Qualifications","identifier":"/us/usc/t7/s7657/b/2","parentIdentifier":"/us/usc/t7/s7657/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7657/b/2/A","parentIdentifier":"/us/usc/t7/s7657/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F2%2FA","sourceRelease":"119-100","text":"have conducted outstanding research in the field of agriculture or forestry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7657/b/2/B","parentIdentifier":"/us/usc/t7/s7657/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F2%2FB","sourceRelease":"119-100","text":"have earned a doctoral level degree at an institution of higher education (as defined in ); andsection 1001 of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s7657/b/2/C","parentIdentifier":"/us/usc/t7/s7657/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F2%2FC","sourceRelease":"119-100","text":"meet qualification standards prescribed by the Director of the Office of Personnel Management for appointment to a position at level GS–15 of the General Schedule.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Number","label":"3 Number","identifier":"/us/usc/t7/s7657/b/3","parentIdentifier":"/us/usc/t7/s7657/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F3","sourceRelease":"119-100","text":"Not more than 100 individuals may serve as members of the Service at any 1 time.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Other requirements","label":"4 Other requirements","identifier":"/us/usc/t7/s7657/b/4","parentIdentifier":"/us/usc/t7/s7657/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s7657/b/4/A","parentIdentifier":"/us/usc/t7/s7657/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s7657/b/4/A/i","parentIdentifier":"/us/usc/t7/s7657/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F4%2FA%2Fi","sourceRelease":"119-100","text":"the provisions of title 5 governing appointments in the competitive service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s7657/b/4/A/ii","parentIdentifier":"/us/usc/t7/s7657/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F4%2FA%2Fii","sourceRelease":"119-100","text":"the provisions of subchapter I of chapter 35 of title 5 relating to retention preference;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s7657/b/4/A/iii","parentIdentifier":"/us/usc/t7/s7657/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F4%2FA%2Fiii","sourceRelease":"119-100","text":"the provisions of chapter 43 of title 5 relating to performance appraisal and performance actions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s7657/b/4/A/iv","parentIdentifier":"/us/usc/t7/s7657/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F4%2FA%2Fiv","sourceRelease":"119-100","text":"the provisions of chapter 51 and subchapter III of chapter 53 of title 5 relating to classification and General Schedule pay rates; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t7/s7657/b/4/A/v","parentIdentifier":"/us/usc/t7/s7657/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F4%2FA%2Fv","sourceRelease":"119-100","text":"the provisions of chapter 75 of title 5 relating to adverse actions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exception","label":"B Exception","identifier":"/us/usc/t7/s7657/b/4/B","parentIdentifier":"/us/usc/t7/s7657/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fb%2F4%2FB","sourceRelease":"119-100","text":"A member of the Service appointed and employed by the Secretary under subparagraph (A) shall have the same right of appeal to the Merit Systems Protection Board and the same right to file a complaint with the Office of Special Counsel as an employee appointed to a position at level GS–15 of the General Schedule.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Performance appraisal system","label":"c Performance appraisal system","identifier":"/us/usc/t7/s7657/c","parentIdentifier":"/us/usc/t7/s7657","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7657/c/1","parentIdentifier":"/us/usc/t7/s7657/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fc%2F1","sourceRelease":"119-100","text":"provide for the systematic appraisal of the employment performance of the members; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7657/c/2","parentIdentifier":"/us/usc/t7/s7657/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fc%2F2","sourceRelease":"119-100","text":"encourage excellence in employment performance by the members.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Compensation","label":"d Compensation","identifier":"/us/usc/t7/s7657/d","parentIdentifier":"/us/usc/t7/s7657","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s7657/d/1","parentIdentifier":"/us/usc/t7/s7657/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fd%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2), the Secretary shall determine the compensation of members of the Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitations","label":"2 Limitations","identifier":"/us/usc/t7/s7657/d/2","parentIdentifier":"/us/usc/t7/s7657/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7657/d/2/A","parentIdentifier":"/us/usc/t7/s7657/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fd%2F2%2FA","sourceRelease":"119-100","text":"not be less than the minimum rate payable for a position at level GS–15 of the General Schedule; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7657/d/2/B","parentIdentifier":"/us/usc/t7/s7657/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fd%2F2%2FB","sourceRelease":"119-100","text":"not be more than the rate payable for a position at level I of the Executive Schedule, unless the rate is approved by the President under .section 5377(d)(2) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Retirement contributions","label":"e Retirement contributions","identifier":"/us/usc/t7/s7657/e","parentIdentifier":"/us/usc/t7/s7657","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s7657/e/1","parentIdentifier":"/us/usc/t7/s7657/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fe%2F1","sourceRelease":"119-100","text":"On the request of a member of the Service who was an employee of an institution of higher education (as defined in ) immediately prior to appointment as a member of the Service and who retains the right to continue to make contributions to the retirement system of the institution, the Secretary may contribute an amount not to exceed 10 percent of the basic pay of the member to the retirement system of the institution on behalf of the member.section 1001 of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Federal retirement system","label":"2 Federal retirement system","identifier":"/us/usc/t7/s7657/e/2","parentIdentifier":"/us/usc/t7/s7657/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s7657/e/2/A","parentIdentifier":"/us/usc/t7/s7657/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fe%2F2%2FA","sourceRelease":"119-100","text":"Subject to subparagraph (B), a member for whom a contribution is made under paragraph (1) shall not, as a result of serving as a member of the Service, be covered by, or earn service credit under, chapter 83 or 84 of title 5.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Annual leave","label":"B Annual leave","identifier":"/us/usc/t7/s7657/e/2/B","parentIdentifier":"/us/usc/t7/s7657/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Fe%2F2%2FB","sourceRelease":"119-100","text":"Service of a member of the Service described in subparagraph (A) shall be creditable for determining years of service under .section 6303(a) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Involuntary separation","label":"f Involuntary separation","identifier":"/us/usc/t7/s7657/f","parentIdentifier":"/us/usc/t7/s7657","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s7657/f/1","parentIdentifier":"/us/usc/t7/s7657/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7657/f/1/A","parentIdentifier":"/us/usc/t7/s7657/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Ff%2F1%2FA","sourceRelease":"119-100","text":"the Secretary may appoint the individual to a position in the competitive civil service at level GS–15 of the General Schedule; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7657/f/1/B","parentIdentifier":"/us/usc/t7/s7657/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Ff%2F1%2FB","sourceRelease":"119-100","text":"the appointment shall be a career appointment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Excepted civil service","label":"2 Excepted civil service","identifier":"/us/usc/t7/s7657/f/2","parentIdentifier":"/us/usc/t7/s7657/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7657/f/2/A","parentIdentifier":"/us/usc/t7/s7657/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Ff%2F2%2FA","sourceRelease":"119-100","text":"shall be to the excepted civil service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7657/f/2/B","parentIdentifier":"/us/usc/t7/s7657/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7657%2Ff%2F2%2FB","sourceRelease":"119-100","text":"may not exceed a period of 2 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
