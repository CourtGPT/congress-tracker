{"type":"section","nativeType":"section","number":"16324","heading":"Energy research fellowships","label":"16324 Energy research fellowships","identifier":"/us/usc/t42/s16324","parentIdentifier":"/us/usc/t42/ch149/schIX/ptG","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16324","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Postdoctoral fellowship program","label":"a Postdoctoral fellowship program","identifier":"/us/usc/t42/s16324/a","parentIdentifier":"/us/usc/t42/s16324","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16324%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish a program under which the Secretary provides fellowships to encourage outstanding young scientists and engineers to pursue postdoctoral research appointments in energy research and development at institutions of higher education of their choice.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Senior research fellowships","label":"b Senior research fellowships","identifier":"/us/usc/t42/s16324/b","parentIdentifier":"/us/usc/t42/s16324","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16324%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16324/b/1","parentIdentifier":"/us/usc/t42/s16324/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16324%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall establish a program under which the Secretary provides fellowships to allow outstanding senior researchers and their research groups in energy research and development to explore research and development topics of their choosing for a period of not less than 3 years, to be determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Consideration","label":"2 Consideration","identifier":"/us/usc/t42/s16324/b/2","parentIdentifier":"/us/usc/t42/s16324/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16324%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16324/b/2/A","parentIdentifier":"/us/usc/t42/s16324/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16324%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the past scientific or technical accomplishment of a senior researcher; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16324/b/2/B","parentIdentifier":"/us/usc/t42/s16324/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16324%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the potential for continued accomplishment by the researcher during the period of the fellowship.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
