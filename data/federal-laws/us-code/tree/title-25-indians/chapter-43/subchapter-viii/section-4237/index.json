{"type":"section","nativeType":"section","number":"4237","heading":"Remedies for noncompliance","label":"4237 Remedies for noncompliance","identifier":"/us/usc/t25/s4237","parentIdentifier":"/us/usc/t25/ch43/schVIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThis chapter, referred to in subsec. (d)(1), was in the original “this Act”, meaning , , , known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under and Tables.Pub. L. 104–330110 Stat. 4016section 4101 of this titleOct. 26, 1996","Codification, and , enacted identical sections 818 of . This section is based on the text of , as added by .Pub. L. 106–568, § 203Pub. L. 106–569, § 513Pub. L. 104–330section 818 of Pub. L. 104–330Pub. L. 106–569, § 513"],"amendments":["References in TextThis chapter, referred to in subsec. (d)(1), was in the original “this Act”, meaning , , , known as the Native American Housing Assistance and Self-Determination Act of 1996. For complete classification of this Act to the Code, see Short Title note set out under and Tables.Pub. L. 104–330110 Stat. 4016section 4101 of this titleOct. 26, 1996"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Actions by Secretary affecting grant amounts","label":"a Actions by Secretary affecting grant amounts","identifier":"/us/usc/t25/s4237/a","parentIdentifier":"/us/usc/t25/s4237","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s4237/a/1","parentIdentifier":"/us/usc/t25/s4237/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s4237/a/1/A","parentIdentifier":"/us/usc/t25/s4237/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fa%2F1%2FA","sourceRelease":"119-100","text":"terminate payments under this subchapter to the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s4237/a/1/B","parentIdentifier":"/us/usc/t25/s4237/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fa%2F1%2FB","sourceRelease":"119-100","text":"reduce payments under this subchapter to the Department by an amount equal to the amount of such payments that were not expended in accordance with this subchapter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s4237/a/1/C","parentIdentifier":"/us/usc/t25/s4237/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fa%2F1%2FC","sourceRelease":"119-100","text":"limit the availability of payments under this subchapter to programs, projects, or activities not affected by such failure to comply.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Actions","label":"2 Actions","identifier":"/us/usc/t25/s4237/a/2","parentIdentifier":"/us/usc/t25/s4237/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fa%2F2","sourceRelease":"119-100","text":"If the Secretary takes an action under subparagraph (A), (B), or (C) of paragraph (1), the Secretary shall continue that action until the Secretary determines that the failure by the Department to comply with the provision has been remedied by the Department and the Department is in compliance with that provision.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Noncompliance because of a technical incapacity","label":"b Noncompliance because of a technical incapacity","identifier":"/us/usc/t25/s4237/b","parentIdentifier":"/us/usc/t25/s4237","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4237/b/1","parentIdentifier":"/us/usc/t25/s4237/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fb%2F1","sourceRelease":"119-100","text":"is not a pattern or practice of activities constituting willful noncompliance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4237/b/2","parentIdentifier":"/us/usc/t25/s4237/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fb%2F2","sourceRelease":"119-100","text":"is a result of the limited capability or capacity of the Department of Hawaiian Home Lands.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Referral for civil action","label":"c Referral for civil action","identifier":"/us/usc/t25/s4237/c","parentIdentifier":"/us/usc/t25/s4237","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Authority","label":"1 Authority","identifier":"/us/usc/t25/s4237/c/1","parentIdentifier":"/us/usc/t25/s4237/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fc%2F1","sourceRelease":"119-100","text":"In lieu of, or in addition to, any action that the Secretary may take under subsection (a), if the Secretary has reason to believe that the Department of Hawaiian Home Lands has failed to comply substantially with any provision of this subchapter, the Secretary may refer the matter to the Attorney General of the United States with a recommendation that an appropriate civil action be instituted.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Civil action","label":"2 Civil action","identifier":"/us/usc/t25/s4237/c/2","parentIdentifier":"/us/usc/t25/s4237/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s4237/c/2/A","parentIdentifier":"/us/usc/t25/s4237/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fc%2F2%2FA","sourceRelease":"119-100","text":"to recover the amount of the assistance furnished under this subchapter that was not expended in accordance with this subchapter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s4237/c/2/B","parentIdentifier":"/us/usc/t25/s4237/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fc%2F2%2FB","sourceRelease":"119-100","text":"for mandatory or injunctive relief.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Review","label":"d Review","identifier":"/us/usc/t25/s4237/d","parentIdentifier":"/us/usc/t25/s4237","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s4237/d/1","parentIdentifier":"/us/usc/t25/s4237/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s4237/d/1/A","parentIdentifier":"/us/usc/t25/s4237/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F1%2FA","sourceRelease":"119-100","text":"may, not later than 60 days after receiving such notice, file with the United States Court of Appeals for the Ninth Circuit, or in the United States Court of Appeals for the District of Columbia, a petition for review of the action of the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s4237/d/1/B","parentIdentifier":"/us/usc/t25/s4237/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F1%2FB","sourceRelease":"119-100","text":"upon the filing of any petition under subparagraph (A), shall forthwith transmit copies of the petition to the Secretary and the Attorney General of the United States, who shall represent the Secretary in the litigation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Procedure","label":"2 Procedure","identifier":"/us/usc/t25/s4237/d/2","parentIdentifier":"/us/usc/t25/s4237/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t25/s4237/d/2/A","parentIdentifier":"/us/usc/t25/s4237/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F2%2FA","sourceRelease":"119-100","text":"The Secretary shall file in the court a record of the proceeding on which the Secretary based the action, as provided in .section 2112 of title 28","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Objections","label":"B Objections","identifier":"/us/usc/t25/s4237/d/2/B","parentIdentifier":"/us/usc/t25/s4237/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F2%2FB","sourceRelease":"119-100","text":"No objection to the action of the Secretary shall be considered by the court unless the Department has registered the objection before the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Disposition","label":"3 Disposition","identifier":"/us/usc/t25/s4237/d/3","parentIdentifier":"/us/usc/t25/s4237/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Court proceedings","label":"A Court proceedings","identifier":"/us/usc/t25/s4237/d/3/A","parentIdentifier":"/us/usc/t25/s4237/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"Jurisdiction of court","label":"i Jurisdiction of court","identifier":"/us/usc/t25/s4237/d/3/A/i","parentIdentifier":"/us/usc/t25/s4237/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FA%2Fi","sourceRelease":"119-100","text":"The court shall have jurisdiction to affirm or modify the action of the Secretary or to set the action aside in whole or in part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Findings of fact","label":"ii Findings of fact","identifier":"/us/usc/t25/s4237/d/3/A/ii","parentIdentifier":"/us/usc/t25/s4237/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FA%2Fii","sourceRelease":"119-100","text":"If supported by substantial evidence on the record considered as a whole, the findings of fact by the Secretary shall be conclusive.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":"Addition","label":"iii Addition","identifier":"/us/usc/t25/s4237/d/3/A/iii","parentIdentifier":"/us/usc/t25/s4237/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"The court may order evidence, in addition to the evidence submitted for review under this subsection, to be taken by the Secretary, and to be made part of the record.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Secretary","label":"B Secretary","identifier":"/us/usc/t25/s4237/d/3/B","parentIdentifier":"/us/usc/t25/s4237/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t25/s4237/d/3/B/i","parentIdentifier":"/us/usc/t25/s4237/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t25/s4237/d/3/B/i/I","parentIdentifier":"/us/usc/t25/s4237/d/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FB%2Fi%2FI","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t25/s4237/d/3/B/i/I/aa","parentIdentifier":"/us/usc/t25/s4237/d/3/B/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FB%2Fi%2FI%2Faa","sourceRelease":"119-100","text":"modify the findings of fact of the Secretary; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t25/s4237/d/3/B/i/I/bb","parentIdentifier":"/us/usc/t25/s4237/d/3/B/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FB%2Fi%2FI%2Fbb","sourceRelease":"119-100","text":"make new findings; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t25/s4237/d/3/B/i/II","parentIdentifier":"/us/usc/t25/s4237/d/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FB%2Fi%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t25/s4237/d/3/B/i/II/aa","parentIdentifier":"/us/usc/t25/s4237/d/3/B/i/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FB%2Fi%2FII%2Faa","sourceRelease":"119-100","text":"such modified or new findings; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t25/s4237/d/3/B/i/II/bb","parentIdentifier":"/us/usc/t25/s4237/d/3/B/i/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FB%2Fi%2FII%2Fbb","sourceRelease":"119-100","text":"the recommendation of the Secretary, if any, for the modification or setting aside of the original action of the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Findings","label":"ii Findings","identifier":"/us/usc/t25/s4237/d/3/B/ii","parentIdentifier":"/us/usc/t25/s4237/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t25/s4237/d/3/B/ii/I","parentIdentifier":"/us/usc/t25/s4237/d/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FB%2Fii%2FI","sourceRelease":"119-100","text":"supported by substantial evidence on the record; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t25/s4237/d/3/B/ii/II","parentIdentifier":"/us/usc/t25/s4237/d/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F3%2FB%2Fii%2FII","sourceRelease":"119-100","text":"considered as a whole.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Finality","label":"4 Finality","identifier":"/us/usc/t25/s4237/d/4","parentIdentifier":"/us/usc/t25/s4237/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t25/s4237/d/4/A","parentIdentifier":"/us/usc/t25/s4237/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s4237/d/4/A/i","parentIdentifier":"/us/usc/t25/s4237/d/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F4%2FA%2Fi","sourceRelease":"119-100","text":"the jurisdiction of the court shall be exclusive; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s4237/d/4/A/ii","parentIdentifier":"/us/usc/t25/s4237/d/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F4%2FA%2Fii","sourceRelease":"119-100","text":"the judgment of the court shall be final.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Review by Supreme Court","label":"B Review by Supreme Court","identifier":"/us/usc/t25/s4237/d/4/B","parentIdentifier":"/us/usc/t25/s4237/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4237%2Fd%2F4%2FB","sourceRelease":"119-100","text":"A judgment under subparagraph (A) shall be subject to review by the Supreme Court of the United States upon writ of certiorari or certification, as provided in .section 1254 of title 28","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
