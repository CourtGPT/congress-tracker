r":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s2204i/a/3/C","parentIdentifier":"/us/usc/t7/s2204i/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204i%2Fa%2F3%2FC","sourceRelease":"119-100","text":"farmland transition and succession.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Farmland ownership","label":"b Farmland ownership","identifier":"/us/usc/t7/s2204i/b","parentIdentifier":"/us/usc/t7/s2204i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204i%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2204i/b/1","parentIdentifier":"/us/usc/t7/s2204i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204i%2Fb%2F1","sourceRelease":"119-100","text":"collect and distribute comprehensive reporting of trends in farmland ownership, tenure, transition, barriers to entry, profitability, and viability of beginning farmers and ranchers and socially disadvantaged farmers and ranchers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2204i/b/2","parentIdentifier":"/us/usc/t7/s2204i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204i%2Fb%2F2","sourceRelease":"119-100","text":"develop surveys and report statistical and economic analysis on farmland ownership, tenure, transition, barriers to entry, profitability, and viability of beginning farmers and ranchers, including a regular follow-on survey to each Census of Agriculture with results of the follow-on survey made public not later than 3 years after the previous Census of Agriculture; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s2204i/b/3","parentIdentifier":"/us/usc/t7/s2204i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204i%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2204i/b/3/A","parentIdentifier":"/us/usc/t7/s2204i/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204i%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the extent to which non-farming landowners are purchasing and holding onto farmland for the sole purpose of real estate investment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2204i/b/3/B","parentIdentifier":"/us/usc/t7/s2204i/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204i%2Fb%2F3%2FB","sourceRelease":"119-100","text":"the impact of these farmland ownership trends on the successful entry and viability of beginning farmers and ranchers and socially disadvantaged farmers and ranchers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s2204i/b/3/C","parentIdentifier":"/us/usc/t7/s2204i/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204i%2Fb%2F3%2FC","sourceRelease":"119-100","text":"the extent to which farm and ranch land with undivided interests and no administrative authority identified have farms or ranches operating on that land; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"