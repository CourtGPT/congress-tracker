{"type":"section","nativeType":"section","number":"1474","heading":"Federal intervention actions","label":"1474 Federal intervention actions","identifier":"/us/usc/t33/s1474","parentIdentifier":"/us/usc/t33/ch28","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1474","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1474/1","parentIdentifier":"/us/usc/t33/s1474","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1474%2F1","sourceRelease":"119-100","text":"coordinate and direct all public and private efforts directed at the removal or elimination of the threatened pollution damage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1474/2","parentIdentifier":"/us/usc/t33/s1474","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1474%2F2","sourceRelease":"119-100","text":"directly or indirectly undertake the whole or any part of any salvage or other action he could require or direct under subsection (1) of this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s1474/3","parentIdentifier":"/us/usc/t33/s1474","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1474%2F3","sourceRelease":"119-100","text":"remove, and, if necessary, destroy the ship and cargo which is the source of the danger.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
