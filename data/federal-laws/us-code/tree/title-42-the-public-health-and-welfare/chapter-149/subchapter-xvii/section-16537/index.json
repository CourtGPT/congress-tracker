{"type":"section","nativeType":"section","number":"16537","heading":"Distinguished scientist program","label":"16537 Distinguished scientist program","identifier":"/us/usc/t42/s16537","parentIdentifier":"/us/usc/t42/ch149/schXVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2011—Subsec. (j)(4) to (6). added pars. (4) to (6).Pub. L. 111–358"],"amendments":["Amendments2011—Subsec. (j)(4) to (6). added pars. (4) to (6).Pub. L. 111–358"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purpose","label":"a Purpose","identifier":"/us/usc/t42/s16537/a","parentIdentifier":"/us/usc/t42/s16537","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fa","sourceRelease":"119-100","text":"The purpose of this section is to promote scientific and academic excellence through collaborations between institutions of higher education and National Laboratories.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t42/s16537/b","parentIdentifier":"/us/usc/t42/s16537","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fb","sourceRelease":"119-100","text":"The Secretary shall establish a program to support the joint appointment of distinguished scientists by institutions of higher education and National Laboratories.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Qualifications","label":"c Qualifications","identifier":"/us/usc/t42/s16537/c","parentIdentifier":"/us/usc/t42/s16537","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fc","sourceRelease":"119-100","text":"To be eligible for appointment as a distinguished scientist under this section, an individual, by reason of professional background and experience, shall be able to bring international recognition to the appointing institution of higher education or National Laboratory in the field of scientific endeavor of the individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Selection","label":"d Selection","identifier":"/us/usc/t42/s16537/d","parentIdentifier":"/us/usc/t42/s16537","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fd","sourceRelease":"119-100","text":"A distinguished scientist appointed under this section shall be selected through an open, competitive process.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Appointment","label":"e Appointment","identifier":"/us/usc/t42/s16537/e","parentIdentifier":"/us/usc/t42/s16537","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Institution of higher education","label":"1 Institution of higher education","identifier":"/us/usc/t42/s16537/e/1","parentIdentifier":"/us/usc/t42/s16537/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fe%2F1","sourceRelease":"119-100","text":"An appointment by an institution of higher education under this section shall be filled within the tenure allotment of the institution of higher education, at a minimum rank of professor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"National Laboratory","label":"2 National Laboratory","identifier":"/us/usc/t42/s16537/e/2","parentIdentifier":"/us/usc/t42/s16537/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fe%2F2","sourceRelease":"119-100","text":"An appointment by a National Laboratory under this section shall be at the rank of the highest grade of distinguished scientist or technical staff of the National Laboratory.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Duration","label":"f Duration","identifier":"/us/usc/t42/s16537/f","parentIdentifier":"/us/usc/t42/s16537","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16537/f/1","parentIdentifier":"/us/usc/t42/s16537/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Ff%2F1","sourceRelease":"119-100","text":"be for a term of 6 years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16537/f/2","parentIdentifier":"/us/usc/t42/s16537/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Ff%2F2","sourceRelease":"119-100","text":"consist of 2 3-year funding allotments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Use of funds","label":"g Use of funds","identifier":"/us/usc/t42/s16537/g","parentIdentifier":"/us/usc/t42/s16537","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16537/g/1","parentIdentifier":"/us/usc/t42/s16537/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fg%2F1","sourceRelease":"119-100","text":"the salary of the distinguished scientist and support staff;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16537/g/2","parentIdentifier":"/us/usc/t42/s16537/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fg%2F2","sourceRelease":"119-100","text":"undergraduate, graduate, and post-doctoral appointments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16537/g/3","parentIdentifier":"/us/usc/t42/s16537/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fg%2F3","sourceRelease":"119-100","text":"research-related equipment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16537/g/4","parentIdentifier":"/us/usc/t42/s16537/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fg%2F4","sourceRelease":"119-100","text":"professional travel; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16537/g/5","parentIdentifier":"/us/usc/t42/s16537/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fg%2F5","sourceRelease":"119-100","text":"such other requirements as the Secretary determines to be necessary to carry out the purpose of the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Review","label":"h Review","identifier":"/us/usc/t42/s16537/h","parentIdentifier":"/us/usc/t42/s16537","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16537/h/1","parentIdentifier":"/us/usc/t42/s16537/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fh%2F1","sourceRelease":"119-100","text":"The appointment of a distinguished scientist under this section shall be reviewed at the end of the first 3-year allotment for the distinguished scientist through an open peer-review process to determine whether the appointment is meeting the purpose of this section under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Funding","label":"2 Funding","identifier":"/us/usc/t42/s16537/h/2","parentIdentifier":"/us/usc/t42/s16537/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fh%2F2","sourceRelease":"119-100","text":"Funding of the appointment of the distinguished scientist for the second 3-year allotment shall be determined based on the review conducted under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Cost sharing","label":"i Cost sharing","identifier":"/us/usc/t42/s16537/i","parentIdentifier":"/us/usc/t42/s16537","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fi","sourceRelease":"119-100","text":"To be eligible for assistance under this section, an appointing institution of higher education shall pay at least 50 percent of the total costs of the appointment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"j","heading":"Authorization of appropriations","label":"j Authorization of appropriations","identifier":"/us/usc/t42/s16537/j","parentIdentifier":"/us/usc/t42/s16537","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fj","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16537/j/1","parentIdentifier":"/us/usc/t42/s16537/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fj%2F1","sourceRelease":"119-100","text":"$15,000,000 for fiscal year 2008;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16537/j/2","parentIdentifier":"/us/usc/t42/s16537/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fj%2F2","sourceRelease":"119-100","text":"$20,000,000 for fiscal year 2009;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16537/j/3","parentIdentifier":"/us/usc/t42/s16537/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fj%2F3","sourceRelease":"119-100","text":"$30,000,000 for fiscal year 2010;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16537/j/4","parentIdentifier":"/us/usc/t42/s16537/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fj%2F4","sourceRelease":"119-100","text":"$31,000,000 for fiscal year 2011;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16537/j/5","parentIdentifier":"/us/usc/t42/s16537/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fj%2F5","sourceRelease":"119-100","text":"$32,000,000 for fiscal year 2012; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s16537/j/6","parentIdentifier":"/us/usc/t42/s16537/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16537%2Fj%2F6","sourceRelease":"119-100","text":"$33,000,000 for fiscal year 2013.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
