{"type":"section","nativeType":"section","number":"6329d","heading":"Parental bereavement leave","label":"6329d Parental bereavement leave","identifier":"/us/usc/t5/s6329d","parentIdentifier":"/us/usc/t5/ptIII/sptE/ch63/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6329d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Definitions","label":"a .—Definitions","identifier":"/us/usc/t5/s6329d/a","parentIdentifier":"/us/usc/t5/s6329d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6329d%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6329d/a/1","parentIdentifier":"/us/usc/t5/s6329d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6329d%2Fa%2F1","sourceRelease":"119-100","text":"the terms “employee” and “son or daughter” have the meanings given those terms in section 6381; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6329d/a/2","parentIdentifier":"/us/usc/t5/s6329d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6329d%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s6329d/a/2/A","parentIdentifier":"/us/usc/t5/s6329d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6329d%2Fa%2F2%2FA","sourceRelease":"119-100","text":"pay;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s6329d/a/2/B","parentIdentifier":"/us/usc/t5/s6329d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6329d%2Fa%2F2%2FB","sourceRelease":"119-100","text":"leave to which the employee is otherwise entitled under law; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s6329d/a/2/C","parentIdentifier":"/us/usc/t5/s6329d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6329d%2Fa%2F2%2FC","sourceRelease":"119-100","text":"credit for time or service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Bereavement Leave.—","label":"b Bereavement Leave.—","identifier":"/us/usc/t5/s6329d/b","parentIdentifier":"/us/usc/t5/s6329d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6329d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t5/s6329d/b/1","parentIdentifier":"/us/usc/t5/s6329d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6329d%2Fb%2F1","sourceRelease":"119-100","text":"Subject to paragraphs (2) and (3), an employee shall be entitled to a total of 2 administrative workweeks of paid leave during any 12-month period because of the death of a son or daughter of the employee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Limitation","label":"2 .—Limitation","identifier":"/us/usc/t5/s6329d/b/2","parentIdentifier":"/us/usc/t5/s6329d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6329d%2Fb%2F2","sourceRelease":"119-100","text":"Leave under paragraph (1) may not be taken by an employee intermittently or on a reduced leave schedule unless the employee and the employing agency of the employee agree otherwise.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Notice","label":"3 .—Notice","identifier":"/us/usc/t5/s6329d/b/3","parentIdentifier":"/us/usc/t5/s6329d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6329d%2Fb%2F3","sourceRelease":"119-100","text":"In any case in which the necessity for leave under this subsection is foreseeable, the employee shall provide the employing agency with such notice as is reasonable and practicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
