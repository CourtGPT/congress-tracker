{"type":"section","nativeType":"section","number":"19211","heading":"Early-career research fellowship program","label":"19211 Early-career research fellowship program","identifier":"/us/usc/t42/s19211","parentIdentifier":"/us/usc/t42/ch163/schVI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s19211/a","parentIdentifier":"/us/usc/t42/s19211","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Fa","sourceRelease":"119-100","text":"The Director of the National Science Foundation may establish a 2-year pilot program to make awards to highly qualified early-career investigators to carry out an independent research program at the institution of higher education or participating Federal research facility chosen by such investigator, to last for a period not greater than two years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Selection process","label":"b Selection process","identifier":"/us/usc/t42/s19211/b","parentIdentifier":"/us/usc/t42/s19211","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Fb","sourceRelease":"119-100","text":"The Director of the National Science Foundation shall select recipients under subsection (a) from among citizens, nationals, and lawfully admitted permanent resident aliens of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Outreach","label":"c Outreach","identifier":"/us/usc/t42/s19211/c","parentIdentifier":"/us/usc/t42/s19211","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19211/c/1","parentIdentifier":"/us/usc/t42/s19211/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Fc%2F1","sourceRelease":"119-100","text":"from all regions of the country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19211/c/2","parentIdentifier":"/us/usc/t42/s19211/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Fc%2F2","sourceRelease":"119-100","text":"from historically underrepresented populations in the fields of science, technology, engineering, and mathematics; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19211/c/3","parentIdentifier":"/us/usc/t42/s19211/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19211/c/3/A","parentIdentifier":"/us/usc/t42/s19211/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Fc%2F3%2FA","sourceRelease":"119-100","text":"historically Black colleges and universities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19211/c/3/B","parentIdentifier":"/us/usc/t42/s19211/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Fc%2F3%2FB","sourceRelease":"119-100","text":"Tribal Colleges and Universities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s19211/c/3/C","parentIdentifier":"/us/usc/t42/s19211/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Fc%2F3%2FC","sourceRelease":"119-100","text":"minority-serving institutions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s19211/c/3/D","parentIdentifier":"/us/usc/t42/s19211/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Fc%2F3%2FD","sourceRelease":"119-100","text":"institutions of higher education that are not among the top 50 institutions in annual Federal funding for research; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s19211/c/3/E","parentIdentifier":"/us/usc/t42/s19211/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Fc%2F3%2FE","sourceRelease":"119-100","text":"EPSCoR institutions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Special consideration","label":"d Special consideration","identifier":"/us/usc/t42/s19211/d","parentIdentifier":"/us/usc/t42/s19211","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Fd","sourceRelease":"119-100","text":"The Director of the National Science Foundation shall give special consideration and priority to an application from an individual who graduated from or is intending to carry out research at an institution of the type specified in subsection (c)(3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Reports from fellows","label":"e Reports from fellows","identifier":"/us/usc/t42/s19211/e","parentIdentifier":"/us/usc/t42/s19211","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Fe","sourceRelease":"119-100","text":"Not later than 180 days after the end of the pilot program under this section, each early-career investigator who receives an award under the pilot program shall submit to the Director of the National Science Foundation a report that describes how the early-career investigator used the award funds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Report from the Director","label":"f Report from the Director","identifier":"/us/usc/t42/s19211/f","parentIdentifier":"/us/usc/t42/s19211","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19211/f/1","parentIdentifier":"/us/usc/t42/s19211/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Ff%2F1","sourceRelease":"119-100","text":"A summary of the uses of award funds under this section and the impact of the pilot program under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19211/f/2","parentIdentifier":"/us/usc/t42/s19211/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Ff%2F2","sourceRelease":"119-100","text":"Statistical summary data on fellowship awardees disaggregated by race, ethnicity, sex, geography, age, years since completion of doctoral degree, and institution type.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19211/f/3","parentIdentifier":"/us/usc/t42/s19211/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19211%2Ff%2F3","sourceRelease":"119-100","text":"If determined effective, a plan for permanent implementation of the pilot program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
