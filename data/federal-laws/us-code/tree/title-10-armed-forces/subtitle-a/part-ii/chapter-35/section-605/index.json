119-100","text":"as lieutenant commander, 425;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s605/g/5/C","parentIdentifier":"/us/usc/t10/s605/g/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs605%2Fg%2F5%2FC","sourceRelease":"119-100","text":"as commander, 175; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s605/g/5/D","parentIdentifier":"/us/usc/t10/s605/g/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs605%2Fg%2F5%2FD","sourceRelease":"119-100","text":"as captain, 80.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
