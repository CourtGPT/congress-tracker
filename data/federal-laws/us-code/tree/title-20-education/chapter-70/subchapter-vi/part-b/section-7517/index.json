{"type":"section","nativeType":"section","number":"7517","heading":"Definitions","label":"7517 Definitions","identifier":"/us/usc/t20/s7517","parentIdentifier":"/us/usc/t20/ch70/schVI/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2015—, added par. (1) and redesignated former pars. (1) to (6) as (2) to (7), respectively.Pub. L. 114–95, § 6003(d)","Statutory Notes and Related Subsidiaries","Effective Date of 2015 AmendmentAmendment by effective , except with respect to certain noncompetitive programs and competitive programs, see , set out as a note under .Pub. L. 114–95section 5 of Pub. L. 114–95section 6301 of this titleDec. 10, 2015"],"amendments":["Amendments2015—, added par. (1) and redesignated former pars. (1) to (6) as (2) to (7), respectively.Pub. L. 114–95, § 6003(d)","Effective Date of 2015 AmendmentAmendment by effective , except with respect to certain noncompetitive programs and competitive programs, see , set out as a note under .Pub. L. 114–95section 5 of Pub. L. 114–95section 6301 of this titleDec. 10, 2015"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Community consultation","label":"1 Community consultation","identifier":"/us/usc/t20/s7517/1","parentIdentifier":"/us/usc/t20/s7517","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s7517/1/A","parentIdentifier":"/us/usc/t20/s7517/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F1%2FA","sourceRelease":"119-100","text":"to discuss Native Hawaiian education concerns; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s7517/1/B","parentIdentifier":"/us/usc/t20/s7517/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F1%2FB","sourceRelease":"119-100","text":"about which the public has been given not less than 30 days notice.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Native Hawaiian","label":"2 Native Hawaiian","identifier":"/us/usc/t20/s7517/2","parentIdentifier":"/us/usc/t20/s7517","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s7517/2/A","parentIdentifier":"/us/usc/t20/s7517/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F2%2FA","sourceRelease":"119-100","text":"a citizen of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s7517/2/B","parentIdentifier":"/us/usc/t20/s7517/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s7517/2/B/i","parentIdentifier":"/us/usc/t20/s7517/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F2%2FB%2Fi","sourceRelease":"119-100","text":"genealogical records;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s7517/2/B/ii","parentIdentifier":"/us/usc/t20/s7517/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F2%2FB%2Fii","sourceRelease":"119-100","text":"Kupuna (elders) or Kamaaina (long-term community residents) verification; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t20/s7517/2/B/iii","parentIdentifier":"/us/usc/t20/s7517/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"certified birth records.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Native Hawaiian community-based organization","label":"3 Native Hawaiian community-based organization","identifier":"/us/usc/t20/s7517/3","parentIdentifier":"/us/usc/t20/s7517","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F3","sourceRelease":"119-100","text":"The term “Native Hawaiian community-based organization” means any organization that is composed primarily of Native Hawaiians from a specific community and that assists in the social, cultural, and educational development of Native Hawaiians in that community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Native Hawaiian educational organization","label":"4 Native Hawaiian educational organization","identifier":"/us/usc/t20/s7517/4","parentIdentifier":"/us/usc/t20/s7517","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s7517/4/A","parentIdentifier":"/us/usc/t20/s7517/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F4%2FA","sourceRelease":"119-100","text":"serves the interests of Native Hawaiians;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s7517/4/B","parentIdentifier":"/us/usc/t20/s7517/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F4%2FB","sourceRelease":"119-100","text":"has Native Hawaiians in substantive and policymaking positions within the organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s7517/4/C","parentIdentifier":"/us/usc/t20/s7517/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F4%2FC","sourceRelease":"119-100","text":"incorporates Native Hawaiian perspective, values, language, culture, and traditions into the core function of the organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s7517/4/D","parentIdentifier":"/us/usc/t20/s7517/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F4%2FD","sourceRelease":"119-100","text":"has demonstrated expertise in the education of Native Hawaiian youth; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s7517/4/E","parentIdentifier":"/us/usc/t20/s7517/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F4%2FE","sourceRelease":"119-100","text":"has demonstrated expertise in research and program development.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Native Hawaiian language","label":"5 Native Hawaiian language","identifier":"/us/usc/t20/s7517/5","parentIdentifier":"/us/usc/t20/s7517","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F5","sourceRelease":"119-100","text":"The term “Native Hawaiian language” means the single Native American language indigenous to the original inhabitants of the State of Hawaii.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Native Hawaiian organization","label":"6 Native Hawaiian organization","identifier":"/us/usc/t20/s7517/6","parentIdentifier":"/us/usc/t20/s7517","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s7517/6/A","parentIdentifier":"/us/usc/t20/s7517/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F6%2FA","sourceRelease":"119-100","text":"serves the interests of Native Hawaiians;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s7517/6/B","parentIdentifier":"/us/usc/t20/s7517/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F6%2FB","sourceRelease":"119-100","text":"has Native Hawaiians in substantive and policymaking positions within the organization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s7517/6/C","parentIdentifier":"/us/usc/t20/s7517/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F6%2FC","sourceRelease":"119-100","text":"is recognized by the Governor of Hawaii for the purpose of planning, conducting, or administering programs (or portions of programs) for the benefit of Native Hawaiians.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Office of Hawaiian Affairs","label":"7 Office of Hawaiian Affairs","identifier":"/us/usc/t20/s7517/7","parentIdentifier":"/us/usc/t20/s7517","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7517%2F7","sourceRelease":"119-100","text":"The term “Office of Hawaiian Affairs” means the Office of Hawaiian Affairs established by the Constitution of the State of Hawaii.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
