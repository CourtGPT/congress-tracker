paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s8617A/b/1","parentIdentifier":"/us/usc/t10/s8617A/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8617A%2Fb%2F1","sourceRelease":"119-100","text":"historical significance to naval operations, technology, or personnel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s8617A/b/2","parentIdentifier":"/us/usc/t10/s8617A/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8617A%2Fb%2F2","sourceRelease":"119-100","text":"public accessibility and educational outreach programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s8617A/b/3","parentIdentifier":"/us/usc/t10/s8617A/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8617A%2Fb%2F3","sourceRelease":"119-100","text":"alignment with the mission of the Navy to preserve its heritage.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Criteria for Closure","label":"c .—Criteria for Closure","identifier":"/us/usc/t10/s8617A/c","parentIdentifier":"/us/usc/t10/s8617A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8617A%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s8617A/c/1","parentIdentifier":"/us/usc/t10/s8617A/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8617A%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"su