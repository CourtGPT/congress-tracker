{"type":"section","nativeType":"section","number":"1093a","heading":"Articulation agreements","label":"1093a Articulation agreements","identifier":"/us/usc/t20/s1093a","parentIdentifier":"/us/usc/t20/ch28/schIV/ptG","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1093a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definition","label":"a Definition","identifier":"/us/usc/t20/s1093a/a","parentIdentifier":"/us/usc/t20/s1093a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1093a%2Fa","sourceRelease":"119-100","text":"In this section, the term “articulation agreement” means an agreement between or among institutions of higher education that specifies the acceptability of courses in transfer toward meeting specific degree or program requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Program to encourage articulation agreements","label":"b Program to encourage articulation agreements","identifier":"/us/usc/t20/s1093a/b","parentIdentifier":"/us/usc/t20/s1093a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1093a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Program established","label":"1 Program established","identifier":"/us/usc/t20/s1093a/b/1","parentIdentifier":"/us/usc/t20/s1093a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1093a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1093a/b/1/A","parentIdentifier":"/us/usc/t20/s1093a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1093a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"common course numbering;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1093a/b/1/B","parentIdentifier":"/us/usc/t20/s1093a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1093a%2Fb%2F1%2FB","sourceRelease":"119-100","text":"a general education core curriculum;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1093a/b/1/C","parentIdentifier":"/us/usc/t20/s1093a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1093a%2Fb%2F1%2FC","sourceRelease":"119-100","text":"management systems regarding course equivalency, transfer of credit, and articulation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1093a/b/1/D","parentIdentifier":"/us/usc/t20/s1093a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1093a%2Fb%2F1%2FD","sourceRelease":"119-100","text":"other strategies identified by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Technical assistance provided","label":"2 Technical assistance provided","identifier":"/us/usc/t20/s1093a/b/2","parentIdentifier":"/us/usc/t20/s1093a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1093a%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary shall provide technical assistance to States and public institutions of higher education for the purposes of developing and implementing articulation agreements in accordance with this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Rule of construction","label":"3 Rule of construction","identifier":"/us/usc/t20/s1093a/b/3","parentIdentifier":"/us/usc/t20/s1093a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1093a%2Fb%2F3","sourceRelease":"119-100","text":"Nothing in this subsection shall be construed to authorize the Secretary to require particular policies, procedures, or practices by institutions of higher education with respect to articulation agreements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
