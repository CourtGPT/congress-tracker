html?req=%2Fus%2Fusc%2Ft7%2Fs2008w%2Fe%2F2%2FB%2Fi","sourceRelease":"119-100","text":"high-wage jobs created;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s2008w/e/2/B/ii","parentIdentifier":"/us/usc/t7/s2008w/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008w%2Fe%2F2%2FB%2Fii","sourceRelease":"119-100","text":"high-wage jobs retained;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s2008w/e/2/B/iii","parentIdentifier":"/us/usc/t7/s2008w/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008w%2Fe%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"private investment leveraged;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s2008w/e/2/B/iv","parentIdentifier":"/us/usc/t7/s2008w/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008w%2Fe%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"businesses improved;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t7/s2008w/e/2/B/v","parentIdentifier":"/us/usc/t7/s2008w/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008w%2Fe%2F2%2FB%2Fv","sourceRelease":"119-100","text":"new business formations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t7/s2008w/e/2/B/vi","parentIdentifier":"/us/usc/t7/s2008w/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2008w%2Fe%2F2%2FB%2Fvi","sourceR