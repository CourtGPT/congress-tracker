{"type":"section","nativeType":"section","number":"1388","heading":"Marine mammal cooperative agreements in Alaska","label":"1388 Marine mammal cooperative agreements in Alaska","identifier":"/us/usc/t16/s1388","parentIdentifier":"/us/usc/t16/ch31/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1388","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s1388/a","parentIdentifier":"/us/usc/t16/s1388","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1388%2Fa","sourceRelease":"119-100","text":"The Secretary may enter into cooperative agreements with Alaska Native organizations to conserve marine mammals and provide co-management of subsistence use by Alaska Natives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Grants","label":"b Grants","identifier":"/us/usc/t16/s1388/b","parentIdentifier":"/us/usc/t16/s1388","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1388%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s1388/b/1","parentIdentifier":"/us/usc/t16/s1388/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1388%2Fb%2F1","sourceRelease":"119-100","text":"collecting and analyzing data on marine mammal populations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s1388/b/2","parentIdentifier":"/us/usc/t16/s1388/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1388%2Fb%2F2","sourceRelease":"119-100","text":"monitoring the harvest of marine mammals for subsistence use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s1388/b/3","parentIdentifier":"/us/usc/t16/s1388/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1388%2Fb%2F3","sourceRelease":"119-100","text":"participating in marine mammal research conducted by the Federal Government, States, academic institutions, and private organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s1388/b/4","parentIdentifier":"/us/usc/t16/s1388/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1388%2Fb%2F4","sourceRelease":"119-100","text":"developing marine mammal co-management structures with Federal and State agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Effect of jurisdiction","label":"c Effect of jurisdiction","identifier":"/us/usc/t16/s1388/c","parentIdentifier":"/us/usc/t16/s1388","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1388%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s1388/c/1","parentIdentifier":"/us/usc/t16/s1388/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1388%2Fc%2F1","sourceRelease":"119-100","text":"as authorizing any expansion or change in the respective jurisdiction of Federal, State, or tribal governments over fish and wildlife resources; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s1388/c/2","parentIdentifier":"/us/usc/t16/s1388/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1388%2Fc%2F2","sourceRelease":"119-100","text":"as altering in any respect the existing political or legal status of Alaska Natives, or the governmental or jurisdictional status of Alaska Native communities or Alaska Native entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t16/s1388/d","parentIdentifier":"/us/usc/t16/s1388","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1388%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s1388/d/1","parentIdentifier":"/us/usc/t16/s1388/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1388%2Fd%2F1","sourceRelease":"119-100","text":"$1,500,000 to the Secretary of Commerce for each of the fiscal years 1994, 1995, 1996, 1997, 1998, and 1999; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s1388/d/2","parentIdentifier":"/us/usc/t16/s1388/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1388%2Fd%2F2","sourceRelease":"119-100","text":"$1,000,000 to the Secretary of the Interior for each of the fiscal years 1994, 1995, 1996, 1997, 1998, and 1999.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
