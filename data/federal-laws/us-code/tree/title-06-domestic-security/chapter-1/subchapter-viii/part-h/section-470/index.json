fectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Required disclosures","label":"b Required disclosures","identifier":"/us/usc/t6/s470/b","parentIdentifier":"/us/usc/t6/s470","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs470%2Fb","sourceRelease":"119-100","text":"Each State or local government that receives a homeland security grant shall, not later than 12 months after the later of , and the date of receipt of such grant, and every 12 months thereafter until all funds provided under such grant are expended, submit a report to the Secretary that contains a list of all expenditures made by such State or local government using funds from such grant.October 13, 2006","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
