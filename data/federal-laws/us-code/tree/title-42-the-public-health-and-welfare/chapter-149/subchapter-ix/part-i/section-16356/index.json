{"type":"section","nativeType":"section","number":"16356","heading":"Report on equal employment opportunity practices","label":"16356 Report on equal employment opportunity practices","identifier":"/us/usc/t42/s16356","parentIdentifier":"/us/usc/t42/ch149/schIX/ptI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16356","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16356/1","parentIdentifier":"/us/usc/t42/s16356","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16356%2F1","sourceRelease":"119-100","text":"a thorough review of each National Laboratory contractor’s equal employment opportunity policies, including promotion to management and professional positions and pay raises;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16356/2","parentIdentifier":"/us/usc/t42/s16356","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16356%2F2","sourceRelease":"119-100","text":"a statistical report on complaints and their disposition in the National Laboratories;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16356/3","parentIdentifier":"/us/usc/t42/s16356","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16356%2F3","sourceRelease":"119-100","text":"a description of how equal employment opportunity practices at the National Laboratories are treated in the contract and in calculating award fees for each contractor;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identi