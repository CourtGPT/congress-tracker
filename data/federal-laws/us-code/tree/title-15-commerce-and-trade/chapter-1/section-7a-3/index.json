{"type":"section","nativeType":"section","number":"7a–3","heading":"Anti-retaliation protection for whistleblowers","label":"7a–3 Anti-retaliation protection for whistleblowers","identifier":"/us/usc/t15/s7a–3","parentIdentifier":"/us/usc/t15/ch1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Whistleblower protections for employees, contractors, subcontractors, and agents","label":"a Whistleblower protections for employees, contractors, subcontractors, and agents","identifier":"/us/usc/t15/s7a–3/a","parentIdentifier":"/us/usc/t15/s7a–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s7a–3/a/1","parentIdentifier":"/us/usc/t15/s7a–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7a–3/a/1/A","parentIdentifier":"/us/usc/t15/s7a–3/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s7a–3/a/1/A/i","parentIdentifier":"/us/usc/t15/s7a–3/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"any violation of, or any act or omission the covered individual reasonably believes to be a violation of, the antitrust laws; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s7a–3/a/1/A/ii","parentIdentifier":"/us/usc/t15/s7a–3/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"any violation of, or any act or omission the covered individual reasonably believes to be a violation of, another criminal law committed in conjunction with a potential violation of the antitrust laws or in conjunction with an investigation by the Department of Justice of a potential violation of the antitrust laws; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7a–3/a/1/B","parentIdentifier":"/us/usc/t15/s7a–3/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s7a–3/a/1/B/i","parentIdentifier":"/us/usc/t15/s7a–3/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"any violation of, or any act or omission the covered individual reasonably believes to be a violation of, the antitrust laws; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s7a–3/a/1/B/ii","parentIdentifier":"/us/usc/t15/s7a–3/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"any violation of, or any act or omission the covered individual reasonably believes to be a violation of, another criminal law committed in conjunction with a potential violation of the antitrust laws or in conjunction with an investigation by the Department of Justice of a potential violation of the antitrust laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitation on protections","label":"2 Limitation on protections","identifier":"/us/usc/t15/s7a–3/a/2","parentIdentifier":"/us/usc/t15/s7a–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7a–3/a/2/A","parentIdentifier":"/us/usc/t15/s7a–3/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the covered individual planned and initiated a violation or attempted violation of the antitrust laws;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7a–3/a/2/B","parentIdentifier":"/us/usc/t15/s7a–3/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the covered individual planned and initiated a violation or attempted violation of another criminal law in conjunction with a violation or attempted violation of the antitrust laws; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s7a–3/a/2/C","parentIdentifier":"/us/usc/t15/s7a–3/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F2%2FC","sourceRelease":"119-100","text":"the covered individual planned and initiated an obstruction or attempted obstruction of an investigation by the Department of Justice of a violation of the antitrust laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Definitions","label":"3 Definitions","identifier":"/us/usc/t15/s7a–3/a/3","parentIdentifier":"/us/usc/t15/s7a–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Antitrust laws","label":"A Antitrust laws","identifier":"/us/usc/t15/s7a–3/a/3/A","parentIdentifier":"/us/usc/t15/s7a–3/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F3%2FA","sourceRelease":"119-100","text":"The term “antitrust laws” means section 1 or 3 of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Covered individual","label":"B Covered individual","identifier":"/us/usc/t15/s7a–3/a/3/B","parentIdentifier":"/us/usc/t15/s7a–3/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F3%2FB","sourceRelease":"119-100","text":"The term “covered individual” means an employee, contractor, subcontractor, or agent of an employer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Employer","label":"C Employer","identifier":"/us/usc/t15/s7a–3/a/3/C","parentIdentifier":"/us/usc/t15/s7a–3/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F3%2FC","sourceRelease":"119-100","text":"The term “employer” means a person, or any officer, employee, contractor, subcontractor, or agent of such person.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Federal Government","label":"D Federal Government","identifier":"/us/usc/t15/s7a–3/a/3/D","parentIdentifier":"/us/usc/t15/s7a–3/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F3%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s7a–3/a/3/D/i","parentIdentifier":"/us/usc/t15/s7a–3/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F3%2FD%2Fi","sourceRelease":"119-100","text":"a Federal regulatory or law enforcement agency; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s7a–3/a/3/D/ii","parentIdentifier":"/us/usc/t15/s7a–3/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F3%2FD%2Fii","sourceRelease":"119-100","text":"any Member of Congress or committee of Congress.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":"Person","label":"E Person","identifier":"/us/usc/t15/s7a–3/a/3/E","parentIdentifier":"/us/usc/t15/s7a–3/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F3%2FE","sourceRelease":"119-100","text":"The term “person” has the same meaning as in subsection (a) of .section 12 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Rule of construction","label":"4 Rule of construction","identifier":"/us/usc/t15/s7a–3/a/4","parentIdentifier":"/us/usc/t15/s7a–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fa%2F4","sourceRelease":"119-100","text":"The term “violation”, with respect to the antitrust laws, shall not be construed to include a civil violation of any law that is not also a criminal violation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Enforcement action","label":"b Enforcement action","identifier":"/us/usc/t15/s7a–3/b","parentIdentifier":"/us/usc/t15/s7a–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s7a–3/b/1","parentIdentifier":"/us/usc/t15/s7a–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7a–3/b/1/A","parentIdentifier":"/us/usc/t15/s7a–3/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fb%2F1%2FA","sourceRelease":"119-100","text":"filing a complaint with the Secretary of Labor; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7a–3/b/1/B","parentIdentifier":"/us/usc/t15/s7a–3/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fb%2F1%2FB","sourceRelease":"119-100","text":"if the Secretary of Labor has not issued a final decision within 180 days of the filing of the complaint and there is no showing that such delay is due to the bad faith of the claimant, bringing an action at law or equity for de novo review in the appropriate district court of the United States, which shall have jurisdiction over such an action without regard to the amount in controversy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Procedure","label":"2 Procedure","identifier":"/us/usc/t15/s7a–3/b/2","parentIdentifier":"/us/usc/t15/s7a–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s7a–3/b/2/A","parentIdentifier":"/us/usc/t15/s7a–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fb%2F2%2FA","sourceRelease":"119-100","text":"A complaint filed with the Secretary of Labor under paragraph (1)(A) shall be governed under the rules and procedures set forth in .section 42121(b) of title 49","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exception","label":"B Exception","identifier":"/us/usc/t15/s7a–3/b/2/B","parentIdentifier":"/us/usc/t15/s7a–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fb%2F2%2FB","sourceRelease":"119-100","text":"Notification made under shall be made to any individual named in the complaint and to the employer.section 42121(b)(1) of title 49","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Burdens of proof","label":"C Burdens of proof","identifier":"/us/usc/t15/s7a–3/b/2/C","parentIdentifier":"/us/usc/t15/s7a–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fb%2F2%2FC","sourceRelease":"119-100","text":"An action brought under paragraph (1)(B) shall be governed by the legal burdens of proof set forth in .section 42121(b) of title 49","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Statute of limitations","label":"D Statute of limitations","identifier":"/us/usc/t15/s7a–3/b/2/D","parentIdentifier":"/us/usc/t15/s7a–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fb%2F2%2FD","sourceRelease":"119-100","text":"A complaint under paragraph (1)(A) shall be filed with the Secretary of Labor not later than 180 days after the date on which the violation occurs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":"Civil actions to enforce","label":"E Civil actions to enforce","identifier":"/us/usc/t15/s7a–3/b/2/E","parentIdentifier":"/us/usc/t15/s7a–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fb%2F2%2FE","sourceRelease":"119-100","text":"If a person fails to comply with an order or preliminary order issued by the Secretary of Labor pursuant to the procedures set forth in , the Secretary of Labor or the person on whose behalf the order was issued may bring a civil action to enforce the order in the district court of the United States for the judicial district in which the violation occurred.section 42121(b) of title 49","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Remedies","label":"c Remedies","identifier":"/us/usc/t15/s7a–3/c","parentIdentifier":"/us/usc/t15/s7a–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s7a–3/c/1","parentIdentifier":"/us/usc/t15/s7a–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fc%2F1","sourceRelease":"119-100","text":"A covered individual prevailing in any action under subsection (b)(1) shall be entitled to all relief necessary to make the covered individual whole.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Compensatory damages","label":"2 Compensatory damages","identifier":"/us/usc/t15/s7a–3/c/2","parentIdentifier":"/us/usc/t15/s7a–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7a–3/c/2/A","parentIdentifier":"/us/usc/t15/s7a–3/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fc%2F2%2FA","sourceRelease":"119-100","text":"reinstatement with the same seniority status that the covered individual would have had, but for the discrimination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7a–3/c/2/B","parentIdentifier":"/us/usc/t15/s7a–3/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the amount of back pay, with interest; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s7a–3/c/2/C","parentIdentifier":"/us/usc/t15/s7a–3/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fc%2F2%2FC","sourceRelease":"119-100","text":"compensation for any special damages sustained as a result of the discrimination including litigation costs, expert witness fees, and reasonable attorney’s fees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Rights retained by whistleblowers","label":"d Rights retained by whistleblowers","identifier":"/us/usc/t15/s7a–3/d","parentIdentifier":"/us/usc/t15/s7a–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7a%E2%80%933%2Fd","sourceRelease":"119-100","text":"Nothing in this section shall be deemed to diminish the rights, privileges, or remedies of any covered individual under any Federal or State law, or under any collective bargaining agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
