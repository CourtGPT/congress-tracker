{"type":"section","nativeType":"section","number":"1596b","heading":"Foreign language proficiency: National Foreign Language Skills Registry","label":"1596b Foreign language proficiency: National Foreign Language Skills Registry","identifier":"/us/usc/t10/s1596b","parentIdentifier":"/us/usc/t10/stA/ptII/ch81","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t10/s1596b/a","parentIdentifier":"/us/usc/t10/s1596b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1596b/a/1","parentIdentifier":"/us/usc/t10/s1596b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s1596b/a/1/A","parentIdentifier":"/us/usc/t10/s1596b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fa%2F1%2FA","sourceRelease":"119-100","text":"have proficiency in one or more critical foreign languages;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s1596b/a/1/B","parentIdentifier":"/us/usc/t10/s1596b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fa%2F1%2FB","sourceRelease":"119-100","text":"are willing to provide linguistic services to the United States in the interests of national security during war or a national emergency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s1596b/a/1/C","parentIdentifier":"/us/usc/t10/s1596b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fa%2F1%2FC","sourceRelease":"119-100","text":"meet the eligibility requirements of subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1596b/a/2","parentIdentifier":"/us/usc/t10/s1596b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fa%2F2","sourceRelease":"119-100","text":"The registry shall be known as the “National Foreign Language Skills Registry” (in this section referred to as the “Registry”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Eligible Persons","label":"b .—Eligible Persons","identifier":"/us/usc/t10/s1596b/b","parentIdentifier":"/us/usc/t10/s1596b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1596b/b/1","parentIdentifier":"/us/usc/t10/s1596b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s1596b/b/1/A","parentIdentifier":"/us/usc/t10/s1596b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fb%2F1%2FA","sourceRelease":"119-100","text":"a national of the United States (as defined in section 101(a)(22) of the Immigration and Nationality Act ()); or8 U.S.C. 1101(a)(22)","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s1596b/b/1/B","parentIdentifier":"/us/usc/t10/s1596b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fb%2F1%2FB","sourceRelease":"119-100","text":"an alien lawfully admitted for permanent residence (as defined in section 101(a)(20) of the Immigration and Nationality Act ());8 U.S.C. 1101(a)(20)","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1596b/b/2","parentIdentifier":"/us/usc/t10/s1596b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s1596b/b/2/A","parentIdentifier":"/us/usc/t10/s1596b/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fb%2F2%2FA","sourceRelease":"119-100","text":"to provide linguistic services for a foreign language as described in subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s1596b/b/2/B","parentIdentifier":"/us/usc/t10/s1596b/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fb%2F2%2FB","sourceRelease":"119-100","text":"to be listed on the Registry; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s1596b/b/3","parentIdentifier":"/us/usc/t10/s1596b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fb%2F3","sourceRelease":"119-100","text":"shall meet such language proficiency and other selection criteria as may be prescribed by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Registered Information","label":"c .—Registered Information","identifier":"/us/usc/t10/s1596b/c","parentIdentifier":"/us/usc/t10/s1596b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1596b/c/1","parentIdentifier":"/us/usc/t10/s1596b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fc%2F1","sourceRelease":"119-100","text":"The names of eligible persons selected by the Secretary for listing on the Registry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1596b/c/2","parentIdentifier":"/us/usc/t10/s1596b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fc%2F2","sourceRelease":"119-100","text":"Such other information on such persons as the Secretary determines pertinent to the use of such persons to provide linguistic services as described in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Protection of Privacy","label":"d .—Protection of Privacy","identifier":"/us/usc/t10/s1596b/d","parentIdentifier":"/us/usc/t10/s1596b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fd","sourceRelease":"119-100","text":"The Secretary may withhold from public disclosure the information maintained in the Registry in accordance with .section 552a of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Designation of Critical Foreign Languages","label":"e .—Designation of Critical Foreign Languages","identifier":"/us/usc/t10/s1596b/e","parentIdentifier":"/us/usc/t10/s1596b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Fe","sourceRelease":"119-100","text":"The Secretary shall designate those languages that are critical foreign languages for the purposes of this section. The Secretary shall make such a designation for any foreign language for which there is a shortage of experts in translation or interpretation available to meet requirements of the Secretary or of the head of any other department or agency of the United States for translation or interpretation in the national security interests of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Linguistic Services Defined","label":"f .—Linguistic Services Defined","identifier":"/us/usc/t10/s1596b/f","parentIdentifier":"/us/usc/t10/s1596b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1596b%2Ff","sourceRelease":"119-100","text":"In this section, the term “linguistic services” means translation or interpretation of communication in a foreign language.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
