[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t43/s1748d/8","parentIdentifier":"/us/usc/t43/s1748d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748d%2F8","sourceRelease":"119-100","text":"the number of miles of roads on Federal land in need of decommissioning;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t43/s1748d/9","parentIdentifier":"/us/usc/t43/s1748d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748d%2F9","sourceRelease":"119-100","text":"the maintenance backlog, as of the date of the report, for roads, trails, and recreational facilities on Federal land;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t43/s1748d/10","parentIdentifier":"/us/usc/t43/s1748d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748d%2F10","sourceRelease":"119-100","text":"other measures needed to maintain, improve, or restore water quality on Federal land; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t43/s1748d/11","parentIdentifier":"/us/usc/t43/s1748d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748d%2F11","sourceRelease":"119-100","text":"other measures needed to improve ecosystem function or resiliency on Federal land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
