{"type":"section","nativeType":"section","number":"4262","heading":"Prioritization of efforts and assistance to combat marine debris and improve plastic waste management","label":"4262 Prioritization of efforts and assistance to combat marine debris and improve plastic waste management","identifier":"/us/usc/t33/s4262","parentIdentifier":"/us/usc/t33/ch55/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t33/s4262/a","parentIdentifier":"/us/usc/t33/s4262","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s4262/a/1","parentIdentifier":"/us/usc/t33/s4262/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F1","sourceRelease":"119-100","text":"lead and coordinate efforts to implement the policy described in ; andsection 4261 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s4262/a/2","parentIdentifier":"/us/usc/t33/s4262/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s4262/a/2/A","parentIdentifier":"/us/usc/t33/s4262/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s4262/a/2/A/i","parentIdentifier":"/us/usc/t33/s4262/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"improve the capacity, security, and standards of operations of post-consumer materials management systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s4262/a/2/A/ii","parentIdentifier":"/us/usc/t33/s4262/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"monitor and track how well post-consumer materials management systems are functioning nationwide, based on uniform and transparent standards developed in cooperation with municipal, industrial, and civil society stakeholders;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t33/s4262/a/2/A/iii","parentIdentifier":"/us/usc/t33/s4262/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"identify the operational challenges of post-consumer materials management systems and develop policy and programmatic solutions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t33/s4262/a/2/A/iv","parentIdentifier":"/us/usc/t33/s4262/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"end intentional or unintentional incentives for municipalities, industries, and individuals to improperly dispose of plastic waste; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t33/s4262/a/2/A/v","parentIdentifier":"/us/usc/t33/s4262/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FA%2Fv","sourceRelease":"119-100","text":"conduct outreach campaigns to raise public awareness of the importance of proper waste disposal and the reduction of plastic waste;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s4262/a/2/B","parentIdentifier":"/us/usc/t33/s4262/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FB","sourceRelease":"119-100","text":"to facilitate the involvement of municipalities and industries in improving solid waste reduction, collection, disposal, and reuse and recycling projects, programs, and initiatives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s4262/a/2/C","parentIdentifier":"/us/usc/t33/s4262/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s4262/a/2/C/i","parentIdentifier":"/us/usc/t33/s4262/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FC%2Fi","sourceRelease":"119-100","text":"maximizing the number of people and businesses, in both rural and urban communities, receiving reliable solid waste and post-consumer materials management services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s4262/a/2/C/ii","parentIdentifier":"/us/usc/t33/s4262/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FC%2Fii","sourceRelease":"119-100","text":"improving and expanding the capacity of foreign industries to responsibly employ post-consumer materials management practices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t33/s4262/a/2/C/iii","parentIdentifier":"/us/usc/t33/s4262/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FC%2Fiii","sourceRelease":"119-100","text":"improving and expanding the capacity and transparency of tracking mechanisms for marine debris to reduce the impacts on the marine environment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t33/s4262/a/2/C/iv","parentIdentifier":"/us/usc/t33/s4262/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FC%2Fiv","sourceRelease":"119-100","text":"eliminating incentives that undermine responsible post-consumer materials management practices and lead to improper waste disposal practices and leakage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t33/s4262/a/2/C/v","parentIdentifier":"/us/usc/t33/s4262/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FC%2Fv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t33/s4262/a/2/C/v/I","parentIdentifier":"/us/usc/t33/s4262/a/2/C/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FC%2Fv%2FI","sourceRelease":"119-100","text":"to reduce, monitor, regulate, and manage waste, post-consumer materials and plastic waste, and pollution appropriately and transparently, including imports of plastic waste from the United States and other countries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t33/s4262/a/2/C/v/II","parentIdentifier":"/us/usc/t33/s4262/a/2/C/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FC%2Fv%2FII","sourceRelease":"119-100","text":"to encourage private investment in post-consumer materials management and reduction; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t33/s4262/a/2/C/v/III","parentIdentifier":"/us/usc/t33/s4262/a/2/C/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FC%2Fv%2FIII","sourceRelease":"119-100","text":"to encourage private investment, grow opportunities, and develop markets for recyclable, reusable, and repurposed plastic waste and post-consumer materials, and products with high levels of recycled plastic content, at both national and local levels; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t33/s4262/a/2/C/vi","parentIdentifier":"/us/usc/t33/s4262/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FC%2Fvi","sourceRelease":"119-100","text":"promoting safe and affordable reusable alternatives to disposable plastic products, to the extent practicable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t33/s4262/a/2/D","parentIdentifier":"/us/usc/t33/s4262/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fa%2F2%2FD","sourceRelease":"119-100","text":"to research, identify, and facilitate opportunities to promote collection and proper disposal of damaged or derelict fishing gear.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Officials specified","label":"b Officials specified","identifier":"/us/usc/t33/s4262/b","parentIdentifier":"/us/usc/t33/s4262","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s4262/b/1","parentIdentifier":"/us/usc/t33/s4262/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fb%2F1","sourceRelease":"119-100","text":"The United States Trade Representative.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s4262/b/2","parentIdentifier":"/us/usc/t33/s4262/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fb%2F2","sourceRelease":"119-100","text":"The Under Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s4262/b/3","parentIdentifier":"/us/usc/t33/s4262/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fb%2F3","sourceRelease":"119-100","text":"The EPA Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s4262/b/4","parentIdentifier":"/us/usc/t33/s4262/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fb%2F4","sourceRelease":"119-100","text":"The Director of the Trade and Development Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t33/s4262/b/5","parentIdentifier":"/us/usc/t33/s4262/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fb%2F5","sourceRelease":"119-100","text":"The President and the Board of Directors of the Overseas Private Investment Corporation or the Chief Executive Officer and the Board of Directors of the United States International Development Finance Corporation, as appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t33/s4262/b/6","parentIdentifier":"/us/usc/t33/s4262/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fb%2F6","sourceRelease":"119-100","text":"The Chief Executive Officer and the Board of Directors of the Millennium Challenge Corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t33/s4262/b/7","parentIdentifier":"/us/usc/t33/s4262/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fb%2F7","sourceRelease":"119-100","text":"The Commandant of the Coast Guard, with respect to pollution from ships.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t33/s4262/b/8","parentIdentifier":"/us/usc/t33/s4262/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fb%2F8","sourceRelease":"119-100","text":"The heads of such other agencies as the Secretary of State considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Prioritization","label":"c Prioritization","identifier":"/us/usc/t33/s4262/c","parentIdentifier":"/us/usc/t33/s4262","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s4262/c/1","parentIdentifier":"/us/usc/t33/s4262/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fc%2F1","sourceRelease":"119-100","text":"rapidly developing economies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s4262/c/2","parentIdentifier":"/us/usc/t33/s4262/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fc%2F2","sourceRelease":"119-100","text":"rivers and coastal areas that are the most severe sources of marine debris, as identified by the best available science.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Effectiveness measurement","label":"d Effectiveness measurement","identifier":"/us/usc/t33/s4262/d","parentIdentifier":"/us/usc/t33/s4262","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fd","sourceRelease":"119-100","text":"In prioritizing and expediting efforts and assistance under this section, the officials specified in subsection (b) shall use clear, accountable, and metric-based targets to measure the effectiveness of guarantees and assistance in achieving the policy described in .section 4261 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Rule of construction","label":"e Rule of construction","identifier":"/us/usc/t33/s4262/e","parentIdentifier":"/us/usc/t33/s4262","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4262%2Fe","sourceRelease":"119-100","text":"Nothing in this section may be construed to authorize the modification of or the imposition of limits on the portfolios of any agency or institution led by an official specified in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
