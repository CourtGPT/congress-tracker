{"type":"section","nativeType":"section","number":"2152j","heading":"Statement of policy","label":"2152j Statement of policy","identifier":"/us/usc/t22/s2152j","parentIdentifier":"/us/usc/t22/ch32/schI/ptI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2152j","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Women, Peace, and Security Act of 2017, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s2152j/1","parentIdentifier":"/us/usc/t22/s2152j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2152j%2F1","sourceRelease":"119-100","text":"integrate the perspectives and interests of affected women into conflict-prevention activities and strategies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s2152j/2","parentIdentifier":"/us/usc/t22/s2152j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2152j%2F2","sourceRelease":"119-100","text":"encourage partner governments to adopt plans to improve the meaningful participation of women in peace and security processes and decision-making institutions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s2152j/3","parentIdentifier":"/us/usc/t22/s2152j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2152j%2F3","sourceRelease":"119-100","text":"promote the physical safety, economic security, and dignity of women and girls;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s2152j/4","parentIdentifier":"/us/usc/t22/s2152j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2152j%2F4","sourceRelease":"119-100","text":"support the equal access of women to aid distribution mechanisms and services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s2152j/5","parentIdentifier":"/us/usc/t22/s2152j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2152j%2F5","sourceRelease":"119-100","text":"collect and analyze gender data for the purpose of developing and enhancing early warning systems of conflict and violence;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s2152j/6","parentIdentifier":"/us/usc/t22/s2152j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2152j%2F6","sourceRelease":"119-100","text":"adjust policies and programs to improve outcomes in gender equality and the empowerment of women; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t22/s2152j/7","parentIdentifier":"/us/usc/t22/s2152j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2152j%2F7","sourceRelease":"119-100","text":"monitor, analyze, and evaluate the efforts related to each strategy submitted under and the impact of such efforts.section 2152j–1 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
