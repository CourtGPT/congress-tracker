{"type":"section","nativeType":"section","number":"8029","heading":"Naval Air Warfare Rapid Capabilities Office","label":"8029 Naval Air Warfare Rapid Capabilities Office","identifier":"/us/usc/t10/s8029","parentIdentifier":"/us/usc/t10/stC/ptI/ch803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t10/s8029/a","parentIdentifier":"/us/usc/t10/s8029","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fa","sourceRelease":"119-100","text":"There is established within the Department of the Navy an office to be known as the Naval Air Warfare Rapid Capabilities Office (in this section referred to as the “Office”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Head of Office","label":"b .—Head of Office","identifier":"/us/usc/t10/s8029/b","parentIdentifier":"/us/usc/t10/s8029","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fb","sourceRelease":"119-100","text":"The head of the Office shall be the designee of the Commander of the Naval Air Systems Command.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Mission","label":"c .—Mission","identifier":"/us/usc/t10/s8029/c","parentIdentifier":"/us/usc/t10/s8029","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s8029/c/1","parentIdentifier":"/us/usc/t10/s8029/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8029/c/1/A","parentIdentifier":"/us/usc/t10/s8029/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fc%2F1%2FA","sourceRelease":"119-100","text":"new naval aviation weapons and airborne electronic warfare capabilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8029/c/1/B","parentIdentifier":"/us/usc/t10/s8029/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fc%2F1%2FB","sourceRelease":"119-100","text":"innovative applications for existing naval aviation weapons and airborne electronic warfare capabilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s8029/c/1/C","parentIdentifier":"/us/usc/t10/s8029/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fc%2F1%2FC","sourceRelease":"119-100","text":"other innovative solutions to enhance the effectiveness of naval aviation weapons and airborne electronic warfare capabilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s8029/c/2","parentIdentifier":"/us/usc/t10/s8029/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fc%2F2","sourceRelease":"119-100","text":"to contribute to the rapid experimentation, development, testing, and fielding of unclassified and classified naval aviation weapons and airborne electronic warfare capabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Acquisition Authorities.—","label":"d Acquisition Authorities.—","identifier":"/us/usc/t10/s8029/d","parentIdentifier":"/us/usc/t10/s8029","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t10/s8029/d/1","parentIdentifier":"/us/usc/t10/s8029/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8029/d/1/A","parentIdentifier":"/us/usc/t10/s8029/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fd%2F1%2FA","sourceRelease":"119-100","text":"any applicable pathway of the adaptive acquisition framework (as described in Department of Defense Instruction 5000.02, “Operation of the Adaptive Acquisition Framework”); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8029/d/1/B","parentIdentifier":"/us/usc/t10/s8029/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fd%2F1%2FB","sourceRelease":"119-100","text":"any other alternative acquisition pathway that allows for accelerated or flexible methods of contracting.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Inapplicability of jcids","label":"2 .—Inapplicability of jcids","identifier":"/us/usc/t10/s8029/d/2","parentIdentifier":"/us/usc/t10/s8029/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fd%2F2","sourceRelease":"119-100","text":"The Joint Capabilities Integration and Development System process shall not apply to procurements described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Required Program Elements","label":"e .—Required Program Elements","identifier":"/us/usc/t10/s8029/e","parentIdentifier":"/us/usc/t10/s8029","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s8029/e/1","parentIdentifier":"/us/usc/t10/s8029/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fe%2F1","sourceRelease":"119-100","text":"there are separate, dedicated program elements for naval air warfare rapid capabilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s8029/e/2","parentIdentifier":"/us/usc/t10/s8029/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fe%2F2","sourceRelease":"119-100","text":"the Office executes the responsibilities of the Office using such program elements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Executive Oversight Board.—","label":"f Executive Oversight Board.—","identifier":"/us/usc/t10/s8029/f","parentIdentifier":"/us/usc/t10/s8029","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t10/s8029/f/1","parentIdentifier":"/us/usc/t10/s8029/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Ff%2F1","sourceRelease":"119-100","text":"There is an executive oversight board for the Office which shall consist of the officials specified in paragraph (2). The executive oversight board shall provide prioritization, oversight, and approval of projects of the Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Officials specified","label":"2 .—Officials specified","identifier":"/us/usc/t10/s8029/f/2","parentIdentifier":"/us/usc/t10/s8029/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8029/f/2/A","parentIdentifier":"/us/usc/t10/s8029/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Ff%2F2%2FA","sourceRelease":"119-100","text":"The Vice Chief of Naval Operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8029/f/2/B","parentIdentifier":"/us/usc/t10/s8029/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Ff%2F2%2FB","sourceRelease":"119-100","text":"The Assistant Commandant of the Marine Corps.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s8029/f/2/C","parentIdentifier":"/us/usc/t10/s8029/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Ff%2F2%2FC","sourceRelease":"119-100","text":"The Assistant Secretary of the Navy for Research, Development and Acquisition.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s8029/f/2/D","parentIdentifier":"/us/usc/t10/s8029/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Ff%2F2%2FD","sourceRelease":"119-100","text":"The Commander of the Naval Air Systems Command.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Annual Reports and Briefings.—","label":"g Annual Reports and Briefings.—","identifier":"/us/usc/t10/s8029/g","parentIdentifier":"/us/usc/t10/s8029","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Report","label":"1 .—Report","identifier":"/us/usc/t10/s8029/g/1","parentIdentifier":"/us/usc/t10/s8029/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fg%2F1","sourceRelease":"119-100","text":"On an annual basis, the head of the Office shall submit to the executive oversight board described in subsection (f) a report on the activities of the Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Briefing","label":"2 .—Briefing","identifier":"/us/usc/t10/s8029/g/2","parentIdentifier":"/us/usc/t10/s8029/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fg%2F2","sourceRelease":"119-100","text":"On an annual basis following the submittal of the report under paragraph (1), the Assistant Secretary of the Navy for Research, Development and Acquisition shall provide to the Committees on Armed Services of the Senate and the House of Representatives a briefing on the activities of the Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Elements","label":"3 .—Elements","identifier":"/us/usc/t10/s8029/g/3","parentIdentifier":"/us/usc/t10/s8029/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fg%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8029/g/3/A","parentIdentifier":"/us/usc/t10/s8029/g/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fg%2F3%2FA","sourceRelease":"119-100","text":"funding allocations for the projects of the Office;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8029/g/3/B","parentIdentifier":"/us/usc/t10/s8029/g/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fg%2F3%2FB","sourceRelease":"119-100","text":"capability gaps addressed by the Office;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s8029/g/3/C","parentIdentifier":"/us/usc/t10/s8029/g/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fg%2F3%2FC","sourceRelease":"119-100","text":"the progress of the Office in experimenting, developing, testing, and fielding capabilities described in subsection (c); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s8029/g/3/D","parentIdentifier":"/us/usc/t10/s8029/g/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8029%2Fg%2F3%2FD","sourceRelease":"119-100","text":"any barriers to the ability of the Office to carry out its mission, including any legislative or regulatory barriers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
