rease determined under section 3015(h).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Covered Preparatory Course Defined","label":"d .—Covered Preparatory Course Defined","identifier":"/us/usc/t38/s3315B/d","parentIdentifier":"/us/usc/t38/s3315B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3315B%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s3315B/d/1","parentIdentifier":"/us/usc/t38/s3315B/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3315B%2Fd%2F1","sourceRelease":"119-100","text":"for a licensing or certification test that is required or used to enter into, maintain, or advance in employment in a predetermined and identified vocation or profession; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s3315B/d/2","parentIdentifier":"/us/usc/t38/s3315B/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3315B%2Fd%2F2","sourceRelease":"119-100","text":"that has been approved by the State approving agency concerned.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
