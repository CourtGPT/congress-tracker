{"type":"section","nativeType":"section","number":"20103","heading":"Members not on sustained duty: agreements concerning conditions of service","label":"20103 Members not on sustained duty: agreements concerning conditions of service","identifier":"/us/usc/t10/s20103","parentIdentifier":"/us/usc/t10/stF/ptI/ch2003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20103","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Agreements","label":"a .—Agreements","identifier":"/us/usc/t10/s20103/a","parentIdentifier":"/us/usc/t10/s20103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20103%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s20103/a/1","parentIdentifier":"/us/usc/t10/s20103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20103%2Fa%2F1","sourceRelease":"119-100","text":"requiring the member to serve on active duty for a definite period of time;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s20103/a/2","parentIdentifier":"/us/usc/t10/s20103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20103%2Fa%2F2","sourceRelease":"119-100","text":"specifying the conditions of the member’s service on active duty; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s20103/a/3","parentIdentifier":"/us/usc/t10/s20103/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20103%2Fa%2F3","sourceRelease":"119-100","text":"for a member serving in a space force inactive status, specifying the conditions for the member’s continued service as well as order to active duty with and without the consent of the member.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Conditions of Service","label":"b .—Conditions of Service","identifier":"/us/usc/t10/s20103/b","parentIdentifier":"/us/usc/t10/s20103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20103%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s20103/b/1","parentIdentifier":"/us/usc/t10/s20103/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20103%2Fb%2F1","sourceRelease":"119-100","text":"what conditions of service may be specified in the agreement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s20103/b/2","parentIdentifier":"/us/usc/t10/s20103/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20103%2Fb%2F2","sourceRelease":"119-100","text":"the obligations of the parties; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s20103/b/3","parentIdentifier":"/us/usc/t10/s20103/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20103%2Fb%2F3","sourceRelease":"119-100","text":"the consequences of failure to comply with the terms of the agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Authority for Retention on Active Duty During War or National Emergency","label":"c .—Authority for Retention on Active Duty During War or National Emergency","identifier":"/us/usc/t10/s20103/c","parentIdentifier":"/us/usc/t10/s20103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20103%2Fc","sourceRelease":"119-100","text":"If the period of service on active duty of a member under an agreement under subsection (a) expires during a war or during a national emergency declared by Congress or the President, the member concerned may be kept on active duty, without the consent of the member, as otherwise prescribed by law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
