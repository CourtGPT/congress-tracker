{"type":"section","nativeType":"section","number":"6416","heading":"Independent evaluation of programs","label":"6416 Independent evaluation of programs","identifier":"/us/usc/t7/s6416","parentIdentifier":"/us/usc/t7/ch93","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6416","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Review and evaluation","label":"a Review and evaluation","identifier":"/us/usc/t7/s6416/a","parentIdentifier":"/us/usc/t7/s6416","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6416%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s6416/a/1","parentIdentifier":"/us/usc/t7/s6416/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6416%2Fa%2F1","sourceRelease":"119-100","text":"determine the effectiveness of the promotion program conducted under this chapter on fluid milk sales;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s6416/a/2","parentIdentifier":"/us/usc/t7/s6416/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6416%2Fa%2F2","sourceRelease":"119-100","text":"determine if the assessments for the program have been passed back to milk producers by fluid milk processors; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s6416/a/3","parentIdentifier":"/us/usc/t7/s6416/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6416%2Fa%2F3","sourceRelease":"119-100","text":"make recommendations for future funding and assessment levels for the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report to Congress","label":"b Report to Congress","identifier":"/us/usc/t7/s6416/b","parentIdentifier":"/us/usc/t7/s6416","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6416%2Fb","sourceRelease":"119-100","text":"The Comptroller General shall submit a report to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate on the valuations made under this section no later than .January 1, 1995","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
