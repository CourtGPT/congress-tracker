{"type":"section","nativeType":"section","number":"10371","heading":"Water prediction and forecasting","label":"10371 Water prediction and forecasting","identifier":"/us/usc/t42/s10371","parentIdentifier":"/us/usc/t42/ch109B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Coordinated Ocean Observations and Research Act of 2020, and not as part of subtitle F of title IX of which comprises this chapter.Pub. L. 111–11"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"National Water Center","label":"a National Water Center","identifier":"/us/usc/t42/s10371/a","parentIdentifier":"/us/usc/t42/s10371","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t42/s10371/a/1","parentIdentifier":"/us/usc/t42/s10371/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s10371/a/1/A","parentIdentifier":"/us/usc/t42/s10371/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s10371/a/1/A/i","parentIdentifier":"/us/usc/t42/s10371/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"to serve as the research and operational center of excellence for hydrologic analyses, forecasting, and related decision support services within the National Oceanic and Atmospheric Administration and the National Weather Service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s10371/a/1/A/ii","parentIdentifier":"/us/usc/t42/s10371/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"to facilitate collaboration across Federal and State departments and agencies, academia, and the private sector on matters relating to water resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Designation","label":"B Designation","identifier":"/us/usc/t42/s10371/a/1/B","parentIdentifier":"/us/usc/t42/s10371/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fa%2F1%2FB","sourceRelease":"119-100","text":"The center established under subparagraph (A) shall be known as the “National Water Center”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Functions","label":"2 Functions","identifier":"/us/usc/t42/s10371/a/2","parentIdentifier":"/us/usc/t42/s10371/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s10371/a/2/A","parentIdentifier":"/us/usc/t42/s10371/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fa%2F2%2FA","sourceRelease":"119-100","text":"Improving understanding of water resources, stakeholder needs regarding water resources, and identifying science and services gaps relating to water resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s10371/a/2/B","parentIdentifier":"/us/usc/t42/s10371/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fa%2F2%2FB","sourceRelease":"119-100","text":"Developing and implementing advanced water resources modeling capabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s10371/a/2/C","parentIdentifier":"/us/usc/t42/s10371/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fa%2F2%2FC","sourceRelease":"119-100","text":"Facilitating the transition of hydrologic research into operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s10371/a/2/D","parentIdentifier":"/us/usc/t42/s10371/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fa%2F2%2FD","sourceRelease":"119-100","text":"Delivering analyses, forecasts, and inundation information and guidance for all hydrologic events in the United States, including flash flooding, riverine flooding, and water resources outlooks.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s10371/a/2/E","parentIdentifier":"/us/usc/t42/s10371/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fa%2F2%2FE","sourceRelease":"119-100","text":"In coordination with warning coordination meteorologists, providing decision-support services to inform emergency management and water resources decisions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"National instructions","label":"b National instructions","identifier":"/us/usc/t42/s10371/b","parentIdentifier":"/us/usc/t42/s10371","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s10371/b/1","parentIdentifier":"/us/usc/t42/s10371/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fb%2F1","sourceRelease":"119-100","text":"Not later than one year after , the Under Secretary, acting through the Director of the National Weather Service, shall make public an operations and services policy directive for the National Water Center.December 31, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t42/s10371/b/2","parentIdentifier":"/us/usc/t42/s10371/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s10371/b/2/A","parentIdentifier":"/us/usc/t42/s10371/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fb%2F2%2FA","sourceRelease":"119-100","text":"Operational staff responsibilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s10371/b/2/B","parentIdentifier":"/us/usc/t42/s10371/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fb%2F2%2FB","sourceRelease":"119-100","text":"Guidelines for content, format, and provision of hydrologic and inundation products developed by the National Water Center.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s10371/b/2/C","parentIdentifier":"/us/usc/t42/s10371/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fb%2F2%2FC","sourceRelease":"119-100","text":"Procedures for cooperation and coordination between the National Water Center, the National Weather Service National Centers for Environmental Prediction, National Weather Service River Forecast Centers, and National Weather Service Weather Forecast Offices.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Total water prediction","label":"c Total water prediction","identifier":"/us/usc/t42/s10371/c","parentIdentifier":"/us/usc/t42/s10371","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s10371/c/1","parentIdentifier":"/us/usc/t42/s10371/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fc%2F1","sourceRelease":"119-100","text":"initiate and lead research and development activities to develop operational water resource prediction and related decision support products;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s10371/c/2","parentIdentifier":"/us/usc/t42/s10371/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s10371/c/2/A","parentIdentifier":"/us/usc/t42/s10371/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the relevant Federal agencies represented on the National Science and Technology Council, Committee on Environment, Natural Resources, and Sustainability and the Subcommittee on Disaster Reduction;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s10371/c/2/B","parentIdentifier":"/us/usc/t42/s10371/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fc%2F2%2FB","sourceRelease":"119-100","text":"State water resource agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s10371/c/2/C","parentIdentifier":"/us/usc/t42/s10371/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fc%2F2%2FC","sourceRelease":"119-100","text":"State and local emergency management agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s10371/c/3","parentIdentifier":"/us/usc/t42/s10371/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fc%2F3","sourceRelease":"119-100","text":"in carrying out the responsibilities described in paragraphs (1) and (2), collaboratively develop capabilities necessary for total water predictive capacity, including observations, modeling, data management, supercomputing, social science, and communications.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s10371/d","parentIdentifier":"/us/usc/t42/s10371","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s10371/d/1","parentIdentifier":"/us/usc/t42/s10371/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fd%2F1","sourceRelease":"119-100","text":"$44,500,000 for fiscal year 2021.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s10371/d/2","parentIdentifier":"/us/usc/t42/s10371/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fd%2F2","sourceRelease":"119-100","text":"$45,000,000 for fiscal year 2022.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s10371/d/3","parentIdentifier":"/us/usc/t42/s10371/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fd%2F3","sourceRelease":"119-100","text":"$45,500,000 for fiscal year 2023.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s10371/d/4","parentIdentifier":"/us/usc/t42/s10371/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fd%2F4","sourceRelease":"119-100","text":"$46,000,000 for fiscal year 2024.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Derivation of funds","label":"e Derivation of funds","identifier":"/us/usc/t42/s10371/e","parentIdentifier":"/us/usc/t42/s10371","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10371%2Fe","sourceRelease":"119-100","text":"Funds to carry out this section shall be derived from amounts authorized to be appropriated to the National Weather Service and the National Ocean Service that are enacted after .December 31, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
