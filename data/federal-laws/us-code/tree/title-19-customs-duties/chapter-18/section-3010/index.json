{"type":"section","nativeType":"section","number":"3010","heading":"United States participation on Customs Cooperation Council regarding Convention","label":"3010 United States participation on Customs Cooperation Council regarding Convention","identifier":"/us/usc/t19/s3010","parentIdentifier":"/us/usc/t19/ch18","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments1996—Subsec. (b)(1). substituted “1484(f)” for “1484(e)”.Pub. L. 104–295"],"amendments":["Amendments1996—Subsec. (b)(1). substituted “1484(f)” for “1484(e)”.Pub. L. 104–295"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Principal United States agencies","label":"a Principal United States agencies","identifier":"/us/usc/t19/s3010/a","parentIdentifier":"/us/usc/t19/s3010","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s3010/a/1","parentIdentifier":"/us/usc/t19/s3010/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s3010/a/1/A","parentIdentifier":"/us/usc/t19/s3010/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fa%2F1%2FA","sourceRelease":"119-100","text":"be primarily responsible for formulating United States Government positions on technical and procedural issues; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s3010/a/1/B","parentIdentifier":"/us/usc/t19/s3010/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fa%2F1%2FB","sourceRelease":"119-100","text":"represent the United States Government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s3010/a/2","parentIdentifier":"/us/usc/t19/s3010/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fa%2F2","sourceRelease":"119-100","text":"The Department of Agriculture and other interested Federal agencies shall provide to the Department of the Treasury, the Department of Commerce, and the Commission technical advice and assistance relating to the functions referred to in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Development of technical proposals","label":"b Development of technical proposals","identifier":"/us/usc/t19/s3010/b","parentIdentifier":"/us/usc/t19/s3010","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s3010/b/1","parentIdentifier":"/us/usc/t19/s3010/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fb%2F1","sourceRelease":"119-100","text":"In connection with responsibilities arising from the implementation of the Convention and under regarding United States programs for the development of adequate and comparable statistical information on merchandise trade, the Secretary of the Treasury, the Secretary of Commerce, and the Commission shall prepare technical proposals that are appropriate or required to assure that the United States contribution to the development of the Convention recognizes the needs of the United States business community for a Convention which reflects sound principles of commodity identification, modern producing methods, and current trading patterns and practices.section 1484(f) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s3010/b/2","parentIdentifier":"/us/usc/t19/s3010/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s3010/b/2/A","parentIdentifier":"/us/usc/t19/s3010/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fb%2F2%2FA","sourceRelease":"119-100","text":"solicit and consider the views of interested parties in the private sector (including a functional advisory committee) and of interested Federal agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s3010/b/2/B","parentIdentifier":"/us/usc/t19/s3010/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fb%2F2%2FB","sourceRelease":"119-100","text":"establish procedures for reviewing, and developing appropriate responses to, inquiries and complaints from interested parties concerning articles produced in and exported from the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t19/s3010/b/2/C","parentIdentifier":"/us/usc/t19/s3010/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fb%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s3010/b/2/C/i","parentIdentifier":"/us/usc/t19/s3010/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fb%2F2%2FC%2Fi","sourceRelease":"119-100","text":"ensuring that the dispute settlement provisions and other relevant procedures available under the Convention are utilized to promote United States export interests, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s3010/b/2/C/ii","parentIdentifier":"/us/usc/t19/s3010/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fb%2F2%2FC%2Fii","sourceRelease":"119-100","text":"submitting classification questions to the Harmonized System Committee of the Customs Cooperation Council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Availability of Customs Cooperation Council publications","label":"c Availability of Customs Cooperation Council publications","identifier":"/us/usc/t19/s3010/c","parentIdentifier":"/us/usc/t19/s3010","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s3010/c/1","parentIdentifier":"/us/usc/t19/s3010/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fc%2F1","sourceRelease":"119-100","text":"summary records of the Harmonized System Committee of the Customs Cooperation Council; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s3010/c/2","parentIdentifier":"/us/usc/t19/s3010/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3010%2Fc%2F2","sourceRelease":"119-100","text":"subject to applicable copyright laws, the Explanatory Notes, Classification Opinions, and other instruments of the Customs Cooperation Council relating to the Convention.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
