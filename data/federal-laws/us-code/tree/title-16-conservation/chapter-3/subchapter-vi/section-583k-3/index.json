{"type":"section","nativeType":"section","number":"583k–3","heading":"Priority trail maintenance program","label":"583k–3 Priority trail maintenance program","identifier":"/us/usc/t16/s583k–3","parentIdentifier":"/us/usc/t16/ch3/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Selection","label":"a Selection","identifier":"/us/usc/t16/s583k–3/a","parentIdentifier":"/us/usc/t16/s583k–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fa","sourceRelease":"119-100","text":"In accordance with subsections (b) and (c), not later than 6 months after , the Secretary of Agriculture shall select no fewer than 9 and no more than 15 priority areas for increased trail maintenance accomplishments.November 28, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Criteria","label":"b Criteria","identifier":"/us/usc/t16/s583k–3/b","parentIdentifier":"/us/usc/t16/s583k–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s583k–3/b/1","parentIdentifier":"/us/usc/t16/s583k–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fb%2F1","sourceRelease":"119-100","text":"reduced access to public land;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s583k–3/b/2","parentIdentifier":"/us/usc/t16/s583k–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fb%2F2","sourceRelease":"119-100","text":"led to an increase, or risk of increase, in harm to natural resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s583k–3/b/3","parentIdentifier":"/us/usc/t16/s583k–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fb%2F3","sourceRelease":"119-100","text":"jeopardized public safety;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s583k–3/b/4","parentIdentifier":"/us/usc/t16/s583k–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fb%2F4","sourceRelease":"119-100","text":"resulted in trails being impassible by the intended managed users; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s583k–3/b/5","parentIdentifier":"/us/usc/t16/s583k–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fb%2F5","sourceRelease":"119-100","text":"increased future deferred trail maintenance costs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Requirements","label":"c Requirements","identifier":"/us/usc/t16/s583k–3/c","parentIdentifier":"/us/usc/t16/s583k–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s583k–3/c/1","parentIdentifier":"/us/usc/t16/s583k–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fc%2F1","sourceRelease":"119-100","text":"consider any public input on priority areas received within 3 months of ;November 28, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s583k–3/c/2","parentIdentifier":"/us/usc/t16/s583k–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fc%2F2","sourceRelease":"119-100","text":"consider the range of trail users (including motorized and non-motorized trail users); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s583k–3/c/3","parentIdentifier":"/us/usc/t16/s583k–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fc%2F3","sourceRelease":"119-100","text":"include at least one priority area in each region of the United States Forest Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Increased trail maintenance","label":"d Increased trail maintenance","identifier":"/us/usc/t16/s583k–3/d","parentIdentifier":"/us/usc/t16/s583k–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s583k–3/d/1","parentIdentifier":"/us/usc/t16/s583k–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fd%2F1","sourceRelease":"119-100","text":"Within 6 months of the selection of priority areas under subsection (a), and in accordance with paragraph (2), the Secretary shall develop an approach to substantially increase trail maintenance accomplishments within each priority area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t16/s583k–3/d/2","parentIdentifier":"/us/usc/t16/s583k–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s583k–3/d/2/A","parentIdentifier":"/us/usc/t16/s583k–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fd%2F2%2FA","sourceRelease":"119-100","text":"consider any public input on trail maintenance priorities and needs within any priority area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s583k–3/d/2/B","parentIdentifier":"/us/usc/t16/s583k–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fd%2F2%2FB","sourceRelease":"119-100","text":"consider the costs and benefits of increased trail maintenance within each priority area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s583k–3/d/2/C","parentIdentifier":"/us/usc/t16/s583k–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fd%2F2%2FC","sourceRelease":"119-100","text":"incorporate partners and volunteers in the trail maintenance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Required trail maintenance","label":"3 Required trail maintenance","identifier":"/us/usc/t16/s583k–3/d/3","parentIdentifier":"/us/usc/t16/s583k–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fd%2F3","sourceRelease":"119-100","text":"Utilizing the approach developed under paragraph (1), the Secretary shall substantially increase trail maintenance within each priority area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Coordination","label":"e Coordination","identifier":"/us/usc/t16/s583k–3/e","parentIdentifier":"/us/usc/t16/s583k–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Fe","sourceRelease":"119-100","text":"The regional volunteer and partnership coordinators may be responsible for assisting partner organizations in developing and implementing volunteer and partnership projects to increase trail maintenance within priority areas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Revision","label":"f Revision","identifier":"/us/usc/t16/s583k–3/f","parentIdentifier":"/us/usc/t16/s583k–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs583k%E2%80%933%2Ff","sourceRelease":"119-100","text":"The Secretary shall periodically review the priority areas to determine whether revisions are necessary and may revise the priority areas, including the selection of new priority areas or removal of existing priority areas, at his sole discretion.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
