{"type":"section","nativeType":"section","number":"13283","heading":"Discount payments","label":"13283 Discount payments","identifier":"/us/usc/t42/s13283","parentIdentifier":"/us/usc/t42/ch134/schIV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13283","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Certification","label":"a Certification","identifier":"/us/usc/t42/s13283/a","parentIdentifier":"/us/usc/t42/s13283","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13283%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13283/a/1","parentIdentifier":"/us/usc/t42/s13283/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13283%2Fa%2F1","sourceRelease":"119-100","text":"the electric motor vehicles have been purchased or leased by a user or users in accordance with the requirements of this part; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13283/a/2","parentIdentifier":"/us/usc/t42/s13283/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13283%2Fa%2F2","sourceRelease":"119-100","text":"the proposer has provided to the user or users a discount payment in accordance with the requirements of this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Payment","label":"b Payment","identifier":"/us/usc/t42/s13283/b","parentIdentifier":"/us/usc/t42/s13283","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13283%2Fb","sourceRelease":"119-100","text":"Not later than 30 days after receipt from the proposer of certification that the Secretary determines satisfies the requirements of subsection (a), the Secretary shall pay to the proposer the full amount of the discount payment, to the extent provided in advance in appropriations Acts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Calculations of discount payments","label":"c Calculations of discount payments","identifier":"/us/usc/t42/s13283/c","parentIdentifier":"/us/usc/t42/s13283","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13283%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13283/c/1","parentIdentifier":"/us/usc/t42/s13283/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13283%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13283/c/1/A","parentIdentifier":"/us/usc/t42/s13283/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13283%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the price differential; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13283/c/1/B","parentIdentifier":"/us/usc/t42/s13283/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13283%2Fc%2F1%2FB","sourceRelease":"119-100","text":"the price of the comparable conventionally fueled motor vehicle.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13283/c/2","parentIdentifier":"/us/usc/t42/s13283/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13283%2Fc%2F2","sourceRelease":"119-100","text":"The purchase price of the electric motor vehicle, less the discount payment and less any additional reduction in the purchase price of the electric motor vehicle that may result from contributions provided by other parties, may not be less than the manufacturer’s suggested retail price of a comparable conventionally fueled motor vehicle.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13283/c/3","parentIdentifier":"/us/usc/t42/s13283/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13283%2Fc%2F3","sourceRelease":"119-100","text":"The maximum discount payment shall be no greater than $10,000 per electric motor vehicle.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
