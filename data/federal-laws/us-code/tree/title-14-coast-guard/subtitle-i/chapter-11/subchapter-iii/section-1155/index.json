{"type":"section","nativeType":"section","number":"1155","heading":"Contract termination","label":"1155 Contract termination","identifier":"/us/usc/t14/s1155","parentIdentifier":"/us/usc/t14/stI/ch11/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2018— renumbered as this section.Pub. L. 115–282section 657 of this title"],"amendments":["Amendments2018— renumbered as this section.Pub. L. 115–282section 657 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In General.—","label":"a In General.—","identifier":"/us/usc/t14/s1155/a","parentIdentifier":"/us/usc/t14/s1155","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Notification","label":"1 .—Notification","identifier":"/us/usc/t14/s1155/a/1","parentIdentifier":"/us/usc/t14/s1155/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t14/s1155/a/1/A","parentIdentifier":"/us/usc/t14/s1155/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fa%2F1%2FA","sourceRelease":"119-100","text":"not less than 1 year after the date of the notification; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t14/s1155/a/1/B","parentIdentifier":"/us/usc/t14/s1155/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the date the Commandant notifies the vendor that maintenance of such work product is no longer required.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Work Product Defined","label":"b .—Work Product Defined","identifier":"/us/usc/t14/s1155/b","parentIdentifier":"/us/usc/t14/s1155","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s1155/b/1","parentIdentifier":"/us/usc/t14/s1155/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fb%2F1","sourceRelease":"119-100","text":"means tangible and intangible items and information produced or possessed as a result of a contract referred to in subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s1155/b/2","parentIdentifier":"/us/usc/t14/s1155/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t14/s1155/b/2/A","parentIdentifier":"/us/usc/t14/s1155/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fb%2F2%2FA","sourceRelease":"119-100","text":"any completed end items;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t14/s1155/b/2/B","parentIdentifier":"/us/usc/t14/s1155/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fb%2F2%2FB","sourceRelease":"119-100","text":"any uncompleted end items; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t14/s1155/b/2/C","parentIdentifier":"/us/usc/t14/s1155/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fb%2F2%2FC","sourceRelease":"119-100","text":"any property in the contractor’s possession in which the United States Government has an interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Penalty","label":"c .—Penalty","identifier":"/us/usc/t14/s1155/c","parentIdentifier":"/us/usc/t14/s1155","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fc","sourceRelease":"119-100","text":"A vendor that fails to maintain work product as required under subsection (a) is liable to the United States for a civil penalty of not more than $25,000 for each day on which such work product is unavailable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Report.—","label":"d Report.—","identifier":"/us/usc/t14/s1155/d","parentIdentifier":"/us/usc/t14/s1155","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t14/s1155/d/1","parentIdentifier":"/us/usc/t14/s1155/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t14/s1155/d/1/A","parentIdentifier":"/us/usc/t14/s1155/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fd%2F1%2FA","sourceRelease":"119-100","text":"all Coast Guard contracts with a total value of more than $1,000,000 that were terminated in the fiscal year;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t14/s1155/d/1/B","parentIdentifier":"/us/usc/t14/s1155/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fd%2F1%2FB","sourceRelease":"119-100","text":"all vendors who were notified under subsection (a)(1) in the fiscal year, and the date of such notification;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t14/s1155/d/1/C","parentIdentifier":"/us/usc/t14/s1155/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fd%2F1%2FC","sourceRelease":"119-100","text":"all criminal, administrative, and other investigations regarding any contract with a total value of more than $1,000,000 that were initiated by the Coast Guard in the fiscal year;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t14/s1155/d/1/D","parentIdentifier":"/us/usc/t14/s1155/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fd%2F1%2FD","sourceRelease":"119-100","text":"all criminal, administrative, and other investigations regarding contracts with a total value of more than $1,000,000 that were completed by the Coast Guard in the fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t14/s1155/d/1/E","parentIdentifier":"/us/usc/t14/s1155/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fd%2F1%2FE","sourceRelease":"119-100","text":"an estimate of costs incurred by the Coast Guard, including contract line items and termination costs, as a result of the requirements of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Limitation","label":"2 .—Limitation","identifier":"/us/usc/t14/s1155/d/2","parentIdentifier":"/us/usc/t14/s1155/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1155%2Fd%2F2","sourceRelease":"119-100","text":"The Commandant is not required to provide a report under paragraph (1) for any fiscal year for which there is no responsive information as described in subparagraphs (A) through (E) of paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
