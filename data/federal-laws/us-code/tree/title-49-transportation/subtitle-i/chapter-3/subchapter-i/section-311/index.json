{"type":"section","nativeType":"section","number":"311","heading":"Congressional notification requirements","label":"311 Congressional notification requirements","identifier":"/us/usc/t49/s311","parentIdentifier":"/us/usc/t49/stI/ch3/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs311","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t49/s311/a","parentIdentifier":"/us/usc/t49/s311","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs311%2Fa","sourceRelease":"119-100","text":"Except as provided in subsection (b) or as expressly provided in another provision of law, the Secretary of Transportation shall provide to the appropriate committees of Congress notice of an announcement concerning a covered project at least 3 full business days before the announcement is made by the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Emergency Program","label":"b .—Emergency Program","identifier":"/us/usc/t49/s311/b","parentIdentifier":"/us/usc/t49/s311","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs311%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s311/b/1","parentIdentifier":"/us/usc/t49/s311/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs311%2Fb%2F1","sourceRelease":"119-100","text":"at least 3 full business days before the issuance of the allocation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s311/b/2","parentIdentifier":"/us/usc/t49/s311/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs311%2Fb%2F2","sourceRelease":"119-100","text":"concurrently with the issuance of the allocation, if the allocation is made using the quick release process of the Department (or any successor process).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Definitions","label":"c .—Definitions","identifier":"/us/usc/t49/s311/c","parentIdentifier":"/us/usc/t49/s311","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs311%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Appropriate committees of congress","label":"1 .—Appropriate committees of congress","identifier":"/us/usc/t49/s311/c/1","parentIdentifier":"/us/usc/t49/s311/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs311%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s311/c/1/A","parentIdentifier":"/us/usc/t49/s311/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs311%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the Committee on Transportation and Infrastructure of the House of Representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s311/c/1/B","parentIdentifier":"/us/usc/t49/s311/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs311%2Fc%2F1%2FB","sourceRelease":"119-100","text":"the Committee on Environment and Public Works, the Committee on Commerce, Science, and Transportation, and the Committee on Banking, Housing, and Urban Affairs of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Covered project","label":"2 .—Covered project","identifier":"/us/usc/t49/s311/c/2","parentIdentifier":"/us/usc/t49/s311/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs311%2Fc%2F2","sourceRelease":"119-100","text":"The term “covered project” means a project competitively selected by the Department to receive a discretionary grant award, letter of intent, loan commitment, loan guarantee commitment, or line of credit commitment in an amount equal to or greater than $750,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Department","label":"3 .—Department","identifier":"/us/usc/t49/s311/c/3","parentIdentifier":"/us/usc/t49/s311/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs311%2Fc%2F3","sourceRelease":"119-100","text":"The term “Department” means the Department of Transportation, including the modal administrations of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
