{"type":"section","nativeType":"section","number":"5505","heading":"Disaster training for State Department personnel","label":"5505 Disaster training for State Department personnel","identifier":"/us/usc/t22/s5505","parentIdentifier":"/us/usc/t22/ch64","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5505","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Additional training","label":"a Additional training","identifier":"/us/usc/t22/s5505/a","parentIdentifier":"/us/usc/t22/s5505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5505%2Fa","sourceRelease":"119-100","text":"The Secretary of State shall institute a supplemental program of training in disaster management for all consular officers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Training improvements","label":"b Training improvements","identifier":"/us/usc/t22/s5505/b","parentIdentifier":"/us/usc/t22/s5505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5505%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s5505/b/1","parentIdentifier":"/us/usc/t22/s5505/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5505%2Fb%2F1","sourceRelease":"119-100","text":"In expanding the training program under subsection (a), the Secretary of State shall consult with death and bereavement counselors concerning the particular demands posed by aviation tragedies and terrorist activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s5505/b/2","parentIdentifier":"/us/usc/t22/s5505/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5505%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s5505/b/2/A","parentIdentifier":"/us/usc/t22/s5505/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5505%2Fb%2F2%2FA","sourceRelease":"119-100","text":"providing specialized training to create a team of “disaster specialists” to deploy immediately in a crisis; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s5505/b/2/B","parentIdentifier":"/us/usc/t22/s5505/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5505%2Fb%2F2%2FB","sourceRelease":"119-100","text":"securing outside experts to be brought in during the initial phases to assist consular personnel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
