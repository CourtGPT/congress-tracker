{"type":"section","nativeType":"section","number":"3111a","heading":"Annual report on Federal Bureau of Investigation case data","label":"3111a Annual report on Federal Bureau of Investigation case data","identifier":"/us/usc/t50/s3111a","parentIdentifier":"/us/usc/t50/ch44/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Annual report","label":"a Annual report","identifier":"/us/usc/t50/s3111a/a","parentIdentifier":"/us/usc/t50/s3111a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111a%2Fa","sourceRelease":"119-100","text":"Not later than 30 days after , and annually thereafter, the Director of the Federal Bureau of Investigation shall submit to the congressional intelligence committees, the Committee on the Judiciary of the Senate, and the Committee on the Judiciary of the House of Representatives a report containing data on cases of the Federal Bureau of Investigation for the fiscal year preceding the fiscal year in which the report is submitted.December 18, 2025","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Elements","label":"b Elements","identifier":"/us/usc/t50/s3111a/b","parentIdentifier":"/us/usc/t50/s3111a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3111a/b/1","parentIdentifier":"/us/usc/t50/s3111a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111a%2Fb%2F1","sourceRelease":"119-100","text":"Russia counterintelligence cases.","notes":[],"amendments":[],"effec