{"type":"section","nativeType":"section","number":"4130","heading":"Additional markets","label":"4130 Additional markets","identifier":"/us/usc/t18/s4130","parentIdentifier":"/us/usc/t18/ptIII/ch307","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4130","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextSection 501 of the Internal Revenue Code of 1986, referred to in subsec. (a)(4), is classified to , Internal Revenue Code.section 501 of Title 26"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t18/s4130/a","parentIdentifier":"/us/usc/t18/s4130","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4130%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s4130/a/1","parentIdentifier":"/us/usc/t18/s4130/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4130%2Fa%2F1","sourceRelease":"119-100","text":"public entities for use in penal or correctional institutions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s4130/a/2","parentIdentifier":"/us/usc/t18/s4130/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4130%2Fa%2F2","sourceRelease":"119-100","text":"public entities for use in disaster relief or emergency response;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s4130/a/3","parentIdentifier":"/us/usc/t18/s4130/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4130%2Fa%2F3","sourceRelease":"119-100","text":"the government of the District of Columbia; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t18/s4130/a/4","parentIdentifier":"/us/usc/t18/s4130/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4130%2Fa%2F4","sourceRelease":"119-100","text":"any organization described in subsection (c)(3), (c)(4), or (d) of section 501 of the Internal Revenue Code of 1986 that is exempt from taxation under section 501(a) of such Code.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Office Furniture","label":"b .—Office Furniture","identifier":"/us/usc/t18/s4130/b","parentIdentifier":"/us/usc/t18/s4130","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4130%2Fb","sourceRelease":"119-100","text":"Federal Prison Industries may not sell office furniture to the organizations described in subsection (a)(4).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Definitions","label":"c .—Definitions","identifier":"/us/usc/t18/s4130/c","parentIdentifier":"/us/usc/t18/s4130","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4130%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s4130/c/1","parentIdentifier":"/us/usc/t18/s4130/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4130%2Fc%2F1","sourceRelease":"119-100","text":"The term “office furniture” means any product or service offering intended to meet the furnishing needs of the workplace, including office, healthcare, educational, and hospitality environments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s4130/c/2","parentIdentifier":"/us/usc/t18/s4130/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4130%2Fc%2F2","sourceRelease":"119-100","text":"The term “public entity” means a State, a subdivision of a State, an Indian tribe, and an agency or governmental corporation or business of any of the foregoing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s4130/c/3","parentIdentifier":"/us/usc/t18/s4130/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs4130%2Fc%2F3","sourceRelease":"119-100","text":"The term “State” means a State, the District of Columbia, the Commonwealth of Puerto Rico, Guam, American Samoa, the Northern Mariana Islands, and the United States Virgin Islands.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
