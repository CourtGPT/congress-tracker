view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6991i/a/1/A","parentIdentifier":"/us/usc/t42/s6991i/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fa%2F1%2FA","sourceRelease":"119-100","text":"persons having primary responsibility for on-site operation and maintenance of underground storage tank systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6991i/a/1/B","parentIdentifier":"/us/usc/t42/s6991i/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fa%2F1%2FB","sourceRelease":"119-100","text":"persons having daily on-site responsibility for the operation and maintenance of underground storage tanks systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6991i/a/1/C","parentIdentifier":"/us/usc/t42/s6991i/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fa%2F1%2FC","sourceRelease":"119-100","text":"daily, on-site employees having primary responsibility for addressing emergencies presented by a spill or release from an underground storage tank system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Considerations","label":"2 Considerations","identifier":"/us/usc/t42/s6991i/a/2","parentIdentifier":"/us/usc/t42/s6991i/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6991i/a/2/A","parentIdentifier":"/us/usc/t42/s6991i/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fa%2F2%2FA","sourceRelease":"119-100","text":"State training programs in existence as of the date of publication of the guidelines;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6991i/a/2/B","parentIdentifier":"/us/usc/t42/s6991i/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fa%2F2%2FB","sourceRelease":"119-100","text":"training programs that are being employed by tank owners and tank operators as of ;August 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6991i/a/2/C","parentIdentifier":"/us/usc/t42/s6991i/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fa%2F2%2FC","sourceRelease":"119-100","text":"the high turnover rate of tank operators and other personnel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6991i/a/2/D","parentIdentifier":"/us/usc/t42/s6991i/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fa%2F2%2FD","sourceRelease":"119-100","text":"the frequency of improvement in underground storage tank equipment technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s6991i/a/2/E","parentIdentifier":"/us/usc/t42/s6991i/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fa%2F2%2FE","sourceRelease":"119-100","text":"the nature of the businesses in which the tank operators are engaged;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s6991i/a/2/F","parentIdentifier":"/us/usc/t42/s6991i/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fa%2F2%2FF","sourceRelease":"119-100","text":"the substantial differences in the scope and length of training needed for the different classes of persons described in subparagraphs (A), (B), and (C) of paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s6991i/a/2/G","parentIdentifier":"/us/usc/t42/s6991i/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fa%2F2%2FG","sourceRelease":"119-100","text":"such other factors as the Administrator determines to be necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"State programs","label":"b State programs","identifier":"/us/usc/t42/s6991i/b","parentIdentifier":"/us/usc/t42/s6991i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s6991i/b/1","parentIdentifier":"/us/usc/t42/s6991i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fb%2F1","sourceRelease":"119-100","text":"Not later than 2 years after the date on which the Administrator publishes the guidelines under subsection (a)(1), each State that receives funding under this subchapter shall develop State-specific training requirements that are consistent with the guidelines developed under subsection (a)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t42/s6991i/b/2","parentIdentifier":"/us/usc/t42/s6991i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6991i/b/2/A","parentIdentifier":"/us/usc/t42/s6991i/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fb%2F2%2FA","sourceRelease":"119-100","text":"be consistent with subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6991i/b/2/B","parentIdentifier":"/us/usc/t42/s6991i/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fb%2F2%2FB","sourceRelease":"119-100","text":"be developed in cooperation with tank owners and tank operators;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6991i/b/2/C","parentIdentifier":"/us/usc/t42/s6991i/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fb%2F2%2FC","sourceRelease":"119-100","text":"take into consideration training programs implemented by tank owners and tank operators as of ; andAugust 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nat