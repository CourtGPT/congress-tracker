{"type":"section","nativeType":"section","number":"16279a","heading":"Advanced reactor demonstration program","label":"16279a Advanced reactor demonstration program","identifier":"/us/usc/t42/s16279a","parentIdentifier":"/us/usc/t42/ch149/schIX/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Demonstration project defined","label":"a Demonstration project defined","identifier":"/us/usc/t42/s16279a/a","parentIdentifier":"/us/usc/t42/s16279a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fa","sourceRelease":"119-100","text":"For the purposes of this section, the term “demonstration project” means an advanced nuclear reactor operated in any manner, including as part of the power generation facilities of an electric utility system, for the purpose of demonstrating the suitability for commercial application of the advanced nuclear reactor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t42/s16279a/b","parentIdentifier":"/us/usc/t42/s16279a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16279a/b/1","parentIdentifier":"/us/usc/t42/s16279a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16279a/b/1/A","parentIdentifier":"/us/usc/t42/s16279a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"safer, emissions-free power at a competitive cost of electricity compared to other new energy generation technologies on ;December 27, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16279a/b/1/B","parentIdentifier":"/us/usc/t42/s16279a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fb%2F1%2FB","sourceRelease":"119-100","text":"heat for community heating, industrial purposes, heat storage, or synthetic fuel production;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16279a/b/1/C","parentIdentifier":"/us/usc/t42/s16279a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fb%2F1%2FC","sourceRelease":"119-100","text":"remote or off-grid energy supply; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16279a/b/1/D","parentIdentifier":"/us/usc/t42/s16279a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fb%2F1%2FD","sourceRelease":"119-100","text":"backup or mission-critical power supplies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16279a/b/2","parentIdentifier":"/us/usc/t42/s16279a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fb%2F2","sourceRelease":"119-100","text":"identifying research areas that the private sector is unable or unwilling to undertake due to the cost of, or risks associated with, the research; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16279a/b/3","parentIdentifier":"/us/usc/t42/s16279a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16279a/b/3/A","parentIdentifier":"/us/usc/t42/s16279a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fb%2F3%2FA","sourceRelease":"119-100","text":"to Federal research facilities and personnel; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16279a/b/3/B","parentIdentifier":"/us/usc/t42/s16279a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fb%2F3%2FB","sourceRelease":"119-100","text":"to the results of research relating to civil nuclear technology funded by the Federal Government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Demonstration projects","label":"c Demonstration projects","identifier":"/us/usc/t42/s16279a/c","parentIdentifier":"/us/usc/t42/s16279a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16279a/c/1","parentIdentifier":"/us/usc/t42/s16279a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16279a/c/1/A","parentIdentifier":"/us/usc/t42/s16279a/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F1%2FA","sourceRelease":"119-100","text":"primary coolants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16279a/c/1/B","parentIdentifier":"/us/usc/t42/s16279a/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F1%2FB","sourceRelease":"119-100","text":"fuel types and compositions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16279a/c/1/C","parentIdentifier":"/us/usc/t42/s16279a/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F1%2FC","sourceRelease":"119-100","text":"neutron spectra;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16279a/c/2","parentIdentifier":"/us/usc/t42/s16279a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16279a/c/2/A","parentIdentifier":"/us/usc/t42/s16279a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the likelihood that the operating cost for future commercial units for each design implemented through a demonstration project under this subsection is cost-competitive in the applicable market, including those designs configured as integrated energy systems as described in ;section 16272(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16279a/c/2/B","parentIdentifier":"/us/usc/t42/s16279a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the technology readiness level of a proposed advanced nuclear reactor technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16279a/c/2/C","parentIdentifier":"/us/usc/t42/s16279a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F2%2FC","sourceRelease":"119-100","text":"the technical abilities and qualifications of teams desiring to demonstrate a proposed advanced nuclear reactor technology; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16279a/c/2/D","parentIdentifier":"/us/usc/t42/s16279a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F2%2FD","sourceRelease":"119-100","text":"the capacity to meet cost-share requirements of the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16279a/c/3","parentIdentifier":"/us/usc/t42/s16279a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16279a/c/3/A","parentIdentifier":"/us/usc/t42/s16279a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16279a/c/3/A/i","parentIdentifier":"/us/usc/t42/s16279a/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F3%2FA%2Fi","sourceRelease":"119-100","text":"an electric utility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16279a/c/3/A/ii","parentIdentifier":"/us/usc/t42/s16279a/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F3%2FA%2Fii","sourceRelease":"119-100","text":"an entity that uses high-temperature process heat for manufacturing or industrial processing, such as a petrochemical or synthetic fuel company, a manufacturer of metals or chemicals, or a manufacturer of concrete;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16279a/c/3/A/iii","parentIdentifier":"/us/usc/t42/s16279a/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"an expert from the investment community;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s16279a/c/3/A/iv","parentIdentifier":"/us/usc/t42/s16279a/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F3%2FA%2Fiv","sourceRelease":"119-100","text":"a project management practitioner; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s16279a/c/3/A/v","parentIdentifier":"/us/usc/t42/s16279a/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F3%2FA%2Fv","sourceRelease":"119-100","text":"an environmental health and safety expert; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16279a/c/3/B","parentIdentifier":"/us/usc/t42/s16279a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F3%2FB","sourceRelease":"119-100","text":"include a review of each demonstration project under this subsection which shall include consideration of cost-competitiveness and other value streams, together with the technology readiness level, the technical abilities and qualifications of teams desiring to demonstrate a proposed advanced nuclear reactor technology, the capacity to meet cost-share requirements of the Department, if Federal funding is provided, and environmental impacts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16279a/c/4","parentIdentifier":"/us/usc/t42/s16279a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F4","sourceRelease":"119-100","text":"for federally funded demonstration projects, enter into cost-sharing agreements with private sector partners in accordance with for the conduct of activities relating to the research, development, and demonstration of advanced nuclear reactor designs under the program;section 16352 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16279a/c/5","parentIdentifier":"/us/usc/t42/s16279a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16279a/c/5/A","parentIdentifier":"/us/usc/t42/s16279a/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F5%2FA","sourceRelease":"119-100","text":"National Laboratories;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16279a/c/5/B","parentIdentifier":"/us/usc/t42/s16279a/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F5%2FB","sourceRelease":"119-100","text":"institutions of higher education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16279a/c/5/C","parentIdentifier":"/us/usc/t42/s16279a/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F5%2FC","sourceRelease":"119-100","text":"traditional end users (such as electric utilities);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16279a/c/5/D","parentIdentifier":"/us/usc/t42/s16279a/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F5%2FD","sourceRelease":"119-100","text":"potential end users of new technologies (such as users of high-temperature process heat for manufacturing processing, including petrochemical or synthetic fuel companies, manufacturers of metals or chemicals, or manufacturers of concrete);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16279a/c/5/E","parentIdentifier":"/us/usc/t42/s16279a/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F5%2FE","sourceRelease":"119-100","text":"developers of advanced nuclear reactor technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s16279a/c/5/F","parentIdentifier":"/us/usc/t42/s16279a/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F5%2FF","sourceRelease":"119-100","text":"environmental and public health and safety experts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s16279a/c/5/G","parentIdentifier":"/us/usc/t42/s16279a/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F5%2FG","sourceRelease":"119-100","text":"non-proliferation experts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s16279a/c/6","parentIdentifier":"/us/usc/t42/s16279a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16279a%2Fc%2F6","sourceRelease":"119-100","text":"seek to ensure that the demonstration projects carried out under this section do not cause any delay in the progress of an ad