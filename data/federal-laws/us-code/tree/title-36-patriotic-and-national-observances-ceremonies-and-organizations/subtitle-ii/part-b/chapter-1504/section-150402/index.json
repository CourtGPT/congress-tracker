{"type":"section","nativeType":"section","number":"150402","heading":"Purposes","label":"150402 Purposes","identifier":"/us/usc/t36/s150402","parentIdentifier":"/us/usc/t36/stII/ptB/ch1504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150402","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t36/s150402/1","parentIdentifier":"/us/usc/t36/s150402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150402%2F1","sourceRelease":"119-100","text":"to uphold and defend the Constitution of the United States while respecting the sovereignty of the American Indian Nations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t36/s150402/2","parentIdentifier":"/us/usc/t36/s150402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150402%2F2","sourceRelease":"119-100","text":"to unite under one body all American Indian veterans who served in the Armed Forces of United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t36/s150402/3","parentIdentifier":"/us/usc/t36/s150402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150402%2F3","sourceRelease":"119-100","text":"to be an advocate on behalf of all American Indian veterans without regard to whether they served during times of peace, conflict, or war;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t36/s150402/4","parentIdentifier":"/us/usc/t36/s150402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150402%2F4","sourceRelease":"119-100","text":"to promote social welfare (including educational, economic, social, physical, and cultural values and traditional healing) in the United States by encouraging the growth and development, readjustment, self-respect, self-confidence, contributions, and self-identity of American Indian veterans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t36/s150402/5","parentIdentifier":"/us/usc/t36/s150402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150402%2F5","sourceRelease":"119-100","text":"to serve as an advocate for the needs of American Indian veterans and their families and survivors in their dealings with all Federal and State government agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t36/s150402/6","parentIdentifier":"/us/usc/t36/s150402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150402%2F6","sourceRelease":"119-100","text":"to promote, support, and utilize research, on a nonpartisan basis, pertaining to the relationship between American Indian veterans and American society; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t36/s150402/7","parentIdentifier":"/us/usc/t36/s150402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150402%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t36/s150402/7/A","parentIdentifier":"/us/usc/t36/s150402/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150402%2F7%2FA","sourceRelease":"119-100","text":"providing outreach service to Indian Tribes in need; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t36/s150402/7/B","parentIdentifier":"/us/usc/t36/s150402/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150402%2F7%2FB","sourceRelease":"119-100","text":"training and educating Tribal Veterans Service Officers for Indian Tribes in need.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
