{"type":"section","nativeType":"section","number":"19060","heading":"Risk and resilience research","label":"19060 Risk and resilience research","identifier":"/us/usc/t42/s19060","parentIdentifier":"/us/usc/t42/ch163/schIII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19060","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19060/1","parentIdentifier":"/us/usc/t42/s19060","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19060%2F1","sourceRelease":"119-100","text":"improvements in our ability to understand, model, and predict extreme events and natural hazards;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19060/2","parentIdentifier":"/us/usc/t42/s19060","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19060%2F2","sourceRelease":"119-100","text":"the creation of novel engineered systems solutions for resilient complex infrastructures, particularly those that address critical interdependence among infrastructures and leverage the growing infusion of cyber-physical-social components into the infrastructures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19060/3","parentIdentifier":"/us/usc/t42/s19060","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19060%2F3","sourceRelease":"119-100","text":"development of equipment and instrumentation for innovation in resilient engineered infrastructures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s19060/4","parentIdentifier":"/us/usc/t42/s19060","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19060%2F4","sourceRelease":"119-100","text":"multidisciplinary research on the behaviors individuals and communities engage in to detect, perceive, understand, predict, assess, mitigate, and prevent risks and to improve and increase resilience; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s19060/5","parentIdentifier":"/us/usc/t42/s19060","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19060%2F5","sourceRelease":"119-100","text":"advancements in multidisciplinary wildfire science, including those related to air quality impacts, human behavior, and early detection and warning.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
