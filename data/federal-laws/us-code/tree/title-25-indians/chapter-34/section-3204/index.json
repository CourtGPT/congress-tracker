{"type":"section","nativeType":"section","number":"3204","heading":"Central registry","label":"3204 Central registry","identifier":"/us/usc/t25/s3204","parentIdentifier":"/us/usc/t25/ch34","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3204","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Preparation of study","label":"a Preparation of study","identifier":"/us/usc/t25/s3204/a","parentIdentifier":"/us/usc/t25/s3204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3204%2Fa","sourceRelease":"119-100","text":"The Secretary, in consultation with the Secretary of Health and Human Services and the Attorney General of the United States, is hereby authorized and directed to prepare a written study on the feasibility of, and need for, the establishment of a Central Register for reports or information on the abuse of children in Indian country.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Content of study","label":"b Content of study","identifier":"/us/usc/t25/s3204/b","parentIdentifier":"/us/usc/t25/s3204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3204%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s3204/b/1","parentIdentifier":"/us/usc/t25/s3204/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3204%2Fb%2F1","sourceRelease":"119-100","text":"the need for, and purpose of, a Central Register;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s3204/b/2","parentIdentifier":"/us/usc/t25/s3204/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3204%2Fb%2F2","sourceRelease":"119-100","text":"the examination of due process implication of the maintenance of such a register;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s3204/b/3","parentIdentifier":"/us/usc/t25/s3204/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3204%2Fb%2F3","sourceRelease":"119-100","text":"the extension of access to information contained in the register;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s3204/b/4","parentIdentifier":"/us/usc/t25/s3204/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3204%2Fb%2F4","sourceRelease":"119-100","text":"the need and process for expunging information from the register;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s3204/b/5","parentIdentifier":"/us/usc/t25/s3204/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3204%2Fb%2F5","sourceRelease":"119-100","text":"the types, and duration of maintenance, of information in the register; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t25/s3204/b/6","parentIdentifier":"/us/usc/t25/s3204/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3204%2Fb%2F6","sourceRelease":"119-100","text":"the classes of persons who should be covered by such register.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Submission to Congress","label":"c Submission to Congress","identifier":"/us/usc/t25/s3204/c","parentIdentifier":"/us/usc/t25/s3204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3204%2Fc","sourceRelease":"119-100","text":"The Secretary shall complete the study conducted pursuant to this section and shall submit such study, together with recommendations and draft legislation to implement such recommendations, to the Congress within 180 days after .November 28, 1990","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
