{"type":"section","nativeType":"section","number":"8421","heading":"Purposes of assistance","label":"8421 Purposes of assistance","identifier":"/us/usc/t22/s8421","parentIdentifier":"/us/usc/t22/ch91/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8421","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s8421/1","parentIdentifier":"/us/usc/t22/s8421","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8421%2F1","sourceRelease":"119-100","text":"to support Pakistan’s paramount national security need to fight and win the ongoing counterinsurgency within its borders in accordance with its national security interests;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s8421/2","parentIdentifier":"/us/usc/t22/s8421","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8421%2F2","sourceRelease":"119-100","text":"to work with the Government of Pakistan to improve Pakistan’s border security and control and help prevent any Pakistani territory from being used as a base or conduit for terrorist attacks in Pakistan, or elsewhere;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s8421/3","parentIdentifier":"/us/usc/t22/s8421","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8421%2F3","sourceRelease":"119-100","text":"to work in close cooperation with the Government of Pakistan to coordinate action against extremist and terrorist targets; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s8421/4","parentIdentifier":"/us/usc/t22/s8421","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8421%2F4","sourceRelease":"119-100","text":"to help strengthen the institutions of democratic governance and promote control of military institutions by a democratically elected civilian government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
