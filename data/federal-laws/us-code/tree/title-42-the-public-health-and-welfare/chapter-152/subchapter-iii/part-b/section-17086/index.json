{"type":"section","nativeType":"section","number":"17086","heading":"Advanced integration of buildings onto the electric grid","label":"17086 Advanced integration of buildings onto the electric grid","identifier":"/us/usc/t42/s17086","parentIdentifier":"/us/usc/t42/ch152/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s17086/a","parentIdentifier":"/us/usc/t42/s17086","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17086/a/1","parentIdentifier":"/us/usc/t42/s17086/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17086/a/1/A","parentIdentifier":"/us/usc/t42/s17086/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fa%2F1%2FA","sourceRelease":"119-100","text":"monitor building energy load;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17086/a/1/B","parentIdentifier":"/us/usc/t42/s17086/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fa%2F1%2FB","sourceRelease":"119-100","text":"forecast building energy need; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17086/a/1/C","parentIdentifier":"/us/usc/t42/s17086/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fa%2F1%2FC","sourceRelease":"119-100","text":"enable building-level energy control;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17086/a/2","parentIdentifier":"/us/usc/t42/s17086/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fa%2F2","sourceRelease":"119-100","text":"developing data management capabilities and standard communication protocols to further interoperability at the building and grid-level;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17086/a/3","parentIdentifier":"/us/usc/t42/s17086/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fa%2F3","sourceRelease":"119-100","text":"developing advanced building-level energy management of components through integration of smart technologies, control systems, and data processing, to enable energy efficiency and savings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17086/a/4","parentIdentifier":"/us/usc/t42/s17086/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fa%2F4","sourceRelease":"119-100","text":"optimizing energy consumption at the building level to enable grid stability and resilience;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s17086/a/5","parentIdentifier":"/us/usc/t42/s17086/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fa%2F5","sourceRelease":"119-100","text":"improving visualization of behind the meter equipment and technologies to provide better insight into the energy needs and energy forecasts of individual buildings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s17086/a/6","parentIdentifier":"/us/usc/t42/s17086/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fa%2F6","sourceRelease":"119-100","text":"reducing the cost of key components to accelerate the adoption of smart building technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s17086/a/7","parentIdentifier":"/us/usc/t42/s17086/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fa%2F7","sourceRelease":"119-100","text":"protecting against cybersecurity threats and addressing security vulnerabilities of building systems or equipment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s17086/a/8","parentIdentifier":"/us/usc/t42/s17086/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fa%2F8","sourceRelease":"119-100","text":"other areas determined appropriate by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Considerations","label":"b Considerations","identifier":"/us/usc/t42/s17086/b","parentIdentifier":"/us/usc/t42/s17086","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17086/b/1","parentIdentifier":"/us/usc/t42/s17086/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fb%2F1","sourceRelease":"119-100","text":"work with utility partners, building owners, technology vendors, and building developers to test and validate technologies and encourage the commercial application of these technologies by building owners; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17086/b/2","parentIdentifier":"/us/usc/t42/s17086/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17086/b/2/A","parentIdentifier":"/us/usc/t42/s17086/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fb%2F2%2FA","sourceRelease":"119-100","text":"small- and medium-sized buildings and the electric grid; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17086/b/2/B","parentIdentifier":"/us/usc/t42/s17086/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fb%2F2%2FB","sourceRelease":"119-100","text":"residential and commercial buildings and the electric grid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Buildings-to-grid integration report","label":"c Buildings-to-grid integration report","identifier":"/us/usc/t42/s17086/c","parentIdentifier":"/us/usc/t42/s17086","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Report requirements","label":"1 Report requirements","identifier":"/us/usc/t42/s17086/c/1","parentIdentifier":"/us/usc/t42/s17086/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17086/c/1/A","parentIdentifier":"/us/usc/t42/s17086/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17086/c/1/A/i","parentIdentifier":"/us/usc/t42/s17086/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"incorporated into new commercial and residential buildings; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17086/c/1/A/ii","parentIdentifier":"/us/usc/t42/s17086/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"retrofitted in older buildings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17086/c/1/B","parentIdentifier":"/us/usc/t42/s17086/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fc%2F1%2FB","sourceRelease":"119-100","text":"guidelines for the design of new buildings and building components to enable modern grid interactivity and improve energy efficiency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17086/c/1/C","parentIdentifier":"/us/usc/t42/s17086/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fc%2F1%2FC","sourceRelease":"119-100","text":"an assessment of barriers to the adoption by building owners of advanced technologies enabling greater integration of building components onto the electric grid; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17086/c/1/D","parentIdentifier":"/us/usc/t42/s17086/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fc%2F1%2FD","sourceRelease":"119-100","text":"an assessment of the feasibility of adopting technologies developed under subsection (a) at Department facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Recommendations","label":"2 Recommendations","identifier":"/us/usc/t42/s17086/c/2","parentIdentifier":"/us/usc/t42/s17086/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fc%2F2","sourceRelease":"119-100","text":"As part of the report, the Secretary shall develop a 10-year roadmap to guide the research, development, and demonstration program to enable components of commercial and residential buildings to serve as dynamic energy loads on and resources for the electric grid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Updates","label":"3 Updates","identifier":"/us/usc/t42/s17086/c/3","parentIdentifier":"/us/usc/t42/s17086/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fc%2F3","sourceRelease":"119-100","text":"The Secretary shall update the report required under this section every 3 years for the duration of the program under subsection (a) and shall submit the updated report to the Committee on Science, Space, and Technology and the Committee on Energy and Commerce of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Program implementation","label":"d Program implementation","identifier":"/us/usc/t42/s17086/d","parentIdentifier":"/us/usc/t42/s17086","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17086/d/1","parentIdentifier":"/us/usc/t42/s17086/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fd%2F1","sourceRelease":"119-100","text":"implement the recommendations from the report in subsection (c); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17086/d/2","parentIdentifier":"/us/usc/t42/s17086/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17086%2Fd%2F2","sourceRelease":"119-100","text":"coordinate across all relevant program offices at the Department to achieve the goals established in this section, including the Office of Electricity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
