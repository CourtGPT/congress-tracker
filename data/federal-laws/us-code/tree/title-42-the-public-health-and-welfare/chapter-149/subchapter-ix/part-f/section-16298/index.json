{"type":"section","nativeType":"section","number":"16298","heading":"Carbon utilization program","label":"16298 Carbon utilization program","identifier":"/us/usc/t42/s16298","parentIdentifier":"/us/usc/t42/ch149/schIX/ptF","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s16298/a","parentIdentifier":"/us/usc/t42/s16298","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fa","sourceRelease":"119-100","text":"The Secretary, in consultation with the Administrator of the Environmental Protection Agency, shall carry out a program of research, development, demonstration, and commercialization relating to carbon utilization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Activities","label":"b Activities","identifier":"/us/usc/t42/s16298/b","parentIdentifier":"/us/usc/t42/s16298","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16298/b/1","parentIdentifier":"/us/usc/t42/s16298/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16298/b/1/A","parentIdentifier":"/us/usc/t42/s16298/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb%2F1%2FA","sourceRelease":"119-100","text":"potential changes in lifecycle carbon dioxide and other greenhouse gas emissions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16298/b/1/B","parentIdentifier":"/us/usc/t42/s16298/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb%2F1%2FB","sourceRelease":"119-100","text":"other environmental safety indicators of new technologies, practices, processes, or methods used in enhanced hydrocarbon recovery as part of the activities authorized under ;section 16293 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16298/b/2","parentIdentifier":"/us/usc/t42/s16298/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16298/b/2/A","parentIdentifier":"/us/usc/t42/s16298/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb%2F2%2FA","sourceRelease":"119-100","text":"chemicals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16298/b/2/B","parentIdentifier":"/us/usc/t42/s16298/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb%2F2%2FB","sourceRelease":"119-100","text":"plastics;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16298/b/2/C","parentIdentifier":"/us/usc/t42/s16298/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb%2F2%2FC","sourceRelease":"119-100","text":"building materials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16298/b/2/D","parentIdentifier":"/us/usc/t42/s16298/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb%2F2%2FD","sourceRelease":"119-100","text":"fuels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16298/b/2/E","parentIdentifier":"/us/usc/t42/s16298/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb%2F2%2FE","sourceRelease":"119-100","text":"cement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s16298/b/2/F","parentIdentifier":"/us/usc/t42/s16298/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb%2F2%2FF","sourceRelease":"119-100","text":"products of coal utilization in power systems or in other applications; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s16298/b/2/G","parentIdentifier":"/us/usc/t42/s16298/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb%2F2%2FG","sourceRelease":"119-100","text":"other products with demonstrated market value;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16298/b/3","parentIdentifier":"/us/usc/t42/s16298/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb%2F3","sourceRelease":"119-100","text":"identify and assess carbon capture technologies for industrial systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16298/b/4","parentIdentifier":"/us/usc/t42/s16298/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fb%2F4","sourceRelease":"119-100","text":"identify and assess alternative uses for coal that result in zero net emissions of carbon dioxide or other pollutants, including products derived from carbon engineering, carbon fiber, and coal conversion methods.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Prioritization","label":"c Prioritization","identifier":"/us/usc/t42/s16298/c","parentIdentifier":"/us/usc/t42/s16298","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16298/c/1","parentIdentifier":"/us/usc/t42/s16298/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fc%2F1","sourceRelease":"119-100","text":"have access to a carbon dioxide emissions stream generated by a stationary source in the United States that is capable of supplying not less than 250 metric tons per day of carbon dioxide for research;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16298/c/2","parentIdentifier":"/us/usc/t42/s16298/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fc%2F2","sourceRelease":"119-100","text":"have access to equipment for testing small-scale carbon dioxide utilization technologies, with onsite access to larger test bays for scale-up; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16298/c/3","parentIdentifier":"/us/usc/t42/s16298/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fc%2F3","sourceRelease":"119-100","text":"have 1 or more existing partnerships with a National Laboratory, an institution of higher education, a private company, or a State or other government entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Coordination","label":"d Coordination","identifier":"/us/usc/t42/s16298/d","parentIdentifier":"/us/usc/t42/s16298","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fd","sourceRelease":"119-100","text":"The Secretary shall coordinate the activities authorized under this section with the activities authorized in as part of a single consolidated program of the Department.section 16298a of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s16298/e","parentIdentifier":"/us/usc/t42/s16298","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298%2Fe","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary to carry out this section $50,000,000, to remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
