{"type":"section","nativeType":"section","number":"6504","heading":"Actions by States","label":"6504 Actions by States","identifier":"/us/usc/t15/s6504","parentIdentifier":"/us/usc/t15/ch91","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateFor effective date of section, see , set out as a note under .section 1308 of Pub. L. 105–277section 6501 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s6504/a","parentIdentifier":"/us/usc/t15/s6504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Civil actions","label":"1 Civil actions","identifier":"/us/usc/t15/s6504/a/1","parentIdentifier":"/us/usc/t15/s6504/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s6504/a/1/A","parentIdentifier":"/us/usc/t15/s6504/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fa%2F1%2FA","sourceRelease":"119-100","text":"enjoin that practice;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s6504/a/1/B","parentIdentifier":"/us/usc/t15/s6504/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fa%2F1%2FB","sourceRelease":"119-100","text":"enforce compliance with the regulation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s6504/a/1/C","parentIdentifier":"/us/usc/t15/s6504/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fa%2F1%2FC","sourceRelease":"119-100","text":"obtain damage, restitution, or other compensation on behalf of residents of the State; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s6504/a/1/D","parentIdentifier":"/us/usc/t15/s6504/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fa%2F1%2FD","sourceRelease":"119-100","text":"obtain such other relief as the court may consider to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Notice","label":"2 Notice","identifier":"/us/usc/t15/s6504/a/2","parentIdentifier":"/us/usc/t15/s6504/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s6504/a/2/A","parentIdentifier":"/us/usc/t15/s6504/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s6504/a/2/A/i","parentIdentifier":"/us/usc/t15/s6504/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"written notice of that action; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s6504/a/2/A/ii","parentIdentifier":"/us/usc/t15/s6504/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"a copy of the complaint for that action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exemption","label":"B Exemption","identifier":"/us/usc/t15/s6504/a/2/B","parentIdentifier":"/us/usc/t15/s6504/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t15/s6504/a/2/B/i","parentIdentifier":"/us/usc/t15/s6504/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"Subparagraph (A) shall not apply with respect to the filing of an action by an attorney general of a State under this subsection, if the attorney general determines that it is not feasible to provide the notice described in that subparagraph before the filing of the action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Notification","label":"ii Notification","identifier":"/us/usc/t15/s6504/a/2/B/ii","parentIdentifier":"/us/usc/t15/s6504/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"In an action described in clause (i), the attorney general of a State shall provide notice and a copy of the complaint to the Commission at the same time as the attorney general files the action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Intervention","label":"b Intervention","identifier":"/us/usc/t15/s6504/b","parentIdentifier":"/us/usc/t15/s6504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s6504/b/1","parentIdentifier":"/us/usc/t15/s6504/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fb%2F1","sourceRelease":"119-100","text":"On receiving notice under subsection (a)(2), the Commission shall have the right to intervene in the action that is the subject of the notice.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Effect of intervention","label":"2 Effect of intervention","identifier":"/us/usc/t15/s6504/b/2","parentIdentifier":"/us/usc/t15/s6504/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s6504/b/2/A","parentIdentifier":"/us/usc/t15/s6504/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fb%2F2%2FA","sourceRelease":"119-100","text":"to be heard with respect to any matter that arises in that action; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s6504/b/2/B","parentIdentifier":"/us/usc/t15/s6504/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fb%2F2%2FB","sourceRelease":"119-100","text":"to file a petition for appeal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Amicus curiae","label":"3 Amicus curiae","identifier":"/us/usc/t15/s6504/b/3","parentIdentifier":"/us/usc/t15/s6504/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fb%2F3","sourceRelease":"119-100","text":"Upon application to the court, a person whose self-regulatory guidelines have been approved by the Commission and are relied upon as a defense by any defendant to a proceeding under this section may file amicus curiae in that proceeding.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Construction","label":"c Construction","identifier":"/us/usc/t15/s6504/c","parentIdentifier":"/us/usc/t15/s6504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s6504/c/1","parentIdentifier":"/us/usc/t15/s6504/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fc%2F1","sourceRelease":"119-100","text":"conduct investigations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s6504/c/2","parentIdentifier":"/us/usc/t15/s6504/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fc%2F2","sourceRelease":"119-100","text":"administer oaths or affirmations; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s6504/c/3","parentIdentifier":"/us/usc/t15/s6504/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fc%2F3","sourceRelease":"119-100","text":"compel the attendance of witnesses or the production of documentary and other evidence.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Actions by Commission","label":"d Actions by Commission","identifier":"/us/usc/t15/s6504/d","parentIdentifier":"/us/usc/t15/s6504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fd","sourceRelease":"119-100","text":"In any case in which an action is instituted by or on behalf of the Commission for violation of any regulation prescribed under , no State may, during the pendency of that action, institute an action under subsection (a) against any defendant named in the complaint in that action for violation of that regulation.section 6502 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Venue; service of process","label":"e Venue; service of process","identifier":"/us/usc/t15/s6504/e","parentIdentifier":"/us/usc/t15/s6504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Venue","label":"1 Venue","identifier":"/us/usc/t15/s6504/e/1","parentIdentifier":"/us/usc/t15/s6504/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fe%2F1","sourceRelease":"119-100","text":"Any action brought under subsection (a) may be brought in the district court of the United States that meets applicable requirements relating to venue under .section 1391 of title 28","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Service of process","label":"2 Service of process","identifier":"/us/usc/t15/s6504/e/2","parentIdentifier":"/us/usc/t15/s6504/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s6504/e/2/A","parentIdentifier":"/us/usc/t15/s6504/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fe%2F2%2FA","sourceRelease":"119-100","text":"is an inhabitant; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s6504/e/2/B","parentIdentifier":"/us/usc/t15/s6504/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6504%2Fe%2F2%2FB","sourceRelease":"119-100","text":"may be found.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
