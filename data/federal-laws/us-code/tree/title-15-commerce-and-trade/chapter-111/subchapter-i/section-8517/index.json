{"type":"section","nativeType":"section","number":"8517","heading":"Observing System Simulation Experiments","label":"8517 Observing System Simulation Experiments","identifier":"/us/usc/t15/s8517","parentIdentifier":"/us/usc/t15/ch111/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s8517/a","parentIdentifier":"/us/usc/t15/s8517","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8517/a/1","parentIdentifier":"/us/usc/t15/s8517/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8517/a/1/A","parentIdentifier":"/us/usc/t15/s8517/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fa%2F1%2FA","sourceRelease":"119-100","text":"global weather prediction;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8517/a/1/B","parentIdentifier":"/us/usc/t15/s8517/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fa%2F1%2FB","sourceRelease":"119-100","text":"hurricane track and intensity forecasting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s8517/a/1/C","parentIdentifier":"/us/usc/t15/s8517/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fa%2F1%2FC","sourceRelease":"119-100","text":"tornado warning lead times and accuracy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s8517/a/1/D","parentIdentifier":"/us/usc/t15/s8517/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fa%2F1%2FD","sourceRelease":"119-100","text":"prediction of mid-latitude severe local storm outbreaks; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s8517/a/1/E","parentIdentifier":"/us/usc/t15/s8517/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fa%2F1%2FE","sourceRelease":"119-100","text":"prediction of storms that have the potential to cause extreme precipitation and flooding lasting from 6 hours to 1 week; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8517/a/2","parentIdentifier":"/us/usc/t15/s8517/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fa%2F2","sourceRelease":"119-100","text":"shall be conducted in cooperation with other appropriate entities within the National Oceanic and Atmospheric Administration, other Federal agencies, the United States weather industry, and academic partners to ensure the technical and scientific merit of results from Observing System Simulation Experiments or other appropriate quantitative assessment methodologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirements","label":"b Requirements","identifier":"/us/usc/t15/s8517/b","parentIdentifier":"/us/usc/t15/s8517","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8517/b/1","parentIdentifier":"/us/usc/t15/s8517/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fb%2F1","sourceRelease":"119-100","text":"determine the potential impact of proposed space-based, suborbital, and in situ observing systems on analyses and forecasts, including potential impacts on extreme weather events across all parts of the Nation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8517/b/2","parentIdentifier":"/us/usc/t15/s8517/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fb%2F2","sourceRelease":"119-100","text":"evaluate and compare observing system design options; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8517/b/3","parentIdentifier":"/us/usc/t15/s8517/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fb%2F3","sourceRelease":"119-100","text":"assess the relative capabilities and costs of various observing systems and combinations of observing systems in providing data necessary to protect life and property.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Implementation","label":"c Implementation","identifier":"/us/usc/t15/s8517/c","parentIdentifier":"/us/usc/t15/s8517","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8517/c/1","parentIdentifier":"/us/usc/t15/s8517/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fc%2F1","sourceRelease":"119-100","text":"shall be conducted prior to the acquisition of major Government-owned or Government-leased operational observing systems, including polar-orbiting and geostationary satellite systems, with a lifecycle cost of more than $500,000,000; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8517/c/2","parentIdentifier":"/us/usc/t15/s8517/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fc%2F2","sourceRelease":"119-100","text":"shall be conducted prior to the purchase of any major new commercially provided data with a lifecycle cost of more than $500,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Priority Observing System Simulation Experiments","label":"d Priority Observing System Simulation Experiments","identifier":"/us/usc/t15/s8517/d","parentIdentifier":"/us/usc/t15/s8517","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Global Navigation Satellite System Radio Occultation","label":"1 Global Navigation Satellite System Radio Occultation","identifier":"/us/usc/t15/s8517/d/1","parentIdentifier":"/us/usc/t15/s8517/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fd%2F1","sourceRelease":"119-100","text":"Not later than 30 days after , the Assistant Administrator for Oceanic and Atmospheric Research shall complete an Observing System Simulation Experiment to assess the value of data from Global Navigation Satellite System Radio Occultation.April 18, 2017","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Geostationary hyperspectral sounder global constellation","label":"2 Geostationary hyperspectral sounder global constellation","identifier":"/us/usc/t15/s8517/d/2","parentIdentifier":"/us/usc/t15/s8517/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fd%2F2","sourceRelease":"119-100","text":"Not later than 120 days after , the Assistant Administrator for Oceanic and Atmospheric Research shall complete an Observing System Simulation Experiment to assess the value of data from a geostationary hyperspectral sounder global constellation.April 18, 2017","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Results","label":"e Results","identifier":"/us/usc/t15/s8517/e","parentIdentifier":"/us/usc/t15/s8517","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8517%2Fe","sourceRelease":"119-100","text":"Upon completion of all Observing System Simulation Experiments, the Assistant Administrator shall make available to the public the results an assessment of related private and public sector weather data sourcing options, including their availability, affordability, and cost-effectiveness. Such assessments shall be developed in accordance with .1section 50503 of title 51So in original.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
