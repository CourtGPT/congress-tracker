{"type":"section","nativeType":"section","number":"5624","heading":"Transfer of positions in Corrections Calendar Office","label":"5624 Transfer of positions in Corrections Calendar Office","identifier":"/us/usc/t2/s5624","parentIdentifier":"/us/usc/t2/ch55/schIX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs5624","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified as a note under prior to editorial reclassification and renumbering as this section.section 74d of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t2/s5624/a","parentIdentifier":"/us/usc/t2/s5624","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs5624%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s5624/a/1","parentIdentifier":"/us/usc/t2/s5624/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs5624%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t2/s5624/a/1/A","parentIdentifier":"/us/usc/t2/s5624/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs5624%2Fa%2F1%2FA","sourceRelease":"119-100","text":"3 of the positions in the Corrections Calendar Office, and the functions associated with such positions, shall be transferred to the Office of the Speaker; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t2/s5624/a/1/B","parentIdentifier":"/us/usc/t2/s5624/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs5624%2Fa%2F1%2FB","sourceRelease":"119-100","text":"2 of the positions in the Corrections Calendar Office, and the functions associated with such positions, shall be transferred to the Office of the Minority Leader.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s5624/a/2","parentIdentifier":"/us/usc/t2/s5624/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs5624%2Fa%2F2","sourceRelease":"119-100","text":"Notwithstanding any other provision of law, in the case of any individual who is an incumbent of a position transferred under paragraph (1) at the time of the transfer, the total number of days of annual leave and the total number of days of sick leave which were provided by the Corrections Calendar Office to the individual and which remain unused as of the date of the transfer shall remain available for the individual to use after the transfer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t2/s5624/b","parentIdentifier":"/us/usc/t2/s5624","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs5624%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s5624/b/1","parentIdentifier":"/us/usc/t2/s5624/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs5624%2Fb%2F1","sourceRelease":"119-100","text":"63.5 percent of such allowance shall be transferred to the Office of the Speaker.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s5624/b/2","parentIdentifier":"/us/usc/t2/s5624/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs5624%2Fb%2F2","sourceRelease":"119-100","text":"36.5 percent of such allowance shall be transferred to the Office of the Minority Leader.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
