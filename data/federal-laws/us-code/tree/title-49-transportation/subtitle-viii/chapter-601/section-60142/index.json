{"type":"section","nativeType":"section","number":"60142","heading":"Pipeline safety enhancement programs","label":"60142 Pipeline safety enhancement programs","identifier":"/us/usc/t49/s60142","parentIdentifier":"/us/usc/t49/stVIII/ch601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142","sourceRelease":"119-100","text":null,"notes":["References in TextThe date of enactment of this section, referred to in subsecs. (b)(4)(A) and (c)(2), is the date of enactment of , which was approved .Pub. L. 116–260Dec. 27, 2020"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t49/s60142/a","parentIdentifier":"/us/usc/t49/s60142","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s60142/a/1","parentIdentifier":"/us/usc/t49/s60142/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fa%2F1","sourceRelease":"119-100","text":"a natural gas pipeline facility; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s60142/a/2","parentIdentifier":"/us/usc/t49/s60142/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fa%2F2","sourceRelease":"119-100","text":"a hazardous liquid pipeline facility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitations.—","label":"b Limitations.—","identifier":"/us/usc/t49/s60142/b","parentIdentifier":"/us/usc/t49/s60142","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s60142/b/1","parentIdentifier":"/us/usc/t49/s60142/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s60142/b/1/A","parentIdentifier":"/us/usc/t49/s60142/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s60142/b/1/A/i","parentIdentifier":"/us/usc/t49/s60142/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the Pipeline and Hazardous Materials Safety Administration; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s60142/b/1/A/ii","parentIdentifier":"/us/usc/t49/s60142/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"a State authority under section 60105 or 60106; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s60142/b/1/B","parentIdentifier":"/us/usc/t49/s60142/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s60142/b/1/B/i","parentIdentifier":"/us/usc/t49/s60142/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the Pipeline and Hazardous Materials Safety Administration; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s60142/b/1/B/ii","parentIdentifier":"/us/usc/t49/s60142/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"a State authority under section 60105 or 60106.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Operator mileage limitation","label":"2 .—Operator mileage limitation","identifier":"/us/usc/t49/s60142/b/2","parentIdentifier":"/us/usc/t49/s60142/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s60142/b/2/A","parentIdentifier":"/us/usc/t49/s60142/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s60142/b/2/A/i","parentIdentifier":"/us/usc/t49/s60142/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the Pipeline and Hazardous Materials Safety Administration; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s60142/b/2/A/ii","parentIdentifier":"/us/usc/t49/s60142/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"a State authority under section 60105 or 60106; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s60142/b/2/B","parentIdentifier":"/us/usc/t49/s60142/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F2%2FB","sourceRelease":"119-100","text":"1,000 miles.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Prohibited areas","label":"3 .—Prohibited areas","identifier":"/us/usc/t49/s60142/b/3","parentIdentifier":"/us/usc/t49/s60142/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s60142/b/3/A","parentIdentifier":"/us/usc/t49/s60142/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F3%2FA","sourceRelease":"119-100","text":"a high population area (as defined in section 195.450 of title 49, Code of Federal Regulations (or a successor regulation));","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s60142/b/3/B","parentIdentifier":"/us/usc/t49/s60142/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F3%2FB","sourceRelease":"119-100","text":"a high consequence area (as defined in section 192.903 of title 49, Code of Federal Regulations (or a successor regulation)); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s60142/b/3/C","parentIdentifier":"/us/usc/t49/s60142/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F3%2FC","sourceRelease":"119-100","text":"an unusually sensitive area (as described under subsection (a)(1)(B)(ii) of section 60109 in accordance with subsection (b) of that section).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"High consequence areas for hazardous liquid pipelines.—","label":"4 High consequence areas for hazardous liquid pipelines.—","identifier":"/us/usc/t49/s60142/b/4","parentIdentifier":"/us/usc/t49/s60142/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t49/s60142/b/4/A","parentIdentifier":"/us/usc/t49/s60142/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F4%2FA","sourceRelease":"119-100","text":"Not later than 1 year after the date of enactment of this section, the Secretary shall submit to Congress a report examining the benefits and costs of prohibiting the testing of hazardous liquid pipelines in high consequence areas (as defined in section 195.450 of title 49, Code of Federal Regulations (or a successor regulation)).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Contents of report","label":"B .—Contents of report","identifier":"/us/usc/t49/s60142/b/4/B","parentIdentifier":"/us/usc/t49/s60142/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s60142/b/4/B/i","parentIdentifier":"/us/usc/t49/s60142/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F4%2FB%2Fi","sourceRelease":"119-100","text":"the safety benefits of allowing the testing of hazardous liquid pipelines in high consequence areas (as defined in section 195.450 of title 49, Code of Federal Regulations (or a successor regulation)); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s60142/b/4/B/ii","parentIdentifier":"/us/usc/t49/s60142/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fb%2F4%2FB%2Fii","sourceRelease":"119-100","text":"whether additional testing conditions are required to protect those areas while conducting a testing program established under subsection (a) in those areas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duration.—","label":"c Duration.—","identifier":"/us/usc/t49/s60142/c","parentIdentifier":"/us/usc/t49/s60142","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s60142/c/1","parentIdentifier":"/us/usc/t49/s60142/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fc%2F1","sourceRelease":"119-100","text":"The term of a testing program established under subsection (a) shall be not more than a period of 3 years beginning on the date of approval of the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Requirement","label":"2 .—Requirement","identifier":"/us/usc/t49/s60142/c/2","parentIdentifier":"/us/usc/t49/s60142/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fc%2F2","sourceRelease":"119-100","text":"The Secretary shall not establish any additional safety-enhancing testing programs under subsection (a) after the date that is 3 years after the date of enactment of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Safety Standards.—","label":"d Safety Standards.—","identifier":"/us/usc/t49/s60142/d","parentIdentifier":"/us/usc/t49/s60142","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s60142/d/1","parentIdentifier":"/us/usc/t49/s60142/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary shall require, as a condition of approval of a testing program under subsection (a), that the safety measures in the testing program are designed to achieve a level of safety that is greater than the level of safety required by this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Determination.—","label":"2 Determination.—","identifier":"/us/usc/t49/s60142/d/2","parentIdentifier":"/us/usc/t49/s60142/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t49/s60142/d/2/A","parentIdentifier":"/us/usc/t49/s60142/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fd%2F2%2FA","sourceRelease":"119-100","text":"The Secretary may issue an order under subparagraph (A) of section 60118(c)(1) to accomplish the purpose of a testing program for a term not to exceed the time period described in subsection (c) if the condition described in paragraph (1) is met, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Limitation","label":"B .—Limitation","identifier":"/us/usc/t49/s60142/d/2/B","parentIdentifier":"/us/usc/t49/s60142/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fd%2F2%2FB","sourceRelease":"119-100","text":"An order under subparagraph (A) shall pertain only to those regulations that would otherwise prevent the use of the safety technology to be tested under the testing program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Increased safety capabilities","label":"3 .—Increased safety capabilities","identifier":"/us/usc/t49/s60142/d/3","parentIdentifier":"/us/usc/t49/s60142/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fd%2F3","sourceRelease":"119-100","text":"For purposes of paragraph (1), improvement in the reliability, accuracy, durability, or certainty of pipeline safety technologies, techniques, or methods shall constitute an appropriate means of meeting the safety measure requirement described in that paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Considerations","label":"e .—Considerations","identifier":"/us/usc/t49/s60142/e","parentIdentifier":"/us/usc/t49/s60142","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s60142/e/1","parentIdentifier":"/us/usc/t49/s60142/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fe%2F1","sourceRelease":"119-100","text":"the accident and incident record of the owners or operators participating in the program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s60142/e/2","parentIdentifier":"/us/usc/t49/s60142/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s60142/e/2/A","parentIdentifier":"/us/usc/t49/s60142/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fe%2F2%2FA","sourceRelease":"119-100","text":"whether the owners or operators participating in the program have a safety management system in place; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s60142/e/2/B","parentIdentifier":"/us/usc/t49/s60142/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fe%2F2%2FB","sourceRelease":"119-100","text":"how the application of that system proposes to eliminate or mitigate potential safety and environmental risks throughout the duration of the program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s60142/e/3","parentIdentifier":"/us/usc/t49/s60142/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fe%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s60142/e/3/A","parentIdentifier":"/us/usc/t49/s60142/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fe%2F3%2FA","sourceRelease":"119-100","text":"the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s60142/e/3/B","parentIdentifier":"/us/usc/t49/s60142/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fe%2F3%2FB","sourceRelease":"119-100","text":"collaborative research development organizations; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s60142/e/3/C","parentIdentifier":"/us/usc/t49/s60142/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fe%2F3%2FC","sourceRelease":"119-100","text":"other institutions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Data and Findings.—","label":"f Data and Findings.—","identifier":"/us/usc/t49/s60142/f","parentIdentifier":"/us/usc/t49/s60142","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s60142/f/1","parentIdentifier":"/us/usc/t49/s60142/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Ff%2F1","sourceRelease":"119-100","text":"As a participant in a testing program established under subsection (a), an owner or operator shall submit to the Secretary detailed findings and a summary of data collected as a result of participation in the testing program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Public report","label":"2 .—Public report","identifier":"/us/usc/t49/s60142/f/2","parentIdentifier":"/us/usc/t49/s60142/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Ff%2F2","sourceRelease":"119-100","text":"The Secretary shall make publicly available on the website of the Department of Transportation an annual report for any ongoing testing program established under subsection (a) summarizing the progress of the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":".—Authority to Revoke Participation","label":"g .—Authority to Revoke Participation","identifier":"/us/usc/t49/s60142/g","parentIdentifier":"/us/usc/t49/s60142","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s60142/g/1","parentIdentifier":"/us/usc/t49/s60142/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fg%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s60142/g/1/A","parentIdentifier":"/us/usc/t49/s60142/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fg%2F1%2FA","sourceRelease":"119-100","text":"the participant has an accident or incident involving death or personal injury necessitating in-patient hospitalization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s60142/g/1/B","parentIdentifier":"/us/usc/t49/s60142/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fg%2F1%2FB","sourceRelease":"119-100","text":"the testing program is determined to be the cause of, or a contributing factor to, that accident or incident;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s60142/g/2","parentIdentifier":"/us/usc/t49/s60142/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fg%2F2","sourceRelease":"119-100","text":"the participant fails to comply with the terms and conditions of the testing program; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s60142/g/3","parentIdentifier":"/us/usc/t49/s60142/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fg%2F3","sourceRelease":"119-100","text":"in the determination of the Secretary, continued participation in the testing program by the participant would be unsafe or would not be consistent with the goals and objectives of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":".—Authority to Terminate Program","label":"h .—Authority to Terminate Program","identifier":"/us/usc/t49/s60142/h","parentIdentifier":"/us/usc/t49/s60142","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fh","sourceRelease":"119-100","text":"The Secretary shall immediately terminate a testing program under subsection (a) if continuation of the testing program would not be consistent with the goals and objectives of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"State Rights.—","label":"i State Rights.—","identifier":"/us/usc/t49/s60142/i","parentIdentifier":"/us/usc/t49/s60142","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Exemption","label":"1 .—Exemption","identifier":"/us/usc/t49/s60142/i/1","parentIdentifier":"/us/usc/t49/s60142/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fi%2F1","sourceRelease":"119-100","text":"Except as provided in paragraph (2), if a State submits to the Secretary notice that the State requests an exemption from any testing program considered for establishment under this section, the State shall be exempt.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitations.—","label":"2 Limitations.—","identifier":"/us/usc/t49/s60142/i/2","parentIdentifier":"/us/usc/t49/s60142/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fi%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t49/s60142/i/2/A","parentIdentifier":"/us/usc/t49/s60142/i/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fi%2F2%2FA","sourceRelease":"119-100","text":"The Secretary shall not grant a requested exemption under paragraph (1) after a testing program is established.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Late notice","label":"B .—Late notice","identifier":"/us/usc/t49/s60142/i/2/B","parentIdentifier":"/us/usc/t49/s60142/i/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fi%2F2%2FB","sourceRelease":"119-100","text":"The Secretary shall not grant a requested exemption under paragraph (1) if the notice submitted under that paragraph is submitted to the Secretary more than 30 days after the date on which the Secretary issues an order providing an effective date for the testing program in accordance with subsection (j).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Effect","label":"3 .—Effect","identifier":"/us/usc/t49/s60142/i/3","parentIdentifier":"/us/usc/t49/s60142/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fi%2F3","sourceRelease":"119-100","text":"If a State has not submitted a notice requesting an exemption under paragraph (1), the State shall not enforce any law (including regulations) that is inconsistent with a testing program in effect in the State under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"j","heading":"Program Review Process and Public Notice.—","label":"j Program Review Process and Public Notice.—","identifier":"/us/usc/t49/s60142/j","parentIdentifier":"/us/usc/t49/s60142","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fj","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s60142/j/1","parentIdentifier":"/us/usc/t49/s60142/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fj%2F1","sourceRelease":"119-100","text":"The Secretary shall publish in the Federal Register and send directly to each relevant State and each appropriate State authority with a certification in effect under section 60105 a notice of each proposed testing program under subsection (a), including the order to be considered, and provide an opportunity for public comment for not less than 90 days.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Response from secretary","label":"2 .—Response from secretary","identifier":"/us/usc/t49/s60142/j/2","parentIdentifier":"/us/usc/t49/s60142/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fj%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s60142/j/2/A","parentIdentifier":"/us/usc/t49/s60142/j/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fj%2F2%2FA","sourceRelease":"119-100","text":"publish the order in the Federal Register; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s60142/j/2/B","parentIdentifier":"/us/usc/t49/s60142/j/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fj%2F2%2FB","sourceRelease":"119-100","text":"respond to each comment submitted under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"k","heading":".—Report to Congress","label":"k .—Report to Congress","identifier":"/us/usc/t49/s60142/k","parentIdentifier":"/us/usc/t49/s60142","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fk","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s60142/k/1","parentIdentifier":"/us/usc/t49/s60142/k","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fk%2F1","sourceRelease":"119-100","text":"the findings and conclusions of the Secretary with respect to the testing program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s60142/k/2","parentIdentifier":"/us/usc/t49/s60142/k","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fk%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s60142/k/2/A","parentIdentifier":"/us/usc/t49/s60142/k/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fk%2F2%2FA","sourceRelease":"119-100","text":"would enhance the safe operation of interstate gas or hazardous liquid pipeline facilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s60142/k/2/B","parentIdentifier":"/us/usc/t49/s60142/k/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fk%2F2%2FB","sourceRelease":"119-100","text":"are technically, operationally, and economically feasible.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"l","heading":".—Standards","label":"l .—Standards","identifier":"/us/usc/t49/s60142/l","parentIdentifier":"/us/usc/t49/s60142","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fl","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s60142/l/1","parentIdentifier":"/us/usc/t49/s60142/l","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fl%2F1","sourceRelease":"119-100","text":"allow operators of interstate gas or hazardous liquid pipeline facilities to use the relevant technology or practice to the extent practicable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s60142/l/2","parentIdentifier":"/us/usc/t49/s60142/l","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60142%2Fl%2F2","sourceRelease":"119-100","text":"establish technically, operationally, and economically feasible standards for the capability and deployment of the technology or practice.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
