anics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of , including authority of Secretary of Labor, see .Pub. L. 117–58section 18851 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s17111/a","parentIdentifier":"/us/usc/t42/s17111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible entity","label":"1 Eligible entity","identifier":"/us/usc/t42/s17111/a/1","parentIdentifier":"/us/usc/t42/s17111/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17111/a/1/A","parentIdentifier":"/us/usc/t42/s17111/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F1%2FA","sourceRelease":"119-100","text":"an energy-intensive industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17111/a/1/B","parentIdentifier":"/us/usc/t42/s17111/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F1%2FB","sourceRelease":"119-100","text":"a national trade association representing an energy-intensive industry; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17111/a/1/C","parentIdentifier":"/us/usc/t42/s17111/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F1%2FC","sourceRelease":"119-100","text":"a person acting on behalf of 1 or more energy-intensive industries or sectors, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Energy-intensive industry","label":"2 Energy-intensive industry","identifier":"/us/usc/t42/s17111/a/2","parentIdentifier":"/us/usc/t42/s17111/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17111/a/2/A","parentIdentifier":"/us/usc/t42/s17111/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FA","sourceRelease":"119-100","text":"information technology, including data centers containing electrical equipment used in processing, storing, and transmitting digital information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17111/a/2/B","parentIdentifier":"/us/usc/t42/s17111/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FB","sourceRelease":"119-100","text":"consumer product manufacturing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17111/a/2/C","parentIdentifier":"/us/usc/t42/s17111/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FC","sourceRelease":"119-100","text":"food processing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17111/a/2/D","parentIdentifier":"/us/usc/t42/s17111/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17111/a/2/D/i","parentIdentifier":"/us/usc/t42/s17111/a/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FD%2Fi","sourceRelease":"119-100","text":"aluminum;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17111/a/2/D/ii","parentIdentifier":"/us/usc/t42/s17111/a/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FD%2Fii","sourceRelease":"119-100","text":"chemicals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s17111/a/2/D/iii","parentIdentifier":"/us/usc/t42/s17111/a/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FD%2Fiii","sourceRelease":"119-100","text":"forest and paper products;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s17111/a/2/D/iv","parentIdentifier":"/us/usc/t42/s17111/a/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FD%2Fiv","sourceRelease":"119-100","text":"metal casting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s17111/a/2/D/v","parentIdentifier":"/us/usc/t42/s17111/a/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FD%2Fv","sourceRelease":"119-100","text":"glass;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s17111/a/2/D/vi","parentIdentifier":"/us/usc/t42/s17111/a/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FD%2Fvi","sourceRelease":"119-100","text":"petroleum refining;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t42/s17111/a/2/D/vii","parentIdentifier":"/us/usc/t42/s17111/a/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FD%2Fvii","sourceRelease":"119-100","text":"mining; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t42/s17111/a/2/D/viii","parentIdentifier":"/us/usc/t42/s17111/a/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FD%2Fviii","sourceRelease":"119-100","text":"steel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17111/a/2/E","parentIdentifier":"/us/usc/t42/s17111/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FE","sourceRelease":"119-100","text":"water and wastewater treatment facilities, including systems that treat municipal, industrial, and agricultural waste; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17111/a/2/F","parentIdentifier":"/us/usc/t42/s17111/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F2%2FF","sourceRelease":"119-100","text":"other energy-intensive industries, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Feedstock","label":"3 Feedstock","identifier":"/us/usc/t42/s17111/a/3","parentIdentifier":"/us/usc/t42/s17111/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F3","sourceRelease":"119-100","text":"The term “feedstock” means the raw material supplied for use in manufacturing, chemical, and biological processes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Partnership","label":"4 Partnership","identifier":"/us/usc/t42/s17111/a/4","parentIdentifier":"/us/usc/t42/s17111/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F4","sourceRelease":"119-100","text":"The term “partnership” means an energy efficiency partnership established under subsection (c)(1)(A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Program","label":"5 Program","identifier":"/us/usc/t42/s17111/a/5","parentIdentifier":"/us/usc/t42/s17111/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fa%2F5","sourceRelease":"119-100","text":"The term “program” means the energy-intensive industries program established under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment of program","label":"b Establishment of program","identifier":"/us/usc/t42/s17111/b","parentIdentifier":"/us/usc/t42/s17111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fb","sourceRelease":"119-100","text":"The Secretary shall establish a program under which the Secretary, in cooperation with energy-intensive industries and national industry trade associations representing the energy-intensive industries, shall support, research, develop, and promote the use of new materials processes, technologies, and techniques to optimize energy efficiency and the economic competitiveness of the United States’ industrial and commercial sectors.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Partnerships","label":"c Partnerships","identifier":"/us/usc/t42/s17111/c","parentIdentifier":"/us/usc/t42/s17111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17111/c/1","parentIdentifier":"/us/usc/t42/s17111/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17111/c/1/A","parentIdentifier":"/us/usc/t42/s17111/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F1%2FA","sourceRelease":"119-100","text":"increase the energy efficiency of industrial processes and facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17111/c/1/B","parentIdentifier":"/us/usc/t42/s17111/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F1%2FB","sourceRelease":"119-100","text":"research, develop, and demonstrate advanced technologies capable of energy intensity reductions and increased environmental performance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17111/c/1/C","parentIdentifier":"/us/usc/t42/s17111/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F1%2FC","sourceRelease":"119-100","text":"promote the use of the processes, technologies, and techniques described in subparagraphs (A) and (B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible activities","label":"2 Eligible activities","identifier":"/us/usc/t42/s17111/c/2","parentIdentifier":"/us/usc/t42/s17111/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17111/c/2/A","parentIdentifier":"/us/usc/t42/s17111/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17111/c/2/A/i","parentIdentifier":"/us/usc/t42/s17111/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"opportunities for meeting industry feedstock requirements with more energy efficient and flexible sources of feedstock or energy supply;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17111/c/2/A/ii","parentIdentifier":"/us/usc/t42/s17111/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":"strategies to develop and deploy technologies that improve the quality and quantity of feedstocks recovered from process and waste streams; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s17111/c/2/A/iii","parentIdentifier":"/us/usc/t42/s17111/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"other methods using recycling, reuse, and improved industrial materials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17111/c/2/B","parentIdentifier":"/us/usc/t42/s17111/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FB","sourceRelease":"119-100","text":"research to develop and demonstrate technologies and processes that utilize alternative energy sources to supply heat, power, and new feedstocks for energy-intensive industries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17111/c/2/C","parentIdentifier":"/us/usc/t42/s17111/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FC","sourceRelease":"119-100","text":"research to achieve energy efficiency in steam, power, control system, and process heat technologies, and in other manufacturing processes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17111/c/2/D","parentIdentifier":"/us/usc/t42/s17111/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17111/c/2/D/i","parentIdentifier":"/us/usc/t42/s17111/c/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FD%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s17111/c/2/D/i/I","parentIdentifier":"/us/usc/t42/s17111/c/2/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FD%2Fi%2FI","sourceRelease":"119-100","text":"the unique processes and facilities of the sectors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s17111/c/2/D/i/II","parentIdentifier":"/us/usc/t42/s17111/c/2/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FD%2Fi%2FII","sourceRelease":"119-100","text":"the energy utilization requirements of the sectors; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t42/s17111/c/2/D/i/III","parentIdentifier":"/us/usc/t42/s17111/c/2/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FD%2Fi%2FIII","sourceRelease":"119-100","text":"the application of new, more energy efficient technologies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17111/c/2/D/ii","parentIdentifier":"/us/usc/t42/s17111/c/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FD%2Fii","sourceRelease":"119-100","text":"conduct energy savings assessments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17111/c/2/E","parentIdentifier":"/us/usc/t42/s17111/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FE","sourceRelease":"119-100","text":"the incorporation of technologies and innovations that would significantly improve the energy efficiency and utilization of energy-intensive commercial applications; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17111/c/2/F","parentIdentifier":"/us/usc/t42/s17111/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F2%2FF","sourceRelease":"119-100","text":"any other activities that the Secretary determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Proposals","label":"3 Proposals","identifier":"/us/usc/t42/s17111/c/3","parentIdentifier":"/us/usc/t42/s17111/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s17111/c/3/A","parentIdentifier":"/us/usc/t42/s17111/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F3%2FA","sourceRelease":"119-100","text":"To be eligible for funding under this subsection, a partnership shall submit to the Secretary a proposal that describes the proposed research, development, or demonstration activity to be conducted by the partnership.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Review","label":"B Review","identifier":"/us/usc/t42/s17111/c/3/B","parentIdentifier":"/us/usc/t42/s17111/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F3%2FB","sourceRelease":"119-100","text":"After reviewing the scientific, technical, and commercial merit of a proposals submitted under subparagraph (A), the Secretary shall approve or disapprove the proposal.1So in original.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Competitive awards","label":"C Competitive awards","identifier":"/us/usc/t42/s17111/c/3/C","parentIdentifier":"/us/usc/t42/s17111/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F3%2FC","sourceRelease":"119-100","text":"The provision of funding under this subsection shall be on a competitive basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Cost-sharing requirement","label":"4 Cost-sharing requirement","identifier":"/us/usc/t42/s17111/c/4","parentIdentifier":"/us/usc/t42/s17111/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fc%2F4","sourceRelease":"119-100","text":"In carrying out this section, the Secretary shall require cost sharing in accordance with .section 16352 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Grants","label":"d Grants","identifier":"/us/usc/t42/s17111/d","parentIdentifier":"/us/usc/t42/s17111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fd","sourceRelease":"119-100","text":"The Secretary may award competitive grants for innovative technology research, development and demonstrations to universities, individual inventors, and small companies, based on energy savings potential, commercial viability, and technical merit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s17111/e","parentIdentifier":"/us/usc/t42/s17111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17111/e/1","parentIdentifier":"/us/usc/t42/s17111/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17111/e/1/A","parentIdentifier":"/us/usc/t42/s17111/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fe%2F1%2FA","sourceRelease":"119-100","text":"$184,000,000 for fiscal year 2008;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17111/e/1/B","parentIdentifier":"/us/usc/t42/s17111/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fe%2F1%2FB","sourceRelease":"119-100","text":"$190,000,000 for fiscal year 2009;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17111/e/1/C","parentIdentifier":"/us/usc/t42/s17111/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fe%2F1%2FC","sourceRelease":"119-100","text":"$196,000,000 for fiscal year 2010;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17111/e/1/D","parentIdentifier":"/us/usc/t42/s17111/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fe%2F1%2FD","sourceRelease":"119-100","text":"$202,000,000 for fiscal year 2011;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17111/e/1/E","parentIdentifier":"/us/usc/t42/s17111/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fe%2F1%2FE","sourceRelease":"119-100","text":"$208,000,000 for fiscal year 2012; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17111/e/1/F","parentIdentifier":"/us/usc/t42/s17111/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fe%2F1%2FF","sourceRelease":"119-100","text":"such sums as are necessary for fiscal year 2013 and each fiscal year thereafter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Partnership activities","label":"2 Partnership activities","identifier":"/us/usc/t42/s17111/e/2","parentIdentifier":"/us/usc/t42/s17111/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fe%2F2","sourceRelease":"119-100","text":"Of the amounts made available under paragraph (1), not less than 50 percent shall be used to pay the Federal share of partnership activities under subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Coordination and nonduplication","label":"3 Coordination and nonduplication","identifier":"/us/usc/t42/s17111/e/3","parentIdentifier":"/us/usc/t42/s17111/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17111%2Fe%2F3","sourceRelease":"119-100","text":"The Secretary shall coordinate efforts under this section with other programs of the Department and other Federal agencies to avoid duplication of effort.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
