{"type":"section","nativeType":"section","number":"460ttt–2","heading":"Administration of national recreation area","label":"460ttt–2 Administration of national recreation area","identifier":"/us/usc/t16/s460ttt–2","parentIdentifier":"/us/usc/t16/ch1/schCXXXI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ttt%E2%80%932","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s460ttt–2/a","parentIdentifier":"/us/usc/t16/s460ttt–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ttt%E2%80%932%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460ttt–2/a/1","parentIdentifier":"/us/usc/t16/s460ttt–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ttt%E2%80%932%2Fa%2F1","sourceRelease":"119-100","text":"laws (including rules and regulations) applicable to units of the National Forest System; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460ttt–2/a/2","parentIdentifier":"/us/usc/t16/s460ttt–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ttt%E2%80%932%2Fa%2F2","sourceRelease":"119-100","text":"the management direction (including objectives, standards, and guidelines) established for the Moosalamoo Recreation and Education Management Area under the Management Plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Fish and wildlife","label":"b Fish and wildlife","identifier":"/us/usc/t16/s460ttt–2/b","parentIdentifier":"/us/usc/t16/s460ttt–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ttt%E2%80%932%2Fb","sourceRelease":"119-100","text":"Nothing in this subchapter affects the jurisdiction of the State with respect to wildlife and fish on the public land located in the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Escarpment and ecological areas","label":"c Escarpment and ecological areas","identifier":"/us/usc/t16/s460ttt–2/c","parentIdentifier":"/us/usc/t16/s460ttt–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ttt%E2%80%932%2Fc","sourceRelease":"119-100","text":"Nothing in this subchapter prevents the Secretary from managing the Green Mountain Escarpment Management Area and the Ecological Special Areas, as described in the Management Plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
