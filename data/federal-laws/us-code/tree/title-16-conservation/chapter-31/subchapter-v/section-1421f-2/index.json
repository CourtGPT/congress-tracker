{"type":"section","nativeType":"section","number":"1421f–2","heading":"Marine Mammal Health Monitoring and Analysis Platform (Health MAP)","label":"1421f–2 Marine Mammal Health Monitoring and Analysis Platform (Health MAP)","identifier":"/us/usc/t16/s1421f–2","parentIdentifier":"/us/usc/t16/ch31/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s1421f–2/a","parentIdentifier":"/us/usc/t16/s1421f–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s1421f–2/a/1","parentIdentifier":"/us/usc/t16/s1421f–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fa%2F1","sourceRelease":"119-100","text":"establish a marine mammal health monitoring and analysis platform (referred to in this chapter as the “Health MAP”);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s1421f–2/a/2","parentIdentifier":"/us/usc/t16/s1421f–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fa%2F2","sourceRelease":"119-100","text":"incorporate the Health MAP into the Observation System; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s1421f–2/a/3","parentIdentifier":"/us/usc/t16/s1421f–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1421f–2/a/3/A","parentIdentifier":"/us/usc/t16/s1421f–2/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fa%2F3%2FA","sourceRelease":"119-100","text":"publicly accessible through the web portal of the Observation System; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1421f–2/a/3/B","parentIdentifier":"/us/usc/t16/s1421f–2/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fa%2F3%2FB","sourceRelease":"119-100","text":"interoperable with other national data systems or other data systems for management or research purposes, as practicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purposes","label":"b Purposes","identifier":"/us/usc/t16/s1421f–2/b","parentIdentifier":"/us/usc/t16/s1421f–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s1421f–2/b/1","parentIdentifier":"/us/usc/t16/s1421f–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1421f–2/b/1/A","parentIdentifier":"/us/usc/t16/s1421f–2/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fb%2F1%2FA","sourceRelease":"119-100","text":"interdisciplinary research among individuals with knowledge and experience in marine mammal science, marine mammal veterinary and husbandry practices, medical science, and oceanography, and with other marine scientists;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1421f–2/b/1/B","parentIdentifier":"/us/usc/t16/s1421f–2/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fb%2F1%2FB","sourceRelease":"119-100","text":"timely and sustained dissemination and availability of marine mammal health, stranding, entanglement, and mortality data;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s1421f–2/b/1/C","parentIdentifier":"/us/usc/t16/s1421f–2/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fb%2F1%2FC","sourceRelease":"119-100","text":"identification of spatial and temporal patterns of marine mammal mortality, disease, and stranding;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s1421f–2/b/1/D","parentIdentifier":"/us/usc/t16/s1421f–2/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fb%2F1%2FD","sourceRelease":"119-100","text":"evaluation of marine mammal health in terms of mortality, as well as sublethal marine mammal health impacts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s1421f–2/b/1/E","parentIdentifier":"/us/usc/t16/s1421f–2/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fb%2F1%2FE","sourceRelease":"119-100","text":"improved collaboration and forecasting of marine mammal and larger ecosystem health events;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t16/s1421f–2/b/1/F","parentIdentifier":"/us/usc/t16/s1421f–2/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fb%2F1%2FF","sourceRelease":"119-100","text":"rapid communication and dissemination of information regarding marine mammal strandings that may have implications for human health, such as those caused by harmful algal blooms; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t16/s1421f–2/b/1/G","parentIdentifier":"/us/usc/t16/s1421f–2/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fb%2F1%2FG","sourceRelease":"119-100","text":"increased accessibility of data in a user friendly visual interface for public education and outreach; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s1421f–2/b/2","parentIdentifier":"/us/usc/t16/s1421f–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fb%2F2","sourceRelease":"119-100","text":"to contribute to an ocean health index that incorporates marine mammal health data.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Requirements","label":"c Requirements","identifier":"/us/usc/t16/s1421f–2/c","parentIdentifier":"/us/usc/t16/s1421f–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s1421f–2/c/1","parentIdentifier":"/us/usc/t16/s1421f–2/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fc%2F1","sourceRelease":"119-100","text":"integrate in situ, remote, and other marine mammal health, stranding, and mortality data, including visualizations and metadata, collected by marine mammal stranding networks, Federal, State, local, and Tribal governments, private partners, and academia; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s1421f–2/c/2","parentIdentifier":"/us/usc/t16/s1421f–2/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1421f–2/c/2/A","parentIdentifier":"/us/usc/t16/s1421f–2/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fc%2F2%2FA","sourceRelease":"119-100","text":"to enhance data and information availability, including data sharing among stranding network participants, scientists, and the public within and across stranding network regions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1421f–2/c/2/B","parentIdentifier":"/us/usc/t16/s1421f–2/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fc%2F2%2FB","sourceRelease":"119-100","text":"to facilitate data and information access across scientific disciplines, scientists, and managers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s1421f–2/c/2/C","parentIdentifier":"/us/usc/t16/s1421f–2/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fc%2F2%2FC","sourceRelease":"119-100","text":"to facilitate public access to national and regional marine mammal health, stranding, entanglement, and mortality data, including visualizations and metadata, through the national and regional data portals of the Observation System; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s1421f–2/c/2/D","parentIdentifier":"/us/usc/t16/s1421f–2/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fc%2F2%2FD","sourceRelease":"119-100","text":"in collaboration with, and with input from, States and stranding network participants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Procedures and guidelines","label":"d Procedures and guidelines","identifier":"/us/usc/t16/s1421f–2/d","parentIdentifier":"/us/usc/t16/s1421f–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s1421f–2/d/1","parentIdentifier":"/us/usc/t16/s1421f–2/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fd%2F1","sourceRelease":"119-100","text":"reporting marine mammal health data collected by stranding networks consistent with subsections (c) and (d) of ;section 1421a of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s1421f–2/d/2","parentIdentifier":"/us/usc/t16/s1421f–2/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fd%2F2","sourceRelease":"119-100","text":"promptly transmitting health data from the stranding networks and other appropriate data providers to the Health MAP;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s1421f–2/d/3","parentIdentifier":"/us/usc/t16/s1421f–2/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fd%2F3","sourceRelease":"119-100","text":"disseminating and making publicly available data on marine mammal health, stranding, entanglement, and mortality data in a timely and sustained manner; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s1421f–2/d/4","parentIdentifier":"/us/usc/t16/s1421f–2/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fd%2F4","sourceRelease":"119-100","text":"integrating additional marine mammal health, stranding, or other relevant data as the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Consultation","label":"e Consultation","identifier":"/us/usc/t16/s1421f–2/e","parentIdentifier":"/us/usc/t16/s1421f–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Fe","sourceRelease":"119-100","text":"The Administrator of the National Oceanic and Atmospheric Administration shall maintain and update the Health MAP in consultation with the Secretary of the Interior and the Marine Mammal Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Acceptance of donations","label":"f Acceptance of donations","identifier":"/us/usc/t16/s1421f–2/f","parentIdentifier":"/us/usc/t16/s1421f–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s1421f–2/f/1","parentIdentifier":"/us/usc/t16/s1421f–2/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Ff%2F1","sourceRelease":"119-100","text":"For the purposes of carrying out this section, the Secretary may solicit, accept, receive, hold, administer, and use gifts, devises, and bequests without any further approval or administrative action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Monetary donations","label":"2 Monetary donations","identifier":"/us/usc/t16/s1421f–2/f/2","parentIdentifier":"/us/usc/t16/s1421f–2/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%E2%80%932%2Ff%2F2","sourceRelease":"119-100","text":"A monetary gift, devise, or bequest accepted by the Secretary under paragraph (1) shall be credited as discretionary offsetting collections to the currently applicable appropriation, account, or fund of the Department of Commerce and shall be made available for such purposes only to the extent and in the amounts provided in advance in appropriations Acts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
