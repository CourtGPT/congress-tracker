{"type":"section","nativeType":"section","number":"2009aa–6","heading":"Development planning process","label":"2009aa–6 Development planning process","identifier":"/us/usc/t7/s2009aa–6","parentIdentifier":"/us/usc/t7/ch50/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%936","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"State development plan","label":"a State development plan","identifier":"/us/usc/t7/s2009aa–6/a","parentIdentifier":"/us/usc/t7/s2009aa–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%936%2Fa","sourceRelease":"119-100","text":"In accordance with policies established by the Authority, each State member shall submit a development plan for the area of the region represented by the State member.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Content of plan","label":"b Content of plan","identifier":"/us/usc/t7/s2009aa–6/b","parentIdentifier":"/us/usc/t7/s2009aa–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%936%2Fb","sourceRelease":"119-100","text":"A State development plan submitted under subsection (a) shall reflect the goals, objectives, and priorities identified in the regional development plan developed under .section 2009aa–1(d)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Consultation with interested local parties","label":"c Consultation with interested local parties","identifier":"/us/usc/t7/s2009aa–6/c","parentIdentifier":"/us/usc/t7/s2009aa–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%936%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2009aa–6/c/1","parentIdentifier":"/us/usc/t7/s2009aa–6/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%936%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2009aa–6/c/1/A","parentIdentifier":"/us/usc/t7/s2009aa–6/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%936%2Fc%2F1%2FA","sourceRelease":"119-100","text":"local development districts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2009aa–6/c/1/B","parentIdentifier":"/us/usc/t7/s2009aa–6/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%936%2Fc%2F1%2FB","sourceRelease":"119-100","text":"local units of government; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2009aa–6/c/2","parentIdentifier":"/us/usc/t7/s2009aa–6/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%936%2Fc%2F2","sourceRelease":"119-100","text":"take into consideration the goals, objectives, priorities, and recommendations of the entities described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Public participation","label":"d Public participation","identifier":"/us/usc/t7/s2009aa–6/d","parentIdentifier":"/us/usc/t7/s2009aa–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%936%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s2009aa–6/d/1","parentIdentifier":"/us/usc/t7/s2009aa–6/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%936%2Fd%2F1","sourceRelease":"119-100","text":"The Authority and applicable State and local development districts shall encourage and assist, to the maximum extent practicable, public participation in the development, revision, and implementation of all plans and programs under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Regulations","label":"2 Regulations","identifier":"/us/usc/t7/s2009aa–6/d/2","parentIdentifier":"/us/usc/t7/s2009aa–6/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%936%2Fd%2F2","sourceRelease":"119-100","text":"The Authority shall develop guidelines for providing public participation described in paragraph (1), including public hearings.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
