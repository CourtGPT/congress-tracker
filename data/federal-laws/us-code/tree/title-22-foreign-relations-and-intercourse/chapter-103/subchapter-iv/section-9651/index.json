{"type":"section","nativeType":"section","number":"9651","heading":"Establishment of risk and audit committees","label":"9651 Establishment of risk and audit committees","identifier":"/us/usc/t22/s9651","parentIdentifier":"/us/usc/t22/ch103/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s9651/a","parentIdentifier":"/us/usc/t22/s9651","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fa","sourceRelease":"119-100","text":"To assist the Board to fulfill its duties and responsibilities under , the Corporation shall establish a risk committee and an audit committee.section 9621(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties and responsibilities of risk committee","label":"b Duties and responsibilities of risk committee","identifier":"/us/usc/t22/s9651/b","parentIdentifier":"/us/usc/t22/s9651","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9651/b/1","parentIdentifier":"/us/usc/t22/s9651/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fb%2F1","sourceRelease":"119-100","text":"formulating risk management policies of the operations of the Corporation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9651/b/2","parentIdentifier":"/us/usc/t22/s9651/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fb%2F2","sourceRelease":"119-100","text":"reviewing and providing guidance on operation of the Corporation’s global risk management framework;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s9651/b/3","parentIdentifier":"/us/usc/t22/s9651/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fb%2F3","sourceRelease":"119-100","text":"developing policies for enterprise risk management, monitoring, and management of strategic, reputational, regulatory, operational, developmental, environmental, social, and financial risks;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s9651/b/4","parentIdentifier":"/us/usc/t22/s9651/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fb%2F4","sourceRelease":"119-100","text":"developing the risk profile of the Corporation, including a risk management and compliance framework and governance structure to support such framework; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s9651/b/5","parentIdentifier":"/us/usc/t22/s9651/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9651/b/5/A","parentIdentifier":"/us/usc/t22/s9651/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fb%2F5%2FA","sourceRelease":"119-100","text":"knowingly engaging in acts of corruption;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9651/b/5/B","parentIdentifier":"/us/usc/t22/s9651/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fb%2F5%2FB","sourceRelease":"119-100","text":"knowingly providing material or financial support for terrorism, drug trafficking, or human trafficking; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9651/b/5/C","parentIdentifier":"/us/usc/t22/s9651/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fb%2F5%2FC","sourceRelease":"119-100","text":"responsible for ordering or otherwise directing serious or gross violations of human rights.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duties and responsibilities of audit committee","label":"c Duties and responsibilities of audit committee","identifier":"/us/usc/t22/s9651/c","parentIdentifier":"/us/usc/t22/s9651","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9651/c/1","parentIdentifier":"/us/usc/t22/s9651/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fc%2F1","sourceRelease":"119-100","text":"the integrity of the Corporation’s financial reporting and systems of internal controls regarding finance and accounting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9651/c/2","parentIdentifier":"/us/usc/t22/s9651/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fc%2F2","sourceRelease":"119-100","text":"the integrity of the Corporation’s financial statements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s9651/c/3","parentIdentifier":"/us/usc/t22/s9651/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fc%2F3","sourceRelease":"119-100","text":"the performance of the Corporation’s internal audit function; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s9651/c/4","parentIdentifier":"/us/usc/t22/s9651/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9651%2Fc%2F4","sourceRelease":"119-100","text":"compliance with legal and regulatory requirements related to the finances of the Corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
