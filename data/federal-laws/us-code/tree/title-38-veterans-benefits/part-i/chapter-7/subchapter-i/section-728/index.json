{"type":"section","nativeType":"section","number":"728","heading":"Misuse of Department purchase cards","label":"728 Misuse of Department purchase cards","identifier":"/us/usc/t38/s728","parentIdentifier":"/us/usc/t38/ptI/ch7/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs728","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t38/s728/a","parentIdentifier":"/us/usc/t38/s728","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs728%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s728/a/1","parentIdentifier":"/us/usc/t38/s728/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs728%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary shall prohibit any employee of the Department who the Secretary or the Inspector General of the Department determines has knowingly misused a purchase card from serving as a purchase card holder or approving official.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s728/a/2","parentIdentifier":"/us/usc/t38/s728/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs728%2Fa%2F2","sourceRelease":"119-100","text":"Such a prohibition shall be in addition to any other applicable penalty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Misuse","label":"b .—Misuse","identifier":"/us/usc/t38/s728/b","parentIdentifier":"/us/usc/t38/s728","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs728%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s728/b/1","parentIdentifier":"/us/usc/t38/s728/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs728%2Fb%2F1","sourceRelease":"119-100","text":"splitting purchases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s728/b/2","parentIdentifier":"/us/usc/t38/s728/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs728%2Fb%2F2","sourceRelease":"119-100","text":"exceeding applicable purchase card limits or purchase thresholds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s728/b/3","parentIdentifier":"/us/usc/t38/s728/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs728%2Fb%2F3","sourceRelease":"119-100","text":"purchasing any unauthorized item;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s728/b/4","parentIdentifier":"/us/usc/t38/s728/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs728%2Fb%2F4","sourceRelease":"119-100","text":"using a purchase card without being an authorized purchase card holder; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t38/s728/b/5","parentIdentifier":"/us/usc/t38/s728/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs728%2Fb%2F5","sourceRelease":"119-100","text":"violating ethics standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
