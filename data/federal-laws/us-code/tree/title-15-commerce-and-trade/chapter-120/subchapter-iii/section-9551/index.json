{"type":"section","nativeType":"section","number":"9551","heading":"Definitions","label":"9551 Definitions","identifier":"/us/usc/t15/s9551","parentIdentifier":"/us/usc/t15/ch120/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9551","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Appropriate congressional committees","label":"1 Appropriate congressional committees","identifier":"/us/usc/t15/s9551/1","parentIdentifier":"/us/usc/t15/s9551","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9551%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9551/1/A","parentIdentifier":"/us/usc/t15/s9551/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9551%2F1%2FA","sourceRelease":"119-100","text":"the Committee on Commerce, Science, and Transportation of the Senate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9551/1/B","parentIdentifier":"/us/usc/t15/s9551/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9551%2F1%2FB","sourceRelease":"119-100","text":"the Committee on Financial Services of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible entity","label":"2 Eligible entity","identifier":"/us/usc/t15/s9551/2","parentIdentifier":"/us/usc/t15/s9551","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9551%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9551/2/A","parentIdentifier":"/us/usc/t15/s9551/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9551%2F2%2FA","sourceRelease":"119-100","text":"a minority-serving institution; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9551/2/B","parentIdentifier":"/us/usc/t15/s9551/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9551%2F2%2FB","sourceRelease":"119-100","text":"a consortium of institutions of higher education that is led by a minority-serving institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"MBDA Rural Business Center","label":"3 MBDA Rural Business Center","identifier":"/us/usc/t15/s9551/3","parentIdentifier":"/us/usc/t15/s9551","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9551%2F3","sourceRelease":"119-100","text":"The term “MBDA Rural Business Center” means an MBDA Business Center that provides technical business assistance to minority business enterprises located in rural areas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"MBDA Rural Business Center agreement","label":"4 MBDA Rural Business Center agreement","identifier":"/us/usc/t15/s9551/4","parentIdentifier":"/us/usc/t15/s9551","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9551%2F4","sourceRelease":"119-100","text":"The term “MBDA Rural Business Center agreement” means an MBDA Business Center agreement that establishes the terms by which the recipient of the Federal assistance award that is the subject of the agreement shall operate an MBDA Rural Business Center.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Minority-serving institution","label":"5 Minority-serving institution","identifier":"/us/usc/t15/s9551/5","parentIdentifier":"/us/usc/t15/s9551","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9551%2F5","sourceRelease":"119-100","text":"The term “minority-serving institution” means an institution described in any of paragraphs (1) through (7) of .section 1067q(a) of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Rural area","label":"6 Rural area","identifier":"/us/usc/t15/s9551/6","parentIdentifier":"/us/usc/t15/s9551","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9551%2F6","sourceRelease":"119-100","text":"The term “rural area” has the meaning given the term in .section 1991(a) of title 7","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Rural minority business enterprise","label":"7 Rural minority business enterprise","identifier":"/us/usc/t15/s9551/7","parentIdentifier":"/us/usc/t15/s9551","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9551%2F7","sourceRelease":"119-100","text":"The term “rural minority business enterprise” means a minority business enterprise located in a rural area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
