{"type":"section","nativeType":"section","number":"6804a","heading":"Availability of Federal, State, and local recreation passes","label":"6804a Availability of Federal, State, and local recreation passes","identifier":"/us/usc/t16/s6804a","parentIdentifier":"/us/usc/t16/ch87","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6804a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment of program","label":"a Establishment of program","identifier":"/us/usc/t16/s6804a/a","parentIdentifier":"/us/usc/t16/s6804a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6804a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s6804a/a/1","parentIdentifier":"/us/usc/t16/s6804a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6804a%2Fa%2F1","sourceRelease":"119-100","text":"To improve the availability of Federal, State, and local outdoor recreation passes, the Secretaries are encouraged to coordinate with States and counties regarding the availability of Federal, State, and local recreation passes to allow a purchaser to buy a Federal recreation pass, State recreation pass, and local recreation pass in a single transaction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Included passes","label":"2 Included passes","identifier":"/us/usc/t16/s6804a/a/2","parentIdentifier":"/us/usc/t16/s6804a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6804a%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6804a/a/2/A","parentIdentifier":"/us/usc/t16/s6804a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6804a%2Fa%2F2%2FA","sourceRelease":"119-100","text":"an America the Beautiful—the National Parks and Federal Recreational Lands Pass under ; andsection 6804 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6804a/a/2/B","parentIdentifier":"/us/usc/t16/s6804a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6804a%2Fa%2F2%2FB","sourceRelease":"119-100","text":"any pass covering any fees charged by participating States and counties for entrance and recreational use of parks and public land in the participating States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Agreements with States and counties","label":"b Agreements with States and counties","identifier":"/us/usc/t16/s6804a/b","parentIdentifier":"/us/usc/t16/s6804a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6804a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s6804a/b/1","parentIdentifier":"/us/usc/t16/s6804a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6804a%2Fb%2F1","sourceRelease":"119-100","text":"The Secretaries, after consultation with the States and counties, may enter into agreements with States and counties to coordinate the availability of passes as described in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Revenue from pass sales","label":"2 Revenue from pass sales","identifier":"/us/usc/t16/s6804a/b/2","parentIdentifier":"/us/usc/t16/s6804a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6804a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6804a/b/2/A","parentIdentifier":"/us/usc/t16/s6804a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6804a%2Fb%2F2%2FA","sourceRelease":"119-100","text":"funds from the sale of State or local passes are transferred to the appropriate State agency or county government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6804a/b/2/B","parentIdentifier":"/us/usc/t16/s6804a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6804a%2Fb%2F2%2FB","sourceRelease":"119-100","text":"funds from the sale of Federal passes are transferred to the appropriate Federal agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6804a/b/2/C","parentIdentifier":"/us/usc/t16/s6804a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6804a%2Fb%2F2%2FC","sourceRelease":"119-100","text":"fund transfers are completed by the end of a fiscal year for all pass sales occurring during the fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
