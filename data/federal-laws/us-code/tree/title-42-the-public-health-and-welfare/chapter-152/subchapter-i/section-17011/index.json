{"type":"section","nativeType":"section","number":"17011","heading":"Transportation electrification","label":"17011 Transportation electrification","identifier":"/us/usc/t42/s17011","parentIdentifier":"/us/usc/t42/ch152/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s17011/a","parentIdentifier":"/us/usc/t42/s17011","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Administrator","label":"1 Administrator","identifier":"/us/usc/t42/s17011/a/1","parentIdentifier":"/us/usc/t42/s17011/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F1","sourceRelease":"119-100","text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Battery","label":"2 Battery","identifier":"/us/usc/t42/s17011/a/2","parentIdentifier":"/us/usc/t42/s17011/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F2","sourceRelease":"119-100","text":"The term “battery” means an electrochemical energy storage system powered directly by electrical current.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Electric transportation technology","label":"3 Electric transportation technology","identifier":"/us/usc/t42/s17011/a/3","parentIdentifier":"/us/usc/t42/s17011/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17011/a/3/A","parentIdentifier":"/us/usc/t42/s17011/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F3%2FA","sourceRelease":"119-100","text":"technology used in vehicles that use an electric motor for all or part of the motive power of the vehicles, including battery electric, hybrid electric, plug-in hybrid electric, fuel cell, and plug-in fuel cell vehicles, or rail transportation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17011/a/3/B","parentIdentifier":"/us/usc/t42/s17011/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17011/a/3/B/i","parentIdentifier":"/us/usc/t42/s17011/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F3%2FB%2Fi","sourceRelease":"119-100","text":"corded electric equipment linked to transportation or mobile sources of air pollution; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17011/a/3/B/ii","parentIdentifier":"/us/usc/t42/s17011/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F3%2FB%2Fii","sourceRelease":"119-100","text":"electrification technologies at airports, ports, truck stops, and material-handling facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Nonroad vehicle","label":"4 Nonroad vehicle","identifier":"/us/usc/t42/s17011/a/4","parentIdentifier":"/us/usc/t42/s17011/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17011/a/4/A","parentIdentifier":"/us/usc/t42/s17011/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17011/a/4/A/i","parentIdentifier":"/us/usc/t42/s17011/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F4%2FA%2Fi","sourceRelease":"119-100","text":"by a nonroad engine, as that term is defined in ; orsection 7550 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17011/a/4/A/ii","parentIdentifier":"/us/usc/t42/s17011/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F4%2FA%2Fii","sourceRelease":"119-100","text":"fully or partially by an electric motor powered by a fuel cell, a battery, or an off-board source of electricity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17011/a/4/B","parentIdentifier":"/us/usc/t42/s17011/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F4%2FB","sourceRelease":"119-100","text":"that is not a motor vehicle or a vehicle used solely for competition.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Plug-in electric drive vehicle","label":"5 Plug-in electric drive vehicle","identifier":"/us/usc/t42/s17011/a/5","parentIdentifier":"/us/usc/t42/s17011/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17011/a/5/A","parentIdentifier":"/us/usc/t42/s17011/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F5%2FA","sourceRelease":"119-100","text":"draws motive power from a battery with a capacity of at least 4 kilowatt-hours;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17011/a/5/B","parentIdentifier":"/us/usc/t42/s17011/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F5%2FB","sourceRelease":"119-100","text":"can be recharged from an external source of electricity for motive power; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17011/a/5/C","parentIdentifier":"/us/usc/t42/s17011/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F5%2FC","sourceRelease":"119-100","text":"is a light-, medium-, or heavy-duty motor vehicle or nonroad vehicle (as those terms are defined in ).section 7550 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Qualified electric transportation project","label":"6 Qualified electric transportation project","identifier":"/us/usc/t42/s17011/a/6","parentIdentifier":"/us/usc/t42/s17011/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17011/a/6/A","parentIdentifier":"/us/usc/t42/s17011/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F6%2FA","sourceRelease":"119-100","text":"shipside or shoreside electrification for vessels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17011/a/6/B","parentIdentifier":"/us/usc/t42/s17011/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F6%2FB","sourceRelease":"119-100","text":"truck-stop electrification;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17011/a/6/C","parentIdentifier":"/us/usc/t42/s17011/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F6%2FC","sourceRelease":"119-100","text":"electric truck refrigeration units;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17011/a/6/D","parentIdentifier":"/us/usc/t42/s17011/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F6%2FD","sourceRelease":"119-100","text":"battery-powered auxiliary power units for trucks;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17011/a/6/E","parentIdentifier":"/us/usc/t42/s17011/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F6%2FE","sourceRelease":"119-100","text":"electric airport ground support equipment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17011/a/6/F","parentIdentifier":"/us/usc/t42/s17011/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F6%2FF","sourceRelease":"119-100","text":"electric material and cargo handling equipment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s17011/a/6/G","parentIdentifier":"/us/usc/t42/s17011/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F6%2FG","sourceRelease":"119-100","text":"electric or dual-mode electric rail;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t42/s17011/a/6/H","parentIdentifier":"/us/usc/t42/s17011/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F6%2FH","sourceRelease":"119-100","text":"any distribution upgrades needed to supply electricity to the project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s17011/a/6/I","parentIdentifier":"/us/usc/t42/s17011/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fa%2F6%2FI","sourceRelease":"119-100","text":"any ancillary infrastructure, including panel upgrades, battery chargers, in-situ transformers, and trenching.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Plug-in electric drive vehicle program","label":"b Plug-in electric drive vehicle program","identifier":"/us/usc/t42/s17011/b","parentIdentifier":"/us/usc/t42/s17011","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t42/s17011/b/1","parentIdentifier":"/us/usc/t42/s17011/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall establish a competitive program to provide grants on a cost-shared basis to State governments, local governments, metropolitan transportation authorities, air pollution control districts, private or nonprofit entities, or combinations of those governments, authorities, districts, and entities, to carry out one or more projects to encourage the use of plug-in electric drive vehicles or other emerging electric vehicle technologies, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Administration","label":"2 Administration","identifier":"/us/usc/t42/s17011/b/2","parentIdentifier":"/us/usc/t42/s17011/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary shall, in consultation with the Secretary of Transportation and the Administrator, establish requirements for applications for grants under this section, including reporting of data to be summarized for dissemination to grantees and the public, including safety, vehicle, and component performance, and vehicle and component life cycle costs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Priority","label":"3 Priority","identifier":"/us/usc/t42/s17011/b/3","parentIdentifier":"/us/usc/t42/s17011/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17011/b/3/A","parentIdentifier":"/us/usc/t42/s17011/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fb%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17011/b/3/A/i","parentIdentifier":"/us/usc/t42/s17011/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fb%2F3%2FA%2Fi","sourceRelease":"119-100","text":"encourage early widespread use of vehicles described in paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17011/b/3/A/ii","parentIdentifier":"/us/usc/t42/s17011/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fb%2F3%2FA%2Fii","sourceRelease":"119-100","text":"are likely to make a significant contribution to the advancement of the production of the vehicles in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17011/b/3/B","parentIdentifier":"/us/usc/t42/s17011/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fb%2F3%2FB","sourceRelease":"119-100","text":"ensure, to the maximum extent practicable, that the program established under this subsection includes a variety of applications, manufacturers, and end-uses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Reporting","label":"4 Reporting","identifier":"/us/usc/t42/s17011/b/4","parentIdentifier":"/us/usc/t42/s17011/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fb%2F4","sourceRelease":"119-100","text":"The Secretary shall require a grant recipient under this subsection to submit to the Secretary, on an annual basis, data relating to safety, vehicle performance, life cycle costs, and emissions of vehicles demonstrated under the grant, including emissions of greenhouse gases.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Cost sharing","label":"5 Cost sharing","identifier":"/us/usc/t42/s17011/b/5","parentIdentifier":"/us/usc/t42/s17011/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fb%2F5","sourceRelease":"119-100","text":"shall apply to a grant made under this subsection.Section 16352 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Authorization of appropriations","label":"6 Authorization of appropriations","identifier":"/us/usc/t42/s17011/b/6","parentIdentifier":"/us/usc/t42/s17011/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fb%2F6","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this subsection $90,000,000 for each of fiscal years 2008 through 2012, of which not less than ⅓ of the total amount appropriated shall be available each fiscal year to make grants to local and municipal governments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Near-term transportation sector electrification program","label":"c Near-term transportation sector electrification program","identifier":"/us/usc/t42/s17011/c","parentIdentifier":"/us/usc/t42/s17011","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17011/c/1","parentIdentifier":"/us/usc/t42/s17011/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fc%2F1","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary, in consultation with the Secretary of Transportation and the Administrator, shall establish a program to provide grants for the conduct of qualified electric transportation projects.December 19, 2007","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Priority","label":"2 Priority","identifier":"/us/usc/t42/s17011/c/2","parentIdentifier":"/us/usc/t42/s17011/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fc%2F2","sourceRelease":"119-100","text":"In providing grants under this subsection, the Secretary shall give priority to large-scale projects and large-scale aggregators of projects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Cost sharing","label":"3 Cost sharing","identifier":"/us/usc/t42/s17011/c/3","parentIdentifier":"/us/usc/t42/s17011/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fc%2F3","sourceRelease":"119-100","text":"shall apply to a grant made under this subsection.Section 16352 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Authorization of appropriations","label":"4 Authorization of appropriations","identifier":"/us/usc/t42/s17011/c/4","parentIdentifier":"/us/usc/t42/s17011/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fc%2F4","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this subsection $95,000,000 for each of fiscal years 2008 through 2013.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Education program","label":"d Education program","identifier":"/us/usc/t42/s17011/d","parentIdentifier":"/us/usc/t42/s17011","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17011/d/1","parentIdentifier":"/us/usc/t42/s17011/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17011/d/1/A","parentIdentifier":"/us/usc/t42/s17011/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fd%2F1%2FA","sourceRelease":"119-100","text":"teaching materials to secondary schools and high schools; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17011/d/1/B","parentIdentifier":"/us/usc/t42/s17011/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fd%2F1%2FB","sourceRelease":"119-100","text":"assistance for programs relating to electric drive system and component engineering to institutions of higher education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Electric vehicle competition","label":"2 Electric vehicle competition","identifier":"/us/usc/t42/s17011/d/2","parentIdentifier":"/us/usc/t42/s17011/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fd%2F2","sourceRelease":"119-100","text":"The program established under paragraph (1) shall include a plug-in hybrid electric vehicle competition for institutions of higher education, which shall be known as the “Dr. Andrew Frank Plug-In Electric Vehicle Competition”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Engineers","label":"3 Engineers","identifier":"/us/usc/t42/s17011/d/3","parentIdentifier":"/us/usc/t42/s17011/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17011/d/3/A","parentIdentifier":"/us/usc/t42/s17011/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17011%2Fd%2F3%2FA","sourceRelease":"119-100","text":"plug-in electric drive vehicles; and","notes":[],"amendments":[],"effectiveDate":null,"childr