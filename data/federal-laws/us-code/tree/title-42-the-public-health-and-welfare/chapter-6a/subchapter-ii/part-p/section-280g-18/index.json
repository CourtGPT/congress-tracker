{"type":"section","nativeType":"section","number":"280g–18","heading":"Maternal mental health hotline","label":"280g–18 Maternal mental health hotline","identifier":"/us/usc/t42/s280g–18","parentIdentifier":"/us/usc/t42/ch6A/schII/ptP","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s280g–18/a","parentIdentifier":"/us/usc/t42/s280g–18","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fa","sourceRelease":"119-100","text":"The Secretary shall maintain, by grant or contract, a national maternal mental health hotline to provide emotional support, information, brief intervention, and mental health and substance use disorder resources to pregnant and postpartum women at risk of, or affected by, maternal mental health and substance use disorders, and to their families or household members.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirements for hotline","label":"b Requirements for hotline","identifier":"/us/usc/t42/s280g–18/b","parentIdentifier":"/us/usc/t42/s280g–18","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s280g–18/b/1","parentIdentifier":"/us/usc/t42/s280g–18/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fb%2F1","sourceRelease":"119-100","text":"be a 24/7 real-time hotline;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s280g–18/b/2","parentIdentifier":"/us/usc/t42/s280g–18/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fb%2F2","sourceRelease":"119-100","text":"provide voice and text support;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s280g–18/b/3","parentIdentifier":"/us/usc/t42/s280g–18/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s280g–18/b/3/A","parentIdentifier":"/us/usc/t42/s280g–18/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fb%2F3%2FA","sourceRelease":"119-100","text":"maternal mental health and substance use disorder prevention, identification, and intervention; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s280g–18/b/3/B","parentIdentifier":"/us/usc/t42/s280g–18/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fb%2F3%2FB","sourceRelease":"119-100","text":"providing culturally and linguistically appropriate support; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s280g–18/b/4","parentIdentifier":"/us/usc/t42/s280g–18/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fb%2F4","sourceRelease":"119-100","text":"provide maternal mental health and substance use disorder assistance and referral services to meet the needs of underserved populations, individuals with disabilities, and family and household members of pregnant or postpartum women at risk of experiencing maternal mental health and substance use disorders.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Additional requirements","label":"c Additional requirements","identifier":"/us/usc/t42/s280g–18/c","parentIdentifier":"/us/usc/t42/s280g–18","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s280g–18/c/1","parentIdentifier":"/us/usc/t42/s280g–18/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fc%2F1","sourceRelease":"119-100","text":"consult with the Domestic Violence Hotline, National Suicide Prevention Lifeline, and Veterans Crisis Line to ensure that pregnant and postpartum women are connected in real-time to the appropriate specialized hotline service, when applicable;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s280g–18/c/2","parentIdentifier":"/us/usc/t42/s280g–18/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fc%2F2","sourceRelease":"119-100","text":"conduct a public awareness campaign for the hotline;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s280g–18/c/3","parentIdentifier":"/us/usc/t42/s280g–18/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fc%2F3","sourceRelease":"119-100","text":"consult with Federal departments and agencies, including the Substance Abuse and Mental Health Services Administration and the Department of Veterans Affairs, to increase awareness regarding the hotline; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s280g–18/c/4","parentIdentifier":"/us/usc/t42/s280g–18/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fc%2F4","sourceRelease":"119-100","text":"consult with appropriate State, local, and Tribal public health officials, including officials who administer programs that serve low-income pregnant and postpartum individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Annual report","label":"d Annual report","identifier":"/us/usc/t42/s280g–18/d","parentIdentifier":"/us/usc/t42/s280g–18","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s280g–18/d/1","parentIdentifier":"/us/usc/t42/s280g–18/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fd%2F1","sourceRelease":"119-100","text":"an evaluation of the effectiveness of activities conducted or supported under subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s280g–18/d/2","parentIdentifier":"/us/usc/t42/s280g–18/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fd%2F2","sourceRelease":"119-100","text":"a directory of entities or organizations to which staff maintaining the hotline funded under this section may make referrals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s280g–18/d/3","parentIdentifier":"/us/usc/t42/s280g–18/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fd%2F3","sourceRelease":"119-100","text":"such additional information as the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s280g–18/e","parentIdentifier":"/us/usc/t42/s280g–18","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280g%E2%80%9318%2Fe","sourceRelease":"119-100","text":"To carry out this section, there are authorized to be appropriated $10,000,000 for each of fiscal years 2023 through 2027.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
