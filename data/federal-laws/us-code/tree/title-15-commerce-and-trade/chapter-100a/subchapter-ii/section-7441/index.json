{"type":"section","nativeType":"section","number":"7441","heading":"Cybersecurity competitions and challenges","label":"7441 Cybersecurity competitions and challenges","identifier":"/us/usc/t15/s7441","parentIdentifier":"/us/usc/t15/ch100A/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7441","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in Text(as amended by section 105 of the America COMPETES Reauthorization Act of 2010 ()), referred to in subsec. (a)(1), probably means as enacted by .Section 3719 of this title124 Stat. 3989section 3719 of this titlesection 105(a) of Pub. L. 111–358"],"amendments":["References in Text(as amended by section 105 of the America COMPETES Reauthorization Act of 2010 ()), referred to in subsec. (a)(1), probably means as enacted by .Section 3719 of this title124 Stat. 3989section 3719 of this titlesection 105(a) of Pub. L. 111–358"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s7441/a","parentIdentifier":"/us/usc/t15/s7441","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7441%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7441/a/1","parentIdentifier":"/us/usc/t15/s7441/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7441%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7441/a/1/A","parentIdentifier":"/us/usc/t15/s7441/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7441%2Fa%2F1%2FA","sourceRelease":"119-100","text":"to identify, develop, and recruit talented individuals to perform duties relating to the security of information technology in Federal, State, local, and tribal government agencies, and the private sector; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7441/a/1/B","parentIdentifier":"/us/usc/t15/s7441/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7441%2Fa%2F1%2FB","sourceRelease":"119-100","text":"to stimulate innovation in basic and applied cybersecurity research, technology development, and prototype demonstration that has the potential for application to the information technology activities of the Federal Government; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7441/a/2","parentIdentifier":"/us/usc/t15/s7441/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7441%2Fa%2F2","sourceRelease":"119-100","text":"ensure the effective operation of the competitions and challenges under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Participation","label":"b Participation","identifier":"/us/usc/t15/s7441/b","parentIdentifier":"/us/usc/t15/s7441","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7441%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7441/b/1","parentIdentifier":"/us/usc/t15/s7441/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7441%2Fb%2F1","sourceRelease":"119-100","text":"students enrolled in grades 9 through 12;","notes":[],"amen