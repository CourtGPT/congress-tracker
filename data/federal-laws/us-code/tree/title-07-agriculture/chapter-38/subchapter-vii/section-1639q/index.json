{"type":"section","nativeType":"section","number":"1639q","heading":"Department of Agriculture","label":"1639q Department of Agriculture","identifier":"/us/usc/t7/s1639q","parentIdentifier":"/us/usc/t7/ch38/schVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Department of Agriculture plan","label":"a Department of Agriculture plan","identifier":"/us/usc/t7/s1639q/a","parentIdentifier":"/us/usc/t7/s1639q","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1639q/a/1","parentIdentifier":"/us/usc/t7/s1639q/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fa%2F1","sourceRelease":"119-100","text":"In the case of a State or Indian tribe for which a State or Tribal plan is not approved under , the production of hemp in that State or the territory of that Indian tribe shall be subject to a plan established by the Secretary to monitor and regulate that production in accordance with paragraph (2).section 1639p of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Content","label":"2 Content","identifier":"/us/usc/t7/s1639q/a/2","parentIdentifier":"/us/usc/t7/s1639q/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1639q/a/2/A","parentIdentifier":"/us/usc/t7/s1639q/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fa%2F2%2FA","sourceRelease":"119-100","text":"a practice to maintain relevant information regarding land on which hemp is produced in the State or territory of the Indian tribe, including a legal description of the land, for a period of not less than 3 calendar years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1639q/a/2/B","parentIdentifier":"/us/usc/t7/s1639q/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fa%2F2%2FB","sourceRelease":"119-100","text":"a procedure for testing, using post-decarboxylation or other similarly reliable methods, delta-9 tetrahydrocannabinol concentration levels of hemp produced in the State or territory of the Indian tribe;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s1639q/a/2/C","parentIdentifier":"/us/usc/t7/s1639q/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fa%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1639q/a/2/C/i","parentIdentifier":"/us/usc/t7/s1639q/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fa%2F2%2FC%2Fi","sourceRelease":"119-100","text":"plants, whether growing or not, that are produced in violation of this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1639q/a/2/C/ii","parentIdentifier":"/us/usc/t7/s1639q/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fa%2F2%2FC%2Fii","sourceRelease":"119-100","text":"products derived from those plants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s1639q/a/2/D","parentIdentifier":"/us/usc/t7/s1639q/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fa%2F2%2FD","sourceRelease":"119-100","text":"a procedure to comply with the enforcement procedures under subsection (c)(2);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s1639q/a/2/E","parentIdentifier":"/us/usc/t7/s1639q/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fa%2F2%2FE","sourceRelease":"119-100","text":"a procedure for conducting annual inspections of, at a minimum, a random sample of hemp producers to verify that hemp is not produced in violation of this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t7/s1639q/a/2/F","parentIdentifier":"/us/usc/t7/s1639q/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fa%2F2%2FF","sourceRelease":"119-100","text":"such other practices or procedures as the Secretary considers to be appropriate, to the extent that the practice or procedure is consistent with this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Licensing","label":"b Licensing","identifier":"/us/usc/t7/s1639q/b","parentIdentifier":"/us/usc/t7/s1639q","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fb","sourceRelease":"119-100","text":"The Secretary shall establish a procedure to issue licenses to hemp producers in accordance with a plan established under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Violations","label":"c Violations","identifier":"/us/usc/t7/s1639q/c","parentIdentifier":"/us/usc/t7/s1639q","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1639q/c/1","parentIdentifier":"/us/usc/t7/s1639q/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fc%2F1","sourceRelease":"119-100","text":"In the case of a State or Indian tribe for which a State or Tribal plan is not approved under , it shall be unlawful to produce hemp in that State or the territory of that Indian tribe without a license issued by the Secretary under subsection (b).section 1639p of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Negligent and other violations","label":"2 Negligent and other violations","identifier":"/us/usc/t7/s1639q/c/2","parentIdentifier":"/us/usc/t7/s1639q/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fc%2F2","sourceRelease":"119-100","text":"A violation of a plan established under subsection (a) shall be subject to enforcement in accordance with paragraphs (2) and (3) of , except that the Secretary shall carry out that enforcement instead of a State department of agriculture or Tribal government.section 1639p(e) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Reporting to Attorney General","label":"3 Reporting to Attorney General","identifier":"/us/usc/t7/s1639q/c/3","parentIdentifier":"/us/usc/t7/s1639q/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fc%2F3","sourceRelease":"119-100","text":"In the case of a State or Indian tribe covered by paragraph (1), the Secretary shall report the production of hemp without a license issued by the Secretary under subsection (b) to the Attorney General.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Information sharing for law enforcement","label":"d Information sharing for law enforcement","identifier":"/us/usc/t7/s1639q/d","parentIdentifier":"/us/usc/t7/s1639q","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1639q/d/1","parentIdentifier":"/us/usc/t7/s1639q/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1639q/d/1/A","parentIdentifier":"/us/usc/t7/s1639q/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd%2F1%2FA","sourceRelease":"119-100","text":"collect the information described in paragraph (2); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1639q/d/1/B","parentIdentifier":"/us/usc/t7/s1639q/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd%2F1%2FB","sourceRelease":"119-100","text":"make the information collected under subparagraph (A) accessible in real time to Federal, State, territorial, and local law enforcement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Content","label":"2 Content","identifier":"/us/usc/t7/s1639q/d/2","parentIdentifier":"/us/usc/t7/s1639q/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1639q/d/2/A","parentIdentifier":"/us/usc/t7/s1639q/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1639q/d/2/A/i","parentIdentifier":"/us/usc/t7/s1639q/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":"a State or Tribal plan is approved under ; orsection 1639p(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1639q/d/2/A/ii","parentIdentifier":"/us/usc/t7/s1639q/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":"a plan is established by the Secretary under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1639q/d/2/B","parentIdentifier":"/us/usc/t7/s1639q/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd%2F2%2FB","sourceRelease":"119-100","text":"a legal description of the land on which hemp is grown by each hemp producer described in subparagraph (A); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s1639q/d/2/C","parentIdentifier":"/us/usc/t7/s1639q/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1639q/d/2/C/i","parentIdentifier":"/us/usc/t7/s1639q/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd%2F2%2FC%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s1639q/d/2/C/i/I","parentIdentifier":"/us/usc/t7/s1639q/d/2/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd%2F2%2FC%2Fi%2FI","sourceRelease":"119-100","text":"a license or other required authorization from the State department of agriculture or Tribal government, as applicable; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s1639q/d/2/C/i/II","parentIdentifier":"/us/usc/t7/s1639q/d/2/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd%2F2%2FC%2Fi%2FII","sourceRelease":"119-100","text":"a license from the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1639q/d/2/C/ii","parentIdentifier":"/us/usc/t7/s1639q/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639q%2Fd%2F2%2FC%2Fii","sourceRelease":"119-100","text":"any changes to the status.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
