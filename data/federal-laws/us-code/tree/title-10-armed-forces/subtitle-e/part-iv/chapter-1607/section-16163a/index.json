{"type":"section","nativeType":"section","number":"16163a","heading":"Authority to transfer unused education benefits to family members","label":"16163a Authority to transfer unused education benefits to family members","identifier":"/us/usc/t10/s16163a","parentIdentifier":"/us/usc/t10/stE/ptIV/ch1607","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2011—Subsec. (b)(2). substituted “subsection (j)” for “section (j)”.Pub. L. 111–383"],"amendments":["Amendments2011—Subsec. (b)(2). substituted “subsection (j)” for “section (j)”.Pub. L. 111–383"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t10/s16163a/a","parentIdentifier":"/us/usc/t10/s16163a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fa","sourceRelease":"119-100","text":"Subject to the provisions of this section, the Secretary concerned may permit, at such Secretary’s sole discretion, a member described in subsection (b) who is entitled to basic educational assistance under this chapter to elect to transfer to one or more of the dependents specified in subsection (c) a portion of such member’s entitlement to such assistance, subject to the limitation under subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Eligible Members","label":"b .—Eligible Members","identifier":"/us/usc/t10/s16163a/b","parentIdentifier":"/us/usc/t10/s16163a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s16163a/b/1","parentIdentifier":"/us/usc/t10/s16163a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fb%2F1","sourceRelease":"119-100","text":"six years of service in the armed forces and enters into an agreement to serve at least four more years as a member of the armed forces; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s16163a/b/2","parentIdentifier":"/us/usc/t10/s16163a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fb%2F2","sourceRelease":"119-100","text":"the years of service as determined in regulations pursuant to subsection (j).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Eligible Dependents","label":"c .—Eligible Dependents","identifier":"/us/usc/t10/s16163a/c","parentIdentifier":"/us/usc/t10/s16163a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s16163a/c/1","parentIdentifier":"/us/usc/t10/s16163a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fc%2F1","sourceRelease":"119-100","text":"To the member’s spouse.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s16163a/c/2","parentIdentifier":"/us/usc/t10/s16163a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fc%2F2","sourceRelease":"119-100","text":"To one or more of the member’s children.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s16163a/c/3","parentIdentifier":"/us/usc/t10/s16163a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fc%2F3","sourceRelease":"119-100","text":"To a combination of the individuals referred to in paragraphs (1) and (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Limitation on Months of Transfer","label":"d .—Limitation on Months of Transfer","identifier":"/us/usc/t10/s16163a/d","parentIdentifier":"/us/usc/t10/s16163a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fd","sourceRelease":"119-100","text":"The total number of months of entitlement transferred by a member under this section may not exceed 36 months. The Secretary of Defense may prescribe regulations that would limit the months of entitlement that may be transferred under this section to no less than 18 months.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Designation of Transferee","label":"e .—Designation of Transferee","identifier":"/us/usc/t10/s16163a/e","parentIdentifier":"/us/usc/t10/s16163a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s16163a/e/1","parentIdentifier":"/us/usc/t10/s16163a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fe%2F1","sourceRelease":"119-100","text":"designate the dependent or dependents to whom such entitlement is being transferred;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s16163a/e/2","parentIdentifier":"/us/usc/t10/s16163a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fe%2F2","sourceRelease":"119-100","text":"designate the number of months of such entitlement to be transferred to each such dependent; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s16163a/e/3","parentIdentifier":"/us/usc/t10/s16163a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fe%2F3","sourceRelease":"119-100","text":"specify the period for which the transfer shall be effective for each dependent designated under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Time for Transfer; Revocation and Modification","label":"f .—Time for Transfer; Revocation and Modification","identifier":"/us/usc/t10/s16163a/f","parentIdentifier":"/us/usc/t10/s16163a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s16163a/f/1","parentIdentifier":"/us/usc/t10/s16163a/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Ff%2F1","sourceRelease":"119-100","text":"Subject to the time limitation for use of entitlement under section 16164, a member approved to transfer entitlement to basic educational assistance under this section may transfer such entitlement only while serving as a member of the armed forces when the transfer is executed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s16163a/f/2","parentIdentifier":"/us/usc/t10/s16163a/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Ff%2F2","sourceRelease":"119-100","text":"A member transferring entitlement under this section may modify or revoke at any time the transfer of any unused portion of the entitlement so transferred. The modification or revocation of the transfer of entitlement under this paragraph shall be made by the submittal of written notice of the action to both the Secretary concerned and the Secretary of Veterans Affairs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s16163a/f/3","parentIdentifier":"/us/usc/t10/s16163a/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Ff%2F3","sourceRelease":"119-100","text":"Entitlement transferred under this section may not be treated as marital property, or the asset of a marital estate, subject to division in a divorce or other civil proceeding.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":".—Commencement of Use","label":"g .—Commencement of Use","identifier":"/us/usc/t10/s16163a/g","parentIdentifier":"/us/usc/t10/s16163a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s16163a/g/1","parentIdentifier":"/us/usc/t10/s16163a/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fg%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s16163a/g/1/A","parentIdentifier":"/us/usc/t10/s16163a/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fg%2F1%2FA","sourceRelease":"119-100","text":"six years of service in the armed forces; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s16163a/g/1/B","parentIdentifier":"/us/usc/t10/s16163a/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fg%2F1%2FB","sourceRelease":"119-100","text":"the years of service as determined in regulations pursuant to subsection (j); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s16163a/g/2","parentIdentifier":"/us/usc/t10/s16163a/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fg%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s16163a/g/2/A","parentIdentifier":"/us/usc/t10/s16163a/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fg%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s16163a/g/2/A/i","parentIdentifier":"/us/usc/t10/s16163a/g/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fg%2F2%2FA%2Fi","sourceRelease":"119-100","text":"ten years of service in the armed forces; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s16163a/g/2/A/ii","parentIdentifier":"/us/usc/t10/s16163a/g/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fg%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the years of service as determined in regulations pursuant to subsection (j); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s16163a/g/2/B","parentIdentifier":"/us/usc/t10/s16163a/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fg%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s16163a/g/2/B/i","parentIdentifier":"/us/usc/t10/s16163a/g/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fg%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the completion by the child of the requirements of a secondary school diploma (or equivalency certificate); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s16163a/g/2/B/ii","parentIdentifier":"/us/usc/t10/s16163a/g/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fg%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the attainment by the child of 18 years of age.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":".—Additional Administrative Matters","label":"h .—Additional Administrative Matters","identifier":"/us/usc/t10/s16163a/h","parentIdentifier":"/us/usc/t10/s16163a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s16163a/h/1","parentIdentifier":"/us/usc/t10/s16163a/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fh%2F1","sourceRelease":"119-100","text":"The use of any entitlement to basic educational assistance transferred under this section shall be charged against the entitlement of the member making the transfer at the rate of one month for each month of transferred entitlement that is used.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s16163a/h/2","parentIdentifier":"/us/usc/t10/s16163a/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fh%2F2","sourceRelease":"119-100","text":"Except as provided under subsection (e)(2) and subject to paragraphs (5) and (6), a dependent to whom entitlement is transferred under this section is entitled to basic educational assistance under this chapter in the same manner as the member from whom the entitlement was transferred.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s16163a/h/3","parentIdentifier":"/us/usc/t10/s16163a/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fh%2F3","sourceRelease":"119-100","text":"The monthly rate of educational assistance payable to a dependent to whom entitlement is transferred under this section shall be the monthly amount payable under sections 16162 and 16162a to the member making the transfer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s16163a/h/4","parentIdentifier":"/us/usc/t10/s16163a/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fh%2F4","sourceRelease":"119-100","text":"The death of a member transferring an entitlement under this section shall not affect the use of the entitlement by the dependent to whom the entitlement is transferred.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s16163a/h/5","parentIdentifier":"/us/usc/t10/s16163a/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fh%2F5","sourceRelease":"119-100","text":"Notwithstanding section 16164(a)(2), a child to whom entitlement is transferred under this section may use the benefit without regard to the 10-year delimiting date, but may not use any entitlement so transferred after attaining the age of 26 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t10/s16163a/h/6","parentIdentifier":"/us/usc/t10/s16163a/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fh%2F6","sourceRelease":"119-100","text":"The administrative provisions of this chapter shall apply to the use of entitlement transferred under this section, except that the dependent to whom the entitlement is transferred shall be treated as the eligible member for purposes of such provisions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t10/s16163a/h/7","parentIdentifier":"/us/usc/t10/s16163a/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fh%2F7","sourceRelease":"119-100","text":"The purposes for which a dependent to whom entitlement is transferred under this section may use such entitlement shall include the pursuit and completion of the requirements of a secondary school diploma (or equivalency certificate).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Overpayment.—","label":"i Overpayment.—","identifier":"/us/usc/t10/s16163a/i","parentIdentifier":"/us/usc/t10/s16163a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Joint and several liability","label":"1 .—Joint and several liability","identifier":"/us/usc/t10/s16163a/i/1","parentIdentifier":"/us/usc/t10/s16163a/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fi%2F1","sourceRelease":"119-100","text":"In the event of an overpayment of basic educational assistance with respect to a dependent to whom entitlement is transferred under this section, the dependent and the member making the transfer shall be jointly and severally liable to the United States for the amount of the overpayment for purposes of .section 3685 of title 38","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Failure to complete service agreement","label":"2 .—Failure to complete service agreement","identifier":"/us/usc/t10/s16163a/i/2","parentIdentifier":"/us/usc/t10/s16163a/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fi%2F2","sourceRelease":"119-100","text":"Except as provided in paragraph (3), if an individual transferring entitlement under this section fails to complete the service agreed to by the individual under subsection (b)(1) in accordance with the terms of the agreement of the individual under that subsection, the amount of any transferred entitlement under this section that is used by a dependent of the individual as of the date of such failure shall be treated as an overpayment of educational assistance under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s16163a/i/3","parentIdentifier":"/us/usc/t10/s16163a/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fi%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s16163a/i/3/A","parentIdentifier":"/us/usc/t10/s16163a/i/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fi%2F3%2FA","sourceRelease":"119-100","text":"by reason of the death of the individual; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s16163a/i/3/B","parentIdentifier":"/us/usc/t10/s16163a/i/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fi%2F3%2FB","sourceRelease":"119-100","text":"for a reason referred to in section 16133(b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"j","heading":".—Regulations","label":"j .—Regulations","identifier":"/us/usc/t10/s16163a/j","parentIdentifier":"/us/usc/t10/s16163a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fj","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s16163a/j/1","parentIdentifier":"/us/usc/t10/s16163a/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fj%2F1","sourceRelease":"119-100","text":"The Secretary of Defense, in coordination with the Secretary of Veterans Affairs, shall prescribe regulations for purposes of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s16163a/j/2","parentIdentifier":"/us/usc/t10/s16163a/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fj%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s16163a/j/2/A","parentIdentifier":"/us/usc/t10/s16163a/j/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fj%2F2%2FA","sourceRelease":"119-100","text":"the manner of authorizing the transfer of entitlements under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s16163a/j/2/B","parentIdentifier":"/us/usc/t10/s16163a/j/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fj%2F2%2FB","sourceRelease":"119-100","text":"the eligibility criteria in accordance with subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s16163a/j/2/C","parentIdentifier":"/us/usc/t10/s16163a/j/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fj%2F2%2FC","sourceRelease":"119-100","text":"the manner and effect of an election to modify or revoke a transfer of entitlement under subsection (f)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"k","heading":".—Secretary Concerned Defined","label":"k .—Secretary Concerned Defined","identifier":"/us/usc/t10/s16163a/k","parentIdentifier":"/us/usc/t10/s16163a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs16163a%2Fk","sourceRelease":"119-100","text":"For purposes of this section, the term “Secretary concerned” has the meaning given in section 101(a)(9) in the case of a member of the armed forces.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
