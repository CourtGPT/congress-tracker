{"type":"section","nativeType":"section","number":"8792","heading":"Imposition of sanctions with respect to the transfer of goods or technologies to Syria that are likely to be used to commit human rights abuses","label":"8792 Imposition of sanctions with respect to the transfer of goods or technologies to Syria that are likely to be used to commit human rights abuses","identifier":"/us/usc/t22/s8792","parentIdentifier":"/us/usc/t22/ch94/schVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792","sourceRelease":"119-100","text":null,"notes":["Termination of SectionFor termination of section, see .section 8795 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s8792/a","parentIdentifier":"/us/usc/t22/s8792","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s8792/a/1","parentIdentifier":"/us/usc/t22/s8792/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fa%2F1","sourceRelease":"119-100","text":"each person on the list required by subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s8792/a/2","parentIdentifier":"/us/usc/t22/s8792/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s8792/a/2/A","parentIdentifier":"/us/usc/t22/s8792/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fa%2F2%2FA","sourceRelease":"119-100","text":"is a successor entity to a person on the list;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s8792/a/2/B","parentIdentifier":"/us/usc/t22/s8792/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fa%2F2%2FB","sourceRelease":"119-100","text":"owns or controls a person on the list, if the person that owns or controls the person on the list had actual knowledge or should have known that the person on the list engaged in the activity described in subsection (b)(2) for which the person was included in the list; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s8792/a/2/C","parentIdentifier":"/us/usc/t22/s8792/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fa%2F2%2FC","sourceRelease":"119-100","text":"is owned or controlled by, or under common ownership or control with, the person on the list, if the person owned or controlled by, or under common ownership or control with (as the case may be), the person on the list knowingly engaged in the activity described in subsection (b)(2) for which the person was included in the list.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"List","label":"b List","identifier":"/us/usc/t22/s8792/b","parentIdentifier":"/us/usc/t22/s8792","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s8792/b/1","parentIdentifier":"/us/usc/t22/s8792/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F1","sourceRelease":"119-100","text":"Not later than 120 days after , the President shall submit to the appropriate congressional committees a list of persons that the President determines have knowingly engaged in an activity described in paragraph (2) on or after .August 10, 2012August 10, 2012","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Activity described","label":"2 Activity described","identifier":"/us/usc/t22/s8792/b/2","parentIdentifier":"/us/usc/t22/s8792/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t22/s8792/b/2/A","parentIdentifier":"/us/usc/t22/s8792/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s8792/b/2/A/i","parentIdentifier":"/us/usc/t22/s8792/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"transfers, or facilitates the transfer of, goods or technologies described in subparagraph (C) to Syria; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s8792/b/2/A/ii","parentIdentifier":"/us/usc/t22/s8792/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"provides services with respect to goods or technologies described in subparagraph (C) after such goods or technologies are transferred to Syria.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Applicability to contracts and other agreements","label":"B Applicability to contracts and other agreements","identifier":"/us/usc/t22/s8792/b/2/B","parentIdentifier":"/us/usc/t22/s8792/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F2%2FB","sourceRelease":"119-100","text":"A person engages in an activity described in subparagraph (A) without regard to whether the activity is carried out pursuant to a contract or other agreement entered into before, on, or after .August 10, 2012","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Goods or technologies described","label":"C Goods or technologies described","identifier":"/us/usc/t22/s8792/b/2/C","parentIdentifier":"/us/usc/t22/s8792/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s8792/b/2/C/i","parentIdentifier":"/us/usc/t22/s8792/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F2%2FC%2Fi","sourceRelease":"119-100","text":"firearms or ammunition (as those terms are defined in ), rubber bullets, police batons, pepper or chemical sprays, stun grenades, electroshock weapons, tear gas, water cannons, or surveillance technology; orsection 921 of title 18","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s8792/b/2/C/ii","parentIdentifier":"/us/usc/t22/s8792/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F2%2FC%2Fii","sourceRelease":"119-100","text":"sensitive technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Sensitive technology defined","label":"D Sensitive technology defined","identifier":"/us/usc/t22/s8792/b/2/D","parentIdentifier":"/us/usc/t22/s8792/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t22/s8792/b/2/D/i","parentIdentifier":"/us/usc/t22/s8792/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F2%2FD%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t22/s8792/b/2/D/i/I","parentIdentifier":"/us/usc/t22/s8792/b/2/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F2%2FD%2Fi%2FI","sourceRelease":"119-100","text":"to restrict the free flow of unbiased information in Syria; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t22/s8792/b/2/D/i/II","parentIdentifier":"/us/usc/t22/s8792/b/2/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F2%2FD%2Fi%2FII","sourceRelease":"119-100","text":"to disrupt, monitor, or otherwise restrict speech of the people of Syria.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Exception","label":"ii Exception","identifier":"/us/usc/t22/s8792/b/2/D/ii","parentIdentifier":"/us/usc/t22/s8792/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F2%2FD%2Fii","sourceRelease":"119-100","text":"The term “sensitive technology” does not include information or informational materials the exportation of which the President does not have the authority to regulate or prohibit pursuant to .section 1702(b)(3) of title 50","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Special rule to allow for termination of sanctionable activity","label":"3 Special rule to allow for termination of sanctionable activity","identifier":"/us/usc/t22/s8792/b/3","parentIdentifier":"/us/usc/t22/s8792/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s8792/b/3/A","parentIdentifier":"/us/usc/t22/s8792/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the person is no longer engaging in, or has taken significant verifiable steps toward stopping, the activity described in paragraph (2) for which the President would otherwise have included the person on the list; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s8792/b/3/B","parentIdentifier":"/us/usc/t22/s8792/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F3%2FB","sourceRelease":"119-100","text":"the President has received reliable assurances that the person will not knowingly engage in any activity described in paragraph (2) in the future.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Updates of list","label":"4 Updates of list","identifier":"/us/usc/t22/s8792/b/4","parentIdentifier":"/us/usc/t22/s8792/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s8792/b/4/A","parentIdentifier":"/us/usc/t22/s8792/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F4%2FA","sourceRelease":"119-100","text":"not later than 300 days after , and every 180 days thereafter; andAugust 10, 2012","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s8792/b/4/B","parentIdentifier":"/us/usc/t22/s8792/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F4%2FB","sourceRelease":"119-100","text":"as new information becomes available.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Form of report; public availability","label":"5 Form of report; public availability","identifier":"/us/usc/t22/s8792/b/5","parentIdentifier":"/us/usc/t22/s8792/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Form","label":"A Form","identifier":"/us/usc/t22/s8792/b/5/A","parentIdentifier":"/us/usc/t22/s8792/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F5%2FA","sourceRelease":"119-100","text":"The list required by paragraph (1) shall be submitted in unclassified form but may contain a classified annex.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Public availability","label":"B Public availability","identifier":"/us/usc/t22/s8792/b/5/B","parentIdentifier":"/us/usc/t22/s8792/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8792%2Fb%2F5%2FB","sourceRelease":"119-100","text":"The unclassified portion of the list required by paragraph (1) shall be made available to the public and posted on the websites of the Department of the Treasury and the Department of State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
