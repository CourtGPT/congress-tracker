{"type":"section","nativeType":"section","number":"4906","heading":"Qualifying facilities","label":"4906 Qualifying facilities","identifier":"/us/usc/t16/s4906","parentIdentifier":"/us/usc/t16/ch69","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4906","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Determination","label":"a Determination","identifier":"/us/usc/t16/s4906/a","parentIdentifier":"/us/usc/t16/s4906","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4906%2Fa","sourceRelease":"119-100","text":"Upon submission of a petition under by any person, the Secretary shall determine whether an exotic bird breeding facility is a qualifying facility. Such determination shall be effective for a period specified by the Secretary, which may not exceed 3 years. The Secretary shall, from time to time, publish a list of qualifying facilities in the Federal Register.section 4909 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Criteria","label":"b Criteria","identifier":"/us/usc/t16/s4906/b","parentIdentifier":"/us/usc/t16/s4906","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4906%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s4906/b/1","parentIdentifier":"/us/usc/t16/s4906/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4906%2Fb%2F1","sourceRelease":"119-100","text":"The facility has demonstrated the capability of producing captive bred birds of the species in the numbers to be imported into the United States from that facility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s4906/b/2","parentIdentifier":"/us/usc/t16/s4906/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4906%2Fb%2F2","sourceRelease":"119-100","text":"The facility is operated in a manner that is not detrimental to the survival of the species in the wild.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s4906/b/3","parentIdentifier":"/us/usc/t16/s4906/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4906%2Fb%2F3","sourceRelease":"119-100","text":"The facility is operated in a humane manner.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s4906/b/4","parentIdentifier":"/us/usc/t16/s4906/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4906%2Fb%2F4","sourceRelease":"119-100","text":"The appropriate governmental authority of the country in which the facility is located has certified in writing, and the Secretary is satisfied, that the facility has the capability of breeding the species in captivity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s4906/b/5","parentIdentifier":"/us/usc/t16/s4906/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4906%2Fb%2F5","sourceRelease":"119-100","text":"The country in which the facility is located is a Party to the Convention.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s4906/b/6","parentIdentifier":"/us/usc/t16/s4906/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4906%2Fb%2F6","sourceRelease":"119-100","text":"All birds exported from the facility are bred at the facility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
