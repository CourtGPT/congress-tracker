{"type":"section","nativeType":"section","number":"300j–1a","heading":"Innovative water technology grant program","label":"300j–1a Innovative water technology grant program","identifier":"/us/usc/t42/s300j–1a","parentIdentifier":"/us/usc/t42/ch6A/schXII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the America’s Water Infrastructure Act of 2018, and not as part of the Public Health Service Act which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s300j–1a/a","parentIdentifier":"/us/usc/t42/s300j–1a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Administrator","label":"1 Administrator","identifier":"/us/usc/t42/s300j–1a/a/1","parentIdentifier":"/us/usc/t42/s300j–1a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fa%2F1","sourceRelease":"119-100","text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible entity","label":"2 Eligible entity","identifier":"/us/usc/t42/s300j–1a/a/2","parentIdentifier":"/us/usc/t42/s300j–1a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–1a/a/2/A","parentIdentifier":"/us/usc/t42/s300j–1a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fa%2F2%2FA","sourceRelease":"119-100","text":"a public water system (as defined under );section 300f(4) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–1a/a/2/B","parentIdentifier":"/us/usc/t42/s300j–1a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fa%2F2%2FB","sourceRelease":"119-100","text":"an institution of higher education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300j–1a/a/2/C","parentIdentifier":"/us/usc/t42/s300j–1a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fa%2F2%2FC","sourceRelease":"119-100","text":"a research institution or foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s300j–1a/a/2/D","parentIdentifier":"/us/usc/t42/s300j–1a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fa%2F2%2FD","sourceRelease":"119-100","text":"a regional water organization; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s300j–1a/a/2/E","parentIdentifier":"/us/usc/t42/s300j–1a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fa%2F2%2FE","sourceRelease":"119-100","text":"a nonprofit organization described in .section 300j–1(e)(8) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Grant program authorized","label":"b Grant program authorized","identifier":"/us/usc/t42/s300j–1a/b","parentIdentifier":"/us/usc/t42/s300j–1a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fb","sourceRelease":"119-100","text":"The Administrator shall carry out a grant program for the purpose of accelerating the development and deployment of innovative water technologies that address pressing drinking water supply, quality, treatment, or security challenges of public water systems, areas served by private wells, or source waters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Grants","label":"c Grants","identifier":"/us/usc/t42/s300j–1a/c","parentIdentifier":"/us/usc/t42/s300j–1a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300j–1a/c/1","parentIdentifier":"/us/usc/t42/s300j–1a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fc%2F1","sourceRelease":"119-100","text":"to develop, test, and deploy innovative water technologies; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300j–1a/c/2","parentIdentifier":"/us/usc/t42/s300j–1a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fc%2F2","sourceRelease":"119-100","text":"to provide technical assistance to deploy demonstrated innovative water technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Selection criteria","label":"d Selection criteria","identifier":"/us/usc/t42/s300j–1a/d","parentIdentifier":"/us/usc/t42/s300j–1a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300j–1a/d/1","parentIdentifier":"/us/usc/t42/s300j–1a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fd%2F1","sourceRelease":"119-100","text":"award grants through a competitive process to eligible entities the Administrator determines are best able to carry out the purpose of the program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300j–1a/d/2","parentIdentifier":"/us/usc/t42/s300j–1a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–1a/d/2/A","parentIdentifier":"/us/usc/t42/s300j–1a/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fd%2F2%2FA","sourceRelease":"119-100","text":"to reduce ratepayer or community costs or costs of future capital investments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–1a/d/2/B","parentIdentifier":"/us/usc/t42/s300j–1a/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fd%2F2%2FB","sourceRelease":"119-100","text":"to significantly improve human health or the environment; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300j–1a/d/2/C","parentIdentifier":"/us/usc/t42/s300j–1a/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fd%2F2%2FC","sourceRelease":"119-100","text":"to provide additional drinking water supplies with minimal environmental impact.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Cost-sharing","label":"e Cost-sharing","identifier":"/us/usc/t42/s300j–1a/e","parentIdentifier":"/us/usc/t42/s300j–1a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fe","sourceRelease":"119-100","text":"The Federal share of the cost of activities carried out using a grant under this section shall be not more than 65 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Limitation","label":"f Limitation","identifier":"/us/usc/t42/s300j–1a/f","parentIdentifier":"/us/usc/t42/s300j–1a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Ff","sourceRelease":"119-100","text":"The maximum amount of a grant under this section shall be $5,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Report","label":"g Report","identifier":"/us/usc/t42/s300j–1a/g","parentIdentifier":"/us/usc/t42/s300j–1a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fg","sourceRelease":"119-100","text":"Each year, the Administrator shall submit to Congress and make publicly available on the website of the Administrator a report that describes any advancements during the previous year in development of innovative water technologies made as a result of funding provided under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Partnerships","label":"h Partnerships","identifier":"/us/usc/t42/s300j–1a/h","parentIdentifier":"/us/usc/t42/s300j–1a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fh","sourceRelease":"119-100","text":"Grants awarded under this program may include projects that are carried out by an eligible entity in cooperation with a private entity, including a farmer, farmer cooperative, or manufacturer of water technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Authorization of appropriations","label":"i Authorization of appropriations","identifier":"/us/usc/t42/s300j–1a/i","parentIdentifier":"/us/usc/t42/s300j–1a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%931a%2Fi","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2019 and 2020.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
