{"type":"section","nativeType":"section","number":"6275","heading":"Limits on construction projects","label":"6275 Limits on construction projects","identifier":"/us/usc/t10/s6275","parentIdentifier":"/us/usc/t10/stA/ptVI/sptB/ch607/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6275","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsProvisions similar to those in this section were contained in , War and National Defense, prior to repeal by .section 2744 of Title 50Pub. L. 119–60, § 3111(b)(1)"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Construction Cost Ceiling","label":"a .—Construction Cost Ceiling","identifier":"/us/usc/t10/s6275/a","parentIdentifier":"/us/usc/t10/s6275","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6275%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6275/a/1","parentIdentifier":"/us/usc/t10/s6275/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6275%2Fa%2F1","sourceRelease":"119-100","text":"the amount authorized for the project; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6275/a/2","parentIdentifier":"/us/usc/t10/s6275/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6275%2Fa%2F2","sourceRelease":"119-100","text":"the amount of the total estimated cost for the project as shown in the most recent budget justification data submitted to Congress.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Exception Where Notice-and-wait Given","label":"b .—Exception Where Notice-and-wait Given","identifier":"/us/usc/t10/s6275/b","parentIdentifier":"/us/usc/t10/s6275","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6275%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6275/b/1","parentIdentifier":"/us/usc/t10/s6275/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6275%2Fb%2F1","sourceRelease":"119-100","text":"the Secretary of Energy has submitted to the congressional defense committees a report on the actions and the circumstances making such action necessary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6275/b/2","parentIdentifier":"/us/usc/t10/s6275/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6275%2Fb%2F2","sourceRelease":"119-100","text":"a period of 30 days has elapsed after the date on which the report is received by the committees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Computation of Days","label":"c .—Computation of Days","identifier":"/us/usc/t10/s6275/c","parentIdentifier":"/us/usc/t10/s6275","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6275%2Fc","sourceRelease":"119-100","text":"In the computation of the 30-day period under subsection (b), there shall be excluded any day on which either House of Congress is not in session because of an adjournment of more than three days to a day certain.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Exception for Minor Projects","label":"d .—Exception for Minor Projects","identifier":"/us/usc/t10/s6275/d","parentIdentifier":"/us/usc/t10/s6275","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6275%2Fd","sourceRelease":"119-100","text":"Subsection (a) does not apply to a construction project with a current estimated cost of less than the minor construction threshold.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
