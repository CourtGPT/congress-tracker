{"type":"section","nativeType":"section","number":"290ee–6","heading":"Regional Centers of Excellence in Substance Use Disorder Education","label":"290ee–6 Regional Centers of Excellence in Substance Use Disorder Education","identifier":"/us/usc/t42/s290ee–6","parentIdentifier":"/us/usc/t42/ch6A/schIII–A/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s290ee–6/a","parentIdentifier":"/us/usc/t42/s290ee–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fa","sourceRelease":"119-100","text":"The Secretary, in consultation with appropriate agencies, shall award cooperative agreements to eligible entities for the designation of such entities as Regional Centers of Excellence in Substance Use Disorder Education for purposes of improving health professional training resources with respect to substance use disorder prevention, treatment, and recovery.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Eligibility","label":"b Eligibility","identifier":"/us/usc/t42/s290ee–6/b","parentIdentifier":"/us/usc/t42/s290ee–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s290ee–6/b/1","parentIdentifier":"/us/usc/t42/s290ee–6/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s290ee–6/b/1/A","parentIdentifier":"/us/usc/t42/s290ee–6/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fb%2F1%2FA","sourceRelease":"119-100","text":"a teaching hospital;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s290ee–6/b/1/B","parentIdentifier":"/us/usc/t42/s290ee–6/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fb%2F1%2FB","sourceRelease":"119-100","text":"a medical school;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s290ee–6/b/1/C","parentIdentifier":"/us/usc/t42/s290ee–6/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fb%2F1%2FC","sourceRelease":"119-100","text":"a certified behavioral health clinic; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s290ee–6/b/1/D","parentIdentifier":"/us/usc/t42/s290ee–6/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fb%2F1%2FD","sourceRelease":"119-100","text":"any other health professions school, school of public health, or Cooperative Extension Program at institutions of higher education, as defined in , engaged in the prevention, treatment, or recovery of substance use disorders;section 1001 of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s290ee–6/b/2","parentIdentifier":"/us/usc/t42/s290ee–6/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fb%2F2","sourceRelease":"119-100","text":"demonstrate community engagement and partnerships with community stakeholders, including entities that train health professionals, mental health counselors, social workers, peer recovery specialists, substance use treatment programs, community health centers, physician offices, certified behavioral health clinics, research institutions, and law enforcement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s290ee–6/b/3","parentIdentifier":"/us/usc/t42/s290ee–6/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fb%2F3","sourceRelease":"119-100","text":"submit to the Secretary an application containing such information, at such time, and in such manner, as the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Activities","label":"c Activities","identifier":"/us/usc/t42/s290ee–6/c","parentIdentifier":"/us/usc/t42/s290ee–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s290ee–6/c/1","parentIdentifier":"/us/usc/t42/s290ee–6/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fc%2F1","sourceRelease":"119-100","text":"the neurology and pathology of substance use disorders;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s290ee–6/c/2","parentIdentifier":"/us/usc/t42/s290ee–6/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fc%2F2","sourceRelease":"119-100","text":"advancements in the treatment of substance use disorders;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s290ee–6/c/3","parentIdentifier":"/us/usc/t42/s290ee–6/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fc%2F3","sourceRelease":"119-100","text":"techniques and best practices to support recovery from substance use disorders;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s290ee–6/c/4","parentIdentifier":"/us/usc/t42/s290ee–6/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fc%2F4","sourceRelease":"119-100","text":"strategies for the prevention and treatment of, and recovery from substance use disorders across patient populations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s290ee–6/c/5","parentIdentifier":"/us/usc/t42/s290ee–6/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fc%2F5","sourceRelease":"119-100","text":"other topic areas that are relevant to the objectives described in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Geographic distribution","label":"d Geographic distribution","identifier":"/us/usc/t42/s290ee–6/d","parentIdentifier":"/us/usc/t42/s290ee–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fd","sourceRelease":"119-100","text":"In awarding cooperative agreements under subsection (a), the Secretary shall take into account regional differences among eligible entities and shall make an effort to ensure geographic distribution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Evaluation","label":"e Evaluation","identifier":"/us/usc/t42/s290ee–6/e","parentIdentifier":"/us/usc/t42/s290ee–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Fe","sourceRelease":"119-100","text":"The Secretary shall evaluate each project carried out by an entity receiving an award under this section and shall disseminate the findings with respect to each such evaluation to appropriate public and private entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Funding","label":"f Funding","identifier":"/us/usc/t42/s290ee–6/f","parentIdentifier":"/us/usc/t42/s290ee–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs290ee%E2%80%936%2Ff","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section, $4,000,000 for each of fiscal years 2019 through 2023.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
