{"type":"section","nativeType":"section","number":"9803","heading":"Restrictions","label":"9803 Restrictions","identifier":"/us/usc/t5/s9803","parentIdentifier":"/us/usc/t5/ptIII/sptI/ch98","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9803","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s9803/a","parentIdentifier":"/us/usc/t5/s9803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9803%2Fa","sourceRelease":"119-100","text":"None of the workforce authorities made available under this chapter may be exercised with respect to any officer who is appointed by the President, by and with the advice and consent of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s9803/b","parentIdentifier":"/us/usc/t5/s9803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9803%2Fb","sourceRelease":"119-100","text":"Unless specifically stated otherwise, all workforce authorities made available under this chapter shall be subject to section 5307.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t5/s9803/c","parentIdentifier":"/us/usc/t5/s9803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9803%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s9803/c/1","parentIdentifier":"/us/usc/t5/s9803/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9803%2Fc%2F1","sourceRelease":"119-100","text":"None of the workforce authorities made available under section 9804, 9805, 9806, 9807, 9809, 9812, 9813, 9814, or 9815 may be exercised with respect to a political appointee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s9803/c/2","parentIdentifier":"/us/usc/t5/s9803/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9803%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s9803/c/2/A","parentIdentifier":"/us/usc/t5/s9803/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9803%2Fc%2F2%2FA","sourceRelease":"119-100","text":"a position which has been excepted from the competitive service by reason of its confidential, policy-determining, policy-making, or policy-advocating character; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s9803/c/2/B","parentIdentifier":"/us/usc/t5/s9803/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9803%2Fc%2F2%2FB","sourceRelease":"119-100","text":"a position in the Senior Executive Service as a noncareer appointee (as such term is defined in section 3132(a)).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
