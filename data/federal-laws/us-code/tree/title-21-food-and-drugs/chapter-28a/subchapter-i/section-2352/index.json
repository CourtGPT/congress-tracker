{"type":"section","nativeType":"section","number":"2352","heading":"Use of national emergency authorities; reporting","label":"2352 Use of national emergency authorities; reporting","identifier":"/us/usc/t21/s2352","parentIdentifier":"/us/usc/t21/ch28A/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2352","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t21/s2352/a","parentIdentifier":"/us/usc/t21/s2352","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2352%2Fa","sourceRelease":"119-100","text":"The President may exercise all authorities provided under sections 1702 and 1704 of title 50 to carry out this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report required","label":"b Report required","identifier":"/us/usc/t21/s2352/b","parentIdentifier":"/us/usc/t21/s2352","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2352%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t21/s2352/b/1","parentIdentifier":"/us/usc/t21/s2352/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2352%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s2352/b/1/A","parentIdentifier":"/us/usc/t21/s2352/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2352%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the issuance of any new or revised regulations, policies, or guidance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s2352/b/1/B","parentIdentifier":"/us/usc/t21/s2352/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2352%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the imposition of sanctions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t21/s2352/b/1/C","parentIdentifier":"/us/usc/t21/s2352/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2352%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the collection of relevant information from outside parties;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t21/s2352/b/1/D","parentIdentifier":"/us/usc/t21/s2352/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2352%2Fb%2F1%2FD","sourceRelease":"119-100","text":"the issuance or closure of general licenses, specific licenses, and statements of licensing policy by the Office of Foreign Assets Control;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t21/s2352/b/1/E","parentIdentifier":"/us/usc/t21/s2352/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2352%2Fb%2F1%2FE","sourceRelease":"119-100","text":"a description of any pending enforcement cases; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t21/s2352/b/1/F","parentIdentifier":"/us/usc/t21/s2352/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2352%2Fb%2F1%2FF","sourceRelease":"119-100","text":"the implementation of mitigation procedures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Form of report","label":"2 Form of report","identifier":"/us/usc/t21/s2352/b/2","parentIdentifier":"/us/usc/t21/s2352/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2352%2Fb%2F2","sourceRelease":"119-100","text":"Each report required under paragraph (1) shall be submitted in unclassified form, but may include the matters required under subparagraphs (C), (D), (E), and (F) of such paragraph in a classified annex.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
