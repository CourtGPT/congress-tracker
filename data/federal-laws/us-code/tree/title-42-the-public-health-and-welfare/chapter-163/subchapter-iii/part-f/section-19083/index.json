{"type":"section","nativeType":"section","number":"19083","heading":"Helium conservation","label":"19083 Helium conservation","identifier":"/us/usc/t42/s19083","parentIdentifier":"/us/usc/t42/ch163/schIII/ptF","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19083","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Major research instrumentation support","label":"a Major research instrumentation support","identifier":"/us/usc/t42/s19083/a","parentIdentifier":"/us/usc/t42/s19083","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19083%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s19083/a/1","parentIdentifier":"/us/usc/t42/s19083/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19083%2Fa%2F1","sourceRelease":"119-100","text":"The Director shall support, through the Major Research Instrumentation program, proposal requests that include the purchase, installation, operation, and maintenance of equipment and instrumentation to reduce consumption of helium.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Cost sharing","label":"2 Cost sharing","identifier":"/us/usc/t42/s19083/a/2","parentIdentifier":"/us/usc/t42/s19083/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19083%2Fa%2F2","sourceRelease":"119-100","text":"The Director may waive the cost-sharing requirement for helium conservation measures for non-Ph.D.-granting institutions of higher education and Ph.D.-granting institutions of higher education that are not ranked among the top 100 institutions receiving Federal research and development funding, as documented by the National Center for Science and Engineering Statistics.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Annual report","label":"b Annual report","identifier":"/us/usc/t42/s19083/b","parentIdentifier":"/us/usc/t42/s19083","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19083%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19083/b/1","parentIdentifier":"/us/usc/t42/s19083/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19083%2Fb%2F1","sourceRelease":"119-100","text":"the volume and price of helium purchased;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19083/b/2","parentIdentifier":"/us/usc/t42/s19083/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19083%2Fb%2F2","sourceRelease":"119-100","text":"changes in pricing and availability of helium; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19083/b/3","parentIdentifier":"/us/usc/t42/s19083/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19083%2Fb%2F3","sourceRelease":"119-100","text":"any supply disruptions impacting a substantial number of institutions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
