{"type":"section","nativeType":"section","number":"6250a","heading":"Authority","label":"6250a Authority","identifier":"/us/usc/t42/s6250a","parentIdentifier":"/us/usc/t42/ch77/schI/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6250a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6250a/1","parentIdentifier":"/us/usc/t42/s6250a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6250a%2F1","sourceRelease":"119-100","text":"purchase, contract for, lease, or otherwise acquire, in whole or in part, storage and related facilities, and storage services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6250a/2","parentIdentifier":"/us/usc/t42/s6250a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6250a%2F2","sourceRelease":"119-100","text":"use, lease, maintain, sell, or otherwise dispose of storage and related facilities acquired under this part;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s6250a/3","parentIdentifier":"/us/usc/t42/s6250a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6250a%2F3","sourceRelease":"119-100","text":"acquire by purchase, exchange (including exchange of petroleum products from the Strategic Petroleum Reserve or received as royalty from Federal lands), lease, or otherwise, petroleum distillate for storage in the Northeast Home Heating Oil Reserve;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s6250a/4","parentIdentifier":"/us/usc/t42/s6250a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6250a%2F4","sourceRelease":"119-100","text":"store petroleum distillate in facilities not owned by the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s6250a/5","parentIdentifier":"/us/usc/t42/s6250a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6250a%2F5","sourceRelease":"119-100","text":"sell, exchange, or otherwise dispose of petroleum distillate from the Reserve established under this part, including to maintain the quality or quantity of the petroleum distillate in the Reserve or to maintain the operational capability of the Reserve.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
