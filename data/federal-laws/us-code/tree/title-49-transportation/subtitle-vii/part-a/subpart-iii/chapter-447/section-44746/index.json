{"type":"section","nativeType":"section","number":"44746","heading":"Flight data recovery from overwater operations","label":"44746 Flight data recovery from overwater operations","identifier":"/us/usc/t49/s44746","parentIdentifier":"/us/usc/t49/stVII/ptA/sptiii/ch447","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44746","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe date of enactment of this section, referred to in subsec. (a), is the date of enactment of , which was approved .Pub. L. 118–63May 16, 2024"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t49/s44746/a","parentIdentifier":"/us/usc/t49/s44746","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44746%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s44746/a/1","parentIdentifier":"/us/usc/t49/s44746/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44746%2Fa%2F1","sourceRelease":"119-100","text":"fitted with a means, in the event of an accident, to recover mandatory flight data parameters in a manner that does not require the underwater retrieval of the cockpit voice recorder or flight data recorder;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s44746/a/2","parentIdentifier":"/us/usc/t49/s44746/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44746%2Fa%2F2","sourceRelease":"119-100","text":"equipped with a tamper-resistant method to broadcast sufficient information to a ground station to establish the location where an applicable aircraft terminates flight as the result of such an event; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s44746/a/3","parentIdentifier":"/us/usc/t49/s44746/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44746%2Fa%2F3","sourceRelease":"119-100","text":"equipped with an airframe low-frequency underwater locating device that functions for at least 90 days and that can be detected by appropriate equipment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Applicable Aircraft Defined","label":"b .—Applicable Aircraft Defined","identifier":"/us/usc/t49/s44746/b","parentIdentifier":"/us/usc/t49/s44746","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44746%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s44746/b/1","parentIdentifier":"/us/usc/t49/s44746/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44746%2Fb%2F1","sourceRelease":"119-100","text":"operated under part 121 of title 14, Code of Federal Regulations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s44746/b/2","parentIdentifier":"/us/usc/t49/s44746/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44746%2Fb%2F2","sourceRelease":"119-100","text":"required by regulation to have a cockpit voice recorder and a flight data recorder; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s44746/b/3","parentIdentifier":"/us/usc/t49/s44746/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs44746%2Fb%2F3","sourceRelease":"119-100","text":"used in extended overwater operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
