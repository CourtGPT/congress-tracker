{"type":"section","nativeType":"section","number":"3682","heading":"Notice to victims of order of special forfeiture","label":"3682 Notice to victims of order of special forfeiture","identifier":"/us/usc/t18/s3682","parentIdentifier":"/us/usc/t18/ptII/ch232A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3682","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s3682/1","parentIdentifier":"/us/usc/t18/s3682","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3682%2F1","sourceRelease":"119-100","text":"the name of, and other identifying information about, the defendant;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s3682/2","parentIdentifier":"/us/usc/t18/s3682","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3682%2F2","sourceRelease":"119-100","text":"the offense for which the defendant was convicted; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s3682/3","parentIdentifier":"/us/usc/t18/s3682","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3682%2F3","sourceRelease":"119-100","text":"that the court has ordered a special forfeiture of certain proceeds that may be used to satisfy a judgment obtained against the defendant by a victim of an offense for which the defendant has been convicted.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
