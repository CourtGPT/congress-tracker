e contractors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17354/b/4/B","parentIdentifier":"/us/usc/t42/s17354/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17354%2Fb%2F4%2FB","sourceRelease":"119-100","text":"costs associated with securing the use of real property for carrying out the functions of the Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17354/b/4/C","parentIdentifier":"/us/usc/t42/s17354/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17354%2Fb%2F4%2FC","sourceRelease":"119-100","text":"total travel expenses incurred by Board members and Foundation employees in connection with Foundation activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17354/b/4/D","parentIdentifier":"/us/usc/t42/s17354/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17354%2Fb%2F4%2FD","sourceRelease":"119-100","text":"total representational expenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
