{"type":"section","nativeType":"section","number":"543e","heading":"Scenic Area Advisory Board","label":"543e Scenic Area Advisory Board","identifier":"/us/usc/t16/s543e","parentIdentifier":"/us/usc/t16/ch2/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment; consultations with Secretary","label":"a Establishment; consultations with Secretary","identifier":"/us/usc/t16/s543e/a","parentIdentifier":"/us/usc/t16/s543e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s543e/a/1","parentIdentifier":"/us/usc/t16/s543e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fa%2F1","sourceRelease":"119-100","text":"the administration of the Scenic Area with respect to policies, programs, and activities in accordance with sections 543 to 543h of this title;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s543e/a/2","parentIdentifier":"/us/usc/t16/s543e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fa%2F2","sourceRelease":"119-100","text":"the preparation and implementation of the comprehensive management plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s543e/a/3","parentIdentifier":"/us/usc/t16/s543e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fa%2F3","sourceRelease":"119-100","text":"the location of the visitor center authorized by .section 543c(f) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Composition and selection","label":"b Composition and selection","identifier":"/us/usc/t16/s543e/b","parentIdentifier":"/us/usc/t16/s543e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s543e/b/1","parentIdentifier":"/us/usc/t16/s543e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fb%2F1","sourceRelease":"119-100","text":"five members appointed by the Mono County Board of Supervisors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s543e/b/2","parentIdentifier":"/us/usc/t16/s543e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fb%2F2","sourceRelease":"119-100","text":"two members appointed by the Governor of California (one of whom shall be an employee of the California Division of Parks and Recreation);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s543e/b/3","parentIdentifier":"/us/usc/t16/s543e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fb%2F3","sourceRelease":"119-100","text":"one member appointed by the mayor of the city of Los Angeles; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s543e/b/4","parentIdentifier":"/us/usc/t16/s543e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fb%2F4","sourceRelease":"119-100","text":"one member appointed by the Secretary (who shall be an employee of the Forest Service).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Terms of appointment","label":"c Terms of appointment","identifier":"/us/usc/t16/s543e/c","parentIdentifier":"/us/usc/t16/s543e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s543e/c/1","parentIdentifier":"/us/usc/t16/s543e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fc%2F1","sourceRelease":"119-100","text":"of those members appointed by the Mono County Board of Supervisors one shall be appointed to serve for a term of one year, two shall be for a term of two years, and two shall be for a term of three years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s543e/c/2","parentIdentifier":"/us/usc/t16/s543e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fc%2F2","sourceRelease":"119-100","text":"of those members appointed by the Governor of California one shall be appointed to serve for a term of one year and one shall be appointed to serve for a term of three years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s543e/c/3","parentIdentifier":"/us/usc/t16/s543e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fc%2F3","sourceRelease":"119-100","text":"the member appointed by the mayor of the city of Los Angeles shall be appointed to serve for a term of two years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s543e/c/4","parentIdentifier":"/us/usc/t16/s543e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fc%2F4","sourceRelease":"119-100","text":"the member appointed by the Secretary shall be appointed to serve for a term of three years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Initial appointment; Chairman","label":"d Initial appointment; Chairman","identifier":"/us/usc/t16/s543e/d","parentIdentifier":"/us/usc/t16/s543e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fd","sourceRelease":"119-100","text":"The members of the Board shall be appointed within ninety days of . The members of the Board shall, at their first meeting, elect a Chairman.September 28, 1984","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Annual meetings and consultations with Secretary or designee","label":"e Annual meetings and consultations with Secretary or designee","identifier":"/us/usc/t16/s543e/e","parentIdentifier":"/us/usc/t16/s543e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fe","sourceRelease":"119-100","text":"The Secretary, or a designee, shall from time to time, but at least annually, meet and consult with the Board on matters relating to the administration of the scenic area.1So in original. Probably should be capitalized.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Compensation; expenses","label":"f Compensation; expenses","identifier":"/us/usc/t16/s543e/f","parentIdentifier":"/us/usc/t16/s543e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Ff","sourceRelease":"119-100","text":"Members of the Board shall serve without compensation as such, but the Secretary is authorized to pay, upon vouchers signed by the Chairman, the expenses reasonably incurred by the Board and its members in carrying out their duties under sections 543 to 543h of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Vacancies","label":"g Vacancies","identifier":"/us/usc/t16/s543e/g","parentIdentifier":"/us/usc/t16/s543e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fg","sourceRelease":"119-100","text":"Any vacancy in the Board shall be filled in the same manner in which the original appointment was made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Quorum","label":"h Quorum","identifier":"/us/usc/t16/s543e/h","parentIdentifier":"/us/usc/t16/s543e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fh","sourceRelease":"119-100","text":"A majority of those members appointed shall constitute a quorum for the conduct of all business of the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Termination","label":"i Termination","identifier":"/us/usc/t16/s543e/i","parentIdentifier":"/us/usc/t16/s543e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs543e%2Fi","sourceRelease":"119-100","text":"The Board shall terminate ten years from the date of its first meeting.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
