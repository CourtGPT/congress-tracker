{"type":"section","nativeType":"section","number":"3581","heading":"Sentence of imprisonment","label":"3581 Sentence of imprisonment","identifier":"/us/usc/t18/s3581","parentIdentifier":"/us/usc/t18/ptII/ch227/schD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3581","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , and applicable only to offenses committed after the taking effect of this section, see , set out as a note under .Nov. 1, 1987section 235(a)(1) of Pub. L. 98–473section 3551 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t18/s3581/a","parentIdentifier":"/us/usc/t18/s3581","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3581%2Fa","sourceRelease":"119-100","text":"A defendant who has been found guilty of an offense may be sentenced to a term of imprisonment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Authorized Terms","label":"b .—Authorized Terms","identifier":"/us/usc/t18/s3581/b","parentIdentifier":"/us/usc/t18/s3581","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3581%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s3581/b/1","parentIdentifier":"/us/usc/t18/s3581/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3581%2Fb%2F1","sourceRelease":"119-100","text":"for a Class A felony, the duration of the defendant’s life or any period of time;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":n