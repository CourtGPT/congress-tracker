{"type":"section","nativeType":"section","number":"8158","heading":"Deposit in escrow","label":"8158 Deposit in escrow","identifier":"/us/usc/t38/s8158","parentIdentifier":"/us/usc/t38/ptVI/ch81/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8158","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t38/s8158/a","parentIdentifier":"/us/usc/t38/s8158","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8158%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s8158/a/1","parentIdentifier":"/us/usc/t38/s8158/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8158%2Fa%2F1","sourceRelease":"119-100","text":"the institutions shall pay to the Secretary the funds necessary to make a payment under ;section 8157(b)(4) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s8158/a/2","parentIdentifier":"/us/usc/t38/s8158/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8158%2Fa%2F2","sourceRelease":"119-100","text":"the Secretary, as escrow agent, shall administer those funds in an escrow account; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s8158/a/3","parentIdentifier":"/us/usc/t38/s8158/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8158%2Fa%2F3","sourceRelease":"119-100","text":"the Secretary shall disburse the escrowed funds to pay for such equipment upon its delivery or in accordance with the contract to procure the equipment and shall disburse all accrued interest or other earnings on the escrowed funds to the institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t38/s8158/b","parentIdentifier":"/us/usc/t38/s8158","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8158%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s8158/b/1","parentIdentifier":"/us/usc/t38/s8158/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8158%2Fb%2F1","sourceRelease":"119-100","text":"invest the escrowed funds in obligations of the Federal Government or obligations which are insured or guaranteed by the Federal Government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s8158/b/2","parentIdentifier":"/us/usc/t38/s8158/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8158%2Fb%2F2","sourceRelease":"119-100","text":"retain in the escrow account interest or other earnings on such investments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s8158/b/3","parentIdentifier":"/us/usc/t38/s8158/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8158%2Fb%2F3","sourceRelease":"119-100","text":"disburse the funds pursuant to the escrow agreement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s8158/b/4","parentIdentifier":"/us/usc/t38/s8158/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8158%2Fb%2F4","sourceRelease":"119-100","text":"return undisbursed funds to the institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t38/s8158/c","parentIdentifier":"/us/usc/t38/s8158","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8158%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s8158/c/1","parentIdentifier":"/us/usc/t38/s8158/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8158%2Fc%2F1","sourceRelease":"119-100","text":"If the Secretary enters into an escrow agreement under this section, the Secretary may enter into an agreement to procure medical equipment if one-half the purchase price of the equipment is available in an appropriation or fund for the expenditure or obligation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s8158/c/2","parentIdentifier":"/us/usc/t38/s8158/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs8158%2Fc%2F2","sourceRelease":"119-100","text":"Funds held in an escrow account under this section shall not be considered to be public funds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
