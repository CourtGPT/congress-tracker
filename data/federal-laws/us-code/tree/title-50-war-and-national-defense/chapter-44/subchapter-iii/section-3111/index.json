{"type":"section","nativeType":"section","number":"3111","heading":"Briefings and notifications on counterintelligence activities of the Federal Bureau of Investigation","label":"3111 Briefings and notifications on counterintelligence activities of the Federal Bureau of Investigation","identifier":"/us/usc/t50/s3111","parentIdentifier":"/us/usc/t50/ch44/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Quarterly briefings","label":"a Quarterly briefings","identifier":"/us/usc/t50/s3111/a","parentIdentifier":"/us/usc/t50/s3111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3111/a/1","parentIdentifier":"/us/usc/t50/s3111/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111%2Fa%2F1","sourceRelease":"119-100","text":"the counterintelligence posture of the Bureau;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3111/a/2","parentIdentifier":"/us/usc/t50/s3111/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111%2Fa%2F2","sourceRelease":"119-100","text":"counterintelligence investigations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s3111/a/3","parentIdentifier":"/us/usc/t50/s3111/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111%2Fa%2F3","sourceRelease":"119-100","text":"any other information relating to the counterintelligence activities of the Bureau that the Director determines necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Notifications","label":"b Notifications","identifier":"/us/usc/t50/s3111/b","parentIdentifier":"/us/usc/t50/s3111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111%2Fb","sourceRelease":"119-100","text":"In addition to the quarterly briefings under subsection (a), the Director of the Federal Bureau of Investigation shall promptly notify the congressional intelligence committees of any counterintelligence investigation carried out by the Bureau with respect to any counterintelligence risk or threat that is related to an election or campaign for Federal office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Guidelines","label":"c Guidelines","identifier":"/us/usc/t50/s3111/c","parentIdentifier":"/us/usc/t50/s3111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Development and consultation","label":"1 Development and consultation","identifier":"/us/usc/t50/s3111/c/1","parentIdentifier":"/us/usc/t50/s3111/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111%2Fc%2F1","sourceRelease":"119-100","text":"The Director shall develop guidelines governing the scope of the briefings provided under subsection (a), the notifications provided under subsection (b), and the information required by . The Director shall consult the congressional intelligence committees during such development.section 3371(a)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Submission","label":"2 Submission","identifier":"/us/usc/t50/s3111/c/2","parentIdentifier":"/us/usc/t50/s3111/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3111/c/2/A","parentIdentifier":"/us/usc/t50/s3111/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the guidelines under paragraph (1) upon issuance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3111/c/2/B","parentIdentifier":"/us/usc/t50/s3111/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3111%2Fc%2F2%2FB","sourceRelease":"119-100","text":"any updates to such guidelines by not later than 15 days after making such update.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
