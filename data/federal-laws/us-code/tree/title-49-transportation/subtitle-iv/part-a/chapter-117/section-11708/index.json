{"type":"section","nativeType":"section","number":"11708","heading":"Voluntary arbitration of certain rail rates and practices disputes","label":"11708 Voluntary arbitration of certain rail rates and practices disputes","identifier":"/us/usc/t49/s11708","parentIdentifier":"/us/usc/t49/stIV/ptA/ch117","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe date of the enactment of the Surface Transportation Board Reauthorization Act of 2015, referred to in subsec. (a), is the date of enactment of , which was approved .Pub. L. 114–110Dec. 18, 2015"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t49/s11708/a","parentIdentifier":"/us/usc/t49/s11708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fa","sourceRelease":"119-100","text":"Not later than 1 year after the date of the enactment of the Surface Transportation Board Reauthorization Act of 2015, the Board shall promulgate regulations to establish a voluntary and binding arbitration process to resolve rail rate and practice complaints subject to the jurisdiction of the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Covered Disputes","label":"b .—Covered Disputes","identifier":"/us/usc/t49/s11708/b","parentIdentifier":"/us/usc/t49/s11708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s11708/b/1","parentIdentifier":"/us/usc/t49/s11708/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s11708/b/1/A","parentIdentifier":"/us/usc/t49/s11708/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fb%2F1%2FA","sourceRelease":"119-100","text":"rates, demurrage, accessorial charges, misrouting, or mishandling of rail cars; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s11708/b/1/B","parentIdentifier":"/us/usc/t49/s11708/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fb%2F1%2FB","sourceRelease":"119-100","text":"a carrier’s published rules and practices as applied to particular rail transportation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s11708/b/2","parentIdentifier":"/us/usc/t49/s11708/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s11708/b/2/A","parentIdentifier":"/us/usc/t49/s11708/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fb%2F2%2FA","sourceRelease":"119-100","text":"to obtain the grant, denial, stay, or revocation of any license, authorization, or exemption;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s11708/b/2/B","parentIdentifier":"/us/usc/t49/s11708/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fb%2F2%2FB","sourceRelease":"119-100","text":"to prescribe for the future any conduct, rules, or results of general, industry-wide applicability;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s11708/b/2/C","parentIdentifier":"/us/usc/t49/s11708/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fb%2F2%2FC","sourceRelease":"119-100","text":"to enforce a labor protective condition; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t49/s11708/b/2/D","parentIdentifier":"/us/usc/t49/s11708/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fb%2F2%2FD","sourceRelease":"119-100","text":"that are solely between 2 or more rail carriers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s11708/b/3","parentIdentifier":"/us/usc/t49/s11708/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fb%2F3","sourceRelease":"119-100","text":"shall not prevent parties from independently seeking or utilizing private arbitration services to resolve any disputes the parties may have.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Arbitration Procedures.—","label":"c Arbitration Procedures.—","identifier":"/us/usc/t49/s11708/c","parentIdentifier":"/us/usc/t49/s11708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s11708/c/1","parentIdentifier":"/us/usc/t49/s11708/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s11708/c/1/A","parentIdentifier":"/us/usc/t49/s11708/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fc%2F1%2FA","sourceRelease":"119-100","text":"may make the voluntary and binding arbitration process established pursuant to subsection (a) available only to the relevant parties;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s11708/c/1/B","parentIdentifier":"/us/usc/t49/s11708/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s11708/c/1/B/i","parentIdentifier":"/us/usc/t49/s11708/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"after receiving the written consent to arbitrate from all relevant parties; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s11708/c/1/B/ii","parentIdentifier":"/us/usc/t49/s11708/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t49/s11708/c/1/B/ii/I","parentIdentifier":"/us/usc/t49/s11708/c/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fc%2F1%2FB%2Fii%2FI","sourceRelease":"119-100","text":"after the filing of a written complaint; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t49/s11708/c/1/B/ii/II","parentIdentifier":"/us/usc/t49/s11708/c/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fc%2F1%2FB%2Fii%2FII","sourceRelease":"119-100","text":"through other procedures adopted by the Board in a rulemaking proceeding;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s11708/c/1/C","parentIdentifier":"/us/usc/t49/s11708/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fc%2F1%2FC","sourceRelease":"119-100","text":"with respect to rate disputes, may make the voluntary and binding arbitration process available only to the relevant parties if the rail carrier has market dominance (as determined under section 10707); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t49/s11708/c/1/D","parentIdentifier":"/us/usc/t49/s11708/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fc%2F1%2FD","sourceRelease":"119-100","text":"may initiate the voluntary and binding arbitration process not later than 40 days after the date on which a written complaint is filed or through other procedures adopted by the Board in a rulemaking proceeding.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Limitation","label":"2 .—Limitation","identifier":"/us/usc/t49/s11708/c/2","parentIdentifier":"/us/usc/t49/s11708/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fc%2F2","sourceRelease":"119-100","text":"Initiation of the voluntary and binding arbitration process shall preclude the Board from separately reviewing a complaint or dispute related to the same rail rate or practice in a covered dispute involving the same parties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Rates","label":"3 .—Rates","identifier":"/us/usc/t49/s11708/c/3","parentIdentifier":"/us/usc/t49/s11708/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fc%2F3","sourceRelease":"119-100","text":"In resolving a covered dispute involving the reasonableness of a rail carrier’s rates, the arbitrator or panel of arbitrators, as applicable, shall consider the Board’s methodologies for setting maximum lawful rates, giving due consideration to the need for differential pricing to permit a rail carrier to collect adequate revenues (as determined under section 10704(a)(2)).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Arbitration Decisions","label":"d .—Arbitration Decisions","identifier":"/us/usc/t49/s11708/d","parentIdentifier":"/us/usc/t49/s11708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s11708/d/1","parentIdentifier":"/us/usc/t49/s11708/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fd%2F1","sourceRelease":"119-100","text":"shall be consistent with sound principles of rail regulation economics;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s11708/d/2","parentIdentifier":"/us/usc/t49/s11708/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fd%2F2","sourceRelease":"119-100","text":"shall be in writing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s11708/d/3","parentIdentifier":"/us/usc/t49/s11708/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fd%2F3","sourceRelease":"119-100","text":"shall contain findings of fact and conclusions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s11708/d/4","parentIdentifier":"/us/usc/t49/s11708/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fd%2F4","sourceRelease":"119-100","text":"shall be binding upon the parties; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t49/s11708/d/5","parentIdentifier":"/us/usc/t49/s11708/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fd%2F5","sourceRelease":"119-100","text":"shall not have any precedential effect in any other or subsequent arbitration dispute.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Timelines.—","label":"e Timelines.—","identifier":"/us/usc/t49/s11708/e","parentIdentifier":"/us/usc/t49/s11708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Selection","label":"1 .—Selection","identifier":"/us/usc/t49/s11708/e/1","parentIdentifier":"/us/usc/t49/s11708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fe%2F1","sourceRelease":"119-100","text":"An arbitrator or panel of arbitrators shall be selected not later than 14 days after the date of the Board’s decision to initiate arbitration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Evidentiary process","label":"2 .—Evidentiary process","identifier":"/us/usc/t49/s11708/e/2","parentIdentifier":"/us/usc/t49/s11708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s11708/e/2/A","parentIdentifier":"/us/usc/t49/s11708/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fe%2F2%2FA","sourceRelease":"119-100","text":"a party requests an extension; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s11708/e/2/B","parentIdentifier":"/us/usc/t49/s11708/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fe%2F2%2FB","sourceRelease":"119-100","text":"the arbitrator or panel of arbitrators, as applicable, grants such extension request.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Decision","label":"3 .—Decision","identifier":"/us/usc/t49/s11708/e/3","parentIdentifier":"/us/usc/t49/s11708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fe%2F3","sourceRelease":"119-100","text":"The arbitrator or panel of arbitrators, as applicable, shall issue a decision not later than 30 days after the date on which the evidentiary record is closed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Extensions","label":"4 .—Extensions","identifier":"/us/usc/t49/s11708/e/4","parentIdentifier":"/us/usc/t49/s11708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fe%2F4","sourceRelease":"119-100","text":"The Board may extend any of the timelines under this subsection upon the agreement of all parties in the dispute.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Arbitrators.—","label":"f Arbitrators.—","identifier":"/us/usc/t49/s11708/f","parentIdentifier":"/us/usc/t49/s11708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s11708/f/1","parentIdentifier":"/us/usc/t49/s11708/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Ff%2F1","sourceRelease":"119-100","text":"Unless otherwise agreed by all of the parties, an arbitration under this section shall be conducted by an arbitrator or panel of arbitrators, which shall be selected from a roster, maintained by the Board, of persons with rail transportation, economic regulation, professional or business experience, including agriculture, in the private sector.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Independence","label":"2 .—Independence","identifier":"/us/usc/t49/s11708/f/2","parentIdentifier":"/us/usc/t49/s11708/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Ff%2F2","sourceRelease":"119-100","text":"In an arbitration under this section, the arbitrators shall perform their duties with diligence, good faith, and in a manner consistent with the requirements of impartiality and independence.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Selection.—","label":"3 Selection.—","identifier":"/us/usc/t49/s11708/f/3","parentIdentifier":"/us/usc/t49/s11708/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Ff%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t49/s11708/f/3/A","parentIdentifier":"/us/usc/t49/s11708/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Ff%2F3%2FA","sourceRelease":"119-100","text":"If the parties cannot mutually agree on an arbitrator, or the lead arbitrator of a panel of arbitrators, the parties shall select the arbitrator or lead arbitrator from the roster by alternately striking names from the roster until only 1 name remains meeting the criteria set forth in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Panel of arbitrators","label":"B .—Panel of arbitrators","identifier":"/us/usc/t49/s11708/f/3/B","parentIdentifier":"/us/usc/t49/s11708/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Ff%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s11708/f/3/B/i","parentIdentifier":"/us/usc/t49/s11708/f/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Ff%2F3%2FB%2Fi","sourceRelease":"119-100","text":"The parties to a dispute may mutually select 1 arbitrator from the roster to serve as the lead arbitrator of the panel of arbitrators.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s11708/f/3/B/ii","parentIdentifier":"/us/usc/t49/s11708/f/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Ff%2F3%2FB%2Fii","sourceRelease":"119-100","text":"If the parties cannot mutually agree on a lead arbitrator, the parties shall select a lead arbitrator using the process described in subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t49/s11708/f/3/B/iii","parentIdentifier":"/us/usc/t49/s11708/f/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Ff%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"In addition to the lead arbitrator selected under this subparagraph, each party to a dispute shall select 1 additional arbitrator from the roster, regardless of whether the other party struck out the arbitrator’s name under subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Cost","label":"4 .—Cost","identifier":"/us/usc/t49/s11708/f/4","parentIdentifier":"/us/usc/t49/s11708/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Ff%2F4","sourceRelease":"119-100","text":"The parties shall share the costs incurred by the Board and arbitrators equally, with each party responsible for paying its own legal and other associated arbitration costs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Relief.—","label":"g Relief.—","identifier":"/us/usc/t49/s11708/g","parentIdentifier":"/us/usc/t49/s11708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s11708/g/1","parentIdentifier":"/us/usc/t49/s11708/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fg%2F1","sourceRelease":"119-100","text":"Subject to the limitations set forth in paragraphs (2) and (3), an arbitral decision under this section may award the payment of damages or rate prescriptive relief.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Practice disputes","label":"2 .—Practice disputes","identifier":"/us/usc/t49/s11708/g/2","parentIdentifier":"/us/usc/t49/s11708/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fg%2F2","sourceRelease":"119-100","text":"The damage award for practice disputes may not exceed $2,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Rate disputes.—","label":"3 Rate disputes.—","identifier":"/us/usc/t49/s11708/g/3","parentIdentifier":"/us/usc/t49/s11708/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fg%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—Monetary limit","label":"A .—Monetary limit","identifier":"/us/usc/t49/s11708/g/3/A","parentIdentifier":"/us/usc/t49/s11708/g/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fg%2F3%2FA","sourceRelease":"119-100","text":"The damage award for rate disputes, including any rate prescription, may not exceed $25,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Time limit","label":"B .—Time limit","identifier":"/us/usc/t49/s11708/g/3/B","parentIdentifier":"/us/usc/t49/s11708/g/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fg%2F3%2FB","sourceRelease":"119-100","text":"Any rate prescription shall be limited to not longer than 5 years from the date of the arbitral decision.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":".—Board Review","label":"h .—Board Review","identifier":"/us/usc/t49/s11708/h","parentIdentifier":"/us/usc/t49/s11708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s11708/h/1","parentIdentifier":"/us/usc/t49/s11708/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fh%2F1","sourceRelease":"119-100","text":"the decision is consistent with sound principles of rail regulation economics;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s11708/h/2","parentIdentifier":"/us/usc/t49/s11708/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fh%2F2","sourceRelease":"119-100","text":"a clear abuse of arbitral authority or discretion occurred;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s11708/h/3","parentIdentifier":"/us/usc/t49/s11708/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fh%2F3","sourceRelease":"119-100","text":"the decision directly contravenes statutory authority; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s11708/h/4","parentIdentifier":"/us/usc/t49/s11708/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs11708%2Fh%2F4","sourceRelease":"119-100","text":"the award limitation under subsection (g) was violated.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
