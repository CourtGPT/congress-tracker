{"type":"section","nativeType":"section","number":"1386","heading":"Adjustment for partial withdrawal; determination of amount; reduction for partial withdrawal liability; procedures applicable","label":"1386 Adjustment for partial withdrawal; determination of amount; reduction for partial withdrawal liability; procedures applicable","identifier":"/us/usc/t29/s1386","parentIdentifier":"/us/usc/t29/ch18/schIII/stE/pt1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t29/s1386/a","parentIdentifier":"/us/usc/t29/s1386","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s1386/a/1","parentIdentifier":"/us/usc/t29/s1386/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s1386/a/1/A","parentIdentifier":"/us/usc/t29/s1386/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fa%2F1%2FA","sourceRelease":"119-100","text":"on the date of the partial withdrawal, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s1386/a/1/B","parentIdentifier":"/us/usc/t29/s1386/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fa%2F1%2FB","sourceRelease":"119-100","text":"in the case of a partial withdrawal described in (relating to 70-percent contribution decline), on the last day of the first plan year in the 3-year testing period,section 1385(a)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s1386/a/2","parentIdentifier":"/us/usc/t29/s1386/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s1386/a/2/A","parentIdentifier":"/us/usc/t29/s1386/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the numerator of which is the employer’s contribution base units for the plan year following the plan year in which the partial withdrawal occurs, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s1386/a/2/B","parentIdentifier":"/us/usc/t29/s1386/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t29/s1386/a/2/B/i","parentIdentifier":"/us/usc/t29/s1386/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"except as provided in clause (ii), the 5 plan years immediately preceding the plan year in which the partial withdrawal occurs, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t29/s1386/a/2/B/ii","parentIdentifier":"/us/usc/t29/s1386/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"in the case of a partial withdrawal described in (relating to 70-percent contribution decline), the 5 plan years immediately preceding the beginning of the 3-year testing period.section 1385(a)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t29/s1386/b","parentIdentifier":"/us/usc/t29/s1386","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s1386/b/1","parentIdentifier":"/us/usc/t29/s1386/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fb%2F1","sourceRelease":"119-100","text":"In the case of an employer that has withdrawal liability for a partial withdrawal from a plan, any withdrawal liability of that employer for a partial or complete withdrawal from that plan in a subsequent plan year shall be reduced by the amount of any partial withdrawal liability (reduced by any abatement or reduction of such liability) of the employer with respect to the plan for a previous plan year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s1386/b/2","parentIdentifier":"/us/usc/t29/s1386/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s1386/b/2/A","parentIdentifier":"/us/usc/t29/s1386/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fb%2F2%2FA","sourceRelease":"119-100","text":"changes in unfunded vested benefits arising after the close of the prior year for which partial withdrawal liability was determined,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s1386/b/2/B","parentIdentifier":"/us/usc/t29/s1386/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fb%2F2%2FB","sourceRelease":"119-100","text":"changes in contribution base units occurring after the close of the prior year for which partial withdrawal liability was determined, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t29/s1386/b/2/C","parentIdentifier":"/us/usc/t29/s1386/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1386%2Fb%2F2%2FC","sourceRelease":"119-100","text":"any other factors for which it determines adjustment to be appropriate,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
