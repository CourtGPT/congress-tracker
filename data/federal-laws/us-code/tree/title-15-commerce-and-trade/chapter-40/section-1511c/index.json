{"type":"section","nativeType":"section","number":"1511c","heading":"Estuarine Programs Office","label":"1511c Estuarine Programs Office","identifier":"/us/usc/t15/s1511c","parentIdentifier":"/us/usc/t15/ch40","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1511c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t15/s1511c/a","parentIdentifier":"/us/usc/t15/s1511c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1511c%2Fa","sourceRelease":"119-100","text":"The Administrator of the National Oceanic and Atmospheric Administration (hereinafter in this section referred to as the “Administrator”) shall establish within the Administration an Estuarine Programs Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Functions","label":"b Functions","identifier":"/us/usc/t15/s1511c/b","parentIdentifier":"/us/usc/t15/s1511c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1511c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s1511c/b/1","parentIdentifier":"/us/usc/t15/s1511c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1511c%2Fb%2F1","sourceRelease":"119-100","text":"develop and implement a national estuarine strategy for the Administration that integrates the research, regulatory, and trusteeship responsibilities of the Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s1511c/b/2","parentIdentifier":"/us/usc/t15/s1511c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1511c%2Fb%2F2","sourceRelease":"119-100","text":"coordinate the estuarine activities of the various organizations within the Administration, including activities in estuarine research and assessment, fisheries research, coastal management, and habitat conservation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s1511c/b/3","parentIdentifier":"/us/usc/t15/s1511c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1511c%2Fb%2F3","sourceRelease":"119-100","text":"coordinate the estuarine activities of the Administration with the activities of other Federal and State agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s1511c/b/4","parentIdentifier":"/us/usc/t15/s1511c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1511c%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s1511c/b/4/A","parentIdentifier":"/us/usc/t15/s1511c/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1511c%2Fb%2F4%2FA","sourceRelease":"119-100","text":"assessing the condition of estuaries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s1511c/b/4/B","parentIdentifier":"/us/usc/t15/s1511c/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1511c%2Fb%2F4%2FB","sourceRelease":"119-100","text":"identifying estuaries of critical national or regional importance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s1511c/b/4/C","parentIdentifier":"/us/usc/t15/s1511c/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1511c%2Fb%2F4%2FC","sourceRelease":"119-100","text":"identifying technical and management alternatives for the restoration and protection of estuarine resources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s1511c/b/4/D","parentIdentifier":"/us/usc/t15/s1511c/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1511c%2Fb%2F4%2FD","sourceRelease":"119-100","text":"monitoring the implementation and effectiveness of estuarine management plans.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization","label":"c Authorization","identifier":"/us/usc/t15/s1511c/c","parentIdentifier":"/us/usc/t15/s1511c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1511c%2Fc","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Administration not to exceed $500,000 for fiscal year 1987, $530,000 for fiscal year 1988, $560,000 for fiscal year 1989, and $600,000 for fiscal year 1990 to carry out the provisions of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
