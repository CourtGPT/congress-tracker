{"type":"section","nativeType":"section","number":"6503","heading":"Training and monitoring","label":"6503 Training and monitoring","identifier":"/us/usc/t5/s6503","parentIdentifier":"/us/usc/t5/ptIII/sptE/ch65","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6503","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe date of enactment of this chapter, referred to in subsec. (b), is the date of enactment of , which was approved .Pub. L. 111–292Dec. 9, 2010"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t5/s6503/a","parentIdentifier":"/us/usc/t5/s6503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6503%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6503/a/1","parentIdentifier":"/us/usc/t5/s6503/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6503%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s6503/a/1/A","parentIdentifier":"/us/usc/t5/s6503/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6503%2Fa%2F1%2FA","sourceRelease":"119-100","text":"employees eligible to participate in the telework program of the agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s6503/a/1/B","parentIdentifier":"/us/usc/t5/s6503/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6503%2Fa%2F1%2FB","sourceRelease":"119-100","text":"all managers of teleworkers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6503/a/2","parentIdentifier":"/us/usc/t5/s6503/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6503%2Fa%2F2","sourceRelease":"119-100","text":"except as provided under subsection (b), an employee has successfully completed the interactive telework training program before that employee enters into a written agreement to telework described under section 6502(b)(2);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s6503/a/3","parentIdentifier":"/us/usc/t5/s6503/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6503%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s6503/a/3/A","parentIdentifier":"/us/usc/t5/s6503/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6503%2Fa%2F3%2FA","sourceRelease":"119-100","text":"periodic appraisals of job performance of employees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s6503/a/3/B","parentIdentifier":"/us/usc/t5/s6503/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6503%2Fa%2F3%2FB","sourceRelease":"119-100","text":"training, rewarding, reassigning, promoting, reducing in grade, retaining, and removing employees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s6503/a/3/C","parentIdentifier":"/us/usc/t5/s6503/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6503%2Fa%2F3%2FC","sourceRelease":"119-100","text":"work requirements; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t5/s6503/a/3/D","parentIdentifier":"/us/usc/t5/s6503/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6503%2Fa%2F3%2FD","sourceRelease":"119-100","text":"other acts involving managerial discretion; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t5/s6503/a/4","parentIdentifier":"/us/usc/t5/s6503/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6503%2Fa%2F4","sourceRelease":"119-100","text":"when determining what constitutes diminished employee performance, the agency shall consult the performance management guidelines of the Office of Personnel Management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Training Requirement Exemptions","label":"b .—Training Requirement Exemptions","identifier":"/us/usc/t5/s6503/b","parentIdentifier":"/us/usc/t5/s6503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6503%2Fb","sourceRelease":"119-100","text":"The head of an executive agency may provide for an exemption from the training requirements under subsection (a), if the head of that agency determines that the training would be unnecessary because the employee is already teleworking under a work arrangement in effect before the date of enactment of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
