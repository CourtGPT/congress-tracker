{"type":"section","nativeType":"section","number":"16357","heading":"Strategy for facilities and infrastructure","label":"16357 Strategy for facilities and infrastructure","identifier":"/us/usc/t42/s16357","parentIdentifier":"/us/usc/t42/ch149/schIX/ptI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2018—, substituted “Strategy for facilities and infrastructure” for “Strategy and plan for science and energy facilities and infrastructure” in section catchline.Pub. L. 115–246, § 205(a)(1)Subsec. (b)(1). , substituted “2018” for “2008”.Pub. L. 115–246, § 205(a)(2)"],"amendments":["Amendments2018—, substituted “Strategy for facilities and infrastructure” for “Strategy and plan for science and energy facilities and infrastructure” in section catchline.Pub. L. 115–246, § 205(a)(1)Subsec. (b)(1). , substituted “2018” for “2008”.Pub. L. 115–246, § 205(a)(2)"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Facility and infrastructure policy","label":"a Facility and infrastructure policy","identifier":"/us/usc/t42/s16357/a","parentIdentifier":"/us/usc/t42/s16357","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16357/a/1","parentIdentifier":"/us/usc/t42/s16357/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary shall develop and implement a strategy for facilities and infrastructure supported primarily from the Office of Science, the Office of Energy Efficiency and Renewable Energy, the Office of Fossil Energy, or the Office of Nuclear Energy, Science and Technology Programs at all National Laboratories and single-purpose research facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Strategy","label":"2 Strategy","identifier":"/us/usc/t42/s16357/a/2","parentIdentifier":"/us/usc/t42/s16357/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16357/a/2/A","parentIdentifier":"/us/usc/t42/s16357/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fa%2F2%2FA","sourceRelease":"119-100","text":"maintaining existing facilities and infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16357/a/2/B","parentIdentifier":"/us/usc/t42/s16357/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fa%2F2%2FB","sourceRelease":"119-100","text":"closing unneeded facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16357/a/2/C","parentIdentifier":"/us/usc/t42/s16357/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fa%2F2%2FC","sourceRelease":"119-100","text":"making facility modifications; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16357/a/2/D","parentIdentifier":"/us/usc/t42/s16357/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fa%2F2%2FD","sourceRelease":"119-100","text":"building new facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report","label":"b Report","identifier":"/us/usc/t42/s16357/b","parentIdentifier":"/us/usc/t42/s16357","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16357/b/1","parentIdentifier":"/us/usc/t42/s16357/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall prepare and submit, along with the budget request of the President submitted to Congress for fiscal year 2018, a report describing the strategy developed under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t42/s16357/b/2","parentIdentifier":"/us/usc/t42/s16357/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16357/b/2/A","parentIdentifier":"/us/usc/t42/s16357/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the current priority list of proposed facilities and infrastructure projects, including cost and schedule requirements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16357/b/2/B","parentIdentifier":"/us/usc/t42/s16357/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fb%2F2%2FB","sourceRelease":"119-100","text":"a current 10-year plan that demonstrates the reconfiguration of its facilities and infrastructure to meet its missions and to address its long-term operational costs and return on investment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16357/b/2/C","parentIdentifier":"/us/usc/t42/s16357/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fb%2F2%2FC","sourceRelease":"119-100","text":"the total current budget for all facilities and infrastructure funding; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16357/b/2/D","parentIdentifier":"/us/usc/t42/s16357/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16357%2Fb%2F2%2FD","sourceRelease":"119-100","text":"the current status of each facility and infrastructure project compared to the original baseline cost, schedule, and scope.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
