{"type":"section","nativeType":"section","number":"16091a","heading":"Clean school bus program","label":"16091a Clean school bus program","identifier":"/us/usc/t42/s16091a","parentIdentifier":"/us/usc/t42/ch149/schVII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Safe, Accountable, Flexible, Efficient Transportation Equity Act: A Legacy for Users or the SAFETEA–LU, and not as part of the Energy Policy Act of 2005 which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s16091a/a","parentIdentifier":"/us/usc/t42/s16091a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Administrator","label":"1 Administrator","identifier":"/us/usc/t42/s16091a/a/1","parentIdentifier":"/us/usc/t42/s16091a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F1","sourceRelease":"119-100","text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Alternative fuel","label":"2 Alternative fuel","identifier":"/us/usc/t42/s16091a/a/2","parentIdentifier":"/us/usc/t42/s16091a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16091a/a/2/A","parentIdentifier":"/us/usc/t42/s16091a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F2%2FA","sourceRelease":"119-100","text":"liquefied natural gas, compressed natural gas, liquefied petroleum gas, hydrogen, or propane;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16091a/a/2/B","parentIdentifier":"/us/usc/t42/s16091a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F2%2FB","sourceRelease":"119-100","text":"methanol or ethanol at no less than 85 percent by volume; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16091a/a/2/C","parentIdentifier":"/us/usc/t42/s16091a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F2%2FC","sourceRelease":"119-100","text":"biodiesel conforming with standards published by the American Society for Testing and Materials as of .August 10, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Clean school bus","label":"3 Clean school bus","identifier":"/us/usc/t42/s16091a/a/3","parentIdentifier":"/us/usc/t42/s16091a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16091a/a/3/A","parentIdentifier":"/us/usc/t42/s16091a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F3%2FA","sourceRelease":"119-100","text":"is powered by a heavy duty engine; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16091a/a/3/B","parentIdentifier":"/us/usc/t42/s16091a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F3%2FB","sourceRelease":"119-100","text":"is operated solely on an alternative fuel or ultra-low sulfur diesel fuel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Eligible recipient","label":"4 Eligible recipient","identifier":"/us/usc/t42/s16091a/a/4","parentIdentifier":"/us/usc/t42/s16091a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16091a/a/4/A","parentIdentifier":"/us/usc/t42/s16091a/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16091a/a/4/A/i","parentIdentifier":"/us/usc/t42/s16091a/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F4%2FA%2Fi","sourceRelease":"119-100","text":"one or more local or State governmental entities responsible for providing school bus service to one or more public school systems or the purchase of school buses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16091a/a/4/A/ii","parentIdentifier":"/us/usc/t42/s16091a/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F4%2FA%2Fii","sourceRelease":"119-100","text":"one or more contracting entities that provide school bus service to one or more public school systems; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16091a/a/4/A/iii","parentIdentifier":"/us/usc/t42/s16091a/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F4%2FA%2Fiii","sourceRelease":"119-100","text":"a nonprofit school transportation association.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Special requirements","label":"B Special requirements","identifier":"/us/usc/t42/s16091a/a/4/B","parentIdentifier":"/us/usc/t42/s16091a/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F4%2FB","sourceRelease":"119-100","text":"In the case of eligible recipients identified under clauses (ii) and (iii) of subparagraph (A), the Administrator shall establish timely and appropriate requirements for notice and may establish timely and appropriate requirements for approval by the public school systems that would be served by buses purchased or retrofit using grant funds made available under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Retrofit technology","label":"5 Retrofit technology","identifier":"/us/usc/t42/s16091a/a/5","parentIdentifier":"/us/usc/t42/s16091a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F5","sourceRelease":"119-100","text":"The term “retrofit technology” means a particulate filter or other emissions control equipment that is verified or certified by the Administrator or the California Air Resources Board as an effective emission reduction technology when installed on an existing school bus.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Secretary","label":"6 Secretary","identifier":"/us/usc/t42/s16091a/a/6","parentIdentifier":"/us/usc/t42/s16091a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F6","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Ultra-low sulfur diesel fuel","label":"7 Ultra-low sulfur diesel fuel","identifier":"/us/usc/t42/s16091a/a/7","parentIdentifier":"/us/usc/t42/s16091a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fa%2F7","sourceRelease":"119-100","text":"The term “ultra-low sulfur diesel fuel” means diesel fuel that contains sulfur at not more than 15 parts per million.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Program for retrofit or replacement of certain existing school buses with clean school buses","label":"b Program for retrofit or replacement of certain existing school buses with clean school buses","identifier":"/us/usc/t42/s16091a/b","parentIdentifier":"/us/usc/t42/s16091a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t42/s16091a/b/1","parentIdentifier":"/us/usc/t42/s16091a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16091a/b/1/A","parentIdentifier":"/us/usc/t42/s16091a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"The Administrator, in consultation with the Secretary and other appropriate Federal departments and agencies, shall establish a program for awarding grants on a competitive basis to eligible recipients for the replacement of, retrofit (including repowering, aftertreatment, and remanufactured engines) of, or purchase of alternative fuels for, certain existing school buses. The awarding of grants for the purchase of alternative fuels should be consistent with the historic funding levels of the program for such purchase.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Balancing","label":"B Balancing","identifier":"/us/usc/t42/s16091a/b/1/B","parentIdentifier":"/us/usc/t42/s16091a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16091a/b/1/B/i","parentIdentifier":"/us/usc/t42/s16091a/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"to replace school buses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16091a/b/1/B/ii","parentIdentifier":"/us/usc/t42/s16091a/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"to install retrofit technologies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16091a/b/1/B/iii","parentIdentifier":"/us/usc/t42/s16091a/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"to purchase and use alternative fuel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Priority of grant applications","label":"2 Priority of grant applications","identifier":"/us/usc/t42/s16091a/b/2","parentIdentifier":"/us/usc/t42/s16091a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Replacement","label":"A Replacement","identifier":"/us/usc/t42/s16091a/b/2/A","parentIdentifier":"/us/usc/t42/s16091a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F2%2FA","sourceRelease":"119-100","text":"In the case of grant applications to replace school buses, the Administrator shall give priority to applicants that propose to replace school buses manufactured before model year 1977.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Retrofitting","label":"B Retrofitting","identifier":"/us/usc/t42/s16091a/b/2/B","parentIdentifier":"/us/usc/t42/s16091a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F2%2FB","sourceRelease":"119-100","text":"In the case of grant applications to retrofit school buses, the Administrator shall give priority to applicants that propose to retrofit school buses manufactured in or after model year 1991.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Use of school bus fleet","label":"3 Use of school bus fleet","identifier":"/us/usc/t42/s16091a/b/3","parentIdentifier":"/us/usc/t42/s16091a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16091a/b/3/A","parentIdentifier":"/us/usc/t42/s16091a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F3%2FA","sourceRelease":"119-100","text":"All school buses acquired or retrofitted with funds provided under this section shall be operated as part of the school bus fleet for which the grant was made for not less than 5 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Maintenance, operation, and fueling","label":"B Maintenance, operation, and fueling","identifier":"/us/usc/t42/s16091a/b/3/B","parentIdentifier":"/us/usc/t42/s16091a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F3%2FB","sourceRelease":"119-100","text":"New school buses and retrofit technology shall be maintained, operated, and fueled according to manufacturer recommendations or State requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Retrofit grants","label":"4 Retrofit grants","identifier":"/us/usc/t42/s16091a/b/4","parentIdentifier":"/us/usc/t42/s16091a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F4","sourceRelease":"119-100","text":"The Administrator may award grants under this section for up to 100 percent of the retrofit technologies and installation costs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Replacement grants","label":"5 Replacement grants","identifier":"/us/usc/t42/s16091a/b/5","parentIdentifier":"/us/usc/t42/s16091a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Eligibility for 50 percent grants","label":"A Eligibility for 50 percent grants","identifier":"/us/usc/t42/s16091a/b/5/A","parentIdentifier":"/us/usc/t42/s16091a/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F5%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16091a/b/5/A/i","parentIdentifier":"/us/usc/t42/s16091a/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F5%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s16091a/b/5/A/i/I","parentIdentifier":"/us/usc/t42/s16091a/b/5/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F5%2FA%2Fi%2FI","sourceRelease":"119-100","text":"1.8 grams per brake horsepower-hour of non-methane hydrocarbons and oxides of nitrogen; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s16091a/b/5/A/i/II","parentIdentifier":"/us/usc/t42/s16091a/b/5/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F5%2FA%2Fi%2FII","sourceRelease":"119-100","text":".01 grams per brake horsepower-hour of particulate matter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16091a/b/5/A/ii","parentIdentifier":"/us/usc/t42/s16091a/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F5%2FA%2Fii","sourceRelease":"119-100","text":"clean school buses with engines manufactured in model year 2007, 2008, or 2009 that satisfy regulatory requirements established by the Administrator for emissions of oxides of nitrogen and particulate matter to be applicable for school buses manufactured in model year 2010.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Eligibility for 25 percent grants","label":"B Eligibility for 25 percent grants","identifier":"/us/usc/t42/s16091a/b/5/B","parentIdentifier":"/us/usc/t42/s16091a/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F5%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16091a/b/5/B/i","parentIdentifier":"/us/usc/t42/s16091a/b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F5%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s16091a/b/5/B/i/I","parentIdentifier":"/us/usc/t42/s16091a/b/5/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F5%2FB%2Fi%2FI","sourceRelease":"119-100","text":"2.5 grams per brake horsepower-hour of non-methane hydrocarbons and oxides of nitrogen; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s16091a/b/5/B/i/II","parentIdentifier":"/us/usc/t42/s16091a/b/5/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F5%2FB%2Fi%2FII","sourceRelease":"119-100","text":".01 grams per brake horsepower-hour of particulate matter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16091a/b/5/B/ii","parentIdentifier":"/us/usc/t42/s16091a/b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F5%2FB%2Fii","sourceRelease":"119-100","text":"clean school buses with engines manufactured in model year 2007 or thereafter that satisfy regulatory requirements established by the Administrator for emissions of oxides of nitrogen and particulate matter from school buses manufactured in that model year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Ultra-low sulfur diesel fuel","label":"6 Ultra-low sulfur diesel fuel","identifier":"/us/usc/t42/s16091a/b/6","parentIdentifier":"/us/usc/t42/s16091a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general2So in original. No subpar. (B) was enacted.2","label":"A In general2So in original. No subpar. (B) was enacted.2","identifier":"/us/usc/t42/s16091a/b/6/A","parentIdentifier":"/us/usc/t42/s16091a/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F6%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16091a/b/6/A/i","parentIdentifier":"/us/usc/t42/s16091a/b/6/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F6%2FA%2Fi","sourceRelease":"119-100","text":"documentation that diesel fuel containing sulfur at not more than 15 parts per million is available for carrying out the purposes of the grant; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16091a/b/6/A/ii","parentIdentifier":"/us/usc/t42/s16091a/b/6/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F6%2FA%2Fii","sourceRelease":"119-100","text":"a commitment by the applicant to use that fuel in carrying out the purposes of the grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Deployment and distribution","label":"7 Deployment and distribution","identifier":"/us/usc/t42/s16091a/b/7","parentIdentifier":"/us/usc/t42/s16091a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16091a/b/7/A","parentIdentifier":"/us/usc/t42/s16091a/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F7%2FA","sourceRelease":"119-100","text":"achieve nationwide deployment of clean school buses through the program under this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16091a/b/7/B","parentIdentifier":"/us/usc/t42/s16091a/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F7%2FB","sourceRelease":"119-100","text":"ensure a broad geographic distribution of grant awards, with no State receiving more than 10 percent of the grant funding made available under this section during a fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Annual report","label":"8 Annual report","identifier":"/us/usc/t42/s16091a/b/8","parentIdentifier":"/us/usc/t42/s16091a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general2","label":"A In general2","identifier":"/us/usc/t42/s16091a/b/8/A","parentIdentifier":"/us/usc/t42/s16091a/b/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F8%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16091a/b/8/A/i","parentIdentifier":"/us/usc/t42/s16091a/b/8/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F8%2FA%2Fi","sourceRelease":"119-100","text":"evaluates the implementation of this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16091a/b/8/A/ii","parentIdentifier":"/us/usc/t42/s16091a/b/8/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F8%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s16091a/b/8/A/ii/I","parentIdentifier":"/us/usc/t42/s16091a/b/8/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F8%2FA%2Fii%2FI","sourceRelease":"119-100","text":"the total number of grant applications received;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s16091a/b/8/A/ii/II","parentIdentifier":"/us/usc/t42/s16091a/b/8/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F8%2FA%2Fii%2FII","sourceRelease":"119-100","text":"the number and types of alternative fuel school buses, ultra-low sulfur diesel fuel school buses, and retrofitted buses requested in grant applications;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t42/s16091a/b/8/A/ii/III","parentIdentifier":"/us/usc/t42/s16091a/b/8/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F8%2FA%2Fii%2FIII","sourceRelease":"119-100","text":"grants awarded and the criteria used to select the grant recipients;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t42/s16091a/b/8/A/ii/IV","parentIdentifier":"/us/usc/t42/s16091a/b/8/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F8%2FA%2Fii%2FIV","sourceRelease":"119-100","text":"certified engine emission levels of all buses purchased or retrofitted under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t42/s16091a/b/8/A/ii/V","parentIdentifier":"/us/usc/t42/s16091a/b/8/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F8%2FA%2Fii%2FV","sourceRelease":"119-100","text":"an evaluation of the in-use emission level of buses purchased or retrofitted under this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VI","heading":null,"label":"VI","identifier":"/us/usc/t42/s16091a/b/8/A/ii/VI","parentIdentifier":"/us/usc/t42/s16091a/b/8/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fb%2F8%2FA%2Fii%2FVI","sourceRelease":"119-100","text":"any other information the Administrator considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Education","label":"c Education","identifier":"/us/usc/t42/s16091a/c","parentIdentifier":"/us/usc/t42/s16091a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16091a/c/1","parentIdentifier":"/us/usc/t42/s16091a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fc%2F1","sourceRelease":"119-100","text":"Not later than 90 days after , the Administrator shall develop an education outreach program to promote and explain the grant program.August 10, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Coordination with stakeholders","label":"2 Coordination with stakeholders","identifier":"/us/usc/t42/s16091a/c/2","parentIdentifier":"/us/usc/t42/s16091a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fc%2F2","sourceRelease":"119-100","text":"The outreach program shall be designed and conducted in conjunction with national school bus transportation associations and other stakeholders.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Components","label":"3 Components","identifier":"/us/usc/t42/s16091a/c/3","parentIdentifier":"/us/usc/t42/s16091a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16091a/c/3/A","parentIdentifier":"/us/usc/t42/s16091a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fc%2F3%2FA","sourceRelease":"119-100","text":"inform potential grant recipients on the process of applying for grants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16091a/c/3/B","parentIdentifier":"/us/usc/t42/s16091a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fc%2F3%2FB","sourceRelease":"119-100","text":"describe the available technologies and the benefits of the technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16091a/c/3/C","parentIdentifier":"/us/usc/t42/s16091a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fc%2F3%2FC","sourceRelease":"119-100","text":"explain the benefits of participating in the grant program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16091a/c/3/D","parentIdentifier":"/us/usc/t42/s16091a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fc%2F3%2FD","sourceRelease":"119-100","text":"include, as appropriate, information from the annual report required under subsection (b)(8).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s16091a/d","parentIdentifier":"/us/usc/t42/s16091a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16091a/d/1","parentIdentifier":"/us/usc/t42/s16091a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fd%2F1","sourceRelease":"119-100","text":"$55,000,000 for each of fiscal years 2006 and 2007; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16091a/d/2","parentIdentifier":"/us/usc/t42/s16091a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16091a%2Fd%2F2","sourceRelease":"119-100","text":"such sums as are necessary for each of fiscal years 2008, 2009, and 2010.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
