{"type":"section","nativeType":"section","number":"2903","heading":"Conservation plans","label":"2903 Conservation plans","identifier":"/us/usc/t16/s2903","parentIdentifier":"/us/usc/t16/ch49","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2903","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s2903/1","parentIdentifier":"/us/usc/t16/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2903%2F1","sourceRelease":"119-100","text":"provide for the vesting in the designated State agency of the overall responsibility for the development and revision of the conservation plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s2903/2","parentIdentifier":"/us/usc/t16/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2903%2F2","sourceRelease":"119-100","text":"provide for an inventory of the nongame fish and wildlife, and such other fish and wildlife as the designated State agency deems appropriate, that are within the State and are valued for ecological, educational, esthetic, cultural, recreational, economic, or scientific benefits by the public;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s2903/3","parentIdentifier":"/us/usc/t16/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2903%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s2903/3/A","parentIdentifier":"/us/usc/t16/s2903/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2903%2F3%2FA","sourceRelease":"119-100","text":"the determination of the size, range, and distribution of their populations, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s2903/3/B","parentIdentifier":"/us/usc/t16/s2903/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2903%2F3%2FB","sourceRelease":"119-100","text":"the identification of the extent, condition, and location of their significant habitats;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s2903/4","parentIdentifier":"/us/usc/t16/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2903%2F4","sourceRelease":"119-100","text":"identify the significant problems which may adversely affect the plan species and their significant habitats;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s2903/5","parentIdentifier":"/us/usc/t16/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2903%2F5","sourceRelease":"119-100","text":"determine those actions which should be taken to conserve the plan species and their significant habitats;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s2903/6","parentIdentifier":"/us/usc/t16/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2903%2F6","sourceRelease":"119-100","text":"establish priorities for implementing the conservation actions determined under paragraph (5);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t16/s2903/7","parentIdentifier":"/us/usc/t16/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2903%2F7","sourceRelease":"119-100","text":"provide for the monitoring, on a regular basis, of the plan species and the effectiveness of the conservation actions determined under paragraph (5);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t16/s2903/8","parentIdentifier":"/us/usc/t16/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2903%2F8","sourceRelease":"119-100","text":"provide for plan review and revision, if appropriate, at intervals of not more than 3 years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t16/s2903/9","parentIdentifier":"/us/usc/t16/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2903%2F9","sourceRelease":"119-100","text":"ensure that the public be given opportunity to make its views known and considered during the development, revision, and implementation of the plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t16/s2903/10","parentIdentifier":"/us/usc/t16/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2903%2F10","sourceRelease":"119-100","text":"provide that the designated State agency consult, as appropriate, with Federal agencies, and other State agencies during the development, revision, and implementation of the plan, in order to minimize duplication of efforts and to ensure that the best information is available to all such agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
