{"type":"section","nativeType":"section","number":"2114a","heading":"Negotiating objectives with respect to trade in services, foreign direct investment, and high technology products","label":"2114a Negotiating objectives with respect to trade in services, foreign direct investment, and high technology products","identifier":"/us/usc/t19/s2114a","parentIdentifier":"/us/usc/t19/ch12/schI/pt1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Trade in services","label":"a Trade in services","identifier":"/us/usc/t19/s2114a/a","parentIdentifier":"/us/usc/t19/s2114a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t19/s2114a/a/1","parentIdentifier":"/us/usc/t19/s2114a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s2114a/a/1/A","parentIdentifier":"/us/usc/t19/s2114a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fa%2F1%2FA","sourceRelease":"119-100","text":"to reduce or to eliminate barriers to, or other distortions of, international trade in services (particularly United States service sector trade in foreign markets), including barriers that deny national treatment and restrictions on the establishment and operation in such markets; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s2114a/a/1/B","parentIdentifier":"/us/usc/t19/s2114a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s2114a/a/1/B/i","parentIdentifier":"/us/usc/t19/s2114a/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"are consistent with the commercial policies of the United States, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s2114a/a/1/B/ii","parentIdentifier":"/us/usc/t19/s2114a/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"will reduce or eliminate such barriers or distortions and help ensure open international trade in services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Domestic objectives","label":"2 Domestic objectives","identifier":"/us/usc/t19/s2114a/a/2","parentIdentifier":"/us/usc/t19/s2114a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fa%2F2","sourceRelease":"119-100","text":"In pursuing the objectives described in paragraph (1), United States negotiators shall take into account legitimate United States domestic objectives including, but not limited to, the protection of legitimate health or safety, essential security, environmental, consumer or employment opportunity interests and the laws and regulations related thereto.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Foreign direct investment","label":"b Foreign direct investment","identifier":"/us/usc/t19/s2114a/b","parentIdentifier":"/us/usc/t19/s2114a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t19/s2114a/b/1","parentIdentifier":"/us/usc/t19/s2114a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s2114a/b/1/A","parentIdentifier":"/us/usc/t19/s2114a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"to reduce or to eliminate artificial or trade-distorting barriers to foreign direct investment, to expand the principle of national treatment, and to reduce unreasonable barriers to establishment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s2114a/b/1/B","parentIdentifier":"/us/usc/t19/s2114a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s2114a/b/1/B/i","parentIdentifier":"/us/usc/t19/s2114a/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"will help ensure a free flow of foreign direct investment, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s2114a/b/1/B/ii","parentIdentifier":"/us/usc/t19/s2114a/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"will reduce or eliminate the trade distortive effects of certain investment related measures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Domestic objectives","label":"2 Domestic objectives","identifier":"/us/usc/t19/s2114a/b/2","parentIdentifier":"/us/usc/t19/s2114a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fb%2F2","sourceRelease":"119-100","text":"In pursuing the objectives described in paragraph (1), United States negotiators shall take into account legitimate United States domestic objectives including, but not limited to, the protection of legitimate health or safety, essential security, environmental, consumer or employment opportunity interests and the laws and regulations related thereto.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"High technology products","label":"c High technology products","identifier":"/us/usc/t19/s2114a/c","parentIdentifier":"/us/usc/t19/s2114a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s2114a/c/1","parentIdentifier":"/us/usc/t19/s2114a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F1","sourceRelease":"119-100","text":"to obtain and preserve the maximum openness with respect to international trade and investment in high technology products and related services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s2114a/c/2","parentIdentifier":"/us/usc/t19/s2114a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s2114a/c/2/A","parentIdentifier":"/us/usc/t19/s2114a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F2%2FA","sourceRelease":"119-100","text":"foreign industrial policies which distort international trade or investment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s2114a/c/2/B","parentIdentifier":"/us/usc/t19/s2114a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F2%2FB","sourceRelease":"119-100","text":"measures which deny national treatment or otherwise discriminate in favor of domestic high technology industries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t19/s2114a/c/2/C","parentIdentifier":"/us/usc/t19/s2114a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F2%2FC","sourceRelease":"119-100","text":"measures which fail to provide adequate and effective means for foreign nationals to secure, exercise, and enforce exclusive rights in intellectual property (including trademarks, patents, and copyrights);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t19/s2114a/c/2/D","parentIdentifier":"/us/usc/t19/s2114a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F2%2FD","sourceRelease":"119-100","text":"measures which impair access to domestic markets for key commodity products; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t19/s2114a/c/2/E","parentIdentifier":"/us/usc/t19/s2114a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F2%2FE","sourceRelease":"119-100","text":"measures which facilitate or encourage anticompetitive market practices or structures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s2114a/c/3","parentIdentifier":"/us/usc/t19/s2114a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F3","sourceRelease":"119-100","text":"to obtain commitments that official policy of foreign countries or instrumentalities will not discourage government or private procurement of foreign high technology products and related services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t19/s2114a/c/4","parentIdentifier":"/us/usc/t19/s2114a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F4","sourceRelease":"119-100","text":"to obtain the reduction or elimination of all tariffs on, and other barriers to, United States exports of high technology products and related services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t19/s2114a/c/5","parentIdentifier":"/us/usc/t19/s2114a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F5","sourceRelease":"119-100","text":"to obtain commitments to foster national treatment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t19/s2114a/c/6","parentIdentifier":"/us/usc/t19/s2114a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s2114a/c/6/A","parentIdentifier":"/us/usc/t19/s2114a/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F6%2FA","sourceRelease":"119-100","text":"foster the pursuit of joint scientific cooperation between companies, institutions or governmental entities of the United States and those of the trading partners of the United States in areas of mutual interest through such measures as financial participation and technical and personnel exchanges, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s2114a/c/6/B","parentIdentifier":"/us/usc/t19/s2114a/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F6%2FB","sourceRelease":"119-100","text":"ensure that access by all participants to the results of any such cooperative efforts should not be impaired; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t19/s2114a/c/7","parentIdentifier":"/us/usc/t19/s2114a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fc%2F7","sourceRelease":"119-100","text":"to provide effective minimum safeguards for the acquisition and enforcement of intellectual property rights and the property value of proprietary data.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definition of barriers and other distortions","label":"d Definition of barriers and other distortions","identifier":"/us/usc/t19/s2114a/d","parentIdentifier":"/us/usc/t19/s2114a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s2114a/d/1","parentIdentifier":"/us/usc/t19/s2114a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fd%2F1","sourceRelease":"119-100","text":"barriers to establishment in foreign markets, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s2114a/d/2","parentIdentifier":"/us/usc/t19/s2114a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s2114a/d/2/A","parentIdentifier":"/us/usc/t19/s2114a/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fd%2F2%2FA","sourceRelease":"119-100","text":"direct or indirect restrictions on the transfer of information into, or out of, the country or instrumentality concerned, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s2114a/d/2/B","parentIdentifier":"/us/usc/t19/s2114a/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2114a%2Fd%2F2%2FB","sourceRelease":"119-100","text":"restrictions on the use of data processing facilities within or outside of such country or instrumentality.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
