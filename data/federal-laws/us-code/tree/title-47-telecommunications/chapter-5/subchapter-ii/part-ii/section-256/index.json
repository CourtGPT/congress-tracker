{"type":"section","nativeType":"section","number":"256","heading":"Coordination for interconnectivity","label":"256 Coordination for interconnectivity","identifier":"/us/usc/t47/s256","parentIdentifier":"/us/usc/t47/ch5/schII/ptII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purpose","label":"a Purpose","identifier":"/us/usc/t47/s256/a","parentIdentifier":"/us/usc/t47/s256","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s256/a/1","parentIdentifier":"/us/usc/t47/s256/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s256/a/1/A","parentIdentifier":"/us/usc/t47/s256/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256%2Fa%2F1%2FA","sourceRelease":"119-100","text":"coordinated public telecommunications network planning and design by telecommunications carriers and other providers of telecommunications service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s256/a/1/B","parentIdentifier":"/us/usc/t47/s256/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256%2Fa%2F1%2FB","sourceRelease":"119-100","text":"public telecommunications network interconnectivity, and interconnectivity of devices with such networks used to provide telecommunications service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s256/a/2","parentIdentifier":"/us/usc/t47/s256/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256%2Fa%2F2","sourceRelease":"119-100","text":"to ensure the ability of users and information providers to seamlessly and transparently transmit and receive information between and across telecommunications networks.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Commission functions","label":"b Commission functions","identifier":"/us/usc/t47/s256/b","parentIdentifier":"/us/usc/t47/s256","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s256/b/1","parentIdentifier":"/us/usc/t47/s256/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256%2Fb%2F1","sourceRelease":"119-100","text":"shall establish procedures for Commission oversight of coordinated network planning by telecommunications carriers and other providers of telecommunications service for the effective and efficient interconnection of public telecommunications networks used to provide telecommunications service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s256/b/2","parentIdentifier":"/us/usc/t47/s256/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s256/b/2/A","parentIdentifier":"/us/usc/t47/s256/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256%2Fb%2F2%2FA","sourceRelease":"119-100","text":"public telecommunications networks used to provide telecommunications service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s256/b/2/B","parentIdentifier":"/us/usc/t47/s256/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256%2Fb%2F2%2FB","sourceRelease":"119-100","text":"network capabilities and services by individuals with disabilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t47/s256/b/2/C","parentIdentifier":"/us/usc/t47/s256/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256%2Fb%2F2%2FC","sourceRelease":"119-100","text":"information services by subscribers of rural telephone companies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Commission’s authority","label":"c Commission’s authority","identifier":"/us/usc/t47/s256/c","parentIdentifier":"/us/usc/t47/s256","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256%2Fc","sourceRelease":"119-100","text":"Nothing in this section shall be construed as expanding or limiting any authority that the Commission may have under law in effect before .February 8, 1996","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"“Public telecommunications network interconnectivity” defined","label":"d “Public telecommunications network interconnectivity” defined","identifier":"/us/usc/t47/s256/d","parentIdentifier":"/us/usc/t47/s256","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs256%2Fd","sourceRelease":"119-100","text":"As used in this section, the term “public telecommunications network interconnectivity” means the ability of two or more public telecommunications networks used to provide telecommunications service to communicate and exchange information without degeneration, and to interact in concert with one another.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
