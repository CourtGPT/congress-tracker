{"type":"section","nativeType":"section","number":"5104","heading":"State license and registration application and issuance","label":"5104 State license and registration application and issuance","identifier":"/us/usc/t12/s5104","parentIdentifier":"/us/usc/t12/ch51","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Background checks","label":"a Background checks","identifier":"/us/usc/t12/s5104/a","parentIdentifier":"/us/usc/t12/s5104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s5104/a/1","parentIdentifier":"/us/usc/t12/s5104/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fa%2F1","sourceRelease":"119-100","text":"fingerprints for submission to the Federal Bureau of Investigation, and any governmental agency or entity authorized to receive such information for a State and national criminal history background check; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s5104/a/2","parentIdentifier":"/us/usc/t12/s5104/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s5104/a/2/A","parentIdentifier":"/us/usc/t12/s5104/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fa%2F2%2FA","sourceRelease":"119-100","text":"an independent credit report obtained from a consumer reporting agency described in ; andsection 1681a(p) of title 15","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s5104/a/2/B","parentIdentifier":"/us/usc/t12/s5104/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fa%2F2%2FB","sourceRelease":"119-100","text":"information related to any administrative, civil or criminal findings by any governmental jurisdiction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Issuance of license","label":"b Issuance of license","identifier":"/us/usc/t12/s5104/b","parentIdentifier":"/us/usc/t12/s5104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s5104/b/1","parentIdentifier":"/us/usc/t12/s5104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fb%2F1","sourceRelease":"119-100","text":"The applicant has never had a loan originator license revoked in any governmental jurisdiction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s5104/b/2","parentIdentifier":"/us/usc/t12/s5104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s5104/b/2/A","parentIdentifier":"/us/usc/t12/s5104/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fb%2F2%2FA","sourceRelease":"119-100","text":"during the 7-year period preceding the date of the application for licensing and registration; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s5104/b/2/B","parentIdentifier":"/us/usc/t12/s5104/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fb%2F2%2FB","sourceRelease":"119-100","text":"at any time preceding such date of application, if such felony involved an act of fraud, dishonesty, or a breach of trust, or money laundering.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t12/s5104/b/3","parentIdentifier":"/us/usc/t12/s5104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fb%2F3","sourceRelease":"119-100","text":"The applicant has demonstrated financial responsibility, character, and general fitness such as to command the confidence of the community and to warrant a determination that the loan originator will operate honestly, fairly, and efficiently within the purposes of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t12/s5104/b/4","parentIdentifier":"/us/usc/t12/s5104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fb%2F4","sourceRelease":"119-100","text":"The applicant has completed the pre-licensing education requirement described in subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t12/s5104/b/5","parentIdentifier":"/us/usc/t12/s5104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fb%2F5","sourceRelease":"119-100","text":"The applicant has passed a written test that meets the test requirement described in subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t12/s5104/b/6","parentIdentifier":"/us/usc/t12/s5104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fb%2F6","sourceRelease":"119-100","text":"The applicant has met either a net worth or surety bond requirement, or paid into a State fund, as required by the State pursuant to .section 5107(d)(6) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Pre-licensing education of loan originators","label":"c Pre-licensing education of loan originators","identifier":"/us/usc/t12/s5104/c","parentIdentifier":"/us/usc/t12/s5104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Minimum educational requirements","label":"1 Minimum educational requirements","identifier":"/us/usc/t12/s5104/c/1","parentIdentifier":"/us/usc/t12/s5104/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s5104/c/1/A","parentIdentifier":"/us/usc/t12/s5104/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fc%2F1%2FA","sourceRelease":"119-100","text":"3 hours of Federal law and regulations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s5104/c/1/B","parentIdentifier":"/us/usc/t12/s5104/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fc%2F1%2FB","sourceRelease":"119-100","text":"3 hours of ethics, which shall include instruction on fraud, consumer protection, and fair lending issues; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s5104/c/1/C","parentIdentifier":"/us/usc/t12/s5104/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fc%2F1%2FC","sourceRelease":"119-100","text":"2 hours of training related to lending standards for the nontraditional mortgage product marketplace.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Approved educational courses","label":"2 Approved educational courses","identifier":"/us/usc/t12/s5104/c/2","parentIdentifier":"/us/usc/t12/s5104/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fc%2F2","sourceRelease":"119-100","text":"For purposes of paragraph (1), pre-licensing education courses shall be reviewed, and approved by the Nationwide Mortgage Licensing System and Registry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Limitation and standards","label":"3 Limitation and standards","identifier":"/us/usc/t12/s5104/c/3","parentIdentifier":"/us/usc/t12/s5104/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Limitation","label":"A Limitation","identifier":"/us/usc/t12/s5104/c/3/A","parentIdentifier":"/us/usc/t12/s5104/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fc%2F3%2FA","sourceRelease":"119-100","text":"To maintain the independence of the approval process, the Nationwide Mortgage Licensing System and Registry shall not directly or indirectly offer pre-licensure educational courses for loan originators.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Standards","label":"B Standards","identifier":"/us/usc/t12/s5104/c/3/B","parentIdentifier":"/us/usc/t12/s5104/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fc%2F3%2FB","sourceRelease":"119-100","text":"In approving courses under this section, the Nationwide Mortgage Licensing System and Registry shall apply reasonable standards in the review and approval of courses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Testing of loan originators","label":"d Testing of loan originators","identifier":"/us/usc/t12/s5104/d","parentIdentifier":"/us/usc/t12/s5104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t12/s5104/d/1","parentIdentifier":"/us/usc/t12/s5104/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fd%2F1","sourceRelease":"119-100","text":"In order to meet the written test requirement referred to in subsection (b)(5), an individual shall pass, in accordance with the standards established under this subsection, a qualified written test developed by the Nationwide Mortgage Licensing System and Registry and administered by an approved test provider.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Qualified test","label":"2 Qualified test","identifier":"/us/usc/t12/s5104/d/2","parentIdentifier":"/us/usc/t12/s5104/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s5104/d/2/A","parentIdentifier":"/us/usc/t12/s5104/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fd%2F2%2FA","sourceRelease":"119-100","text":"ethics;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s5104/d/2/B","parentIdentifier":"/us/usc/t12/s5104/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fd%2F2%2FB","sourceRelease":"119-100","text":"Federal law and regulation pertaining to mortgage origination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s5104/d/2/C","parentIdentifier":"/us/usc/t12/s5104/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fd%2F2%2FC","sourceRelease":"119-100","text":"State law and regulation pertaining to mortgage origination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t12/s5104/d/2/D","parentIdentifier":"/us/usc/t12/s5104/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fd%2F2%2FD","sourceRelease":"119-100","text":"Federal and State law and regulation, including instruction on fraud, consumer protection, the nontraditional mortgage marketplace, and fair lending issues.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Minimum competence","label":"3 Minimum competence","identifier":"/us/usc/t12/s5104/d/3","parentIdentifier":"/us/usc/t12/s5104/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Passing score","label":"A Passing score","identifier":"/us/usc/t12/s5104/d/3/A","parentIdentifier":"/us/usc/t12/s5104/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fd%2F3%2FA","sourceRelease":"119-100","text":"An individual shall not be considered to have passed a qualified written test unless the individual achieves a test score of not less than 75 percent correct answers to questions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Initial retests","label":"B Initial retests","identifier":"/us/usc/t12/s5104/d/3/B","parentIdentifier":"/us/usc/t12/s5104/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fd%2F3%2FB","sourceRelease":"119-100","text":"An individual may retake a test 3 consecutive times with each consecutive taking occurring at least 30 days after the preceding test.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Subsequent retests","label":"C Subsequent retests","identifier":"/us/usc/t12/s5104/d/3/C","parentIdentifier":"/us/usc/t12/s5104/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fd%2F3%2FC","sourceRelease":"119-100","text":"After failing 3 consecutive tests, an individual shall wait at least 6 months before taking the test again.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Retest after lapse of license","label":"D Retest after lapse of license","identifier":"/us/usc/t12/s5104/d/3/D","parentIdentifier":"/us/usc/t12/s5104/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fd%2F3%2FD","sourceRelease":"119-100","text":"A State-licensed loan originator who fails to maintain a valid license for a period of 5 years or longer shall retake the test, not taking into account any time during which such individual is a registered loan originator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Mortgage call reports","label":"e Mortgage call reports","identifier":"/us/usc/t12/s5104/e","parentIdentifier":"/us/usc/t12/s5104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5104%2Fe","sourceRelease":"119-100","text":"Each mortgage licensee shall submit to the Nationwide Mortgage Licensing System and Registry reports of condition, which shall be in such form and shall contain such information as the Nationwide Mortgage Licensing System and Registry may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
