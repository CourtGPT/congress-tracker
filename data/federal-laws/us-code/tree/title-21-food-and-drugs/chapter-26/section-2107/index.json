{"type":"section","nativeType":"section","number":"2107","heading":"Sense of Congress","label":"2107 Sense of Congress","identifier":"/us/usc/t21/s2107","parentIdentifier":"/us/usc/t21/ch26","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2107","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s2107/1","parentIdentifier":"/us/usc/t21/s2107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2107%2F1","sourceRelease":"119-100","text":"it is vital for Congress to provide the Food and Drug Administration with additional resources, authorities, and direction with respect to ensuring the safety of the food supply of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s2107/2","parentIdentifier":"/us/usc/t21/s2107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2107%2F2","sourceRelease":"119-100","text":"additional inspectors are required to improve the Food and Drug Administration’s ability to safeguard the food supply of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t21/s2107/3","parentIdentifier":"/us/usc/t21/s2107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2107%2F3","sourceRelease":"119-100","text":"because of the increasing volume of international trade in food products the Secretary should make it a priority to enter into agreements with the trading partners of the United States with respect to food safety; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t21/s2107/4","parentIdentifier":"/us/usc/t21/s2107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2107%2F4","sourceRelease":"119-100","text":"Congress should work to develop a comprehensive response to the issue of food safety.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
