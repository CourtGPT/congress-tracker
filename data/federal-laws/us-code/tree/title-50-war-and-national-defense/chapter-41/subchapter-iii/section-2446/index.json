{"type":"section","nativeType":"section","number":"2446","heading":"Treatment of contractors who engage in improper program management","label":"2446 Treatment of contractors who engage in improper program management","identifier":"/us/usc/t50/s2446","parentIdentifier":"/us/usc/t50/ch41/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2446","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t50/s2446/a","parentIdentifier":"/us/usc/t50/s2446","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2446%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2446/a/1","parentIdentifier":"/us/usc/t50/s2446/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2446%2Fa%2F1","sourceRelease":"119-100","text":"an explanation as to whether termination of the contract is an appropriate remedy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2446/a/2","parentIdentifier":"/us/usc/t50/s2446/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2446%2Fa%2F2","sourceRelease":"119-100","text":"a description of the terms of the contract regarding award fees and performance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s2446/a/3","parentIdentifier":"/us/usc/t50/s2446/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2446%2Fa%2F3","sourceRelease":"119-100","text":"a description of how the Secretary or the Administrator, as the case may be, plans to exercise options under the contract.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Exception","label":"b Exception","identifier":"/us/usc/t50/s2446/b","parentIdentifier":"/us/usc/t50/s2446","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2446%2Fb","sourceRelease":"119-100","text":"If the Secretary or the Administrator, as the case may be, is not able to submit the information described in paragraphs (1) through (3) of subsection (a) by reason of a contract enforcement action, the Secretary or the Administrator, as the case may be, shall submit to the appropriate congressional committees a notification of such contract enforcement action and the date on which the Secretary or the Administrator, as the case may be, plans to submit the information described in such paragraphs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Definitions","label":"c Definitions","identifier":"/us/usc/t50/s2446/c","parentIdentifier":"/us/usc/t50/s2446","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2446%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2446/c/1","parentIdentifier":"/us/usc/t50/s2446/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2446%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s2446/c/1/A","parentIdentifier":"/us/usc/t50/s2446/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2446%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the congressional defense committees; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s2446/c/1/B","parentIdentifier":"/us/usc/t50/s2446/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2446%2Fc%2F1%2FB","sourceRelease":"119-100","text":"the Committee on Energy and Commerce of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2446/c/2","parentIdentifier":"/us/usc/t50/s2446/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2446%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s2446/c/2/A","parentIdentifier":"/us/usc/t50/s2446/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2446%2Fc%2F2%2FA","sourceRelease":"119-100","text":"a contractor of the Administration; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s2446/c/2/B","parentIdentifier":"/us/usc/t50/s2446/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2446%2Fc%2F2%2FB","sourceRelease":"119-100","text":"a contractor of an element of the Department of Energy (other than the Administration) involved in nuclear security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
