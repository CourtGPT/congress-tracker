{"type":"section","nativeType":"section","number":"6294b","heading":"WaterSense program","label":"6294b WaterSense program","identifier":"/us/usc/t42/s6294b","parentIdentifier":"/us/usc/t42/ch77/schIII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment of WaterSense program","label":"a Establishment of WaterSense program","identifier":"/us/usc/t42/s6294b/a","parentIdentifier":"/us/usc/t42/s6294b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s6294b/a/1","parentIdentifier":"/us/usc/t42/s6294b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6294b/a/1/A","parentIdentifier":"/us/usc/t42/s6294b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F1%2FA","sourceRelease":"119-100","text":"reduce water use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6294b/a/1/B","parentIdentifier":"/us/usc/t42/s6294b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F1%2FB","sourceRelease":"119-100","text":"reduce the strain on public water systems, community water systems, and wastewater and stormwater infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6294b/a/1/C","parentIdentifier":"/us/usc/t42/s6294b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F1%2FC","sourceRelease":"119-100","text":"conserve energy used to pump, heat, transport, and treat water; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6294b/a/1/D","parentIdentifier":"/us/usc/t42/s6294b/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F1%2FD","sourceRelease":"119-100","text":"preserve water resources for future generations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Inclusions","label":"2 Inclusions","identifier":"/us/usc/t42/s6294b/a/2","parentIdentifier":"/us/usc/t42/s6294b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6294b/a/2/A","parentIdentifier":"/us/usc/t42/s6294b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F2%2FA","sourceRelease":"119-100","text":"irrigation technologies and services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6294b/a/2/B","parentIdentifier":"/us/usc/t42/s6294b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F2%2FB","sourceRelease":"119-100","text":"point-of-use water treatment devices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6294b/a/2/C","parentIdentifier":"/us/usc/t42/s6294b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F2%2FC","sourceRelease":"119-100","text":"plumbing products;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6294b/a/2/D","parentIdentifier":"/us/usc/t42/s6294b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F2%2FD","sourceRelease":"119-100","text":"water reuse and recycling technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s6294b/a/2/E","parentIdentifier":"/us/usc/t42/s6294b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F2%2FE","sourceRelease":"119-100","text":"landscaping and gardening products, including moisture control or water enhancing technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s6294b/a/2/F","parentIdentifier":"/us/usc/t42/s6294b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F2%2FF","sourceRelease":"119-100","text":"xeriscaping and other landscape conversions that reduce water use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s6294b/a/2/G","parentIdentifier":"/us/usc/t42/s6294b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F2%2FG","sourceRelease":"119-100","text":"whole house humidifiers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t42/s6294b/a/2/H","parentIdentifier":"/us/usc/t42/s6294b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fa%2F2%2FH","sourceRelease":"119-100","text":"water-efficient buildings or facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties","label":"b Duties","identifier":"/us/usc/t42/s6294b/b","parentIdentifier":"/us/usc/t42/s6294b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6294b/b/1","parentIdentifier":"/us/usc/t42/s6294b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6294b/b/1/A","parentIdentifier":"/us/usc/t42/s6294b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F1%2FA","sourceRelease":"119-100","text":"a WaterSense label to be used for products, buildings, landscapes, facilities, processes, and services meeting the certification criteria established pursuant to this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6294b/b/1/B","parentIdentifier":"/us/usc/t42/s6294b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the procedure, including the methods and means, and criteria by which products, buildings, landscapes, facilities, processes, and services may be certified to display the WaterSense label;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6294b/b/2","parentIdentifier":"/us/usc/t42/s6294b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F2","sourceRelease":"119-100","text":"enhance public awareness regarding the WaterSense label through outreach and public education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s6294b/b/3","parentIdentifier":"/us/usc/t42/s6294b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6294b/b/3/A","parentIdentifier":"/us/usc/t42/s6294b/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F3%2FA","sourceRelease":"119-100","text":"establishing and maintaining feasible performance criteria so that products, buildings, landscapes, facilities, processes, and services certified to display the WaterSense label perform as well or better than less water-efficient counterparts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6294b/b/3/B","parentIdentifier":"/us/usc/t42/s6294b/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F3%2FB","sourceRelease":"119-100","text":"overseeing WaterSense certifications made by third parties, which shall be independent third-party product certification bodies accredited by an accreditation entity domiciled in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6294b/b/3/C","parentIdentifier":"/us/usc/t42/s6294b/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F3%2FC","sourceRelease":"119-100","text":"using testing protocols, from the appropriate, applicable, and relevant consensus standards, for the purpose of determining compliance with performance criteria; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6294b/b/3/D","parentIdentifier":"/us/usc/t42/s6294b/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F3%2FD","sourceRelease":"119-100","text":"auditing the use of the WaterSense label in the marketplace and preventing cases of misuse;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s6294b/b/4","parentIdentifier":"/us/usc/t42/s6294b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F4","sourceRelease":"119-100","text":"not more frequently than every 6 years after adoption or major revision of any WaterSense performance criteria, review and, if appropriate, revise the performance criteria to achieve additional water savings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s6294b/b/5","parentIdentifier":"/us/usc/t42/s6294b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6294b/b/5/A","parentIdentifier":"/us/usc/t42/s6294b/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F5%2FA","sourceRelease":"119-100","text":"provide reasonable notice to interested parties and the public of any changes, including effective dates, and an explanation of the changes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6294b/b/5/B","parentIdentifier":"/us/usc/t42/s6294b/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F5%2FB","sourceRelease":"119-100","text":"solicit comments from interested parties and the public prior to any changes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6294b/b/5/C","parentIdentifier":"/us/usc/t42/s6294b/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F5%2FC","sourceRelease":"119-100","text":"as appropriate, respond to comments submitted by interested parties and the public; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6294b/b/5/D","parentIdentifier":"/us/usc/t42/s6294b/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F5%2FD","sourceRelease":"119-100","text":"provide an appropriate transition time prior to the applicable effective date of any changes, taking into account the timing necessary for the manufacture, marketing, training, and distribution of the specific product, building, landscape, process, or service category being addressed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s6294b/b/6","parentIdentifier":"/us/usc/t42/s6294b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fb%2F6","sourceRelease":"119-100","text":"not later than , consider for review and revise, if necessary, any WaterSense performance criteria adopted before .December 31, 2019January 1, 2012","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Transparency","label":"c Transparency","identifier":"/us/usc/t42/s6294b/c","parentIdentifier":"/us/usc/t42/s6294b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fc","sourceRelease":"119-100","text":"The Administrator of the Environmental Protection Agency shall, to the extent practicable and not less than annually, estimate and make available to the public the relative water and energy savings attributable to the use of WaterSense-labeled products, buildings, landscapes, facilities, processes, and services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Distinction of authorities","label":"d Distinction of authorities","identifier":"/us/usc/t42/s6294b/d","parentIdentifier":"/us/usc/t42/s6294b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fd","sourceRelease":"119-100","text":"In setting or maintaining specifications and criteria for Energy Star pursuant to , and WaterSense under this section, the Secretary of Energy and the Administrator of the Environmental Protection Agency shall coordinate to prevent duplicative or conflicting requirements among the respective programs.section 6294a of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"No warranty","label":"e No warranty","identifier":"/us/usc/t42/s6294b/e","parentIdentifier":"/us/usc/t42/s6294b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fe","sourceRelease":"119-100","text":"A WaterSense label shall not create any express or implied warranty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Methods for establishing performance criteria","label":"f Methods for establishing performance criteria","identifier":"/us/usc/t42/s6294b/f","parentIdentifier":"/us/usc/t42/s6294b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Ff","sourceRelease":"119-100","text":"In establishing performance criteria for products, buildings, landscapes, facilities, processes, or services pursuant to this section, the Administrator of the Environmental Protection Agency shall use technical specifications and testing protocols established by voluntary consensus standards organizations relevant to specific products, buildings, landscapes, facilities, processes, or services, as appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Definition of feasible","label":"g Definition of feasible","identifier":"/us/usc/t42/s6294b/g","parentIdentifier":"/us/usc/t42/s6294b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294b%2Fg","sourceRelease":"119-100","text":"The term “feasible” means feasible with the use of the best technology, techniques, and other means that the Administrator of the Environmental Protection Agency finds, after examination for efficacy under field conditions and not solely under laboratory conditions, are available (taking cost into consideration).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
