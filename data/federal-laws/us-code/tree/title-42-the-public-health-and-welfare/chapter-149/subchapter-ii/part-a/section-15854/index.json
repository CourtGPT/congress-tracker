{"type":"section","nativeType":"section","number":"15854","heading":"Sugar Cane Ethanol Program","label":"15854 Sugar Cane Ethanol Program","identifier":"/us/usc/t42/s15854","parentIdentifier":"/us/usc/t42/ch149/schII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definition of program","label":"a Definition of program","identifier":"/us/usc/t42/s15854/a","parentIdentifier":"/us/usc/t42/s15854","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854%2Fa","sourceRelease":"119-100","text":"In this section, the term “program” means the Sugar Cane Ethanol Program established by subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t42/s15854/b","parentIdentifier":"/us/usc/t42/s15854","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854%2Fb","sourceRelease":"119-100","text":"There is established within the Environmental Protection Agency a program to be known as the “Sugar Cane Ethanol Program”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Project","label":"c Project","identifier":"/us/usc/t42/s15854/c","parentIdentifier":"/us/usc/t42/s15854","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s15854/c/1","parentIdentifier":"/us/usc/t42/s15854/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15854/c/1/A","parentIdentifier":"/us/usc/t42/s15854/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s15854/c/1/A/i","parentIdentifier":"/us/usc/t42/s15854/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"in each of which is produced cane sugar that is eligible for loans under , or a similar subsequent authority; andsection 7272 of title 7","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s15854/c/1/A/ii","parentIdentifier":"/us/usc/t42/s15854/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"at the option of each such State, that have an incentive program that requires the use of ethanol in the State; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15854/c/1/B","parentIdentifier":"/us/usc/t42/s15854/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854%2Fc%2F1%2FB","sourceRelease":"119-100","text":"designed to study the production of ethanol from cane sugar, sugarcane, and sugarcane byproducts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t42/s15854/c/2","parentIdentifier":"/us/usc/t42/s15854/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15854/c/2/A","parentIdentifier":"/us/usc/t42/s15854/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854%2Fc%2F2%2FA","sourceRelease":"119-100","text":"be limited to sugar producers and the production of ethanol in the States of Florida, Louisiana, Texas, and Hawaii, divided equally among the States, to demonstrate that the process may be applicable to cane sugar, sugarcane, and sugarcane byproducts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15854/c/2/B","parentIdentifier":"/us/usc/t42/s15854/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854%2Fc%2F2%2FB","sourceRelease":"119-100","text":"include information on the ways in which the scale of production may be replicated once the sugar cane industry has located sites for, and constructed, ethanol production facilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s15854/c/2/C","parentIdentifier":"/us/usc/t42/s15854/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854%2Fc%2F2%2FC","sourceRelease":"119-100","text":"not last more than 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s15854/d","parentIdentifier":"/us/usc/t42/s15854","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15854%2Fd","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $36,000,000, to remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
