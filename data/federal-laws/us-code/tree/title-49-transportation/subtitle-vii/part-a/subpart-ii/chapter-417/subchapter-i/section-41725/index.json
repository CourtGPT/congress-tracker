{"type":"section","nativeType":"section","number":"41725","heading":"Prohibition on certain cell phone voice communications","label":"41725 Prohibition on certain cell phone voice communications","identifier":"/us/usc/t49/s41725","parentIdentifier":"/us/usc/t49/stVII/ptA/sptii/ch417/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs41725","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Prohibition","label":"a .—Prohibition","identifier":"/us/usc/t49/s41725/a","parentIdentifier":"/us/usc/t49/s41725","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs41725%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s41725/a/1","parentIdentifier":"/us/usc/t49/s41725/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs41725%2Fa%2F1","sourceRelease":"119-100","text":"to prohibit an individual on an aircraft from engaging in voice communications using a mobile communications device during a flight of that aircraft in scheduled passenger interstate or intrastate air transportation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s41725/a/2","parentIdentifier":"/us/usc/t49/s41725/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs41725%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s41725/a/2/A","parentIdentifier":"/us/usc/t49/s41725/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs41725%2Fa%2F2%2FA","sourceRelease":"119-100","text":"member of the flight crew on duty on an aircraft;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s41725/a/2/B","parentIdentifier":"/us/usc/t49/s41725/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs41725%2Fa%2F2%2FB","sourceRelease":"119-100","text":"flight attendant on duty on an aircraft; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s41725/a/2/C","parentIdentifier":"/us/usc/t49/s41725/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs41725%2Fa%2F2%2FC","sourceRelease":"119-100","text":"Federal law enforcement officer acting in an official capacity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Definitions","label":"b .—Definitions","identifier":"/us/usc/t49/s41725/b","parentIdentifier":"/us/usc/t49/s41725","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs41725%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Flight","label":"1 .—Flight","identifier":"/us/usc/t49/s41725/b/1","parentIdentifier":"/us/usc/t49/s41725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs41725%2Fb%2F1","sourceRelease":"119-100","text":"The term “flight” means, with respect to an aircraft, the period beginning when the aircraft takes off and ending when the aircraft lands.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Mobile communications device.—","label":"2 Mobile communications device.—","identifier":"/us/usc/t49/s41725/b/2","parentIdentifier":"/us/usc/t49/s41725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs41725%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t49/s41725/b/2/A","parentIdentifier":"/us/usc/t49/s41725/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs41725%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The term “mobile communications device” means any portable wireless telecommunications equipment utilized for the transmission or reception of voice data.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Limitation","label":"B .—Limitation","identifier":"/us/usc/t49/s41725/b/2/B","parentIdentifier":"/us/usc/t49/s41725/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs41725%2Fb%2F2%2FB","sourceRelease":"119-100","text":"The term “mobile communications device” does not include a phone installed on an aircraft.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
