{"type":"section","nativeType":"section","number":"2734e","heading":"Annual Report","label":"2734e Annual Report","identifier":"/us/usc/t22/s2734e","parentIdentifier":"/us/usc/t22/ch38","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2734e","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s2734e/1","parentIdentifier":"/us/usc/t22/s2734e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2734e%2F1","sourceRelease":"119-100","text":"A rationale for the use of assignment restrictions by the Department of State, including specific case studies related to cleared United States Foreign Service and civil service employees of the Department that demonstrate country-specific restrictions serve a counterintelligence role beyond that which is already covered by the security clearance process.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s2734e/2","parentIdentifier":"/us/usc/t22/s2734e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2734e%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s2734e/2/A","parentIdentifier":"/us/usc/t22/s2734e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2734e%2F2%2FA","sourceRelease":"119-100","text":"identification as a Foreign Service officer, civil service employee, eligible family member, or other employment status;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s2734e/2/B","parentIdentifier":"/us/usc/t22/s2734e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2734e%2F2%2FB","sourceRelease":"119-100","text":"the ethnicity, national origin, and race of the precluded employee;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s2734e/2/C","parentIdentifier":"/us/usc/t22/s2734e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2734e%2F2%2FC","sourceRelease":"119-100","text":"gender; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s2734e/2/D","parentIdentifier":"/us/usc/t22/s2734e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2734e%2F2%2FD","sourceRelease":"119-100","text":"the country of restriction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s2734e/3","parentIdentifier":"/us/usc/t22/s2734e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2734e%2F3","sourceRelease":"119-100","text":"A description of the considerations and criteria used by the Bureau of Diplomatic Security to determine whether an assignment restriction is warranted.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s2734e/4","parentIdentifier":"/us/usc/t22/s2734e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2734e%2F4","sourceRelease":"119-100","text":"The number of restrictions that were appealed and the success rate of such appeals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"