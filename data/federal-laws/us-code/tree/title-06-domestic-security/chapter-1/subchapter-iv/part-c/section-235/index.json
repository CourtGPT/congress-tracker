{"type":"section","nativeType":"section","number":"235","heading":"Coordination of information and information technology","label":"235 Coordination of information and information technology","identifier":"/us/usc/t6/s235","parentIdentifier":"/us/usc/t6/ch1/schIV/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs235","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definition of affected agency","label":"a Definition of affected agency","identifier":"/us/usc/t6/s235/a","parentIdentifier":"/us/usc/t6/s235","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs235%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s235/a/1","parentIdentifier":"/us/usc/t6/s235/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs235%2Fa%2F1","sourceRelease":"119-100","text":"the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s235/a/2","parentIdentifier":"/us/usc/t6/s235/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs235%2Fa%2F2","sourceRelease":"119-100","text":"the Department of Agriculture;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s235/a/3","parentIdentifier":"/us/usc/t6/s235/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs235%2Fa%2F3","sourceRelease":"119-100","text":"the Department of Health and Human Services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"pa