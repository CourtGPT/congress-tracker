h","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s7914/c/1/I","parentIdentifier":"/us/usc/t7/s7914/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fc%2F1%2FI","sourceRelease":"119-100","text":"Other oilseeds, $0.0980 per pound.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Subsequent crop years","label":"2 Subsequent crop years","identifier":"/us/usc/t7/s7914/c/2","parentIdentifier":"/us/usc/t7/s7914/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7914/c/2/A","parentIdentifier":"/us/usc/t7/s7914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fc%2F2%2FA","sourceRelease":"119-100","text":"Wheat, $3.92 per bushel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7914/c/2/B","parentIdentifier":"/us/usc/t7/s7914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fc%2F2%2FB","sourceRelease":"119-100","text":"Corn, $2.63 per bushel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s7914/c/2/C","parentIdentifier":"/us/usc/t7/s7914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fc%2F2%2FC","sourceRelease":"119-100","text":"Grain sorghum, $2.57 per bushel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s7914/c/2/D","parentIdentifier":"/us/usc/t7/s7914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fc%2F2%2FD","sourceRelease":"119-100","text":"Barley, $2.24 per bushel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s7914/c/2/E","parentIdentifier":"/us/usc/t7/s7914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fc%2F2%2FE","sourceRelease":"119-100","text":"Oats, $1.44 per bushel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t7/s7914/c/2/F","parentIdentifier":"/us/usc/t7/s7914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fc%2F2%2FF","sourceRelease":"119-100","text":"Upland cotton, $0.7240 per pound.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t7/s7914/c/2/G","parentIdentifier":"/us/usc/t7/s7914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fc%2F2%2FG","sourceRelease":"119-100","text":"Rice, $10.50 per hundredweight.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t7/s7914/c/2/H","parentIdentifier":"/us/usc/t7/s7914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fc%2F2%2FH","sourceRelease":"119-100","text":"Soybeans, $5.80 per bushel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s7914/c/2/I","parentIdentifier":"/us/usc/t7/s7914/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fc%2F2%2FI","sourceRelease":"119-100","text":"Other oilseeds, $0.1010 per pound.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Payment rate","label":"d Payment rate","identifier":"/us/usc/t7/s7914/d","parentIdentifier":"/us/usc/t7/s7914","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7914/d/1","parentIdentifier":"/us/usc/t7/s7914/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fd%2F1","sourceRelease":"119-100","text":"the target price for the covered commodity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7914/d/2","parentIdentifier":"/us/usc/t7/s7914/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fd%2F2","sourceRelease":"119-100","text":"the effective price determined under subsection (b) for the covered commodity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Payment amount","label":"e Payment amount","identifier":"/us/usc/t7/s7914/e","parentIdentifier":"/us/usc/t7/s7914","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7914/e/1","parentIdentifier":"/us/usc/t7/s7914/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fe%2F1","sourceRelease":"119-100","text":"The payment rate specified in subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7914/e/2","parentIdentifier":"/us/usc/t7/s7914/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fe%2F2","sourceRelease":"119-100","text":"The payment acres of the covered commodity on the farm.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7914/e/3","parentIdentifier":"/us/usc/t7/s7914/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Fe%2F3","sourceRelease":"119-100","text":"The payment yield or updated payment yield for the farm, depending on the election of the owner of the farm under .section 7912 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Time for payments","label":"f Time for payments","identifier":"/us/usc/t7/s7914/f","parentIdentifier":"/us/usc/t7/s7914","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"General rule","label":"1 General rule","identifier":"/us/usc/t7/s7914/f/1","parentIdentifier":"/us/usc/t7/s7914/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F1","sourceRelease":"119-100","text":"If the Secretary determines under subsection (a) that counter-cyclical payments are required to be made under this section for the crop of a covered commodity, the Secretary shall make the counter-cyclical payments for the crop as soon as practicable after the end of the 12-month marketing year for the covered commodity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Availability of partial payments","label":"2 Availability of partial payments","identifier":"/us/usc/t7/s7914/f/2","parentIdentifier":"/us/usc/t7/s7914/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F2","sourceRelease":"119-100","text":"If, before the end of the 12-month marketing year for a covered commodity, the Secretary estimates that counter-cyclical payments will be required for the crop of the covered commodity, the Secretary shall give producers on a farm the option to receive partial payments of the counter-cyclical payment projected to be made for that crop of the covered commodity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Time for partial payments","label":"3 Time for partial payments","identifier":"/us/usc/t7/s7914/f/3","parentIdentifier":"/us/usc/t7/s7914/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"2002 through 2006 crop years","label":"A 2002 through 2006 crop years","identifier":"/us/usc/t7/s7914/f/3/A","parentIdentifier":"/us/usc/t7/s7914/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s7914/f/3/A/i","parentIdentifier":"/us/usc/t7/s7914/f/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F3%2FA%2Fi","sourceRelease":"119-100","text":"the first partial payment for the crop year shall be made not earlier than October 1, and, to the maximum extent practicable, not later than October 31, of the calendar year in which the crop of the covered commodity is harvested;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s7914/f/3/A/ii","parentIdentifier":"/us/usc/t7/s7914/f/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F3%2FA%2Fii","sourceRelease":"119-100","text":"the second partial payment shall be made not earlier than February 1 of the next calendar year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s7914/f/3/A/iii","parentIdentifier":"/us/usc/t7/s7914/f/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"the final partial payment shall be made as soon as practicable after the end of the 12-month marketing year for the covered commodity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"2007 crop year","label":"B 2007 crop year","identifier":"/us/usc/t7/s7914/f/3/B","parentIdentifier":"/us/usc/t7/s7914/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s7914/f/3/B/i","parentIdentifier":"/us/usc/t7/s7914/f/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F3%2FB%2Fi","sourceRelease":"119-100","text":"the first partial payment shall be made after completion of the first 6 months of the marketing year for the covered commodity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s7914/f/3/B/ii","parentIdentifier":"/us/usc/t7/s7914/f/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F3%2FB%2Fii","sourceRelease":"119-100","text":"the final partial payment shall be made as soon as practicable after the end of the 12-month marketing year for the covered commodity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Amount of partial payments","label":"4 Amount of partial payments","identifier":"/us/usc/t7/s7914/f/4","parentIdentifier":"/us/usc/t7/s7914/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"2002 through 2006 crop years","label":"A 2002 through 2006 crop years","identifier":"/us/usc/t7/s7914/f/4/A","parentIdentifier":"/us/usc/t7/s7914/f/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"First partial payment","label":"i First partial payment","identifier":"/us/usc/t7/s7914/f/4/A/i","parentIdentifier":"/us/usc/t7/s7914/f/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4%2FA%2Fi","sourceRelease":"119-100","text":"For each of the 2002 through 2006 crop years of a covered commodity, the first partial payment under paragraph (3) to the producers on a farm may not exceed 35 percent of the projected counter-cyclical payment for the covered commodity for the crop year, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Second partial payment","label":"ii Second partial payment","identifier":"/us/usc/t7/s7914/f/4/A/ii","parentIdentifier":"/us/usc/t7/s7914/f/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s7914/f/4/A/ii/I","parentIdentifier":"/us/usc/t7/s7914/f/4/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4%2FA%2Fii%2FI","sourceRelease":"119-100","text":"70 percent of the projected counter-cyclical payment (including any revision thereof) for the crop of the covered commodity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s7914/f/4/A/ii/II","parentIdentifier":"/us/usc/t7/s7914/f/4/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4%2FA%2Fii%2FII","sourceRelease":"119-100","text":"the amount of the payment made under clause (i).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":"Final payment","label":"iii Final payment","identifier":"/us/usc/t7/s7914/f/4/A/iii","parentIdentifier":"/us/usc/t7/s7914/f/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s7914/f/4/A/iii/I","parentIdentifier":"/us/usc/t7/s7914/f/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"the actual counter-cyclical payment to be made to the producers for the covered commodity for that crop year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s7914/f/4/A/iii/II","parentIdentifier":"/us/usc/t7/s7914/f/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"the amount of the partial payments made to the producers under clauses (i) and (ii) for that crop year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"2007 crop year","label":"B 2007 crop year","identifier":"/us/usc/t7/s7914/f/4/B","parentIdentifier":"/us/usc/t7/s7914/f/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"First partial payment","label":"i First partial payment","identifier":"/us/usc/t7/s7914/f/4/B/i","parentIdentifier":"/us/usc/t7/s7914/f/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4%2FB%2Fi","sourceRelease":"119-100","text":"For the 2007 crop year, the first partial payment under paragraph (3) to the producers on a farm may not exceed 40 percent of the projected counter-cyclical payment for the covered commodity for the crop year, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Final payment","label":"ii Final payment","identifier":"/us/usc/t7/s7914/f/4/B/ii","parentIdentifier":"/us/usc/t7/s7914/f/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s7914/f/4/B/ii/I","parentIdentifier":"/us/usc/t7/s7914/f/4/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4%2FB%2Fii%2FI","sourceRelease":"119-100","text":"the actual counter-cyclical payment to be made to the producers for the covered commodity for that crop year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s7914/f/4/B/ii/II","parentIdentifier":"/us/usc/t7/s7914/f/4/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F4%2FB%2Fii%2FII","sourceRelease":"119-100","text":"the amount of the partial payment made to the producers under clause (i).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Repayment","label":"5 Repayment","identifier":"/us/usc/t7/s7914/f/5","parentIdentifier":"/us/usc/t7/s7914/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7914%2Ff%2F5","sourceRelease":"119-100","text":"The producers on a farm that receive a partial payment under this subsection for a crop year shall repay to the Secretary the amount, if any, by which the total of the partial payments exceed the actual counter-cyclical payment to be made for the covered commodity for that crop year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
