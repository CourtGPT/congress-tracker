{"type":"section","nativeType":"section","number":"1644h","heading":"Certification of amounts; priority of payments","label":"1644h Certification of amounts; priority of payments","identifier":"/us/usc/t22/s1644h","parentIdentifier":"/us/usc/t22/ch21/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1644h","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t22/s1644h/a","parentIdentifier":"/us/usc/t22/s1644h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1644h%2Fa","sourceRelease":"119-100","text":"The Commission shall certify to the Secretary of the Treasury, in terms of United States currency, each award made pursuant to .section 1644b of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t22/s1644h/b","parentIdentifier":"/us/usc/t22/s1644h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1644h%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s1644h/b/1","parentIdentifier":"/us/usc/t22/s1644h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1644h%2Fb%2F1","sourceRelease":"119-100","text":"payment in full of the principal amount of each award of $1,000 or less;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s1644h/b/2","parentIdentifier":"/us/usc/t22/s1644h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1644h%2Fb%2F2","sourceRelease":"119-100","text":"payment in the amount of $1,000 on account of the principal amount of each award of more than $1,000 in principal amount;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s1644h/b/3","parentIdentifier":"/us/usc/t22/s1644h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1644h%2Fb%2F3","sourceRelease":"119-100","text":"thereafter, payments from time to time, in ratable proportions, on account of the unpaid balance of the principal amounts of all awards according to the proportions which the unpaid balance of such awards bear to the total amount in the fund available for distribution at the time such payments are made;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s1644h/b/4","parentIdentifier":"/us/usc/t22/s1644h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1644h%2Fb%2F4","sourceRelease":"119-100","text":"after payment has been made in full of the principal amounts of all awards, pro rata payments may be made on account of any interest that may be allowed on such awards;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s1644h/b/5","parentIdentifier":"/us/usc/t22/s1644h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1644h%2Fb%2F5","sourceRelease":"119-100","text":"payments or applications for payments shall be made in accordance with such regulations as the Secretary of the Treasury may prescribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
