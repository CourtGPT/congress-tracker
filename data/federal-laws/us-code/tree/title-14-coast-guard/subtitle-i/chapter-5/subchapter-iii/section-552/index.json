{"type":"section","nativeType":"section","number":"552","heading":"Discontinuance of aid to navigation","label":"552 Discontinuance of aid to navigation","identifier":"/us/usc/t14/s552","parentIdentifier":"/us/usc/t14/stI/ch5/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe date of enactment of this section, referred to in subsec. (a), is the date of enactment of , which was approved .Pub. L. 119–60Dec. 18, 2025"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t14/s552/a","parentIdentifier":"/us/usc/t14/s552","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fa","sourceRelease":"119-100","text":"Not later than 180 days after the date of enactment of this section, the Secretary shall establish a process for the discontinuance of an aid to navigation (other than a seasonal or temporary aid) established, maintained, or operated by the Coast Guard.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Requirement","label":"b .—Requirement","identifier":"/us/usc/t14/s552/b","parentIdentifier":"/us/usc/t14/s552","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s552/b/1","parentIdentifier":"/us/usc/t14/s552/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fb%2F1","sourceRelease":"119-100","text":"to notify the public of any discontinuance of an aid to navigation described in that subsection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s552/b/2","parentIdentifier":"/us/usc/t14/s552/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fb%2F2","sourceRelease":"119-100","text":"to safeguard against any discontinuation that may compromise the safety of mariners or the public or hinder maritime operational readiness, including with respect to food security and maritime transportation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Consultation","label":"c .—Consultation","identifier":"/us/usc/t14/s552/c","parentIdentifier":"/us/usc/t14/s552","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s552/c/1","parentIdentifier":"/us/usc/t14/s552/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fc%2F1","sourceRelease":"119-100","text":"the Navigation Safety Advisory Council; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s552/c/2","parentIdentifier":"/us/usc/t14/s552/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t14/s552/c/2/A","parentIdentifier":"/us/usc/t14/s552/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs552%2Fc%2F2%2FA","sourceRelease":"119-100","text":"State agencies;","note