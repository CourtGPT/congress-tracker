{"type":"section","nativeType":"section","number":"9076","heading":"Limitation on certain employee compensation","label":"9076 Limitation on certain employee compensation","identifier":"/us/usc/t15/s9076","parentIdentifier":"/us/usc/t15/ch116/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9076","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s9076/a","parentIdentifier":"/us/usc/t15/s9076","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9076%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9076/a/1","parentIdentifier":"/us/usc/t15/s9076/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9076%2Fa%2F1","sourceRelease":"119-100","text":"will receive from the air carrier or contractor total compensation which exceeds, during any 12 consecutive months of such 2-year period, the total compensation received by the officer or employee from the air carrier or contractor in calendar year 2019;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9076/a/2","parentIdentifier":"/us/usc/t15/s9076/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9076%2Fa%2F2","sourceRelease":"119-100","text":"will receive from the air carrier or contractor severance pay or other benefits upon termination of employment with the air carrier or contractor which exceeds twice the maximum total compensation received by the officer or employee from the air carrier or contractor in calendar year 2019; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s9076/a/3","parentIdentifier":"/us/usc/t15/s9076/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9076%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9076/a/3/A","parentIdentifier":"/us/usc/t15/s9076/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9076%2Fa%2F3%2FA","sourceRelease":"119-100","text":"$3,000,000; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9076/a/3/B","parentIdentifier":"/us/usc/t15/s9076/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9076%2Fa%2F3%2FB","sourceRelease":"119-100","text":"50 percent of the excess over $3,000,000 of the total compensation received by the officer or employee from the eligible business in calendar year 2019.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Total compensation defined","label":"b Total compensation defined","identifier":"/us/usc/t15/s9076/b","parentIdentifier":"/us/usc/t15/s9076","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9076%2Fb","sourceRelease":"119-100","text":"In this section, the term “total compensation” includes salary, bonuses, awards of stock, and other financial benefits provided by an air carrier or contractor to an officer or employee of the air carrier or contractor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
