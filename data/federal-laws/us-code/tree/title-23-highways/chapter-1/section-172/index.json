on of Wildlife Collision and Carcass Data.—","label":"c Standardization of Wildlife Collision and Carcass Data.—","identifier":"/us/usc/t23/s172/c","parentIdentifier":"/us/usc/t23/s172","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Standardized methodology.—","label":"1 Standardized methodology.—","identifier":"/us/usc/t23/s172/c/1","parentIdentifier":"/us/usc/t23/s172/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t23/s172/c/1/A","parentIdentifier":"/us/usc/t23/s172/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FA","sourceRelease":"119-100","text":"The Secretary, acting through the Administrator of the Federal Highway Administration (referred to in this subsection as the “Secretary”), shall develop a quality standardized methodology for collecting and reporting spatially accurate wildlife collision and carcass data for the National Highway System, considering the practicability of the methodology with respect to technology and cost.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Methodology","label":"B .—Methodology","identifier":"/us/usc/t23/s172/c/1/B","parentIdentifier":"/us/usc/t23/s172/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t23/s172/c/1/B/i","parentIdentifier":"/us/usc/t23/s172/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"survey existing methodologies and sources of data collection, including the Fatality Analysis Reporting System, the General Estimates System of the National Automotive Sampling System, and the Highway Safety Information System; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t23/s172/c/1/B/ii","parentIdentifier":"/us/usc/t23/s172/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"to the extent practicable, identify and correct limitations of those existing methodologies and sources of data collection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":".—Consultation","label":"C .—Consultation","identifier":"/us/usc/t23/s172/c/1/C","parentIdentifier":"/us/usc/t23/s172/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t23/s172/c/1/C/i","parentIdentifier":"/us/usc/t23/s172/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FC%2Fi","sourceRelease":"119-100","text":"the Secretary of the Interior;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t23/s172/c/1/C/ii","parentIdentifier":"/us/usc/t23/s172/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FC%2Fii","sourceRelease":"119-100","text":"the Secretary of Agriculture, acting through the Chief of the Forest Service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t23/s172/c/1/C/iii","parentIdentifier":"/us/usc/t23/s172/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"Tribal, State, and local transportation and wildlife authorities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t23/s172/c/1/C/iv","parentIdentifier":"/us/usc/t23/s172/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FC%2Fiv","sourceRelease":"119-100","text":"metropolitan planning organizations (as defined in section 134(b));","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t23/s172/c/1/C/v","parentIdentifier":"/us/usc/t23/s172/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FC%2Fv","sourceRelease":"119-100","text":"members of the American Association of State Highway Transportation Officials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t23/s172/c/1/C/vi","parentIdentifier":"/us/usc/t23/s172/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FC%2Fvi","sourceRelease":"119-100","text":"members of the Association of Fish and Wildlife Agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t23/s172/c/1/C/vii","parentIdentifier":"/us/usc/t23/s172/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FC%2Fvii","sourceRelease":"119-100","text":"experts in the field of wildlife-vehicle collisions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t23/s172/c/1/C/viii","parentIdentifier":"/us/usc/t23/s172/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FC%2Fviii","sourceRelease":"119-100","text":"nongovernmental organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ix","heading":null,"label":"ix","identifier":"/us/usc/t23/s172/c/1/C/ix","parentIdentifier":"/us/usc/t23/s172/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F1%2FC%2Fix","sourceRelease":"119-100","text":"other interested stakeholders, as appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Standardized national data system with voluntary template implementation","label":"2 .—Standardized national data system with voluntary template implementation","identifier":"/us/usc/t23/s172/c/2","parentIdentifier":"/us/usc/t23/s172/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t23/s172/c/2/A","parentIdentifier":"/us/usc/t23/s172/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F2%2FA","sourceRelease":"119-100","text":"develop a template for State implementation of a standardized national wildlife collision and carcass data system for the National Highway System that is based on the standardized methodology developed under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t23/s172/c/2/B","parentIdentifier":"/us/usc/t23/s172/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F2%2FB","sourceRelease":"119-100","text":"encourage the voluntary implementation of the template developed under subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Reports.—","label":"3 Reports.—","identifier":"/us/usc/t23/s172/c/3","parentIdentifier":"/us/usc/t23/s172/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—Methodology","label":"A .—Methodology","identifier":"/us/usc/t23/s172/c/3/A","parentIdentifier":"/us/usc/t23/s172/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t23/s172/c/3/A/i","parentIdentifier":"/us/usc/t23/s172/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F3%2FA%2Fi","sourceRelease":"119-100","text":"the date that is 18 months after the date of enactment of the Surface Transportation Reauthorization Act of 2021; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t23/s172/c/3/A/ii","parentIdentifier":"/us/usc/t23/s172/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F3%2FA%2Fii","sourceRelease":"119-100","text":"the date that is 180 days after the date on which the Secretary completes the development of the standardized methodology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Implementation","label":"B .—Implementation","identifier":"/us/usc/t23/s172/c/3/B","parentIdentifier":"/us/usc/t23/s172/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t23/s172/c/3/B/i","parentIdentifier":"/us/usc/t23/s172/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":"the status of the voluntary implementation of the standardized methodology developed under paragraph (1) and the template developed under paragraph (2)(A);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t23/s172/c/3/B/ii","parentIdentifier":"/us/usc/t23/s172/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t23/s172/c/3/B/ii/I","parentIdentifier":"/us/usc/t23/s172/c/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F3%2FB%2Fii%2FI","sourceRelease":"119-100","text":"to reduce the number of wildlife-vehicle collisions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t23/s172/c/3/B/ii/II","parentIdentifier":"/us/usc/t23/s172/c/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F3%2FB%2Fii%2FII","sourceRelease":"119-100","text":"to improve habitat connectivity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t23/s172/c/3/B/iii","parentIdentifier":"/us/usc/t23/s172/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"the degree of the impact described in clause (ii); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t23/s172/c/3/B/iv","parentIdentifier":"/us/usc/t23/s172/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fc%2F3%2FB%2Fiv","sourceRelease":"119-100","text":"the recommendations of the Secretary, including recommendations for further study aimed at reducing motorist collisions involving wildlife and improving habitat connectivity for terrestrial and aquatic species on the National Highway System, if any.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—National Threshold Guidance","label":"d .—National Threshold Guidance","identifier":"/us/usc/t23/s172/d","parentIdentifier":"/us/usc/t23/s172","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t23/s172/d/1","parentIdentifier":"/us/usc/t23/s172/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t23/s172/d/1/A","parentIdentifier":"/us/usc/t23/s172/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the number of wildlife-vehicle collisions on the highway that pose a human safety risk;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t23/s172/d/1/B","parentIdentifier":"/us/usc/t23/s172/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fd%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t23/s172/d/1/B/i","parentIdentifier":"/us/usc/t23/s172/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fd%2F1%2FB%2Fi","sourceRelease":"119-100","text":"species listed as endangered species or threatened species under the Endangered Species Act of 1973 ( et seq.);16 U.S.C. 1531","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t23/s172/d/1/B/ii","parentIdentifier":"/us/usc/t23/s172/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fd%2F1%2FB%2Fii","sourceRelease":"119-100","text":"species identified by a State as species of greatest conservation need;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t23/s172/d/1/B/iii","parentIdentifier":"/us/usc/t23/s172/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fd%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"species identified in State wildlife plans; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t23/s172/d/1/B/iv","parentIdentifier":"/us/usc/t23/s172/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fd%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"medium and small terrestrial and aquatic species; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t23/s172/d/1/C","parentIdentifier":"/us/usc/t23/s172/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft23%2Fs172%2Fd%2F1%2FC","sourceRelease":"119-100","text":"habitat connectivity values for terrestrial and aquatic species and the barrier effect of the highway on the movements and migrations of those species.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
