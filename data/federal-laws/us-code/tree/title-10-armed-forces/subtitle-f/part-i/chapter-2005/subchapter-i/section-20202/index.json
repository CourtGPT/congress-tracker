{"type":"section","nativeType":"section","number":"20202","heading":"Original appointments: qualifications","label":"20202 Original appointments: qualifications","identifier":"/us/usc/t10/s20202","parentIdentifier":"/us/usc/t10/stF/ptI/ch2005/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20202","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t10/s20202/a","parentIdentifier":"/us/usc/t10/s20202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20202%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s20202/a/1","parentIdentifier":"/us/usc/t10/s20202/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20202%2Fa%2F1","sourceRelease":"119-100","text":"is a citizen of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s20202/a/2","parentIdentifier":"/us/usc/t10/s20202/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20202%2Fa%2F2","sourceRelease":"119-100","text":"is at least 18 years of age; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s20202/a/3","parentIdentifier":"/us/usc/t10/s20202/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20202%2Fa%2F3","sourceRelease":"119-100","text":"has such other physical, mental, moral, professional, and age qualifications as the Secretary of the Air Force may prescribe by regulation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Exception","label":"b .—Exception","identifier":"/us/usc/t10/s20202/b","parentIdentifier":"/us/usc/t10/s20202","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20202%2Fb","sourceRelease":"119-100","text":"A person who is otherwise qualified, but who has a physical condition that the Secretary of the Air Force determines will not interfere with the performance of the duties to which that person may be assigned, may be appointed as an officer in the Space Force.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
