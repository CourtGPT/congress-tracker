{"type":"section","nativeType":"section","number":"17115","heading":"Technical assistance program to implement industrial emissions reduction","label":"17115 Technical assistance program to implement industrial emissions reduction","identifier":"/us/usc/t42/s17115","parentIdentifier":"/us/usc/t42/ch152/schIII/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s17115/a","parentIdentifier":"/us/usc/t42/s17115","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible entity","label":"1 Eligible entity","identifier":"/us/usc/t42/s17115/a/1","parentIdentifier":"/us/usc/t42/s17115/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17115/a/1/A","parentIdentifier":"/us/usc/t42/s17115/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fa%2F1%2FA","sourceRelease":"119-100","text":"a State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17115/a/1/B","parentIdentifier":"/us/usc/t42/s17115/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fa%2F1%2FB","sourceRelease":"119-100","text":"a unit of local government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17115/a/1/C","parentIdentifier":"/us/usc/t42/s17115/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fa%2F1%2FC","sourceRelease":"119-100","text":"a territory or possession of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17115/a/1/D","parentIdentifier":"/us/usc/t42/s17115/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fa%2F1%2FD","sourceRelease":"119-100","text":"a relevant State or local office, including an energy office;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17115/a/1/E","parentIdentifier":"/us/usc/t42/s17115/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fa%2F1%2FE","sourceRelease":"119-100","text":"a tribal organization (as defined in );section 3765 of title 38","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17115/a/1/F","parentIdentifier":"/us/usc/t42/s17115/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fa%2F1%2FF","sourceRelease":"119-100","text":"an institution of higher education; and1So in original.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s17115/a/1/G","parentIdentifier":"/us/usc/t42/s17115/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fa%2F1%2FG","sourceRelease":"119-100","text":"a private entity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t42/s17115/a/1/H","parentIdentifier":"/us/usc/t42/s17115/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fa%2F1%2FH","sourceRelease":"119-100","text":"a trade association or technical society.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Emissions reduction","label":"2 Emissions reduction","identifier":"/us/usc/t42/s17115/a/2","parentIdentifier":"/us/usc/t42/s17115/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fa%2F2","sourceRelease":"119-100","text":"The term “emissions reduction” has the meaning given the term in .section 17113(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Program","label":"3 Program","identifier":"/us/usc/t42/s17115/a/3","parentIdentifier":"/us/usc/t42/s17115/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fa%2F3","sourceRelease":"119-100","text":"The term “program” means the program established under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t42/s17115/b","parentIdentifier":"/us/usc/t42/s17115","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fb","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary shall establish a program to provide technical assistance to eligible entities to promote the commercial application of emission reduction technologies developed through the program established in .December 27, 2020section 17113(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Applications","label":"c Applications","identifier":"/us/usc/t42/s17115/c","parentIdentifier":"/us/usc/t42/s17115","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17115/c/1","parentIdentifier":"/us/usc/t42/s17115/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fc%2F1","sourceRelease":"119-100","text":"An eligible entity desiring technical assistance under the program shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Application process","label":"2 Application process","identifier":"/us/usc/t42/s17115/c/2","parentIdentifier":"/us/usc/t42/s17115/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fc%2F2","sourceRelease":"119-100","text":"The Secretary shall seek applications for technical assistance under the program on a periodic basis, but not less frequently than once every 12 months.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Factors for consideration","label":"3 Factors for consideration","identifier":"/us/usc/t42/s17115/c/3","parentIdentifier":"/us/usc/t42/s17115/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17115/c/3/A","parentIdentifier":"/us/usc/t42/s17115/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fc%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17115/c/3/A/i","parentIdentifier":"/us/usc/t42/s17115/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fc%2F3%2FA%2Fi","sourceRelease":"119-100","text":"activities carried out with technical assistance under the program that have the greatest potential for achieving emissions reduction in nonpower industrial sectors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17115/c/3/A/ii","parentIdentifier":"/us/usc/t42/s17115/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fc%2F3%2FA%2Fii","sourceRelease":"119-100","text":"activities carried out in a State in which there are active or inactive industrial facilities that may be used or retrofitted to carry out activities under the focus areas described in ; andsection 17113(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s17115/c/3/A/iii","parentIdentifier":"/us/usc/t42/s17115/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fc%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"activities carried out in an economically distressed area (as described in ); andsection 3161(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17115/c/3/B","parentIdentifier":"/us/usc/t42/s17115/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17115/c/3/B/i","parentIdentifier":"/us/usc/t42/s17115/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":"there is geographic diversity among the eligible entities selected; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17115/c/3/B/ii","parentIdentifier":"/us/usc/t42/s17115/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":"the activities carried out with technical assistance under the program reflect a majority of the focus areas described in .section 17113(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
