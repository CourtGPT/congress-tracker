{"type":"section","nativeType":"section","number":"6294a","heading":"Energy Star program","label":"6294a Energy Star program","identifier":"/us/usc/t42/s6294a","parentIdentifier":"/us/usc/t42/ch77/schIII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2007—Subsec. (d)(2). substituted “” for “”.Pub. L. 110–140July 1, 2009January 1, 2010","Statutory Notes and Related Subsidiaries","Effective Date of 2007 AmendmentAmendment by effective on the date that is 1 day after , see , set out as an Effective Date note under , The Congress.Pub. L. 110–140section 1601 of Pub. L. 110–140section 1824 of Title 2Dec. 19, 2007"],"amendments":["Amendments2007—Subsec. (d)(2). substituted “” for “”.Pub. L. 110–140July 1, 2009January 1, 2010","Effective Date of 2007 AmendmentAmendment by effective on the date that is 1 day after , see , set out as an Effective Date note under , The Congress.Pub. L. 110–140section 1601 of Pub. L. 110–140section 1824 of Title 2Dec. 19, 2007"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s6294a/a","parentIdentifier":"/us/usc/t42/s6294a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fa","sourceRelease":"119-100","text":"There is established within the Department of Energy and the Environmental Protection Agency a voluntary program to identify and promote energy-efficient products and buildings in order to reduce energy consumption, improve energy security, and reduce pollution through voluntary labeling of, or other forms of communication about, products and buildings that meet the highest energy conservation standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Division of responsibilities","label":"b Division of responsibilities","identifier":"/us/usc/t42/s6294a/b","parentIdentifier":"/us/usc/t42/s6294a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fb","sourceRelease":"119-100","text":"Responsibilities under the program shall be divided between the Department of Energy and the Environmental Protection Agency in accordance with the terms of applicable agreements between those agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duties","label":"c Duties","identifier":"/us/usc/t42/s6294a/c","parentIdentifier":"/us/usc/t42/s6294a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6294a/c/1","parentIdentifier":"/us/usc/t42/s6294a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6294a/c/1/A","parentIdentifier":"/us/usc/t42/s6294a/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fc%2F1%2FA","sourceRelease":"119-100","text":"achieving energy efficiency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6294a/c/1/B","parentIdentifier":"/us/usc/t42/s6294a/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fc%2F1%2FB","sourceRelease":"119-100","text":"reducing pollution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6294a/c/2","parentIdentifier":"/us/usc/t42/s6294a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fc%2F2","sourceRelease":"119-100","text":"work to enhance public awareness of the Energy Star label, including by providing special outreach to small businesses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s6294a/c/3","parentIdentifier":"/us/usc/t42/s6294a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fc%2F3","sourceRelease":"119-100","text":"preserve the integrity of the Energy Star label;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s6294a/c/4","parentIdentifier":"/us/usc/t42/s6294a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fc%2F4","sourceRelease":"119-100","text":"regularly update Energy Star product criteria for product categories;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s6294a/c/5","parentIdentifier":"/us/usc/t42/s6294a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fc%2F5","sourceRelease":"119-100","text":"solicit comments from interested parties prior to establishing or revising an Energy Star product category, specification, or criterion (or prior to effective dates for any such product category, specification, or criterion);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s6294a/c/6","parentIdentifier":"/us/usc/t42/s6294a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fc%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6294a/c/6/A","parentIdentifier":"/us/usc/t42/s6294a/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fc%2F6%2FA","sourceRelease":"119-100","text":"an explanation of the changes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6294a/c/6/B","parentIdentifier":"/us/usc/t42/s6294a/c/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fc%2F6%2FB","sourceRelease":"119-100","text":"as appropriate, responses to comments submitted by interested parties; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s6294a/c/7","parentIdentifier":"/us/usc/t42/s6294a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fc%2F7","sourceRelease":"119-100","text":"provide appropriate lead time (which shall be 270 days, unless the Agency or Department specifies otherwise) prior to the applicable effective date for a new or a significant revision to a product category, specification, or criterion, taking into account the timing requirements of the manufacturing, product marketing, and distribution process for the specific product addressed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Deadlines","label":"d Deadlines","identifier":"/us/usc/t42/s6294a/d","parentIdentifier":"/us/usc/t42/s6294a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6294a/d/1","parentIdentifier":"/us/usc/t42/s6294a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fd%2F1","sourceRelease":"119-100","text":"not later than , for clothes washers and dishwashers, effective beginning ; andJanuary 1, 2006January 1, 2007","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6294a/d/2","parentIdentifier":"/us/usc/t42/s6294a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6294a%2Fd%2F2","sourceRelease":"119-100","text":"not later than , for clothes washers, effective beginning .January 1, 2008July 1, 2009","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
