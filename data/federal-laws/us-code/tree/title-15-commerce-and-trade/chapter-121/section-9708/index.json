{"type":"section","nativeType":"section","number":"9708","heading":"Interagency Committee on Water Management and Infrastructure","label":"9708 Interagency Committee on Water Management and Infrastructure","identifier":"/us/usc/t15/s9708","parentIdentifier":"/us/usc/t15/ch121","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t15/s9708/a","parentIdentifier":"/us/usc/t15/s9708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fa","sourceRelease":"119-100","text":"There is established a committee, to be known as the “Interagency Committee on Water Management and Infrastructure” (in this section referred to as the “Water Policy Committee”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Membership","label":"b Membership","identifier":"/us/usc/t15/s9708/b","parentIdentifier":"/us/usc/t15/s9708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9708/b/1","parentIdentifier":"/us/usc/t15/s9708/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fb%2F1","sourceRelease":"119-100","text":"The Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9708/b/2","parentIdentifier":"/us/usc/t15/s9708/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary of the Interior.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s9708/b/3","parentIdentifier":"/us/usc/t15/s9708/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fb%2F3","sourceRelease":"119-100","text":"The Administrator of the Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s9708/b/4","parentIdentifier":"/us/usc/t15/s9708/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fb%2F4","sourceRelease":"119-100","text":"The Secretary of Agriculture.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s9708/b/5","parentIdentifier":"/us/usc/t15/s9708/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fb%2F5","sourceRelease":"119-100","text":"The Secretary of Commerce.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s9708/b/6","parentIdentifier":"/us/usc/t15/s9708/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fb%2F6","sourceRelease":"119-100","text":"The Secretary of Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t15/s9708/b/7","parentIdentifier":"/us/usc/t15/s9708/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fb%2F7","sourceRelease":"119-100","text":"The Secretary of the Army.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t15/s9708/b/8","parentIdentifier":"/us/usc/t15/s9708/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fb%2F8","sourceRelease":"119-100","text":"The heads of such other agencies as the co-chairs consider appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Co-chairs","label":"c Co-chairs","identifier":"/us/usc/t15/s9708/c","parentIdentifier":"/us/usc/t15/s9708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fc","sourceRelease":"119-100","text":"The Water Policy Committee shall be co-chaired by the Secretary of the Interior and the Administrator of the Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Meetings","label":"d Meetings","identifier":"/us/usc/t15/s9708/d","parentIdentifier":"/us/usc/t15/s9708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fd","sourceRelease":"119-100","text":"The Water Policy Committee shall meet not less frequently than 6 times each year, at the call of the co-chairs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"General purpose and duties","label":"e General purpose and duties","identifier":"/us/usc/t15/s9708/e","parentIdentifier":"/us/usc/t15/s9708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9708/e/1","parentIdentifier":"/us/usc/t15/s9708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fe%2F1","sourceRelease":"119-100","text":"improve interagency coordination among Federal agencies and departments on water resource management and water infrastructure issues;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9708/e/2","parentIdentifier":"/us/usc/t15/s9708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fe%2F2","sourceRelease":"119-100","text":"coordinate existing water-related Federal task forces, working groups, and other formal cross-agency initiatives, as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s9708/e/3","parentIdentifier":"/us/usc/t15/s9708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fe%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9708/e/3/A","parentIdentifier":"/us/usc/t15/s9708/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fe%2F3%2FA","sourceRelease":"119-100","text":"increasing water storage, water supply reliability, and drought resiliency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9708/e/3/B","parentIdentifier":"/us/usc/t15/s9708/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fe%2F3%2FB","sourceRelease":"119-100","text":"improving water quality, source water protection, and nutrient management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9708/e/3/C","parentIdentifier":"/us/usc/t15/s9708/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fe%2F3%2FC","sourceRelease":"119-100","text":"promoting restoration activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s9708/e/3/D","parentIdentifier":"/us/usc/t15/s9708/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fe%2F3%2FD","sourceRelease":"119-100","text":"improving water systems, including with respect to drinking water, desalination, water reuse, wastewater, and flood control; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s9708/e/3/E","parentIdentifier":"/us/usc/t15/s9708/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fe%2F3%2FE","sourceRelease":"119-100","text":"improving water data management, research, modeling, and forecasting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s9708/e/4","parentIdentifier":"/us/usc/t15/s9708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fe%2F4","sourceRelease":"119-100","text":"improve interagency coordination of data management, access, modeling, and visualization with respect to water-related matters;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s9708/e/5","parentIdentifier":"/us/usc/t15/s9708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fe%2F5","sourceRelease":"119-100","text":"promote integrated planning for Federal investments in water-related infrastructure to enhance coordination and protect taxpayer investment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s9708/e/6","parentIdentifier":"/us/usc/t15/s9708/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Fe%2F6","sourceRelease":"119-100","text":"support workforce development and efforts to recruit, train, and retain professionals to operate and maintain essential drinking water, wastewater, flood control, hydropower, water delivery, and water storage facilities in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Cross-agency priority research needs","label":"f Cross-agency priority research needs","identifier":"/us/usc/t15/s9708/f","parentIdentifier":"/us/usc/t15/s9708","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9708%2Ff","sourceRelease":"119-100","text":"Not later than 1 year after , the Water Policy Committee shall develop and submit to Congress a list of research needs that includes needs for cross-agency research and coordination.December 27, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
