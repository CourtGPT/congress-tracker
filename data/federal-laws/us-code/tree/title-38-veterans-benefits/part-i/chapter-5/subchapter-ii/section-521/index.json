{"type":"section","nativeType":"section","number":"521","heading":"Assistance to certain rehabilitation activities","label":"521 Assistance to certain rehabilitation activities","identifier":"/us/usc/t38/s521","parentIdentifier":"/us/usc/t38/ptI/ch5/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs521","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsPrior section 521 was renumbered .section 1521 of this titleProvisions similar to those in this section were contained in prior to repeal by .section 216 of this titlePub. L. 102–83, § 2(a)"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t38/s521/a","parentIdentifier":"/us/usc/t38/s521","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs521%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s521/a/1","parentIdentifier":"/us/usc/t38/s521/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs521%2Fa%2F1","sourceRelease":"119-100","text":"the activities are available to disabled veterans on a national basis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s521/a/2","parentIdentifier":"/us/usc/t38/s521/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs521%2Fa%2F2","sourceRelease":"119-100","text":"a significant percentage of the individuals participating in the activities are eligible for rehabilitative services under chapter 17 of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t38/s521/b","parentIdentifier":"/us/usc/t38/s521","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs521%2Fb","sourceRelease":"119-100","text":"The Secretary may accept from any appropriate source contributions of funds and of other assistance to support the Secretary’s provision of assistance for such activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t38/s521/c","parentIdentifier":"/us/usc/t38/s521","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs521%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s521/c/1","parentIdentifier":"/us/usc/t38/s521/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs521%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s521/c/1/A","parentIdentifier":"/us/usc/t38/s521/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs521%2Fc%2F1%2FA","sourceRelease":"119-100","text":"any organization which provides an activity described in subsection (a) with assistance from the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s521/c/1/B","parentIdentifier":"/us/usc/t38/s521/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs521%2Fc%2F1%2FB","sourceRelease":"119-100","text":"any individual or entity from which the Secretary accepts a significant contribution under subsection (b) or an offer of such a contribution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s521/c/2","parentIdentifier":"/us/usc/t38/s521/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs521%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s521/c/2/A","parentIdentifier":"/us/usc/t38/s521/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs521%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the Secretary has approved the advertisement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s521/c/2/B","parentIdentifier":"/us/usc/t38/s521/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs521%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the advertisement contains a clear statement that no product, project, or commercial line of endeavor referred to in the advertisement is endorsed by the Department of Veterans Affairs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
