ction 2113a of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t16/s8571/a","parentIdentifier":"/us/usc/t16/s8571","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Authorized recreation services","label":"1 Authorized recreation services","identifier":"/us/usc/t16/s8571/a/1","parentIdentifier":"/us/usc/t16/s8571/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8571/a/1/A","parentIdentifier":"/us/usc/t16/s8571/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F1%2FA","sourceRelease":"119-100","text":"on Federal land, non-Federal land, or land owned by an Indian Tribe; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8571/a/1/B","parentIdentifier":"/us/usc/t16/s8571/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F1%2FB","sourceRelease":"119-100","text":"by either the Secretary or a Governor, Indian Tribe, or county, as applicable, pursuant to a good neighbor agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"County","label":"2 County","identifier":"/us/usc/t16/s8571/a/2","parentIdentifier":"/us/usc/t16/s8571/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8571/a/2/A","parentIdentifier":"/us/usc/t16/s8571/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the appropriate executive official of an affected county; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8571/a/2/B","parentIdentifier":"/us/usc/t16/s8571/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F2%2FB","sourceRelease":"119-100","text":"in any case in which multiple counties are affected, the appropriate executive official of a compact of the affected counties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Federal land","label":"3 Federal land","identifier":"/us/usc/t16/s8571/a/3","parentIdentifier":"/us/usc/t16/s8571/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8571/a/3/A","parentIdentifier":"/us/usc/t16/s8571/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8571/a/3/A/i","parentIdentifier":"/us/usc/t16/s8571/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F3%2FA%2Fi","sourceRelease":"119-100","text":"the National Forest System; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8571/a/3/A/ii","parentIdentifier":"/us/usc/t16/s8571/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F3%2FA%2Fii","sourceRelease":"119-100","text":"the National Park System; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8571/a/3/B","parentIdentifier":"/us/usc/t16/s8571/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F3%2FB","sourceRelease":"119-100","text":"public lands (as defined in ).section 1702 of title 43","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Recreation enhancement or improvement services","label":"4 Recreation enhancement or improvement services","identifier":"/us/usc/t16/s8571/a/4","parentIdentifier":"/us/usc/t16/s8571/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8571/a/4/A","parentIdentifier":"/us/usc/t16/s8571/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8571/a/4/A/i","parentIdentifier":"/us/usc/t16/s8571/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FA%2Fi","sourceRelease":"119-100","text":"trails or trailheads;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8571/a/4/A/ii","parentIdentifier":"/us/usc/t16/s8571/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FA%2Fii","sourceRelease":"119-100","text":"campgrounds and camping areas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s8571/a/4/A/iii","parentIdentifier":"/us/usc/t16/s8571/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FA%2Fiii","sourceRelease":"119-100","text":"cabins;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s8571/a/4/A/iv","parentIdentifier":"/us/usc/t16/s8571/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FA%2Fiv","sourceRelease":"119-100","text":"picnic areas or other day use areas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t16/s8571/a/4/A/v","parentIdentifier":"/us/usc/t16/s8571/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FA%2Fv","sourceRelease":"119-100","text":"shooting ranges;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t16/s8571/a/4/A/vi","parentIdentifier":"/us/usc/t16/s8571/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FA%2Fvi","sourceRelease":"119-100","text":"restroom or shower facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t16/s8571/a/4/A/vii","parentIdentifier":"/us/usc/t16/s8571/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FA%2Fvii","sourceRelease":"119-100","text":"paved or permanent roads or parking areas that serve existing recreation facilities or areas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t16/s8571/a/4/A/viii","parentIdentifier":"/us/usc/t16/s8571/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FA%2Fviii","sourceRelease":"119-100","text":"fishing piers, wildlife viewing platforms, docks, or other constructed features at a recreation site;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ix","heading":null,"label":"ix","identifier":"/us/usc/t16/s8571/a/4/A/ix","parentIdentifier":"/us/usc/t16/s8571/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FA%2Fix","sourceRelease":"119-100","text":"boat landings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"x","heading":null,"label":"x","identifier":"/us/usc/t16/s8571/a/4/A/x","parentIdentifier":"/us/usc/t16/s8571/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FA%2Fx","sourceRelease":"119-100","text":"hunting or fishing sites;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xi","heading":null,"label":"xi","identifier":"/us/usc/t16/s8571/a/4/A/xi","parentIdentifier":"/us/usc/t16/s8571/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FA%2Fxi","sourceRelease":"119-100","text":"infrastructure within ski areas; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xii","heading":null,"label":"xii","identifier":"/us/usc/t16/s8571/a/4/A/xii","parentIdentifier":"/us/usc/t16/s8571/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FA%2Fxii","sourceRelease":"119-100","text":"visitor centers or other interpretative sites; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8571/a/4/B","parentIdentifier":"/us/usc/t16/s8571/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F4%2FB","sourceRelease":"119-100","text":"activities that create, improve, or restore access to existing recreation facilities or areas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Good neighbor agreement","label":"5 Good neighbor agreement","identifier":"/us/usc/t16/s8571/a/5","parentIdentifier":"/us/usc/t16/s8571/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F5","sourceRelease":"119-100","text":"The term “good neighbor agreement” means a cooperative agreement or contract (including a sole source contract) entered into between the Secretary and a Governor, Indian Tribe, or county, as applicable, to carry out authorized recreation services under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Governor","label":"6 Governor","identifier":"/us/usc/t16/s8571/a/6","parentIdentifier":"/us/usc/t16/s8571/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F6","sourceRelease":"119-100","text":"The term “Governor” means the Governor or any other appropriate executive official of an affected State or the Commonwealth of Puerto Rico.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Secretary concerned","label":"7 Secretary concerned","identifier":"/us/usc/t16/s8571/a/7","parentIdentifier":"/us/usc/t16/s8571/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8571/a/7/A","parentIdentifier":"/us/usc/t16/s8571/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F7%2FA","sourceRelease":"119-100","text":"the Secretary of Agriculture, with respect to National Forest System land; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8571/a/7/B","parentIdentifier":"/us/usc/t16/s8571/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fa%2F7%2FB","sourceRelease":"119-100","text":"the Secretary of the Interior, with respect to National Park System land and public lands.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Good neighbor agreements for recreation","label":"b Good neighbor agreements for recreation","identifier":"/us/usc/t16/s8571/b","parentIdentifier":"/us/usc/t16/s8571","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s8571/b/1","parentIdentifier":"/us/usc/t16/s8571/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary concerned may enter into a good neighbor agreement with a Governor, Indian Tribe, or county to carry out authorized recreation services in accordance with this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Public availability","label":"2 Public availability","identifier":"/us/usc/t16/s8571/b/2","parentIdentifier":"/us/usc/t16/s8571/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary concerned shall make each good neighbor agreement available to the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Financial and technical assistance","label":"3 Financial and technical assistance","identifier":"/us/usc/t16/s8571/b/3","parentIdentifier":"/us/usc/t16/s8571/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s8571/b/3/A","parentIdentifier":"/us/usc/t16/s8571/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fb%2F3%2FA","sourceRelease":"119-100","text":"The Secretary concerned may provide financial or technical assistance to a Governor, Indian Tribe, or county carrying out authorized recreation services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Omitted","label":"B Omitted","identifier":"/us/usc/t16/s8571/b/3/B","parentIdentifier":"/us/usc/t16/s8571/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Retention of NEPA responsibilities","label":"4 Retention of NEPA responsibilities","identifier":"/us/usc/t16/s8571/b/4","parentIdentifier":"/us/usc/t16/s8571/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8571%2Fb%2F4","sourceRelease":"119-100","text":"Any decision required to be made under the National Environmental Policy Act of 1969 ( et seq.) with respect to any authorized recreation services to be provided under this section on Federal land shall not be delegated to a Governor, Indian Tribe, or county.42 U.S.C. 4321","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
