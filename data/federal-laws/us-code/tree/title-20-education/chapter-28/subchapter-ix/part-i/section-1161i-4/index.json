a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F2%2FD","sourceRelease":"119-100","text":"specialized knowledge of child development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s1161i–4/a/2/E","parentIdentifier":"/us/usc/t20/s1161i–4/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F2%2FE","sourceRelease":"119-100","text":"years of experience in an early childhood education program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t20/s1161i–4/a/2/F","parentIdentifier":"/us/usc/t20/s1161i–4/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F2%2FF","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1161i–4/a/2/F/i","parentIdentifier":"/us/usc/t20/s1161i–4/a/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F2%2FF%2Fi","sourceRelease":"119-100","text":"academic credit for coursework;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1161i–4/a/2/F/ii","parentIdentifier":"/us/usc/t20/s1161i–4/a/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F2%2FF%2Fii","sourceRelease":"119-100","text":"an academic degree;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t20/s1161i–4/a/2/F/iii","parentIdentifier":"/us/usc/t20/s1161i–4/a/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F2%2FF%2Fiii","sourceRelease":"119-100","text":"a credential;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t20/s1161i–4/a/2/F/iv","parentIdentifier":"/us/usc/t20/s1161i–4/a/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F2%2FF%2Fiv","sourceRelease":"119-100","text":"licensure; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t20/s1161i–4/a/2/F/v","parentIdentifier":"/us/usc/t20/s1161i–4/a/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F2%2FF%2Fv","sourceRelease":"119-100","text":"certification in early childhood education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t20/s1161i–4/a/2/G","parentIdentifier":"/us/usc/t20/s1161i–4/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F2%2FG","sourceRelease":"119-100","text":"specialized knowledge in the education of children with limited English proficiency and students with disabilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s1161i–4/a/3","parentIdentifier":"/us/usc/t20/s1161i–4/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161i–4/a/3/A","parentIdentifier":"/us/usc/t20/s1161i–4/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FA","sourceRelease":"119-100","text":"methods of providing outreach to early childhood education program staff, directors, and administrators, including methods for how outreach is provided to non-English speaking providers, in order to enable the providers to be aware of opportunities and resources under the statewide plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161i–4/a/3/B","parentIdentifier":"/us/usc/t20/s1161i–4/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FB","sourceRelease":"119-100","text":"developing a unified data collection and dissemination system for early childhood education training, professional development, and higher education programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161i–4/a/3/C","parentIdentifier":"/us/usc/t20/s1161i–4/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FC","sourceRelease":"119-100","text":"increasing the participation of early childhood educators in high-quality training and professional development by assisting in paying the costs of enrollment in and completion of such training and professional development courses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1161i–4/a/3/D","parentIdentifier":"/us/usc/t20/s1161i–4/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1161i–4/a/3/D/i","parentIdentifier":"/us/usc/t20/s1161i–4/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FD%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t20/s1161i–4/a/3/D/i/I","parentIdentifier":"/us/usc/t20/s1161i–4/a/3/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FD%2Fi%2FI","sourceRelease":"119-100","text":"in the case of an individual pursuing an undergraduate or graduate degree, enters into an agreement under which the individual agrees to work, for a reasonable number of years after receiving such a degree, in an early childhood education program that is located in a low-income area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t20/s1161i–4/a/3/D/i/II","parentIdentifier":"/us/usc/t20/s1161i–4/a/3/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FD%2Fi%2FII","sourceRelease":"119-100","text":"has a family income equal to or less than the annually adjusted national median family income as determined by the Bureau of the Census; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1161i–4/a/3/D/ii","parentIdentifier":"/us/usc/t20/s1161i–4/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FD%2Fii","sourceRelease":"119-100","text":"shall be provided in an amount that does not exceed $17,500;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s1161i–4/a/3/E","parentIdentifier":"/us/usc/t20/s1161i–4/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FE","sourceRelease":"119-100","text":"supporting professional development activities and a career lattice for a variety of early childhood professional roles with varying professional qualifications and responsibilities for early childhood education personnel, including strategies to enhance the compensation of such personnel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t20/s1161i–4/a/3/F","parentIdentifier":"/us/usc/t20/s1161i–4/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FF","sourceRelease":"119-100","text":"supporting articulation agreements between two- and four-year public and private institutions of higher education and mechanisms to transform other training, professional development, and experience into academic credit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t20/s1161i–4/a/3/G","parentIdentifier":"/us/usc/t20/s1161i–4/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FG","sourceRelease":"119-100","text":"developing mentoring and coaching programs to support new educators in and directors of early childhood education programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t20/s1161i–4/a/3/H","parentIdentifier":"/us/usc/t20/s1161i–4/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FH","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1161i–4/a/3/H/i","parentIdentifier":"/us/usc/t20/s1161i–4/a/3/H","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FH%2Fi","sourceRelease":"119-100","text":"entry into and continuing education requirements for professional roles in the field;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1161i–4/a/3/H/ii","parentIdentifier":"/us/usc/t20/s1161i–4/a/3/H","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FH%2Fii","sourceRelease":"119-100","text":"available financial assistance for postsecondary education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t20/s1161i–4/a/3/H/iii","parentIdentifier":"/us/usc/t20/s1161i–4/a/3/H","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FH%2Fiii","sourceRelease":"119-100","text":"professional development and career advancement in the field;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t20/s1161i–4/a/3/I","parentIdentifier":"/us/usc/t20/s1161i–4/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FI","sourceRelease":"119-100","text":"enhancing the capacity and quality of faculty and coursework in postsecondary programs that lead to an associate, baccalaureate, or graduate degree in early childhood education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t20/s1161i–4/a/3/J","parentIdentifier":"/us/usc/t20/s1161i–4/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FJ","sourceRelease":"119-100","text":"consideration of the availability of on-line graduate level professional development offered by institutions of higher education with experience and demonstrated expertise in establishing programs in child development, in order to improve the skills and expertise of individuals working in early childhood education programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"K","heading":null,"label":"K","identifier":"/us/usc/t20/s1161i–4/a/3/K","parentIdentifier":"/us/usc/t20/s1161i–4/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fa%2F3%2FK","sourceRelease":"119-100","text":"developing or enhancing a system of quality assurance with respect to the early childhood education professional development and career system, including standards or qualifications for individuals and entities who offer training and professional development in early childhood education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Public hearings","label":"b Public hearings","identifier":"/us/usc/t20/s1161i–4/b","parentIdentifier":"/us/usc/t20/s1161i–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fb","sourceRelease":"119-100","text":"The State Task Force shall hold public hearings and provide an opportunity for public comment on the activities described in the statewide plan described in subsection (a)(3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Periodic review","label":"c Periodic review","identifier":"/us/usc/t20/s1161i–4/c","parentIdentifier":"/us/usc/t20/s1161i–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161i%E2%80%934%2Fc","sourceRelease":"119-100","text":"The State Task Force shall meet periodically to review implementation of the statewide plan and to recommend any changes to the statewide plan the State Task Force determines necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
