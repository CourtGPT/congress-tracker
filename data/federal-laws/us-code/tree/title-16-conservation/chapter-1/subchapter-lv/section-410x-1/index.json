{"type":"section","nativeType":"section","number":"410x–1","heading":"Residential occupancy","label":"410x–1 Residential occupancy","identifier":"/us/usc/t16/s410x–1","parentIdentifier":"/us/usc/t16/ch1/schLV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410x%E2%80%931","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Offer","label":"a Offer","identifier":"/us/usc/t16/s410x–1/a","parentIdentifier":"/us/usc/t16/s410x–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410x%E2%80%931%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410x–1/a/1","parentIdentifier":"/us/usc/t16/s410x–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410x%E2%80%931%2Fa%2F1","sourceRelease":"119-100","text":"sold residential property between 1966 and 1968 to the United States for purposes of the park, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410x–1/a/2","parentIdentifier":"/us/usc/t16/s410x–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410x%E2%80%931%2Fa%2F2","sourceRelease":"119-100","text":"continues to occupy such residential property pursuant to a residential special use permit as of ,October 24, 1992","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Terms and conditions","label":"b Terms and conditions","identifier":"/us/usc/t16/s410x–1/b","parentIdentifier":"/us/usc/t16/s410x–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410x%E2%80%931%2