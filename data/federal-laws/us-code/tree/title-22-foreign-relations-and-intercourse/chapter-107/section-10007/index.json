{"type":"section","nativeType":"section","number":"10007","heading":"Suspension of assistance","label":"10007 Suspension of assistance","identifier":"/us/usc/t22/s10007","parentIdentifier":"/us/usc/t22/ch107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10007","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s10007/a","parentIdentifier":"/us/usc/t22/s10007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10007%2Fa","sourceRelease":"119-100","text":"The President is authorized to suspend the provision of assistance authorized under section 10003, 10004, 10005, or 10006 of this title to the Government of Sudan if the President determines that conditions in Sudan or the composition of the Government of Sudan changes such that it is no longer in the United States national interest to continue to provide such assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report","label":"b Report","identifier":"/us/usc/t22/s10007/b","parentIdentifier":"/us/usc/t22/s10007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10007%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10007/b/1","parentIdentifier":"/us/usc/t22/s10007/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10007%2Fb%2F1","sourceRelease":"119-100","text":"the political and security conditions in Sudan that led to such determination; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10007/b/2","parentIdentifier":"/us/usc/t22/s10007/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10007%2Fb%2F2","sourceRelease":"119-100","text":"any planned diplomatic engagement to restart the provision of such assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
