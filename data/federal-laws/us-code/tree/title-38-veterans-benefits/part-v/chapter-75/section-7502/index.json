{"type":"section","nativeType":"section","number":"7502","heading":"Application and acceptance","label":"7502 Application and acceptance","identifier":"/us/usc/t38/s7502","parentIdentifier":"/us/usc/t38/ptV/ch75","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7502","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Application","label":"a .—Application","identifier":"/us/usc/t38/s7502/a","parentIdentifier":"/us/usc/t38/s7502","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7502%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s7502/a/1","parentIdentifier":"/us/usc/t38/s7502/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7502%2Fa%2F1","sourceRelease":"119-100","text":"To apply and participate in the scholarship program under this chapter, an individual shall submit to the Secretary an application for such participation together with an agreement described in under which the participant agrees to serve a period of obligated service in the Department as provided in the agreement in return for payment of educational assistance as provided in the agreement.section 7504 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s7502/a/2","parentIdentifier":"/us/usc/t38/s7502/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7502%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s7502/a/2/A","parentIdentifier":"/us/usc/t38/s7502/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7502%2Fa%2F2%2FA","sourceRelease":"119-100","text":"A fair summary of the rights and liabilities of an individual whose application is approved (and whose agreement is accepted) by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s7502/a/2/B","parentIdentifier":"/us/usc/t38/s7502/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7502%2Fa%2F2%2FB","sourceRelease":"119-100","text":"A full description of the terms and conditions that apply to participation in the scholarship program and service in the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Approval","label":"b .—Approval","identifier":"/us/usc/t38/s7502/b","parentIdentifier":"/us/usc/t38/s7502","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7502%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s7502/b/1","parentIdentifier":"/us/usc/t38/s7502/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7502%2Fb%2F1","sourceRelease":"119-100","text":"Upon the Secretary’s approval of an individual’s participation in the scholarship program, the Secretary shall, in writing, promptly notify the individual of that acceptance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s7502/b/2","parentIdentifier":"/us/usc/t38/s7502/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7502%2Fb%2F2","sourceRelease":"119-100","text":"An individual becomes a participant in the scholarship program upon such approval by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
