{"type":"section","nativeType":"section","number":"7784","heading":"Agreements","label":"7784 Agreements","identifier":"/us/usc/t7/s7784","parentIdentifier":"/us/usc/t7/ch104/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Consultation and consent","label":"a Consultation and consent","identifier":"/us/usc/t7/s7784/a","parentIdentifier":"/us/usc/t7/s7784","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7784/a/1","parentIdentifier":"/us/usc/t7/s7784/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fa%2F1","sourceRelease":"119-100","text":"if the activities funded under the agreement will take place on Federal land, consult with the heads of the Federal agencies having jurisdiction over the land; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7784/a/2","parentIdentifier":"/us/usc/t7/s7784/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fa%2F2","sourceRelease":"119-100","text":"obtain the written consent of the non-Federal landowner.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Application of other laws","label":"b Application of other laws","identifier":"/us/usc/t7/s7784/b","parentIdentifier":"/us/usc/t7/s7784","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fb","sourceRelease":"119-100","text":"The Secretary may enter into agreements under this section with weed management entities notwithstanding sections 6301 through 6309 of title 31 and other laws relating to the procurement of goods and services for the Federal Government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Eligible activities","label":"c Eligible activities","identifier":"/us/usc/t7/s7784/c","parentIdentifier":"/us/usc/t7/s7784","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7784/c/1","parentIdentifier":"/us/usc/t7/s7784/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fc%2F1","sourceRelease":"119-100","text":"Education, inventories and mapping, management, monitoring, methods development, and other capacity building activities, including the payment of the cost of personnel and equipment that promote control or eradication of noxious weeds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7784/c/2","parentIdentifier":"/us/usc/t7/s7784/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fc%2F2","sourceRelease":"119-100","text":"Other activities to control or eradicate noxious weeds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Selection of activities","label":"d Selection of activities","identifier":"/us/usc/t7/s7784/d","parentIdentifier":"/us/usc/t7/s7784","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7784/d/1","parentIdentifier":"/us/usc/t7/s7784/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fd%2F1","sourceRelease":"119-100","text":"The severity of the noxious weeds problem or potential problem addressed by the activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7784/d/2","parentIdentifier":"/us/usc/t7/s7784/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fd%2F2","sourceRelease":"119-100","text":"The likelihood that the activity will prevent or resolve the problem, or increase knowledge about resolving similar problems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7784/d/3","parentIdentifier":"/us/usc/t7/s7784/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fd%2F3","sourceRelease":"119-100","text":"The extent to which the activity will provide a comprehensive approach to the control or eradication of noxious weeds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s7784/d/4","parentIdentifier":"/us/usc/t7/s7784/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fd%2F4","sourceRelease":"119-100","text":"The extent to which the program will improve the overall capacity of the United States to address noxious weed control and management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s7784/d/5","parentIdentifier":"/us/usc/t7/s7784/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fd%2F5","sourceRelease":"119-100","text":"The extent to which the project promotes cooperation and participation between States that have common interests in controlling and eradicating noxious weeds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s7784/d/6","parentIdentifier":"/us/usc/t7/s7784/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fd%2F6","sourceRelease":"119-100","text":"Other factors that the Secretary determines to be relevant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Regional, State, and local involvement","label":"e Regional, State, and local involvement","identifier":"/us/usc/t7/s7784/e","parentIdentifier":"/us/usc/t7/s7784","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7784/e/1","parentIdentifier":"/us/usc/t7/s7784/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fe%2F1","sourceRelease":"119-100","text":"rely on technical and merit reviews provided by regional, State, or local weed management experts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7784/e/2","parentIdentifier":"/us/usc/t7/s7784/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Fe%2F2","sourceRelease":"119-100","text":"give priority to activities that maximize the involvement of State, local, and, where applicable, representatives of Indian Tribe governments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Rapid response program","label":"f Rapid response program","identifier":"/us/usc/t7/s7784/f","parentIdentifier":"/us/usc/t7/s7784","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7784/f/1","parentIdentifier":"/us/usc/t7/s7784/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Ff%2F1","sourceRelease":"119-100","text":"there is a demonstrated need for the assistance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7784/f/2","parentIdentifier":"/us/usc/t7/s7784/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Ff%2F2","sourceRelease":"119-100","text":"the noxious weed is considered to be a significant threat to native fish, wildlife, or their habitats, as determined by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7784/f/3","parentIdentifier":"/us/usc/t7/s7784/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Ff%2F3","sourceRelease":"119-100","text":"the economic impact of delaying action is considered by the Secretary to be substantial; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s7784/f/4","parentIdentifier":"/us/usc/t7/s7784/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Ff%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7784/f/4/A","parentIdentifier":"/us/usc/t7/s7784/f/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Ff%2F4%2FA","sourceRelease":"119-100","text":"is technically feasible;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7784/f/4/B","parentIdentifier":"/us/usc/t7/s7784/f/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Ff%2F4%2FB","sourceRelease":"119-100","text":"economically responsible; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s7784/f/4/C","parentIdentifier":"/us/usc/t7/s7784/f/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7784%2Ff%2F4%2FC","sourceRelease":"119-100","text":"minimizes adverse impacts to the structure and function of an ecosystem and adverse effects on nontarget species and ecosystems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
