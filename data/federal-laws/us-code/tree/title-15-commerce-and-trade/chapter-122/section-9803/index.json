ments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9803/a/2","parentIdentifier":"/us/usc/t15/s9803/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F2","sourceRelease":"119-100","text":"develop recommendations for achieving the annual goals established pursuant to paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s9803/a/3","parentIdentifier":"/us/usc/t15/s9803/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9803/a/3/A","parentIdentifier":"/us/usc/t15/s9803/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F3%2FA","sourceRelease":"119-100","text":"the Tourism Policy Council;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9803/a/3/B","parentIdentifier":"/us/usc/t15/s9803/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F3%2FB","sourceRelease":"119-100","text":"the Secretary of State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9803/a/3/C","parentIdentifier":"/us/usc/t15/s9803/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F3%2FC","sourceRelease":"119-100","text":"the Secretary of Homeland Security;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s9803/a/3/D","parentIdentifier":"/us/usc/t15/s9803/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F3%2FD","sourceRelease":"119-100","text":"the Corporation for Travel Promotion;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s9803/a/3/E","parentIdentifier":"/us/usc/t15/s9803/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F3%2FE","sourceRelease":"119-100","text":"the United States Travel and Tourism Advisory Board; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t15/s9803/a/3/F","parentIdentifier":"/us/usc/t15/s9803/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F3%2FF","sourceRelease":"119-100","text":"travel and tourism industry representatives, including public and private destination marketing organizations, travel and tourism suppliers, gig economy representatives, and labor representatives from these industries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s9803/a/4","parentIdentifier":"/us/usc/t15/s9803/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F4","sourceRelease":"119-100","text":"establish short, medium, and long-term timelines for implementing the recommendations developed pursuant to paragraph (2);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s9803/a/5","parentIdentifier":"/us/usc/t15/s9803/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F5","sourceRelease":"119-100","text":"conduct Federal agency needs assessments, in consultation with the Office of Management and Budget and other relevant Federal agencies, to identify the resources, statutory or regulatory changes, and private sector engagement needed to achieve the annual visitation goals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s9803/a/6","parentIdentifier":"/us/usc/t15/s9803/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9803/a/6/A","parentIdentifier":"/us/usc/t15/s9803/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F6%2FA","sourceRelease":"119-100","text":"the Committee on Commerce, Science, and Transportation of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9803/a/6/B","parentIdentifier":"/us/usc/t15/s9803/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F6%2FB","sourceRelease":"119-100","text":"the Committee on Energy and Commerce of the House of Representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9803/a/6/C","parentIdentifier":"/us/usc/t15/s9803/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fa%2F6%2FC","sourceRelease":"119-100","text":"the public through a publicly accessible website.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Domestic travel and tourism","label":"b Domestic travel and tourism","identifier":"/us/usc/t15/s9803/b","parentIdentifier":"/us/usc/t15/s9803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9803/b/1","parentIdentifier":"/us/usc/t15/s9803/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fb%2F1","sourceRelease":"119-100","text":"evaluate, on an ongoing basis, domestic policy options for supporting competitiveness with respect to the strengths, weaknesses, and growth of the domestic travel industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9803/b/2","parentIdentifier":"/us/usc/t15/s9803/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fb%2F2","sourceRelease":"119-100","text":"develop recommendations and goals to support and enhance domestic tourism, separated by business and leisure; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s9803/b/3","parentIdentifier":"/us/usc/t15/s9803/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fb%2F3","sourceRelease":"119-100","text":"engage public and private stakeholders to support domestic tourism.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Workforce","label":"c Workforce","identifier":"/us/usc/t15/s9803/c","parentIdentifier":"/us/usc/t15/s9803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9803/c/1","parentIdentifier":"/us/usc/t15/s9803/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fc%2F1","sourceRelease":"119-100","text":"consult with the Secretary of Labor to develop strategies and best practices for improving the timeliness and reliability of travel and tourism workforce data;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9803/c/2","parentIdentifier":"/us/usc/t15/s9803/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fc%2F2","sourceRelease":"119-100","text":"work with the Secretary of Labor and the Bureau of Economic Analysis to improve travel and tourism industry data;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s9803/c/3","parentIdentifier":"/us/usc/t15/s9803/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fc%2F3","sourceRelease":"119-100","text":"provide recommendations for policy enhancements and efficiencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s9803/c/4","parentIdentifier":"/us/usc/t15/s9803/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fc%2F4","sourceRelease":"119-100","text":"provide policy recommendations regarding the gig economy as it relates to travel and tourism.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Facilitation of international business travel","label":"d Facilitation of international business travel","identifier":"/us/usc/t15/s9803/d","parentIdentifier":"/us/usc/t15/s9803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9803/d/1","parentIdentifier":"/us/usc/t15/s9803/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fd%2F1","sourceRelease":"119-100","text":"facilitating large meetings, incentives, conferences, and exhibitions in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9803/d/2","parentIdentifier":"/us/usc/t15/s9803/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fd%2F2","sourceRelease":"119-100","text":"emphasizing rural and other destinations in the United States that are rich in cultural heritage or ecological tourism, among other uniquely American destinations, as locations for hosting international meetings, incentives, conferences, and exhibitions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s9803/d/3","parentIdentifier":"/us/usc/t15/s9803/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fd%2F3","sourceRelease":"119-100","text":"facilitating sports and recreation events and activities in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Recovery strategies","label":"e Recovery strategies","identifier":"/us/usc/t15/s9803/e","parentIdentifier":"/us/usc/t15/s9803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s9803/e/1","parentIdentifier":"/us/usc/t15/s9803/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fe%2F1","sourceRelease":"119-100","text":"Not later than 1 year after amounts are appropriated to the Department of Commerce to accomplish the purposes of this section, the Assistant Secretary, in consultation with the entities referred to in subsection (a)(3), shall develop recovery strategies for the travel and tourism industry in response to the economic impacts of the COVID–19 pandemic and in anticipation of other unpredictable catastrophic events that would significantly affect the travel and tourism industry, such as hurricanes, floods, tsunamis, tornadoes, wildfires, terrorist attacks, and pandemics.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Cost-benefit analysis","label":"2 Cost-benefit analysis","identifier":"/us/usc/t15/s9803/e/2","parentIdentifier":"/us/usc/t15/s9803/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Fe%2F2","sourceRelease":"119-100","text":"In developing the recovery strategies under paragraph (1), the Assistant Secretary shall conduct cost-benefit analyses that take into account the health and economic effects of public health mitigation measures on the travel and tourism industry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Reporting requirements","label":"f Reporting requirements","identifier":"/us/usc/t15/s9803/f","parentIdentifier":"/us/usc/t15/s9803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Assistant Secretary","label":"1 Assistant Secretary","identifier":"/us/usc/t15/s9803/f/1","parentIdentifier":"/us/usc/t15/s9803/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9803/f/1/A","parentIdentifier":"/us/usc/t15/s9803/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff%2F1%2FA","sourceRelease":"119-100","text":"domestic employment needs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9803/f/1/B","parentIdentifier":"/us/usc/t15/s9803/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff%2F1%2FB","sourceRelease":"119-100","text":"international inbound volume and spending, taking into account the lasting effects of the COVID–19 public health emergency and the impact of the recovery strategy implemented pursuant to subsection (e)(1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9803/f/1/C","parentIdentifier":"/us/usc/t15/s9803/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff%2F1%2FC","sourceRelease":"119-100","text":"domestic volume and spending, including Federal and State public land travel and tourism data.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Bureau of Economic Analysis","label":"2 Bureau of Economic Analysis","identifier":"/us/usc/t15/s9803/f/2","parentIdentifier":"/us/usc/t15/s9803/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9803/f/2/A","parentIdentifier":"/us/usc/t15/s9803/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff%2F2%2FA","sourceRelease":"119-100","text":"State-level travel and tourism spending data;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9803/f/2/B","parentIdentifier":"/us/usc/t15/s9803/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff%2F2%2FB","sourceRelease":"119-100","text":"travel and tourism workforce data for full-time and part-time employment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9803/f/2/C","parentIdentifier":"/us/usc/t15/s9803/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff%2F2%2FC","sourceRelease":"119-100","text":"Federal and State public lands outdoor recreational activity and tourism spending data.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"National Travel and Tourism Office","label":"3 National Travel and Tourism Office","identifier":"/us/usc/t15/s9803/f/3","parentIdentifier":"/us/usc/t15/s9803/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9803/f/3/A","parentIdentifier":"/us/usc/t15/s9803/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9803/f/3/A/i","parentIdentifier":"/us/usc/t15/s9803/f/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff%2F3%2FA%2Fi","sourceRelease":"119-100","text":"the Travel and Tourism Advisory Board; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9803/f/3/A/ii","parentIdentifier":"/us/usc/t15/s9803/f/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff%2F3%2FA%2Fii","sourceRelease":"119-100","text":"the public through a publicly accessible website; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9803/f/3/B","parentIdentifier":"/us/usc/t15/s9803/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9803%2Ff%2F3%2FB","sourceRelease":"119-100","text":"shall include questions in the Survey of International Air Travelers regarding wait-times, visits to public lands, and State data, to the extent applicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
