{"type":"section","nativeType":"section","number":"360k","heading":"State and local requirements respecting devices","label":"360k State and local requirements respecting devices","identifier":"/us/usc/t21/s360k","parentIdentifier":"/us/usc/t21/ch9/schV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360k","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"General rule","label":"a General rule","identifier":"/us/usc/t21/s360k/a","parentIdentifier":"/us/usc/t21/s360k","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360k%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s360k/a/1","parentIdentifier":"/us/usc/t21/s360k/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360k%2Fa%2F1","sourceRelease":"119-100","text":"which is different from, or in addition to, any requirement applicable under this chapter to the device, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s360k/a/2","parentIdentifier":"/us/usc/t21/s360k/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360k%2Fa%2F2","sourceRelease":"119-100","text":"which relates to the safety or effectiveness of the device or to any other matter included in a requirement applicable to the device under this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Exempt requirements","label":"b Exempt requirements","identifier":"/us/usc/t21/s360k/b","parentIdentifier":"/us/usc/t21/s360k","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360k%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s360k/b/1","parentIdentifier":"/us/usc/t21/s360k/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360k%2Fb%2F1","sourceRelease":"119-100","text":"the requirement is more stringent than a requirement under this chapter which would be applicable to the device if an exemption were not in effect under this subsection; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s360k/b/2","parentIdentifier":"/us/usc/t21/s360k/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360k%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s360k/b/2/A","parentIdentifier":"/us/usc/t21/s360k/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360k%2Fb%2F2%2FA","sourceRelease":"119-100","text":"is required by compelling local conditions, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s360k/b/2/B","parentIdentifier":"/us/usc/t21/s360k/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360k%2Fb%2F2%2FB","sourceRelease":"119-100","text":"compliance with the requirement would not cause the device to be in violation of any applicable requirement under this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
