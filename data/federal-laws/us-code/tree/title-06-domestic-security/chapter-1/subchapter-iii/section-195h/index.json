{"type":"section","nativeType":"section","number":"195h","heading":"National Urban Security Technology Laboratory","label":"195h National Urban Security Technology Laboratory","identifier":"/us/usc/t6/s195h","parentIdentifier":"/us/usc/t6/ch1/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195h","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t6/s195h/a","parentIdentifier":"/us/usc/t6/s195h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195h%2Fa","sourceRelease":"119-100","text":"The Secretary, acting through the Under Secretary for Science and Technology, shall designate the laboratory described in subsection (b) as an additional laboratory pursuant to the authority under . Such laboratory shall be used to test and evaluate emerging technologies and conduct research and development to assist emergency response providers in preparing for, and protecting against, threats of terrorism.section 188(c)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Laboratory described","label":"b Laboratory described","identifier":"/us/usc/t6/s195h/b","parentIdentifier":"/us/usc/t6/s195h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195h%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s195h/b/1","parentIdentifier":"/us/usc/t6/s195h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195h%2Fb%2F1","sourceRelease":"119-100","text":"known, as of , as the National Urban Security Technology Laboratory; andDecember 27, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s195h/b/2","parentIdentifier":"/us/usc/t6/s195h/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195h%2Fb%2F2","sourceRelease":"119-100","text":"transferred to the Department pursuant to .section 183(1)(E) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Laboratory activities","label":"c Laboratory activities","identifier":"/us/usc/t6/s195h/c","parentIdentifier":"/us/usc/t6/s195h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195h%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s195h/c/1","parentIdentifier":"/us/usc/t6/s195h/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195h%2Fc%2F1","sourceRelease":"119-100","text":"conduct tests, evaluations, and assessments of current and emerging technologies, including, as appropriate, the cybersecurity of such technologies that can connect to the internet, for emergency response providers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s195h/c/2","parentIdentifier":"/us/usc/t6/s195h/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195h%2Fc%2F2","sourceRelease":"119-100","text":"act as a technical advisor to emergency response providers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s195h/c/3","parentIdentifier":"/us/usc/t6/s195h/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195h%2Fc%2F3","sourceRelease":"119-100","text":"carry out other such activities as the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Rule of construction","label":"d Rule of construction","identifier":"/us/usc/t6/s195h/d","parentIdentifier":"/us/usc/t6/s195h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195h%2Fd","sourceRelease":"119-100","text":"Nothing in this section may be construed as affecting in any manner the authorities or responsibilities of the Countering Weapons of Mass Destruction Office of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
