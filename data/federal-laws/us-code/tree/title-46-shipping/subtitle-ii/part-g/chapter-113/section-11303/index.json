{"type":"section","nativeType":"section","number":"11303","heading":"Penalties","label":"11303 Penalties","identifier":"/us/usc/t46/s11303","parentIdentifier":"/us/usc/t46/stII/ptG/ch113","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11303","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevised sectionSource section (U.S. Code)1130346:203Section 11303 provides a penalty for violation of the provisions about logbooks in this part."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t46/s11303/a","parentIdentifier":"/us/usc/t46/s11303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11303%2Fa","sourceRelease":"119-100","text":"A master failing to maintain an official logbook as required by this part is liable to the United States Government for a civil penalty of $200.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t46/s11303/b","parentIdentifier":"/us/usc/t46/s11303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11303%2Fb","sourceRelease":"119-100","text":"A master failing to make an entry in the vessel’s official logbook as required by this part is liable to the Government for a civil penalty of $200.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t46/s11303/c","parentIdentifier":"/us/usc/t46/s11303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11303%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s11303/c/1","parentIdentifier":"/us/usc/t46/s11303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11303%2Fc%2F1","sourceRelease":"119-100","text":"later than 24 hours after the vessel’s arrival at the final port of discharge; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s11303/c/2","parentIdentifier":"/us/usc/t46/s11303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs11303%2Fc%2F2","sourceRelease":"119-100","text":"that is about an occurrence that happened before that arrival.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
