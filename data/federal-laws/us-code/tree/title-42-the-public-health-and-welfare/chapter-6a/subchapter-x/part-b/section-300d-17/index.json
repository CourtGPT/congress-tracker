{"type":"section","nativeType":"section","number":"300d–17","heading":"Requirement of submission of application containing certain agreements and assurances","label":"300d–17 Requirement of submission of application containing certain agreements and assurances","identifier":"/us/usc/t42/s300d–17","parentIdentifier":"/us/usc/t42/ch6A/schX/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300d%E2%80%9317","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300d–17/1","parentIdentifier":"/us/usc/t42/s300d–17","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300d%E2%80%9317%2F1","sourceRelease":"119-100","text":"the State submits to the Secretary an application for the payments containing agreements in accordance with this part;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300d–17/2","parentIdentifier":"/us/usc/t42/s300d–17","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300d%E2%80%9317%2F2","sourceRelease":"119-100","text":"the agreements are made through certification from the chief executive officer of the State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300d–17/3","parentIdentifier":"/us/usc/t42/s300d–17","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300d%E2%80%9317%2F3","sourceRelease":"119-100","text":"with respect to such agreements, the application provides assurances of compliance satisfactory to the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s300d–17/4","parentIdentifier":"/us/usc/t42/s300d–17","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300d%E2%80%9317%2F4","sourceRelease":"119-100","text":"the application contains the plan provisions and the information required to be submitted to the Secretary pursuant to ; andsection 300d–14 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s300d–17/5","parentIdentifier":"/us/usc/t42/s300d–17","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300d%E2%80%9317%2F5","sourceRelease":"119-100","text":"the application otherwise is in such form, is made in such manner, and contains such agreements, assurances, and information as the Secretary determines to be necessary to carry out this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
