ments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Metrics","label":"b Metrics","identifier":"/us/usc/t42/s18775/b","parentIdentifier":"/us/usc/t42/s18775","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18775%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18775/b/1","parentIdentifier":"/us/usc/t42/s18775/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18775%2Fb%2F1","sourceRelease":"119-100","text":"over the 1-year, 5-year, and 10-year periods beginning on the date on which development of the plan is completed;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18775/b/2","parentIdentifier":"/us/usc/t42/s18775/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18775%2Fb%2F2","sourceRelease":"119-100","text":"by economic sector; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18775/b/3","parentIdentifier":"/us/usc/t42/s18775/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18775%2Fb%2F3","sourceRelease":"119-100","text":"according to any other parameters that the Administrator, in collaboration with the Secretary of the Interior, acting through the Director of the United States Geological Survey, determines are needed for the Annual Critical Minerals Outlook.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Collaboration","label":"c Collaboration","identifier":"/us/usc/t42/s18775/c","parentIdentifier":"/us/usc/t42/s18775","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18775%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18775/c/1","parentIdentifier":"/us/usc/t42/s18775/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18775%2Fc%2F1","sourceRelease":"119-100","text":"the Secretary with respect to the possible trajectories of emerging energy-producing and energy-storing technologies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18775/c/2","parentIdentifier":"/us/usc/t42/s18775/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18775%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18775/c/2/A","parentIdentifier":"/us/usc/t42/s18775/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18775%2Fc%2F2%2FA","sourceRelease":"119-100","text":"to ensure coordination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18775/c/2/B","parentIdentifier":"/us/usc/t42/s18775/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18775%2Fc%2F2%2FB","sourceRelease":"119-100","text":"to avoid duplicative effort; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18775/c/2/C","parentIdentifier":"/us/usc/t42/s18775/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18775%2Fc%2F2%2FC","sourceRelease":"119-100","text":"to align the analysis of demand with data and analysis of where the minerals are produced, refined, and subsequently processed into materials and parts that are used to build energy technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
