{"type":"section","nativeType":"section","number":"1472","heading":"Withholdable payments to other foreign entities","label":"1472 Withholdable payments to other foreign entities","identifier":"/us/usc/t26/s1472","parentIdentifier":"/us/usc/t26/stA/ch4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t26/s1472/a","parentIdentifier":"/us/usc/t26/s1472","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s1472/a/1","parentIdentifier":"/us/usc/t26/s1472/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fa%2F1","sourceRelease":"119-100","text":"the beneficial owner of such payment is such entity or any other non-financial foreign entity, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s1472/a/2","parentIdentifier":"/us/usc/t26/s1472/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fa%2F2","sourceRelease":"119-100","text":"the requirements of subsection (b) are not met with respect to such beneficial owner,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirements for waiver of withholding","label":"b Requirements for waiver of withholding","identifier":"/us/usc/t26/s1472/b","parentIdentifier":"/us/usc/t26/s1472","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s1472/b/1","parentIdentifier":"/us/usc/t26/s1472/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s1472/b/1/A","parentIdentifier":"/us/usc/t26/s1472/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fb%2F1%2FA","sourceRelease":"119-100","text":"a certification that such beneficial owner does not have any substantial United States owners, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s1472/b/1/B","parentIdentifier":"/us/usc/t26/s1472/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the name, address, and TIN of each substantial United States owner of such beneficial owner,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s1472/b/2","parentIdentifier":"/us/usc/t26/s1472/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fb%2F2","sourceRelease":"119-100","text":"the withholding agent does not know, or have reason to know, that any information provided under paragraph (1) is incorrect, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t26/s1472/b/3","parentIdentifier":"/us/usc/t26/s1472/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fb%2F3","sourceRelease":"119-100","text":"the withholding agent reports the information provided under paragraph (1)(B) to the Secretary in such manner as the Secretary may provide.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Exceptions","label":"c Exceptions","identifier":"/us/usc/t26/s1472/c","parentIdentifier":"/us/usc/t26/s1472","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s1472/c/1","parentIdentifier":"/us/usc/t26/s1472/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s1472/c/1/A","parentIdentifier":"/us/usc/t26/s1472/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fc%2F1%2FA","sourceRelease":"119-100","text":"any corporation the stock of which is regularly traded on an established securities market,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s1472/c/1/B","parentIdentifier":"/us/usc/t26/s1472/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fc%2F1%2FB","sourceRelease":"119-100","text":"any corporation which is a member of the same expanded affiliated group (as defined in section 1471(e)(2) without regard to the last sentence thereof) as a corporation described in subparagraph (A),","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t26/s1472/c/1/C","parentIdentifier":"/us/usc/t26/s1472/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fc%2F1%2FC","sourceRelease":"119-100","text":"any entity which is organized under the laws of a possession of the United States and which is wholly owned by one or more bona fide residents (as defined in section 937(a)) of such possession,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t26/s1472/c/1/D","parentIdentifier":"/us/usc/t26/s1472/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fc%2F1%2FD","sourceRelease":"119-100","text":"any foreign government, any political subdivision of a foreign government, or any wholly owned agency or instrumentality of any one or more of the foregoing,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t26/s1472/c/1/E","parentIdentifier":"/us/usc/t26/s1472/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fc%2F1%2FE","sourceRelease":"119-100","text":"any international organization or any wholly owned agency or instrumentality thereof,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t26/s1472/c/1/F","parentIdentifier":"/us/usc/t26/s1472/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fc%2F1%2FF","sourceRelease":"119-100","text":"any foreign central bank of issue, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t26/s1472/c/1/G","parentIdentifier":"/us/usc/t26/s1472/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fc%2F1%2FG","sourceRelease":"119-100","text":"any other class of persons identified by the Secretary for purposes of this subsection, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s1472/c/2","parentIdentifier":"/us/usc/t26/s1472/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fc%2F2","sourceRelease":"119-100","text":"any class of payments identified by the Secretary for purposes of this subsection as posing a low risk of tax evasion.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Non-financial foreign entity","label":"d Non-financial foreign entity","identifier":"/us/usc/t26/s1472/d","parentIdentifier":"/us/usc/t26/s1472","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1472%2Fd","sourceRelease":"119-100","text":"For purposes of this section, the term “non-financial foreign entity” means any foreign entity which is not a financial institution (as defined in section 1471(d)(5)).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
