ii","identifier":"/us/usc/t42/s19351/a/2/H/ii","parentIdentifier":"/us/usc/t42/s19351/a/2/H","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19351%2Fa%2F2%2FH%2Fii","sourceRelease":"119-100","text":"nuclear supply chains; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s19351/a/2/H/iii","parentIdentifier":"/us/usc/t42/s19351/a/2/H","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19351%2Fa%2F2%2FH%2Fiii","sourceRelease":"119-100","text":"with respect to nuclear technologies and nonelectric applications of nuclear technologies, construction, project financing, contract structuring and risk allocation, or regulatory and licensing processes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Program","label":"3 Program","identifier":"/us/usc/t42/s19351/a/3","parentIdentifier":"/us/usc/t42/s19351/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19351%2Fa%2F3","sourceRelease":"119-100","text":"The term “program” means the program established under subsection (b)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Secretary","label":"4 Secretary","identifier":"/us/usc/t42/s19351/a/4","parentIdentifier":"/us/usc/t42/s19351/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19351%2Fa%2F4","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment of program","label":"b Establishment of program","identifier":"/us/usc/t42/s19351/b","parentIdentifier":"/us/usc/t42/s19351","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19351%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s19351/b/1","parentIdentifier":"/us/usc/t42/s19351/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19351%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall establish a program to provide Federal financial assistance to eligible entities to support the research, development, demonstration, and deployment of advanced nuclear reactors and associated supply chain infrastructure.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Competitive procedures","label":"2 Competitive procedures","identifier":"/us/usc/t42/s19351/b/2","parentIdentifier":"/us/usc/t42/s19351/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19351%2Fb%2F2","sourceRelease":"119-100","text":"To the maximum extent practicable, the Secretary shall carry out the program using a competitive, merit-based review process that is consistent with .section 16353 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Applications","label":"c Applications","identifier":"/us/usc/t42/s19351/c","parentIdentifier":"/us/usc/t42/s19351","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19351%2Fc","sourceRelease":"119-100","text":"An eligible entity desiring Federal financial assistance under the program shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Priority","label":"d Priority","identifier":"/us/usc/t42/s19351/d","parentIdentifier":"/us/usc/t42/s19351","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19351%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19351/d/1","parentIdentifier":"/us/usc/t42/s19351/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19351%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19351/d/1/A","parentIdentifier":"/us/usc/t42/s19351/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19351%2Fd%2F1%2FA","sourceRelease":"119-100","text":"to support the productive reuse of fossil fuel electric generation facilities that are retired or scheduled to retire; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19351/d/1/B","parentIdentifier":"/us/usc/t42/s19351/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19351%2Fd%2F1%2FB","sourceRelease":"119-100","text":"to sustain and revitalize communities impacted by the closure of fossil fuel electric generation facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19351/d/2","parentIdentifier":"/us/usc/t42/s19351/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19351%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph",