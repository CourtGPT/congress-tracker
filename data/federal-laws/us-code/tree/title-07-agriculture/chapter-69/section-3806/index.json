{"type":"section","nativeType":"section","number":"3806","heading":"Criminal penalties","label":"3806 Criminal penalties","identifier":"/us/usc/t7/s3806","parentIdentifier":"/us/usc/t7/ch69","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3806","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t7/s3806/a","parentIdentifier":"/us/usc/t7/s3806","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3806%2Fa","sourceRelease":"119-100","text":"Whoever willfully violates any provision of this chapter or the regulations of the Secretary issued hereunder shall be guilty of a misdemeanor and shall be fined not more than $10,000, or imprisoned not more than one year, or both.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t7/s3806/b","parentIdentifier":"/us/usc/t7/s3806","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3806%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s3806/b/1","parentIdentifier":"/us/usc/t7/s3806/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3806%2Fb%2F1","sourceRelease":"119-100","text":"after the expiration of the time allowed for filing a petition in the court of appeals to review such order, if no such petition has been filed within such time; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s3806/b/2","parentIdentifier":"/us/usc/t7/s3806/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3806%2Fb%2F2","sourceRelease":"119-100","text":"after the expiration of the time allowed for applying for a writ of certiorari, if such order, or such order as modified, has been sustained by the court of appeals and no such writ has been applied for within such time; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s3806/b/3","parentIdentifier":"/us/usc/t7/s3806/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3806%2Fb%2F3","sourceRelease":"119-100","text":"after such order, or such order as modified, has been sustained by the courts as provided in ;section 3804(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
