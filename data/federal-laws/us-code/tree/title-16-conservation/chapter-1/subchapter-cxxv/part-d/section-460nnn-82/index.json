{"type":"section","nativeType":"section","number":"460nnn–82","heading":"Treatment of State lands and mineral interests","label":"460nnn–82 Treatment of State lands and mineral interests","identifier":"/us/usc/t16/s460nnn–82","parentIdentifier":"/us/usc/t16/ch1/schCXXV/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9382","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Acquisition required","label":"a Acquisition required","identifier":"/us/usc/t16/s460nnn–82/a","parentIdentifier":"/us/usc/t16/s460nnn–82","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9382%2Fa","sourceRelease":"119-100","text":"The Secretary shall acquire, for approximately equal value and as agreed to by the Secretary and the State of Oregon, lands and interests in lands owned by the State within the boundaries of the mineral withdrawal area designated pursuant to .section 460nnn–81 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Acquisition methods","label":"b Acquisition methods","identifier":"/us/usc/t16/s460nnn–82/b","parentIdentifier":"/us/usc/t16/s460nnn–82","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9382%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460nnn–82/b/1","parentIdentifier":"/us/usc/t16/s460nnn–82/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9382%2Fb%2F1","sourceRelease":"119-100","text":"Federal lands or Federal mineral interests that are outside the boundaries of the mineral withdrawal area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460nnn–82/b/2","parentIdentifier":"/us/usc/t16/s460nnn–82/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9382%2Fb%2F2","sourceRelease":"119-100","text":"a monetary payment to the State; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s460nnn–82/b/3","parentIdentifier":"/us/usc/t16/s460nnn–82/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9382%2Fb%2F3","sourceRelease":"119-100","text":"a combination of a conveyance under paragraph (1) and a monetary payment under paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
