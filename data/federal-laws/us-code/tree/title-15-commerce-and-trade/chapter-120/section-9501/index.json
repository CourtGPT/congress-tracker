xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F14","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9501/14/A","parentIdentifier":"/us/usc/t15/s9501/14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F14%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9501/14/A/i","parentIdentifier":"/us/usc/t15/s9501/14/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F14%2FA%2Fi","sourceRelease":"119-100","text":"that is not less than 51 percent owned by 1 or more socially or economically disadvantaged individuals; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9501/14/A/ii","parentIdentifier":"/us/usc/t15/s9501/14/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F14%2FA%2Fii","sourceRelease":"119-100","text":"that is socially or economically disadvantaged; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9501/14/B","parentIdentifier":"/us/usc/t15/s9501/14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F14%2FB","sourceRelease":"119-100","text":"the management and daily business operations of which are controlled by 1 or more socially or economically disadvantaged individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"15","heading":"Socially or economically disadvantaged individual","label":"15 Socially or economically disadvantaged individual","identifier":"/us/usc/t15/s9501/15","parentIdentifier":"/us/usc/t15/s9501","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F15","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s9501/15/A","parentIdentifier":"/us/usc/t15/s9501/15","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F15%2FA","sourceRelease":"119-100","text":"The term “socially or economically disadvantaged individual” means an individual who has been subjected to racial or ethnic prejudice or cultural bias (or the ability of whom to compete in the free enterprise system has been impaired due to diminished capital and credit opportunities, as compared to others in the same line of business and competitive market area) because of the identity of the individual as a member of a group, without regard to any individual quality of the individual that is unrelated to that identity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Presumption","label":"B Presumption","identifier":"/us/usc/t15/s9501/15/B","parentIdentifier":"/us/usc/t15/s9501/15","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F15%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9501/15/B/i","parentIdentifier":"/us/usc/t15/s9501/15/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F15%2FB%2Fi","sourceRelease":"119-100","text":"Black or African American;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9501/15/B/ii","parentIdentifier":"/us/usc/t15/s9501/15/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F15%2FB%2Fii","sourceRelease":"119-100","text":"Hispanic or Latino;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s9501/15/B/iii","parentIdentifier":"/us/usc/t15/s9501/15/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F15%2FB%2Fiii","sourceRelease":"119-100","text":"American Indian or Alaska Native;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t15/s9501/15/B/iv","parentIdentifier":"/us/usc/t15/s9501/15/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F15%2FB%2Fiv","sourceRelease":"119-100","text":"Asian;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t15/s9501/15/B/v","parentIdentifier":"/us/usc/t15/s9501/15/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F15%2FB%2Fv","sourceRelease":"119-100","text":"Native Hawaiian or other Pacific Islander; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t15/s9501/15/B/vi","parentIdentifier":"/us/usc/t15/s9501/15/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F15%2FB%2Fvi","sourceRelease":"119-100","text":"a member of a group that the Agency determines under part 1400 of title 15, Code of Federal Regulations, as in effect on , is a socially disadvantaged group eligible to receive assistance.November 23, 1984","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"16","heading":"Specialty center","label":"16 Specialty center","identifier":"/us/usc/t15/s9501/16","parentIdentifier":"/us/usc/t15/s9501","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F16","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9501/16/A","parentIdentifier":"/us/usc/t15/s9501/16","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F16%2FA","sourceRelease":"119-100","text":"capital access;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9501/16/B","parentIdentifier":"/us/usc/t15/s9501/16","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F16%2FB","sourceRelease":"119-100","text":"Federal procurement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9501/16/C","parentIdentifier":"/us/usc/t15/s9501/16","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F16%2FC","sourceRelease":"119-100","text":"entrepreneurship;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s9501/16/D","parentIdentifier":"/us/usc/t15/s9501/16","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F16%2FD","sourceRelease":"119-100","text":"technology transfer; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":