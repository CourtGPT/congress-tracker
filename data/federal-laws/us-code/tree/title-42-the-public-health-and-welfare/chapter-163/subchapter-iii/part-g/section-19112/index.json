{"type":"section","nativeType":"section","number":"19112","heading":"Entrepreneurial fellowships","label":"19112 Entrepreneurial fellowships","identifier":"/us/usc/t42/s19112","parentIdentifier":"/us/usc/t42/ch163/schIII/ptG","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19112","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s19112/a","parentIdentifier":"/us/usc/t42/s19112","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19112%2Fa","sourceRelease":"119-100","text":"The Director, acting through the Directorate for Technology, Innovation, and Partnerships, shall award fellowships to scientists and engineers to help develop leaders capable of maturing promising ideas and technologies from lab to market or other use and forge connections between academic research and the government, industry, financial sectors, and other end users.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Application","label":"b Application","identifier":"/us/usc/t42/s19112/b","parentIdentifier":"/us/usc/t42/s19112","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19112%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19112/b/1","parentIdentifier":"/us/usc/t42/s19112/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19112%2Fb%2F1","sourceRelease":"119-100","text":"have completed a doctoral degree in a STEM field no more than 5 years prior to the date of the application, or have otherwise demonstrated significant postbaccalaureate scientific research experience and are considered early career, according to requirements established by the Director; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19112/b/2","parentIdentifier":"/us/usc/t42/s19112/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19112%2Fb%2F2","sourceRelease":"119-100","text":"have included in the application a proposal for how the fellow will be embedded in a host institution’s research environment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Outreach","label":"c Outreach","identifier":"/us/usc/t42/s19112/c","parentIdentifier":"/us/usc/t42/s19112","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19112%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19112/c/1","parentIdentifier":"/us/usc/t42/s19112/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19112%2Fc%2F1","sourceRelease":"119-100","text":"from diverse research institutions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19112/c/2","parentIdentifier":"/us/usc/t42/s19112/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19112%2Fc%2F2","sourceRelease":"119-100","text":"from all regions of the country; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19112/c/3","parentIdentifier":"/us/usc/t42/s19112/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19112%2Fc%2F3","sourceRelease":"119-100","text":"from groups historically underrepresented in STEM fields.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Administration agreements","label":"d Administration agreements","identifier":"/us/usc/t42/s19112/d","parentIdentifier":"/us/usc/t42/s19112","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19112%2Fd","sourceRelease":"119-100","text":"The Director may enter into an agreement with a qualified third-party entity to administer the fellowships, subject to the provisions of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s19112/e","parentIdentifier":"/us/usc/t42/s19112","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19112%2Fe","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Director a total of $125,000,000 for fiscal years 2023 through 2027, to carry out the activities outlined in this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
