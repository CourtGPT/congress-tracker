{"type":"section","nativeType":"section","number":"690c","heading":"Selection of Renewable Fuel Capital Investment companies","label":"690c Selection of Renewable Fuel Capital Investment companies","identifier":"/us/usc/t15/s690c","parentIdentifier":"/us/usc/t15/ch14B/schIII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Eligibility","label":"a Eligibility","identifier":"/us/usc/t15/s690c/a","parentIdentifier":"/us/usc/t15/s690c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s690c/a/1","parentIdentifier":"/us/usc/t15/s690c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fa%2F1","sourceRelease":"119-100","text":"is a newly formed for-profit entity or a newly formed for-profit subsidiary of an existing entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s690c/a/2","parentIdentifier":"/us/usc/t15/s690c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fa%2F2","sourceRelease":"119-100","text":"has a management team with experience in alternative energy financing or relevant venture capital financing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s690c/a/3","parentIdentifier":"/us/usc/t15/s690c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fa%2F3","sourceRelease":"119-100","text":"has a primary objective of investment in smaller enterprises that research, manufacture, develop, produce, or bring to market goods, products, or services that generate or support the production of renewable energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Application","label":"b Application","identifier":"/us/usc/t15/s690c/b","parentIdentifier":"/us/usc/t15/s690c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s690c/b/1","parentIdentifier":"/us/usc/t15/s690c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fb%2F1","sourceRelease":"119-100","text":"a business plan describing how the company intends to make successful venture capital investments in smaller enterprises primarily engaged in the research, manufacture, development, production, or bringing to market of goods, products, or services that generate or support the production of renewable energy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s690c/b/2","parentIdentifier":"/us/usc/t15/s690c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fb%2F2","sourceRelease":"119-100","text":"information regarding the relevant venture capital qualifications and general reputation of the management of the company;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s690c/b/3","parentIdentifier":"/us/usc/t15/s690c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fb%2F3","sourceRelease":"119-100","text":"a description of how the company intends to seek to address the unmet capital needs of the smaller enterprises served;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s690c/b/4","parentIdentifier":"/us/usc/t15/s690c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fb%2F4","sourceRelease":"119-100","text":"a proposal describing how the company intends to use the grant funds provided under this part to provide operational assistance to smaller enterprises financed by the company, including information regarding whether the company has employees with appropriate professional licenses or will contract with another entity when the services of such an individual are necessary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s690c/b/5","parentIdentifier":"/us/usc/t15/s690c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fb%2F5","sourceRelease":"119-100","text":"with respect to binding commitments to be made to the company under this part, an estimate of the ratio of cash to in-kind contributions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s690c/b/6","parentIdentifier":"/us/usc/t15/s690c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fb%2F6","sourceRelease":"119-100","text":"a description of whether and to what extent the company meets the criteria under subsection (c)(2) and the objectives of the program established under this part;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t15/s690c/b/7","parentIdentifier":"/us/usc/t15/s690c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fb%2F7","sourceRelease":"119-100","text":"information regarding the management and financial strength of any parent firm, affiliated firm, or any other firm essential to the success of the business plan of the company; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t15/s690c/b/8","parentIdentifier":"/us/usc/t15/s690c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fb%2F8","sourceRelease":"119-100","text":"such other information as the Administrator may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Conditional approval","label":"c Conditional approval","identifier":"/us/usc/t15/s690c/c","parentIdentifier":"/us/usc/t15/s690c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s690c/c/1","parentIdentifier":"/us/usc/t15/s690c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fc%2F1","sourceRelease":"119-100","text":"From among companies submitting applications under subsection (b), the Administrator shall conditionally approve companies to operate as Renewable Fuel Capital Investment companies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Selection criteria","label":"2 Selection criteria","identifier":"/us/usc/t15/s690c/c/2","parentIdentifier":"/us/usc/t15/s690c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s690c/c/2/A","parentIdentifier":"/us/usc/t15/s690c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the likelihood that the company will meet the goal of its business plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s690c/c/2/B","parentIdentifier":"/us/usc/t15/s690c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the experience and background of the management team of the company;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s690c/c/2/C","parentIdentifier":"/us/usc/t15/s690c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fc%2F2%2FC","sourceRelease":"119-100","text":"the need for venture capital investments in the geographic areas in which the company intends to invest;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s690c/c/2/D","parentIdentifier":"/us/usc/t15/s690c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fc%2F2%2FD","sourceRelease":"119-100","text":"the extent to which the company will concentrate its activities on serving the geographic areas in which it intends to invest;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s690c/c/2/E","parentIdentifier":"/us/usc/t15/s690c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fc%2F2%2FE","sourceRelease":"119-100","text":"the likelihood that the company will be able to satisfy the conditions under subsection (d);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t15/s690c/c/2/F","parentIdentifier":"/us/usc/t15/s690c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fc%2F2%2FF","sourceRelease":"119-100","text":"the extent to which the activities proposed by the company will expand economic opportunities in the geographic areas in which the company intends to invest;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t15/s690c/c/2/G","parentIdentifier":"/us/usc/t15/s690c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fc%2F2%2FG","sourceRelease":"119-100","text":"the strength of the proposal by the company to provide operational assistance under this part as the proposal relates to the ability of the company to meet applicable cash requirements and properly use in-kind contributions, including the use of resources for the services of licensed professionals, when necessary, whether provided by employees or contractors; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t15/s690c/c/2/H","parentIdentifier":"/us/usc/t15/s690c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fc%2F2%2FH","sourceRelease":"119-100","text":"any other factor determined appropriate by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Nationwide distribution","label":"3 Nationwide distribution","identifier":"/us/usc/t15/s690c/c/3","parentIdentifier":"/us/usc/t15/s690c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fc%2F3","sourceRelease":"119-100","text":"From among companies submitting applications under subsection (b), the Administrator shall consider the selection criteria under paragraph (2) and shall, to the maximum extent practicable, approve at least one company from each geographic region of the Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Requirements to be met for final approval","label":"d Requirements to be met for final approval","identifier":"/us/usc/t15/s690c/d","parentIdentifier":"/us/usc/t15/s690c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s690c/d/1","parentIdentifier":"/us/usc/t15/s690c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fd%2F1","sourceRelease":"119-100","text":"The Administrator shall grant each conditionally approved company 2 years to satisfy the requirements of this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Capital requirement","label":"2 Capital requirement","identifier":"/us/usc/t15/s690c/d/2","parentIdentifier":"/us/usc/t15/s690c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fd%2F2","sourceRelease":"119-100","text":"Each conditionally approved company shall raise not less than $3,000,000 of private capital or binding capital commitments from 1 or more investors (which shall not be departments or agencies of the Federal Government) who meet criteria established by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Nonadministration resources for operational assistance","label":"3 Nonadministration resources for operational assistance","identifier":"/us/usc/t15/s690c/d/3","parentIdentifier":"/us/usc/t15/s690c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s690c/d/3/A","parentIdentifier":"/us/usc/t15/s690c/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fd%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s690c/d/3/A/i","parentIdentifier":"/us/usc/t15/s690c/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fd%2F3%2FA%2Fi","sourceRelease":"119-100","text":"from sources other than the Administration that meet criteria established by the Administrator; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s690c/d/3/A/ii","parentIdentifier":"/us/usc/t15/s690c/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fd%2F3%2FA%2Fii","sourceRelease":"119-100","text":"payable or available over a multiyear period determined appropriate by the Administrator (not to exceed 10 years).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exception","label":"B Exception","identifier":"/us/usc/t15/s690c/d/3/B","parentIdentifier":"/us/usc/t15/s690c/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fd%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s690c/d/3/B/i","parentIdentifier":"/us/usc/t15/s690c/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fd%2F3%2FB%2Fi","sourceRelease":"119-100","text":"a viable plan that reasonably projects the capacity of the applicant to raise the amount (in cash or in-kind) required under subparagraph (A); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s690c/d/3/B/ii","parentIdentifier":"/us/usc/t15/s690c/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fd%2F3%2FB%2Fii","sourceRelease":"119-100","text":"binding commitments in an amount equal to not less than 20 percent of the total amount required under paragraph (A).1So in original. Probably should be “subparagraph”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Limitation","label":"C Limitation","identifier":"/us/usc/t15/s690c/d/3/C","parentIdentifier":"/us/usc/t15/s690c/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fd%2F3%2FC","sourceRelease":"119-100","text":"The total amount of a in-kind contributions by a company shall be not more than 50 percent of the total contributions by a company.2So in original. The article probably should not appear.2","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Final approval; designation","label":"e Final approval; designation","identifier":"/us/usc/t15/s690c/e","parentIdentifier":"/us/usc/t15/s690c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s690c/e/1","parentIdentifier":"/us/usc/t15/s690c/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s690c/e/1/A","parentIdentifier":"/us/usc/t15/s690c/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fe%2F1%2FA","sourceRelease":"119-100","text":"satisfies the requirements of subsection (d) on or before the expiration of the time period described in that subsection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s690c/e/1/B","parentIdentifier":"/us/usc/t15/s690c/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fe%2F1%2FB","sourceRelease":"119-100","text":"enters into a participation agreement with the Administrator; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s690c/e/2","parentIdentifier":"/us/usc/t15/s690c/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690c%2Fe%2F2","sourceRelease":"119-100","text":"if the applicant fails to satisfy the requirements of subsection (d) on or before the expiration of the time period described in paragraph (1) of that subsection, revoke the conditional approval granted under that subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
