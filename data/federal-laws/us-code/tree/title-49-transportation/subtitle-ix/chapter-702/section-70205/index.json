[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s70205/d/1/C","parentIdentifier":"/us/usc/t49/s70205/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70205%2Fd%2F1%2FC","sourceRelease":"119-100","text":"quantifying the national impact of blocked railroad crossings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t49/s70205/d/1/D","parentIdentifier":"/us/usc/t49/s70205/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70205%2Fd%2F1%2FD","sourceRelease":"119-100","text":"improved techniques for estimating and quantifying public benefits derived from freight transportation projects; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t49/s70205/d/1/E","parentIdentifier":"/us/usc/t49/s70205/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70205%2Fd%2F1%2FE","sourceRelease":"119-100","text":"low-cost methods to reduce congestion at bottlenecks.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s70205/d/2","parentIdentifier":"/us/usc/t49/s70205/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70205%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s70205/d/2/A","parentIdentifier":"/us/usc/t49/s70205/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70205%2Fd%2F2%2FA","sourceRelease":"119-100","text":"consider