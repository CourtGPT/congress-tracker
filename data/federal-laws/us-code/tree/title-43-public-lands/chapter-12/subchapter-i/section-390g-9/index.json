ype":"subparagraph","number":"C","heading":"Modifications to contracts","label":"C Modifications to contracts","identifier":"/us/usc/t43/s390g–9/c/2/C","parentIdentifier":"/us/usc/t43/s390g–9/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s390g–9/c/2/C/i","parentIdentifier":"/us/usc/t43/s390g–9/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F2%2FC%2Fi","sourceRelease":"119-100","text":"necessary to allow for the use of water available under the contract for aquifer recharge under this subsection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s390g–9/c/2/C/ii","parentIdentifier":"/us/usc/t43/s390g–9/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F2%2FC%2Fii","sourceRelease":"119-100","text":"in the best interest of the Reclamation project and the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t43/s390g–9/c/2/C/iii","parentIdentifier":"/us/usc/t43/s390g–9/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F2%2FC%2Fiii","sourceRelease":"119-100","text":"approved by the contractor that is responsible for repaying the cost of construction, operations, and maintenance of the facility that delivers the water under the contract.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Requirements","label":"D Requirements","identifier":"/us/usc/t43/s390g–9/c/2/D","parentIdentifier":"/us/usc/t43/s390g–9/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s390g–9/c/2/D/i","parentIdentifier":"/us/usc/t43/s390g–9/c/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F2%2FD%2Fi","sourceRelease":"119-100","text":"the use or transfer shall not be implemented in a manner that materially impacts any power service or water contract for the Reclamation project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s390g–9/c/2/D/ii","parentIdentifier":"/us/usc/t43/s390g–9/c/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F2%2FD%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s390g–9/c/2/D/ii/I","parentIdentifier":"/us/usc/t43/s390g–9/c/2/D/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F2%2FD%2Fii%2FI","sourceRelease":"119-100","text":"results in a net water storage benefit for the Reclamation project; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s390g–9/c/2/D/ii/II","parentIdentifier":"/us/usc/t43/s390g–9/c/2/D/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F2%2FD%2Fii%2FII","sourceRelease":"119-100","text":"contributes to the recharge of an aquifer on eligible land; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t43/s390g–9/c/2/D/iii","parentIdentifier":"/us/usc/t43/s390g–9/c/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F2%2FD%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s390g–9/c/2/D/iii/I","parentIdentifier":"/us/usc/t43/s390g–9/c/2/D/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F2%2FD%2Fiii%2FI","sourceRelease":"119-100","text":"Federal laws and policies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s390g–9/c/2/D/iii/II","parentIdentifier":"/us/usc/t43/s390g–9/c/2/D/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F2%2FD%2Fiii%2FII","sourceRelease":"119-100","text":"interstate water compacts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Conveyance for aquifer recharge purposes","label":"3 Conveyance for aquifer recharge purposes","identifier":"/us/usc/t43/s390g–9/c/3","parentIdentifier":"/us/usc/t43/s390g–9/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F3","sourceRelease":"119-100","text":"The holder of a right-of-way, easement, permit, or other authorization to transport water across public land administered by the Bureau of Land Management may transport water for aquifer recharge purposes without requiring additional authorization from the Secretary where the use does not expand or modify the operation of the right-of-way, easement, permit, or other authorization across public land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Effect","label":"4 Effect","identifier":"/us/usc/t43/s390g–9/c/4","parentIdentifier":"/us/usc/t43/s390g–9/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F4","sourceRelease":"119-100","text":"Nothing in this section creates, impairs, alters, or supersedes a Federal or State water right.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Exemption","label":"5 Exemption","identifier":"/us/usc/t43/s390g–9/c/5","parentIdentifier":"/us/usc/t43/s390g–9/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F5","sourceRelease":"119-100","text":"This section shall not apply to the State of California.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Advisory group","label":"6 Advisory group","identifier":"/us/usc/t43/s390g–9/c/6","parentIdentifier":"/us/usc/t43/s390g–9/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F6","sourceRelease":"119-100","text":"The Secretary may participate in any State-led collaborative, multi-stakeholder advisory group created in any watershed the purpose of which is to monitor, review, and assess aquifer recharge activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
