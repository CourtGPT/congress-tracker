{"type":"section","nativeType":"section","number":"6705","heading":"Cooperation between Institutes and Federal agencies","label":"6705 Cooperation between Institutes and Federal agencies","identifier":"/us/usc/t16/s6705","parentIdentifier":"/us/usc/t16/ch86","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s6705/1","parentIdentifier":"/us/usc/t16/s6705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705%2F1","sourceRelease":"119-100","text":"to the extent that funds are appropriated for the purpose, shall provide financial and technical assistance to the Institutes to carry out the duties of the Institutes under ;section 6704 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6705/2","parentIdentifier":"/us/usc/t16/s6705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705%2F2","sourceRelease":"119-100","text":"shall encourage Federal agencies to use, on a cooperative basis, information and expertise provided by the Institutes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s6705/3","parentIdentifier":"/us/usc/t16/s6705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6705/3/A","parentIdentifier":"/us/usc/t16/s6705/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705%2F3%2FA","sourceRelease":"119-100","text":"ecological restoration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6705/3/B","parentIdentifier":"/us/usc/t16/s6705/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705%2F3%2FB","sourceRelease":"119-100","text":"wildfire risk reduction; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6705/3/C","parentIdentifier":"/us/usc/t16/s6705/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705%2F3%2FC","sourceRelease":"119-100","text":"wildfire management technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s6705/4","parentIdentifier":"/us/usc/t16/s6705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6705/4/A","parentIdentifier":"/us/usc/t16/s6705/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705%2F4%2FA","sourceRelease":"119-100","text":"enter into contracts, cooperative agreements, and interagency personnel agreements to carry out this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6705/4/B","parentIdentifier":"/us/usc/t16/s6705/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705%2F4%2FB","sourceRelease":"119-100","text":"carry out other transactions under this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s6705/5","parentIdentifier":"/us/usc/t16/s6705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705%2F5","sourceRelease":"119-100","text":"may accept funds from other Federal agencies to supplement or fully fund grants made, and contracts entered into, by the Secretaries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s6705/6","parentIdentifier":"/us/usc/t16/s6705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705%2F6","sourceRelease":"119-100","text":"may support a program of internships for qualified individuals at the undergraduate and graduate levels to carry out the educational and training objectives of this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t16/s6705/7","parentIdentifier":"/us/usc/t16/s6705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705%2F7","sourceRelease":"119-100","text":"shall encourage professional education and public information activities relating to the purposes of this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t16/s6705/8","parentIdentifier":"/us/usc/t16/s6705","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6705%2F8","sourceRelease":"119-100","text":"may promulgate such regulations as the Secretaries determine are necessary to carry out this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
