{"type":"section","nativeType":"section","number":"2402","heading":"Rural water supply program","label":"2402 Rural water supply program","identifier":"/us/usc/t43/s2402","parentIdentifier":"/us/usc/t43/ch42/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t43/s2402/a","parentIdentifier":"/us/usc/t43/s2402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2402/a/1","parentIdentifier":"/us/usc/t43/s2402/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fa%2F1","sourceRelease":"119-100","text":"investigate and identify opportunities to ensure safe and adequate rural water supply projects for domestic, municipal, and industrial use in small communities and rural areas of the Reclamation States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2402/a/2","parentIdentifier":"/us/usc/t43/s2402/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fa%2F2","sourceRelease":"119-100","text":"plan the design and construction, through the conduct of appraisal investigations and feasibility studies, of rural water supply projects in Reclamation States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s2402/a/3","parentIdentifier":"/us/usc/t43/s2402/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fa%2F3","sourceRelease":"119-100","text":"oversee, as appropriate, the construction of rural water supply projects in Reclamation States that are recommended by the Secretary in a feasibility report developed pursuant to and subsequently authorized by Congress.section 2405 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Non-Federal project entity","label":"b Non-Federal project entity","identifier":"/us/usc/t43/s2402/b","parentIdentifier":"/us/usc/t43/s2402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fb","sourceRelease":"119-100","text":"Any activity carried out under this subchapter shall be carried out in cooperation with a qualifying non-Federal project entity, consistent with this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Eligibility criteria","label":"c Eligibility criteria","identifier":"/us/usc/t43/s2402/c","parentIdentifier":"/us/usc/t43/s2402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2402/c/1","parentIdentifier":"/us/usc/t43/s2402/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fc%2F1","sourceRelease":"119-100","text":"determining the eligibility of a rural community for assistance under the Program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2402/c/2","parentIdentifier":"/us/usc/t43/s2402/c","sourceUrl":"https://uscode.house.gov/view.xht