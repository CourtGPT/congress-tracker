{"type":"section","nativeType":"section","number":"16155","heading":"Hydrogen and Fuel Cell Technical Task Force","label":"16155 Hydrogen and Fuel Cell Technical Task Force","identifier":"/us/usc/t42/s16155","parentIdentifier":"/us/usc/t42/ch149/schVIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t42/s16155/a","parentIdentifier":"/us/usc/t42/s16155","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16155/a/1","parentIdentifier":"/us/usc/t42/s16155/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fa%2F1","sourceRelease":"119-100","text":"The Office of Science and Technology Policy within the Executive Office of the President.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16155/a/2","parentIdentifier":"/us/usc/t42/s16155/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fa%2F2","sourceRelease":"119-100","text":"The Department of Transportation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16155/a/3","parentIdentifier":"/us/usc/t42/s16155/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fa%2F3","sourceRelease":"119-100","text":"The Department of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16155/a/4","parentIdentifier":"/us/usc/t42/s16155/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fa%2F4","sourceRelease":"119-100","text":"The Department of Commerce (including the National Institute of Standards and Technology).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16155/a/5","parentIdentifier":"/us/usc/t42/s16155/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fa%2F5","sourceRelease":"119-100","text":"The Department of State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s16155/a/6","parentIdentifier":"/us/usc/t42/s16155/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fa%2F6","sourceRelease":"119-100","text":"The Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s16155/a/7","parentIdentifier":"/us/usc/t42/s16155/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fa%2F7","sourceRelease":"119-100","text":"The National Aeronautics and Space Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s16155/a/8","parentIdentifier":"/us/usc/t42/s16155/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fa%2F8","sourceRelease":"119-100","text":"Other Federal agencies as the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties","label":"b Duties","identifier":"/us/usc/t42/s16155/b","parentIdentifier":"/us/usc/t42/s16155","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Planning","label":"1 Planning","identifier":"/us/usc/t42/s16155/b/1","parentIdentifier":"/us/usc/t42/s16155/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16155/b/1/A","parentIdentifier":"/us/usc/t42/s16155/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fb%2F1%2FA","sourceRelease":"119-100","text":"a safe, economical, and environmentally sound fuel infrastructure for hydrogen and hydrogen-carrier fuels, including an infrastructure that supports buses and other fleet transportation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16155/b/1/B","parentIdentifier":"/us/usc/t42/s16155/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fb%2F1%2FB","sourceRelease":"119-100","text":"fuel cells in government and other applications, including portable, stationary, and transportation applications;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16155/b/1/C","parentIdentifier":"/us/usc/t42/s16155/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fb%2F1%2FC","sourceRelease":"119-100","text":"distributed power generation, including the generation of combined heat, power, and clean fuels including hydrogen;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16155/b/1/D","parentIdentifier":"/us/usc/t42/s16155/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fb%2F1%2FD","sourceRelease":"119-100","text":"uniform hydrogen codes, standards, and safety protocols; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16155/b/1/E","parentIdentifier":"/us/usc/t42/s16155/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fb%2F1%2FE","sourceRelease":"119-100","text":"vehicle hydrogen fuel system integrity safety performance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Activities","label":"2 Activities","identifier":"/us/usc/t42/s16155/b/2","parentIdentifier":"/us/usc/t42/s16155/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16155/b/2/A","parentIdentifier":"/us/usc/t42/s16155/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fb%2F2%2FA","sourceRelease":"119-100","text":"foster the exchange of generic, nonproprietary information and technology among industry, academia, and government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16155/b/2/B","parentIdentifier":"/us/usc/t42/s16155/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fb%2F2%2FB","sourceRelease":"119-100","text":"develop and maintain an inventory and assessment of hydrogen, fuel cells, and other advanced technologies, including the commercial capability of each technology for the economic and environmentally safe production, distribution, delivery, storage, and use of hydrogen;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16155/b/2/C","parentIdentifier":"/us/usc/t42/s16155/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fb%2F2%2FC","sourceRelease":"119-100","text":"integrate technical and other information made available as a result of the programs and activities under this subchapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16155/b/2/D","parentIdentifier":"/us/usc/t42/s16155/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fb%2F2%2FD","sourceRelease":"119-100","text":"promote the marketplace introduction of infrastructure for hydrogen fuel vehicles; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16155/b/2/E","parentIdentifier":"/us/usc/t42/s16155/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fb%2F2%2FE","sourceRelease":"119-100","text":"conduct an education program to provide hydrogen and fuel cell information to potential end-users.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Agency cooperation","label":"c Agency cooperation","identifier":"/us/usc/t42/s16155/c","parentIdentifier":"/us/usc/t42/s16155","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16155%2Fc","sourceRelease":"119-100","text":"The heads of all agencies, including those whose agencies are not represented on the Task Force, shall cooperate with and furnish information to the Task Force, the Technical Advisory Committee, and the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
