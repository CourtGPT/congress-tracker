{"type":"section","nativeType":"section","number":"459","heading":"Office of International Affairs","label":"459 Office of International Affairs","identifier":"/us/usc/t6/s459","parentIdentifier":"/us/usc/t6/ch1/schVIII/ptH","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs459","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t6/s459/a","parentIdentifier":"/us/usc/t6/s459","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs459%2Fa","sourceRelease":"119-100","text":"There is established within the Office of the Secretary an Office of International Affairs. The Office shall be headed by a Director, who shall be a senior official appointed by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties of the Director","label":"b Duties of the Director","identifier":"/us/usc/t6/s459/b","parentIdentifier":"/us/usc/t6/s459","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs459%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s459/b/1","parentIdentifier":"/us/usc/t6/s459/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs459%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s459/b/1/A","parentIdentifier":"/us/usc/t6/s459/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs459%2Fb%2F1%2FA","sourceRelease":"119-100","text":"Exchange of information on research and development on homeland security technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s459/b/1/B","parentIdentifier":"/us/usc/t6/s459/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs459%2Fb%2F1%2FB","sourceRelease":"119-100","text":"Joint training exercises of first responders.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s459/b/1/C","parentIdentifier":"/us/usc/t6/s459/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs459%2Fb%2F1%2FC","sourceRelease":"119-100","text":"Exchange of expertise on terrorism prevention, response, and crisis management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s459/b/2","parentIdentifier":"/us/usc/t6/s459/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs459%2Fb%2F2","sourceRelease":"119-100","text":"To identify areas for homeland security information and training exchange where the United States has a demonstrated weakness and another friendly nation or nations have a demonstrated expertise.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s459/b/3","parentIdentifier":"/us/usc/t6/s459/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs459%2Fb%2F3","sourceRelease":"119-100","text":"To plan and undertake international conferences, exchange programs, and training activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s459/b/4","parentIdentifier":"/us/usc/t6/s459/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs459%2Fb%2F4","sourceRelease":"119-100","text":"To manage international activities within the Department in coordination with other Federal officials with responsibility for counter-terrorism matters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
