{"type":"section","nativeType":"section","number":"13415","heading":"Midcontinent Energy Research Center","label":"13415 Midcontinent Energy Research Center","identifier":"/us/usc/t42/s13415","parentIdentifier":"/us/usc/t42/ch134/schVIII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Finding","label":"a Finding","identifier":"/us/usc/t42/s13415/a","parentIdentifier":"/us/usc/t42/s13415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fa","sourceRelease":"119-100","text":"Congress finds that petroleum resources in the midcontinent region of the United States are very large but are being prematurely abandoned.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purposes","label":"b Purposes","identifier":"/us/usc/t42/s13415/b","parentIdentifier":"/us/usc/t42/s13415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13415/b/1","parentIdentifier":"/us/usc/t42/s13415/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fb%2F1","sourceRelease":"119-100","text":"improve the efficiency of petroleum recovery;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13415/b/2","parentIdentifier":"/us/usc/t42/s13415/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fb%2F2","sourceRelease":"119-100","text":"increase ultimate petroleum recovery; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13415/b/3","parentIdentifier":"/us/usc/t42/s13415/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fb%2F3","sourceRelease":"119-100","text":"delay the abandonment of resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Establishment","label":"c Establishment","identifier":"/us/usc/t42/s13415/c","parentIdentifier":"/us/usc/t42/s13415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13415/c/1","parentIdentifier":"/us/usc/t42/s13415/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fc%2F1","sourceRelease":"119-100","text":"conduct research in petroleum geology and engineering focused on improving the recovery of petroleum from existing fields and established plays in the upper midcontinent region of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13415/c/2","parentIdentifier":"/us/usc/t42/s13415/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fc%2F2","sourceRelease":"119-100","text":"ensure that the results of the research described in paragraph (1) are transferred to users.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Research","label":"d Research","identifier":"/us/usc/t42/s13415/d","parentIdentifier":"/us/usc/t42/s13415","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s13415/d/1","parentIdentifier":"/us/usc/t42/s13415/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fd%2F1","sourceRelease":"119-100","text":"In conducting research under this section, the Center shall, to the extent practicable, cooperate with agencies of the Federal Government, the States in the midcontinent region of the United States, and the affected industry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Programs","label":"2 Programs","identifier":"/us/usc/t42/s13415/d/2","parentIdentifier":"/us/usc/t42/s13415/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13415/d/2/A","parentIdentifier":"/us/usc/t42/s13415/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fd%2F2%2FA","sourceRelease":"119-100","text":"data base development and transfer of technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13415/d/2/B","parentIdentifier":"/us/usc/t42/s13415/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fd%2F2%2FB","sourceRelease":"119-100","text":"reservoir management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s13415/d/2/C","parentIdentifier":"/us/usc/t42/s13415/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fd%2F2%2FC","sourceRelease":"119-100","text":"reservoir characterization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s13415/d/2/D","parentIdentifier":"/us/usc/t42/s13415/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fd%2F2%2FD","sourceRelease":"119-100","text":"advanced recovery methods; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s13415/d/2/E","parentIdentifier":"/us/usc/t42/s13415/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13415%2Fd%2F2%2FE","sourceRelease":"119-100","text":"development of new technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
