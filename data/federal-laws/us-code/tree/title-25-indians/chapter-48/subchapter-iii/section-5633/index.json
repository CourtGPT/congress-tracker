{"type":"section","nativeType":"section","number":"5633","heading":"Under Secretary for Indian Affairs","label":"5633 Under Secretary for Indian Affairs","identifier":"/us/usc/t25/s5633","parentIdentifier":"/us/usc/t25/ch48/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment of position","label":"a Establishment of position","identifier":"/us/usc/t25/s5633/a","parentIdentifier":"/us/usc/t25/s5633","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fa","sourceRelease":"119-100","text":"Notwithstanding any other provision of law, the Secretary may establish in the Department the position of Under Secretary for Indian Affairs, who shall report directly to the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Appointment","label":"b Appointment","identifier":"/us/usc/t25/s5633/b","parentIdentifier":"/us/usc/t25/s5633","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s5633/b/1","parentIdentifier":"/us/usc/t25/s5633/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fb%2F1","sourceRelease":"119-100","text":"Except as provided in paragraph (2), the Under Secretary shall be appointed by the President, by and with the advice and consent of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Exception","label":"2 Exception","identifier":"/us/usc/t25/s5633/b/2","parentIdentifier":"/us/usc/t25/s5633/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s5633/b/2/A","parentIdentifier":"/us/usc/t25/s5633/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fb%2F2%2FA","sourceRelease":"119-100","text":"that individual was appointed as Assistant Secretary for Indian Affairs by the President, by and with the advice and consent of the Senate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s5633/b/2/B","parentIdentifier":"/us/usc/t25/s5633/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fb%2F2%2FB","sourceRelease":"119-100","text":"not later than 180 days after , the Secretary approves the assumption.June 22, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duties","label":"c Duties","identifier":"/us/usc/t25/s5633/c","parentIdentifier":"/us/usc/t25/s5633","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s5633/c/1","parentIdentifier":"/us/usc/t25/s5633/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fc%2F1","sourceRelease":"119-100","text":"coordinate with the Special Trustee for American Indians to ensure an orderly transition of the functions of the Special Trustee to one or more appropriate agencies, offices, or bureaus within the Department, as determined by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s5633/c/2","parentIdentifier":"/us/usc/t25/s5633/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s5633/c/2/A","parentIdentifier":"/us/usc/t25/s5633/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the Bureau of Reclamation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s5633/c/2/B","parentIdentifier":"/us/usc/t25/s5633/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the Bureau of Land Management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s5633/c/2/C","parentIdentifier":"/us/usc/t25/s5633/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fc%2F2%2FC","sourceRelease":"119-100","text":"the Office of Natural Resources Revenue;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s5633/c/2/D","parentIdentifier":"/us/usc/t25/s5633/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fc%2F2%2FD","sourceRelease":"119-100","text":"the National Park Service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t25/s5633/c/2/E","parentIdentifier":"/us/usc/t25/s5633/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fc%2F2%2FE","sourceRelease":"119-100","text":"the United States Fish and Wildlife Service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s5633/c/3","parentIdentifier":"/us/usc/t25/s5633/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fc%2F3","sourceRelease":"119-100","text":"provide for regular consultation with Indians and Indian tribes that own interests in trust resources and trust fund accounts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Personnel provisions","label":"d Personnel provisions","identifier":"/us/usc/t25/s5633/d","parentIdentifier":"/us/usc/t25/s5633","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Appointments","label":"1 Appointments","identifier":"/us/usc/t25/s5633/d/1","parentIdentifier":"/us/usc/t25/s5633/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fd%2F1","sourceRelease":"119-100","text":"The Under Secretary may appoint and fix the compensation of such officers and employees as the Under Secretary determines to be necessary to carry out any function transferred under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t25/s5633/d/2","parentIdentifier":"/us/usc/t25/s5633/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s5633/d/2/A","parentIdentifier":"/us/usc/t25/s5633/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fd%2F2%2FA","sourceRelease":"119-100","text":"any officer or employee described in paragraph (1) shall be appointed in accordance with the civil service laws;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s5633/d/2/B","parentIdentifier":"/us/usc/t25/s5633/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fd%2F2%2FB","sourceRelease":"119-100","text":"the compensation of such an officer or employee shall be fixed in accordance with title 5; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s5633/d/2/C","parentIdentifier":"/us/usc/t25/s5633/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5633%2Fd%2F2%2FC","sourceRelease":"119-100","text":"in appointing or otherwise hiring any employee, the Under Secretary shall give preference to Indians in accordance with .section 5116 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
