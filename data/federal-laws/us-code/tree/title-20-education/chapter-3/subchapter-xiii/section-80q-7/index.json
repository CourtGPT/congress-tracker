{"type":"section","nativeType":"section","number":"80q–7","heading":"Audubon Terrace","label":"80q–7 Audubon Terrace","identifier":"/us/usc/t20/s80q–7","parentIdentifier":"/us/usc/t20/ch3/schXIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%937","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t20/s80q–7/a","parentIdentifier":"/us/usc/t20/s80q–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%937%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s80q–7/a/1","parentIdentifier":"/us/usc/t20/s80q–7/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%937%2Fa%2F1","sourceRelease":"119-100","text":"assure that, on the date on which a qualified successor to the Heye Foundation at Audubon Terrace first takes possession of Audubon Terrace, an area of at least 2,000 square feet at that facility is accessible to the public and physically suitable for exhibition of museum objects and for related exhibition activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s80q–7/a/2","parentIdentifier":"/us/usc/t20/s80q–7/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%937%2Fa%2F2","sourceRelease":"119-100","text":"upon written agreement between the Board and any qualified successor, lend objects from the collections of the Smithsonian Institution to the successor for exhibition at Audubon Terrace; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s80q–7/a/3","parentIdentifier":"/us/usc/t20/s80q–7/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%937%2Fa%2F3","sourceRelease":"119-100","text":"upon written agreement between the Board and any qualified successor, provide training, scholarship, technical, and other assistance (other than operating funds) with respect to the area referred to in paragraph (1) for the purposes described in that paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Determination of charges","label":"b Determination of charges","identifier":"/us/usc/t20/s80q–7/b","parentIdentifier":"/us/usc/t20/s80q–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%937%2Fb","sourceRelease":"119-100","text":"Any charge by the Board of Regents for activities pursuant to agreements under paragraph (2) or (3) of subsection (a) shall be determined according to the ability of the successor to pay.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Definition","label":"c Definition","identifier":"/us/usc/t20/s80q–7/c","parentIdentifier":"/us/usc/t20/s80q–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%937%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s80q–7/c/1","parentIdentifier":"/us/usc/t20/s80q–7/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%937%2Fc%2F1","sourceRelease":"119-100","text":"is a successor occupant to the Heye Foundation at Audubon Terrace, 3753 Broadway, New York, New York;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s80q–7/c/2","parentIdentifier":"/us/usc/t20/s80q–7/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%937%2Fc%2F2","sourceRelease":"119-100","text":"is qualified to operate the area referred to in paragraph (1) for the purposes described in that paragraph; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s80q–7/c/3","parentIdentifier":"/us/usc/t20/s80q–7/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%937%2Fc%2F3","sourceRelease":"119-100","text":"is committed to making a good faith effort to respond to community cultural interests in such operation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
