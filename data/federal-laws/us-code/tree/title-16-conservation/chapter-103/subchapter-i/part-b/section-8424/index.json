{"type":"section","nativeType":"section","number":"8424","heading":"Restoration of overnight campsites","label":"8424 Restoration of overnight campsites","identifier":"/us/usc/t16/s8424","parentIdentifier":"/us/usc/t16/ch103/schI/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t16/s8424/a","parentIdentifier":"/us/usc/t16/s8424","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Recreation Area","label":"1 Recreation Area","identifier":"/us/usc/t16/s8424/a/1","parentIdentifier":"/us/usc/t16/s8424/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fa%2F1","sourceRelease":"119-100","text":"The term “Recreation Area” means the recreation area and grounds associated with the recreation area on the map entitled “Ouachita National Forest Camping Restoration” and dated , on file with the Forest Service.November 30, 2023","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Secretary","label":"2 Secretary","identifier":"/us/usc/t16/s8424/a/2","parentIdentifier":"/us/usc/t16/s8424/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fa%2F2","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Agriculture.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"In general","label":"b In general","identifier":"/us/usc/t16/s8424/b","parentIdentifier":"/us/usc/t16/s8424","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s8424/b/1","parentIdentifier":"/us/usc/t16/s8424/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fb%2F1","sourceRelease":"119-100","text":"not later than 6 months after , identify 54 areas within the Recreation Area that may be suitable for overnight camping; andJanuary 4, 2025","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s8424/b/2","parentIdentifier":"/us/usc/t16/s8424/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8424/b/2/A","parentIdentifier":"/us/usc/t16/s8424/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fb%2F2%2FA","sourceRelease":"119-100","text":"review each area identified under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8424/b/2/B","parentIdentifier":"/us/usc/t16/s8424/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fb%2F2%2FB","sourceRelease":"119-100","text":"from the areas so identified, select and establish at least 27 campsites and related facilities within the Recreation Area for public use.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Requirements related to campsites and related facilities","label":"c Requirements related to campsites and related facilities","identifier":"/us/usc/t16/s8424/c","parentIdentifier":"/us/usc/t16/s8424","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s8424/c/1","parentIdentifier":"/us/usc/t16/s8424/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fc%2F1","sourceRelease":"119-100","text":"ensure that at least 27 campsites are available under subsection (b), of which not less than 8 shall have electric and water hookups; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s8424/c/2","parentIdentifier":"/us/usc/t16/s8424/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fc%2F2","sourceRelease":"119-100","text":"ensure that each campsite and related facility identified or established under subsection (b) is located outside of the 1 percent annual exceedance probability flood elevation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Reopening of certain sites","label":"d Reopening of certain sites","identifier":"/us/usc/t16/s8424/d","parentIdentifier":"/us/usc/t16/s8424","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s8424/d/1","parentIdentifier":"/us/usc/t16/s8424/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fd%2F1","sourceRelease":"119-100","text":"exists on ;January 4, 2025","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s8424/d/2","parentIdentifier":"/us/usc/t16/s8424/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fd%2F2","sourceRelease":"119-100","text":"is located outside of the 1 percent annual exceedance probability flood elevation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s8424/d/3","parentIdentifier":"/us/usc/t16/s8424/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fd%2F3","sourceRelease":"119-100","text":"was in operation on ; andJune 1, 2010","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s8424/d/4","parentIdentifier":"/us/usc/t16/s8424/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fd%2F4","sourceRelease":"119-100","text":"would not interfere with any current (as of ) day use areas.January 4, 2025","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Day use areas","label":"e Day use areas","identifier":"/us/usc/t16/s8424/e","parentIdentifier":"/us/usc/t16/s8424","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s8424/e/1","parentIdentifier":"/us/usc/t16/s8424/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fe%2F1","sourceRelease":"119-100","text":"Loop A.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s8424/e/2","parentIdentifier":"/us/usc/t16/s8424/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fe%2F2","sourceRelease":"119-100","text":"Loop B.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s8424/e/3","parentIdentifier":"/us/usc/t16/s8424/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fe%2F3","sourceRelease":"119-100","text":"The covered, large-group picnic pavilion in Loop D.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s8424/e/4","parentIdentifier":"/us/usc/t16/s8424/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8424%2Fe%2F4","sourceRelease":"119-100","text":"The parking lot in Loop D.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
