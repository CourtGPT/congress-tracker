{"type":"section","nativeType":"section","number":"8205","heading":"Streamlined application for commercial purchasers","label":"8205 Streamlined application for commercial purchasers","identifier":"/us/usc/t15/s8205","parentIdentifier":"/us/usc/t15/ch108/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8205","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8205/1","parentIdentifier":"/us/usc/t15/s8205","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8205%2F1","sourceRelease":"119-100","text":"the broker procuring or placing the surplus lines insurance has disclosed to the exempt commercial purchaser that such insurance may or may not be available from the admitted market that may provide greater protection with more regulatory oversight; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8205/2","parentIdentifier":"/us/usc/t15/s8205","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8205%2F2","sourceRelease":"119-100","text":"the exempt commercial purchaser has subsequently requested in writing the broker to procure or place such insurance from a nonadmitted insurer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
