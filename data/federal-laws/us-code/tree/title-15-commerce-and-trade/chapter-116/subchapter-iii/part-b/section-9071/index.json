{"type":"section","nativeType":"section","number":"9071","heading":"Definitions","label":"9071 Definitions","identifier":"/us/usc/t15/s9071","parentIdentifier":"/us/usc/t15/ch116/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2020—Pars. (5), (6). added par. (5) and redesignated former par. (5) as (6).Pub. L. 116–260"],"amendments":["Amendments2020—Pars. (5), (6). added par. (5) and redesignated former par. (5) as (6).Pub. L. 116–260"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9071/1","parentIdentifier":"/us/usc/t15/s9071","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F1","sourceRelease":"119-100","text":"the term “airline catering employee” means an employee who performs airline catering services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9071/2","parentIdentifier":"/us/usc/t15/s9071","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F2","sourceRelease":"119-100","text":"the term “airline catering services” means preparation, assembly, or both, of food, beverages, provisions and related supplies for delivery, and the delivery of such items, directly to aircraft or to a location on or near airport property for subsequent delivery to aircraft;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s9071/3","parentIdentifier":"/us/usc/t15/s9071","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9071/3/A","parentIdentifier":"/us/usc/t15/s9071/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9071/3/A/i","parentIdentifier":"/us/usc/t15/s9071/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F3%2FA%2Fi","sourceRelease":"119-100","text":"catering functions; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9071/3/A/ii","parentIdentifier":"/us/usc/t15/s9071/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F3%2FA%2Fii","sourceRelease":"119-100","text":"functions on the property of an airport that are directly related to the air transportation of persons, property, or mail, including but not limited to the loading and unloading of property on aircraft; assistance to passengers under part 382 of title 14, Code of Federal Regulations; security; airport ticketing and check-in functions; ground-handling of aircraft; or aircraft cleaning and sanitization functions and waste removal; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9071/3/B","parentIdentifier":"/us/usc/t15/s9071/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F3%2FB","sourceRelease":"119-100","text":"a subcontractor that performs such functions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s9071/4","parentIdentifier":"/us/usc/t15/s9071","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F4","sourceRelease":"119-100","text":"the term “employee” means an individual, other than a corporate officer, who is employed by an air carrier or a contractor;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s9071/5","parentIdentifier":"/us/usc/t15/s9071","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9071/5/A","parentIdentifier":"/us/usc/t15/s9071/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F5%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9071/5/A/i","parentIdentifier":"/us/usc/t15/s9071/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F5%2FA%2Fi","sourceRelease":"119-100","text":"to return to employment or bypass return to employment in accordance with an applicable collective bargaining agreement or, in the absence of a collective bargaining agreement, company policy; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9071/5/A/ii","parentIdentifier":"/us/usc/t15/s9071/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F5%2FA%2Fii","sourceRelease":"119-100","text":"to permanently separate from employment with the contractor; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9071/5/B","parentIdentifier":"/us/usc/t15/s9071/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F5%2FB","sourceRelease":"119-100","text":"failure to respond within such time period specified will be deemed to be an election under subparagraph (A)(ii); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s9071/6","parentIdentifier":"/us/usc/t15/s9071","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9071%2F6","sourceRelease":"119-100","text":"the term “Secretary” means the Secretary of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
