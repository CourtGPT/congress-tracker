{"type":"section","nativeType":"section","number":"2009c","heading":"Strategic plans","label":"2009c Strategic plans","identifier":"/us/usc/t7/s2009c","parentIdentifier":"/us/usc/t7/ch50/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t7/s2009c/a","parentIdentifier":"/us/usc/t7/s2009c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2009c/a/1","parentIdentifier":"/us/usc/t7/s2009c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fa%2F1","sourceRelease":"119-100","text":"for each State for the delivery of assistance under this subchapter in the State; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2009c/a/2","parentIdentifier":"/us/usc/t7/s2009c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fa%2F2","sourceRelease":"119-100","text":"for each federally recognized Indian tribe for the delivery of assistance under this subchapter to the Indian tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Assistance","label":"b Assistance","identifier":"/us/usc/t7/s2009c/b","parentIdentifier":"/us/usc/t7/s2009c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s2009c/b/1","parentIdentifier":"/us/usc/t7/s2009c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fb%2F1","sourceRelease":"119-100","text":"Financial assistance for rural development provided under this subchapter for a State or a federally recognized Indian tribe shall be used only for orderly community development that is consistent with the strategic plan of the State or Indian tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Rural area","label":"2 Rural area","identifier":"/us/usc/t7/s2009c/b/2","parentIdentifier":"/us/usc/t7/s2009c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fb%2F2","sourceRelease":"119-100","text":"Assistance under this subchapter may only be provided in a rural area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Small communities","label":"3 Small communities","identifier":"/us/usc/t7/s2009c/b/3","parentIdentifier":"/us/usc/t7/s2009c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fb%2F3","sourceRelease":"119-100","text":"In carrying out this subchapter in a State, the Secretary shall give priority to communities with the smallest populations and lowest per capita income.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Review","label":"c Review","identifier":"/us/usc/t7/s2009c/c","parentIdentifier":"/us/usc/t7/s2009c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fc","sourceRelease":"119-100","text":"The Secretary shall review the strategic plan of each State and federally recognized Indian tribe not later than 60 days after receiving the plan, and at least once every 5 years thereafter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Contents","label":"d Contents","identifier":"/us/usc/t7/s2009c/d","parentIdentifier":"/us/usc/t7/s2009c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2009c/d/1","parentIdentifier":"/us/usc/t7/s2009c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fd%2F1","sourceRelease":"119-100","text":"coordinates economic, human, and community development plans and related activities proposed for an affected area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2009c/d/2","parentIdentifier":"/us/usc/t7/s2009c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fd%2F2","sourceRelease":"119-100","text":"provides that the State or federally recognized Indian tribe, as appropriate, and an affected community (including local institutions and organizations that have contributed to the planning process) shall act as full partners in the process of developing and implementing the plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s2009c/d/3","parentIdentifier":"/us/usc/t7/s2009c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fd%2F3","sourceRelease":"119-100","text":"identifies goals, methods, and benchmarks for measuring the success of carrying out the plan and how the plan relates to local or regional ecosystems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s2009c/d/4","parentIdentifier":"/us/usc/t7/s2009c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fd%2F4","sourceRelease":"119-100","text":"in the case of a State, provides for the involvement, in the preparation of the plan, of State, local, private, and public persons, State rural development councils, federally recognized Indian tribes in the State, and community-based organizations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s2009c/d/5","parentIdentifier":"/us/usc/t7/s2009c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fd%2F5","sourceRelease":"119-100","text":"identifies the amount and source of Federal and non-Federal resources that are available for carrying out the plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s2009c/d/6","parentIdentifier":"/us/usc/t7/s2009c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009c%2Fd%2F6","sourceRelease":"119-100","text":"includes such other information as may be required by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
