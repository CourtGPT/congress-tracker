{"type":"section","nativeType":"section","number":"300z–2","heading":"Demonstration projects; grant authorization, etc.","label":"300z–2 Demonstration projects; grant authorization, etc.","identifier":"/us/usc/t42/s300z–2","parentIdentifier":"/us/usc/t42/ch6A/schXVIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300z%E2%80%932","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t42/s300z–2/a","parentIdentifier":"/us/usc/t42/s300z–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300z%E2%80%932%2Fa","sourceRelease":"119-100","text":"The Secretary may make grants to further the purposes of this subchapter to eligible grant recipients which have submitted an application which the Secretary finds meets the requirements of for demonstration projects which the Secretary determines will help communities provide appropriate care and prevention services in easily accessible locations. Demonstration projects shall, as appropriate, provide, supplement, or improve the quality of such services. Demonstration projects shall use such methods as will strengthen the capacity of families to deal with the sexual behavior, pregnancy, or parenthood of adolescents and to make use of support systems such as other family members, friends, religious and charitable organizations, and voluntary associations.section 300z–5 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t42/s300z–2/b","parentIdentifier":"/us/usc/t42/s300z–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300z%E2%80%932%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300z–2/b/1","parentIdentifier":"/us/usc/t42/s300z–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300z%E2%80%932%2Fb%2F1","sourceRelease":"119-100","text":"care services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300z–2/b/2","parentIdentifier":"/us/usc/t42/s300z–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300z%E2%80%932%2Fb%2F2","sourceRelease":"119-100","text":"prevention services; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300z–2/b/3","parentIdentifier":"/us/usc/t42/s300z–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300z%E2%80%932%2Fb%2F3","sourceRelease":"119-100","text":"a combination of care services and prevention services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
