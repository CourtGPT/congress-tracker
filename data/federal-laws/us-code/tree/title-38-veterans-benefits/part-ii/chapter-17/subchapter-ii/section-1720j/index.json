{"type":"section","nativeType":"section","number":"1720J","heading":"Emergent suicide care","label":"1720J Emergent suicide care","identifier":"/us/usc/t38/s1720J","parentIdentifier":"/us/usc/t38/ptII/ch17/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective Date, , , provided that:Pub. L. 116–214, title II, § 201(c)134 Stat. 1033Dec. 5, 2020“The Secretary shall furnish or pay for emergent suicide care under , United States Code, as added by subsection (a), beginning on the date that is 270 days after the date of the enactment of this Act [].”section 1720J of title 38Dec. 5, 2020"],"amendments":["Effective Date, , , provided that:Pub. L. 116–214, title II, § 201(c)134 Stat. 1033Dec. 5, 2020“The Secretary shall furnish or pay for emergent suicide care under , United States Code, as added by subsection (a), beginning on the date that is 270 days after the date of the enactment of this Act [].”section 1720J of title 38Dec. 5, 2020"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Emergent Suicide Care","label":"a .—Emergent Suicide Care","identifier":"/us/usc/t38/s1720J/a","parentIdentifier":"/us/usc/t38/s1720J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1720J/a/1","parentIdentifier":"/us/usc/t38/s1720J/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fa%2F1","sourceRelease":"119-100","text":"furnish emergent suicide care to an eligible individual at a medical facility of the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1720J/a/2","parentIdentifier":"/us/usc/t38/s1720J/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fa%2F2","sourceRelease":"119-100","text":"pay for emergent suicide care provided to an eligible individual at a non-Department facility; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1720J/a/3","parentIdentifier":"/us/usc/t38/s1720J/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fa%2F3","sourceRelease":"119-100","text":"reimburse an eligible individual for emergent suicide care provided to the eligible individual at a non-Department facility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Eligibility","label":"b .—Eligibility","identifier":"/us/usc/t38/s1720J/b","parentIdentifier":"/us/usc/t38/s1720J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1720J/b/1","parentIdentifier":"/us/usc/t38/s1720J/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fb%2F1","sourceRelease":"119-100","text":"A veteran (as defined in section 101).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1720J/b/2","parentIdentifier":"/us/usc/t38/s1720J/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fb%2F2","sourceRelease":"119-100","text":"An individual described in .section 1720I(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Period of Care","label":"c .—Period of Care","identifier":"/us/usc/t38/s1720J/c","parentIdentifier":"/us/usc/t38/s1720J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1720J/c/1","parentIdentifier":"/us/usc/t38/s1720J/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1720J/c/1/A","parentIdentifier":"/us/usc/t38/s1720J/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fc%2F1%2FA","sourceRelease":"119-100","text":"through inpatient or crisis residential care, for a period not to exceed 30 days; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1720J/c/1/B","parentIdentifier":"/us/usc/t38/s1720J/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fc%2F1%2FB","sourceRelease":"119-100","text":"if care under subparagraph (A) is unavailable, or if such care is not clinically appropriate, as outpatient care for a period not to exceed 90 days.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1720J/c/2","parentIdentifier":"/us/usc/t38/s1720J/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fc%2F2","sourceRelease":"119-100","text":"If, upon the expiration of a period under paragraph (1), the Secretary determines that the eligible individual remains in an acute suicidal crisis, the Secretary may extend such period as the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Notification","label":"d .—Notification","identifier":"/us/usc/t38/s1720J/d","parentIdentifier":"/us/usc/t38/s1720J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fd","sourceRelease":"119-100","text":"An eligible individual who receives emergent suicide care under subsection (a) at a non-Department facility (or a person acting on behalf of the individual) shall notify the Secretary of such care within seven days of admission to such facility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Outreach","label":"e .—Outreach","identifier":"/us/usc/t38/s1720J/e","parentIdentifier":"/us/usc/t38/s1720J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1720J/e/1","parentIdentifier":"/us/usc/t38/s1720J/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1720J/e/1/A","parentIdentifier":"/us/usc/t38/s1720J/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fe%2F1%2FA","sourceRelease":"119-100","text":"in the case of an eligible individual whom the Veterans Crisis Line recommends to seek emergent suicide care at a medical facility of the Department, the Veterans Crisis Line notifies the Suicide Prevention Coordinator of such medical facility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1720J/e/1/B","parentIdentifier":"/us/usc/t38/s1720J/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fe%2F1%2FB","sourceRelease":"119-100","text":"in the case of an eligible individual who presents at a medical facility of the Department in an acute suicidal crisis without a recommendation by the Veterans Crisis Line, the Secretary notifies the Suicide Prevention Coordinator;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s1720J/e/1/C","parentIdentifier":"/us/usc/t38/s1720J/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fe%2F1%2FC","sourceRelease":"119-100","text":"in the case of an eligible individual whom the Veterans Crisis Line recommends to seek treatment at a non-Department facility, the Veterans Crisis Line notifies the Suicide Prevention Coordinator and the Office of Community Care at the medical facility of the Department located nearest to the eligible individual; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t38/s1720J/e/1/D","parentIdentifier":"/us/usc/t38/s1720J/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fe%2F1%2FD","sourceRelease":"119-100","text":"in the case of an eligible individual who presents at a non-Department facility in an acute suicidal crisis without a recommendation by the Veterans Crisis Line and for whom the Secretary receives a notification under subsection (d), the Secretary notifies the Suicide Prevention Coordinator and the Office of Community Care at the medical facility of the Department located nearest to the eligible individual;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1720J/e/2","parentIdentifier":"/us/usc/t38/s1720J/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fe%2F2","sourceRelease":"119-100","text":"determine the eligibility of the eligible individual for other programs and benefits under the laws administered by the Secretary (or shall make such determination as soon as practicable following the period of such emergent suicide care); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1720J/e/3","parentIdentifier":"/us/usc/t38/s1720J/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fe%2F3","sourceRelease":"119-100","text":"make referrals for care following the period of such emergent suicide care, as the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Prohibition on Charge","label":"f .—Prohibition on Charge","identifier":"/us/usc/t38/s1720J/f","parentIdentifier":"/us/usc/t38/s1720J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1720J/f/1","parentIdentifier":"/us/usc/t38/s1720J/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1720J/f/1/A","parentIdentifier":"/us/usc/t38/s1720J/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Ff%2F1%2FA","sourceRelease":"119-100","text":"may not charge the eligible individual for any cost of such emergent suicide care; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1720J/f/1/B","parentIdentifier":"/us/usc/t38/s1720J/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Ff%2F1%2FB","sourceRelease":"119-100","text":"shall pay for any costs of emergency transportation to a facility for such emergent suicide care (as such costs are determined pursuant to , to the extent practicable).section 1725 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1720J/f/2","parentIdentifier":"/us/usc/t38/s1720J/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1720J/f/2/A","parentIdentifier":"/us/usc/t38/s1720J/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Ff%2F2%2FA","sourceRelease":"119-100","text":"In addition to the requirements of paragraph (1), if the Secretary pays for emergent suicide care provided under subsection (a) to an eligible individual at a non-Department facility, the Secretary shall reimburse the facility for the reasonable value of such emergent suicide care.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1720J/f/2/B","parentIdentifier":"/us/usc/t38/s1720J/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Ff%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t38/s1720J/f/2/B/i","parentIdentifier":"/us/usc/t38/s1720J/f/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Ff%2F2%2FB%2Fi","sourceRelease":"119-100","text":"In carrying out subparagraph (A), the Secretary may determine the amount to reimburse a non-Department facility in a similar manner to the manner in which the Secretary determines reimbursement amounts for that non-Department facility for medical care and services provided under another provision of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t38/s1720J/f/2/B/ii","parentIdentifier":"/us/usc/t38/s1720J/f/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Ff%2F2%2FB%2Fii","sourceRelease":"119-100","text":"The requirements of shall apply with respect to payments made under subparagraph (A) of this paragraph.section 1725(c)(3) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1720J/f/3","parentIdentifier":"/us/usc/t38/s1720J/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Ff%2F3","sourceRelease":"119-100","text":"In the case of an eligible individual who receives emergent suicide care under this section and who is entitled to emergent suicide care (or payment for emergent suicide care) under a health-plan contract, the Secretary may recover the costs of such emergent suicide care provided under this section, other than for such care for a service-connected disability.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s1720J/f/4","parentIdentifier":"/us/usc/t38/s1720J/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Ff%2F4","sourceRelease":"119-100","text":"In carrying out subsection (d), the Secretary may not charge an eligible individual for any cost of emergent suicide care provided under subsection (a) solely by reason of the Secretary not having been notified of such care pursuant to such subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":".—Annual Report","label":"g .—Annual Report","identifier":"/us/usc/t38/s1720J/g","parentIdentifier":"/us/usc/t38/s1720J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1720J/g/1","parentIdentifier":"/us/usc/t38/s1720J/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fg%2F1","sourceRelease":"119-100","text":"the number of eligible individuals who received emergent suicide care under subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1720J/g/2","parentIdentifier":"/us/usc/t38/s1720J/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fg%2F2","sourceRelease":"119-100","text":"demographic information regarding eligible individuals described in paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1720J/g/3","parentIdentifier":"/us/usc/t38/s1720J/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fg%2F3","sourceRelease":"119-100","text":"the types of care furnished or paid for this section; and1So in original. Probably should be “under this section;”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s1720J/g/4","parentIdentifier":"/us/usc/t38/s1720J/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fg%2F4","sourceRelease":"119-100","text":"the total cost of providing care under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":".—Definitions","label":"h .—Definitions","identifier":"/us/usc/t38/s1720J/h","parentIdentifier":"/us/usc/t38/s1720J","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1720J/h/1","parentIdentifier":"/us/usc/t38/s1720J/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh%2F1","sourceRelease":"119-100","text":"The term “acute suicidal crisis” means that an individual was determined to be at imminent risk of self-harm by a trained crisis responder or health care provider.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1720J/h/2","parentIdentifier":"/us/usc/t38/s1720J/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1720J/h/2/A","parentIdentifier":"/us/usc/t38/s1720J/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh%2F2%2FA","sourceRelease":"119-100","text":"in a residential setting; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1720J/h/2/B","parentIdentifier":"/us/usc/t38/s1720J/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh%2F2%2FB","sourceRelease":"119-100","text":"in a facility other than a hospital.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1720J/h/3","parentIdentifier":"/us/usc/t38/s1720J/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1720J/h/3/A","parentIdentifier":"/us/usc/t38/s1720J/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh%2F3%2FA","sourceRelease":"119-100","text":"the severity of distress;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1720J/h/3/B","parentIdentifier":"/us/usc/t38/s1720J/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh%2F3%2FB","sourceRelease":"119-100","text":"the need for urgent care; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s1720J/h/3/C","parentIdentifier":"/us/usc/t38/s1720J/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh%2F3%2FC","sourceRelease":"119-100","text":"the likelihood that the distress under subparagraph (A) or need under subparagraph (B) will increase during the transfer of that individual from a facility at which the individual has received care for that acute suicidal crisis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s1720J/h/4","parentIdentifier":"/us/usc/t38/s1720J/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1720J/h/4/A","parentIdentifier":"/us/usc/t38/s1720J/h/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh%2F4%2FA","sourceRelease":"119-100","text":"pursuant to a recommendation of the eligible individual from the Veterans Crisis Line; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1720J/h/4/B","parentIdentifier":"/us/usc/t38/s1720J/h/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh%2F4%2FB","sourceRelease":"119-100","text":"who presents at a medical facility in an acute suicidal crisis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t38/s1720J/h/5","parentIdentifier":"/us/usc/t38/s1720J/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh%2F5","sourceRelease":"119-100","text":"The term “health-plan contract” has the meaning given such term in .section 1725 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t38/s1720J/h/6","parentIdentifier":"/us/usc/t38/s1720J/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1720J%2Fh%2F6","sourceRelease":"119-100","text":"The term “Veterans Crisis Line” means the hotline under .section 1720F(h) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
