{"type":"section","nativeType":"section","number":"7610","heading":"Definitions","label":"7610 Definitions","identifier":"/us/usc/t15/s7610","parentIdentifier":"/us/usc/t15/ch102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective 60 days after , see , set out as a note under .Dec. 6, 2003section 12 of Pub. L. 108–164section 7601 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Contact lens fitting","label":"1 Contact lens fitting","identifier":"/us/usc/t15/s7610/1","parentIdentifier":"/us/usc/t15/s7610","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7610/1/A","parentIdentifier":"/us/usc/t15/s7610/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F1%2FA","sourceRelease":"119-100","text":"an examination to determine lens specifications;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7610/1/B","parentIdentifier":"/us/usc/t15/s7610/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F1%2FB","sourceRelease":"119-100","text":"except in the case of a renewal of a prescription, an initial evaluation of the fit of the lens on the eye; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s7610/1/C","parentIdentifier":"/us/usc/t15/s7610/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F1%2FC","sourceRelease":"119-100","text":"medically necessary follow up examinations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Prescriber","label":"2 Prescriber","identifier":"/us/usc/t15/s7610/2","parentIdentifier":"/us/usc/t15/s7610","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F2","sourceRelease":"119-100","text":"The term “prescriber” means, with respect to contact lens prescriptions, an ophthalmologist, optometrist, or other person permitted under State law to issue prescriptions for contact lenses in compliance with any applicable requirements established by the Food and Drug Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Contact lens prescription","label":"3 Contact lens prescription","identifier":"/us/usc/t15/s7610/3","parentIdentifier":"/us/usc/t15/s7610","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7610/3/A","parentIdentifier":"/us/usc/t15/s7610/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F3%2FA","sourceRelease":"119-100","text":"Name of the patient.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7610/3/B","parentIdentifier":"/us/usc/t15/s7610/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F3%2FB","sourceRelease":"119-100","text":"Date of examination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s7610/3/C","parentIdentifier":"/us/usc/t15/s7610/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F3%2FC","sourceRelease":"119-100","text":"Issue date and expiration date of prescription.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s7610/3/D","parentIdentifier":"/us/usc/t15/s7610/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F3%2FD","sourceRelease":"119-100","text":"Name, postal address, telephone number, and facsimile telephone number of prescriber.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s7610/3/E","parentIdentifier":"/us/usc/t15/s7610/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F3%2FE","sourceRelease":"119-100","text":"Power, material or manufacturer or both.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t15/s7610/3/F","parentIdentifier":"/us/usc/t15/s7610/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F3%2FF","sourceRelease":"119-100","text":"Base curve or appropriate designation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t15/s7610/3/G","parentIdentifier":"/us/usc/t15/s7610/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F3%2FG","sourceRelease":"119-100","text":"Diameter, when appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t15/s7610/3/H","parentIdentifier":"/us/usc/t15/s7610/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7610%2F3%2FH","sourceRelease":"119-100","text":"In the case of a private label contact lens, name of manufacturer, trade name of private label brand, and, if applicable, trade name of equivalent brand name.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
