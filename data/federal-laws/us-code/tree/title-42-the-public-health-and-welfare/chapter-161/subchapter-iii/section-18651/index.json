{"type":"section","nativeType":"section","number":"18651","heading":"High intensity laser research initiative","label":"18651 High intensity laser research initiative","identifier":"/us/usc/t42/s18651","parentIdentifier":"/us/usc/t42/ch161/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18651","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s18651/a","parentIdentifier":"/us/usc/t42/s18651","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18651%2Fa","sourceRelease":"119-100","text":"The Director shall establish a high intensity laser research initiative consistent with the recommendations of the National Academies report entitled “Opportunities in Intense Ultrafast Lasers: Reaching for the Brightest Light” and the report from the Brightest Light Initiative workshop entitled “The Future of Intense Ultrafast Lasers in the U.S.”. The initiative should include research and development of petawatt-scale and of high average power laser technologies necessary for future facility needs in discovery science and to advance energy technologies, as well as support for a user network of academic and National Laboratory high intensity laser facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Leverage","label":"b Leverage","identifier":"/us/usc/t42/s18651/b","parentIdentifier":"/us/usc/t42/s18651","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18651%2Fb","sourceRelease":"119-100","text":"The Director shall leverage new laser technologies for more compact, less complex, and low-cost accelerator systems needed for science applications.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Coordination","label":"c Coordination","identifier":"/us/usc/t42/s18651/c","parentIdentifier":"/us/usc/t42/s18651","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18651%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Director","label":"1 Director","identifier":"/us/usc/t42/s18651/c/1","parentIdentifier":"/us/usc/t42/s18651/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18651%2Fc%2F1","sourceRelease":"119-100","text":"The Director shall coordinate the initiative established under subsection (a) among all relevant programs within the Office of Science.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Under Secretary","label":"2 Under Secretary","identifier":"/us/usc/t42/s18651/c/2","parentIdentifier":"/us/usc/t42/s18651/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18651%2Fc%2F2","sourceRelease":"119-100","text":"The Under Secretary for Science shall coordinate the initiative established under subsection (a) with other relevant programs within the Department and other Federal agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s18651/d","parentIdentifier":"/us/usc/t42/s18651","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18651%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18651/d/1","parentIdentifier":"/us/usc/t42/s18651/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18651%2Fd%2F1","sourceRelease":"119-100","text":"$50,000,000 for fiscal year 2023;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18651/d/2","parentIdentifier":"/us/usc/t42/s18651/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18651%2Fd%2F2","sourceRelease":"119-100","text":"$100,000,000 for fiscal year 2024;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18651/d/3","parentIdentifier":"/us/usc/t42/s18651/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18651%2Fd%2F3","sourceRelease":"119-100","text":"$150,000,000 for fiscal year 2025;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18651/d/4","parentIdentifier":"/us/usc/t42/s18651/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18651%2Fd%2F4","sourceRelease":"119-100","text":"$200,000,000 for fiscal year 2026; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s18651/d/5","parentIdentifier":"/us/usc/t42/s18651/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18651%2Fd%2F5","sourceRelease":"119-100","text":"$250,000,000 for fiscal year 2027.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
