s://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1465/b/1","parentIdentifier":"/us/usc/t20/s1465/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1465/b/1/A","parentIdentifier":"/us/usc/t20/s1465/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fb%2F1%2FA","sourceRelease":"119-100","text":"training for school staff on early identification, prereferral, and referral procedures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1465/b/1/B","parentIdentifier":"/us/usc/t20/s1465/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fb%2F1%2FB","sourceRelease":"119-100","text":"training for administrators, teachers, related services personnel, behavioral specialists, and other school staff in positive behavioral interventions and supports, behavioral intervention planning, and classroom and student management techniques;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1465/b/1/C","parentIdentifier":"/us/usc/t20/s1465/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fb%2F1%2FC","sourceRelease":"119-100","text":"joint training for administrators, parents, teachers, related services personnel, behavioral specialists, and other school staff on effective strategies for positive behavioral interventions and behavior management strategies that focus on the prevention of behavior problems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1465/b/1/D","parentIdentifier":"/us/usc/t20/s1465/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fb%2F1%2FD","sourceRelease":"119-100","text":"developing or implementing specific curricula, programs, or interventions aimed at addressing behavioral problems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s1465/b/1/E","parentIdentifier":"/us/usc/t20/s1465/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fb%2F1%2FE","sourceRelease":"119-100","text":"stronger linkages between school-based services and community-based resources, such as community mental health and primary care providers; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t20/s1465/b/1/F","parentIdentifier":"/us/usc/t20/s1465/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fb%2F1%2FF","sourceRelease":"119-100","text":"using behavioral specialists, related services personnel, and other staff necessary to implement behavioral supports; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1465/b/2","parentIdentifier":"/us/usc/t20/s1465/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1465/b/2/A","parentIdentifier":"/us/usc/t20/s1465/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fb%2F2%2FA","sourceRelease":"119-100","text":"improving the training of administrators, teachers, related services personnel, behavioral specialists, and other school staff (including ongoing mentoring of new teachers) in behavioral supports and interventions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1465/b/2/B","parentIdentifier":"/us/usc/t20/s1465/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fb%2F2%2FB","sourceRelease":"119-100","text":"attracting and retaining a high quality, diverse staff;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1465/b/2/C","parentIdentifier":"/us/usc/t20/s1465/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fb%2F2%2FC","sourceRelease":"119-100","text":"providing for referral to counseling services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1465/b/2/D","parentIdentifier":"/us/usc/t20/s1465/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1465%2Fb%2F2%2FD","sourceRelease":"119-100","text":"utilizing research-based interventions, curriculum, and practices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s1465/b/2/E