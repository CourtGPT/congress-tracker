{"type":"section","nativeType":"section","number":"5207","heading":"Department of Defense","label":"5207 Department of Defense","identifier":"/us/usc/t15/s5207","parentIdentifier":"/us/usc/t15/ch78","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5207","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Focus of research","label":"a Focus of research","identifier":"/us/usc/t15/s5207/a","parentIdentifier":"/us/usc/t15/s5207","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5207%2Fa","sourceRelease":"119-100","text":"In conformance with the Superconductivity Action Plan, the Secretary of Defense, in the superconductivity research and development activities of the Department of Defense, shall give emphasis to fundamental research, materials processing, and applications of new superconducting materials.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Additional activities","label":"b Additional activities","identifier":"/us/usc/t15/s5207/b","parentIdentifier":"/us/usc/t15/s5207","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5207%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s5207/b/1","parentIdentifier":"/us/usc/t15/s5207/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5207%2Fb%2F1","sourceRelease":"119-100","text":"systematically define the engineering parameters for high-temperature superconducting materials; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s5207/b/2","parentIdentifier":"/us/usc/t15/s5207/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5207%2Fb%2F2","sourceRelease":"119-100","text":"conduct the necessary development, engineering, and operational prototype testing considered appropriate to the overall mission of the Department of Defense. Such operational prototype testing shall, where appropriate, utilize criteria developed by the Defense Advanced Research Projects Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Defense Advanced Research Projects Agency","label":"c Defense Advanced Research Projects Agency","identifier":"/us/usc/t15/s5207/c","parentIdentifier":"/us/usc/t15/s5207","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5207%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s5207/c/1","parentIdentifier":"/us/usc/t15/s5207/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5207%2Fc%2F1","sourceRelease":"119-100","text":"augment, as appropriate, basic and applied superconductivity research conducted in other Federal agencies and industry; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s5207/c/2","parentIdentifier":"/us/usc/t15/s5207/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5207%2Fc%2F2","sourceRelease":"119-100","text":"develop criteria for operational prototype testing within the Department of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
