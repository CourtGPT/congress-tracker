{"type":"section","nativeType":"section","number":"1306","heading":"Design notice","label":"1306 Design notice","identifier":"/us/usc/t17/s1306","parentIdentifier":"/us/usc/t17/ch13","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft17%2Fs1306","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Contents of Design Notice","label":"a .—Contents of Design Notice","identifier":"/us/usc/t17/s1306/a","parentIdentifier":"/us/usc/t17/s1306","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft17%2Fs1306%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t17/s1306/a/1","parentIdentifier":"/us/usc/t17/s1306/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft17%2Fs1306%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t17/s1306/a/1/A","parentIdentifier":"/us/usc/t17/s1306/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft17%2Fs1306%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the words “Protected Design”, the abbreviation “Prot’d Des.”, or the letter “D” with a circle, or the symbol “*D*”;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t17/s1306/a/1/B","parentIdentifier":"/us/usc/t17/s1306/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft17%2Fs1306%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the year of the date on which protection for the design commenced; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t17/s1306/a/1/C","parentIdentifier":"/us/usc/t17/s1306/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft17%2Fs1306%2Fa%2F1%2FC","sourceRelease":"119-100","text":"the name of the owner, an abbreviation by which the name can be recognized, or a generally accepted alternative designation of the owner.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t17/s1306/a/2","parentIdentifier":"/us/usc/t17/s1306/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft17%2Fs1306%2Fa%2F2","sourceRelease":"119-100","text":"After registration, the registration number may be used instead of the elements specified in subparagraphs (B) and (C) of paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Location of Notice","label":"b .—Location of Notice","identifier":"/us/usc/t17/s1306/b","parentIdentifier":"/us/usc/t17/s1306","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft17%2Fs1306%2Fb","sourceRelease":"119-100","text":"The design notice shall be so located and applied as to give reasonable notice of design protection while the useful article embodying the design is passing through its normal channels of commerce.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Subsequent Removal of Notice","label":"c .—Subsequent Removal of Notice","identifier":"/us/usc/t17/s1306/c","parentIdentifier":"/us/usc/t17/s1306","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft17%2Fs1306%2Fc","sourceRelease":"119-100","text":"When the owner of a design has complied with the provisions of this section, protection under this chapter shall not be affected by the removal, destruction, or obliteration by others of the design notice on an article.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
