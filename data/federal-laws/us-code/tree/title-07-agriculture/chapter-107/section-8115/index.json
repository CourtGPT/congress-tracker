{"type":"section","nativeType":"section","number":"8115","heading":"Carbon utilization and biogas education program","label":"8115 Carbon utilization and biogas education program","identifier":"/us/usc/t7/s8115","parentIdentifier":"/us/usc/t7/ch107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t7/s8115/a","parentIdentifier":"/us/usc/t7/s8115","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Carbon dioxide","label":"1 Carbon dioxide","identifier":"/us/usc/t7/s8115/a/1","parentIdentifier":"/us/usc/t7/s8115/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115%2Fa%2F1","sourceRelease":"119-100","text":"The term “carbon dioxide” means carbon dioxide that is produced as a byproduct of the production of a biobased product.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible entity","label":"2 Eligible entity","identifier":"/us/usc/t7/s8115/a/2","parentIdentifier":"/us/usc/t7/s8115/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s8115/a/2/A","parentIdentifier":"/us/usc/t7/s8115/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s8115/a/2/A/i","parentIdentifier":"/us/usc/t7/s8115/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"an organization described in and exempt from taxation under section 501(a) of that title; orsection 501(c)(3) of title 26","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s8115/a/2/A/ii","parentIdentifier":"/us/usc/t7/s8115/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"an institution of higher education (as defined in );section 1001(a) of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s8115/a/2/B","parentIdentifier":"/us/usc/t7/s8115/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s8115/a/2/B/i","parentIdentifier":"/us/usc/t7/s8115/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"sequestration and utilization of carbon dioxide; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s8115/a/2/B/ii","parentIdentifier":"/us/usc/t7/s8115/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"aggregation of organic waste from multiple sources into a single biogas system; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s8115/a/2/C","parentIdentifier":"/us/usc/t7/s8115/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115%2Fa%2F2%2FC","sourceRelease":"119-100","text":"has a demonstrated ability to conduct educational and technical support programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t7/s8115/b","parentIdentifier":"/us/usc/t7/s8115","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s8115/b/1","parentIdentifier":"/us/usc/t7/s8115/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115%2Fb%2F1","sourceRelease":"119-100","text":"to provide education to the public about the economic and emissions benefits of permanent sequestration or utilization of carbon dioxide with a primary objective of providing benefits and opportunities for rural businesses, rural communities, and utilities serving rural communities; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s8115/b/2","parentIdentifier":"/us/usc/t7/s8115/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8115%2Fb%2F2","sourceRelease":"119-100","text":"to provide education to agricultural producers and other stakeholders about opportunities for aggregation of organic waste f