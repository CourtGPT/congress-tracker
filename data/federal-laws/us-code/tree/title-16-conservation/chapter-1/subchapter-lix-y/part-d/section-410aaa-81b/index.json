es Act of 1973 ( et seq.); and16 U.S.C. 1531","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s410aaa–81b/b/3/C","parentIdentifier":"/us/usc/t16/s410aaa–81b/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381b%2Fb%2F3%2FC","sourceRelease":"119-100","text":"any other applicable law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Land management plans","label":"c Land management plans","identifier":"/us/usc/t16/s410aaa–81b/c","parentIdentifier":"/us/usc/t16/s410aaa–81b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381b%2Fc","sourceRelease":"119-100","text":"The Secretary shall incorporate into all land management plans applicable to the California Desert Conservation Area the findings and recommendations of the study completed under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
