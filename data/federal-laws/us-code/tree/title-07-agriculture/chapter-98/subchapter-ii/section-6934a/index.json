{"type":"section","nativeType":"section","number":"6934a","heading":"Beginning farmer and rancher coordination","label":"6934a Beginning farmer and rancher coordination","identifier":"/us/usc/t7/s6934a","parentIdentifier":"/us/usc/t7/ch98/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsA prior was classified as a note under , prior to repeal by , , .section 7404 of Pub. L. 107–171section 3101 of this titlePub. L. 115–334, title VII, § 7506132 Stat. 4823Dec. 20, 2018","CodificationSection was enacted as part of the Farm Security and Rural Investment Act of 2002, and not as part of the Department of Agriculture Reorganization Act of 1994, which in part comprises this chapter."],"amendments":["Prior ProvisionsA prior was classified as a note under , prior to repeal by , , .section 7404 of Pub. L. 107–171section 3101 of this titlePub. L. 115–334, title VII, § 7506132 Stat. 4823Dec. 20, 2018"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t7/s6934a/a","parentIdentifier":"/us/usc/t7/s6934a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Beginning farmer or rancher","label":"1 Beginning farmer or rancher","identifier":"/us/usc/t7/s6934a/a/1","parentIdentifier":"/us/usc/t7/s6934a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fa%2F1","sourceRelease":"119-100","text":"The term “beginning farmer or rancher” has the meaning given such term in .section 2279(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"National Coordinator","label":"2 National Coordinator","identifier":"/us/usc/t7/s6934a/a/2","parentIdentifier":"/us/usc/t7/s6934a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fa%2F2","sourceRelease":"119-100","text":"The term “National Coordinator” means the National Beginning Farmer and Rancher Coordinator established under subsection (b)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"State coordinator","label":"3 State coordinator","identifier":"/us/usc/t7/s6934a/a/3","parentIdentifier":"/us/usc/t7/s6934a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fa%2F3","sourceRelease":"119-100","text":"The term “State coordinator” means a State beginning farmer and rancher coordinator designated under subsection (c)(1)(A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"State office","label":"4 State office","identifier":"/us/usc/t7/s6934a/a/4","parentIdentifier":"/us/usc/t7/s6934a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6934a/a/4/A","parentIdentifier":"/us/usc/t7/s6934a/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fa%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6934a/a/4/A/i","parentIdentifier":"/us/usc/t7/s6934a/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fa%2F4%2FA%2Fi","sourceRelease":"119-100","text":"the Farm Service Agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6934a/a/4/A/ii","parentIdentifier":"/us/usc/t7/s6934a/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fa%2F4%2FA%2Fii","sourceRelease":"119-100","text":"the Natural Resources Conservation Service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s6934a/a/4/A/iii","parentIdentifier":"/us/usc/t7/s6934a/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fa%2F4%2FA%2Fiii","sourceRelease":"119-100","text":"the Rural Business-Cooperative Service; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s6934a/a/4/A/iv","parentIdentifier":"/us/usc/t7/s6934a/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fa%2F4%2FA%2Fiv","sourceRelease":"119-100","text":"the Rural Utilities Service; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6934a/a/4/B","parentIdentifier":"/us/usc/t7/s6934a/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fa%2F4%2FB","sourceRelease":"119-100","text":"a regional office of the Risk Management Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"National Beginning Farmer and Rancher Coordinator","label":"b National Beginning Farmer and Rancher Coordinator","identifier":"/us/usc/t7/s6934a/b","parentIdentifier":"/us/usc/t7/s6934a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t7/s6934a/b/1","parentIdentifier":"/us/usc/t7/s6934a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall establish in the Department the position of National Beginning Farmer and Rancher Coordinator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Duties","label":"2 Duties","identifier":"/us/usc/t7/s6934a/b/2","parentIdentifier":"/us/usc/t7/s6934a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s6934a/b/2/A","parentIdentifier":"/us/usc/t7/s6934a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6934a/b/2/A/i","parentIdentifier":"/us/usc/t7/s6934a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"advise the Secretary and coordinate activities of the Department on programs, policies, and issues relating to beginning farmers and ranchers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6934a/b/2/A/ii","parentIdentifier":"/us/usc/t7/s6934a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"in consultation with the applicable State food and agriculture council, determine whether to approve a plan submitted by a State coordinator under subsection (c)(3)(B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Discretionary duties","label":"B Discretionary duties","identifier":"/us/usc/t7/s6934a/b/2/B","parentIdentifier":"/us/usc/t7/s6934a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6934a/b/2/B/i","parentIdentifier":"/us/usc/t7/s6934a/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s6934a/b/2/B/i/I","parentIdentifier":"/us/usc/t7/s6934a/b/2/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F2%2FB%2Fi%2FI","sourceRelease":"119-100","text":"for outreach to beginning farmers and ranchers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s6934a/b/2/B/i/II","parentIdentifier":"/us/usc/t7/s6934a/b/2/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F2%2FB%2Fi%2FII","sourceRelease":"119-100","text":"to assist beginning farmers and ranchers with connecting to owners or operators that have ended, or expect to end within 5 years, actively owning or operating a farm or ranch; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6934a/b/2/B/ii","parentIdentifier":"/us/usc/t7/s6934a/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"facilitating interagency and interdepartmental collaboration on issues relating to beginning farmers and ranchers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Reports","label":"3 Reports","identifier":"/us/usc/t7/s6934a/b/3","parentIdentifier":"/us/usc/t7/s6934a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F3","sourceRelease":"119-100","text":"Not less frequently than once each year, the National Coordinator shall distribute within the Department and make publicly available a report describing the status of steps taken to carry out the duties described in subparagraphs (A) and (B) of paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Contracts and cooperative agreements","label":"4 Contracts and cooperative agreements","identifier":"/us/usc/t7/s6934a/b/4","parentIdentifier":"/us/usc/t7/s6934a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6934a/b/4/A","parentIdentifier":"/us/usc/t7/s6934a/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F4%2FA","sourceRelease":"119-100","text":"to conduct research on the profitability of new farms in operation for not less than 5 years in a region;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6934a/b/4/B","parentIdentifier":"/us/usc/t7/s6934a/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F4%2FB","sourceRelease":"119-100","text":"to develop educational materials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s6934a/b/4/C","parentIdentifier":"/us/usc/t7/s6934a/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F4%2FC","sourceRelease":"119-100","text":"to conduct workshops, courses, training, or certified vocational training; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s6934a/b/4/D","parentIdentifier":"/us/usc/t7/s6934a/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fb%2F4%2FD","sourceRelease":"119-100","text":"to conduct mentoring activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"State beginning farmer and rancher coordinators","label":"c State beginning farmer and rancher coordinators","identifier":"/us/usc/t7/s6934a/c","parentIdentifier":"/us/usc/t7/s6934a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s6934a/c/1","parentIdentifier":"/us/usc/t7/s6934a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Designation","label":"A Designation","identifier":"/us/usc/t7/s6934a/c/1/A","parentIdentifier":"/us/usc/t7/s6934a/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fc%2F1%2FA","sourceRelease":"119-100","text":"The National Coordinator, in consultation with State food and agriculture councils and directors of State offices, shall designate in each State a State beginning farmer and rancher coordinator from among employees of State offices.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Requirements","label":"B Requirements","identifier":"/us/usc/t7/s6934a/c/1/B","parentIdentifier":"/us/usc/t7/s6934a/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6934a/c/1/B/i","parentIdentifier":"/us/usc/t7/s6934a/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"be familiar with issues relating to beginning farmers and ranchers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6934a/c/1/B/ii","parentIdentifier":"/us/usc/t7/s6934a/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"have the ability to coordinate with other Federal departments and agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Training","label":"2 Training","identifier":"/us/usc/t7/s6934a/c/2","parentIdentifier":"/us/usc/t7/s6934a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fc%2F2","sourceRelease":"119-100","text":"The Secretary shall develop a training plan to provide to each State coordinator knowledge of programs and services available from the Department for beginning farmers and ranchers, taking into consideration the needs of all production types and sizes of agricultural operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Duties","label":"3 Duties","identifier":"/us/usc/t7/s6934a/c/3","parentIdentifier":"/us/usc/t7/s6934a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6934a/c/3/A","parentIdentifier":"/us/usc/t7/s6934a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fc%2F3%2FA","sourceRelease":"119-100","text":"coordinate technical assistance at the State level to assist beginning farmers and ranchers in accessing programs of the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6934a/c/3/B","parentIdentifier":"/us/usc/t7/s6934a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fc%2F3%2FB","sourceRelease":"119-100","text":"develop and submit to the National Coordinator for approval under subsection (b)(2)(A)(ii) a State plan to improve the coordination, delivery, and efficacy of programs of the Department to beginning farmers and ranchers, taking into consideration the needs of all types of production methods and sizes of agricultural operation, at each county and area office in the State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s6934a/c/3/C","parentIdentifier":"/us/usc/t7/s6934a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fc%2F3%2FC","sourceRelease":"119-100","text":"oversee implementation of an approved State plan described in subparagraph (B);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s6934a/c/3/D","parentIdentifier":"/us/usc/t7/s6934a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fc%2F3%2FD","sourceRelease":"119-100","text":"work with outreach coordinators in the State offices to ensure appropriate information about technical assistance is available at outreach events and activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s6934a/c/3/E","parentIdentifier":"/us/usc/t7/s6934a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6934a%2Fc%2F3%2FE","sourceRelease":"119-100","text":"coordinate partnerships and joint outreach efforts with other organizations and government agencies serving beginning farmers and ranchers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
