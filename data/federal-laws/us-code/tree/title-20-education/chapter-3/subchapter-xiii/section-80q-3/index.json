{"type":"section","nativeType":"section","number":"80q–3","heading":"Board of Trustees of National Museum of the American Indian","label":"80q–3 Board of Trustees of National Museum of the American Indian","identifier":"/us/usc/t20/s80q–3","parentIdentifier":"/us/usc/t20/ch3/schXIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments1996—Subsec. (f)(1)(B). substituted “a senior official” for “an Assistant Secretary”.Pub. L. 104–278"],"amendments":["Amendments1996—Subsec. (f)(1)(B). substituted “a senior official” for “an Assistant Secretary”.Pub. L. 104–278"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t20/s80q–3/a","parentIdentifier":"/us/usc/t20/s80q–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fa","sourceRelease":"119-100","text":"The National Museum shall be under a Board of Trustees with the duties, powers, and authority specified in this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"General duties and powers","label":"b General duties and powers","identifier":"/us/usc/t20/s80q–3/b","parentIdentifier":"/us/usc/t20/s80q–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s80q–3/b/1","parentIdentifier":"/us/usc/t20/s80q–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fb%2F1","sourceRelease":"119-100","text":"recommend annual operating budgets for the National Museum to the Board of Regents;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s80q–3/b/2","parentIdentifier":"/us/usc/t20/s80q–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fb%2F2","sourceRelease":"119-100","text":"advise and assist the Board of Regents on all matters relating to the administration, operation, maintenance, and preservation of the National Museum;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s80q–3/b/3","parentIdentifier":"/us/usc/t20/s80q–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fb%2F3","sourceRelease":"119-100","text":"adopt bylaws for the Board of Trustees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s80q–3/b/4","parentIdentifier":"/us/usc/t20/s80q–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fb%2F4","sourceRelease":"119-100","text":"designate a chairman and other officers from among the members of the Board of trustees; and1So in original. Probably should be capitalized.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t20/s80q–3/b/5","parentIdentifier":"/us/usc/t20/s80q–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fb%2F5","sourceRelease":"119-100","text":"report annually to the Board of Regents on the acquisition, disposition, and display of Native American objects and artifacts and on other appropriate matters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Sole authority","label":"c Sole authority","identifier":"/us/usc/t20/s80q–3/c","parentIdentifier":"/us/usc/t20/s80q–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s80q–3/c/1","parentIdentifier":"/us/usc/t20/s80q–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fc%2F1","sourceRelease":"119-100","text":"lend, exchange, sell, or otherwise dispose of any part of the collections of the National Museum, with the proceeds of such transactions to be used for additions to the collections of the National Museum or additions to the endowment of the National Museum, as the case may be;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s80q–3/c/2","parentIdentifier":"/us/usc/t20/s80q–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fc%2F2","sourceRelease":"119-100","text":"purchase, accept, borrow, or otherwise acquire artifacts and other objects for addition to the collections of the Natural Museum; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s80q–3/c/3","parentIdentifier":"/us/usc/t20/s80q–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fc%2F3","sourceRelease":"119-100","text":"specify criteria for use of the collections of the National Museum for appropriate purposes, including research, evaluation, education, and method of display.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authority","label":"d Authority","identifier":"/us/usc/t20/s80q–3/d","parentIdentifier":"/us/usc/t20/s80q–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s80q–3/d/1","parentIdentifier":"/us/usc/t20/s80q–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fd%2F1","sourceRelease":"119-100","text":"provide for restoration, preservation, and maintenance of the collections of the National Museum;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s80q–3/d/2","parentIdentifier":"/us/usc/t20/s80q–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fd%2F2","sourceRelease":"119-100","text":"solicit funds for the National Museum and determine the purposes to which such funds shall be applied; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s80q–3/d/3","parentIdentifier":"/us/usc/t20/s80q–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fd%2F3","sourceRelease":"119-100","text":"approve expenditures from the endowment of the National Museum for any purpose of the Museum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Initial appointments to Board of Trustees","label":"e Initial appointments to Board of Trustees","identifier":"/us/usc/t20/s80q–3/e","parentIdentifier":"/us/usc/t20/s80q–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Membership","label":"1 Membership","identifier":"/us/usc/t20/s80q–3/e/1","parentIdentifier":"/us/usc/t20/s80q–3/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s80q–3/e/1/A","parentIdentifier":"/us/usc/t20/s80q–3/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fe%2F1%2FA","sourceRelease":"119-100","text":"the Secretary of the Smithsonian Institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s80q–3/e/1/B","parentIdentifier":"/us/usc/t20/s80q–3/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fe%2F1%2FB","sourceRelease":"119-100","text":"an Assistant Secretary of the Smithsonian Institution appointed by the Board of Regents;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s80q–3/e/1/C","parentIdentifier":"/us/usc/t20/s80q–3/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fe%2F1%2FC","sourceRelease":"119-100","text":"8 individuals appointed by the Board of Regents; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s80q–3/e/1/D","parentIdentifier":"/us/usc/t20/s80q–3/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fe%2F1%2FD","sourceRelease":"119-100","text":"15 individuals, each of whom shall be a member of the board of trustees of the Heye Museum, appointed by the Board of Regents from a list of nominees recommended by the board of trustees of the Heye Museum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Special rule","label":"2 Special rule","identifier":"/us/usc/t20/s80q–3/e/2","parentIdentifier":"/us/usc/t20/s80q–3/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fe%2F2","sourceRelease":"119-100","text":"At least 7 of the 23 members appointed under subparagraphs (C) and (D) of paragraph (1) shall be Indians.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Terms","label":"3 Terms","identifier":"/us/usc/t20/s80q–3/e/3","parentIdentifier":"/us/usc/t20/s80q–3/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fe%2F3","sourceRelease":"119-100","text":"The trustee appointed under paragraph (1)(B) shall serve at the pleasure of the Board of Regents. The terms of the trustees appointed under subparagraph (C) or (D) of paragraph (1) shall be 3 years, beginning on the date of the transfer of the Heye Foundation assets to the Smithsonian Institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Vacancies","label":"4 Vacancies","identifier":"/us/usc/t20/s80q–3/e/4","parentIdentifier":"/us/usc/t20/s80q–3/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fe%2F4","sourceRelease":"119-100","text":"Any vacancy shall be filled only for the remainder of the term involved. Any vacancy appointment under paragraph (1)(D) shall not be subject to the source and recommendation requirements of that paragraph, but shall be subject to paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Subsequent appointments to Board of Trustees","label":"f Subsequent appointments to Board of Trustees","identifier":"/us/usc/t20/s80q–3/f","parentIdentifier":"/us/usc/t20/s80q–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Membership","label":"1 Membership","identifier":"/us/usc/t20/s80q–3/f/1","parentIdentifier":"/us/usc/t20/s80q–3/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s80q–3/f/1/A","parentIdentifier":"/us/usc/t20/s80q–3/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Ff%2F1%2FA","sourceRelease":"119-100","text":"the Secretary of the Smithsonian Institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s80q–3/f/1/B","parentIdentifier":"/us/usc/t20/s80q–3/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Ff%2F1%2FB","sourceRelease":"119-100","text":"a senior official of the Smithsonian Institution appointed by the Board of Regents; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s80q–3/f/1/C","parentIdentifier":"/us/usc/t20/s80q–3/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Ff%2F1%2FC","sourceRelease":"119-100","text":"23 individuals appointed by the Board of Regents from a list of nominees recommended by the Board of Trustees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Special rule","label":"2 Special rule","identifier":"/us/usc/t20/s80q–3/f/2","parentIdentifier":"/us/usc/t20/s80q–3/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Ff%2F2","sourceRelease":"119-100","text":"A least 12 of the 23 members appointed under paragraph (1)(C) shall be Indians.2So in original. Probably should be “At”.2","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Terms","label":"3 Terms","identifier":"/us/usc/t20/s80q–3/f/3","parentIdentifier":"/us/usc/t20/s80q–3/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Ff%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s80q–3/f/3/A","parentIdentifier":"/us/usc/t20/s80q–3/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Ff%2F3%2FA","sourceRelease":"119-100","text":"7 members, 4 of whom shall be Indians, shall be appointed for a term of one year, as designated at the time of appointment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s80q–3/f/3/B","parentIdentifier":"/us/usc/t20/s80q–3/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Ff%2F3%2FB","sourceRelease":"119-100","text":"8 members, 4 of whom shall be Indians, shall be appointed for a term of 2 years, as designated at the time of appointment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Vacancies","label":"4 Vacancies","identifier":"/us/usc/t20/s80q–3/f/4","parentIdentifier":"/us/usc/t20/s80q–3/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Ff%2F4","sourceRelease":"119-100","text":"Any vacancy shall be filled only for the remainder of the term involved.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Quorum","label":"g Quorum","identifier":"/us/usc/t20/s80q–3/g","parentIdentifier":"/us/usc/t20/s80q–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fg","sourceRelease":"119-100","text":"A majority of the members of the Board of Trustees then in office shall constitute a quorum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Expenses","label":"h Expenses","identifier":"/us/usc/t20/s80q–3/h","parentIdentifier":"/us/usc/t20/s80q–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80q%E2%80%933%2Fh","sourceRelease":"119-100","text":"Members of the Board shall be entitled (to the same extent as provided in with respect to employees serving intermittently in the Government service) to per diem, travel, and transportation expenses for each day (including travel time) during which they are engaged in the performance of their duties.section 5703 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
