{"type":"section","nativeType":"section","number":"4201","heading":"Purposes","label":"4201 Purposes","identifier":"/us/usc/t50/s4201","parentIdentifier":"/us/usc/t50/ch52","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4201","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to section 1989 of the former Appendix to this title prior to editorial reclassification and renumbering as this section."],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s4201/1","parentIdentifier":"/us/usc/t50/s4201","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4201%2F1","sourceRelease":"119-100","text":"acknowledge the fundamental injustice of the evacuation, relocation, and internment of United States citizens and permanent resident aliens of Japanese ancestry during World War II;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s4201/2","parentIdentifier":"/us/usc/t50/s4201","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4201%2F2","sourceRelease":"119-100","text":"apologize on behalf of the people of the United States for the evacuation, relocation, and internment of such citizens and permanent resident aliens;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s4201/3","parentIdentifier":"/us/usc/t50/s4201","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4201%2F3","sourceRelease":"119-100","text":"provide for a public education fund to finance efforts to inform the public about the internment of such individuals so as to prevent the recurrence of any similar event;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t50/s4201/4","parentIdentifier":"/us/usc/t50/s4201","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4201%2F4","sourceRelease":"119-100","text":"make restitution to those individuals of Japanese ancestry who were interned;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t50/s4201/5","parentIdentifier":"/us/usc/t50/s4201","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4201%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s4201/5/A","parentIdentifier":"/us/usc/t50/s4201/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4201%2F5%2FA","sourceRelease":"119-100","text":"injustices suffered and unreasonable hardships endured while those Aleut residents were under United States control during World War II;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s4201/5/B","parentIdentifier":"/us/usc/t50/s4201/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4201%2F5%2FB","sourceRelease":"119-100","text":"personal property taken or destroyed by United States forces during World War II;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t50/s4201/5/C","parentIdentifier":"/us/usc/t50/s4201/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4201%2F5%2FC","sourceRelease":"119-100","text":"community property, including community church property, taken or destroyed by United States forces during World War II; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t50/s4201/5/D","parentIdentifier":"/us/usc/t50/s4201/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4201%2F5%2FD","sourceRelease":"119-100","text":"traditional village lands on Attu Island not rehabilitated after World War II for Aleut occupation or other productive use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t50/s4201/6","parentIdentifier":"/us/usc/t50/s4201","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4201%2F6","sourceRelease":"119-100","text":"discourage the occurrence of similar injustices and violations of civil liberties in the future; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t50/s4201/7","parentIdentifier":"/us/usc/t50/s4201","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4201%2F7","sourceRelease":"119-100","text":"make more credible and sincere any declaration of concern by the United States over violations of human rights committed by other nations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
