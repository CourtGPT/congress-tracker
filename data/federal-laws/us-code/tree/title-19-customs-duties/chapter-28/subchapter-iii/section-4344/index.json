{"type":"section","nativeType":"section","number":"4344","heading":"National Intellectual Property Rights Coordination Center","label":"4344 National Intellectual Property Rights Coordination Center","identifier":"/us/usc/t19/s4344","parentIdentifier":"/us/usc/t19/ch28/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t19/s4344/a","parentIdentifier":"/us/usc/t19/s4344","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4344/a/1","parentIdentifier":"/us/usc/t19/s4344/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fa%2F1","sourceRelease":"119-100","text":"establish within U.S. Immigration and Customs Enforcement a National Intellectual Property Rights Coordination Center; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4344/a/2","parentIdentifier":"/us/usc/t19/s4344/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fa%2F2","sourceRelease":"119-100","text":"appoint an Assistant Director to head the National Intellectual Property Rights Coordination Center.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties","label":"b Duties","identifier":"/us/usc/t19/s4344/b","parentIdentifier":"/us/usc/t19/s4344","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4344/b/1","parentIdentifier":"/us/usc/t19/s4344/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fb%2F1","sourceRelease":"119-100","text":"coordinate the investigation of sources of merchandise that infringe intellectual property rights to identify organizations and individuals that produce, smuggle, or distribute such merchandise;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4344/b/2","parentIdentifier":"/us/usc/t19/s4344/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s4344/b/2/A","parentIdentifier":"/us/usc/t19/s4344/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fb%2F2%2FA","sourceRelease":"119-100","text":"to develop and expand the capability of such agencies to enforce intellectual property rights; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s4344/b/2/B","parentIdentifier":"/us/usc/t19/s4344/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fb%2F2%2FB","sourceRelease":"119-100","text":"to develop metrics to assess whether the training improved enforcement of intellectual property rights;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s4344/b/3","parentIdentifier":"/us/usc/t19/s4344/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fb%2F3","sourceRelease":"119-100","text":"coordinate, with U.S. Customs and Border Protection, activities conducted by the United States to prevent the importation or exportation of merchandise that infringes intellectual property rights;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t19/s4344/b/4","parentIdentifier":"/us/usc/t19/s4344/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fb%2F4","sourceRelease":"119-100","text":"support the international interdiction of merchandise destined for the United States that infringes intellectual property rights;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t19/s4344/b/5","parentIdentifier":"/us/usc/t19/s4344/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fb%2F5","sourceRelease":"119-100","text":"collect and integrate information regarding infringement of intellectual property rights from domestic and international law enforcement agencies and other non-Federal sources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t19/s4344/b/6","parentIdentifier":"/us/usc/t19/s4344/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fb%2F6","sourceRelease":"119-100","text":"develop a means to receive and organize information regarding infringement of intellectual property rights from such agencies and other sources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t19/s4344/b/7","parentIdentifier":"/us/usc/t19/s4344/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fb%2F7","sourceRelease":"119-100","text":"disseminate information regarding infringement of intellectual property rights to other Federal agencies, as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t19/s4344/b/8","parentIdentifier":"/us/usc/t19/s4344/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fb%2F8","sourceRelease":"119-100","text":"develop and implement risk-based alert systems, in coordination with U.S. Customs and Border Protection, to improve the targeting of persons that repeatedly infringe intellectual property rights;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t19/s4344/b/9","parentIdentifier":"/us/usc/t19/s4344/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fb%2F9","sourceRelease":"119-100","text":"coordinate with the offices of United States attorneys in order to develop expertise in, and assist with the investigation and prosecution of, crimes relating to the infringement of intellectual property rights; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t19/s4344/b/10","parentIdentifier":"/us/usc/t19/s4344/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fb%2F10","sourceRelease":"119-100","text":"carry out such other duties as the Secretary of Homeland Security may assign.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Coordination with other agencies","label":"c Coordination with other agencies","identifier":"/us/usc/t19/s4344/c","parentIdentifier":"/us/usc/t19/s4344","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4344/c/1","parentIdentifier":"/us/usc/t19/s4344/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fc%2F1","sourceRelease":"119-100","text":"U.S. Customs and Border Protection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4344/c/2","parentIdentifier":"/us/usc/t19/s4344/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fc%2F2","sourceRelease":"119-100","text":"the Food and Drug Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s4344/c/3","parentIdentifier":"/us/usc/t19/s4344/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fc%2F3","sourceRelease":"119-100","text":"the Department of Justice;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t19/s4344/c/4","parentIdentifier":"/us/usc/t19/s4344/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fc%2F4","sourceRelease":"119-100","text":"the Department of Commerce, including the United States Patent and Trademark Office;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t19/s4344/c/5","parentIdentifier":"/us/usc/t19/s4344/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fc%2F5","sourceRelease":"119-100","text":"the United States Postal Inspection Service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t19/s4344/c/6","parentIdentifier":"/us/usc/t19/s4344/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fc%2F6","sourceRelease":"119-100","text":"the Office of the United States Trade Representative;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t19/s4344/c/7","parentIdentifier":"/us/usc/t19/s4344/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fc%2F7","sourceRelease":"119-100","text":"any Federal, State, local, or international law enforcement agencies that the Director of U.S. Immigration and Customs Enforcement considers appropriate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t19/s4344/c/8","parentIdentifier":"/us/usc/t19/s4344/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fc%2F8","sourceRelease":"119-100","text":"any other entities that the Director considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Private sector outreach","label":"d Private sector outreach","identifier":"/us/usc/t19/s4344/d","parentIdentifier":"/us/usc/t19/s4344","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t19/s4344/d/1","parentIdentifier":"/us/usc/t19/s4344/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fd%2F1","sourceRelease":"119-100","text":"The Assistant Director of the National Intellectual Property Rights Coordination Center shall work with U.S. Customs and Border Protection and other Federal agencies to conduct outreach to private sector entities in order to determine trends in and methods of infringing intellectual property rights.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Information sharing","label":"2 Information sharing","identifier":"/us/usc/t19/s4344/d/2","parentIdentifier":"/us/usc/t19/s4344/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4344%2Fd%2F2","sourceRelease":"119-100","text":"The Assistant Director shall share information and best practices with respect to the enforcement of intellectual property rights with private sector entities, as appropriate, in order to coordinate public and private sector efforts to combat the infringement of intellectual property rights.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
