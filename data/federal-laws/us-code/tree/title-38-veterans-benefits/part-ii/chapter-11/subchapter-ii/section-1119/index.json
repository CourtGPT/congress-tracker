entIdentifier":"/us/usc/t38/s1119/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1119%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1119/c/2/A","parentIdentifier":"/us/usc/t38/s1119/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1119%2Fc%2F2%2FA","sourceRelease":"119-100","text":"means any system, program, or pilot program used by the Secretary of Veterans Affairs or the Secretary of Defense to track how veterans or members of the Armed Forces have been exposed to various occupational or environmental hazards; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1119/c/2/B","parentIdentifier":"/us/usc/t38/s1119/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1119%2Fc%2F2%2FB","sourceRelease":"119-100","text":"includes the Individual Longitudinal Exposure Record, or successor system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1119/c/3","parentIdentifier":"/us/usc/t38/s1119/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1119%2Fc%2F3","sourceRelease":"119-100","text":"The term “toxic exposure risk activity” has the meaning given such term in .section 1710(e)(4) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
