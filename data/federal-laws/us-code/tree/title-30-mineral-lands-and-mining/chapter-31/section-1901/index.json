” in .section 6304 of title 31","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t30/s1901/5","parentIdentifier":"/us/usc/t30/s1901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1901%2F5","sourceRelease":"119-100","text":"The term “in-kind contribution” means a noncash contribution provided by a non-Federal entity that directly benefits and is related to a specific project or program. An in-kind contribution may include real property, equipment, supplies, other expendable property, goods, and services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t30/s1901/6","parentIdentifier":"/us/usc/t30/s1901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1901%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t30/s1901/6/A","parentIdentifier":"/us/usc/t30/s1901/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1901%2F6%2FA","sourceRelease":"119-100","text":"sand and aggregates;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t30/s1901/6/B","parentIdentifier":"/us/usc/t30/s1901/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1901%2F6%2FB","sourceRelease":"119-100","text":"placers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t30/s1901/6/C","parentIdentifier":"/us/usc/t30/s1901/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1901%2F6%2FC","sourceRelease":"119-100","text":"phosphates;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t30/s1901/6/D","parentIdentifier":"/us/usc/t30/s1901/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1901%2F6%2FD","sourceRelease":"119-100","text":"manganese nodules;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t30/s1901/6/E","parentIdentifier":"/us/usc/t30/s1901/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1901%2F6%2FE","sourceRelease":"119-100","text":"cobalt crusts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t30/s1901/6/F","parentIdentifier":"/us/usc/t30/s1901/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1901%2F6%2FF","sourceRelease":"119-100","text":"metal sulfides;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t30/s1901/6/G","parentIdentifier":"/us/usc/t30/s1901/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1901%2F6%2FG","sourceRelease":"119-100","text":"for purposes of this section and sections 1902 through 1905 of this title only, methane hydrate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t30/s1901/6/H","parentIdentifier":"/us/usc/t30/s1901/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1901%2F6%2FH","s