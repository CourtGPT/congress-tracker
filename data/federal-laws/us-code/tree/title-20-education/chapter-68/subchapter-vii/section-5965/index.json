{"type":"section","nativeType":"section","number":"5965","heading":"Use of funds","label":"5965 Use of funds","identifier":"/us/usc/t20/s5965","parentIdentifier":"/us/usc/t20/ch68/schVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t20/s5965/a","parentIdentifier":"/us/usc/t20/s5965","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s5965/a/1","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F1","sourceRelease":"119-100","text":"Identifying and assessing school violence and discipline problems, including coordinating needs assessment activities with education, law enforcement, judicial, health, social service, and other appropriate agencies and organizations, juvenile justice programs, and gang prevention activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s5965/a/2","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F2","sourceRelease":"119-100","text":"Conducting school safety reviews or violence prevention reviews of programs, policies, practices, and facilities to determine what changes are needed to reduce or prevent violence and promote safety and discipline.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s5965/a/3","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F3","sourceRelease":"119-100","text":"Planning for comprehensive, long-term strategies for addressing and preventing school violence and discipline problems through the involvement and coordination of school programs with other education, law enforcement, judicial, health, social service, and other appropriate agencies and organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s5965/a/4","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F4","sourceRelease":"119-100","text":"Training school personnel in programs of demonstrated effectiveness in addressing violence, including violence prevention, conflict resolution, anger management, peer mediation, and identification of high-risk youth.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t20/s5965/a/5","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F5","sourceRelease":"119-100","text":"Activities which involve parents in efforts to promote school safety and prevent school violence.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t20/s5965/a/6","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s5965/a/6/A","parentIdentifier":"/us/usc/t20/s5965/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F6%2FA","sourceRelease":"119-100","text":"the local educational agency’s plan to promote school safety and reduce and prevent school violence and discipline problems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s5965/a/6/B","parentIdentifier":"/us/usc/t20/s5965/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F6%2FB","sourceRelease":"119-100","text":"the need for community support.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t20/s5965/a/7","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F7","sourceRelease":"119-100","text":"Coordination of school-based activities designed to promote school safety and reduce or prevent school violence and discipline problems with related efforts of education, law enforcement, judicial, health, social service, and other appropriate agencies and organizations and juvenile justice programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t20/s5965/a/8","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s5965/a/8/A","parentIdentifier":"/us/usc/t20/s5965/a/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F8%2FA","sourceRelease":"119-100","text":"conflict resolution and social skills development for students, teachers, aides, other school personnel, and parents;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s5965/a/8/B","parentIdentifier":"/us/usc/t20/s5965/a/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F8%2FB","sourceRelease":"119-100","text":"disciplinary alternatives to expulsion and suspension of students who exhibit violent or antisocial behavior;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s5965/a/8/C","parentIdentifier":"/us/usc/t20/s5965/a/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F8%2FC","sourceRelease":"119-100","text":"student-led activities such as peer mediation, peer counseling, and student courts; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s5965/a/8/D","parentIdentifier":"/us/usc/t20/s5965/a/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F8%2FD","sourceRelease":"119-100","text":"alternative after-school programs that provide safe havens for students, which may include cultural, recreational, educational and instructional activities, and mentoring and community service programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t20/s5965/a/9","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F9","sourceRelease":"119-100","text":"Educating students and parents regarding the dangers of guns and other weapons and the consequences of their use.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t20/s5965/a/10","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F10","sourceRelease":"119-100","text":"Developing and implementing innovative curricula to prevent violence in schools and training staff how to stop disruptive or violent behavior if such behavior occurs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t20/s5965/a/11","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F11","sourceRelease":"119-100","text":"Supporting “safe zones of passage” for students between home and school through such measures as Drug- and Weapon-Free School Zones, enhanced law enforcement, and neighborhood patrols.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t20/s5965/a/12","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F12","sourceRelease":"119-100","text":"Counseling programs for victims and witnesses of school violence and crime.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"13","heading":null,"label":"13","identifier":"/us/usc/t20/s5965/a/13","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F13","sourceRelease":"119-100","text":"Acquiring and installing metal detectors and hiring security personnel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"14","heading":null,"label":"14","identifier":"/us/usc/t20/s5965/a/14","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F14","sourceRelease":"119-100","text":"Reimbursing law enforcement authorities for their personnel who participate in school violence prevention activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"15","heading":null,"label":"15","identifier":"/us/usc/t20/s5965/a/15","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F15","sourceRelease":"119-100","text":"Evaluating projects and activities assisted under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"16","heading":null,"label":"16","identifier":"/us/usc/t20/s5965/a/16","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F16","sourceRelease":"119-100","text":"The cost of administering projects or activities assisted under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"17","heading":null,"label":"17","identifier":"/us/usc/t20/s5965/a/17","parentIdentifier":"/us/usc/t20/s5965/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fa%2F17","sourceRelease":"119-100","text":"Other projects or activities that meet the purpose of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitations","label":"b Limitations","identifier":"/us/usc/t20/s5965/b","parentIdentifier":"/us/usc/t20/s5965","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t20/s5965/b/1","parentIdentifier":"/us/usc/t20/s5965/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s5965/b/1/A","parentIdentifier":"/us/usc/t20/s5965/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fb%2F1%2FA","sourceRelease":"119-100","text":"a total of 5 percent of grant funds received under this subchapter in each fiscal year for activities described in paragraphs (11), (13), and (14) of subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s5965/b/1/B","parentIdentifier":"/us/usc/t20/s5965/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fb%2F1%2FB","sourceRelease":"119-100","text":"5 percent of grant funds received under this subchapter in each fiscal year for activities described in paragraph (16) of subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Special rule","label":"2 Special rule","identifier":"/us/usc/t20/s5965/b/2","parentIdentifier":"/us/usc/t20/s5965/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fb%2F2","sourceRelease":"119-100","text":"A local educational agency shall only be able to use grant funds received under this subchapter for activities described in paragraphs (11), (13), and (14) of subsection (a) if funding for such activities is not available from other Federal sources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Prohibition","label":"3 Prohibition","identifier":"/us/usc/t20/s5965/b/3","parentIdentifier":"/us/usc/t20/s5965/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs5965%2Fb%2F3","sourceRelease":"119-100","text":"A local educational agency may not use grant funds received under this subchapter for construction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
