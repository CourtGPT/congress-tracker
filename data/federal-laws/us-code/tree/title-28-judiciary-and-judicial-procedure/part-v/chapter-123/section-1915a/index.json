{"type":"section","nativeType":"section","number":"1915A","heading":"Screening","label":"1915A Screening","identifier":"/us/usc/t28/s1915A","parentIdentifier":"/us/usc/t28/ptV/ch123","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs1915A","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Screening","label":"a .—Screening","identifier":"/us/usc/t28/s1915A/a","parentIdentifier":"/us/usc/t28/s1915A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs1915A%2Fa","sourceRelease":"119-100","text":"The court shall review, before docketing, if feasible or, in any event, as soon as practicable after docketing, a complaint in a civil action in which a prisoner seeks redress from a governmental entity or officer or employee of a governmental entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Grounds for Dismissal","label":"b .—Grounds for Dismissal","identifier":"/us/usc/t28/s1915A/b","parentIdentifier":"/us/usc/t28/s1915A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs1915A%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t28/s1915A/b/1","parentIdentifier":"/us/usc/t28/s1915A/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs1915A%2Fb%2F1","sourceRelease":"119-100","text":"is frivolous, malicious, or fails to state a claim upon which relief may be granted; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t28/s1915A/b/2","parentIdentifier":"/us/usc/t28/s1915A/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs1915A%2Fb%2F2","sourceRelease":"119-100","text":"seeks monetary relief from a defendant who is immune from such relief.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Definition","label":"c .—Definition","identifier":"/us/usc/t28/s1915A/c","parentIdentifier":"/us/usc/t28/s1915A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs1915A%2Fc","sourceRelease":"119-100","text":"As used in this section, the term “prisoner” means any person incarcerated or detained in any facility who is accused of, convicted of, sentenced for, or adjudicated delinquent for, violations of criminal law or the terms and conditions of parole, probation, pretrial release, or diversionary program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
