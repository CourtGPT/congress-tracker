{"type":"section","nativeType":"section","number":"1313","heading":"Definitions","label":"1313 Definitions","identifier":"/us/usc/t26/s1313","parentIdentifier":"/us/usc/t26/stA/ch1/schQ/ptII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1313","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments1976—Subsec. (a)(3), (4). struck out “or his delegate” after “Secretary” wherever appearing.Pub. L. 94–455"],"amendments":["Amendments1976—Subsec. (a)(3), (4). struck out “or his delegate” after “Secretary” wherever appearing.Pub. L. 94–455"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Determination","label":"a Determination","identifier":"/us/usc/t26/s1313/a","parentIdentifier":"/us/usc/t26/s1313","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1313%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s1313/a/1","parentIdentifier":"/us/usc/t26/s1313/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1313%2Fa%2F1","sourceRelease":"119-100","text":"a decision by the Tax Court or a judgment, decree, or other order by any court of competent jurisdiction, which has become final;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s1313/a/2","parentIdentifier":"/us/usc/t26/s1313/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1313%2Fa%2F2","sourceRelease":"119-100","text":"a closing agreement made under section 7121;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t26/s1313/a/3","parentIdenti