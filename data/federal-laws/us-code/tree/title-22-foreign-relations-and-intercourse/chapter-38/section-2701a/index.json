{"type":"section","nativeType":"section","number":"2701a","heading":"Education allowance for dependents of Department of State employees located in United States territories","label":"2701a Education allowance for dependents of Department of State employees located in United States territories","identifier":"/us/usc/t22/s2701a","parentIdentifier":"/us/usc/t22/ch38","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2701a","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","DefinitionFor definition of “Department” as used in this section, see , set out as a note under .section 6002 of Pub. L. 118–31section 2651 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s2701a/a","parentIdentifier":"/us/usc/t22/s2701a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2701a%2Fa","sourceRelease":"119-100","text":"An individual employed by the Department at a location described in subsection (b) shall be eligible for a cost-of-living allowance for the education of the dependents of such employee in an amount that does not exceed the educational allowance authorized by the Secretary of Defense for such location.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Location described","label":"b Location described","identifier":"/us/usc/t22/s2701a/b","parentIdentifier":"/us/usc/t22/s2701a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2701a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s2701a/b/1","parentIdentifier":"/us/usc/t22/s2701a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2701a%2Fb%2F1","sourceRelease":"119-100","text":"such location is in a territory of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s2701a/b/2","parentIdentifier":"/us/usc/t22/s2701a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2701a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s2701a/b/2/A","parentIdentifier":"/us/usc/t22/s2701a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2701a%2Fb%2F2%2FA","sourceRelease":"119-100","text":"dependents of members of the Armed Forces; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s2701a/b/2/B","parentIdentifier":"/us/usc/t22/s2701a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2701a%2Fb%2F2%2FB","sourceRelease":"119-100","text":"dependents of employees of the Department of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
