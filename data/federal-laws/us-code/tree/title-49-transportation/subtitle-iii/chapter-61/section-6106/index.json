{"type":"section","nativeType":"section","number":"6106","heading":"Grants to States","label":"6106 Grants to States","identifier":"/us/usc/t49/s6106","parentIdentifier":"/us/usc/t49/stIII/ch61","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6106","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe date of enactment of this chapter, referred to in subsec. (b), is the date of enactment of , which was approved .Pub. L. 105–178June 9, 1998"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t49/s6106/a","parentIdentifier":"/us/usc/t49/s6106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6106%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s6106/a/1","parentIdentifier":"/us/usc/t49/s6106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6106%2Fa%2F1","sourceRelease":"119-100","text":"the overall quality and effectiveness of one-call notification systems in the State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s6106/a/2","parentIdentifier":"/us/usc/t49/s6106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6106%2Fa%2F2","sourceRelease":"119-100","text":"communications systems linking one-call notification systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s6106/a/3","parentIdentifier":"/us/usc/t49/s6106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6106%2Fa%2F3","sourceRelease":"119-100","text":"location capabilities, including training personnel and developing and using location technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s6106/a/4","parentIdentifier":"/us/usc/t49/s6106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6106%2Fa%2F4","sourceRelease":"119-100","text":"record retention and recording capabilities for one-call notification systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t49/s6106/a/5","parentIdentifier":"/us/usc/t49/s6106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6106%2Fa%2F5","sourceRelease":"119-100","text":"public information and education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t49/s6106/a/6","parentIdentifier":"/us/usc/t49/s6106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6106%2Fa%2F6","sourceRelease":"119-100","text":"participation in one-call notification systems; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t49/s6106/a/7","parentIdentifier":"/us/usc/t49/s6106/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6106%2Fa%2F7","sourceRelease":"119-100","text":"compliance and enforcement under the State one-call notification program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—State Action Taken Into Account","label":"b .—State Action Taken Into Account","identifier":"/us/usc/t49/s6106/b","parentIdentifier":"/us/usc/t49/s6106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6106%2Fb","sourceRelease":"119-100","text":"In making grants under this section, the Secretary shall take into consideration the commitment of each State to improving its State one-call notification program, including legislative and regulatory actions taken by the State after the date of enactment of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Funding for One-Call Notification Systems","label":"c .—Funding for One-Call Notification Systems","identifier":"/us/usc/t49/s6106/c","parentIdentifier":"/us/usc/t49/s6106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6106%2Fc","sourceRelease":"119-100","text":"A State may provide funds received under this section directly to any one-call notification system in such State that substantially adopts the best practices identified under section 6105.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
