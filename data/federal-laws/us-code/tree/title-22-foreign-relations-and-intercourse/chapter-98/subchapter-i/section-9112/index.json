{"type":"section","nativeType":"section","number":"9112","heading":"Standards and assistance","label":"9112 Standards and assistance","identifier":"/us/usc/t22/s9112","parentIdentifier":"/us/usc/t22/ch98/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9112","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9112/1","parentIdentifier":"/us/usc/t22/s9112","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9112%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9112/1/A","parentIdentifier":"/us/usc/t22/s9112/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9112%2F1%2FA","sourceRelease":"119-100","text":"maintain a consistent reporting standard with respect to abduction and access cases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9112/1/B","parentIdentifier":"/us/usc/t22/s9112/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9112%2F1%2FB","sourceRelease":"119-100","text":"designate at least 1 senior official in each such mission, at the discretion of the Chief of Mission, to assist left-behind parents from the United States who are visiting such country or otherwise seeking to resolve abduction or access cases; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9112/1/C","parentIdentifier":"/us/usc/t22/s9112/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9112%2F1%2FC","sourceRelease":"119-100","text":"monitor developments in abduction and access cases; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9112/2","parentIdentifier":"/us/usc/t22/s9112","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9112%2F2","sourceRelease":"119-100","text":"develop and implement written strategic plans for engagement with any Convention or non-Convention country in which there are 5 or more cases of international child abduction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
