{"type":"section","nativeType":"section","number":"16253","heading":"Small business bioproduct marketing and certification grants","label":"16253 Small business bioproduct marketing and certification grants","identifier":"/us/usc/t42/s16253","parentIdentifier":"/us/usc/t42/ch149/schIX/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2014—Subsec. (c)(2)(A). substituted “section 8102(b)” for “section 8102(h)(1)”.Pub. L. 113–79"],"amendments":["Amendments2014—Subsec. (c)(2)(A). substituted “section 8102(b)” for “section 8102(h)(1)”.Pub. L. 113–79"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s16253/a","parentIdentifier":"/us/usc/t42/s16253","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fa","sourceRelease":"119-100","text":"Using amounts made available under subsection (g), the Secretary of Agriculture (referred to in this section as the “Secretary”) shall make available on a competitive basis grants to eligible entities described in subsection (b) for the biobased product marketing and certification purposes described in subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Eligible entities","label":"b Eligible entities","identifier":"/us/usc/t42/s16253/b","parentIdentifier":"/us/usc/t42/s16253","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16253/b/1","parentIdentifier":"/us/usc/t42/s16253/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16253/b/1/A","parentIdentifier":"/us/usc/t42/s16253/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fb%2F1%2FA","sourceRelease":"119-100","text":"proposes to use the grant for the biobased product marketing and certification purposes described in subsection (c); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16253/b/1/B","parentIdentifier":"/us/usc/t42/s16253/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fb%2F1%2FB","sourceRelease":"119-100","text":"has not previously received a grant under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Preference","label":"2 Preference","identifier":"/us/usc/t42/s16253/b/2","parentIdentifier":"/us/usc/t42/s16253/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fb%2F2","sourceRelease":"119-100","text":"In making grants under this section, the Secretary shall provide a preference to an eligible entity that has fewer than 50 employees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Biobased product marketing and certification grant purposes","label":"c Biobased product marketing and certification grant purposes","identifier":"/us/usc/t42/s16253/c","parentIdentifier":"/us/usc/t42/s16253","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16253/c/1","parentIdentifier":"/us/usc/t42/s16253/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fc%2F1","sourceRelease":"119-100","text":"to provide working capital for marketing of biobased products; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16253/c/2","parentIdentifier":"/us/usc/t42/s16253/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16253/c/2/A","parentIdentifier":"/us/usc/t42/s16253/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fc%2F2%2FA","sourceRelease":"119-100","text":"qualify for the label described in ; orsection 8102(b) of title 7","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16253/c/2/B","parentIdentifier":"/us/usc/t42/s16253/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fc%2F2%2FB","sourceRelease":"119-100","text":"meet other biobased standards determined appropriate by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Matching funds","label":"d Matching funds","identifier":"/us/usc/t42/s16253/d","parentIdentifier":"/us/usc/t42/s16253","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16253/d/1","parentIdentifier":"/us/usc/t42/s16253/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fd%2F1","sourceRelease":"119-100","text":"Grant recipients shall provide matching non-Federal funds equal to the amount of the grant received.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Expenditure","label":"2 Expenditure","identifier":"/us/usc/t42/s16253/d/2","parentIdentifier":"/us/usc/t42/s16253/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fd%2F2","sourceRelease":"119-100","text":"Matching funds shall be expended in advance of grant funding, so that for every dollar of grant that is advanced, an equal amount of matching funds shall have been funded prior to submitting the request for reimbursement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Amount","label":"e Amount","identifier":"/us/usc/t42/s16253/e","parentIdentifier":"/us/usc/t42/s16253","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fe","sourceRelease":"119-100","text":"A grant made under this section shall not exceed $100,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Administration","label":"f Administration","identifier":"/us/usc/t42/s16253/f","parentIdentifier":"/us/usc/t42/s16253","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Ff","sourceRelease":"119-100","text":"The Secretary shall establish such administrative requirements for grants under this section, including requirements for applications for the grants, as the Secretary considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Authorizations of appropriations","label":"g Authorizations of appropriations","identifier":"/us/usc/t42/s16253/g","parentIdentifier":"/us/usc/t42/s16253","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16253/g/1","parentIdentifier":"/us/usc/t42/s16253/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fg%2F1","sourceRelease":"119-100","text":"$1,000,000 for fiscal year 2006; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16253/g/2","parentIdentifier":"/us/usc/t42/s16253/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16253%2Fg%2F2","sourceRelease":"119-100","text":"such sums as are necessary for each of fiscal years 2007 through 2015.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
