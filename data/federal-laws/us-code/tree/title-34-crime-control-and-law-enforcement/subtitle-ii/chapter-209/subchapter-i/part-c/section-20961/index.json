nly in investigating or responding to reports of child abuse, neglect, or exploitation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Conditions of access","label":"b Conditions of access","identifier":"/us/usc/t34/s20961/b","parentIdentifier":"/us/usc/t34/s20961","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs20961%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s20961/b/1","parentIdentifier":"/us/usc/t34/s20961/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs20961%2Fb%2F1","sourceRelease":"119-100","text":"defined by the Attorney General; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s20961/b/2","parentIdentifier":"/us/usc/t34/s20961/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs20961%2Fb%2F2","sourceRelease":"119-100","text":"limited to personnel of the Center or such agencies that have met all requirements set by the Attorney General, including training, certification, and background screening.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
