:"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Defined term","label":"1 Defined term","identifier":"/us/usc/t22/s9753/b/1","parentIdentifier":"/us/usc/t22/s9753/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9753/b/1/A","parentIdentifier":"/us/usc/t22/s9753/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the Committee on Foreign Relations of the Senate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9753/b/1/B","parentIdentifier":"/us/usc/t22/s9753/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the Committee on Foreign Affairs of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Threat assessment","label":"2 Threat assessment","identifier":"/us/usc/t22/s9753/b/2","parentIdentifier":"/us/usc/t22/s9753/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9753/b/2/A","parentIdentifier":"/us/usc/t22/s9753/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fb%2F2%2FA","sourceRelease":"119-100","text":"an assessment of Russian-Venezuelan security cooperation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9753/b/2/B","parentIdentifier":"/us/usc/t22/s9753/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the potential threat such cooperation poses to the United States and countries in the Western Hemisphere; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9753/b/2/C","parentIdentifier":"/us/usc/t22/s9753/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fb%2F2%2FC","sourceRelease":"119-100","text":"a strategy to counter threats identified in subparagraphs (A) and (B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Aliens ineligible for visas, admission, or parole","label":"c Aliens ineligible for visas, admission, or parole","identifier":"/us/usc/t22/s9753/c","parentIdentifier":"/us/usc/t22/s9753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Aliens described","label":"1 Aliens described","identifier":"/us/usc/t22/s9753/c/1","parentIdentifier":"/us/usc/t22/s9753/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F1","sourceRelease":"119-100","text":"An alien described in this paragraph is an alien who the Secretary of State or the Secretary of Homeland Security (or a designee of either Secretary) knows, or has reason to believe, is acting or has acted on behalf of the Government of Russia in direct support of the security forces of the Maduro regime.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Visas, admission, or parole","label":"2 Visas, admission, or parole","identifier":"/us/usc/t22/s9753/c/2","parentIdentifier":"/us/usc/t22/s9753/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9753/c/2/A","parentIdentifier":"/us/usc/t22/s9753/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F2%2FA","sourceRelease":"119-100","text":"inadmissible to the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9753/c/2/B","parentIdentifier":"/us/usc/t22/s9753/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F2%2FB","sourceRelease":"119-100","text":"ineligible to receive a visa or other documentation to enter the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9753/c/2/C","parentIdentifier":"/us/usc/t22/s9753/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F2%2FC","sourceRelease":"119-100","text":"otherwise ineligible to be admitted or paroled into the United States or to receive any benefit under the Immigration and Nationality Act ( et seq.).8 U.S.C. 1101","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Current visas revoked","label":"3 Current visas revoked","identifier":"/us/usc/t22/s9753/c/3","parentIdentifier":"/us/usc/t22/s9753/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t22/s9753/c/3/A","parentIdentifier":"/us/usc/t22/s9753/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F3%2FA","sourceRelease":"119-100","text":"An alien described in paragraph (1) is subject to revocation of any visa or other entry documentation regardless of when the visa or other entry documentation is or was issued.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Immediate effect","label":"B Immediate effect","identifier":"/us/usc/t22/s9753/c/3/B","parentIdentifier":"/us/usc/t22/s9753/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s9753/c/3/B/i","parentIdentifier":"/us/usc/t22/s9753/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":"take effect immediately; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s9753/c/3/B/ii","parentIdentifier":"/us/usc/t22/s9753/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":"automatically cancel any other valid visa or entry documentation that is in the alien’s possession.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Exceptions","label":"4 Exceptions","identifier":"/us/usc/t22/s9753/c/4","parentIdentifier":"/us/usc/t22/s9753/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9753/c/4/A","parentIdentifier":"/us/usc/t22/s9753/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F4%2FA","sourceRelease":"119-100","text":"to permit the United States to comply with the Agreement regarding the Headquarters of the United Nations, signed at Lake Success , and entered into force , between the United Nations and the United States, or other applicable international obligations; orJune 26, 1947November 21, 1947","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9753/c/4/B","parentIdentifier":"/us/usc/t22/s9753/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F4%2FB","sourceRelease":"119-100","text":"to carry out or assist law enforcement activity in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"National security","label":"5 National security","identifier":"/us/usc/t22/s9753/c/5","parentIdentifier":"/us/usc/t22/s9753/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9753/c/5/A","parentIdentifier":"/us/usc/t22/s9753/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F5%2FA","sourceRelease":"119-100","text":"determines that such a waiver is in the national interest of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9753/c/5/B","parentIdentifier":"/us/usc/t22/s9753/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F5%2FB","sourceRelease":"119-100","text":"submits a notice of, and justification for, such waiver to the appropriate congressional committees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Sunset","label":"6 Sunset","identifier":"/us/usc/t22/s9753/c/6","parentIdentifier":"/us/usc/t22/s9753/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9753%2Fc%2F6","sourceRelease":"119-100","text":"This subsection shall terminate on the date that is 1 year after .December 20, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
