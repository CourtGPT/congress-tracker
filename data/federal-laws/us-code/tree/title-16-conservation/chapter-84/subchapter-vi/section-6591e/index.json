/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fv%2FIV","sourceRelease":"119-100","text":"economic opportunities consistent with multiple-use management; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t16/s6591e/a/1/A/v/V","parentIdentifier":"/us/usc/t16/s6591e/a/1/A/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fv%2FV","sourceRelease":"119-100","text":"the identified values of a unit of the National Landscape Conservation System;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t16/s6591e/a/1/A/vi","parentIdentifier":"/us/usc/t16/s6591e/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fvi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s6591e/a/1/A/vi/I","parentIdentifier":"/us/usc/t16/s6591e/a/1/A/vi","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fvi%2FI","sourceRelease":"119-100","text":"restores native vegetation following a natural disturbance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s6591e/a/1/A/vi/II","parentIdentifier":"/us/usc/t16/s6591e/a/1/A/vi","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fvi%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t16/s6591e/a/1/A/vi/II/aa","parentIdentifier":"/us/usc/t16/s6591e/a/1/A/vi/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fvi%2FII%2Faa","sourceRelease":"119-100","text":"juniper, pinyon pine, or other associated conifers; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t16/s6591e/a/1/A/vi/II/bb","parentIdentifier":"/us/usc/t16/s6591e/a/1/A/vi/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fvi%2FII%2Fbb","sourceRelease":"119-100","text":"nonnative or invasive vegetation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s6591e/a/1/A/vi/III","parentIdentifier":"/us/usc/t16/s6591e/a/1/A/vi","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fvi%2FIII","sourceRelease":"119-100","text":"reduces the risk of loss of greater sage-grouse or mule deer habitat from wildfire or any other natural disturbance; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t16/s6591e/a/1/A/vi/IV","parentIdentifier":"/us/usc/t16/s6591e/a/1/A/vi","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fvi%2FIV","sourceRelease":"119-100","text":"provides emergency stabilization of soil resources after a natural disturbance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t16/s6591e/a/1/A/vii","parentIdentifier":"/us/usc/t16/s6591e/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fvii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s6591e/a/1/A/vii/I","parentIdentifier":"/us/usc/t16/s6591e/a/1/A/vii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fvii%2FI","sourceRelease":"119-100","text":"maximize the retention of old-growth and large trees, as appropriate for the forest type;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s6591e/a/1/A/vii/II","parentIdentifier":"/us/usc/t16/s6591e/a/1/A/vii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fvii%2FII","sourceRelease":"119-100","text":"consider the best available scientific information to maintain or restore the ecological integrity, including maintaining or restoring structure, function, composition, and connectivity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s6591e/a/1/A/vii/III","parentIdentifier":"/us/usc/t16/s6591e/a/1/A/vii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fvii%2FIII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t16/s6591e/a/1/A/vii/III/aa","parentIdentifier":"/us/usc/t16/s6591e/a/1/A/vii/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fa%2F1%2FA%2Fvii%2FIII%2Faa","sourceRelease":"119-100","text":"includes multiple interested persons representing diverse interests; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","native