{"type":"section","nativeType":"section","number":"944","heading":"Effect of confirmation","label":"944 Effect of confirmation","identifier":"/us/usc/t11/s944","parentIdentifier":"/us/usc/t11/ch9/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944","sourceRelease":"119-100","text":null,"notes":["Historical and Revision Notes","senate report no. 95–989[Section 947] Subsection (a) [enacted as section 944(a)] makes the provisions of a confirmed plan binding on the debtor and creditors. It is derived from section 95(a) of chapter 9 [section 415(a) of former title 11].Subsections (b) and (c) [enacted as section 944(b) and (c)] provide for the discharge of a municipality. The discharge is essentially the same as that granted under section 95(b) of the Bankruptcy Act [section 415(b) of former title 11]."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t11/s944/a","parentIdentifier":"/us/usc/t11/s944","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t11/s944/a/1","parentIdentifier":"/us/usc/t11/s944/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944%2Fa%2F1","sourceRelease":"119-100","text":"a proof of such creditor’s claim is filed or deemed filed under ;section 501 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t11/s944/a/2","parentIdentifier":"/us/usc/t11/s944/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944%2Fa%2F2","sourceRelease":"119-100","text":"such claim is allowed under ; orsection 502 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t11/s944/a/3","parentIdentifier":"/us/usc/t11/s944/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944%2Fa%2F3","sourceRelease":"119-100","text":"such creditor has accepted the plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t11/s944/b","parentIdentifier":"/us/usc/t11/s944","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t11/s944/b/1","parentIdentifier":"/us/usc/t11/s944/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944%2Fb%2F1","sourceRelease":"119-100","text":"the plan is confirmed;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t11/s944/b/2","parentIdentifier":"/us/usc/t11/s944/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944%2Fb%2F2","sourceRelease":"119-100","text":"the debtor deposits any consideration to be distributed under the plan with a disbursing agent appointed by the court; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t11/s944/b/3","parentIdentifier":"/us/usc/t11/s944/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t11/s944/b/3/A","parentIdentifier":"/us/usc/t11/s944/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944%2Fb%2F3%2FA","sourceRelease":"119-100","text":"that any security so deposited will constitute, after distribution, a valid legal obligation of the debtor; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t11/s944/b/3/B","parentIdentifier":"/us/usc/t11/s944/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944%2Fb%2F3%2FB","sourceRelease":"119-100","text":"that any provision made to pay or secure payment of such obligation is valid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t11/s944/c","parentIdentifier":"/us/usc/t11/s944","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t11/s944/c/1","parentIdentifier":"/us/usc/t11/s944/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944%2Fc%2F1","sourceRelease":"119-100","text":"excepted from discharge by the plan or order confirming the plan; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t11/s944/c/2","parentIdentifier":"/us/usc/t11/s944/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft11%2Fs944%2Fc%2F2","sourceRelease":"119-100","text":"owed to an entity that, before confirmation of the plan, had neither notice nor actual knowledge of the case.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
