{"type":"section","nativeType":"section","number":"9305","heading":"Agreements with Canada","label":"9305 Agreements with Canada","identifier":"/us/usc/t46/s9305","parentIdentifier":"/us/usc/t46/stII/ptF/ch93","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs9305","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevised sectionSource section (U.S. Code)930546:216b(d)46:216dSection 9305 authorizes the Secretary of Transportation, subject to the concurrence of the Secretary of State, to make agreements with Canada for a coordinated system of pilotage service on the Great Lakes. The agreements may fix the number of registered pilots, provide for equitable participation, prescribe rates and charges, coordinate pool operations, and establish conditions for service."],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s9305/1","parentIdentifier":"/us/usc/t46/s9305","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs9305%2F1","sourceRelease":"119-100","text":"fix the number of pilots to be registered in each country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s9305/2","parentIdentifier":"/us/usc/t46/s9305","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs9305%2F2","sourceRelease":"119-100","text":"provide for participation on an equitable basis;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s9305/3","parentIdentifier":"/us/usc/t46/s9305","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs9305%2F3","sourceRelease":"119-100","text":"prescribe joint or identical rates and charges;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t46/s9305/4","parentIdentifier":"/us/usc/t46/s9305","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs9305%2F4","sourceRelease":"119-100","text":"coordinate pool operations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t46/s9305/5","parentIdentifier":"/us/usc/t46/s9305","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs9305%2F5","sourceRelease":"119-100","text":"establish conditions for services by registered pilots.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
