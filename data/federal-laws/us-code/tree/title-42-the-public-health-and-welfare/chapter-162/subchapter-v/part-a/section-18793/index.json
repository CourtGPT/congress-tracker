,"sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fa%2F1%2FA","sourceRelease":"119-100","text":"The American Society of Heating, Refrigerating and Air-Conditioning Engineers Building Energy Assessment Professional certification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18793/a/1/B","parentIdentifier":"/us/usc/t42/s18793/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fa%2F1%2FB","sourceRelease":"119-100","text":"The Association of Energy Engineers Certified Energy Auditor certification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18793/a/1/C","parentIdentifier":"/us/usc/t42/s18793/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fa%2F1%2FC","sourceRelease":"119-100","text":"The Building Performance Institute Home Energy Professional Energy Auditor certification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s18793/a/1/D","parentIdentifier":"/us/usc/t42/s18793/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fa%2F1%2FD","sourceRelease":"119-100","text":"The Residential Energy Services Network Home Energy Rater certification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s18793/a/1/E","parentIdentifier":"/us/usc/t42/s18793/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fa%2F1%2FE","sourceRelease":"119-100","text":"Any other third-party certification recognized by the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s18793/a/1/F","parentIdentifier":"/us/usc/t42/s18793/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fa%2F1%2FF","sourceRelease":"119-100","text":"Any third-party certification that the Secretary determines is equivalent to the certifications described in subparagraphs (A) through (E).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible State","label":"2 Eligible State","identifier":"/us/usc/t42/s18793/a/2","parentIdentifier":"/us/usc/t42/s18793/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18793/a/2/A","parentIdentifier":"/us/usc/t42/s18793/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fa%2F2%2FA","sourceRelease":"119-100","text":"has a demonstrated need for assistance for training energy auditors; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18793/a/2/B","parentIdentifier":"/us/usc/t42/s18793/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fa%2F2%2FB","sourceRelease":"119-100","text":"meets any additional criteria determined necessary by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t42/s18793/b","parentIdentifier":"/us/usc/t42/s18793","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fb","sourceRelease":"119-100","text":"Under the State Energy Program, the Secretary shall establish a competitive grant program under which the Secretary shall award grants to eligible States to train individuals to conduct energy audits or surveys of commercial and residential buildings.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Applications","label":"c Applications","identifier":"/us/usc/t42/s18793/c","parentIdentifier":"/us/usc/t42/s18793","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18793/c/1","parentIdentifier":"/us/usc/t42/s18793/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fc%2F1","sourceRelease":"119-100","text":"A State seeking a grant under subsection (b) shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including the energy auditor training program plan described in paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Energy auditor training program plan","label":"2 Energy auditor training program plan","identifier":"/us/usc/t42/s18793/c/2","parentIdentifier":"/us/usc/t42/s18793/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18793/c/2/A","parentIdentifier":"/us/usc/t42/s18793/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18793/c/2/A/i","parentIdentifier":"/us/usc/t42/s18793/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"a proposed training curriculum for energy audit trainees; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18793/c/2/A/ii","parentIdentifier":"/us/usc/t42/s18793/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":"an identification of the covered certification that those trainees will receive on completion of that training curriculum;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18793/c/2/B","parentIdentifier":"/us/usc/t42/s18793/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the expected per-individual cost of training;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18793/c/2/C","parentIdentifier":"/us/usc/t42/s18793/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fc%2F2%2FC","sourceRelease":"119-100","text":"a plan for connecting trainees with employment opportunities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s18793/c/2/D","parentIdentifier":"/us/usc/t42/s18793/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fc%2F2%2FD","sourceRelease":"119-100","text":"any additional information required by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Amount of grant","label":"d Amount of grant","identifier":"/us/usc/t42/s18793/d","parentIdentifier":"/us/usc/t42/s18793","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18793/d/1","parentIdentifier":"/us/usc/t42/s18793/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fd%2F1","sourceRelease":"119-100","text":"shall be determined by the Secretary, taking into account the population of the eligible State; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18793/d/2","parentIdentifier":"/us/usc/t42/s18793/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fd%2F2","sourceRelease":"119-100","text":"shall not exceed $2,000,000 for any eligible State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Use of funds","label":"e Use of funds","identifier":"/us/usc/t42/s18793/e","parentIdentifier":"/us/usc/t42/s18793","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18793/e/1","parentIdentifier":"/us/usc/t42/s18793/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18793/e/1/A","parentIdentifier":"/us/usc/t42/s18793/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fe%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18793/e/1/A/i","parentIdentifier":"/us/usc/t42/s18793/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fe%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the State; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18793/e/1/A/ii","parentIdentifier":"/us/usc/t42/s18793/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fe%2F1%2FA%2Fii","sourceRelease":"119-100","text":"a State-certified third party training program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18793/e/1/B","parentIdentifier":"/us/usc/t42/s18793/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fe%2F1%2FB","sourceRelease":"119-100","text":"subject to paragraph (2), to pay the wages of a trainee during the period in which the trainee receives training and certification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitation","label":"2 Limitation","identifier":"/us/usc/t42/s18793/e/2","parentIdentifier":"/us/usc/t42/s18793/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fe%2F2","sourceRelease":"119-100","text":"Not more than 10 percent of grant funds provided under subsection (b) to an eligible State may be used for the purpose described in paragraph (1)(B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Consultation","label":"f Consultation","identifier":"/us/usc/t42/s18793/f","parentIdentifier":"/us/usc/t42/s18793","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Ff","sourceRelease":"119-100","text":"In carrying out this section, the Secretary shall consult with the Secretary of Labor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Authorization of appropriations","label":"g Authorization of appropriations","identifier":"/us/usc/t42/s18793/g","parentIdentifier":"/us/usc/t42/s18793","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18793%2Fg","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary to carry out this section $40,000,000 for the period of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
