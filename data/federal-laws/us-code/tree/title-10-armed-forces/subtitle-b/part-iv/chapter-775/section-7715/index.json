{"type":"section","nativeType":"section","number":"7715","heading":"Army museum system","label":"7715 Army museum system","identifier":"/us/usc/t10/s7715","parentIdentifier":"/us/usc/t10/stB/ptIV/ch775","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t10/s7715/a","parentIdentifier":"/us/usc/t10/s7715","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715%2Fa","sourceRelease":"119-100","text":"The Secretary of the Army shall support a system of official Army museums within the United States Army Center of Military History. Such system shall include the National Museum of the United States Army and may contain other museums honoring individual installations, units, and branches, as designated by the Secretary of the Army, that meet criteria established under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Criteria for Designation","label":"b .—Criteria for Designation","identifier":"/us/usc/t10/s7715/b","parentIdentifier":"/us/usc/t10/s7715","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s7715/b/1","parentIdentifier":"/us/usc/t10/s7715/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715%2Fb%2F1","sourceRelease":"119-100","text":"historical significance to Army operations, technology, or personnel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s7715/b/2","parentIdentifier":"/us/usc/t10/s7715/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715%2Fb%2F2","sourceRelease":"119-100","text":"public accessibility and educational outreach programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s7715/b/3","parentIdentifier":"/us/usc/t10/s7715/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715%2Fb%2F3","sourceRelease":"119-100","text":"alignment with the mission of the Army to preserve its heritage.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Criteria for Closure","label":"c .—Criteria for Closure","identifier":"/us/usc/t10/s7715/c","parentIdentifier":"/us/usc/t10/s7715","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s7715/c/1","parentIdentifier":"/us/usc/t10/s7715/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s7715/c/1/A","parentIdentifier":"/us/usc/t10/s7715/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715%2Fc%2F1%2FA","sourceRelease":"119-100","text":"a plan for the preservation, storage, or alternate display of historical collections contained in the museum;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s7715/c/1/B","parentIdentifier":"/us/usc/t10/s7715/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715%2Fc%2F1%2FB","sourceRelease":"119-100","text":"how any issues relating to museum personnel will be resolved;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s7715/c/1/C","parentIdentifier":"/us/usc/t10/s7715/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715%2Fc%2F1%2FC","sourceRelease":"119-100","text":"an identification of any efforts to maintain museum operations through public-private partnerships; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s7715/c/1/D","parentIdentifier":"/us/usc/t10/s7715/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715%2Fc%2F1%2FD","sourceRelease":"119-100","text":"an analysis of the cost to transport, consolidate, and preserve the historical collections contained in the museum; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s7715/c/2","parentIdentifier":"/us/usc/t10/s7715/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715%2Fc%2F2","sourceRelease":"119-100","text":"a period of 90 days has elapsed after the date on which such notice is received by such committees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Funding and Support","label":"d .—Funding and Support","identifier":"/us/usc/t10/s7715/d","parentIdentifier":"/us/usc/t10/s7715","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs7715%2Fd","sourceRelease":"119-100","text":"Consistent with applicable law, the Secretary may enter into partnerships, including with nonprofit organizations, to enhance the financial sustainability and public engagement of the museums in the Army museum system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
