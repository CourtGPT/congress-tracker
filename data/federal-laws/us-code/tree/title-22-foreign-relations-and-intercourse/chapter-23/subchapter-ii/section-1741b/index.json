{"type":"section","nativeType":"section","number":"1741b","heading":"Hostage Recovery Fusion Cell","label":"1741b Hostage Recovery Fusion Cell","identifier":"/us/usc/t22/s1741b","parentIdentifier":"/us/usc/t22/ch23/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t22/s1741b/a","parentIdentifier":"/us/usc/t22/s1741b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fa","sourceRelease":"119-100","text":"The President shall establish an interagency Hostage Recovery Fusion Cell.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Participation","label":"b Participation","identifier":"/us/usc/t22/s1741b/b","parentIdentifier":"/us/usc/t22/s1741b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s1741b/b/1","parentIdentifier":"/us/usc/t22/s1741b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fb%2F1","sourceRelease":"119-100","text":"The Department of State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s1741b/b/2","parentIdentifier":"/us/usc/t22/s1741b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fb%2F2","sourceRelease":"119-100","text":"The Department of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s1741b/b/3","parentIdentifier":"/us/usc/t22/s1741b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fb%2F3","sourceRelease":"119-100","text":"The Department of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s1741b/b/4","parentIdentifier":"/us/usc/t22/s1741b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fb%2F4","sourceRelease":"119-100","text":"The Department of Justice.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s1741b/b/5","parentIdentifier":"/us/usc/t22/s1741b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fb%2F5","sourceRelease":"119-100","text":"The Office of the Director of National Intelligence.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s1741b/b/6","parentIdentifier":"/us/usc/t22/s1741b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fb%2F6","sourceRelease":"119-100","text":"The Federal Bureau of Investigation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t22/s1741b/b/7","parentIdentifier":"/us/usc/t22/s1741b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fb%2F7","sourceRelease":"119-100","text":"The Central Intelligence Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t22/s1741b/b/8","parentIdentifier":"/us/usc/t22/s1741b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fb%2F8","sourceRelease":"119-100","text":"Other agencies as the President, from time to time, may designate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Personnel","label":"c Personnel","identifier":"/us/usc/t22/s1741b/c","parentIdentifier":"/us/usc/t22/s1741b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s1741b/c/1","parentIdentifier":"/us/usc/t22/s1741b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fc%2F1","sourceRelease":"119-100","text":"a Director, who shall be a full-time senior officer or employee of the United States Government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s1741b/c/2","parentIdentifier":"/us/usc/t22/s1741b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s1741b/c/2/A","parentIdentifier":"/us/usc/t22/s1741b/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fc%2F2%2FA","sourceRelease":"119-100","text":"work to ensure that all interactions by executive branch officials with a hostage’s family occur in a coordinated fashion and that the family receives consistent and accurate information from the United States Government; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s1741b/c/2/B","parentIdentifier":"/us/usc/t22/s1741b/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fc%2F2%2FB","sourceRelease":"119-100","text":"if directed, perform the same function as set out in subparagraph (A) with regard to the family of a United States national who is unlawfully or wrongfully detained abroad; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s1741b/c/3","parentIdentifier":"/us/usc/t22/s1741b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fc%2F3","sourceRelease":"119-100","text":"other officers and employees as deemed appropriate by the President.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Duties","label":"d Duties","identifier":"/us/usc/t22/s1741b/d","parentIdentifier":"/us/usc/t22/s1741b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s1741b/d/1","parentIdentifier":"/us/usc/t22/s1741b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fd%2F1","sourceRelease":"119-100","text":"coordinate efforts by participating agencies to ensure that all relevant information, expertise, and resources are brought to bear to secure the safe recovery of United States nationals held hostage abroad;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s1741b/d/2","parentIdentifier":"/us/usc/t22/s1741b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fd%2F2","sourceRelease":"119-100","text":"if directed, coordinate the United States Government’s response to other hostage-takings occurring abroad in which the United States has a national interest;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s1741b/d/3","parentIdentifier":"/us/usc/t22/s1741b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fd%2F3","sourceRelease":"119-100","text":"if directed, coordinate or assist the United States Government’s response to help secure the release of United States nationals unlawfully or wrongfully detained abroad; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s1741b/d/4","parentIdentifier":"/us/usc/t22/s1741b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fd%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s1741b/d/4/A","parentIdentifier":"/us/usc/t22/s1741b/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fd%2F4%2FA","sourceRelease":"119-100","text":"identify and recommend hostage recovery options and strategies to the President through the National Security Council or the Deputies Committee of the National Security Council;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s1741b/d/4/B","parentIdentifier":"/us/usc/t22/s1741b/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fd%2F4%2FB","sourceRelease":"119-100","text":"coordinate efforts by participating agencies to ensure that information regarding hostage events, including potential recovery options and engagements with families and external actors (including foreign governments), is appropriately shared within the United States Government to facilitate a coordinated response to a hostage-taking;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s1741b/d/4/C","parentIdentifier":"/us/usc/t22/s1741b/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fd%2F4%2FC","sourceRelease":"119-100","text":"assess and track all hostage-takings of United States nationals abroad and provide regular reports to the President and Congress on the status of such cases and any measures being taken toward the hostages’ safe recovery;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s1741b/d/4/D","parentIdentifier":"/us/usc/t22/s1741b/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fd%2F4%2FD","sourceRelease":"119-100","text":"provide a forum for intelligence sharing and, with the support of the Director of National Intelligence, coordinate the declassification of relevant information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t22/s1741b/d/4/E","parentIdentifier":"/us/usc/t22/s1741b/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fd%2F4%2FE","sourceRelease":"119-100","text":"coordinate efforts by participating agencies to provide appropriate support and assistance to hostages and their families in a coordinated and consistent manner and to provide families with timely information regarding significant events in their cases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t22/s1741b/d/4/F","parentIdentifier":"/us/usc/t22/s1741b/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fd%2F4%2FF","sourceRelease":"119-100","text":"make recommendations to agencies in order to reduce the likelihood of United States nationals’ being taken hostage abroad and enhance United States Government preparation to maximize the probability of a favorable outcome following a hostage-taking; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t22/s1741b/d/4/G","parentIdentifier":"/us/usc/t22/s1741b/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fd%2F4%2FG","sourceRelease":"119-100","text":"coordinate with agencies regarding congressional, media, and other public inquiries pertaining to hostage events.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Administration","label":"e Administration","identifier":"/us/usc/t22/s1741b/e","parentIdentifier":"/us/usc/t22/s1741b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1741b%2Fe","sourceRelease":"119-100","text":"The Hostage Recovery Fusion Cell shall be located within the Federal Bureau of Investigation for administrative purposes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
