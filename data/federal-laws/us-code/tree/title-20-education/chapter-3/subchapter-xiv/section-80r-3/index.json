{"type":"section","nativeType":"section","number":"80r–3","heading":"Council","label":"80r–3 Council","identifier":"/us/usc/t20/s80r–3","parentIdentifier":"/us/usc/t20/ch3/schXIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t20/s80r–3/a","parentIdentifier":"/us/usc/t20/s80r–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fa","sourceRelease":"119-100","text":"There is established within the Smithsonian Institution a council to be known as the “National Museum of African American History and Culture Council”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties","label":"b Duties","identifier":"/us/usc/t20/s80r–3/b","parentIdentifier":"/us/usc/t20/s80r–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t20/s80r–3/b/1","parentIdentifier":"/us/usc/t20/s80r–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s80r–3/b/1/A","parentIdentifier":"/us/usc/t20/s80r–3/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F1%2FA","sourceRelease":"119-100","text":"make recommendations to the Board of Regents concerning the planning, design, and construction of the Museum;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s80r–3/b/1/B","parentIdentifier":"/us/usc/t20/s80r–3/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F1%2FB","sourceRelease":"119-100","text":"advise and assist the Board of Regents on all matters relating to the administration, operation, maintenance, and preservation of the Museum;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s80r–3/b/1/C","parentIdentifier":"/us/usc/t20/s80r–3/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F1%2FC","sourceRelease":"119-100","text":"recommend annual operating budgets for the Museum to the Board of Regents;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s80r–3/b/1/D","parentIdentifier":"/us/usc/t20/s80r–3/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F1%2FD","sourceRelease":"119-100","text":"report annually to the Board of Regents on the acquisition, disposition, and display of objects relating to African American life, art, history, and culture; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s80r–3/b/1/E","parentIdentifier":"/us/usc/t20/s80r–3/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F1%2FE","sourceRelease":"119-100","text":"adopt bylaws for the operation of the Council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Principal responsibilities","label":"2 Principal responsibilities","identifier":"/us/usc/t20/s80r–3/b/2","parentIdentifier":"/us/usc/t20/s80r–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s80r–3/b/2/A","parentIdentifier":"/us/usc/t20/s80r–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F2%2FA","sourceRelease":"119-100","text":"purchase, accept, borrow, and otherwise acquire artifacts for addition to the collections of the Museum;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s80r–3/b/2/B","parentIdentifier":"/us/usc/t20/s80r–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F2%2FB","sourceRelease":"119-100","text":"loan, exchange, sell, and otherwise dispose of any part of the collections of the Museum, but only if the funds generated by that disposition are used for additions to the collections of the Museum; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s80r–3/b/2/C","parentIdentifier":"/us/usc/t20/s80r–3/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s80r–3/b/2/C/i","parentIdentifier":"/us/usc/t20/s80r–3/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F2%2FC%2Fi","sourceRelease":"119-100","text":"the life, art, history, and culture of African Americans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s80r–3/b/2/C/ii","parentIdentifier":"/us/usc/t20/s80r–3/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F2%2FC%2Fii","sourceRelease":"119-100","text":"the role of African Americans in the history of the United States from the period of slavery to the present; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t20/s80r–3/b/2/C/iii","parentIdentifier":"/us/usc/t20/s80r–3/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F2%2FC%2Fiii","sourceRelease":"119-100","text":"the contributions of African Americans to society.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Other responsibilities","label":"3 Other responsibilities","identifier":"/us/usc/t20/s80r–3/b/3","parentIdentifier":"/us/usc/t20/s80r–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s80r–3/b/3/A","parentIdentifier":"/us/usc/t20/s80r–3/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F3%2FA","sourceRelease":"119-100","text":"to provide for preservation, restoration, and maintenance of the collections of the Museum; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s80r–3/b/3/B","parentIdentifier":"/us/usc/t20/s80r–3/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fb%2F3%2FB","sourceRelease":"119-100","text":"to solicit, accept, use, and dispose of gifts, bequests, and devises of personal property for the purpose of aiding and facilitating the work of the Museum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Composition and appointment","label":"c Composition and appointment","identifier":"/us/usc/t20/s80r–3/c","parentIdentifier":"/us/usc/t20/s80r–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t20/s80r–3/c/1","parentIdentifier":"/us/usc/t20/s80r–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fc%2F1","sourceRelease":"119-100","text":"The Council shall be composed of 19 voting members as provided under paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Voting members","label":"2 Voting members","identifier":"/us/usc/t20/s80r–3/c/2","parentIdentifier":"/us/usc/t20/s80r–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s80r–3/c/2/A","parentIdentifier":"/us/usc/t20/s80r–3/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fc%2F2%2FA","sourceRelease":"119-100","text":"The Secretary of the Smithsonian Institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s80r–3/c/2/B","parentIdentifier":"/us/usc/t20/s80r–3/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fc%2F2%2FB","sourceRelease":"119-100","text":"One member of the Board of Regents, appointed by the Board of Regents.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s80r–3/c/2/C","parentIdentifier":"/us/usc/t20/s80r–3/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fc%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s80r–3/c/2/C/i","parentIdentifier":"/us/usc/t20/s80r–3/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fc%2F2%2FC%2Fi","sourceRelease":"119-100","text":"taking into consideration individuals recommended by organizations and entities that are committed to the advancement of knowledge of African American life, art, history, and culture; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s80r–3/c/2/C/ii","parentIdentifier":"/us/usc/t20/s80r–3/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fc%2F2%2FC%2Fii","sourceRelease":"119-100","text":"taking into consideration individuals recommended by the members of the Council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Initial appointments","label":"3 Initial appointments","identifier":"/us/usc/t20/s80r–3/c/3","parentIdentifier":"/us/usc/t20/s80r–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fc%2F3","sourceRelease":"119-100","text":"The Board of Regents shall make initial appointments to the Council under paragraph (2) not later than 180 days after .December 16, 2003","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Terms","label":"d Terms","identifier":"/us/usc/t20/s80r–3/d","parentIdentifier":"/us/usc/t20/s80r–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t20/s80r–3/d/1","parentIdentifier":"/us/usc/t20/s80r–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fd%2F1","sourceRelease":"119-100","text":"Except as provided in this subsection, each appointed member of the Council shall be appointed for a term of 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Initial appointees","label":"2 Initial appointees","identifier":"/us/usc/t20/s80r–3/d/2","parentIdentifier":"/us/usc/t20/s80r–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s80r–3/d/2/A","parentIdentifier":"/us/usc/t20/s80r–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fd%2F2%2FA","sourceRelease":"119-100","text":"six members shall be appointed for a term of 1 year;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s80r–3/d/2/B","parentIdentifier":"/us/usc/t20/s80r–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fd%2F2%2FB","sourceRelease":"119-100","text":"six members shall be appointed for a term of 2 years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s80r–3/d/2/C","parentIdentifier":"/us/usc/t20/s80r–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fd%2F2%2FC","sourceRelease":"119-100","text":"five members shall be appointed for a term of 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Reappointment","label":"3 Reappointment","identifier":"/us/usc/t20/s80r–3/d/3","parentIdentifier":"/us/usc/t20/s80r–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fd%2F3","sourceRelease":"119-100","text":"A member of the Council may be reappointed, except that no individual may serve on the Council for a total of more than 2 terms. For purposes of this paragraph, the number of terms an individual serves on the Council shall not include any portion of a term for which an individual is appointed to fill a vacancy under paragraph (4)(B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Vacancies","label":"4 Vacancies","identifier":"/us/usc/t20/s80r–3/d/4","parentIdentifier":"/us/usc/t20/s80r–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fd%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t20/s80r–3/d/4/A","parentIdentifier":"/us/usc/t20/s80r–3/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fd%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s80r–3/d/4/A/i","parentIdentifier":"/us/usc/t20/s80r–3/d/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fd%2F4%2FA%2Fi","sourceRelease":"119-100","text":"shall not affect the powers of the Council; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s80r–3/d/4/A/ii","parentIdentifier":"/us/usc/t20/s80r–3/d/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fd%2F4%2FA%2Fii","sourceRelease":"119-100","text":"shall be filled in the same manner as the original appointment was made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Term","label":"B Term","identifier":"/us/usc/t20/s80r–3/d/4/B","parentIdentifier":"/us/usc/t20/s80r–3/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fd%2F4%2FB","sourceRelease":"119-100","text":"Any member of the Council appointed to fill a vacancy occurring before the expiration of the term for which the member’s predecessor was appointed shall be appointed for the remainder of that term.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Compensation","label":"e Compensation","identifier":"/us/usc/t20/s80r–3/e","parentIdentifier":"/us/usc/t20/s80r–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t20/s80r–3/e/1","parentIdentifier":"/us/usc/t20/s80r–3/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fe%2F1","sourceRelease":"119-100","text":"Except as provided in paragraph (2), a member of the Council shall serve without pay.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Travel expenses","label":"2 Travel expenses","identifier":"/us/usc/t20/s80r–3/e/2","parentIdentifier":"/us/usc/t20/s80r–3/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fe%2F2","sourceRelease":"119-100","text":"A member of the Council shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for an employee of an agency under subchapter I of chapter 57 of title 5, while away from the home or regular place of business of the member in the performance of the duties of the Council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Chairperson","label":"f Chairperson","identifier":"/us/usc/t20/s80r–3/f","parentIdentifier":"/us/usc/t20/s80r–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Ff","sourceRelease":"119-100","text":"By a majority vote of its voting members, the Council shall elect a chairperson from its members.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Meetings","label":"g Meetings","identifier":"/us/usc/t20/s80r–3/g","parentIdentifier":"/us/usc/t20/s80r–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t20/s80r–3/g/1","parentIdentifier":"/us/usc/t20/s80r–3/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fg%2F1","sourceRelease":"119-100","text":"The Council shall meet at the call of the chairperson or on the written request of a majority of the voting members of the Council, but not fewer than twice each year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Initial meetings","label":"2 Initial meetings","identifier":"/us/usc/t20/s80r–3/g/2","parentIdentifier":"/us/usc/t20/s80r–3/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fg%2F2","sourceRelease":"119-100","text":"During the 1-year period beginning on the date of the first meeting of the Council, the Council shall meet not fewer than 4 times for the purpose of carrying out the duties of the Council under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Quorum","label":"h Quorum","identifier":"/us/usc/t20/s80r–3/h","parentIdentifier":"/us/usc/t20/s80r–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80r%E2%80%933%2Fh","sourceRelease":"119-100","text":"A majority of the voting members of the Council holding office shall constitute a quorum for the purpose of conducting business, but a lesser number may receive information on behalf of the Council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
