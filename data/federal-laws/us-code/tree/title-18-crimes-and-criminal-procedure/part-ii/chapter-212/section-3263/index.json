{"type":"section","nativeType":"section","number":"3263","heading":"Delivery to authorities of foreign countries","label":"3263 Delivery to authorities of foreign countries","identifier":"/us/usc/t18/s3263","parentIdentifier":"/us/usc/t18/ptII/ch212","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3263","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t18/s3263/a","parentIdentifier":"/us/usc/t18/s3263","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3263%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s3263/a/1","parentIdentifier":"/us/usc/t18/s3263/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3263%2Fa%2F1","sourceRelease":"119-100","text":"appropriate authorities of that country request the delivery of the person to such country for trial for such conduct as an offense under the laws of that country; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s3263/a/2","parentIdentifier":"/us/usc/t18/s3263/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3263%2Fa%2F2","sourceRelease":"119-100","text":"the delivery of such person to that country is authorized by a treaty or other international agreement to which the United States is a party.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t18/s3263/b","parentIdentifier":"/us/usc/t18/s3263","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3263%2Fb","sourceRelease":"119-100","text":"The Secretary of Defense, in consultation with the Secretary of State, shall determine which officials of a foreign country constitute appropriate authorities for purposes of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
