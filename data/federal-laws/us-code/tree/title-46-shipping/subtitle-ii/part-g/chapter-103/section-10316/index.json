{"type":"section","nativeType":"section","number":"10316","heading":"Trusts","label":"10316 Trusts","identifier":"/us/usc/t46/s10316","parentIdentifier":"/us/usc/t46/stII/ptG/ch103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10316","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevised sectionSource section (U.S. Code)1031646:599(g)Section 10316 qualifies the two previous sections by allowing an employer to make deductions from seamen’s wages for the purpose of placing the wages into a trust fund or holding them in trust to provide for the seamen’s benefit."],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s10316/1","parentIdentifier":"/us/usc/t46/s10316","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10316%2F1","sourceRelease":"119-100","text":"the deductions are paid into a trust fund established only for the benefit of seamen employed by that employer, and the families and dependents of those seamen (or of those seamen, families, and dependents jointly with other seamen employed by other employers, and the families and dependents of the other seamen); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s10316/2","parentIdentifier":"/us/usc/t46/s10316","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10316%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s10316/2/A","parentIdentifier":"/us/usc/t46/s10316/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10316%2F2%2FA","sourceRelease":"119-100","text":"medical or hospital care, or both.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s10316/2/B","parentIdentifier":"/us/usc/t46/s10316/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10316%2F2%2FB","sourceRelease":"119-100","text":"pensions on retirement or death of the seaman.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t46/s10316/2/C","parentIdentifier":"/us/usc/t46/s10316/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10316%2F2%2FC","sourceRelease":"119-100","text":"life insurance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t46/s10316/2/D","parentIdentifier":"/us/usc/t46/s10316/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10316%2F2%2FD","sourceRelease":"119-100","text":"unemployment benefits.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t46/s10316/2/E","parentIdentifier":"/us/usc/t46/s10316/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10316%2F2%2FE","sourceRelease":"119-100","text":"compensation for illness or injuries resulting from occupational activity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t46/s10316/2/F","parentIdentifier":"/us/usc/t46/s10316/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10316%2F2%2FF","sourceRelease":"119-100","text":"sickness, accident, and disability compensation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t46/s10316/2/G","parentIdentifier":"/us/usc/t46/s10316/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs10316%2F2%2FG","sourceRelease":"119-100","text":"purchasing insurance to provide any of the benefits specified in this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
