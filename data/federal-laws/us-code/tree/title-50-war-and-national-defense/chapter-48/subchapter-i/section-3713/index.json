eDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3713/b/2","parentIdentifier":"/us/usc/t50/s3713/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3713%2Fb%2F2","sourceRelease":"119-100","text":"the Secretary of State and the Secretary of Energy concur with such determination; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s3713/b/3","parentIdentifier":"/us/usc/t50/s3713/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3713%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3713/b/3/A","parentIdentifier":"/us/usc/t50/s3713/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3713%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the determination under paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3713/b/3/B","parentIdentifier":"/us/usc/t50/s3713/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3713%2Fb%2F3%2FB","sourceRelease":"119-100","text":"a description of the covered activities to be carried out using such funds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t50/s3713/b/3/C","parentIdentifier":"/us/usc/t50/s3713/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3713%2Fb%2F3%2FC","sourceRelease":"119-100","text":"the expected time frame for such activities; a