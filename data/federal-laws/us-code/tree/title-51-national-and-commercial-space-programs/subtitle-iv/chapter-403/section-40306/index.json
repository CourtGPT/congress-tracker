":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t51/s40306/a/1/B","parentIdentifier":"/us/usc/t51/s40306/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fa%2F1%2FB","sourceRelease":"119-100","text":"any association or other alliance of 2 or more persons, other than individuals, as a space grant regional consortium.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Space grant college requirements","label":"2 .—Space grant college requirements","identifier":"/us/usc/t51/s40306/a/2","parentIdentifier":"/us/usc/t51/s40306/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t51/s40306/a/2/A","parentIdentifier":"/us/usc/t51/s40306/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fa%2F2%2FA","sourceRelease":"119-100","text":"is maintaining a balanced program of research, education, training, and advisory services in fields related to space;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t51/s40306/a/2/B","parentIdentifier":"/us/usc/t51/s40306/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fa%2F2%2FB","sourceRelease":"119-100","text":"will act in accordance with such guidelines as are prescribed under subsection (b)(2); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t51/s40306/a/2/C","parentIdentifier":"/us/usc/t51/s40306/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fa%2F2%2FC","sourceRelease":"119-100","text":"meets such other qualifications as the Administrator considers necessary or appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Space grant regional consortium requirements","label":"3 .—Space grant regional consortium requirements","identifier":"/us/usc/t51/s40306/a/3","parentIdentifier":"/us/usc/t51/s40306/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t51/s40306/a/3/A","parentIdentifier":"/us/usc/t51/s40306/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fa%2F3%2FA","sourceRelease":"119-100","text":"is established for the purpose of sharing expertise, research, educational facilities or training facilities, and other capabilities in order to facilitate research, education, training, and advisory services in any field related to space;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t51/s40306/a/3/B","parentIdentifier":"/us/usc/t51/s40306/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fa%2F3%2FB","sourceRelease":"119-100","text":"will encourage and follow a regional approach to solving problems or meeting needs relating to space, in cooperation with appropriate space grant colleges, space grant programs, and other persons in the region;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t51/s40306/a/3/C","parentIdentifier":"/us/usc/t51/s40306/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fa%2F3%2FC","sourceRelease":"119-100","text":"will act in accordance with such guidelines as are prescribed under subsection (b)(2); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t51/s40306/a/3/D","parentIdentifier":"/us/usc/t51/s40306/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fa%2F3%2FD","sourceRelease":"119-100","text":"meets such other qualifications as the Administrator considers necessary or appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Qualifications and Guidelines","label":"b .—Qualifications and Guidelines","identifier":"/us/usc/t51/s40306/b","parentIdentifier":"/us/usc/t51/s40306","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t51/s40306/b/1","parentIdentifier":"/us/usc/t51/s40306/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fb%2F1","sourceRelease":"119-100","text":"the qualifications required to be met under paragraphs (2)(C) and (3)(D) of subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t51/s40306/b/2","parentIdentifier":"/us/usc/t51/s40306/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fb%2F2","sourceRelease":"119-100","text":"guidelines relating to the activities and responsibilities of space grant colleges and space grant regional consortia.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Suspension or Termination of Designation","label":"c .—Suspension or Termination of Designation","identifier":"/us/usc/t51/s40306/c","parentIdentifier":"/us/usc/t51/s40306","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs40306%2Fc","sourceRelease":"119-100","text":"The Administrator may, for cause and after an opportunity for hearing, suspend or terminate any designation under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
