{"type":"section","nativeType":"section","number":"2902","heading":"Definitions","label":"2902 Definitions","identifier":"/us/usc/t43/s2902","parentIdentifier":"/us/usc/t43/ch47","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Definition of “Secretary”Secretary means the Secretary of the Interior, see , set out as a note under , Conservation.section 2 of Pub. L. 116–9section 1 of Title 16"],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Conveyed property","label":"1 Conveyed property","identifier":"/us/usc/t43/s2902/1","parentIdentifier":"/us/usc/t43/s2902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F1","sourceRelease":"119-100","text":"The term “conveyed property” means an eligible facility that has been conveyed to a qualifying entity under .section 2903 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible facility","label":"2 Eligible facility","identifier":"/us/usc/t43/s2902/2","parentIdentifier":"/us/usc/t43/s2902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F2","sourceRelease":"119-100","text":"The term “eligible facility” means a facility that meets the criteria for potential transfer established under .section 2904(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Facility","label":"3 Facility","identifier":"/us/usc/t43/s2902/3","parentIdentifier":"/us/usc/t43/s2902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t43/s2902/3/A","parentIdentifier":"/us/usc/t43/s2902/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F3%2FA","sourceRelease":"119-100","text":"The term “facility” includes a dam or appurtenant works, canal, lateral, ditch, gate, control structure, pumping station, other infrastructure, recreational facility, building, distribution and drainage works, and associated land or interest in land or water.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exclusions","label":"B Exclusions","identifier":"/us/usc/t43/s2902/3/B","parentIdentifier":"/us/usc/t43/s2902/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s2902/3/B/i","parentIdentifier":"/us/usc/t43/s2902/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F3%2FB%2Fi","sourceRelease":"119-100","text":"that is a reserved works as of ;March 12, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s2902/3/B/ii","parentIdentifier":"/us/usc/t43/s2902/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F3%2FB%2Fii","sourceRelease":"119-100","text":"that generates hydropower marketed by a Federal power marketing administration; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t43/s2902/3/B/iii","parentIdentifier":"/us/usc/t43/s2902/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"that is managed for recreation under a lease, permit, license, or other management agreement that does contribute to capital repayment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Project use power","label":"4 Project use power","identifier":"/us/usc/t43/s2902/4","parentIdentifier":"/us/usc/t43/s2902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F4","sourceRelease":"119-100","text":"The term “project use power” means the electrical capacity, energy, and associated ancillary service components required to provide the minimum electrical service needed to operate or maintain Reclamation project facilities in accordance with the authorization for the Reclamation project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Qualifying entity","label":"5 Qualifying entity","identifier":"/us/usc/t43/s2902/5","parentIdentifier":"/us/usc/t43/s2902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2902/5/A","parentIdentifier":"/us/usc/t43/s2902/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F5%2FA","sourceRelease":"119-100","text":"as of the date of conveyance under this chapter, is the current operator of the eligible facility pursuant to a contract with Reclamation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2902/5/B","parentIdentifier":"/us/usc/t43/s2902/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F5%2FB","sourceRelease":"119-100","text":"as determined by the Secretary, has the capacity to continue to manage the eligible facility for the same purposes for which the property has been managed under the reclamation laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Reclamation","label":"6 Reclamation","identifier":"/us/usc/t43/s2902/6","parentIdentifier":"/us/usc/t43/s2902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F6","sourceRelease":"119-100","text":"The term “Reclamation” means the Bureau of Reclamation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Reclamation project","label":"7 Reclamation project","identifier":"/us/usc/t43/s2902/7","parentIdentifier":"/us/usc/t43/s2902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2902/7/A","parentIdentifier":"/us/usc/t43/s2902/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F7%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s2902/7/A/i","parentIdentifier":"/us/usc/t43/s2902/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F7%2FA%2Fi","sourceRelease":"119-100","text":"that is authorized by the reclamation laws;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s2902/7/A/ii","parentIdentifier":"/us/usc/t43/s2902/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F7%2FA%2Fii","sourceRelease":"119-100","text":"that is constructed by the United States pursuant to the reclamation laws; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t43/s2902/7/A/iii","parentIdentifier":"/us/usc/t43/s2902/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F7%2FA%2Fiii","sourceRelease":"119-100","text":"in connection with which there is a repayment or water service contract executed by the United States pursuant to the reclamation laws; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2902/7/B","parentIdentifier":"/us/usc/t43/s2902/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F7%2FB","sourceRelease":"119-100","text":"any project constructed by the Secretary for the reclamation of land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Reserved works","label":"8 Reserved works","identifier":"/us/usc/t43/s2902/8","parentIdentifier":"/us/usc/t43/s2902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2902/8/A","parentIdentifier":"/us/usc/t43/s2902/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F8%2FA","sourceRelease":"119-100","text":"that is owned by the Bureau; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2902/8/B","parentIdentifier":"/us/usc/t43/s2902/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F8%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s2902/8/B/i","parentIdentifier":"/us/usc/t43/s2902/8/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F8%2FB%2Fi","sourceRelease":"119-100","text":"by an employee of the Bureau; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s2902/8/B/ii","parentIdentifier":"/us/usc/t43/s2902/8/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F8%2FB%2Fii","sourceRelease":"119-100","text":"through a contract entered into by the Commissioner.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":"Secretary","label":"9 Secretary","identifier":"/us/usc/t43/s2902/9","parentIdentifier":"/us/usc/t43/s2902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2902%2F9","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary, acting through the Commissioner of Reclamation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
