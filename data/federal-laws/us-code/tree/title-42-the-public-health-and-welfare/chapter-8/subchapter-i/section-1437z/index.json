{"type":"section","nativeType":"section","number":"1437z","heading":"Exchange of information with law enforcement agencies","label":"1437z Exchange of information with law enforcement agencies","identifier":"/us/usc/t42/s1437z","parentIdentifier":"/us/usc/t42/ch8/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437z","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s1437z/1","parentIdentifier":"/us/usc/t42/s1437z","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437z%2F1","sourceRelease":"119-100","text":"furnishes the public housing agency with the name of the recipient; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s1437z/2","parentIdentifier":"/us/usc/t42/s1437z","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437z%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s1437z/2/A","parentIdentifier":"/us/usc/t42/s1437z/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437z%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s1437z/2/A/i","parentIdentifier":"/us/usc/t42/s1437z/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437z%2F2%2FA%2Fi","sourceRelease":"119-100","text":"is fleeing to avoid prosecution, or custody or confinement after conviction, under the laws of the place from which the individual flees, for a crime, or attempt to commit a crime, which is a felony under the laws of the place from which the individual flees, or which, in the case of the State of New Jersey, is a high misdemeanor under the laws of such State; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s1437z/2/A/ii","parentIdentifier":"/us/usc/t42/s1437z/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437z%2F2%2FA%2Fii","sourceRelease":"119-100","text":"is violating a condition of probation or parole imposed under Federal or State law; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s1437z/2/A/iii","parentIdentifier":"/us/usc/t42/s1437z/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437z%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"has information that is necessary for the officer to conduct the officer’s official duties;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s1437z/2/B","parentIdentifier":"/us/usc/t42/s1437z/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437z%2F2%2FB","sourceRelease":"119-100","text":"the location or apprehension of the recipient is within such officer’s official duties; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s1437z/2/C","parentIdentifier":"/us/usc/t42/s1437z/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437z%2F2%2FC","sourceRelease":"119-100","text":"the request is made in the proper exercise of the officer’s official duties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
