{"type":"section","nativeType":"section","number":"11112","heading":"Standards for professional review actions","label":"11112 Standards for professional review actions","identifier":"/us/usc/t42/s11112","parentIdentifier":"/us/usc/t42/ch117/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s11112/a","parentIdentifier":"/us/usc/t42/s11112","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s11112/a/1","parentIdentifier":"/us/usc/t42/s11112/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fa%2F1","sourceRelease":"119-100","text":"in the reasonable belief that the action was in the furtherance of quality health care,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s11112/a/2","parentIdentifier":"/us/usc/t42/s11112/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fa%2F2","sourceRelease":"119-100","text":"after a reasonable effort to obtain the facts of the matter,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s11112/a/3","parentIdentifier":"/us/usc/t42/s11112/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fa%2F3","sourceRelease":"119-100","text":"after adequate notice and hearing procedures are afforded to the physician involved or after such other procedures as are fair to the physician under the circumstances, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s11112/a/4","parentIdentifier":"/us/usc/t42/s11112/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fa%2F4","sourceRelease":"119-100","text":"in the reasonable belief that the action was warranted by the facts known after such reasonable effort to obtain facts and after meeting the requirement of paragraph (3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Adequate notice and hearing","label":"b Adequate notice and hearing","identifier":"/us/usc/t42/s11112/b","parentIdentifier":"/us/usc/t42/s11112","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Notice of proposed action","label":"1 Notice of proposed action","identifier":"/us/usc/t42/s11112/b/1","parentIdentifier":"/us/usc/t42/s11112/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s11112/b/1/A","parentIdentifier":"/us/usc/t42/s11112/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s11112/b/1/A/i","parentIdentifier":"/us/usc/t42/s11112/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"that a professional review action has been proposed to be taken against the physician,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s11112/b/1/A/ii","parentIdentifier":"/us/usc/t42/s11112/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"reasons for the proposed action,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s11112/b/1/B","parentIdentifier":"/us/usc/t42/s11112/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s11112/b/1/B/i","parentIdentifier":"/us/usc/t42/s11112/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"that the physician has the right to request a hearing on the proposed action,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s11112/b/1/B/ii","parentIdentifier":"/us/usc/t42/s11112/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"any time limit (of not less than 30 days) within which to request such a hearing, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s11112/b/1/C","parentIdentifier":"/us/usc/t42/s11112/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F1%2FC","sourceRelease":"119-100","text":"a summary of the rights in the hearing under paragraph (3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Notice of hearing","label":"2 Notice of hearing","identifier":"/us/usc/t42/s11112/b/2","parentIdentifier":"/us/usc/t42/s11112/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s11112/b/2/A","parentIdentifier":"/us/usc/t42/s11112/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the place, time, and date, of the hearing, which date shall not be less than 30 days after the date of the notice, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s11112/b/2/B","parentIdentifier":"/us/usc/t42/s11112/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F2%2FB","sourceRelease":"119-100","text":"a list of the witnesses (if any) expected to testify at the hearing on behalf of the professional review body.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Conduct of hearing and notice","label":"3 Conduct of hearing and notice","identifier":"/us/usc/t42/s11112/b/3","parentIdentifier":"/us/usc/t42/s11112/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s11112/b/3/A","parentIdentifier":"/us/usc/t42/s11112/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s11112/b/3/A/i","parentIdentifier":"/us/usc/t42/s11112/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FA%2Fi","sourceRelease":"119-100","text":"before an arbitrator mutually acceptable to the physician and the health care entity,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s11112/b/3/A/ii","parentIdentifier":"/us/usc/t42/s11112/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FA%2Fii","sourceRelease":"119-100","text":"before a hearing officer who is appointed by the entity and who is not in direct economic competition with the physician involved, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s11112/b/3/A/iii","parentIdentifier":"/us/usc/t42/s11112/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"before a panel of individuals who are appointed by the entity and are not in direct economic competition with the physician involved;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s11112/b/3/B","parentIdentifier":"/us/usc/t42/s11112/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FB","sourceRelease":"119-100","text":"the right to the hearing may be forfeited if the physician fails, without good cause, to appear;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s11112/b/3/C","parentIdentifier":"/us/usc/t42/s11112/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s11112/b/3/C/i","parentIdentifier":"/us/usc/t42/s11112/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FC%2Fi","sourceRelease":"119-100","text":"to representation by an attorney or other person of the physician’s choice,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s11112/b/3/C/ii","parentIdentifier":"/us/usc/t42/s11112/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FC%2Fii","sourceRelease":"119-100","text":"to have a record made of the proceedings, copies of which may be obtained by the physician upon payment of any reasonable charges associated with the preparation thereof,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s11112/b/3/C/iii","parentIdentifier":"/us/usc/t42/s11112/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FC%2Fiii","sourceRelease":"119-100","text":"to call, examine, and cross-examine witnesses,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s11112/b/3/C/iv","parentIdentifier":"/us/usc/t42/s11112/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FC%2Fiv","sourceRelease":"119-100","text":"to present evidence determined to be relevant by the hearing officer, regardless of its admissibility in a court of law, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s11112/b/3/C/v","parentIdentifier":"/us/usc/t42/s11112/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FC%2Fv","sourceRelease":"119-100","text":"to submit a written statement at the close of the hearing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s11112/b/3/D","parentIdentifier":"/us/usc/t42/s11112/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s11112/b/3/D/i","parentIdentifier":"/us/usc/t42/s11112/b/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FD%2Fi","sourceRelease":"119-100","text":"to receive the written recommendation of the arbitrator, officer, or panel, including a statement of the basis for the recommendations, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s11112/b/3/D/ii","parentIdentifier":"/us/usc/t42/s11112/b/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fb%2F3%2FD%2Fii","sourceRelease":"119-100","text":"to receive a written decision of the health care entity, including a statement of the basis for the decision.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Adequate procedures in investigations or health emergencies","label":"c Adequate procedures in investigations or health emergencies","identifier":"/us/usc/t42/s11112/c","parentIdentifier":"/us/usc/t42/s11112","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s11112/c/1","parentIdentifier":"/us/usc/t42/s11112/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s11112/c/1/A","parentIdentifier":"/us/usc/t42/s11112/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fc%2F1%2FA","sourceRelease":"119-100","text":"where there is no adverse professional review action taken, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s11112/c/1/B","parentIdentifier":"/us/usc/t42/s11112/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fc%2F1%2FB","sourceRelease":"119-100","text":"in the case of a suspension or restriction of clinical privileges, for a period of not longer than 14 days, during which an investigation is being conducted to determine the need for a professional review action; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s11112/c/2","parentIdentifier":"/us/usc/t42/s11112/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11112%2Fc%2F2","sourceRelease":"119-100","text":"precluding an immediate suspension or restriction of clinical privileges, subject to subsequent notice and hearing or other adequate procedures, where the failure to take such an action may result in an imminent danger to the health of any individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
