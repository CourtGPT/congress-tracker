{"type":"section","nativeType":"section","number":"51301","heading":"Definitions","label":"51301 Definitions","identifier":"/us/usc/t51/s51301","parentIdentifier":"/us/usc/t51/stV/ch513","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs51301","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Asteroid resource","label":"1 .—Asteroid resource","identifier":"/us/usc/t51/s51301/1","parentIdentifier":"/us/usc/t51/s51301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs51301%2F1","sourceRelease":"119-100","text":"The term “asteroid resource” means a space resource found on or within a single asteroid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Space resource.—","label":"2 Space resource.—","identifier":"/us/usc/t51/s51301/2","parentIdentifier":"/us/usc/t51/s51301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs51301%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t51/s51301/2/A","parentIdentifier":"/us/usc/t51/s51301/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs51301%2F2%2FA","sourceRelease":"119-100","text":"The term “space resource” means an abiotic resource in situ in outer space.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Inclusions","label":"B .—Inclusions","identifier":"/us/usc/t51/s51301/2/B","parentIdentifier":"/us/usc/t51/s51301/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs51301%2F2%2FB","sourceRelease":"119-100","text":"The term “space resource” includes water and minerals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—United states citizen","label":"3 .—United states citizen","identifier":"/us/usc/t51/s51301/3","parentIdentifier":"/us/usc/t51/s51301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft51%2Fs51301%2F3","sourceRelease":"119-100","text":"The term “United States citizen” has the meaning given the term “citizen of the United States” in section 50902.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
