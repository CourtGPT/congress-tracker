{"type":"section","nativeType":"section","number":"6521a","heading":"Organic agricultural product imports interagency working group","label":"6521a Organic agricultural product imports interagency working group","identifier":"/us/usc/t7/s6521a","parentIdentifier":"/us/usc/t7/ch94","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Trade Savings Provision, , , provided that:Pub. L. 115–334, title X, § 10104(k)132 Stat. 4905Dec. 20, 2018“The amendments made by subsection (i) [enacting this section] shall be carried out in a manner consistent with United States obligations under international agreements.”"],"amendments":["Trade Savings Provision, , , provided that:Pub. L. 115–334, title X, § 10104(k)132 Stat. 4905Dec. 20, 2018“The amendments made by subsection (i) [enacting this section] shall be carried out in a manner consistent with United States obligations under international agreements.”"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t7/s6521a/a","parentIdentifier":"/us/usc/t7/s6521a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s6521a/a/1","parentIdentifier":"/us/usc/t7/s6521a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary and the Secretary of Homeland Security shall jointly establish a working group to facilitate coordination and information sharing between the Department of Agriculture and U.S. Customs and Border Protection relating to imports of organically produced agricultural products (referred to in this section as the “working group”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Members","label":"2 Members","identifier":"/us/usc/t7/s6521a/a/2","parentIdentifier":"/us/usc/t7/s6521a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6521a/a/2/A","parentIdentifier":"/us/usc/t7/s6521a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6521a/a/2/A/i","parentIdentifier":"/us/usc/t7/s6521a/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the Secretary (or a designee); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6521a/a/2/A/ii","parentIdentifier":"/us/usc/t7/s6521a/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the Secretary of Homeland Security (or a designee); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6521a/a/2/B","parentIdentifier":"/us/usc/t7/s6521a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa%2F2%2FB","sourceRelease":"119-100","text":"shall not include any non-Federal officer or employee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Duties","label":"3 Duties","identifier":"/us/usc/t7/s6521a/a/3","parentIdentifier":"/us/usc/t7/s6521a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6521a/a/3/A","parentIdentifier":"/us/usc/t7/s6521a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa%2F3%2FA","sourceRelease":"119-100","text":"identifying imports of organically produced agricultural products;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6521a/a/3/B","parentIdentifier":"/us/usc/t7/s6521a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa%2F3%2FB","sourceRelease":"119-100","text":"verifying the authenticity of organically produced agricultural product import documentation, such as national organic program import certificates;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s6521a/a/3/C","parentIdentifier":"/us/usc/t7/s6521a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa%2F3%2FC","sourceRelease":"119-100","text":"ensuring imported agricultural products represented as organically produced meet the requirements under this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s6521a/a/3/D","parentIdentifier":"/us/usc/t7/s6521a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa%2F3%2FD","sourceRelease":"119-100","text":"collecting and organizing quantitative data on imports of organically produced agricultural products; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s6521a/a/3/E","parentIdentifier":"/us/usc/t7/s6521a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa%2F3%2FE","sourceRelease":"119-100","text":"requesting feedback from stakeholders on how to improve the oversight of imports of organically produced agricultural products.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Designated employees and officials","label":"4 Designated employees and officials","identifier":"/us/usc/t7/s6521a/a/4","parentIdentifier":"/us/usc/t7/s6521a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fa%2F4","sourceRelease":"119-100","text":"An employee or official designated to carry out the duties of the Secretary or the Secretary of Homeland Security on the working group under subparagraph (A) or (B) of paragraph (2) shall be an employee or official compensated at a rate of pay not less than the minimum annual rate of basic pay for GS–12 under .section 5332 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Reports","label":"b Reports","identifier":"/us/usc/t7/s6521a/b","parentIdentifier":"/us/usc/t7/s6521a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","numb