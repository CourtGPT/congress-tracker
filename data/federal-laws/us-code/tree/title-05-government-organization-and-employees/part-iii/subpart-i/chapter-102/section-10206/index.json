{"type":"section","nativeType":"section","number":"10206","heading":"Technician positions","label":"10206 Technician positions","identifier":"/us/usc/t5/s10206","parentIdentifier":"/us/usc/t5/ptIII/sptI/ch102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10206","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on first day of first pay period which begins after , see , set out as an Effective Date of 2010 Amendment note under .Oct. 15, 2010section 5 of Pub. L. 111–282section 5102 of this title"],"amendments":["Effective DateSection effective on first day of first pay period which begins after , see , set out as an Effective Date of 2010 Amendment note under .Oct. 15, 2010section 5 of Pub. L. 111–282section 5102 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t5/s10206/a","parentIdentifier":"/us/usc/t5/s10206","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10206%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s10206/a/1","parentIdentifier":"/us/usc/t5/s10206/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10206%2Fa%2F1","sourceRelease":"119-100","text":"Each member whose position is determined under section 10202(a)(3) to be included as a technician position shall, on or after such date, receive, in addition to the member’s scheduled rate of basic pay, an amount equal to 6 percent of the sum of such member’s rate of basic pay and the applicable locality-based comparability payment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s10206/a/2","parentIdentifier":"/us/usc/t5/s10206/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10206%2Fa%2F2","sourceRelease":"119-100","text":"A member described in this subsection shall receive the additional compensation authorized by this subsection until such time as the member’s position is determined under section 10202(a)(3) not to be a technician position, or until the member no longer occupies such position, whichever occurs first.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s10206/a/3","parentIdentifier":"/us/usc/t5/s10206/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10206%2Fa%2F3","sourceRelease":"119-100","text":"The additional compensation authorized by this subsection shall be paid to a member in the same manner and at the same time as the member’s basic pay is paid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Exceptions","label":"b .—Exceptions","identifier":"/us/usc/t5/s10206/b","parentIdentifier":"/us/usc/t5/s10206","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10206%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s10206/b/1","parentIdentifier":"/us/usc/t5/s10206/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10206%2Fb%2F1","sourceRelease":"119-100","text":"Except as provided in paragraph (2), the additional compensation authorized by subsection (a)(1) shall be considered as basic pay for all purposes, including section 8401(4).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s10206/b/2","parentIdentifier":"/us/usc/t5/s10206/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10206%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s10206/b/2/A","parentIdentifier":"/us/usc/t5/s10206/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10206%2Fb%2F2%2FA","sourceRelease":"119-100","text":"section 5304; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s10206/b/2/B","parentIdentifier":"/us/usc/t5/s10206/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10206%2Fb%2F2%2FB","sourceRelease":"119-100","text":"section 7511(a)(4).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s10206/b/3","parentIdentifier":"/us/usc/t5/s10206/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10206%2Fb%2F3","sourceRelease":"119-100","text":"The loss of the additional compensation authorized by subsection (a)(1) shall not constitute an adverse action for the purposes of section 7512.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
