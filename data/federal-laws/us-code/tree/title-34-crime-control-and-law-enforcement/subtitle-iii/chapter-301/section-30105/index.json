[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s30105/a/1/B","parentIdentifier":"/us/usc/t34/s30105/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs30105%2Fa%2F1%2FB","sourceRelease":"119-100","text":"$10,000,000 to the Attorney General for the Criminal Division of the Department of Justice.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Availability","label":"2 Availability","identifier":"/us/usc/t34/s30105/a/2","parentIdentifier":"/us/usc/t34/s30105/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs30105%2Fa%2F2","sourceRelease":"119-100","text":"Any amounts appropriated under paragraph (1) shall remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Use of additional funding","label":"b Use of additional funding","identifier":"/us/usc/t34/s30105/b","parentIdentifier":"/us/usc/t34/s30105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs30105%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s30105/b/1","parentIdentifier":"/us/usc/t34/s30105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs30105%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s30105/b/1/A","parentIdentifier":"/us/usc/t34/s30105/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs30105%2Fb%2F1%2FA","sourceRelease":"119-100"