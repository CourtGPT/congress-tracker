<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.courtgpt.congress-sync</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/d/Library/Application Support/CourtGPT/congress-tracker-sync/repo/scripts/run-local-sync.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/d/Library/Application Support/CourtGPT/congress-tracker-sync/repo</string>
