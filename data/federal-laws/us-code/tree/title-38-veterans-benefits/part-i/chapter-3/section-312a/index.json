{"type":"section","nativeType":"section","number":"312A","heading":"Director of Construction and Facilities Management","label":"312A Director of Construction and Facilities Management","identifier":"/us/usc/t38/s312A","parentIdentifier":"/us/usc/t38/ptI/ch3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t38/s312A/a","parentIdentifier":"/us/usc/t38/s312A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s312A/a/1","parentIdentifier":"/us/usc/t38/s312A/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fa%2F1","sourceRelease":"119-100","text":"There is in the Department a Director of Construction and Facilities Management, who shall be appointed by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s312A/a/2","parentIdentifier":"/us/usc/t38/s312A/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fa%2F2","sourceRelease":"119-100","text":"The position of Director of Construction and Facilities Management is a career reserved position, as such term is defined in .section 3132(a)(8) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s312A/a/3","parentIdentifier":"/us/usc/t38/s312A/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fa%2F3","sourceRelease":"119-100","text":"The Director shall provide direct support to the Secretary in matters covered by the responsibilities of the Director under subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s312A/a/4","parentIdentifier":"/us/usc/t38/s312A/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fa%2F4","sourceRelease":"119-100","text":"The Director shall report to the Deputy Secretary in the discharge of the responsibilities of the Director under subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Qualifications","label":"b .—Qualifications","identifier":"/us/usc/t38/s312A/b","parentIdentifier":"/us/usc/t38/s312A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s312A/b/1","parentIdentifier":"/us/usc/t38/s312A/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fb%2F1","sourceRelease":"119-100","text":"holds an undergraduate or master’s degree in architectural design or engineering; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s312A/b/2","parentIdentifier":"/us/usc/t38/s312A/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fb%2F2","sourceRelease":"119-100","text":"has substantive professional experience in the area of construction project management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Responsibilities","label":"c .—Responsibilities","identifier":"/us/usc/t38/s312A/c","parentIdentifier":"/us/usc/t38/s312A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s312A/c/1","parentIdentifier":"/us/usc/t38/s312A/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s312A/c/1/A","parentIdentifier":"/us/usc/t38/s312A/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fc%2F1%2FA","sourceRelease":"119-100","text":"be responsible for overseeing and managing the planning, design, construction, and operation of facilities and infrastructure of the Department, including major and minor construction projects; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s312A/c/1/B","parentIdentifier":"/us/usc/t38/s312A/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fc%2F1%2FB","sourceRelease":"119-100","text":"perform such other functions as the Secretary shall prescribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s312A/c/2","parentIdentifier":"/us/usc/t38/s312A/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s312A/c/2/A","parentIdentifier":"/us/usc/t38/s312A/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fc%2F2%2FA","sourceRelease":"119-100","text":"Development and updating of short-range and long-range strategic capital investment strategies and plans of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s312A/c/2/B","parentIdentifier":"/us/usc/t38/s312A/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fc%2F2%2FB","sourceRelease":"119-100","text":"Planning, design, and construction of facilities for the Department, including determining architectural and engineering requirements and ensuring compliance of the Department with applicable laws relating to the construction program of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s312A/c/2/C","parentIdentifier":"/us/usc/t38/s312A/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fc%2F2%2FC","sourceRelease":"119-100","text":"Management of the short-term and long-term leasing of real property by the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t38/s312A/c/2/D","parentIdentifier":"/us/usc/t38/s312A/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fc%2F2%2FD","sourceRelease":"119-100","text":"Repair and maintenance of facilities of the Department, including custodial services, building management and administration, and maintenance of roads, grounds, and infrastructure.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t38/s312A/c/2/E","parentIdentifier":"/us/usc/t38/s312A/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs312A%2Fc%2F2%2FE","sourceRelease":"119-100","text":"Management of procurement and acquisition processes relating to the construction and operation of facilities of the Department, including the award of contracts related to design, construction, furnishing, and supplies and equipment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
