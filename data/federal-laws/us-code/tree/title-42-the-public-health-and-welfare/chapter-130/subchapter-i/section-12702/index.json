{"type":"section","nativeType":"section","number":"12702","heading":"Objective of national housing policy","label":"12702 Objective of national housing policy","identifier":"/us/usc/t42/s12702","parentIdentifier":"/us/usc/t42/ch130/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12702","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s12702/1","parentIdentifier":"/us/usc/t42/s12702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12702%2F1","sourceRelease":"119-100","text":"to ensure that every resident of the United States has access to decent shelter or assistance in avoiding homelessness;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s12702/2","parentIdentifier":"/us/usc/t42/s12702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12702%2F2","sourceRelease":"119-100","text":"to increase the Nation’s supply of decent housing that is affordable to low-income and moderate-income families and accessible to job opportunities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s12702/3","parentIdentifier":"/us/usc/t42/s12702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12702%2F3","sourceRelease":"119-100","text":"to improve housing opportunities for all residents of the United States, particularly members of disadvantaged minorities, on a nondiscriminatory basis;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s12702/4","parentIdentifier":"/us/usc/t42/s12702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12702%2F4","sourceRelease":"119-100","text":"to help make neighborhoods safe and livable;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s12702/5","parentIdentifier":"/us/usc/t42/s12702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12702%2F5","sourceRelease":"119-100","text":"to expand opportunities for homeownership;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s12702/6","parentIdentifier":"/us/usc/t42/s12702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12702%2F6","sourceRelease":"119-100","text":"to provide every American community with a reliable, readily available supply of mortgage finance at the lowest possible interest rates; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s12702/7","parentIdentifier":"/us/usc/t42/s12702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12702%2F7","sourceRelease":"119-100","text":"to encourage tenant empowerment and reduce generational poverty in federally assisted and public housing by improving the means by which self-sufficiency may be achieved.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
