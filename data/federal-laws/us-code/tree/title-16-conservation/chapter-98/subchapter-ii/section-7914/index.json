raph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s7914/b/3/C","parentIdentifier":"/us/usc/t16/s7914/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7914%2Fb%2F3%2FC","sourceRelease":"119-100","text":"a primitive or semiprimitive area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s7914/b/4","parentIdentifier":"/us/usc/t16/s7914/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7914%2Fb%2F4","sourceRelease":"119-100","text":"a national monument, national volcanic monument, or national scenic area; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s7914/b/5","parentIdentifier":"/us/usc/t16/s7914/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7914%2Fb%2F5","sourceRelease":"119-100","text":"a component of the National Wild and Scenic Rivers System (including areas designated for study for potential addition to the National Wild and Scenic Rivers System).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
