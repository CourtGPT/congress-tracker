{"type":"section","nativeType":"section","number":"244d","heading":"Promoting student access to AEDs and CPR","label":"244d Promoting student access to AEDs and CPR","identifier":"/us/usc/t42/s244d","parentIdentifier":"/us/usc/t42/ch6A/schII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s244d/a","parentIdentifier":"/us/usc/t42/s244d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fa","sourceRelease":"119-100","text":"The Secretary may award grants to eligible entities to develop and implement a comprehensive program to promote student access to automated external defibrillators (in this section referred to as “AEDs”) and cardiopulmonary resuscitation (in this section referred to as “CPR”) in public elementary schools and secondary schools.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Use of funds","label":"b Use of funds","identifier":"/us/usc/t42/s244d/b","parentIdentifier":"/us/usc/t42/s244d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s244d/b/1","parentIdentifier":"/us/usc/t42/s244d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fb%2F1","sourceRelease":"119-100","text":"Developing and providing comprehensive materials to establish AED and CPR programs in public elementary schools and secondary schools.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s244d/b/2","parentIdentifier":"/us/usc/t42/s244d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fb%2F2","sourceRelease":"119-100","text":"Providing support for CPR and AED training programs in such schools for students, staff, and related sports volunteers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s244d/b/3","parentIdentifier":"/us/usc/t42/s244d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fb%2F3","sourceRelease":"119-100","text":"Providing support for developing a cardiac emergency response plan within such schools.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s244d/b/4","parentIdentifier":"/us/usc/t42/s244d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fb%2F4","sourceRelease":"119-100","text":"Purchasing AEDs that have been approved under , cleared under section 360(k) of such title, or classified under section 360c(f)(2) of such title.section 360e of title 21","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s244d/b/5","parentIdentifier":"/us/usc/t42/s244d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fb%2F5","sourceRelease":"119-100","text":"Purchasing necessary AED batteries and performing necessary AED maintenance (such as by replacing AED pads) in accordance with the labeling of the AED involved.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s244d/b/6","parentIdentifier":"/us/usc/t42/s244d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fb%2F6","sourceRelease":"119-100","text":"Replacing old and outdated AED and CPR equipment, machinery, and educational materials.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Eligibility; application","label":"c Eligibility; application","identifier":"/us/usc/t42/s244d/c","parentIdentifier":"/us/usc/t42/s244d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s244d/c/1","parentIdentifier":"/us/usc/t42/s244d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fc%2F1","sourceRelease":"119-100","text":"be a local educational agency (including a public charter school operating as a local educational agency under State law), in consultation with a qualified health care entity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s244d/c/2","parentIdentifier":"/us/usc/t42/s244d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fc%2F2","sourceRelease":"119-100","text":"submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may reasonably require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definitions","label":"d Definitions","identifier":"/us/usc/t42/s244d/d","parentIdentifier":"/us/usc/t42/s244d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"ESEA terms","label":"1 ESEA terms","identifier":"/us/usc/t42/s244d/d/1","parentIdentifier":"/us/usc/t42/s244d/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fd%2F1","sourceRelease":"119-100","text":"The terms “elementary school”, “local educational agency”, and “secondary school” have the meanings given such terms in .section 7801 of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Qualified health care entity","label":"2 Qualified health care entity","identifier":"/us/usc/t42/s244d/d/2","parentIdentifier":"/us/usc/t42/s244d/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s244d/d/2/A","parentIdentifier":"/us/usc/t42/s244d/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s244d/d/2/A/i","parentIdentifier":"/us/usc/t42/s244d/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":"a public entity; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s244d/d/2/A/ii","parentIdentifier":"/us/usc/t42/s244d/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":"an organization that is described in and exempt from taxation under section 501(a) of such title;section 501(c) of title 26","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s244d/d/2/B","parentIdentifier":"/us/usc/t42/s244d/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fd%2F2%2FB","sourceRelease":"119-100","text":"demonstrates an ability to develop, train, and implement a comprehensive program to promote student access to defibrillation in public elementary and secondary schools; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s244d/d/2/C","parentIdentifier":"/us/usc/t42/s244d/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244d%2Fd%2F2%2FC","sourceRelease":"119-100","text":"is qualified in providing technical assistance in AED and CPR training.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
