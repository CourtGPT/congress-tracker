{"type":"section","nativeType":"section","number":"5901","heading":"Definitions","label":"5901 Definitions","identifier":"/us/usc/t25/s5901","parentIdentifier":"/us/usc/t25/ch51","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5901","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Short Title, , , provided that:Pub. L. 119–88, § 1140 Stat. 812May 4, 2026“This Act [enacting this chapter] may be cited as the ‘Tribal Trust Land Homeownership Act of 2025’.”"],"amendments":["Short Title, , , provided that:Pub. L. 119–88, § 1140 Stat. 812May 4, 2026“This Act [enacting this chapter] may be cited as the ‘Tribal Trust Land Homeownership Act of 2025’.”"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Applicable Bureau office","label":"1 Applicable Bureau office","identifier":"/us/usc/t25/s5901/1","parentIdentifier":"/us/usc/t25/s5901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5901%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s5901/1/A","parentIdentifier":"/us/usc/t25/s5901/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5901%2F1%2FA","sourceRelease":"119-100","text":"a Regional office of the Bureau;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s5901/1/B","parentIdentifier":"/us/usc/t25/s5901/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5901%2F1%2FB","sourceRelease":"119-100","text":"an Agency office of the Bureau; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"