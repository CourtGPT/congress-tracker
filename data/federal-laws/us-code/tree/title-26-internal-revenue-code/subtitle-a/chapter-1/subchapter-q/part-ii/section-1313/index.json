","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Taxpayer","label":"b Taxpayer","identifier":"/us/usc/t26/s1313/b","parentIdentifier":"/us/usc/t26/s1313","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1313%2Fb","sourceRelease":"119-100","text":"Notwithstanding section 7701(a)(14), the term “taxpayer” means any person subject to a tax under the applicable revenue law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Related taxpayer","label":"c Related taxpayer","identifier":"/us/usc/t26/s1313/c","parentIdentifier":"/us/usc/t26/s1313","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1313%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s1313/c/1","parentIdentifier":"/us/usc/t26/s1313/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1313%2Fc%2F1","sourceRelease":"119-100","text":"husband and wife,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s1313/c/2","parentIdentifier":"/us/usc/t26/s1313/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1313%2Fc%2F2","sourceRelease":"119-100","text":"grantor and fiduciary,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t26/s1313/c/3","parentIdentifier":"/us/usc/t26/s1313/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1313%2Fc%2F3","sourceRelease":"119-100","text":"grantor and beneficiary,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t26/s1313/c/4","parentIdentifier":"/us/usc/t26/s1313/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1313%2Fc%2F4","sourceRelease":"119-100","text":"fiduciary and beneficiary, legatee, or heir,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t26/s1313/c/5","parentIdentifier":"/us/usc/t26/s1313/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1313%2Fc%2F5","sourceRelease":"119-100","text":"decedent and decedent’s estate,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t26/s1313/c/6","parentIdentifier":"/us/usc/t26/s1313/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1313%2Fc%2F6","sourceRelease":"119-100","text":"partner, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t26/s1313/c/7","parentIdentifier":"/us/usc/t26/s1313/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1313%2Fc%2F7","sourceRelease":"119-100","text":"member of an affiliated group of corporations (as defined in section 1504).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
