{"type":"section","nativeType":"section","number":"460l–6c","heading":"Admission, entrance, and recreation fees","label":"460l–6c Admission, entrance, and recreation fees","identifier":"/us/usc/t16/s460l–6c","parentIdentifier":"/us/usc/t16/ch1/schLXIX/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Agricultural Reconciliation Act of 1993 and as part of the Omnibus Budget Reconciliation Act of 1993, and not as part of the Land and Water Conservation Fund Act of 1965."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t16/s460l–6c/a","parentIdentifier":"/us/usc/t16/s460l–6c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Area of concentrated public use","label":"1 Area of concentrated public use","identifier":"/us/usc/t16/s460l–6c/a/1","parentIdentifier":"/us/usc/t16/s460l–6c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460l–6c/a/1/A","parentIdentifier":"/us/usc/t16/s460l–6c/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F1%2FA","sourceRelease":"119-100","text":"The area is managed primarily for outdoor recreation purposes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460l–6c/a/1/B","parentIdentifier":"/us/usc/t16/s460l–6c/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F1%2FB","sourceRelease":"119-100","text":"Facilities and services necessary to accommodate heavy public use are provided in the area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s460l–6c/a/1/C","parentIdentifier":"/us/usc/t16/s460l–6c/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F1%2FC","sourceRelease":"119-100","text":"The area contains at least 1 major recreation attraction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s460l–6c/a/1/D","parentIdentifier":"/us/usc/t16/s460l–6c/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F1%2FD","sourceRelease":"119-100","text":"Public access to the area is provided in such a manner that admission fees can be efficiently collected at 1 or more centralized locations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Boat launching facility","label":"2 Boat launching facility","identifier":"/us/usc/t16/s460l–6c/a/2","parentIdentifier":"/us/usc/t16/s460l–6c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F2","sourceRelease":"119-100","text":"The term “boat launching facility” includes any boat launching facility, regardless of whether specialized facilities or services, such as mechanical or hydraulic boat lifts or facilities, are provided.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Campground","label":"3 Campground","identifier":"/us/usc/t16/s460l–6c/a/3","parentIdentifier":"/us/usc/t16/s460l–6c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460l–6c/a/3/A","parentIdentifier":"/us/usc/t16/s460l–6c/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F3%2FA","sourceRelease":"119-100","text":"Tent or trailer spaces.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460l–6c/a/3/B","parentIdentifier":"/us/usc/t16/s460l–6c/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F3%2FB","sourceRelease":"119-100","text":"Drinking water.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s460l–6c/a/3/C","parentIdentifier":"/us/usc/t16/s460l–6c/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F3%2FC","sourceRelease":"119-100","text":"An access road.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s460l–6c/a/3/D","parentIdentifier":"/us/usc/t16/s460l–6c/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F3%2FD","sourceRelease":"119-100","text":"Refuse containers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s460l–6c/a/3/E","parentIdentifier":"/us/usc/t16/s460l–6c/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F3%2FE","sourceRelease":"119-100","text":"Toilet facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t16/s460l–6c/a/3/F","parentIdentifier":"/us/usc/t16/s460l–6c/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F3%2FF","sourceRelease":"119-100","text":"The personal collection of recreation use fees by an employee or agent of the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t16/s460l–6c/a/3/G","parentIdentifier":"/us/usc/t16/s460l–6c/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F3%2FG","sourceRelease":"119-100","text":"Reasonable visitor protection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t16/s460l–6c/a/3/H","parentIdentifier":"/us/usc/t16/s460l–6c/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F3%2FH","sourceRelease":"119-100","text":"If campfires are permitted in the campground, simple devices for containing the fires.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Secretary","label":"4 Secretary","identifier":"/us/usc/t16/s460l–6c/a/4","parentIdentifier":"/us/usc/t16/s460l–6c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fa%2F4","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Agriculture.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Authority to impose fees","label":"b Authority to impose fees","identifier":"/us/usc/t16/s460l–6c/b","parentIdentifier":"/us/usc/t16/s460l–6c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460l–6c/b/1","parentIdentifier":"/us/usc/t16/s460l–6c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fb%2F1","sourceRelease":"119-100","text":"admission or entrance fees at national monuments, national volcanic monuments, national scenic areas, and areas of concentrated public use administered by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460l–6c/b/2","parentIdentifier":"/us/usc/t16/s460l–6c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fb%2F2","sourceRelease":"119-100","text":"recreation use fees at lands administered by the Secretary in connection with the use of specialized outdoor recreation sites, equipment, services, and facilities, including visitors’ centers, picnic tables, boat launching facilities, and campgrounds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Amount of fees","label":"c Amount of fees","identifier":"/us/usc/t16/s460l–6c/c","parentIdentifier":"/us/usc/t16/s460l–6c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460l%E2%80%936c%2Fc","sourceRelease":"119-100","text":"The amount of the admission, entrance, and recreation fees authorized to be imposed under this section shall be determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
