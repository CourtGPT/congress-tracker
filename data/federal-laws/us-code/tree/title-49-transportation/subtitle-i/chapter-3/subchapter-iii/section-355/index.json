{"type":"section","nativeType":"section","number":"355","heading":"Motorcyclist Advisory Council","label":"355 Motorcyclist Advisory Council","identifier":"/us/usc/t49/s355","parentIdentifier":"/us/usc/t49/stI/ch3/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe date of enactment of this section, referred to in subsec. (a), is the date of enactment of , which was approved .Pub. L. 117–58Nov. 15, 2021"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t49/s355/a","parentIdentifier":"/us/usc/t49/s355","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fa","sourceRelease":"119-100","text":"Not later than 90 days after the date of enactment of this section, the Secretary of Transportation (referred to in this section as the “Secretary”) shall establish a council, to be known as the “Motorcyclist Advisory Council” (referred to in this section as the “Council”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Membership.—","label":"b Membership.—","identifier":"/us/usc/t49/s355/b","parentIdentifier":"/us/usc/t49/s355","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s355/b/1","parentIdentifier":"/us/usc/t49/s355/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s355/b/1/A","parentIdentifier":"/us/usc/t49/s355/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s355/b/1/A/i","parentIdentifier":"/us/usc/t49/s355/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"motorcycle and motorcyclist safety;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s355/b/1/A/ii","parentIdentifier":"/us/usc/t49/s355/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"barrier and road design, construction, and maintenance; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t49/s355/b/1/A/iii","parentIdentifier":"/us/usc/t49/s355/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"intelligent transportation systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s355/b/1/B","parentIdentifier":"/us/usc/t49/s355/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s355/b/1/B/i","parentIdentifier":"/us/usc/t49/s355/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"traffic and safety engineer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s355/b/1/B/ii","parentIdentifier":"/us/usc/t49/s355/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"design engineer; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t49/s355/b/1/B/iii","parentIdentifier":"/us/usc/t49/s355/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"other transportation department official;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s355/b/1/C","parentIdentifier":"/us/usc/t49/s355/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FC","sourceRelease":"119-100","text":"1 shall be a representative of a national association of State transportation officials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t49/s355/b/1/D","parentIdentifier":"/us/usc/t49/s355/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FD","sourceRelease":"119-100","text":"1 shall be a representative of a national motorcyclist association;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t49/s355/b/1/E","parentIdentifier":"/us/usc/t49/s355/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FE","sourceRelease":"119-100","text":"1 shall be a representative of a national motorcyclist foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t49/s355/b/1/F","parentIdentifier":"/us/usc/t49/s355/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FF","sourceRelease":"119-100","text":"1 shall be a representative of a national motorcycle manufacturing association;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t49/s355/b/1/G","parentIdentifier":"/us/usc/t49/s355/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FG","sourceRelease":"119-100","text":"1 shall be a representative of a motorcycle manufacturing company headquartered in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t49/s355/b/1/H","parentIdentifier":"/us/usc/t49/s355/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FH","sourceRelease":"119-100","text":"1 shall be a roadway safety data expert with expertise relating to crash testing and analysis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t49/s355/b/1/I","parentIdentifier":"/us/usc/t49/s355/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F1%2FI","sourceRelease":"119-100","text":"1 shall be a member of a national safety organization that represents the traffic safety systems industry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Term.—","label":"2 Term.—","identifier":"/us/usc/t49/s355/b/2","parentIdentifier":"/us/usc/t49/s355/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t49/s355/b/2/A","parentIdentifier":"/us/usc/t49/s355/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F2%2FA","sourceRelease":"119-100","text":"Subject to subparagraphs (B) and (C), each member shall serve on the Council for a single term of 2 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Additional term","label":"B .—Additional term","identifier":"/us/usc/t49/s355/b/2/B","parentIdentifier":"/us/usc/t49/s355/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F2%2FB","sourceRelease":"119-100","text":"If a successor is not appointed for a member of the Council before the expiration of the term of service of the member, the member may serve on the Council for a second term of not longer than 2 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":".—Appointment of replacements","label":"C .—Appointment of replacements","identifier":"/us/usc/t49/s355/b/2/C","parentIdentifier":"/us/usc/t49/s355/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s355/b/2/C/i","parentIdentifier":"/us/usc/t49/s355/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F2%2FC%2Fi","sourceRelease":"119-100","text":"the Secretary may appoint a replacement for the member, who shall serve the remaining portion of the term; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s355/b/2/C/ii","parentIdentifier":"/us/usc/t49/s355/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F2%2FC%2Fii","sourceRelease":"119-100","text":"the resigning member may continue to serve after resignation until the date on which a successor is appointed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Vacancies","label":"3 .—Vacancies","identifier":"/us/usc/t49/s355/b/3","parentIdentifier":"/us/usc/t49/s355/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F3","sourceRelease":"119-100","text":"A vacancy on the Council shall be filled in the manner in which the original appointment was made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Compensation","label":"4 .—Compensation","identifier":"/us/usc/t49/s355/b/4","parentIdentifier":"/us/usc/t49/s355/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fb%2F4","sourceRelease":"119-100","text":"A member of the Council shall serve without compensation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duties.—","label":"c Duties.—","identifier":"/us/usc/t49/s355/c","parentIdentifier":"/us/usc/t49/s355","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Advising","label":"1 .—Advising","identifier":"/us/usc/t49/s355/c/1","parentIdentifier":"/us/usc/t49/s355/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s355/c/1/A","parentIdentifier":"/us/usc/t49/s355/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fc%2F1%2FA","sourceRelease":"119-100","text":"motorcycle and motorcyclist safety;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s355/c/1/B","parentIdentifier":"/us/usc/t49/s355/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fc%2F1%2FB","sourceRelease":"119-100","text":"barrier and road design, construction, and maintenance practices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s355/c/1/C","parentIdentifier":"/us/usc/t49/s355/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fc%2F1%2FC","sourceRelease":"119-100","text":"the architecture and implementation of intelligent transportation system technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Biennial report","label":"2 .—Biennial report","identifier":"/us/usc/t49/s355/c/2","parentIdentifier":"/us/usc/t49/s355/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fc%2F2","sourceRelease":"119-100","text":"Not later than October 31 of the calendar year following the calendar year in which the Council is established, and not less frequently than once every 2 years thereafter, the Council shall submit to the Secretary a report containing recommendations of the Council regarding the issues described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Duties of Secretary.—","label":"d Duties of Secretary.—","identifier":"/us/usc/t49/s355/d","parentIdentifier":"/us/usc/t49/s355","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Council recommendations.—","label":"1 Council recommendations.—","identifier":"/us/usc/t49/s355/d/1","parentIdentifier":"/us/usc/t49/s355/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t49/s355/d/1/A","parentIdentifier":"/us/usc/t49/s355/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F1%2FA","sourceRelease":"119-100","text":"The Secretary shall determine whether to accept or reject a recommendation contained in a report of the Council under subsection (c)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Inclusion in review.—","label":"B Inclusion in review.—","identifier":"/us/usc/t49/s355/d/1/B","parentIdentifier":"/us/usc/t49/s355/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":".—In general","label":"i .—In general","identifier":"/us/usc/t49/s355/d/1/B/i","parentIdentifier":"/us/usc/t49/s355/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F1%2FB%2Fi","sourceRelease":"119-100","text":"The Secretary shall indicate in each review under paragraph (2) whether the Secretary accepts or rejects each recommendation of the Council covered by the review.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":".—Exception","label":"ii .—Exception","identifier":"/us/usc/t49/s355/d/1/B/ii","parentIdentifier":"/us/usc/t49/s355/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F1%2FB%2Fii","sourceRelease":"119-100","text":"The Secretary may indicate in a review under paragraph (2) that a recommendation of the Council is under consideration, subject to the condition that a recommendation so under consideration shall be accepted or rejected by the Secretary in the subsequent review of the Secretary under paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Review.—","label":"2 Review.—","identifier":"/us/usc/t49/s355/d/2","parentIdentifier":"/us/usc/t49/s355/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t49/s355/d/2/A","parentIdentifier":"/us/usc/t49/s355/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s355/d/2/A/i","parentIdentifier":"/us/usc/t49/s355/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the Committee on Commerce, Science, and Transportation of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s355/d/2/A/ii","parentIdentifier":"/us/usc/t49/s355/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the Committee on Environment and Public Works of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t49/s355/d/2/A/iii","parentIdentifier":"/us/usc/t49/s355/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"the Subcommittee on Transportation, Housing and Urban Development, and Related Agencies of the Committee on Appropriations of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t49/s355/d/2/A/iv","parentIdentifier":"/us/usc/t49/s355/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"the Committee on Transportation and Infrastructure of the House of Representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t49/s355/d/2/A/v","parentIdentifier":"/us/usc/t49/s355/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F2%2FA%2Fv","sourceRelease":"119-100","text":"the Subcommittee on Transportation, Housing and Urban Development, and Related Agencies of the Committee on Appropriations of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Contents","label":"B .—Contents","identifier":"/us/usc/t49/s355/d/2/B","parentIdentifier":"/us/usc/t49/s355/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s355/d/2/B/i","parentIdentifier":"/us/usc/t49/s355/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F2%2FB%2Fi","sourceRelease":"119-100","text":"each recommendation contained in the Council report covered by the review; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s355/d/2/B/ii","parentIdentifier":"/us/usc/t49/s355/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t49/s355/d/2/B/ii/I","parentIdentifier":"/us/usc/t49/s355/d/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs355%2Fd%2F2