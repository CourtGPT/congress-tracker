{"type":"section","nativeType":"section","number":"950bb–3","heading":"Community Connect Grant Program","label":"950bb–3 Community Connect Grant Program","identifier":"/us/usc/t7/s950bb–3","parentIdentifier":"/us/usc/t7/ch31/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t7/s950bb–3/a","parentIdentifier":"/us/usc/t7/s950bb–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible broadband service","label":"1 Eligible broadband service","identifier":"/us/usc/t7/s950bb–3/a/1","parentIdentifier":"/us/usc/t7/s950bb–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F1","sourceRelease":"119-100","text":"The term “eligible broadband service” means broadband service that has the capability to transmit data at a speed specified by the Secretary, which may not be less than the applicable minimum download and upload speeds established by the Federal Communications Commission in defining the term “advanced telecommunications capability” for purposes of .section 1302 of title 47","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible service area","label":"2 Eligible service area","identifier":"/us/usc/t7/s950bb–3/a/2","parentIdentifier":"/us/usc/t7/s950bb–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950bb–3/a/2/A","parentIdentifier":"/us/usc/t7/s950bb–3/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F2%2FA","sourceRelease":"119-100","text":"a 10-Mbps downstream transmission capacity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s950bb–3/a/2/B","parentIdentifier":"/us/usc/t7/s950bb–3/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F2%2FB","sourceRelease":"119-100","text":"a 1-Mbps upstream transmission capacity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Eligible entity","label":"3 Eligible entity","identifier":"/us/usc/t7/s950bb–3/a/3","parentIdentifier":"/us/usc/t7/s950bb–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s950bb–3/a/3/A","parentIdentifier":"/us/usc/t7/s950bb–3/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s950bb–3/a/3/A/i","parentIdentifier":"/us/usc/t7/s950bb–3/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F3%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s950bb–3/a/3/A/i/I","parentIdentifier":"/us/usc/t7/s950bb–3/a/3/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F3%2FA%2Fi%2FI","sourceRelease":"119-100","text":"an incorporated organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s950bb–3/a/3/A/i/II","parentIdentifier":"/us/usc/t7/s950bb–3/a/3/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F3%2FA%2Fi%2FII","sourceRelease":"119-100","text":"an Indian Tribe or Tribal organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t7/s950bb–3/a/3/A/i/III","parentIdentifier":"/us/usc/t7/s950bb–3/a/3/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F3%2FA%2Fi%2FIII","sourceRelease":"119-100","text":"a State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t7/s950bb–3/a/3/A/i/IV","parentIdentifier":"/us/usc/t7/s950bb–3/a/3/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F3%2FA%2Fi%2FIV","sourceRelease":"119-100","text":"a unit of local government; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t7/s950bb–3/a/3/A/i/V","parentIdentifier":"/us/usc/t7/s950bb–3/a/3/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F3%2FA%2Fi%2FV","sourceRelease":"119-100","text":"any other legal entity, including a cooperative, a private corporation, or a limited liability company, that is organized on a for-profit or a not-for-profit basis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s950bb–3/a/3/A/ii","parentIdentifier":"/us/usc/t7/s950bb–3/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F3%2FA%2Fii","sourceRelease":"119-100","text":"has the legal capacity and authority to enter into a contract, to comply with applicable Federal laws, and to own and operate broadband facilities, as proposed in the application submitted by the entity for a grant under the Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exclusions","label":"B Exclusions","identifier":"/us/usc/t7/s950bb–3/a/3/B","parentIdentifier":"/us/usc/t7/s950bb–3/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s950bb–3/a/3/B/i","parentIdentifier":"/us/usc/t7/s950bb–3/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F3%2FB%2Fi","sourceRelease":"119-100","text":"an individual; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s950bb–3/a/3/B/ii","parentIdentifier":"/us/usc/t7/s950bb–3/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F3%2FB%2Fii","sourceRelease":"119-100","text":"a partnership.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Rural area","label":"4 Rural area","identifier":"/us/usc/t7/s950bb–3/a/4","parentIdentifier":"/us/usc/t7/s950bb–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fa%2F4","sourceRelease":"119-100","text":"The term “rural area” has the meaning given the term in .section 950bb(b)(3)(A) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t7/s950bb–3/b","parentIdentifier":"/us/usc/t7/s950bb–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fb","sourceRelease":"119-100","text":"The Secretary shall establish a program, to be known as the “Community Connect Grant Program”, to provide grants to eligible entities to finance broadband transmission in rural areas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Eligible projects","label":"c Eligible projects","identifier":"/us/usc/t7/s950bb–3/c","parentIdentifier":"/us/usc/t7/s950bb–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s950bb–3/c/1","parentIdentifier":"/us/usc/t7/s950bb–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950bb–3/c/1/A","parentIdentifier":"/us/usc/t7/s950bb–3/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fc%2F1%2FA","sourceRelease":"119-100","text":"each essential community facility as defined pursuant to ; andsection 1926(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s950bb–3/c/1/B","parentIdentifier":"/us/usc/t7/s950bb–3/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fc%2F1%2FB","sourceRelease":"119-100","text":"any required facilities necessary to offer that eligible broadband service to each residential and business customer within such proposed eligible service area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s950bb–3/c/2","parentIdentifier":"/us/usc/t7/s950bb–3/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950bb–3/c/2/A","parentIdentifier":"/us/usc/t7/s950bb–3/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fc%2F2%2FA","sourceRelease":"119-100","text":"furnishes free eligible broadband service to a community center described in subsection (d)(1)(B);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s950bb–3/c/2/B","parentIdentifier":"/us/usc/t7/s950bb–3/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fc%2F2%2FB","sourceRelease":"119-100","text":"provides not fewer than 2 computer access points for that free eligible broadband service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s950bb–3/c/2/C","parentIdentifier":"/us/usc/t7/s950bb–3/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fc%2F2%2FC","sourceRelease":"119-100","text":"covers the cost of bandwidth to provide free eligible broadband service to each essential community facility that requests broadband services within the proposed eligible service area described in the application submitted by the eligible entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Uses of grant funds","label":"d Uses of grant funds","identifier":"/us/usc/t7/s950bb–3/d","parentIdentifier":"/us/usc/t7/s950bb–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s950bb–3/d/1","parentIdentifier":"/us/usc/t7/s950bb–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950bb–3/d/1/A","parentIdentifier":"/us/usc/t7/s950bb–3/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the construction, acquisition, or leasing of facilities (including spectrum), land, or buildings to deploy eligible broadband service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s950bb–3/d/1/B","parentIdentifier":"/us/usc/t7/s950bb–3/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fd%2F1%2FB","sourceRelease":"119-100","text":"the improvement, expansion, construction, or acquisition of a community center within the proposed eligible service area described in the application submitted by the eligible entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Ineligible uses","label":"2 Ineligible uses","identifier":"/us/usc/t7/s950bb–3/d/2","parentIdentifier":"/us/usc/t7/s950bb–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950bb–3/d/2/A","parentIdentifier":"/us/usc/t7/s950bb–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fd%2F2%2FA","sourceRelease":"119-100","text":"the duplication of any existing eligible broadband service provided by another entity in the eligible service area; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s950bb–3/d/2/B","parentIdentifier":"/us/usc/t7/s950bb–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fd%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s950bb–3/d/2/B/i","parentIdentifier":"/us/usc/t7/s950bb–3/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fd%2F2%2FB%2Fi","sourceRelease":"119-100","text":"subsection (c)(2)(C) with respect to free eligible broadband service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s950bb–3/d/2/B/ii","parentIdentifier":"/us/usc/t7/s950bb–3/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fd%2F2%2FB%2Fii","sourceRelease":"119-100","text":"paragraph (1)(A) with respect to spectrum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Free access for community centers","label":"3 Free access for community centers","identifier":"/us/usc/t7/s950bb–3/d/3","parentIdentifier":"/us/usc/t7/s950bb–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950bb–3/d/3/A","parentIdentifier":"/us/usc/t7/s950bb–3/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fd%2F3%2FA","sourceRelease":"119-100","text":"10 percent; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s950bb–3/d/3/B","parentIdentifier":"/us/usc/t7/s950bb–3/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fd%2F3%2FB","sourceRelease":"119-100","text":"$150,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Matching funds","label":"e Matching funds","identifier":"/us/usc/t7/s950bb–3/e","parentIdentifier":"/us/usc/t7/s950bb–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s950bb–3/e/1","parentIdentifier":"/us/usc/t7/s950bb–3/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fe%2F1","sourceRelease":"119-100","text":"An eligible entity that receives a grant under the Program shall provide a cash contribution in an amount that is not less than 15 percent of the amount of the grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t7/s950bb–3/e/2","parentIdentifier":"/us/usc/t7/s950bb–3/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950bb–3/e/2/A","parentIdentifier":"/us/usc/t7/s950bb–3/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fe%2F2%2FA","sourceRelease":"119-100","text":"shall be used solely for the project for which the eligible entity receives a grant under the Program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s950bb–3/e/2/B","parentIdentifier":"/us/usc/t7/s950bb–3/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fe%2F2%2FB","sourceRelease":"119-100","text":"shall not include any Federal funds, unless a Federal statute specifically provides that those Federal funds may be considered to be from a non-Federal source.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Applications","label":"f Applications","identifier":"/us/usc/t7/s950bb–3/f","parentIdentifier":"/us/usc/t7/s950bb–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s950bb–3/f/1","parentIdentifier":"/us/usc/t7/s950bb–3/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Ff%2F1","sourceRelease":"119-100","text":"To be eligible to receive a grant under the Program, an eligible entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirement","label":"2 Requirement","identifier":"/us/usc/t7/s950bb–3/f/2","parentIdentifier":"/us/usc/t7/s950bb–3/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Ff%2F2","sourceRelease":"119-100","text":"An application submitted by an eligible entity under paragraph (1) shall include documentation sufficient to demonstrate the availability of funds to satisfy the requirement of subsection (e).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Authorization of appropriations","label":"g Authorization of appropriations","identifier":"/us/usc/t7/s950bb–3/g","parentIdentifier":"/us/usc/t7/s950bb–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%933%2Fg","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $50,000,000 for each of fiscal years 2019 through 2023.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
