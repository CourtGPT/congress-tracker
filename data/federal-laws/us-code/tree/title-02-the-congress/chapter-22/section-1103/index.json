{"type":"section","nativeType":"section","number":"1103","heading":"Establishment of John C. Stennis Center for Public Service Training and Development","label":"1103 Establishment of John C. Stennis Center for Public Service Training and Development","identifier":"/us/usc/t2/s1103","parentIdentifier":"/us/usc/t2/ch22","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t2/s1103/a","parentIdentifier":"/us/usc/t2/s1103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103%2Fa","sourceRelease":"119-100","text":"There is established in the legislative branch of the Government a center to be known as the “John C. Stennis Center for Public Service Training and Development”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Board of Trustees","label":"b Board of Trustees","identifier":"/us/usc/t2/s1103/b","parentIdentifier":"/us/usc/t2/s1103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s1103/b/1","parentIdentifier":"/us/usc/t2/s1103/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103%2Fb%2F1","sourceRelease":"119-100","text":"Two members to be appointed by the majority leader of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s1103/b/2","parentIdentifier":"/us/usc/t2/s1103/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103%2Fb%2F2","sourceRelease":"119-100","text":"One member to be appointed by the minority leader of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t2/s1103/b/3","parentIdentifier":"/us/usc/t2/s1103/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103%2Fb%2F3","sourceRelease":"119-100","text":"Two members to be appointed by the Speaker of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t2/s1103/b/4","parentIdentifier":"/us/usc/t2/s1103/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103%2Fb%2F4","sourceRelease":"119-100","text":"One member to be appointed by the minority leader of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t2/s1103/b/5","parentIdentifier":"/us/usc/t2/s1103/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103%2Fb%2F5","sourceRelease":"119-100","text":"The Executive Director of the Center, who shall serve as an ex officio member of the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Term of office","label":"c Term of office","identifier":"/us/usc/t2/s1103/c","parentIdentifier":"/us/usc/t2/s1103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s1103/c/1","parentIdentifier":"/us/usc/t2/s1103/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103%2Fc%2F1","sourceRelease":"119-100","text":"the members first appointed under paragraphs (1) and (2) shall serve, as designated by the majority leader of the Senate, one for a term of two years, one for a term of four years, and one for a term of six years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s1103/c/2","parentIdentifier":"/us/usc/t2/s1103/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103%2Fc%2F2","sourceRelease":"119-100","text":"the members first appointed under paragraphs (3) and (4) shall serve, as designated by the Speaker of the House of Representatives, one for a term of two years, one for a term of four years, and one for a term of six years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t2/s1103/c/3","parentIdentifier":"/us/usc/t2/s1103/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103%2Fc%2F3","sourceRelease":"119-100","text":"a member appointed to fill a vacancy shall serve for the remainder of the term for which his predecessor was appointed and shall be appointed in the same manner as the original appointment for that vacancy was made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Travel and subsistence pay","label":"d Travel and subsistence pay","identifier":"/us/usc/t2/s1103/d","parentIdentifier":"/us/usc/t2/s1103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103%2Fd","sourceRelease":"119-100","text":"Members of the Board (other than the Executive Director) shall serve without pay, but shall be entitled to reimbursement for travel, subsistence, and other necessary expenses incurred in the performance of their duties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Location of Center","label":"e Location of Center","identifier":"/us/usc/t2/s1103/e","parentIdentifier":"/us/usc/t2/s1103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1103%2Fe","sourceRelease":"119-100","text":"The Center shall be located at or near Starkville, Mississippi, the location of Mississippi State University.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
