{"type":"section","nativeType":"section","number":"6176","heading":"Defense environmental cleanup technology program","label":"6176 Defense environmental cleanup technology program","identifier":"/us/usc/t10/s6176","parentIdentifier":"/us/usc/t10/stA/ptVI/sptB/ch604/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6176","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsProvisions similar to those in this section were contained in , War and National Defense, prior to repeal by .section 2586 of Title 50Pub. L. 119–60, § 3111(b)(1)"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment of Program","label":"a .—Establishment of Program","identifier":"/us/usc/t10/s6176/a","parentIdentifier":"/us/usc/t10/s6176","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6176%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6176/a/1","parentIdentifier":"/us/usc/t10/s6176/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6176%2Fa%2F1","sourceRelease":"119-100","text":"the reduction of environmental hazards and contamination resulting from defense waste; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6176/a/2","parentIdentifier":"/us/usc/t10/s6176/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6176%2Fa%2F2","sourceRelease":"119-100","text":"environmental restoration of inactive defense waste disposal sites.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Definitions","label":"b .—Definitions","identifier":"/us/usc/t10/s6176/b","parentIdentifier":"/us/usc/t10/s6176","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6176%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6176/b/1","parentIdentifier":"/us/usc/t10/s6176/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6176%2Fb%2F1","sourceRelease":"119-100","text":"The term “defense waste” means waste, including radioactive waste, resulting primarily from atomic energy defense activities of the Department of Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6176/b/2","parentIdentifier":"/us/usc/t10/s6176/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6176%2Fb%2F2","sourceRelease":"119-100","text":"The term “inactive defense waste disposal site” means any site (including any facility) under the control or jurisdiction of the Secretary of Energy which is used for the disposal of defense waste and is closed to the disposal of additional defense waste, including any site that is subject to decontamination and decommissioning.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
