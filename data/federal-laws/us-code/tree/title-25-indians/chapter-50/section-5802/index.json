his title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Institution of higher education","label":"4 Institution of higher education","identifier":"/us/usc/t25/s5802/4","parentIdentifier":"/us/usc/t25/s5802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5802%2F4","sourceRelease":"119-100","text":"The term “institution of higher education” has the meaning given the term in .section 1001 of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Native American; Native","label":"5 Native American; Native","identifier":"/us/usc/t25/s5802/5","parentIdentifier":"/us/usc/t25/s5802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5802%2F5","sourceRelease":"119-100","text":"The terms “Native American” and “Native” have the meaning given the term “Indian” in .section 5304 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Native business","label":"6 Native business","identifier":"/us/usc/t25/s5802/6","parentIdentifier":"/us/usc/t25/s5802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5802%2F6","sourceRelease":"119-100","text":"The term “Native business” means a business concern that is at least 51-percent owned and controlled by 1 or more Native Americans.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Native entrepreneur","label":"7 Native entrepreneur","identifier":"/us/usc/t25/s5802/7","parentIdentifier":"/us/usc/t25/s5802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5802%2F7","sourceRelease":"119-100","text":"The term “Native entrepreneur” means an entrepreneur who is a Native American.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Program","label":"8 Program","identifier":"/us/usc/t25/s5802/8","parentIdentifier":"/us/usc/t25/s5802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5802%2F8","sourceRelease":"119-100","text":"The term “program” means the program established under .section 5803(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":"Reservation","label":"9 Reservation","identifier":"/us/usc/t25/s5802/9","parentIdentifier":"/us/usc/t25/s5802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5802%2F9","sourceRelease":"119-100","text":"The term “reservation” has the meaning given the term in .section 1452 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":"Secretary","label":"10 Secretary","identifier":"/us/usc/t25/s5802/10","parentIdentifier":"/us/usc/t25/s5802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5802%2F10","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of the Interior.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":"Tribal college or university","label":"11 Tribal college or university","identifier":"/us/usc/t25/s5802/11","parentIdentifier":"/us/usc/t25/s5802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5802%2F11","sourceRelease":"119-100","text":"The term “tribal college or university” has the meaning given the term “Tribal College or University” in .section 1059c(b) of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
