{"type":"section","nativeType":"section","number":"9741","heading":"Recovering assets stolen from the Venezuelan people","label":"9741 Recovering assets stolen from the Venezuelan people","identifier":"/us/usc/t22/s9741","parentIdentifier":"/us/usc/t22/ch104/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9741","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Recovering assets","label":"a Recovering assets","identifier":"/us/usc/t22/s9741/a","parentIdentifier":"/us/usc/t22/s9741","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9741%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9741/a/1","parentIdentifier":"/us/usc/t22/s9741/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9741%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9741/a/1/A","parentIdentifier":"/us/usc/t22/s9741/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9741%2Fa%2F1%2FA","sourceRelease":"119-100","text":"to share financial investigations intelligence, as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9741/a/1/B","parentIdentifier":"/us/usc/t22/s9741/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9741%2Fa%2F1%2FB","sourceRelease":"119-100","text":"to block the assets identified pursuant to paragraph (2); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s9741/a/1/C","parentIdentifier":"/us/usc/t22/s9741/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9741%2Fa%2F1%2FC","sourceRelease":"119-100","text":"to provide technical assistance to help governments establish the necessary legal framework to carry out asset forfeitures; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9741/a/2","parentIdentifier":"/us/usc/t22/s9741/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9741%2Fa%2F2","sourceRelease":"119-100","text":"to carry out special financial investigations to identify and track assets taken from the people and institutions of Venezuela through theft, corruption, money laundering, or other illicit means.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Strategy requirement","label":"b Strategy requirement","identifier":"/us/usc/t22/s9741/b","parentIdentifier":"/us/usc/t22/s9741","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9741%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s9741/b/1","parentIdentifier":"/us/usc/t22/s9741/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9741%2Fb%2F1","sourceRelease":"119-100","text":"Not later than 180 days after , the President, acting through the Secretary of State and in consultation with the Secretary of the Treasury, shall submit a strategy for carrying out the activities described in subsection (a) to Congress.December 20, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Additional elements","label":"2 Additional elements","identifier":"/us/usc/t22/s9741/b/2","parentIdentifier":"/us/usc/t22/s9741/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9741%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s9741/b/2/A","parentIdentifier":"/us/usc/t22/s9741/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9741%2Fb%2F2%2FA","sourceRelease":"119-100","text":"assess whether the United States or another member of the international community should establish a managed fund to hold the assets identified pursuant to subsection (a)(2) that could be returned to a future democratic government in Venezuela; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s9741/b/2/B","parentIdentifier":"/us/usc/t22/s9741/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9741%2Fb%2F2%2FB","sourceRelease":"119-100","text":"include such recommendations as the President and the Secretary of State consider appropriate for legislative or administrative action in the United States that would be needed to establish and manage the fund described in subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
