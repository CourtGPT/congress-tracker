{"type":"section","nativeType":"section","number":"13102","heading":"Definitions","label":"13102 Definitions","identifier":"/us/usc/t42/s13102","parentIdentifier":"/us/usc/t42/ch133","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13102","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13102/1","parentIdentifier":"/us/usc/t42/s13102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13102%2F1","sourceRelease":"119-100","text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13102/2","parentIdentifier":"/us/usc/t42/s13102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13102%2F2","sourceRelease":"119-100","text":"The term “Agency” means the Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13102/3","parentIdentifier":"/us/usc/t42/s13102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13102%2F3","sourceRelease":"119-100","text":"The term “toxic chemical” means any substance on the list described in .section 11023(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s13102/4","parentIdentifier":"/us/usc/t42/s13102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13102%2F4","sourceRelease":"119-100","text":"The term “release” has the same meaning as provided by .section 11049(8) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s13102/5","parentIdentifier":"/us/usc/t42/s13102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13102%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13102/5/A","parentIdentifier":"/us/usc/t42/s13102/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13102%2F5%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s13102/5/A/i","parentIdentifier":"/us/usc/t42/s13102/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13102%2F5%2FA%2Fi","sourceRelease":"119-100","text":"reduces the amount of any hazardous substance, pollutant, or contaminant entering any waste stream or otherwise released into the environment (including fugitive emissions) prior to recycling, treatment, or disposal; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s13102/5/A/ii","parentIdentifier":"/us/usc/t42/s13102/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13102%2F5%2FA%2Fii","sourceRelease":"119-100","text":"reduces the hazards to public health and the environment associated with the release of such substances, pollutants, or contaminants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13102/5/B","parentIdentifier":"/us/usc/t42/s13102/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13102%2F5%2FB","sourceRelease":"119-100","text":"The term “source reduction” does not include any practice which alters the physical, chemical, or biological characteristics or the volume of a hazardous substance, pollutant, or contaminant through a process or activity which itself is not integral to and necessary for the production of a product or the providing of a service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s13102/6","parentIdentifier":"/us/usc/t42/s13102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13102%2F6","sourceRelease":"119-100","text":"The term “multi-media” means water, air, and land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s13102/7","parentIdentifier":"/us/usc/t42/s13102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13102%2F7","sourceRelease":"119-100","text":"The term “SIC codes” refers to the 2-digit code numbers used for classification of economic activity in the Standard Industrial Classification Manual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
