{"type":"section","nativeType":"section","number":"6410","heading":"Petition and review","label":"6410 Petition and review","identifier":"/us/usc/t7/s6410","parentIdentifier":"/us/usc/t7/ch93","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6410","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe Federal Rules of Civil Procedure, referred to in subsec. (b)(2), are set out in the Appendix to Title 28, Judiciary and Judicial Procedure."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Petition","label":"a Petition","identifier":"/us/usc/t7/s6410/a","parentIdentifier":"/us/usc/t7/s6410","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6410%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s6410/a/1","parentIdentifier":"/us/usc/t7/s6410/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6410%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6410/a/1/A","parentIdentifier":"/us/usc/t7/s6410/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6410%2Fa%2F1%2FA","sourceRelease":"119-100","text":"stating that the order, any provision of the order, or any obligation imposed in connection with the order is not established in accordance with law; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6410/a/1/B","parentIdentifier":"/us/usc/t7/s6410/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6410%2Fa%2F1%2FB","sourceRelease":"119-100","text":"requesting a modification of the order or an exemption from the order.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Hearings","label":"2 Hearings","identifier":"/us/usc/t7/s6410/a/2","parentIdentifier":"/us/usc/t7/s6410/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6410%2Fa%2F2","sourceRelease":"119-100","text":"The petitioner shall be given the opportunity for a hearing on the petition, in accordance with regulations issued by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Ruling","label":"3 Ruling","identifier":"/us/usc/t7/s6410/a/3","parentIdentifier":"/us/usc/t7/s6410/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6410%2Fa%2F3","sourceRelease":"119-100","text":"After the hearing, the Secretary shall make a ruling on the petition, which shall be final if in accordance with law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Review","label":"b Review","identifier":"/us/usc/t7/s6410/b","parentIdentifier":"/us/usc/t7/s6410","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6410%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Commencement of action","label":"1 Commencement of action","identifier":"/us/usc/t7/s6410/b/1","parentIdentifier":"/us/usc/t7/s6410/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6410%2Fb%2F1","sourceRelease":"119-100","text":"The district courts of the United States in any district in which the person who is a petitioner under subsection (a) resides or carries on business are hereby vested with jurisdiction to review the ruling on such person’s petition, if a complaint for that purpose is filed within 20 days after the date of the entry of a ruling by the Secretary under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Process","label":"2 Process","identifier":"/us/usc/t7/s6410/b/2","parentIdentifier":"/us/usc/t7/s6410/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6410%2Fb%2F2","sourceRelease":"119-100","text":"Service of process in such proceedings shall be conducted in accordance with the Federal Rules of Civil Procedure.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Remands","label":"3 Remands","identifier":"/us/usc/t7/s6410/b/3","parentIdentifier":"/us/usc/t7/s6410/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6410%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6410/b/3/A","parentIdentifier":"/us/usc/t7/s6410/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6410%2Fb%2F3%2FA","sourceRelease":"119-100","text":"to make such ruling as the court shall determine to be in accordance with law; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6410/b/3/B","parentIdentifier":"/us/usc/t7/s6410/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6410%2Fb%2F3%2FB","sourceRelease":"119-100","text":"to take such further proceedings as, in the opinion of the court, the law requires.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
