ubparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6521a/b/1/B","parentIdentifier":"/us/usc/t7/s6521a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6521a/b/1/B/i","parentIdentifier":"/us/usc/t7/s6521a/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s6521a/b/1/B/i/I","parentIdentifier":"/us/usc/t7/s6521a/b/1/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F1%2FB%2Fi%2FI","sourceRelease":"119-100","text":"tracking the fumigation of imports of organically produced agricultural products into the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s6521a/b/1/B/i/II","parentIdentifier":"/us/usc/t7/s6521a/b/1/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F1%2FB%2Fi%2FII","sourceRelease":"119-100","text":"electronically verifying national organic program import certificate authenticity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6521a/b/1/B/ii","parentIdentifier":"/us/usc/t7/s6521a/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s6521a/b/1/B/ii/I","parentIdentifier":"/us/usc/t7/s6521a/b/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F1%2FB%2Fii%2FI","sourceRelease":"119-100","text":"the use of the systems described in clause (i); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s6521a/b/1/B/ii/II","parentIdentifier":"/us/usc/t7/s6521a/b/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F1%2FB%2Fii%2FII","sourceRelease":"119-100","text":"requirements and protocols under this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s6521a/b/1/C","parentIdentifier":"/us/usc/t7/s6521a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F1%2FC","sourceRelease":"119-100","text":"establishing methodology for ensuring imports of agricultural products represented as organically produced meet the requirements under this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s6521a/b/1/D","parentIdentifier":"/us/usc/t7/s6521a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F1%2FD","sourceRelease":"119-100","text":"recommending steps to improve the documentation and traceability of imported organically produced agricultural products;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s6521a/b/1/E","parentIdentifier":"/us/usc/t7/s6521a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F1%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6521a/b/1/E/i","parentIdentifier":"/us/usc/t7/s6521a/b/1/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F1%2FE%2Fi","sourceRelease":"119-100","text":"improving compliance with the requirements of this chapter for all agricultural products imported into the United States and represented as organically produced; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6521a/b/1/E/ii","parentIdentifier":"/us/usc/t7/s6521a/b/1/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F1%2FE%2Fii","sourceRelease":"119-100","text":"ensuring accurate labeling and marketing of imported agricultural products represented as organically produced by the exporter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t7/s6521a/b/1/F","parentIdentifier":"/us/usc/t7/s6521a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F1%2FF","sourceRelease":"119-100","text":"describing staffing needs and additional resources at U.S. Customs and Border Protection and the Department of Agriculture needed to ensure compliance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report on enforcement actions taken on organic imports","label":"2 Report on enforcement actions taken on organic imports","identifier":"/us/usc/t7/s6521a/b/2","parentIdentifier":"/us/usc/t7/s6521a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6521a/b/2/A","parentIdentifier":"/us/usc/t7/s6521a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F2%2FA","sourceRelease":"119-100","text":"providing detailed quantitative data (broken down by agricultural product, quantity, value, month, and origin) on imports of agricultural products represented as organically produced found to be fraudulent or lacking any documentation required under this chapter at the port of entry during the report year;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6521a/b/2/B","parentIdentifier":"/us/usc/t7/s6521a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F2%2FB","sourceRelease":"119-100","text":"providing data on domestic enforcement actions taken on imported agricultural products represented as organically produced, including the number and type of actions taken by United States officials at ports of entry in response to violations of this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s6521a/b/2/C","parentIdentifier":"/us/usc/t7/s6521a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F2%2FC","sourceRelease":"119-100","text":"providing data on fumigation of agricultural products represented as organically produced at ports of entry and notifications of fumigation actions to shipment owners, broken down by product variety and country of origin; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s6521a/b/2/D","parentIdentifier":"/us/usc/t7/s6521a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s6521a/b/2/D/i","parentIdentifier":"/us/usc/t7/s6521a/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F2%2FD%2Fi","sourceRelease":"119-100","text":"the number of investigations by country; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s6521a/b/2/D/ii","parentIdentifier":"/us/usc/t7/s6521a/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6521a%2Fb%2F2%2FD%2Fii","sourceRelease":"119-100","text":"a descriptive summary of compliance actions taken by certifying agents in each country.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
