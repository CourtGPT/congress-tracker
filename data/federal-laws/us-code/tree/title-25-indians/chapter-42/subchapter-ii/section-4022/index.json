{"type":"section","nativeType":"section","number":"4022","heading":"Voluntary withdrawal from trust funds program","label":"4022 Voluntary withdrawal from trust funds program","identifier":"/us/usc/t25/s4022","parentIdentifier":"/us/usc/t25/ch42/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4022","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t25/s4022/a","parentIdentifier":"/us/usc/t25/s4022","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4022%2Fa","sourceRelease":"119-100","text":"An Indian tribe may, in accordance with this section, submit a plan to withdraw some or all funds held in trust for such tribe by the United States and managed by the Secretary through the Bureau.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Approval of plan","label":"b Approval of plan","identifier":"/us/usc/t25/s4022/b","parentIdentifier":"/us/usc/t25/s4022","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4022%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4022/b/1","parentIdentifier":"/us/usc/t25/s4022/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4022%2Fb%2F1","sourceRelease":"119-100","text":"Such plan has been approved by the appropriate Indian tribe and is accompanied by a resolution from the tribal governing body approving the plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4022/b/2","parentIdentifier":"/us/usc/t25/s4022/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4022%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s4022/b/2/A","parentIdentifier":"/us/usc/t25/s4022/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4022%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The capability and experience of the individuals or institutions that will be managing the trust funds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s4022/b/2/B","parentIdentifier":"/us/usc/t25/s4022/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4022%2Fb%2F2%2FB","sourceRelease":"119-100","text":"The protection against substantial loss of principal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Dissolution of trust responsibility","label":"c Dissolution of trust responsibility","identifier":"/us/usc/t25/s4022/c","parentIdentifier":"/us/usc/t25/s4022","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4022%2Fc","sourceRelease":"119-100","text":"Beginning on the date funds are withdrawn pursuant to this section, any trust responsibility or liability of the United States with respect to such funds shall cease except as provided for in .section 4027 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
