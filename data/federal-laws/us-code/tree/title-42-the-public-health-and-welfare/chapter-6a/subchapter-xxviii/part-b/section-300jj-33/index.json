{"type":"section","nativeType":"section","number":"300jj–33","heading":"State grants to promote health information technology","label":"300jj–33 State grants to promote health information technology","identifier":"/us/usc/t42/s300jj–33","parentIdentifier":"/us/usc/t42/ch6A/schXXVIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s300jj–33/a","parentIdentifier":"/us/usc/t42/s300jj–33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fa","sourceRelease":"119-100","text":"The Secretary, acting through the National Coordinator, shall establish a program in accordance with this section to facilitate and expand the electronic movement and use of health information among organizations according to nationally recognized standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Planning grants","label":"b Planning grants","identifier":"/us/usc/t42/s300jj–33/b","parentIdentifier":"/us/usc/t42/s300jj–33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fb","sourceRelease":"119-100","text":"The Secretary may award a grant to a State or qualified State-designated entity (as described in subsection (f)) that submits an application to the Secretary at such time, in such manner, and containing such information as the Secretary may specify, for the purpose of planning activities described in subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Implementation grants","label":"c Implementation grants","identifier":"/us/usc/t42/s300jj–33/c","parentIdentifier":"/us/usc/t42/s300jj–33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300jj–33/c/1","parentIdentifier":"/us/usc/t42/s300jj–33/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fc%2F1","sourceRelease":"119-100","text":"has submitted, and the Secretary has approved, a plan described in subsection (e) (regardless of whether such plan was prepared using amounts awarded under subsection (b); and2So in original. Another closing parenthesis probably should precede the semicolon.2","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300jj–33/c/2","parentIdentifier":"/us/usc/t42/s300jj–33/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fc%2F2","sourceRelease":"119-100","text":"submits an application at such time, in such manner, and containing such information as the Secretary may specify.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Use of funds","label":"d Use of funds","identifier":"/us/usc/t42/s300jj–33/d","parentIdentifier":"/us/usc/t42/s300jj–33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300jj–33/d/1","parentIdentifier":"/us/usc/t42/s300jj–33/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fd%2F1","sourceRelease":"119-100","text":"enhancing broad and varied participation in the authorized and secure nationwide electronic use and exchange of health information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300jj–33/d/2","parentIdentifier":"/us/usc/t42/s300jj–33/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fd%2F2","sourceRelease":"119-100","text":"identifying State or local resources available towards a nationwide effort to promote health information technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300jj–33/d/3","parentIdentifier":"/us/usc/t42/s300jj–33/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fd%2F3","sourceRelease":"119-100","text":"complementing other Federal grants, programs, and efforts towards the promotion of health information technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s300jj–33/d/4","parentIdentifier":"/us/usc/t42/s300jj–33/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fd%2F4","sourceRelease":"119-100","text":"providing technical assistance for the development and dissemination of solutions to barriers to the exchange of electronic health information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s300jj–33/d/5","parentIdentifier":"/us/usc/t42/s300jj–33/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fd%2F5","sourceRelease":"119-100","text":"promoting effective strategies to adopt and utilize health information technology in medically underserved communities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s300jj–33/d/6","parentIdentifier":"/us/usc/t42/s300jj–33/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fd%2F6","sourceRelease":"119-100","text":"assisting patients in utilizing health information technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s300jj–33/d/7","parentIdentifier":"/us/usc/t42/s300jj–33/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fd%2F7","sourceRelease":"119-100","text":"encouraging clinicians to work with Health Information Technology Regional Extension Centers as described in , to the extent they are available and valuable;section 300jj–32 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s300jj–33/d/8","parentIdentifier":"/us/usc/t42/s300jj–33/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fd%2F8","sourceRelease":"119-100","text":"supporting public health agencies’ authorized use of and access to electronic health information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t42/s300jj–33/d/9","parentIdentifier":"/us/usc/t42/s300jj–33/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fd%2F9","sourceRelease":"119-100","text":"promoting the use of electronic health records for quality improvement including through quality measures reporting; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t42/s300jj–33/d/10","parentIdentifier":"/us/usc/t42/s300jj–33/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fd%2F10","sourceRelease":"119-100","text":"such other activities as the Secretary may specify.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Plan","label":"e Plan","identifier":"/us/usc/t42/s300jj–33/e","parentIdentifier":"/us/usc/t42/s300jj–33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s300jj–33/e/1","parentIdentifier":"/us/usc/t42/s300jj–33/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fe%2F1","sourceRelease":"119-100","text":"A plan described in this subsection is a plan that describes the activities to be carried out by a State or by the qualified State-designated entity within such State to facilitate and expand the electronic movement and use of health information among organizations according to nationally recognized standards and implementation specifications.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Required elements","label":"2 Required elements","identifier":"/us/usc/t42/s300jj–33/e/2","parentIdentifier":"/us/usc/t42/s300jj–33/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300jj–33/e/2/A","parentIdentifier":"/us/usc/t42/s300jj–33/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fe%2F2%2FA","sourceRelease":"119-100","text":"be pursued in the public interest;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300jj–33/e/2/B","parentIdentifier":"/us/usc/t42/s300jj–33/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fe%2F2%2FB","sourceRelease":"119-100","text":"be consistent with the strategic plan developed by the National Coordinator, (and, as available) under ;section 300jj–11 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300jj–33/e/2/C","parentIdentifier":"/us/usc/t42/s300jj–33/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fe%2F2%2FC","sourceRelease":"119-100","text":"include a description of the ways the State or qualified State-designated entity will carry out the activities described in subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s300jj–33/e/2/D","parentIdentifier":"/us/usc/t42/s300jj–33/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fe%2F2%2FD","sourceRelease":"119-100","text":"contain such elements as the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Qualified State-designated entity","label":"f Qualified State-designated entity","identifier":"/us/usc/t42/s300jj–33/f","parentIdentifier":"/us/usc/t42/s300jj–33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300jj–33/f/1","parentIdentifier":"/us/usc/t42/s300jj–33/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Ff%2F1","sourceRelease":"119-100","text":"be designated by the State as eligible to receive awards under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300jj–33/f/2","parentIdentifier":"/us/usc/t42/s300jj–33/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Ff%2F2","sourceRelease":"119-100","text":"be a not-for-profit entity with broad stakeholder representation on its governing board;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300jj–33/f/3","parentIdentifier":"/us/usc/t42/s300jj–33/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Ff%2F3","sourceRelease":"119-100","text":"demonstrate that one of its principal goals is to use information technology to improve health care quality and efficiency through the authorized and secure electronic exchange and use of health information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s300jj–33/f/4","parentIdentifier":"/us/usc/t42/s300jj–33/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Ff%2F4","sourceRelease":"119-100","text":"adopt nondiscrimination and conflict of interest policies that demonstrate a commitment to open, fair, and nondiscriminatory participation by stakeholders; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s300jj–33/f/5","parentIdentifier":"/us/usc/t42/s300jj–33/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Ff%2F5","sourceRelease":"119-100","text":"conform to such other requirements as the Secretary may establish.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Required consultation","label":"g Required consultation","identifier":"/us/usc/t42/s300jj–33/g","parentIdentifier":"/us/usc/t42/s300jj–33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300jj–33/g/1","parentIdentifier":"/us/usc/t42/s300jj–33/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fg%2F1","sourceRelease":"119-100","text":"health care providers (including providers that provide services to low income and underserved populations);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300jj–33/g/2","parentIdentifier":"/us/usc/t42/s300jj–33/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fg%2F2","sourceRelease":"119-100","text":"health plans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300jj–33/g/3","parentIdentifier":"/us/usc/t42/s300jj–33/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fg%2F3","sourceRelease":"119-100","text":"patient or consumer organizations that represent the population to be served;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s300jj–33/g/4","parentIdentifier":"/us/usc/t42/s300jj–33/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fg%2F4","sourceRelease":"119-100","text":"health information technology vendors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s300jj–33/g/5","parentIdentifier":"/us/usc/t42/s300jj–33/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fg%2F5","sourceRelease":"119-100","text":"health care purchasers and employers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s300jj–33/g/6","parentIdentifier":"/us/usc/t42/s300jj–33/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fg%2F6","sourceRelease":"119-100","text":"public health agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s300jj–33/g/7","parentIdentifier":"/us/usc/t42/s300jj–33/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fg%2F7","sourceRelease":"119-100","text":"health professions schools, universities and colleges;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s300jj–33/g/8","parentIdentifier":"/us/usc/t42/s300jj–33/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fg%2F8","sourceRelease":"119-100","text":"clinical researchers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t42/s300jj–33/g/9","parentIdentifier":"/us/usc/t42/s300jj–33/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fg%2F9","sourceRelease":"119-100","text":"other users of health information technology such as the support and clerical staff of providers and others involved in the care and care coordination of patients; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t42/s300jj–33/g/10","parentIdentifier":"/us/usc/t42/s300jj–33/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fg%2F10","sourceRelease":"119-100","text":"such other entities, as may be determined appropriate by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Continuous improvement","label":"h Continuous improvement","identifier":"/us/usc/t42/s300jj–33/h","parentIdentifier":"/us/usc/t42/s300jj–33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fh","sourceRelease":"119-100","text":"The Secretary shall annually evaluate the activities conducted under this section and shall, in awarding grants under this section, implement the lessons learned from such evaluation in a manner so that awards made subsequent to each such evaluation are made in a manner that, in the determination of the Secretary, will lead towards the greatest improvement in quality of care, decrease in costs, and the most effective authorized and secure electronic exchange of health information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Required match","label":"i Required match","identifier":"/us/usc/t42/s300jj–33/i","parentIdentifier":"/us/usc/t42/s300jj–33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s300jj–33/i/1","parentIdentifier":"/us/usc/t42/s300jj–33/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fi%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300jj–33/i/1/A","parentIdentifier":"/us/usc/t42/s300jj–33/i/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fi%2F1%2FA","sourceRelease":"119-100","text":"for fiscal year 2011, not less than $1 for each $10 of Federal funds provided under the grant;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300jj–33/i/1/B","parentIdentifier":"/us/usc/t42/s300jj–33/i/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fi%2F1%2FB","sourceRelease":"119-100","text":"for fiscal year 2012, not less than $1 for each $7 of Federal funds provided under the grant; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300jj–33/i/1/C","parentIdentifier":"/us/usc/t42/s300jj–33/i/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fi%2F1%2FC","sourceRelease":"119-100","text":"for fiscal year 2013 and each subsequent fiscal year, not less than $1 for each $3 of Federal funds provided under the grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Authority to require State match for fiscal years before fiscal year 2011","label":"2 Authority to require State match for fiscal years before fiscal year 2011","identifier":"/us/usc/t42/s300jj–33/i/2","parentIdentifier":"/us/usc/t42/s300jj–33/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300jj%E2%80%9333%2Fi%2F2","sourceRelease":"119-100","text":"For any fiscal year during the grant program under this section before fiscal year 2011, the Secretary may determine the extent to which there shall be required a non-Federal contribution from a State receiving a grant under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
