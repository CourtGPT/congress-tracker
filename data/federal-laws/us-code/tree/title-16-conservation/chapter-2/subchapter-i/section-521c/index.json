{"type":"section","nativeType":"section","number":"521c","heading":"Definitions","label":"521c Definitions","identifier":"/us/usc/t16/s521c","parentIdentifier":"/us/usc/t16/ch2/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs521c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s521c/1","parentIdentifier":"/us/usc/t16/s521c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs521c%2F1","sourceRelease":"119-100","text":"the term “person” includes any State or any political subdivision or entity thereof;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s521c/2","parentIdentifier":"/us/usc/t16/s521c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs521c%2F2","sourceRelease":"119-100","text":"the term “interchange” means a land transfer in which the Secretary and another person exchange titles to lands or interests in lands of approximately equal value where the Secretary finds that such a value determination can be made without a formal appraisal and under such regulations as the Secretary may prescribe; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s521c/3","parentIdentifier":"/us/usc/t16/s521c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs521c%2F3","sourceRelease":"119-100","text":"the term “Secretary” means the Secretary of Agriculture of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
