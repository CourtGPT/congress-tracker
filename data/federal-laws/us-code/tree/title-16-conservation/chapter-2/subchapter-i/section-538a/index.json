ew.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s538a/c/1/A/i/I","parentIdentifier":"/us/usc/t16/s538a/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F1%2FA%2Fi%2FI","sourceRelease":"119-100","text":"to close the road or trail to access; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s538a/c/1/A/i/II","parentIdentifier":"/us/usc/t16/s538a/c/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F1%2FA%2Fi%2FII","sourceRelease":"119-100","text":"to minimize impacts to natural resources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s538a/c/1/A/ii","parentIdentifier":"/us/usc/t16/s538a/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"has closed the road or trail to access as described in clause (i)(I).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Requirement","label":"B Requirement","identifier":"/us/usc/t16/s538a/c/1/B","parentIdentifier":"/us/usc/t16/s538a/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s538a/c/1/B/i","parentIdentifier":"/us/usc/t16/s538a/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"a project described in subsection (b)(2); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s538a/c/1/B/ii","parentIdentifier":"/us/usc/t16/s538a/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"a project carried out on a watershed for which the Secretary has entered into a cooperative agreement under .section 1011a of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Annual selection of projects for funding","label":"2 Annual selection of projects for funding","identifier":"/us/usc/t16/s538a/c/2","parentIdentifier":"/us/usc/t16/s538a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s538a/c/2/A","parentIdentifier":"/us/usc/t16/s538a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F2%2FA","sourceRelease":"119-100","text":"establish a process for annually selecting projects for funding under the Program, consistent with the requirements of this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s538a/c/2/B","parentIdentifier":"/us/usc/t16/s538a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F2%2FB","sourceRelease":"119-100","text":"solicit and consider public input regionally in the ranking of projects for funding under the Program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s538a/c/2/C","parentIdentifier":"/us/usc/t16/s538a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s538a/c/2/C/i","parentIdentifier":"/us/usc/t16/s538a/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F2%2FC%2Fi","sourceRelease":"119-100","text":"protect or improve water quality in public drinking water source areas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s538a/c/2/C/ii","parentIdentifier":"/us/usc/t16/s538a/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F2%2FC%2Fii","sourceRelease":"119-100","text":"restore the habitat of a threatened, endangered, or sensitive fish or wildlife species; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s538a/c/2/C/iii","parentIdentifier":"/us/usc/t16/s538a/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F2%2FC%2Fiii","sourceRelease":"119-100","text":"maintain future access to the adjacent area for the public, contractors, permittees, or firefighters; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s538a/c/2/D","parentIdentifier":"/us/usc/t16/s538a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s538a/c/2/D/i","parentIdentifier":"/us/usc/t16/s538a/c/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F2%2FD%2Fi","sourceRelease":"119-100","text":"the selection process established under subparagraph (A); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s538a/c/2/D/ii","parentIdentifier":"/us/usc/t16/s538a/c/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fc%2F2%2FD%2Fii","sourceRelease":"119-100","text":"a list that includes a description and the proposed outcome of each project funded under the Program in each fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Implementation","label":"d Implementation","identifier":"/us/usc/t16/s538a/d","parentIdentifier":"/us/usc/t16/s538a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s538a/d/1","parentIdentifier":"/us/usc/t16/s538a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s538a/d/1/A","parentIdentifier":"/us/usc/t16/s538a/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fd%2F1%2FA","sourceRelease":"119-100","text":"is adequate to meet any increasing demands for timber, recreation, and other uses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s538a/d/1/B","parentIdentifier":"/us/usc/t16/s538a/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fd%2F1%2FB","sourceRelease":"119-100","text":"provides for intensive use, protection, development, and management of the land under principles of multiple use and sustained yield of products and services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s538a/d/1/C","parentIdentifier":"/us/usc/t16/s538a/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fd%2F1%2FC","sourceRelease":"119-100","text":"does not damage, degrade, or impair adjacent resources, including aquatic and wildlife resources, to the extent practicable;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s538a/d/1/D","parentIdentifier":"/us/usc/t16/s538a/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fd%2F1%2FD","sourceRelease":"119-100","text":"reflects long-term funding expectations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s538a/d/1/E","parentIdentifier":"/us/usc/t16/s538a/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fd%2F1%2FE","sourceRelease":"119-100","text":"is adequate for supporting emergency operations, such as evacuation routes during wildfires, floods, and other natural disasters; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s538a/d/2","parentIdentifier":"/us/usc/t16/s538a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fd%2F2","sourceRelease":"119-100","text":"all projects funded under the Program are consistent with any applicable forest plan or travel management plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Savings clause","label":"e Savings clause","identifier":"/us/usc/t16/s538a/e","parentIdentifier":"/us/usc/t16/s538a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fe","sourceRelease":"119-100","text":"A decision to fund a project under the Program shall not affect any determination made previously or to be made in the future by the Secretary with regard to road or trail closures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
