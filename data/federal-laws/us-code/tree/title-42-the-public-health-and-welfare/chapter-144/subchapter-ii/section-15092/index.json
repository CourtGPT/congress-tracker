{"type":"section","nativeType":"section","number":"15092","heading":"Definitions and special rule","label":"15092 Definitions and special rule","identifier":"/us/usc/t42/s15092","parentIdentifier":"/us/usc/t42/ch144/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s15092/a","parentIdentifier":"/us/usc/t42/s15092","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Child with a disability","label":"1 Child with a disability","identifier":"/us/usc/t42/s15092/a/1","parentIdentifier":"/us/usc/t42/s15092/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15092/a/1/A","parentIdentifier":"/us/usc/t42/s15092/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F1%2FA","sourceRelease":"119-100","text":"has a significant physical or mental impairment, as defined pursuant to State policy to the extent that such policy is established without regard to type of disability; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15092/a/1/B","parentIdentifier":"/us/usc/t42/s15092/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F1%2FB","sourceRelease":"119-100","text":"is an infant or a young child from birth through age 8 and has a substantial developmental delay or specific congenital or acquired condition that presents a high probability of resulting in a disability if services are not provided to the infant or child.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Family","label":"2 Family","identifier":"/us/usc/t42/s15092/a/2","parentIdentifier":"/us/usc/t42/s15092/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s15092/a/2/A","parentIdentifier":"/us/usc/t42/s15092/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F2%2FA","sourceRelease":"119-100","text":"Subject to subparagraph (B), for purposes of the application of this subchapter in a State, the term “family” has the meaning given the term by the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exclusion of employees","label":"B Exclusion of employees","identifier":"/us/usc/t42/s15092/a/2/B","parentIdentifier":"/us/usc/t42/s15092/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F2%2FB","sourceRelease":"119-100","text":"The term does not include an employee who, acting in a paid employment capacity, provides services to a child with a disability in an out-of-home setting such as a hospital, nursing home, personal care home, board and care home, group home, or other facility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Family support for families of children with disabilities","label":"3 Family support for families of children with disabilities","identifier":"/us/usc/t42/s15092/a/3","parentIdentifier":"/us/usc/t42/s15092/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15092/a/3/A","parentIdentifier":"/us/usc/t42/s15092/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F3%2FA","sourceRelease":"119-100","text":"support families in the efforts of such families to raise their children with disabilities in the home;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15092/a/3/B","parentIdentifier":"/us/usc/t42/s15092/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F3%2FB","sourceRelease":"119-100","text":"strengthen the role of the family as primary caregiver for such children;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s15092/a/3/C","parentIdentifier":"/us/usc/t42/s15092/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F3%2FC","sourceRelease":"119-100","text":"prevent involuntary out-of-the-home placement of such children and maintain family unity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s15092/a/3/D","parentIdentifier":"/us/usc/t42/s15092/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F3%2FD","sourceRelease":"119-100","text":"reunite families with children with disabilities who have been placed out of the home, whenever possible.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Secretary","label":"4 Secretary","identifier":"/us/usc/t42/s15092/a/4","parentIdentifier":"/us/usc/t42/s15092/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F4","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Health and Human Services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"State","label":"5 State","identifier":"/us/usc/t42/s15092/a/5","parentIdentifier":"/us/usc/t42/s15092/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F5","sourceRelease":"119-100","text":"The term “State” means each of the 50 States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Systems change activities","label":"6 Systems change activities","identifier":"/us/usc/t42/s15092/a/6","parentIdentifier":"/us/usc/t42/s15092/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15092/a/6/A","parentIdentifier":"/us/usc/t42/s15092/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F6%2FA","sourceRelease":"119-100","text":"that are family-centered and family-directed;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15092/a/6/B","parentIdentifier":"/us/usc/t42/s15092/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F6%2FB","sourceRelease":"119-100","text":"that facilitate and increase access to, provision of, and funding for, family support services for families of children with disabilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s15092/a/6/C","parentIdentifier":"/us/usc/t42/s15092/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fa%2F6%2FC","sourceRelease":"119-100","text":"that otherwise accomplish the purposes of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Special rule","label":"b Special rule","identifier":"/us/usc/t42/s15092/b","parentIdentifier":"/us/usc/t42/s15092","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15092/b/1","parentIdentifier":"/us/usc/t42/s15092/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fb%2F1","sourceRelease":"119-100","text":"has a significant impairment described in subsection (a)(1)(A); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15092/b/2","parentIdentifier":"/us/usc/t42/s15092/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15092%2Fb%2F2","sourceRelease":"119-100","text":"is residing with and receiving assistance from a family member.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
