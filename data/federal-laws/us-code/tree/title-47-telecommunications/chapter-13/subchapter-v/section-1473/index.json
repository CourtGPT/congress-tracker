{"type":"section","nativeType":"section","number":"1473","heading":"Commission proceeding on autodialing","label":"1473 Commission proceeding on autodialing","identifier":"/us/usc/t47/s1473","parentIdentifier":"/us/usc/t47/ch13/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1473","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t47/s1473/a","parentIdentifier":"/us/usc/t47/s1473","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1473%2Fa","sourceRelease":"119-100","text":"Not later than 90 days after , the Commission shall initiate a proceeding to create a specialized Do-Not-Call registry for public safety answering points.February 22, 2012","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Features of the registry","label":"b Features of the registry","identifier":"/us/usc/t47/s1473/b","parentIdentifier":"/us/usc/t47/s1473","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1473%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s1473/b/1","parentIdentifier":"/us/usc/t47/s1473/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1473%2Fb%2F1","sourceRelease":"119-100","text":"permit verified public safety answering point administrators or managers to register the telephone numbers of all 9–1–1 trunks and other lines used for the provision of emergency services to the public or for communications between public safety agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s1473/b/2","parentIdentifier":"/us/usc/t47/s1473/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1473%2Fb%2F2","sourceRelease":"119-100","text":"provide a process for verifying, no less frequently than once every 7 years, that registered numbers should continue to appear upon the registry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t47/s1473/b/3","parentIdentifier":"/us/usc/t47/s1473/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1473%2Fb%2F3","sourceRelease":"119-100","text":"provide a process for granting and tracking access to the registry by the operators of automatic dialing equipment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t47/s1473/b/4","parentIdentifier":"/us/usc/t47/s1473/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1473%2Fb%2F4","sourceRelease":"119-100","text":"protect the list of registered numbers from disclosure or dissemination by parties granted access to the registry; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t47/s1473/b/5","parentIdentifier":"/us/usc/t47/s1473/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1473%2Fb%2F5","sourceRelease":"119-100","text":"prohibit the use of automatic dialing or “robocall” equipment to establish contact with registered numbers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Enforcement","label":"c Enforcement","identifier":"/us/usc/t47/s1473/c","parentIdentifier":"/us/usc/t47/s1473","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1473%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s1473/c/1","parentIdentifier":"/us/usc/t47/s1473/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1473%2Fc%2F1","sourceRelease":"119-100","text":"establish monetary penalties for violations of the protective regulations established pursuant to subsection (b)(4) of not less than $100,000 per incident nor more than $1,000,000 per incident;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s1473/c/2","parentIdentifier":"/us/usc/t47/s1473/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1473%2Fc%2F2","sourceRelease":"119-100","text":"establish monetary penalties for violations of the prohibition on automatically dialing registered numbers established pursuant to subsection (b)(5) of not less than $10,000 per call nor more than $100,000 per call; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t47/s1473/c/3","parentIdentifier":"/us/usc/t47/s1473/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1473%2Fc%2F3","sourceRelease":"119-100","text":"provide for the imposition of fines under paragraphs (1) or (2) that vary depending upon whether the conduct leading to the violation was negligent, grossly negligent, reckless, or willful, and depending on whether the violation was a first or subsequent offence.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
