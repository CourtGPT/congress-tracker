{"type":"section","nativeType":"section","number":"4145a","heading":"Program authority","label":"4145a Program authority","identifier":"/us/usc/t25/s4145a","parentIdentifier":"/us/usc/t25/ch43/schII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4145a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definition of qualifying Indian tribe","label":"a Definition of qualifying Indian tribe","identifier":"/us/usc/t25/s4145a/a","parentIdentifier":"/us/usc/t25/s4145a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4145a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4145a/a/1","parentIdentifier":"/us/usc/t25/s4145a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4145a%2Fa%2F1","sourceRelease":"119-100","text":"to or on behalf of which a grant is made under ;section 4111 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4145a/a/2","parentIdentifier":"/us/usc/t25/s4145a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4145a%2Fa%2F2","sourceRelease":"119-100","text":"that has complied with the requirements of section 4112(b)(6) of this title; and1So in original. does not contain a par. (6).1Section 4112(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s4145a/a/3","parentIdentifier":"/us/usc/t25/s4145a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4145a%2Fa%2F3","sourceRe