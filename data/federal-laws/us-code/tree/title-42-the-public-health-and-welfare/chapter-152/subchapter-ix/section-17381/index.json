{"type":"section","nativeType":"section","number":"17381","heading":"Statement of policy on modernization of electricity grid","label":"17381 Statement of policy on modernization of electricity grid","identifier":"/us/usc/t42/s17381","parentIdentifier":"/us/usc/t42/ch152/schIX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17381","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2"],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17381/1","parentIdentifier":"/us/usc/t42/s17381","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17381%2F1","sourceRelease":"119-100","text":"Increased use of digital information and controls technology to improve reliability, security, and efficiency of the electric grid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17381/2","parentIdentifier":"/us/usc/t42/s17381","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17381%2F2","sourceRelease":"119-100","text":"Dynamic optimization of grid operations and resources, with full cyber-security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17381/3","parentIdentifier":"/us/usc/t42/s17381","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17381%2F3","sourceRelease":"119-100","text":"Deployment and integration of distributed resources and generation, including renewable resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17381/4","parentIdentifier":"/us/usc/t42/s17381","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17381%2F4","sourceRelease":"119-100","text":"Development and incorporation of demand response, demand-side resources, and energy-efficiency resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s17381/5","parentIdentifier":"/us/usc/t42/s17381","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17381%2F5","sourceRelease":"119-100","text":"Deployment of “smart” technologies (real-time, automated, interactive technologies that optimize the physical operation of appliances and consumer devices) for metering, communications concerning grid operations and status, and distribution automation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s17381/6","parentIdentifier":"/us/usc/t42/s17381","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17381%2F6","sourceRelease":"119-100","text":"Integration of “smart” appliances and consumer devices.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s17381/7","parentIdentifier":"/us/usc/t42/s17381","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17381%2F7","sourceRelease":"119-100","text":"Deployment and integration of advanced electricity storage and peak-shaving technologies, including plug-in electric and hybrid electric vehicles, and thermal-storage air conditioning.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s17381/8","parentIdentifier":"/us/usc/t42/s17381","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17381%2F8","sourceRelease":"119-100","text":"Provision to consumers of timely information and control options.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t42/s17381/9","parentIdentifier":"/us/usc/t42/s17381","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17381%2F9","sourceRelease":"119-100","text":"Development of standards for communication and interoperability of appliances and equipment connected to the electric grid, including the infrastructure serving the grid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t42/s17381/10","parentIdentifier":"/us/usc/t42/s17381","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17381%2F10","sourceRelease":"119-100","text":"Identification and lowering of unreasonable or unnecessary barriers to adoption of smart grid technologies, practices, and services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
