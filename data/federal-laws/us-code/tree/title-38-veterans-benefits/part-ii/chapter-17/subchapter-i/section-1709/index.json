{"type":"section","nativeType":"section","number":"1709","heading":"Comprehensive policy on reporting and tracking sexual assault incidents and other safety incidents","label":"1709 Comprehensive policy on reporting and tracking sexual assault incidents and other safety incidents","identifier":"/us/usc/t38/s1709","parentIdentifier":"/us/usc/t38/ptII/ch17/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Policy Required","label":"a .—Policy Required","identifier":"/us/usc/t38/s1709/a","parentIdentifier":"/us/usc/t38/s1709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1709/a/1","parentIdentifier":"/us/usc/t38/s1709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1709/a/1/A","parentIdentifier":"/us/usc/t38/s1709/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fa%2F1%2FA","sourceRelease":"119-100","text":"suspected, alleged, attempted, or confirmed cases of sexual assault, regardless of whether such assaults lead to prosecution or conviction;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1709/a/1/B","parentIdentifier":"/us/usc/t38/s1709/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fa%2F1%2FB","sourceRelease":"119-100","text":"criminal and purposefully unsafe acts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s1709/a/1/C","parentIdentifier":"/us/usc/t38/s1709/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fa%2F1%2FC","sourceRelease":"119-100","text":"alcohol or substance abuse related acts (including by employees of the Department); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t38/s1709/a/1/D","parentIdentifier":"/us/usc/t38/s1709/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fa%2F1%2FD","sourceRelease":"119-100","text":"any kind of event involving alleged or suspected abuse of a patient.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1709/a/2","parentIdentifier":"/us/usc/t38/s1709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1709/a/2/A","parentIdentifier":"/us/usc/t38/s1709/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the use by veterans of mental health care and substance abuse treatments; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1709/a/2/B","parentIdentifier":"/us/usc/t38/s1709/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the ability of the Department to refer veterans to such care or treatment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Scope","label":"b .—Scope","identifier":"/us/usc/t38/s1709/b","parentIdentifier":"/us/usc/t38/s1709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1709/b/1","parentIdentifier":"/us/usc/t38/s1709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1709/b/1/A","parentIdentifier":"/us/usc/t38/s1709/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F1%2FA","sourceRelease":"119-100","text":"“safety incident”;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1709/b/1/B","parentIdentifier":"/us/usc/t38/s1709/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F1%2FB","sourceRelease":"119-100","text":"“sexual assault”; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s1709/b/1/C","parentIdentifier":"/us/usc/t38/s1709/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F1%2FC","sourceRelease":"119-100","text":"“sexual assault incident”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1709/b/2","parentIdentifier":"/us/usc/t38/s1709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1709/b/2/A","parentIdentifier":"/us/usc/t38/s1709/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t38/s1709/b/2/A/i","parentIdentifier":"/us/usc/t38/s1709/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the legal history of the veteran; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t38/s1709/b/2/A/ii","parentIdentifier":"/us/usc/t38/s1709/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the medical record of the veteran.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1709/b/2/B","parentIdentifier":"/us/usc/t38/s1709/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F2%2FB","sourceRelease":"119-100","text":"In developing and using tools under subparagraph (A), the Secretary shall consider the effects of using such tools on the use by veterans of health care furnished by the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1709/b/3","parentIdentifier":"/us/usc/t38/s1709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F3","sourceRelease":"119-100","text":"The mandatory training of employees of the Department on security issues, including awareness, preparedness, precautions, and police assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s1709/b/4","parentIdentifier":"/us/usc/t38/s1709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F4","sourceRelease":"119-100","text":"The mandatory implementation, use, and regular testing of appropriate physical security precautions and equipment, including surveillance camera systems, computer-based panic alarm systems, stationary panic alarms, and electronic portable personal panic alarms.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t38/s1709/b/5","parentIdentifier":"/us/usc/t38/s1709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1709/b/5/A","parentIdentifier":"/us/usc/t38/s1709/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F5%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t38/s1709/b/5/A/i","parentIdentifier":"/us/usc/t38/s1709/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F5%2FA%2Fi","sourceRelease":"119-100","text":"a medical facility of the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t38/s1709/b/5/A/ii","parentIdentifier":"/us/usc/t38/s1709/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F5%2FA%2Fii","sourceRelease":"119-100","text":"an office of a Veterans Integrated Service Network; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t38/s1709/b/5/A/iii","parentIdentifier":"/us/usc/t38/s1709/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F5%2FA%2Fiii","sourceRelease":"119-100","text":"the central office of the Veterans Health Administration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1709/b/5/B","parentIdentifier":"/us/usc/t38/s1709/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F5%2FB","sourceRelease":"119-100","text":"a law enforcement official of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t38/s1709/b/6","parentIdentifier":"/us/usc/t38/s1709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F6","sourceRelease":"119-100","text":"Clear and consistent criteria and guidelines with respect to an employee of the Department referring and reporting to the Office of Inspector General of the Department sexual assault incidents and other safety incidents that meet the regulatory criminal threshold prescribed under sections 901 and 902 of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t38/s1709/b/7","parentIdentifier":"/us/usc/t38/s1709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1709/b/7/A","parentIdentifier":"/us/usc/t38/s1709/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F7%2FA","sourceRelease":"119-100","text":"systematic information sharing of reported sexual assault incidents and other safety incidents among officials of the Administration who have programmatic responsibility; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1709/b/7/B","parentIdentifier":"/us/usc/t38/s1709/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F7%2FB","sourceRelease":"119-100","text":"a centralized reporting, tracking, and monitoring system for such incidents.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t38/s1709/b/8","parentIdentifier":"/us/usc/t38/s1709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F8","sourceRelease":"119-100","text":"Consistent procedures and systems for law enforcement officials of the Department with respect to investigating, tracking, and closing reported sexual assault incidents and other safety incidents.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t38/s1709/b/9","parentIdentifier":"/us/usc/t38/s1709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fb%2F9","sourceRelease":"119-100","text":"Clear and consistent guidance for the clinical management of the treatment of sexual assaults that are reported more than 72 hours after the assault.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Updates to Policy","label":"c .—Updates to Policy","identifier":"/us/usc/t38/s1709/c","parentIdentifier":"/us/usc/t38/s1709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fc","sourceRelease":"119-100","text":"The Secretary shall review and revise the policy required by subsection (a) on a periodic basis as the Secretary considers appropriate and in accordance with best practices.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Annual Report","label":"d .—Annual Report","identifier":"/us/usc/t38/s1709/d","parentIdentifier":"/us/usc/t38/s1709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1709/d/1","parentIdentifier":"/us/usc/t38/s1709/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fd%2F1","sourceRelease":"119-100","text":"Not later than 60 days after the date on which the Secretary develops the policy required by subsection (a) and not later than October 1 of each year thereafter, the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report on the implementation of the policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1709/d/2","parentIdentifier":"/us/usc/t38/s1709/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1709/d/2/A","parentIdentifier":"/us/usc/t38/s1709/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fd%2F2%2FA","sourceRelease":"119-100","text":"the number and type of sexual assault incidents and other safety incidents reported by each medical facility of the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1709/d/2/B","parentIdentifier":"/us/usc/t38/s1709/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fd%2F2%2FB","sourceRelease":"119-100","text":"a detailed description of the implementation of the policy required by subsection (a), including any revisions made to such policy from the previous year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s1709/d/2/C","parentIdentifier":"/us/usc/t38/s1709/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709%2Fd%2F2%2FC","sourceRelease":"119-100","text":"the effectiveness of such policy on improving the safety and security of the medical facilities of the Department, including the performance measures used to evaluate such effectiveness.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
