{"type":"section","nativeType":"section","number":"3732","heading":"Requirement for on-site managers","label":"3732 Requirement for on-site managers","identifier":"/us/usc/t50/s3732","parentIdentifier":"/us/usc/t50/ch48/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"On-site manager requirement","label":"a On-site manager requirement","identifier":"/us/usc/t50/s3732/a","parentIdentifier":"/us/usc/t50/s3732","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fa","sourceRelease":"119-100","text":"Before obligating any Cooperative Threat Reduction funds for a project described in subsection (b), the Secretary of Defense shall appoint one on-site manager for that project. The manager shall be appointed from among employees of the Federal Government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Projects covered","label":"b Projects covered","identifier":"/us/usc/t50/s3732/b","parentIdentifier":"/us/usc/t50/s3732","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3732/b/1","parentIdentifier":"/us/usc/t50/s3732/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fb%2F1","sourceRelease":"119-100","text":"to be located in a state of the former Soviet Union;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3732/b/2","parentIdentifier":"/us/usc/t50/s3732/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fb%2F2","sourceRelease":"119-100","text":"which involves dismantlement, destruction, or storage facilities, or construction of a facility; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s3732/b/3","parentIdentifier":"/us/usc/t50/s3732/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fb%2F3","sourceRelease":"119-100","text":"with respect to which the total contribution by the Department of Defense is expected to exceed $50,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duties of on-site manager","label":"c Duties of on-site manager","identifier":"/us/usc/t50/s3732/c","parentIdentifier":"/us/usc/t50/s3732","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3732/c/1","parentIdentifier":"/us/usc/t50/s3732/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fc%2F1","sourceRelease":"119-100","text":"develop, in cooperation with representatives from governments of states participating in the project, a list of those steps or activities critical to achieving the disarmament or nonproliferation goals of the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3732/c/2","parentIdentifier":"/us/usc/t50/s3732/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fc%2F2","sourceRelease":"119-100","text":"establish a schedule for completing those steps or activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s3732/c/3","parentIdentifier":"/us/usc/t50/s3732/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fc%2F3","sourceRelease":"119-100","text":"meet with all participants to seek assurances that those steps or activities are being completed on schedule; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t50/s3732/c/4","parentIdentifier":"/us/usc/t50/s3732/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fc%2F4","sourceRelease":"119-100","text":"suspend the participation of the United States in a project when a participant other than the United States fails to complete a scheduled step or activity on time, unless the Secretary of Defense directs the on-site manager to resume the participation of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authority to manage more than one project","label":"d Authority to manage more than one project","identifier":"/us/usc/t50/s3732/d","parentIdentifier":"/us/usc/t50/s3732","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t50/s3732/d/1","parentIdentifier":"/us/usc/t50/s3732/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fd%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2), an employee of the Federal Government may serve as on-site manager for more than one project, including projects at different locations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitation","label":"2 Limitation","identifier":"/us/usc/t50/s3732/d/2","parentIdentifier":"/us/usc/t50/s3732/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fd%2F2","sourceRelease":"119-100","text":"If such an employee serves as on-site manager for more than one project in a fiscal year, the total cost of the projects for that fiscal year may not exceed $150,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Steps or activities","label":"e Steps or activities","identifier":"/us/usc/t50/s3732/e","parentIdentifier":"/us/usc/t50/s3732","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3732/e/1","parentIdentifier":"/us/usc/t50/s3732/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fe%2F1","sourceRelease":"119-100","text":"Identification and acquisition of permits (as defined in ).section 3733 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3732/e/2","parentIdentifier":"/us/usc/t50/s3732/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fe%2F2","sourceRelease":"119-100","text":"Verification that the items, substances, or capabilities to be dismantled, secured, or otherwise modified are available for dismantlement, securing, or modification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s3732/e/3","parentIdentifier":"/us/usc/t50/s3732/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Fe%2F3","sourceRelease":"119-100","text":"Timely provision of financial, personnel, management, transportation, and other resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Notification to Congress","label":"f Notification to Congress","identifier":"/us/usc/t50/s3732/f","parentIdentifier":"/us/usc/t50/s3732","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3732%2Ff","sourceRelease":"119-100","text":"In any case in which the Secretary directs an on-site manager to resume the participation of the United States in a project under subsection (c)(4), the Secretary shall notify the congressional defense committees of such direction by not later than 30 days after the date of such direction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
