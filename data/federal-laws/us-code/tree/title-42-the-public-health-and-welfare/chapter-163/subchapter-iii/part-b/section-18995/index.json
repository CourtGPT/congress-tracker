{"type":"section","nativeType":"section","number":"18995","heading":"Cyber workforce development research and development","label":"18995 Cyber workforce development research and development","identifier":"/us/usc/t42/s18995","parentIdentifier":"/us/usc/t42/ch163/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18995","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s18995/a","parentIdentifier":"/us/usc/t42/s18995","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18995%2Fa","sourceRelease":"119-100","text":"The Director shall make awards on a merit-reviewed, competitive basis to institutions of higher education or nonprofit organizations (or consortia of such institutions or organizations) to carry out research on the cyber workforce.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Research","label":"b Research","identifier":"/us/usc/t42/s18995/b","parentIdentifier":"/us/usc/t42/s18995","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18995%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18995/b/1","parentIdentifier":"/us/usc/t42/s18995/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18995%2Fb%2F1","sourceRelease":"119-100","text":"understand the current state of the cyber workforce, including factors that influence growth, retention, and development of that workforce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18995/b/2","parentIdentifier":"/us/usc/t42/s18995/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18995%2Fb%2F2","sourceRelease":"119-100","text":"examine paths to entry and re-entry into the cyber workforce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18995/b/3","parentIdentifier":"/us/usc/t42/s18995/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18995%2Fb%2F3","sourceRelease":"119-100","text":"understand trends of the cyber workforce, including demographic representation, educational and professional backgrounds present, competencies available, and factors that shape employee recruitment, development, and retention and how to increase the size, diversity, and capability of the cyber workforce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18995/b/4","parentIdentifier":"/us/usc/t42/s18995/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18995%2Fb%2F4","sourceRelease":"119-100","text":"examine and evaluate training practices, models, programs, and technologies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s18995/b/5","parentIdentifier":"/us/usc/t42/s18995/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18995%2Fb%2F5","sourceRelease":"119-100","text":"other closely related topics as the Director determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Requirements","label":"c Requirements","identifier":"/us/usc/t42/s18995/c","parentIdentifier":"/us/usc/t42/s18995","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18995%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18995/c/1","parentIdentifier":"/us/usc/t42/s18995/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18995%2Fc%2F1","sourceRelease":"119-100","text":"collaborate with the National Institute of Standards and Technology, including the National Initiative for Cybersecurity Education, the Department of Homeland Security, the Department of Defense, the Office of Personnel Management, and other Federal departments and agencies, as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18995/c/2","parentIdentifier":"/us/usc/t42/s18995/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18995%2Fc%2F2","sourceRelease":"119-100","text":"align with or build on the National Initiative on Cybersecurity Education Cybersecurity Workforce Framework wherever practicable and applicable;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18995/c/3","parentIdentifier":"/us/usc/t42/s18995/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18995%2Fc%2F3","sourceRelease":"119-100","text":"leverage the collective body of knowledge from existing cyber workforce development research and education activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18995/c/4","parentIdentifier":"/us/usc/t42/s18995/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18995%2Fc%2F4","sourceRelease":"119-100","text":"engage with other Federal departments and agencies, research communities, and potential users of information produced under this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
