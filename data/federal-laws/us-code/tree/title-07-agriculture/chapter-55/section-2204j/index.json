{"type":"section","nativeType":"section","number":"2204j","heading":"National agriculture imagery program","label":"2204j National agriculture imagery program","identifier":"/us/usc/t7/s2204j","parentIdentifier":"/us/usc/t7/ch55","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204j","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t7/s2204j/a","parentIdentifier":"/us/usc/t7/s2204j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204j%2Fa","sourceRelease":"119-100","text":"The Secretary of Agriculture, acting through the Administrator of the Farm Service Agency, shall carry out a national agriculture imagery program to annually acquire aerial imagery during agricultural growing seasons from the continental United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Data","label":"b Data","identifier":"/us/usc/t7/s2204j/b","parentIdentifier":"/us/usc/t7/s2204j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204j%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2204j/b/1","parentIdentifier":"/us/usc/t7/s2204j/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204j%2Fb%2F1","sourceRelease":"119-100","text":"consist of high resolution processed digital imagery;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2204j/b/2","parentIdentifier":"/us/usc/t7/s2204j/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204j%2Fb%2F2","sourceRelease":"119-100","text":"be made available in a format that can be provided to Federal, State, and private sector entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s2204j/b/3","parentIdentifier":"/us/usc/t7/s2204j/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204j%2Fb%2F3","sourceRelease":"119-100","text":"be technologically compatible with geospatial information technology; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s2204j/b/4","parentIdentifier":"/us/usc/t7/s2204j/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204j%2Fb%2F4","sourceRelease":"119-100","text":"be consistent with the standards established by the Federal Geographic Data Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Supplemental satellite imagery","label":"c Supplemental satellite imagery","identifier":"/us/usc/t7/s2204j/c","parentIdentifier":"/us/usc/t7/s2204j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204j%2Fc","sourceRelease":"119-100","text":"The Secretary of Agriculture may supplement the aerial imagery collected under this section with satellite imagery.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t7/s2204j/d","parentIdentifier":"/us/usc/t7/s2204j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2204j%2Fd","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $23,000,000 for fiscal year 2019 and each fiscal year thereafter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
