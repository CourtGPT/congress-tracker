{"type":"section","nativeType":"section","number":"6012","heading":"Suspension or termination of plan","label":"6012 Suspension or termination of plan","identifier":"/us/usc/t7/s6012","parentIdentifier":"/us/usc/t7/ch89","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6012","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Mandatory suspension or termination","label":"a Mandatory suspension or termination","identifier":"/us/usc/t7/s6012/a","parentIdentifier":"/us/usc/t7/s6012","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6012%2Fa","sourceRelease":"119-100","text":"The Secretary shall, whenever the Secretary finds that the plan or any provision of the plan obstructs or does not tend to effectuate the declared policy of this chapter, terminate or suspend the operation of such plan or provision.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Suspension or termination","label":"b Suspension or termination","identifier":"/us/usc/t7/s6012/b","parentIdentifier":"/us/usc/t7/s6012","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6012%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s6012/b/1","parentIdentifier":"/us/usc/t7/s6012/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6012%2Fb%2F1","sourceRelease":"119-100","text":"within 6 months after making such determination, suspend or terminate, as the case may be, collection of assessments under the plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s6012/b/2","parentIdentifier":"/us/usc/t7/s6012/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6012%2Fb%2F2","sourceRelease":"119-100","text":"suspend or terminate, as the case may be, activities under the plan in an orderly manner as soon as practicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Limitation","label":"c Limitation","identifier":"/us/usc/t7/s6012/c","parentIdentifier":"/us/usc/t7/s6012","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6012%2Fc","sourceRelease":"119-100","text":"The termination or suspension of any plan, or any provision thereof, shall not be considered a plan within the meaning of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
