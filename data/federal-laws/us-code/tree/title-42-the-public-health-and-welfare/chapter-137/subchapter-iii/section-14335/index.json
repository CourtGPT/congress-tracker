{"type":"section","nativeType":"section","number":"14335","heading":"Limitations on sale of other mercuric-oxide batteries","label":"14335 Limitations on sale of other mercuric-oxide batteries","identifier":"/us/usc/t42/s14335","parentIdentifier":"/us/usc/t42/ch137/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14335","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Prohibition","label":"a Prohibition","identifier":"/us/usc/t42/s14335/a","parentIdentifier":"/us/usc/t42/s14335","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14335%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s14335/a/1","parentIdentifier":"/us/usc/t42/s14335/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14335%2Fa%2F1","sourceRelease":"119-100","text":"identifies a collection site in the United States that has all required Federal, State, and local government approvals, to which persons may send used mercuric-oxide batteries for recycling or proper disposal;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s14335/a/2","parentIdentifier":"/us/usc/t42/s14335/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14335%2Fa%2F2","sourceRelease":"119-100","text":"informs each of its purchasers of mercuric-oxide batteries of the collection site identified under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s14335/a/3","parentIdentifier":"/us/usc/t42/s14335/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14335%2Fa%2F3","sourceRelease":"119-100","text":"informs each of its purchasers of mercuric-oxide batteries of a telephone number that the purchaser may call to get information about sending mercuric-oxide batteries for recycling or proper disposal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Application of section","label":"b Application of section","identifier":"/us/usc/t42/s14335/b","parentIdentifier":"/us/usc/t42/s14335","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14335%2Fb","sourceRelease":"119-100","text":"This section does not apply to a sale or offer of a mercuric-oxide button cell battery.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
