{"type":"section","nativeType":"section","number":"460lll–31","heading":"Trust Fund","label":"460lll–31 Trust Fund","identifier":"/us/usc/t16/s460lll–31","parentIdentifier":"/us/usc/t16/ch1/schCXXIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9331","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t16/s460lll–31/a","parentIdentifier":"/us/usc/t16/s460lll–31","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9331%2Fa","sourceRelease":"119-100","text":"There is established in the Treasury of the United States a special interest-bearing fund known as the “Land Between the Lakes Trust Fund”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Availability","label":"b Availability","identifier":"/us/usc/t16/s460lll–31/b","parentIdentifier":"/us/usc/t16/s460lll–31","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9331%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460lll–31/b/1","parentIdentifier":"/us/usc/t16/s460lll–31/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9331%2Fb%2F1","sourceRelease":"119-100","text":"public education, grants, and internships related to recreation, conservation, and multiple use land management in the Recreation Area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460lll–31/b/2","parentIdentifier":"/us/usc/t16/s460lll–31/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9331%2Fb%2F2","sourceRelease":"119-100","text":"regional promotion in the Recreation Area, in cooperation with development districts, chambers of commerce, and State and local governments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Deposits","label":"c Deposits","identifier":"/us/usc/t16/s460lll–31/c","parentIdentifier":"/us/usc/t16/s460lll–31","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9331%2Fc","sourceRelease":"119-100","text":"The Tennessee Valley Authority shall deposit into the Fund $1,000,000 annually for each of the 5 fiscal years commencing in the first fiscal year of the transfer. Funding to carry out this section shall be derived from funding described in section 460–49 of this title.lll","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
