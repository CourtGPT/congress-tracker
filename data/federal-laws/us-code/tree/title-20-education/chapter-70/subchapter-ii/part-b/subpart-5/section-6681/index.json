{"type":"section","nativeType":"section","number":"6681","heading":"Findings","label":"6681 Findings","identifier":"/us/usc/t20/s6681","parentIdentifier":"/us/usc/t20/ch70/schII/ptB/spt5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6681","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Recognizing Achievement in Classified School Employees Act, and not as part of the Elementary and Secondary Education Act of 1965 which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s6681/1","parentIdentifier":"/us/usc/t20/s6681","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6681%2F1","sourceRelease":"119-100","text":"Classified school employees provide valuable service in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s6681/2","parentIdentifier":"/us/usc/t20/s6681","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6681%2F2","sourceRelease":"119-100","text":"Classified school employees provide essential services, such as transportation, facilities maintenance and operations, food service, safety, and health care.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s6681/3","parentIdentifier":"/us/usc/t20/s6681","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6681%2F3","sourceRelease":"119-100","text":"Classified school employees play a vital role in providing for the welfare and safety of students.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s6681/4","parentIdentifier":"/us/usc/t20/s6681","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6681%2F4","sourceRelease":"119-100","text":"Classified school employees strive for excellence in all areas of service to the education community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t20/s6681/5","parentIdentifier":"/us/usc/t20/s6681","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6681%2F5","sourceRelease":"119-100","text":"Exemplary classified school employees should be recognized for their outstanding contributions to quality education in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
