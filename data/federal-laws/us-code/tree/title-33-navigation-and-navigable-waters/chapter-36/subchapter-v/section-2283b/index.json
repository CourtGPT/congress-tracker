agraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s2283b/a/2/A","parentIdentifier":"/us/usc/t33/s2283b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2283b%2Fa%2F2%2FA","sourceRelease":"119-100","text":"feasible;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s2283b/a/2/B","parentIdentifier":"/us/usc/t33/s2283b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2283b%2Fa%2F2%2FB","sourceRelease":"119-100","text":"consistent with authorized project purposes and the fish hatchery; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s2283b/a/2/C","parentIdentifier":"/us/usc/t33/s2283b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2283b%2Fa%2F2%2FC","sourceRelease":"119-100","text":"in the public interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Cost sharing","label":"b Cost sharing","identifier":"/us/usc/t33/s2283b/b","parentIdentifier":"/us/usc/t33/s2283b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2283b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s2283b/b/1","parentIdentifier":"/us/usc/t33/s2283b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2283b%2Fb%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2), the non-Federal interest shall contribute 35 percent of the total cost of carrying out activities under this section, including the costs relating to the provision or acquisition of required land, easements, rights-of-way, dredged material disposal areas, and relocations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Operation and maintenance","label":"2 Operation and maintenance","identifier":"/us/usc/t33/s2283b/b/2","parentIdentifier":"/us/usc/t33/s2283b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2283b%2Fb%2F2","sourceRelease":"119-100","text":"The non-Federal interest shall contribute 100 percent of the costs of operation, maintenance, replacement, repair, and rehabilitation of the measures carried out under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
