{"type":"section","nativeType":"section","number":"4706","heading":"Selection of institutions","label":"4706 Selection of institutions","identifier":"/us/usc/t12/s4706","parentIdentifier":"/us/usc/t12/ch47/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Selection criteria","label":"a Selection criteria","identifier":"/us/usc/t12/s4706/a","parentIdentifier":"/us/usc/t12/s4706","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4706/a/1","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F1","sourceRelease":"119-100","text":"the likelihood of success of the applicant in meeting the goals of its comprehensive strategic plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4706/a/2","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F2","sourceRelease":"119-100","text":"the experience and background of the management team;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t12/s4706/a/3","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F3","sourceRelease":"119-100","text":"the extent of need for equity investments, loans, and development services within the investment areas or targeted populations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t12/s4706/a/4","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F4","sourceRelease":"119-100","text":"the extent of economic distress within the investment areas or the extent of need within the targeted populations, as those factors are measured by objective criteria;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t12/s4706/a/5","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F5","sourceRelease":"119-100","text":"the extent to which the applicant will concentrate its activities on serving its investment areas or targeted populations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t12/s4706/a/6","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F6","sourceRelease":"119-100","text":"the amount of firm commitments to meet or exceed the matching requirements and the likely success of the plan for raising the balance of the match;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t12/s4706/a/7","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F7","sourceRelease":"119-100","text":"the extent to which the matching funds are derived from private sources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t12/s4706/a/8","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F8","sourceRelease":"119-100","text":"the extent to which the proposed activities will expand economic opportunities within the investment areas or the targeted populations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t12/s4706/a/9","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F9","sourceRelease":"119-100","text":"whether the applicant is, or will become, an insured community development financial institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t12/s4706/a/10","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F10","sourceRelease":"119-100","text":"the extent of support from the investment areas or targeted populations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t12/s4706/a/11","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F11","sourceRelease":"119-100","text":"the extent to which the applicant is, or will be, community-owned or community-governed;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t12/s4706/a/12","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F12","sourceRelease":"119-100","text":"the extent to which the applicant will increase its resources through coordination with other institutions or participation in a secondary market;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"13","heading":null,"label":"13","identifier":"/us/usc/t12/s4706/a/13","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F13","sourceRelease":"119-100","text":"in the case of an applicant with a prior history of serving investment areas or targeted populations, the extent of success in serving them; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"14","heading":null,"label":"14","identifier":"/us/usc/t12/s4706/a/14","parentIdentifier":"/us/usc/t12/s4706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fa%2F14","sourceRelease":"119-100","text":"other factors deemed to be appropriate by the Fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Geographic diversity","label":"b Geographic diversity","identifier":"/us/usc/t12/s4706/b","parentIdentifier":"/us/usc/t12/s4706","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4706%2Fb","sourceRelease":"119-100","text":"In selecting applicants for assistance, the Fund shall seek to fund a geographically diverse group of applicants, which shall include applicants from metropolitan, nonmetropolitan, and rural areas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
