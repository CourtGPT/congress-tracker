{"type":"section","nativeType":"section","number":"5801","heading":"Findings","label":"5801 Findings","identifier":"/us/usc/t25/s5801","parentIdentifier":"/us/usc/t25/ch50","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5801","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Short Title, , , provided that:Pub. L. 116–174, § 1134 Stat. 839Oct. 20, 2020“This Act [enacting this chapter] may be cited as the ‘Native American Business Incubators Program Act’.”"],"amendments":["Short Title, , , provided that:Pub. L. 116–174, § 1134 Stat. 839Oct. 20, 2020“This Act [enacting this chapter] may be cited as the ‘Native American Business Incubators Program Act’.”"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s5801/1","parentIdentifier":"/us/usc/t25/s5801","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5801%2F1","sourceRelease":"119-100","text":"entrepreneurs face specific challenges when transforming ideas into profitable business enterprises;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s5801/2","parentIdentifier":"/us/usc/t25/s5801","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5801%2F2","sourceRelease":"119-100","text":"entrepreneurs that want to provide products and services in reservation communities face an additional set of challenges that requires special knowledge;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s5801/3","parentIdentifier":"/us/usc/t25/s5801","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5801%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s5801/3/A","parentIdentifier":"/us/usc/t25/s5801/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5801%2F3%2FA","sourceRelease":"119-100","text":"workspace and facilities resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s5801/3/B","parentIdentifier":"/us/usc/t25/s5801/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5801%2F3%2FB","sourceRelease":"119-100","text":"access to capital, business education, and counseling;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s5801/3/C","parentIdentifier":"/us/usc/t25/s5801/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5801%2F3%2FC","sourceRelease":"119-100","text":"networking opportunities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s5801/3/D","parentIdentifier":"/us/usc/t25/s5801/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5801%2F3%2FD","sourceRelease":"119-100","text":"mentorship opportunities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t25/s5801/3/E","parentIdentifier":"/us/usc/t25/s5801/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5801%2F3%2FE","sourceRelease":"119-100","text":"an environment intended to help establish and expand business operations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s5801/4","parentIdentifier":"/us/usc/t25/s5801","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5801%2F4","sourceRelease":"119-100","text":"the business incubator model is suited to accelerating entrepreneurship in reservation communities because the business incubator model promotes collaboration to address shared challenges and provides individually tailored services for the purpose of overcoming obstacles unique to each participating business; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s5801/5","parentIdentifier":"/us/usc/t25/s5801","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5801%2F5","sourceRelease":"119-100","text":"business incubators will stimulate economic development by providing Native entrepreneurs with the tools necessary to grow businesses that offer products and services to reservation communities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
