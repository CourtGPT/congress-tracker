{"type":"section","nativeType":"section","number":"17387","heading":"Integrated energy systems","label":"17387 Integrated energy systems","identifier":"/us/usc/t42/s17387","parentIdentifier":"/us/usc/t42/ch152/schIX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s17387/a","parentIdentifier":"/us/usc/t42/s17387","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17387/a/1","parentIdentifier":"/us/usc/t42/s17387/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fa%2F1","sourceRelease":"119-100","text":"development of computer modeling to design different configurations of integrated energy systems and to optimize system operation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17387/a/2","parentIdentifier":"/us/usc/t42/s17387/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fa%2F2","sourceRelease":"119-100","text":"research on system integration needed to plan, design, build, and operate integrated energy systems, including interconnection requirements with the electric grid;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17387/a/3","parentIdentifier":"/us/usc/t42/s17387/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17387/a/3/A","parentIdentifier":"/us/usc/t42/s17387/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fa%2F3%2FA","sourceRelease":"119-100","text":"thermal energy generation and storage for buildings and manufacturing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17387/a/3/B","parentIdentifier":"/us/usc/t42/s17387/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fa%2F3%2FB","sourceRelease":"119-100","text":"electricity storage coupled with energy generation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17387/a/3/C","parentIdentifier":"/us/usc/t42/s17387/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fa%2F3%2FC","sourceRelease":"119-100","text":"desalination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17387/a/3/D","parentIdentifier":"/us/usc/t42/s17387/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fa%2F3%2FD","sourceRelease":"119-100","text":"production of liquid and gaseous fuels; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17387/a/3/E","parentIdentifier":"/us/usc/t42/s17387/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fa%2F3%2FE","sourceRelease":"119-100","text":"production of chemicals such as ammonia and ethylene;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17387/a/4","parentIdentifier":"/us/usc/t42/s17387/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fa%2F4","sourceRelease":"119-100","text":"development of testing facilities for integrated energy systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s17387/a/5","parentIdentifier":"/us/usc/t42/s17387/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fa%2F5","sourceRelease":"119-100","text":"research on incorporation of various technologies for integrated energy systems, including nuclear energy, renewable energy, storage, and carbon capture, utilization, and sequestration technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Strategic plan","label":"b Strategic plan","identifier":"/us/usc/t42/s17387/b","parentIdentifier":"/us/usc/t42/s17387","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17387/b/1","parentIdentifier":"/us/usc/t42/s17387/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17387/b/1/A","parentIdentifier":"/us/usc/t42/s17387/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fb%2F1%2FA","sourceRelease":"119-100","text":"analysis of the potential benefits of development of integrated electric systems on the electric grid;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17387/b/1/B","parentIdentifier":"/us/usc/t42/s17387/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fb%2F1%2FB","sourceRelease":"119-100","text":"analysis of the potential contributions of integrated energy systems to different grid architecture scenarios;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17387/b/1/C","parentIdentifier":"/us/usc/t42/s17387/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fb%2F1%2FC","sourceRelease":"119-100","text":"research and development goals for various integrated energy systems, including those identified in subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17387/b/1/D","parentIdentifier":"/us/usc/t42/s17387/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fb%2F1%2FD","sourceRelease":"119-100","text":"assessment of policy and market barriers to the adoption of integrated energy systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17387/b/1/E","parentIdentifier":"/us/usc/t42/s17387/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fb%2F1%2FE","sourceRelease":"119-100","text":"analysis of the technical and economic feasibility of adoption of different integrated energy systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17387/b/1/F","parentIdentifier":"/us/usc/t42/s17387/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fb%2F1%2FF","sourceRelease":"119-100","text":"a 10-year roadmap to guide the program established under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Updates","label":"2 Updates","identifier":"/us/usc/t42/s17387/b/2","parentIdentifier":"/us/usc/t42/s17387/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fb%2F2","sourceRelease":"119-100","text":"Not less than once every 3 years for the duration of this research program, the Secretary shall submit an updated version of the strategic plan to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Program implementation","label":"c Program implementation","identifier":"/us/usc/t42/s17387/c","parentIdentifier":"/us/usc/t42/s17387","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17387/c/1","parentIdentifier":"/us/usc/t42/s17387/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fc%2F1","sourceRelease":"119-100","text":"implement the recommendations set forth in the strategic plan in subsection (b);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17387/c/2","parentIdentifier":"/us/usc/t42/s17387/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17387/c/2/A","parentIdentifier":"/us/usc/t42/s17387/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the Office of Energy Efficiency and Renewable Energy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17387/c/2/B","parentIdentifier":"/us/usc/t42/s17387/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the Office of Nuclear Energy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17387/c/2/C","parentIdentifier":"/us/usc/t42/s17387/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fc%2F2%2FC","sourceRelease":"119-100","text":"the Office of Fossil Energy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17387/c/3","parentIdentifier":"/us/usc/t42/s17387/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fc%2F3","sourceRelease":"119-100","text":"leverage existing programs and resources of the Department; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17387/c/4","parentIdentifier":"/us/usc/t42/s17387/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fc%2F4","sourceRelease":"119-100","text":"prioritize activities that accelerate the development of integrated electricity generation, storage, and distribution systems with net zero greenhouse gas emissions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Integrated energy system defined","label":"d Integrated energy system defined","identifier":"/us/usc/t42/s17387/d","parentIdentifier":"/us/usc/t42/s17387","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17387%2Fd","sourceRelease":"119-100","text":"The term “integrated energy system” means a system composed of 2 or more co-located or jointly operated sub-systems of energy generation, energy storage, or other energy technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
