{"type":"section","nativeType":"section","number":"16491","heading":"Energy production incentives","label":"16491 Energy production incentives","identifier":"/us/usc/t42/s16491","parentIdentifier":"/us/usc/t42/ch149/schXIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16491","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s16491/a","parentIdentifier":"/us/usc/t42/s16491","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16491%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16491/a/1","parentIdentifier":"/us/usc/t42/s16491/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16491%2Fa%2F1","sourceRelease":"119-100","text":"a credit against any tax or fee owed to the State under a State law, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16491/a/2","parentIdentifier":"/us/usc/t42/s16491/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16491%2Fa%2F2","sourceRelease":"119-100","text":"any other tax incentive,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Eligible entities","label":"b Eligible entities","identifier":"/us/usc/t42/s16491/b","parentIdentifier":"/us/usc/t42/s16491","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16491%2Fb","sourceRelease":"119-100","text":"Subsection (a) shall apply with respect to the production in the State of electricity from coal mined in the State and used in a facility, if such production meets all applicable Federal and State laws and if such facility uses scrubbers or other forms of clean coal technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Effect on interstate commerce","label":"c Effect on interstate commerce","identifier":"/us/usc/t42/s16491/c","parentIdentifier":"/us/usc/t42/s16491","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16491%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16491/c/1","parentIdentifier":"/us/usc/t42/s16491/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16491%2Fc%2F1","sourceRelease":"119-100","text":"be considered to be a reasonable regulation of commerce; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16491/c/2","parentIdentifier":"/us/usc/t42/s16491/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16491%2Fc%2F2","sourceRelease":"119-100","text":"not be considered to impose an undue burden on interstate commerce or to otherwise impair, restrain, or discriminate, against interstate commerce.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
