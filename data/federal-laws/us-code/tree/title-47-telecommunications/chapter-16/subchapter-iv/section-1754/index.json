{"type":"section","nativeType":"section","number":"1754","heading":"Digital discrimination","label":"1754 Digital discrimination","identifier":"/us/usc/t47/s1754","parentIdentifier":"/us/usc/t47/ch16/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Statement of policy","label":"a Statement of policy","identifier":"/us/usc/t47/s1754/a","parentIdentifier":"/us/usc/t47/s1754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s1754/a/1","parentIdentifier":"/us/usc/t47/s1754/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754%2Fa%2F1","sourceRelease":"119-100","text":"subscribers should benefit from equal access to broadband internet access service within the service area of a provider of such service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s1754/a/2","parentIdentifier":"/us/usc/t47/s1754/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754%2Fa%2F2","sourceRelease":"119-100","text":"the term “equal access”, for purposes of this section, means the equal opportunity to subscribe to an offered service that provides comparable speeds, capacities, latency, and other quality of service metrics in a given area, for comparable terms and conditions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t47/s1754/a/3","parentIdentifier":"/us/usc/t47/s1754/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754%2Fa%2F3","sourceRelease":"119-100","text":"the Commission should take steps to ensure that all people of the United States benefit from equal access to broadband internet access service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Adoption of rules","label":"b Adoption of rules","identifier":"/us/usc/t47/s1754/b","parentIdentifier":"/us/usc/t47/s1754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s1754/b/1","parentIdentifier":"/us/usc/t47/s1754/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754%2Fb%2F1","sourceRelease":"119-100","text":"preventing digital discrimination of access based on income level, race, ethnicity, color, religion, or national origin; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s1754/b/2","parentIdentifier":"/us/usc/t47/s1754/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754%2Fb%2F2","sourceRelease":"119-100","text":"identifying necessary steps for the Commissions to take to eliminate discrimination described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Federal policies","label":"c Federal policies","identifier":"/us/usc/t47/s1754/c","parentIdentifier":"/us/usc/t47/s1754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s1754/c/1","parentIdentifier":"/us/usc/t47/s1754/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754%2Fc%2F1","sourceRelease":"119-100","text":"the income level of an area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s1754/c/2","parentIdentifier":"/us/usc/t47/s1754/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754%2Fc%2F2","sourceRelease":"119-100","text":"the predominant race or ethnicity composition of an area; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t47/s1754/c/3","parentIdentifier":"/us/usc/t47/s1754/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754%2Fc%2F3","sourceRelease":"119-100","text":"other factors the Commission determines to be relevant based on the findings in the record developed from the rulemaking under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Model State and local policies","label":"d Model State and local policies","identifier":"/us/usc/t47/s1754/d","parentIdentifier":"/us/usc/t47/s1754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754%2Fd","sourceRelease":"119-100","text":"The Commission shall develop model policies and best practices that can be adopted by States and localities to ensure that broadband internet access service providers do not engage in digital discrimination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Complaints","label":"e Complaints","identifier":"/us/usc/t47/s1754/e","parentIdentifier":"/us/usc/t47/s1754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1754%2Fe","sourceRelease":"119-100","text":"The Commission shall revise its public complaint process to accept complaints from consumers or other members of the public that relate to digital discrimination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
