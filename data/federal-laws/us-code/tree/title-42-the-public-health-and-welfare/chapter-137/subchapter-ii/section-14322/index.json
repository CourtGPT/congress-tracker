{"type":"section","nativeType":"section","number":"14322","heading":"Rechargeable consumer products and labeling","label":"14322 Rechargeable consumer products and labeling","identifier":"/us/usc/t42/s14322","parentIdentifier":"/us/usc/t42/ch137/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Prohibition","label":"a Prohibition","identifier":"/us/usc/t42/s14322/a","parentIdentifier":"/us/usc/t42/s14322","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s14322/a/1","parentIdentifier":"/us/usc/t42/s14322/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s14322/a/1/A","parentIdentifier":"/us/usc/t42/s14322/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fa%2F1%2FA","sourceRelease":"119-100","text":"is easily removable from the rechargeable consumer product; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s14322/a/1/B","parentIdentifier":"/us/usc/t42/s14322/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fa%2F1%2FB","sourceRelease":"119-100","text":"is sold separately.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Application","label":"2 Application","identifier":"/us/usc/t42/s14322/a/2","parentIdentifier":"/us/usc/t42/s14322/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s14322/a/2/A","parentIdentifier":"/us/usc/t42/s14322/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fa%2F2%2FA","sourceRelease":"119-100","text":"The sale of a remanufactured product unit unless paragraph (1) applied to the sale of the unit when originally manufactured.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s14322/a/2/B","parentIdentifier":"/us/usc/t42/s14322/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fa%2F2%2FB","sourceRelease":"119-100","text":"The sale of a product unit intended for export purposes only.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Labeling","label":"b Labeling","identifier":"/us/usc/t42/s14322/b","parentIdentifier":"/us/usc/t42/s14322","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s14322/b/1","parentIdentifier":"/us/usc/t42/s14322/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fb%2F1","sourceRelease":"119-100","text":"3 chasing arrows or a comparable recycling symbol.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s14322/b/2","parentIdentifier":"/us/usc/t42/s14322/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s14322/b/2/A","parentIdentifier":"/us/usc/t42/s14322/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fb%2F2%2FA","sourceRelease":"119-100","text":"On each regulated battery which is a nickel-cadmium battery, the chemical name or the abbreviation “Ni-Cd” and the phrase “BATTERY MUST BE RECYCLED OR DISPOSED OF PROPERLY.”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s14322/b/2/B","parentIdentifier":"/us/usc/t42/s14322/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fb%2F2%2FB","sourceRelease":"119-100","text":"On each regulated battery which is a lead-acid battery, “Pb” or the words “LEAD”, “RETURN”, and “RECYCLE” and if the regulated battery is sealed, the phrase “BATTERY MUST BE RECYCLED.”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s14322/b/3","parentIdentifier":"/us/usc/t42/s14322/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fb%2F3","sourceRelease":"119-100","text":"On each rechargeable consumer product containing a regulated battery that is not easily removable, the phrase “CONTAINS NICKEL-CADMIUM BATTERY. BATTERY MUST BE RECYCLED OR DISPOSED OF PROPERLY.” or “CONTAINS SEALED LEAD BATTERY. BATTERY MUST BE RECYCLED.”, as applicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s14322/b/4","parentIdentifier":"/us/usc/t42/s14322/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fb%2F4","sourceRelease":"119-100","text":"On the packaging of each rechargeable consumer product, and the packaging of each regulated battery sold separately from such a product, unless the required label is clearly visible through the packaging, the phrase “CONTAINS NICKEL-CADMIUM BATTERY. BATTERY MUST BE RECYCLED OR DISPOSED OF PROPERLY.” or “CONTAINS SEALED LEAD BATTERY. BATTERY MUST BE RECYCLED.”, as applicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Existing or alternative labeling","label":"c Existing or alternative labeling","identifier":"/us/usc/t42/s14322/c","parentIdentifier":"/us/usc/t42/s14322","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Initial period","label":"1 Initial period","identifier":"/us/usc/t42/s14322/c/1","parentIdentifier":"/us/usc/t42/s14322/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fc%2F1","sourceRelease":"119-100","text":"For a period of 2 years after , regulated batteries, rechargeable consumer products containing regulated batteries, and rechargeable consumer product packages that are labeled in substantial compliance with subsection (b) shall be deemed to comply with the labeling requirements of subsection (b).May 13, 1996","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Certification","label":"2 Certification","identifier":"/us/usc/t42/s14322/c/2","parentIdentifier":"/us/usc/t42/s14322/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s14322/c/2/A","parentIdentifier":"/us/usc/t42/s14322/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s14322/c/2/A/i","parentIdentifier":"/us/usc/t42/s14322/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"conveys the same information as the label required under subsection (b) or (d), respectively; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s14322/c/2/A/ii","parentIdentifier":"/us/usc/t42/s14322/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":"conforms with a recognized international standard that is consistent with the overall purposes of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Constructive certification","label":"B Constructive certification","identifier":"/us/usc/t42/s14322/c/2/B","parentIdentifier":"/us/usc/t42/s14322/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fc%2F2%2FB","sourceRelease":"119-100","text":"Failure of the Administrator to object to an application under subparagraph (A) on the ground that a different label does not meet either of the conditions described in subparagraph (A)(i) or (ii) within 120 days after the date on which the application is made shall constitute certification for the purposes of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Rulemaking authority of Administrator","label":"d Rulemaking authority of Administrator","identifier":"/us/usc/t42/s14322/d","parentIdentifier":"/us/usc/t42/s14322","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s14322/d/1","parentIdentifier":"/us/usc/t42/s14322/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s14322/d/1/A","parentIdentifier":"/us/usc/t42/s14322/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fd%2F1%2FA","sourceRelease":"119-100","text":"promulgate labeling requirements for the batteries with different electrode chemistries, rechargeable consumer products containing such batteries that are not easily removable batteries, and packaging for the batteries and products; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s14322/d/1/B","parentIdentifier":"/us/usc/t42/s14322/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fd%2F1%2FB","sourceRelease":"119-100","text":"promulgate requirements for easy removability of regulated batteries from rechargeable consumer products designed to contain such batteries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Substantial similarity","label":"2 Substantial similarity","identifier":"/us/usc/t42/s14322/d/2","parentIdentifier":"/us/usc/t42/s14322/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fd%2F2","sourceRelease":"119-100","text":"The regulations promulgated under paragraph (1) shall be substantially similar to the requirements set forth in subsections (a) and (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Uniformity","label":"e Uniformity","identifier":"/us/usc/t42/s14322/e","parentIdentifier":"/us/usc/t42/s14322","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Fe","sourceRelease":"119-100","text":"After the effective dates of a requirement set forth in subsection (a), (b), or (c) or a regulation promulgated by the Administrator under subsection (d), no Federal agency, State, or political subdivision of a State may enforce any easy removability or environmental labeling requirement for a rechargeable battery or rechargeable consumer product that is not identical to the requirement or regulation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Exemptions","label":"f Exemptions","identifier":"/us/usc/t42/s14322/f","parentIdentifier":"/us/usc/t42/s14322","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s14322/f/1","parentIdentifier":"/us/usc/t42/s14322/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s14322/f/1/A","parentIdentifier":"/us/usc/t42/s14322/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Ff%2F1%2FA","sourceRelease":"119-100","text":"A statement of the specific basis for the request for the exemption.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s14322/f/1/B","parentIdentifier":"/us/usc/t42/s14322/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Ff%2F1%2FB","sourceRelease":"119-100","text":"The name, business address, and telephone number of the applicant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Granting of exemption","label":"2 Granting of exemption","identifier":"/us/usc/t42/s14322/f/2","parentIdentifier":"/us/usc/t42/s14322/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s14322/f/2/A","parentIdentifier":"/us/usc/t42/s14322/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Ff%2F2%2FA","sourceRelease":"119-100","text":"posing a threat to human health, safety, or the environment; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s14322/f/2/B","parentIdentifier":"/us/usc/t42/s14322/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Ff%2F2%2FB","sourceRelease":"119-100","text":"violating requirements for approvals from governmental agencies or widely recognized private standard-setting organizations (including Underwriters Laboratories).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Renewal of exemption","label":"3 Renewal of exemption","identifier":"/us/usc/t42/s14322/f/3","parentIdentifier":"/us/usc/t42/s14322/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14322%2Ff%2F3","sourceRelease":"119-100","text":"A person granted an exemption under paragraph (2) may apply for a renewal of the exemption in accordance with the requirements and procedures described in paragraphs (1) and (2). The Administrator may grant a renewal of such an exemption for a period of not more than 2 years after the date of the granting of the renewal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
