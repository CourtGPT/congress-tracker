{"type":"section","nativeType":"section","number":"9008","heading":"Definitions","label":"9008 Definitions","identifier":"/us/usc/t42/s9008","parentIdentifier":"/us/usc/t42/ch98","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9008","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s9008/1","parentIdentifier":"/us/usc/t42/s9008","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9008%2F1","sourceRelease":"119-100","text":"“ocean thermal energy conversion” means a method of converting part of the heat from the Sun which is stored in the surface layers of a body of water into electrical energy or energy product equivalent;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s9008/2","parentIdentifier":"/us/usc/t42/s9008","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9008%2F2","sourceRelease":"119-100","text":"“energy product equivalent” means an energy carrier including, but not limited to, ammonia, hydrogen, or molten salts or an energy-intensive commodity, including, but not limited to, electrometals, fresh water, or nutrients for aquaculture; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s9008/3","parentIdentifier":"/us/usc/t42/s9008","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9008%2F3","sourceRelease":"119-100","text":"“Secretary” means the Secretary of Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
