{"type":"section","nativeType":"section","number":"282l","heading":"Capital stock increase","label":"282l Capital stock increase","identifier":"/us/usc/t22/s282l","parentIdentifier":"/us/usc/t22/ch7/schXI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs282l","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Subscription authorized","label":"a Subscription authorized","identifier":"/us/usc/t22/s282l/a","parentIdentifier":"/us/usc/t22/s282l","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs282l%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s282l/a/1","parentIdentifier":"/us/usc/t22/s282l/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs282l%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s282l/a/1/A","parentIdentifier":"/us/usc/t22/s282l/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs282l%2Fa%2F1%2FA","sourceRelease":"119-100","text":"vote for an increase of 1,000,000 shares in the authorized capital stock of the Corporation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s282l/a/1/B","parentIdentifier":"/us/usc/t22/s282l/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs282l%2Fa%2F1%2FB","sourceRelease":"119-100","text":"subscribe on behalf of the United States to 250,000 additional shares of the capital stock of the Corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Prior appropriation required","label":"2 Prior appropriation required","identifier":"/us/usc/t22/s282l/a/2","parentIdentifier":"/us/usc/t22/s282l/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs282l%2Fa%2F2","sourceRelease":"119-100","text":"The subscription authority provided in paragraph (1) shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitations on authorization of appropriations","label":"b Limitations on authorization of appropriations","identifier":"/us/usc/t22/s282l/b","parentIdentifier":"/us/usc/t22/s282l","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs282l%2Fb","sourceRelease":"119-100","text":"In order to pay for the subscription authorized in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $50,000,000 for payment by the Secretary of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
