{"type":"section","nativeType":"section","number":"4314","heading":"Joint strategic plan","label":"4314 Joint strategic plan","identifier":"/us/usc/t19/s4314","parentIdentifier":"/us/usc/t19/ch28/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t19/s4314/a","parentIdentifier":"/us/usc/t19/s4314","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fa","sourceRelease":"119-100","text":"Not later than one year after , and every 2 years thereafter, the Commissioner and the Director of U.S. Immigration and Customs Enforcement shall jointly develop and submit to the appropriate congressional committees a joint strategic plan.February 24, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Contents","label":"b Contents","identifier":"/us/usc/t19/s4314/b","parentIdentifier":"/us/usc/t19/s4314","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4314/b/1","parentIdentifier":"/us/usc/t19/s4314/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb%2F1","sourceRelease":"119-100","text":"a summary of actions taken during the 2-year period preceding the submission of the plan to improve trade enforcement and trade facilitation, including a description and analysis of specific performance measures to evaluate the progress of U.S. Customs and Border Protection and U.S. Immigration and Customs Enforcement in meeting each such responsibility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4314/b/2","parentIdentifier":"/us/usc/t19/s4314/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb%2F2","sourceRelease":"119-100","text":"a statement of objectives and plans for further improving trade enforcement and trade facilitation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s4314/b/3","parentIdentifier":"/us/usc/t19/s4314/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s4314/b/3/A","parentIdentifier":"/us/usc/t19/s4314/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb%2F3%2FA","sourceRelease":"119-100","text":"a description of the targeting methodologies used for enforcement activities with respect to each such issue;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s4314/b/3/B","parentIdentifier":"/us/usc/t19/s4314/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb%2F3%2FB","sourceRelease":"119-100","text":"recommendations for improving such enforcement activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t19/s4314/b/3/C","parentIdentifier":"/us/usc/t19/s4314/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb%2F3%2FC","sourceRelease":"119-100","text":"a description of the implementation of previous recommendations for improving such enforcement activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t19/s4314/b/4","parentIdentifier":"/us/usc/t19/s4314/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb%2F4","sourceRelease":"119-100","text":"a description of efforts made to improve consultation and coordination among and within Federal agencies, and in particular between U.S. Customs and Border Protection and U.S. Immigration and Customs Enforcement, regarding trade enforcement and trade facilitation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t19/s4314/b/5","parentIdentifier":"/us/usc/t19/s4314/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb%2F5","sourceRelease":"119-100","text":"a description of the training that has occurred to date within U.S. Customs and Border Protection and U.S. Immigration and Customs Enforcement to improve trade enforcement and trade facilitation, including training at educational seminars carried out under ;section 4313 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t19/s4314/b/6","parentIdentifier":"/us/usc/t19/s4314/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb%2F6","sourceRelease":"119-100","text":"a description of efforts to work with the World Customs Organization and other international organizations, in consultation with other Federal agencies as appropriate, with respect to enhancing trade enforcement and trade facilitation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t19/s4314/b/7","parentIdentifier":"/us/usc/t19/s4314/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb%2F7","sourceRelease":"119-100","text":"a description of U.S. Custom and Border Protection organizational benchmarks for optimizing staffing and wait times at ports of entry;1So in original. Probably should be “Customs”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t19/s4314/b/8","parentIdentifier":"/us/usc/t19/s4314/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb%2F8","sourceRelease":"119-100","text":"a specific identification of any domestic or international best practices that may further improve trade enforcement and trade facilitation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t19/s4314/b/9","parentIdentifier":"/us/usc/t19/s4314/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb%2F9","sourceRelease":"119-100","text":"any legislative recommendations to further improve trade enforcement and trade facilitation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t19/s4314/b/10","parentIdentifier":"/us/usc/t19/s4314/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fb%2F10","sourceRelease":"119-100","text":"a description of efforts made to improve consultation and coordination with the private sector to enhance trade enforcement and trade facilitation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Consultations","label":"c Consultations","identifier":"/us/usc/t19/s4314/c","parentIdentifier":"/us/usc/t19/s4314","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t19/s4314/c/1","parentIdentifier":"/us/usc/t19/s4314/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s4314/c/1/A","parentIdentifier":"/us/usc/t19/s4314/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s4314/c/1/A/i","parentIdentifier":"/us/usc/t19/s4314/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the Department of the Treasury;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s4314/c/1/A/ii","parentIdentifier":"/us/usc/t19/s4314/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4314%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the Department of Agriculture;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"ii