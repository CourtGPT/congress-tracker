us/usc/t43/s3207/a/2","parentIdentifier":"/us/usc/t43/s3207/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fa%2F2","sourceRelease":"119-100","text":"a Tribal or local government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s3207/a/3","parentIdentifier":"/us/usc/t43/s3207/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fa%2F3","sourceRelease":"119-100","text":"an organization with power or water delivery authority;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t43/s3207/a/4","parentIdentifier":"/us/usc/t43/s3207/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fa%2F4","sourceRelease":"119-100","text":"a regional authority; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t43/s3207/a/5","parentIdentifier":"/us/usc/t43/s3207/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fa%2F5","sourceRelease":"119-100","text":"a nonprofit conservation organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment of competitive grant program","label":"b Establishment of competitive grant program","identifier":"/us/usc/t43/s3207/b","parentIdentifier":"/us/usc/t43/s3207","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s3207/b/1","parentIdentifier":"/us/usc/t43/s3207/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fb%2F1","sourceRelease":"119-100","text":"Ecosystem benefits.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s3207/b/2","parentIdentifier":"/us/usc/t43/s3207/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fb%2F2","sourceRelease":"119-100","text":"Restoration of native species.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s3207/b/3","parentIdentifier":"/us/usc/t43/s3207/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fb%2F3","sourceRelease":"119-100","text":"Mitigation against the impacts of climate change to fish and wildlife habitats.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t43/s3207/b/4","parentIdentifier":"/us/usc/t43/s3207/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fb%2F4","sourceRelease":"119-100","text":"Protection against invasive species.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t43/s3207/b/5","parentIdentifier":"/us/usc/t43/s3207/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fb%2F5","sourceRelease":"119-100","text":"Restoration of aspects of the natural ecosystem.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t43/s3207/b/6","parentIdentifier":"/us/usc/t43/s3207/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fb%2F6","sourceRelease":"119-100","text":"Enhancement of commercial, recreational, subsistence, or Tribal ceremonial fishing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t43/s3207/b/7","parentIdentifier":"/us/usc/t43/s3207/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fb%2F7","sourceRelease":"119-100","text":"Enhancement of river-based recreation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Requirements","label":"c Requirements","identifier":"/us/usc/t43/s3207/c","parentIdentifier":"/us/usc/t43/s3207","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s3207/c/1","parentIdentifier":"/us/usc/t43/s3207/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s3207/c/1/A","parentIdentifier":"/us/usc/t43/s3207/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fc%2F1%2FA","sourceRelease":"119-100","text":"shall give priority to an eligible applicant that would carry out a habitat restoration project that achieves more than 1 of the benefits described in that subsection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s3207/c/1/B","parentIdentifier":"/us/usc/t43/s3207/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fc%2F1%2FB","sourceRelease":"119-100","text":"may not provide a grant to carry out a habitat restoration project the purpose of which is to meet existing environmental mitigation or compliance obligations under Federal or State law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Compliance","label":"2 Compliance","identifier":"/us/usc/t43/s3207/c/2","parentIdentifier":"/us/usc/t43/s3207/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fc%2F2","sourceRelease":"119-100","text":"A habitat restoration project awarded a grant under subsection (b) shall comply with all applicable Federal and State laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Cost-sharing requirement","label":"d Cost-sharing requirement","identifier":"/us/usc/t43/s3207/d","parentIdentifier":"/us/usc/t43/s3207","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s3207/d/1","parentIdentifier":"/us/usc/t43/s3207/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fd%2F1","sourceRelease":"119-100","text":"shall not exceed 50 percent of the cost of the habitat restoration project; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s3207/d/2","parentIdentifier":"/us/usc/t43/s3207/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3207%2Fd%2F2","sourceRelease":"119-100","text":"in the case of a habitat restoration project that provides benefits to ecological or recreational values in which the nonconsumptive water conservation benefit or habitat restoration benefit accounts for at least 75 percent of the cost of the habitat restoration project, as determined by the Secretary, shall not exceed 75 percent of the cost of the habitat restoration project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
