{"type":"section","nativeType":"section","number":"10706","heading":"Promoting cross-cultural and educational engagement","label":"10706 Promoting cross-cultural and educational engagement","identifier":"/us/usc/t22/s10706","parentIdentifier":"/us/usc/t22/ch114","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10706","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Sense of Congress","label":"a Sense of Congress","identifier":"/us/usc/t22/s10706/a","parentIdentifier":"/us/usc/t22/s10706","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10706%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10706/a/1","parentIdentifier":"/us/usc/t22/s10706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10706%2Fa%2F1","sourceRelease":"119-100","text":"promoting partnerships between United States universities and universities in the Western Balkans advances United States foreign policy goals and requires a whole-of-government approach, including the utilization of public-private partnerships; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10706/a/2","parentIdentifier":"/us/usc/t22/s10706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10706%2Fa%2F2","sourceRelease":"119-100","text":"such partnerships would provide opportunities for exchanging academic ideas, technical expertise, research, and cultural understanding for the benefit of the United States and may provide additional beneficial opportunities for cooperation in the private sector.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"University partnerships","label":"b University partnerships","identifier":"/us/usc/t22/s10706/b","parentIdentifier":"/us/usc/t22/s10706","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10706%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10706/b/1","parentIdentifier":"/us/usc/t22/s10706/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10706%2Fb%2F1","sourceRelease":"119-100","text":"supporting research and analysis on cyber resilience;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10706/b/2","parentIdentifier":"/us/usc/t22/s10706/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10706%2Fb%2F2","sourceRelease":"119-100","text":"working with partner governments to reform policies, improve curricula, strengthen data systems, train teachers and students, including English language teaching, and to provide quality, inclusive learning materials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s10706/b/3","parentIdentifier":"/us/usc/t22/s10706/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10706%2Fb%2F3","sourceRelease":"119-100","text":"encouraging knowledge exchanges to help provide individuals, especially those who historically have had reduced access to relevant education, training, and skills for meaningful employment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s10706/b/4","parentIdentifier":"/us/usc/t22/s10706/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10706%2Fb%2F4","sourceRelease":"119-100","text":"promoting teaching and research exchanges between institutions of higher education in the Western Balkans and in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s10706/b/5","parentIdentifier":"/us/usc/t22/s10706/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10706%2Fb%2F5","sourceRelease":"119-100","text":"encouraging alliances and exchanges with like-minded institutions of education within the Western Balkans and the larger European continent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
