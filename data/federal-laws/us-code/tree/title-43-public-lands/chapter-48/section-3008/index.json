{"type":"section","nativeType":"section","number":"3008","heading":"Renewable energy revenue sharing","label":"3008 Renewable energy revenue sharing","identifier":"/us/usc/t43/s3008","parentIdentifier":"/us/usc/t43/ch48","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of , and not as part of subtitle B of title III of div. Z of which comprises this chapter.Pub. L. 119–21Pub. L. 116–260"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t43/s3008/a","parentIdentifier":"/us/usc/t43/s3008","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"County","label":"1 County","identifier":"/us/usc/t43/s3008/a/1","parentIdentifier":"/us/usc/t43/s3008/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F1","sourceRelease":"119-100","text":"The term “county” includes a parish, township, borough, and any other similar, independent unit of local government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Covered land","label":"2 Covered land","identifier":"/us/usc/t43/s3008/a/2","parentIdentifier":"/us/usc/t43/s3008/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s3008/a/2/A","parentIdentifier":"/us/usc/t43/s3008/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F2%2FA","sourceRelease":"119-100","text":"public land administered by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s3008/a/2/B","parentIdentifier":"/us/usc/t43/s3008/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s3008/a/2/B/i","parentIdentifier":"/us/usc/t43/s3008/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"a land use plan; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s3008/a/2/B/ii","parentIdentifier":"/us/usc/t43/s3008/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"other Federal law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"National Forest System","label":"3 National Forest System","identifier":"/us/usc/t43/s3008/a/3","parentIdentifier":"/us/usc/t43/s3008/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t43/s3008/a/3/A","parentIdentifier":"/us/usc/t43/s3008/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F3%2FA","sourceRelease":"119-100","text":"The term “National Forest System” means land of the National Forest System (as defined in ) administered by the Secretary of Agriculture.section 1609(a) of title 16","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exclusion","label":"B Exclusion","identifier":"/us/usc/t43/s3008/a/3/B","parentIdentifier":"/us/usc/t43/s3008/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F3%2FB","sourceRelease":"119-100","text":"The term “National Forest System” does not include any forest reserve not created from the public domain.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Public land","label":"4 Public land","identifier":"/us/usc/t43/s3008/a/4","parentIdentifier":"/us/usc/t43/s3008/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s3008/a/4/A","parentIdentifier":"/us/usc/t43/s3008/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F4%2FA","sourceRelease":"119-100","text":"public lands (as defined in ); andsection 1702 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s3008/a/4/B","parentIdentifier":"/us/usc/t43/s3008/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F4%2FB","sourceRelease":"119-100","text":"National Forest System land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Renewable energy project","label":"5 Renewable energy project","identifier":"/us/usc/t43/s3008/a/5","parentIdentifier":"/us/usc/t43/s3008/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F5","sourceRelease":"119-100","text":"The term “renewable energy project” means a system described in section 2801.9(a)(4) of title 43, Code of Federal Regulations (as in effect on ), located on covered land that uses wind or solar energy to generate energy.July 4, 2025","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Secretary","label":"6 Secretary","identifier":"/us/usc/t43/s3008/a/6","parentIdentifier":"/us/usc/t43/s3008/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s3008/a/6/A","parentIdentifier":"/us/usc/t43/s3008/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F6%2FA","sourceRelease":"119-100","text":"the Secretary of the Interior, with respect to land controlled or administered by the Secretary of the Interior; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s3008/a/6/B","parentIdentifier":"/us/usc/t43/s3008/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fa%2F6%2FB","sourceRelease":"119-100","text":"the Secretary of Agriculture, with respect to National Forest System land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Disposition of revenue","label":"b Disposition of revenue","identifier":"/us/usc/t43/s3008/b","parentIdentifier":"/us/usc/t43/s3008","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Disposition of revenues","label":"1 Disposition of revenues","identifier":"/us/usc/t43/s3008/b/1","parentIdentifier":"/us/usc/t43/s3008/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s3008/b/1/A","parentIdentifier":"/us/usc/t43/s3008/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fb%2F1%2FA","sourceRelease":"119-100","text":"be deposited in the general fund of the Treasury; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s3008/b/1/B","parentIdentifier":"/us/usc/t43/s3008/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s3008/b/1/B/i","parentIdentifier":"/us/usc/t43/s3008/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"25 percent shall be paid from amounts in the general fund of the Treasury to the State within the boundaries of which the revenue is derived.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s3008/b/1/B/ii","parentIdentifier":"/us/usc/t43/s3008/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"25 percent shall be paid from amounts in the general fund of the Treasury to each county in a State within the boundaries of which the revenue is derived, to be allocated among each applicable county based on the percentage of county land from which the revenue is derived.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Payments to States and counties","label":"2 Payments to States and counties","identifier":"/us/usc/t43/s3008/b/2","parentIdentifier":"/us/usc/t43/s3008/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t43/s3008/b/2/A","parentIdentifier":"/us/usc/t43/s3008/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fb%2F2%2FA","sourceRelease":"119-100","text":"Amounts paid to States and counties under paragraph (1) shall be used in accordance with the requirements of .section 191 of title 30","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Payments in lieu of taxes","label":"B Payments in lieu of taxes","identifier":"/us/usc/t43/s3008/b/2/B","parentIdentifier":"/us/usc/t43/s3008/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fb%2F2%2FB","sourceRelease":"119-100","text":"A payment to a county under paragraph (1) shall be in addition to a payment in lieu of taxes received by the county under chapter 69 of title 31.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Timing","label":"C Timing","identifier":"/us/usc/t43/s3008/b/2/C","parentIdentifier":"/us/usc/t43/s3008/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs3008%2Fb%2F2%2FC","sourceRelease":"119-100","text":"The amounts required to be paid under paragraph (1)(B) for an applicable fiscal year shall be made available in the fiscal year that immediately follows the fiscal year for which the amounts were collected.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
