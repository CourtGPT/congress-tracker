es":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s1437aaa–5/5/B","parentIdentifier":"/us/usc/t42/s1437aaa–5/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437aaa%E2%80%935%2F5%2FB","sourceRelease":"119-100","text":"adopts written procedures providing for the election of officers on a regular basis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s1437aaa–5/5/C","parentIdentifier":"/us/usc/t42/s1437aaa–5/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437aaa%E2%80%935%2F5%2FC","sourceRelease":"119-100","text":"has a democratically elected governing board, elected by the tenants of the housing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
