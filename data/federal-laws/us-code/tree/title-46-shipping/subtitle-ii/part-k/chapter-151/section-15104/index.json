{"type":"section","nativeType":"section","number":"15104","heading":"National Merchant Mariner Medical Advisory Committee","label":"15104 National Merchant Mariner Medical Advisory Committee","identifier":"/us/usc/t46/s15104","parentIdentifier":"/us/usc/t46/stII/ptK/ch151","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15104","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t46/s15104/a","parentIdentifier":"/us/usc/t46/s15104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15104%2Fa","sourceRelease":"119-100","text":"There is established a National Merchant Mariner Medical Advisory Committee (in this section referred to as the “Committee”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Function","label":"b .—Function","identifier":"/us/usc/t46/s15104/b","parentIdentifier":"/us/usc/t46/s15104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15104%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s15104/b/1","parentIdentifier":"/us/usc/t46/s15104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15104%2Fb%2F1","sourceRelease":"119-100","text":"medical certification determinations for the issuance of licenses, certification of registry, and merchant mariners’ documents with respect to merchant mariners;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s15104/b/2","parentIdentifier":"/us/usc/t46/s15104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15104%2Fb%2F2","sourceRelease":"119-100","text":"medical standards and guidelines for the physical qualifications of operators of commercial vessels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s15104/b/3","parentIdentifier":"/us/usc/t46/s15104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15104%2Fb%2F3","sourceRelease":"119-100","text":"medical examiner education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t46/s15104/b/4","parentIdentifier":"/us/usc/t46/s15104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15104%2Fb%2F4","sourceRelease":"119-100","text":"medical research.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Membership.—","label":"c Membership.—","identifier":"/us/usc/t46/s15104/c","parentIdentifier":"/us/usc/t46/s15104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15104%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t46/s15104/c/1","parentIdentifier":"/us/usc/t46/s15104/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15104%2Fc%2F1","sourceRelease":"119-100","text":"The Committee shall consist of 14 members appointed by the Secretary in accordance with this section and section 15109 of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Expertise","label":"2 .—Expertise","identifier":"/us/usc/t46/s15104/c/2","parentIdentifier":"/us/usc/t46/s15104/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15104%2Fc%2F2","sourceRelease":"119-100","text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Representation","label":"3 .—Representation","identifier":"/us/usc/t46/s15104/c/3","parentIdentifier":"/us/usc/t46/s15104/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15104%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s15104/c/3/A","parentIdentifier":"/us/usc/t46/s15104/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15104%2Fc%2F3%2FA","sourceRelease":"119-100","text":"9 shall represent health-care professionals and have particular expertise, knowledge, and experience regarding the medical examinations of merchant mariners or occupational medicine.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s15104/c/3/B","parentIdentifier":"/us/usc/t46/s15104/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15104%2Fc%2F3%2FB","sourceRelease":"119-100","text":"5 shall represent professional mariners and have particular expertise, knowledge, and experience in occupational requirements for mariners.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
