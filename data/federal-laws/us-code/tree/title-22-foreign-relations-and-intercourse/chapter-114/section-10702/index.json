{"type":"section","nativeType":"section","number":"10702","heading":"Sense of Congress","label":"10702 Sense of Congress","identifier":"/us/usc/t22/s10702","parentIdentifier":"/us/usc/t22/ch114","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10702/1","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F1","sourceRelease":"119-100","text":"encourage increased business links and investment between the United States and allies and partners;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10702/2","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F2","sourceRelease":"119-100","text":"support regional integration efforts in the Western Balkans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s10702/3","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F3","sourceRelease":"119-100","text":"strengthen and expand regional economic integration in the Western Balkans, with consideration for enterprises owned by and employing women and youth;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s10702/4","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F4","sourceRelease":"119-100","text":"work with allies and partners committed to improving the rule of law, energy resource diversification, democratic and economic reform, and the reduction of poverty in the Western Balkans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s10702/5","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10702/5/A","parentIdentifier":"/us/usc/t22/s10702/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F5%2FA","sourceRelease":"119-100","text":"to decrease dependence on Russian energy sources and fossil fuels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10702/5/B","parentIdentifier":"/us/usc/t22/s10702/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F5%2FB","sourceRelease":"119-100","text":"to increase energy diversification, efficiency, and conservation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10702/5/C","parentIdentifier":"/us/usc/t22/s10702/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F5%2FC","sourceRelease":"119-100","text":"to facilitate the transition to cleaner and more reliable sources of energy, including renewables, as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s10702/6","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10702/6/A","parentIdentifier":"/us/usc/t22/s10702/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F6%2FA","sourceRelease":"119-100","text":"strong civil societies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10702/6/B","parentIdentifier":"/us/usc/t22/s10702/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F6%2FB","sourceRelease":"119-100","text":"public-private partnerships;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10702/6/C","parentIdentifier":"/us/usc/t22/s10702/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F6%2FC","sourceRelease":"119-100","text":"independent media;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s10702/6/D","parentIdentifier":"/us/usc/t22/s10702/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F6%2FD","sourceRelease":"119-100","text":"transparent, accountable, citizen-responsive governance that ensure equal representation of all ethnic groups and respect for religious freedom;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t22/s10702/6/E","parentIdentifier":"/us/usc/t22/s10702/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F6%2FE","sourceRelease":"119-100","text":"political stability; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t22/s10702/6/F","parentIdentifier":"/us/usc/t22/s10702/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F6%2FF","sourceRelease":"119-100","text":"modern, free-market based economies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t22/s10702/7","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10702/7/A","parentIdentifier":"/us/usc/t22/s10702/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F7%2FA","sourceRelease":"119-100","text":"desire membership;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10702/7/B","parentIdentifier":"/us/usc/t22/s10702/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F7%2FB","sourceRelease":"119-100","text":"are eligible for membership,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10702/7/C","parentIdentifier":"/us/usc/t22/s10702/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F7%2FC","sourceRelease":"119-100","text":"are supported by all allies to proceed with an invitation for such membership; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s10702/7/D","parentIdentifier":"/us/usc/t22/s10702/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F7%2FD","sourceRelease":"119-100","text":"are in a position to further the principles of the North Atlantic Treaty and meaningfully contribute to the collective security of NATO;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t22/s10702/8","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10702/8/A","parentIdentifier":"/us/usc/t22/s10702/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F8%2FA","sourceRelease":"119-100","text":"maintaining the full European Union Force (EUFOR) mandate in Bosnia and Herzegovina as being in the national security interests of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10702/8/B","parentIdentifier":"/us/usc/t22/s10702/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F8%2FB","sourceRelease":"119-100","text":"encouraging NATO and the European Union to review their mission mandates and posture in Bosnia and Herzegovina to ensure they are playing a proactive role in establishing a safe and secure environment, particularly in the realm of defense;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t22/s10702/9","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F9","sourceRelease":"119-100","text":"acknowledge the European Union membership aspirations of Albania, Bosnia and Herzegovina, Kosovo, North Macedonia, Montenegro, and Serbia and support those countries to meet the benchmarks required for their accession;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t22/s10702/10","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F10","sourceRelease":"119-100","text":"continue to support the cultural heritage, and recognize the languages, of the Western Balkans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t22/s10702/11","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F11","sourceRelease":"119-100","text":"coordinate closely with the European Union, the United Kingdom, and other allies and partners on sanctions designations in Western Balkans countries and work to align efforts as much as possible to demonstrate a clear commitment to upholding democratic values;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t22/s10702/12","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F12","sourceRelease":"119-100","text":"expand bilateral security cooperation with non-NATO member Western Balkans countries, particularly efforts focused on regional integration and cooperation, including through the Adriatic Charter, which was launched at Tirana on ;May 2, 2003","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"13","heading":null,"label":"13","identifier":"/us/usc/t22/s10702/13","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F13","sourceRelease":"119-100","text":"increase efforts to combat Russian malign influence campaigns and any other destabilizing or disruptive activities targeting the Western Balkans through engagement with government institutions, political stakeholders, journalists, civil society organizations, and industry leaders;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"14","heading":null,"label":"14","identifier":"/us/usc/t22/s10702/14","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F14","sourceRelease":"119-100","text":"develop a series of cyber resilience standards, consistent with the Enhanced Cyber Defence Policy and Readiness Action Plan endorsed at the 2014 Wales Summit of the North Atlantic Treaty Organization to expand cooperation with partners and allies, including in the Western Balkans, on cyber security, hybrid warfare, and ICT infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"15","heading":null,"label":"15","identifier":"/us/usc/t22/s10702/15","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F15","sourceRelease":"119-100","text":"articulate clearly and unambiguously the United States commitment to supporting democratic values and respect for international law as the sole path forward for the countries of the Western Balkans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"16","heading":null,"label":"16","identifier":"/us/usc/t22/s10702/16","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F16","sourceRelease":"119-100","text":"prioritize partnerships and programming with Western Balkan countries that demonstrate commitment toward strengthening their democracies and show respect for human rights;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"17","heading":null,"label":"17","identifier":"/us/usc/t22/s10702/17","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F17","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10702/17/A","parentIdentifier":"/us/usc/t22/s10702/17","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F17%2FA","sourceRelease":"119-100","text":"the development and expansion of the respective defense industrial bases of NATO Allies and security partners in the Western Balkan countries; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10702/17/B","parentIdentifier":"/us/usc/t22/s10702/17","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F17%2FB","sourceRelease":"119-100","text":"increased national defense spending in accordance with the NATO Hague Summit Declaration agreed to by all NATO Allies in June 2025;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"18","heading":null,"label":"18","identifier":"/us/usc/t22/s10702/18","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F18","sourceRelease":"119-100","text":"support the implementation of the Export Control and Related Border Security programs in the Western Balkans; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"19","heading":null,"label":"19","identifier":"/us/usc/t22/s10702/19","parentIdentifier":"/us/usc/t22/s10702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10702%2F19","sourceRelease":"119-100","text":"work with allies and partners to strengthen law enforcement and investigative capacities in Western Balkan countries to disrupt transnational criminal organizations and corruption.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
