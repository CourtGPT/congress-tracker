{"type":"section","nativeType":"section","number":"6127","heading":"Compressed schedules; agencies authorized to use","label":"6127 Compressed schedules; agencies authorized to use","identifier":"/us/usc/t5/s6127","parentIdentifier":"/us/usc/t5/ptIII/sptE/ch61/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6127","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s6127/a","parentIdentifier":"/us/usc/t5/s6127","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6127%2Fa","sourceRelease":"119-100","text":"Notwithstanding , each agency may establish programs which use a 4-day workweek or other compressed schedule.section 6101 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s6127/b","parentIdentifier":"/us/usc/t5/s6127","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6127%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6127/b/1","parentIdentifier":"/us/usc/t5/s6127/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6127%2Fb%2F1","sourceRelease":"119-100","text":"An employee in a unit with respect to which an organization of Government employees has not been accorded exclusive recognition shall not be required to participate in any program under subsection (a) unless a majority of the employees in such unit who, but for this paragraph, would be included in such program have voted to be so included.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6127/b/2","parentIdentifier":"/us/usc/t5/s6127/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6127%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s6127/b/2/A","parentIdentifier":"/us/usc/t5/s6127/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6127%2Fb%2F2%2FA","sourceRelease":"119-100","text":"except such employee from such program; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s6127/b/2/B","parentIdentifier":"/us/usc/t5/s6127/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6127%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t5/s6127/b/2/B/i","parentIdentifier":"/us/usc/t5/s6127/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6127%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"which becomes vacant after such determination,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t5/s6127/b/2/B/ii","parentIdentifier":"/us/usc/t5/s6127/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6127%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"which is not included within such program,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t5/s6127/b/2/B/iii","parentIdentifier":"/us/usc/t5/s6127/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6127%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"for which such employee is qualified, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t5/s6127/b/2/B/iv","parentIdentifier":"/us/usc/t5/s6127/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6127%2Fb%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"which is acceptable to the employee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
