{"type":"section","nativeType":"section","number":"16102","heading":"Diesel fueled vehicles","label":"16102 Diesel fueled vehicles","identifier":"/us/usc/t42/s16102","parentIdentifier":"/us/usc/t42/ch149/schVII/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16102","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definition of tier 2 emission standards","label":"a Definition of tier 2 emission standards","identifier":"/us/usc/t42/s16102/a","parentIdentifier":"/us/usc/t42/s16102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16102%2Fa","sourceRelease":"119-100","text":"In this section, the term “tier 2 emission standards” means the motor vehicle emission standards that apply to passenger cars, light trucks, and larger passenger vehicles manufactured after the 2003 model year, as issued on , by the Administrator of the Environmental Protection Agency under sections 7521 and 7545 of this title.February 10, 2000","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Diesel combustion and after-treatment technologies","label":"b Diesel combustion and after-treatment technologies","identifier":"/us/usc/t42/s16102/b","parentIdentifier":"/us/usc/t42/s16102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16102%2Fb","sourceRelease":"119-100","text":"The Secretary shall accelerate efforts to improve diesel combustion and after-treatment technologies for use in diesel fueled motor vehicles.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Goals","label":"c Goals","identifier":"/us/usc/t42/s16102/c","parentIdentifier":"/us/usc/t42/s16102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16102%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16102/c/1","parentIdentifier":"/us/usc/t42/s16102/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16102%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16102/c/1/A","parentIdentifier":"/us/usc/t42/s16102/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16102%2Fc%2F1%2FA","sourceRelease":"119-100","text":"Tier 2 emission standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16102/c/1/B","parentIdentifier":"/us/usc/t42/s16102/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16102%2Fc%2F1%2FB","sourceRelease":"119-100","text":"The heavy-duty emissions standards of 2007 that are applicable to heavy-duty vehicles under regulations issued by the Administrator of the Environmental Protection Agency as of .August 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16102/c/2","parentIdentifier":"/us/usc/t42/s16102/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16102%2Fc%2F2","sourceRelease":"119-100","text":"Developing the next generation of low-emission, high efficiency diesel engine technologies, including homogeneous charge compression ignition technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
