{"type":"section","nativeType":"section","number":"563d","heading":"Small business contracting goals","label":"563d Small business contracting goals","identifier":"/us/usc/t6/s563d","parentIdentifier":"/us/usc/t6/ch1/schXII–A/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s563d/1","parentIdentifier":"/us/usc/t6/s563d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563d%2F1","sourceRelease":"119-100","text":"the Administration’s performance record with respect to meeting its published small-business contracting goals during the preceding fiscal year;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s563d/2","parentIdentifier":"/us/usc/t6/s563d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563d%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s563d/2/A","parentIdentifier":"/us/usc/t6/s563d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563d%2F2%2FA","sourceRelease":"119-100","text":"a list of challenges, including deviations from the Administration’s subcontracting plans, and factors that contributed to the level of performance during the preceding fiscal year;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s563d/2/B","parentIdentifier":"/us/usc/t6/s563d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563d%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s563d/2/B/i","parentIdentifier":"/us/usc/t6/s563d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563d%2F2%2FB%2Fi","sourceRelease":"119-100","text":"is prepared after consultation with the Secretary of Defense and the heads of Federal departments and agencies that achieved their published goals for prime contracting with small and minority-owned businesses, including small and disadvantaged businesses, in prior fiscal years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s563d/2/B/ii","parentIdentifier":"/us/usc/t6/s563d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563d%2F2%2FB%2Fii","sourceRelease":"119-100","text":"identifies policies and procedures that could be incorporated by the Administration in furtherance of achieving the Administration’s published goal for such contracting; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s563d/3","parentIdentifier":"/us/usc/t6/s563d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563d%2F3","sourceRelease":"119-100","text":"a status report on the implementation of the action plan that was developed in the preceding fiscal year in accordance with paragraph (2)(B), if such a plan was required.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
