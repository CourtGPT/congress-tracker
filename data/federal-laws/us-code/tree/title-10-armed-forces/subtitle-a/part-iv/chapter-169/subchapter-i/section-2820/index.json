{"type":"section","nativeType":"section","number":"2820","heading":"Development of infrastructure improvement plan for each military department","label":"2820 Development of infrastructure improvement plan for each military department","identifier":"/us/usc/t10/s2820","parentIdentifier":"/us/usc/t10/stA/ptIV/ch169/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t10/s2820/a","parentIdentifier":"/us/usc/t10/s2820","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2820/a/1","parentIdentifier":"/us/usc/t10/s2820/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2820/a/1/A","parentIdentifier":"/us/usc/t10/s2820/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fa%2F1%2FA","sourceRelease":"119-100","text":"a summary of major efforts of the Secretary concerned to be carried out pursuant to the plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2820/a/1/B","parentIdentifier":"/us/usc/t10/s2820/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fa%2F1%2FB","sourceRelease":"119-100","text":"milestones and specific goals for such major efforts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s2820/a/1/C","parentIdentifier":"/us/usc/t10/s2820/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fa%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s2820/a/1/C/i","parentIdentifier":"/us/usc/t10/s2820/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fa%2F1%2FC%2Fi","sourceRelease":"119-100","text":"utility systems (electric, water and wastewater systems, energy distribution systems, transportation, and communication networks); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s2820/a/1/C/ii","parentIdentifier":"/us/usc/t10/s2820/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fa%2F1%2FC%2Fii","sourceRelease":"119-100","text":"all physical structures located on a military installation under the jurisdiction of the Secretary concerned.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2820/a/2","parentIdentifier":"/us/usc/t10/s2820/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fa%2F2","sourceRelease":"119-100","text":"A certification that the budget of the President for the applicable fiscal year and the future-years defense program submitted to Congress in relation to such budget under provide for funding of planning, design, and construction at a level that is sufficient to meet the requirements specified in the plan under paragraph (1) on the schedule provided in such plan.section 221 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Elements","label":"b .—Elements","identifier":"/us/usc/t10/s2820/b","parentIdentifier":"/us/usc/t10/s2820","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2820/b/1","parentIdentifier":"/us/usc/t10/s2820/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fb%2F1","sourceRelease":"119-100","text":"The estimated costs of necessary infrastructure and facility improvements and a description of how such costs would be addressed by the budget request of the Department of Defense and the future-years defense program submitted for the applicable fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2820/b/2","parentIdentifier":"/us/usc/t10/s2820/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fb%2F2","sourceRelease":"119-100","text":"An assessment of how the military department is accurately accounting for the costs of sustaining facilities and addressing the identified necessary improvements of infrastructure and facilities as outlined in the plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Incorporation of Results-oriented Management Practices","label":"c .—Incorporation of Results-oriented Management Practices","identifier":"/us/usc/t10/s2820/c","parentIdentifier":"/us/usc/t10/s2820","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2820/c/1","parentIdentifier":"/us/usc/t10/s2820/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fc%2F1","sourceRelease":"119-100","text":"analytically based goals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2820/c/2","parentIdentifier":"/us/usc/t10/s2820/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fc%2F2","sourceRelease":"119-100","text":"results-oriented metrics;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2820/c/3","parentIdentifier":"/us/usc/t10/s2820/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fc%2F3","sourceRelease":"119-100","text":"an identification of required resources, risks, and stakeholders; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s2820/c/4","parentIdentifier":"/us/usc/t10/s2820/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fc%2F4","sourceRelease":"119-100","text":"regular reporting on progress to decision makers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Service Chief Assessment","label":"d .—Service Chief Assessment","identifier":"/us/usc/t10/s2820/d","parentIdentifier":"/us/usc/t10/s2820","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2820/d/1","parentIdentifier":"/us/usc/t10/s2820/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fd%2F1","sourceRelease":"119-100","text":"assess each plan and certification developed by the Secretary concerned under subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2820/d/2","parentIdentifier":"/us/usc/t10/s2820/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2820%2Fd%2F2","sourceRelease":"119-100","text":"submit to the congressional defense committees, not later than the date on which the Secretary concerned submits the plan and certification to such committees, an unaltered copy of the results of such assessment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
