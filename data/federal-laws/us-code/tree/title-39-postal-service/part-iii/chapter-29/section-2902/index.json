{"type":"section","nativeType":"section","number":"2902","heading":"Property management","label":"2902 Property management","identifier":"/us/usc/t39/s2902","parentIdentifier":"/us/usc/t39/ptIII/ch29","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe date of enactment of this chapter, referred to in subsec. (a)(4)(B)(ix), is the date of enactment of , which was approved .Pub. L. 114–318Dec. 16, 2016"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t39/s2902/a","parentIdentifier":"/us/usc/t39/s2902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t39/s2902/a/1","parentIdentifier":"/us/usc/t39/s2902/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F1","sourceRelease":"119-100","text":"shall maintain adequate inventory controls and accountability systems for postal property;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t39/s2902/a/2","parentIdentifier":"/us/usc/t39/s2902/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F2","sourceRelease":"119-100","text":"shall develop current and future workforce projections so as to have the capacity to assess the needs of the Postal Service workforce regarding the use of property;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t39/s2902/a/3","parentIdentifier":"/us/usc/t39/s2902/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t39/s2902/a/3/A","parentIdentifier":"/us/usc/t39/s2902/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F3%2FA","sourceRelease":"119-100","text":"establishes goals and policies that will lead to the reduction of excess property and underutilized property in the inventory of the Postal Service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t39/s2902/a/3/B","parentIdentifier":"/us/usc/t39/s2902/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F3%2FB","sourceRelease":"119-100","text":"adopts workplace practices, configurations, and management techniques that can achieve increased levels of productivity and decrease the need for real property assets;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t39/s2902/a/3/C","parentIdentifier":"/us/usc/t39/s2902/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F3%2FC","sourceRelease":"119-100","text":"assesses leased space to identify space that is not fully used or occupied;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t39/s2902/a/3/D","parentIdentifier":"/us/usc/t39/s2902/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F3%2FD","sourceRelease":"119-100","text":"develops recommendations on how to address excess capacity at Postal Service facilities without negatively impacting mail delivery; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t39/s2902/a/3/E","parentIdentifier":"/us/usc/t39/s2902/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F3%2FE","sourceRelease":"119-100","text":"develops recommendations on ensuring the security of mail processing operations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t39/s2902/a/4","parentIdentifier":"/us/usc/t39/s2902/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t39/s2902/a/4/A","parentIdentifier":"/us/usc/t39/s2902/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F4%2FA","sourceRelease":"119-100","text":"conduct an inventory of postal property that is real property; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t39/s2902/a/4/B","parentIdentifier":"/us/usc/t39/s2902/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t39/s2902/a/4/B/i","parentIdentifier":"/us/usc/t39/s2902/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F4%2FB%2Fi","sourceRelease":"119-100","text":"the date on which the Postal Service first occupied the property;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t39/s2902/a/4/B/ii","parentIdentifier":"/us/usc/t39/s2902/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F4%2FB%2Fii","sourceRelease":"119-100","text":"the size of the property in square footage and acreage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t39/s2902/a/4/B/iii","parentIdentifier":"/us/usc/t39/s2902/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F4%2FB%2Fiii","sourceRelease":"119-100","text":"the geographical location of the property, including an address and description;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t39/s2902/a/4/B/iv","parentIdentifier":"/us/usc/t39/s2902/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F4%2FB%2Fiv","sourceRelease":"119-100","text":"the extent to which the property is being utilized;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t39/s2902/a/4/B/v","parentIdentifier":"/us/usc/t39/s2902/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F4%2FB%2Fv","sourceRelease":"119-100","text":"the actual annual operating costs associated with the property;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t39/s2902/a/4/B/vi","parentIdentifier":"/us/usc/t39/s2902/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F4%2FB%2Fvi","sourceRelease":"119-100","text":"the total cost of capital expenditures associated with the property;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t39/s2902/a/4/B/vii","parentIdentifier":"/us/usc/t39/s2902/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F4%2FB%2Fvii","sourceRelease":"119-100","text":"the number of postal employees, contractor employees, and functions housed at the property;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t39/s2902/a/4/B/viii","parentIdentifier":"/us/usc/t39/s2902/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F4%2FB%2Fviii","sourceRelease":"119-100","text":"the extent to which the mission of the Postal Service is dependent on the property; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ix","heading":null,"label":"ix","identifier":"/us/usc/t39/s2902/a/4/B/ix","parentIdentifier":"/us/usc/t39/s2902/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fa%2F4%2FB%2Fix","sourceRelease":"119-100","text":"the estimated amount of capital expenditures projected to maintain and operate the property over each of the next 5 years after the date of enactment of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Rule of Construction","label":"b .—Rule of Construction","identifier":"/us/usc/t39/s2902/b","parentIdentifier":"/us/usc/t39/s2902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2902%2Fb","sourceRelease":"119-100","text":"Nothing in subsection (a)(4)(B) shall be construed to require the Postal Service to obtain an appraisal of postal property.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
