{"type":"section","nativeType":"section","number":"3057","heading":"Rule violations and civil sanctions","label":"3057 Rule violations and civil sanctions","identifier":"/us/usc/t15/s3057","parentIdentifier":"/us/usc/t15/ch57A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Description of rule violations","label":"a Description of rule violations","identifier":"/us/usc/t15/s3057/a","parentIdentifier":"/us/usc/t15/s3057","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s3057/a/1","parentIdentifier":"/us/usc/t15/s3057/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F1","sourceRelease":"119-100","text":"The Authority shall issue, by rule in accordance with , a description of safety, performance, and anti-doping and medication control rule violations applicable to covered horses and covered persons.section 3053 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Elements","label":"2 Elements","identifier":"/us/usc/t15/s3057/a/2","parentIdentifier":"/us/usc/t15/s3057/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s3057/a/2/A","parentIdentifier":"/us/usc/t15/s3057/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s3057/a/2/A/i","parentIdentifier":"/us/usc/t15/s3057/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the presence of a prohibited substance or method in a sample or the use of a prohibited substance or method;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s3057/a/2/A/ii","parentIdentifier":"/us/usc/t15/s3057/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the presence of a permitted substance in a sample in excess of the amount allowed by the horseracing anti-doping and medication control program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s3057/a/2/A/iii","parentIdentifier":"/us/usc/t15/s3057/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"the use of a permitted method in violation of the applicable limitations established under the horseracing anti-doping and medication control program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s3057/a/2/B","parentIdentifier":"/us/usc/t15/s3057/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FB","sourceRelease":"119-100","text":"Attempted use of a prohibited substance or method on a covered horse.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s3057/a/2/C","parentIdentifier":"/us/usc/t15/s3057/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FC","sourceRelease":"119-100","text":"Possession of any prohibited substance or method.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s3057/a/2/D","parentIdentifier":"/us/usc/t15/s3057/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FD","sourceRelease":"119-100","text":"Attempted possession of any prohibited substance or method.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s3057/a/2/E","parentIdentifier":"/us/usc/t15/s3057/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FE","sourceRelease":"119-100","text":"Administration or attempted administration of any prohibited substance or method on a covered horse.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t15/s3057/a/2/F","parentIdentifier":"/us/usc/t15/s3057/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FF","sourceRelease":"119-100","text":"Refusal or failure, without compelling justification, to submit a covered horse for sample collection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t15/s3057/a/2/G","parentIdentifier":"/us/usc/t15/s3057/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FG","sourceRelease":"119-100","text":"Failure to cooperate with the Authority or an agent of the Authority during any investigation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t15/s3057/a/2/H","parentIdentifier":"/us/usc/t15/s3057/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FH","sourceRelease":"119-100","text":"Failure to respond truthfully, to the best of a covered person’s knowledge, to a question of the Authority or an agent of the Authority with respect to any matter under the jurisdiction of the Authority.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s3057/a/2/I","parentIdentifier":"/us/usc/t15/s3057/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FI","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s3057/a/2/I/i","parentIdentifier":"/us/usc/t15/s3057/a/2/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FI%2Fi","sourceRelease":"119-100","text":"the intentional interference, or an attempt to interfere, with an official or agent of the Authority;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s3057/a/2/I/ii","parentIdentifier":"/us/usc/t15/s3057/a/2/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FI%2Fii","sourceRelease":"119-100","text":"the procurement or the provision of fraudulent information to the Authority or agent; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s3057/a/2/I/iii","parentIdentifier":"/us/usc/t15/s3057/a/2/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FI%2Fiii","sourceRelease":"119-100","text":"the intimidation of, or an attempt to intimidate, a potential witness.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t15/s3057/a/2/J","parentIdentifier":"/us/usc/t15/s3057/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FJ","sourceRelease":"119-100","text":"Trafficking or attempted trafficking in any prohibited substance or method.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"K","heading":null,"label":"K","identifier":"/us/usc/t15/s3057/a/2/K","parentIdentifier":"/us/usc/t15/s3057/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FK","sourceRelease":"119-100","text":"Assisting, encouraging, aiding, abetting, conspiring, covering up, or any other type of intentional complicity involving a safety, performance, or anti-doping and medication control rule violation or the violation of a period of suspension or eligibility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"L","heading":null,"label":"L","identifier":"/us/usc/t15/s3057/a/2/L","parentIdentifier":"/us/usc/t15/s3057/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FL","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s3057/a/2/L/i","parentIdentifier":"/us/usc/t15/s3057/a/2/L","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FL%2Fi","sourceRelease":"119-100","text":"an alleged safety, performance, or anti-doping and medication control rule violation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s3057/a/2/L/ii","parentIdentifier":"/us/usc/t15/s3057/a/2/L","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fa%2F2%2FL%2Fii","sourceRelease":"119-100","text":"alleged noncompliance with a safety, performance, or anti-doping and medication control rule.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Testing laboratories","label":"b Testing laboratories","identifier":"/us/usc/t15/s3057/b","parentIdentifier":"/us/usc/t15/s3057","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Accreditation and standards","label":"1 Accreditation and standards","identifier":"/us/usc/t15/s3057/b/1","parentIdentifier":"/us/usc/t15/s3057/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s3057/b/1/A","parentIdentifier":"/us/usc/t15/s3057/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fb%2F1%2FA","sourceRelease":"119-100","text":"standards of accreditation for laboratories involved in testing samples from covered horses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s3057/b/1/B","parentIdentifier":"/us/usc/t15/s3057/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the process for achieving and maintaining accreditation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s3057/b/1/C","parentIdentifier":"/us/usc/t15/s3057/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the standards and protocols for testing such samples.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Administration","label":"2 Administration","identifier":"/us/usc/t15/s3057/b/2","parentIdentifier":"/us/usc/t15/s3057/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fb%2F2","sourceRelease":"119-100","text":"The accreditation of laboratories and the conduct of audits of accredited laboratories to ensure compliance with Authority rules shall be administered by the anti-doping and medication control enforcement agency. The anti-doping and medication control enforcement agency shall have the authority to require specific test samples to be directed to and tested by laboratories having special expertise in the required tests.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Extension of provisional or interim accreditation","label":"3 Extension of provisional or interim accreditation","identifier":"/us/usc/t15/s3057/b/3","parentIdentifier":"/us/usc/t15/s3057/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fb%2F3","sourceRelease":"119-100","text":"The Authority may, by rule in accordance with , extend provisional or interim accreditation to a laboratory accredited by the Racing Medication and Testing Consortium, Inc., on a date before the program effective date.section 3053 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Selection of laboratories","label":"4 Selection of laboratories","identifier":"/us/usc/t15/s3057/b/4","parentIdentifier":"/us/usc/t15/s3057/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s3057/b/4/A","parentIdentifier":"/us/usc/t15/s3057/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fb%2F4%2FA","sourceRelease":"119-100","text":"Except as provided in paragraph (2), a State racing commission may select a laboratory accredited in accordance with the standards established under paragraph (1) to test samples taken in the applicable State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Selection by the authority","label":"B Selection by the authority","identifier":"/us/usc/t15/s3057/b/4/B","parentIdentifier":"/us/usc/t15/s3057/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fb%2F4%2FB","sourceRelease":"119-100","text":"If a State racing commission does not select an accredited laboratory under subparagraph (A), the Authority shall select such a laboratory to test samples taken in the State concerned.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Results management and disciplinary process","label":"c Results management and disciplinary process","identifier":"/us/usc/t15/s3057/c","parentIdentifier":"/us/usc/t15/s3057","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s3057/c/1","parentIdentifier":"/us/usc/t15/s3057/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s3057/c/1/A","parentIdentifier":"/us/usc/t15/s3057/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fc%2F1%2FA","sourceRelease":"119-100","text":"rules for safety, performance, and anti-doping and medication control results management; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s3057/c/1/B","parentIdentifier":"/us/usc/t15/s3057/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fc%2F1%2FB","sourceRelease":"119-100","text":"the disciplinary process for safety, performance, and anti-doping and medication control rule violations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Elements","label":"2 Elements","identifier":"/us/usc/t15/s3057/c/2","parentIdentifier":"/us/usc/t15/s3057/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s3057/c/2/A","parentIdentifier":"/us/usc/t15/s3057/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fc%2F2%2FA","sourceRelease":"119-100","text":"Provisions for notification of safety, performance, and anti-doping and medication control rule violations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s3057/c/2/B","parentIdentifier":"/us/usc/t15/s3057/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fc%2F2%2FB","sourceRelease":"119-100","text":"Hearing procedures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s3057/c/2/C","parentIdentifier":"/us/usc/t15/s3057/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fc%2F2%2FC","sourceRelease":"119-100","text":"Standards for burden of proof.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s3057/c/2/D","parentIdentifier":"/us/usc/t15/s3057/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fc%2F2%2FD","sourceRelease":"119-100","text":"Presumptions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s3057/c/2/E","parentIdentifier":"/us/usc/t15/s3057/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fc%2F2%2FE","sourceRelease":"119-100","text":"Evidentiary rules.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t15/s3057/c/2/F","parentIdentifier":"/us/usc/t15/s3057/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fc%2F2%2FF","sourceRelease":"119-100","text":"Appeals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t15/s3057/c/2/G","parentIdentifier":"/us/usc/t15/s3057/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fc%2F2%2FG","sourceRelease":"119-100","text":"Guidelines for confidentiality and public reporting of decisions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Due process","label":"3 Due process","identifier":"/us/usc/t15/s3057/c/3","parentIdentifier":"/us/usc/t15/s3057/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fc%2F3","sourceRelease":"119-100","text":"The rules established under paragraph (1) shall provide for adequate due process, including impartial hearing officers or tribunals commensurate with the seriousness of the alleged safety, performance, or anti-doping and medication control rule violation and the possible civil sanctions for such violation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Civil sanctions","label":"d Civil sanctions","identifier":"/us/usc/t15/s3057/d","parentIdentifier":"/us/usc/t15/s3057","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s3057/d/1","parentIdentifier":"/us/usc/t15/s3057/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fd%2F1","sourceRelease":"119-100","text":"The Authority shall establish uniform rules, in accordance with , imposing civil sanctions against covered persons or covered horses for safety, performance, and anti-doping and medication control rule violations.section 3053 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t15/s3057/d/2","parentIdentifier":"/us/usc/t15/s3057/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s3057/d/2/A","parentIdentifier":"/us/usc/t15/s3057/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fd%2F2%2FA","sourceRelease":"119-100","text":"take into account the unique aspects of horseracing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s3057/d/2/B","parentIdentifier":"/us/usc/t15/s3057/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fd%2F2%2FB","sourceRelease":"119-100","text":"be designed to ensure fair and transparent horseraces; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s3057/d/2/C","parentIdentifier":"/us/usc/t15/s3057/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fd%2F2%2FC","sourceRelease":"119-100","text":"deter safety, performance, and anti-doping and medication control rule violations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Severity","label":"3 Severity","identifier":"/us/usc/t15/s3057/d/3","parentIdentifier":"/us/usc/t15/s3057/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s3057/d/3/A","parentIdentifier":"/us/usc/t15/s3057/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fd%2F3%2FA","sourceRelease":"119-100","text":"lifetime bans from horseracing, disgorgement of purses, monetary fines and penalties, and changes to the order of finish in covered races; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s3057/d/3/B","parentIdentifier":"/us/usc/t15/s3057/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fd%2F3%2FB","sourceRelease":"119-100","text":"with respect to anti-doping and medication control rule violators, an opportunity to reduce the applicable civil sanctions that is comparable to the opportunity provided by the Protocol for Olympic Movement Testing of the United States Anti-Doping Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Modifications","label":"e Modifications","identifier":"/us/usc/t15/s3057/e","parentIdentifier":"/us/usc/t15/s3057","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3057%2Fe","sourceRelease":"119-100","text":"The Authority may propose a modification to any rule established under this section as the Authority considers appropriate, and the proposed modification shall be submitted to and considered by the Commission in accordance with .section 3053 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
