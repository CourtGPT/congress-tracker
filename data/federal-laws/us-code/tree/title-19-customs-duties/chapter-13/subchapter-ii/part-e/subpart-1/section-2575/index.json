{"type":"section","nativeType":"section","number":"2575","heading":"General","label":"2575 General","identifier":"/us/usc/t19/s2575","parentIdentifier":"/us/usc/t19/ch13/schII/ptE/spt1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s2575/1","parentIdentifier":"/us/usc/t19/s2575","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575%2F1","sourceRelease":"119-100","text":"to prohibit a Federal agency or State agency from engaging in activity related to sanitary or phytosanitary measures to protect human, animal, or plant life or health; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s2575/2","parentIdentifier":"/us/usc/t19/s2575","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2575%2F2","sourceRelease":"119-100","text":"to limit the authority of a Federal agency or State agency to determine the level of protection of human, animal, or plant life or health the agency considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
