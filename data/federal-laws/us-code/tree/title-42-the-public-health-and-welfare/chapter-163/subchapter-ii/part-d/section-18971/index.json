{"type":"section","nativeType":"section","number":"18971","heading":"Expanding opportunities through the Manufacturing USA Program","label":"18971 Expanding opportunities through the Manufacturing USA Program","identifier":"/us/usc/t42/s18971","parentIdentifier":"/us/usc/t42/ch163/schII/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18971","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s18971/a","parentIdentifier":"/us/usc/t42/s18971","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18971%2Fa","sourceRelease":"119-100","text":"The Secretary of Commerce, in consultation with the Secretary of Energy, the Secretary of Defense, and the heads of such other Federal agencies as the Secretary of Commerce considers relevant, shall coordinate with existing and new Manufacturing USA institutes to integrate covered entities as active members of the Manufacturing USA institutes, including through the development of preferences in selection criteria for proposals to create new Manufacturing USA institutes or renew existing Manufacturing USA institutes that include one or more covered entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Covered entities","label":"b Covered entities","identifier":"/us/usc/t42/s18971/b","parentIdentifier":"/us/usc/t42/s18971","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18971%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18971/b/1","parentIdentifier":"/us/usc/t42/s18971/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18971%2Fb%2F1","sourceRelease":"119-100","text":"an historically Black college and university;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18971/b/2","parentIdentifier":"/us/usc/t42/s18971/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18971%2Fb%2F2","sourceRelease":"119-100","text":"a Tribal College or University;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18971/b/3","parentIdentifier":"/us/usc/t42/s18971/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18971%2Fb%2F3","sourceRelease":"119-100","text":"a minority-serving institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18971/b/4","parentIdentifier":"/us/usc/t42/s18971/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18971%2Fb%2F4","sourceRelease":"119-100","text":"a minority business enterprise (as such term is defined in section 1400.2 of title 15, Code of Federal Regulations, or successor regulation); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s18971/b/5","parentIdentifier":"/us/usc/t42/s18971/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18971%2Fb%2F5","sourceRelease":"119-100","text":"a rural-serving institution of higher education (as such term is defined in ).section 1161q of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
