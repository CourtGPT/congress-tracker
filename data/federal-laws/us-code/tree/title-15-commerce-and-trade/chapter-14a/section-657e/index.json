{"type":"section","nativeType":"section","number":"657e","heading":"Mentoring Networks","label":"657e Mentoring Networks","identifier":"/us/usc/t15/s657e","parentIdentifier":"/us/usc/t15/ch14A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Findings","label":"a Findings","identifier":"/us/usc/t15/s657e/a","parentIdentifier":"/us/usc/t15/s657e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s657e/a/1","parentIdentifier":"/us/usc/t15/s657e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fa%2F1","sourceRelease":"119-100","text":"the SBIR and STTR programs create jobs, increase capacity for technological innovation, and boost international competitiveness;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s657e/a/2","parentIdentifier":"/us/usc/t15/s657e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fa%2F2","sourceRelease":"119-100","text":"increasing the quantity of applications from all States to the SBIR and STTR programs would enhance competition for such awards and the quality of the completed projects; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s657e/a/3","parentIdentifier":"/us/usc/t15/s657e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fa%2F3","sourceRelease":"119-100","text":"mentoring is a natural complement to the FAST program of reaching out to new companies regarding the SBIR and STTR programs as an effective and low-cost way to improve the likelihood that such companies will succeed in such programs in developing and commercializing their research.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Authorization for Mentoring Networks","label":"b Authorization for Mentoring Networks","identifier":"/us/usc/t15/s657e/b","parentIdentifier":"/us/usc/t15/s657e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fb","sourceRelease":"119-100","text":"The recipient of an award or participant in a cooperative agreement under may use a reasonable amount of such assistance for the establishment of a Mentoring Network under this section.section 657d of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Criteria for Mentoring Networks","label":"c Criteria for Mentoring Networks","identifier":"/us/usc/t15/s657e/c","parentIdentifier":"/us/usc/t15/s657e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s657e/c/1","parentIdentifier":"/us/usc/t15/s657e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fc%2F1","sourceRelease":"119-100","text":"provide business advice and counseling to high technology small business concerns located in the State or region served by the Mentoring Network and identified under as potential candidates for the SBIR or STTR programs;section 657d(c)(1)(E)(ii) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s657e/c/2","parentIdentifier":"/us/usc/t15/s657e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s657e/c/2/A","parentIdentifier":"/us/usc/t15/s657e/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fc%2F2%2FA","sourceRelease":"119-100","text":"are persons associated with a small business concern that has successfully completed one or more SBIR or STTR funding agreements; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s657e/c/2/B","parentIdentifier":"/us/usc/t15/s657e/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s657e/c/2/B/i","parentIdentifier":"/us/usc/t15/s657e/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"proposal writing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s657e/c/2/B/ii","parentIdentifier":"/us/usc/t15/s657e/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"marketing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clau