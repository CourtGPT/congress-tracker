ding":"Trust","label":"6 Trust","identifier":"/us/usc/t42/s12854/6","parentIdentifier":"/us/usc/t42/s12854","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12854%2F6","sourceRelease":"119-100","text":"The term “Trust” means the National Homeownership Trust established in .section 12851 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
