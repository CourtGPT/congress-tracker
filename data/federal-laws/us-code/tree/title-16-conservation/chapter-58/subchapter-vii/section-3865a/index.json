 semicolon at end.Pub. L. 115–334, § 2602(4)(B)Par. (5). , added par. (5). Former par. (5) redesignated (7).Pub. L. 115–334, § 2602(5)Pars. (6), (7). , redesignated pars. (4) and (5) as (6) and (7), respectively.Pub. L. 115–334, § 2602(2)"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Agricultural land easement","label":"1 Agricultural land easement","identifier":"/us/usc/t16/s3865a/1","parentIdentifier":"/us/usc/t16/s3865a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s3865a/1/A","parentIdentifier":"/us/usc/t16/s3865a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F1%2FA","sourceRelease":"119-100","text":"is conveyed for the purpose of protecting natural resources and the agricultural nature of the land; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s3865a/1/B","parentIdentifier":"/us/usc/t16/s3865a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F1%2FB","sourceRelease":"119-100","text":"permits the landowner the right to continue agricultural production and related uses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Buy-protect-sell transaction","label":"2 Buy-protect-sell transaction","identifier":"/us/usc/t16/s3865a/2","parentIdentifier":"/us/usc/t16/s3865a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s3865a/2/A","parentIdentifier":"/us/usc/t16/s3865a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s3865a/2/A/i","parentIdentifier":"/us/usc/t16/s3865a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F2%2FA%2Fi","sourceRelease":"119-100","text":"between an eligible entity and the Secretary relating to land that an eligible entity owns or is going to purchase prior to acquisition of an agricultural land easement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s3865a/2/A/ii","parentIdentifier":"/us/usc/t16/s3865a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F2%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s3865a/2/A/ii/I","parentIdentifier":"/us/usc/t16/s3865a/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F2%2FA%2Fii%2FI","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t16/s3865a/2/A/ii/I/aa","parentIdentifier":"/us/usc/t16/s3865a/2/A/ii/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F2%2FA%2Fii%2FI%2Faa","sourceRelease":"119-100","text":"hold an agricultural land easement on that land, but transfer ownership of the land to a farmer or rancher that is not an eligible entity prior to or on acquisition of the agricultural land easement; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t16/s3865a/2/A/ii/I/bb","parentIdentifier":"/us/usc/t16/s3865a/2/A/ii/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F2%2FA%2Fii%2FI%2Fbb","sourceRelease":"119-100","text":"hold an agricultural land easement on that land, but transfer ownership of the land to a farmer or rancher that is not an eligible entity in a timely manner and, subject to subparagraph (B), not later than 3 years after the date of acquisition of the agricultural land easement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s3865a/2/A/ii/II","parentIdentifier":"/us/usc/t16/s3865a/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F2%2FA%2Fii%2FII","sourceRelease":"119-100","text":"make an initial sale of the land subject to the agricultural land easement to a farmer or rancher at not more than agricultural value, plus any reasonable holding and transaction costs incurred by the eligible entity, as determined by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s3865a/2/A/iii","parentIdentifier":"/us/usc/t16/s3865a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"under which the Secretary shall be reimbursed for the entirety of the Federal share of the cost of the agricultural land easement by the eligible entity if the eligible entity fails to transfer ownership under item (aa) or (bb), as applicable, of clause (ii)(I).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Time extension","label":"B Time extension","identifier":"/us/usc/t16/s3865a/2/B","parentIdentifier":"/us/usc/t16/s3865a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F2%2FB","sourceRelease":"119-100","text":"Under subparagraph (A)(ii)(I)(bb), an eligible entity may transfer land later than 3 years after the date of acquisition of the agricultural land easement if the Secretary determines an extension of time is justified.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Eligible entity","label":"3 Eligible entity","identifier":"/us/usc/t16/s3865a/3","parentIdentifier":"/us/usc/t16/s3865a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s3865a/3/A","parentIdentifier":"/us/usc/t16/s3865a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F3%2FA","sourceRelease":"119-100","text":"an agency of State or local government or an Indian tribe (including a farmland protection board or land resource council established under State law); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s3865a/3/B","parentIdentifier":"/us/usc/t16/s3865a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s3865a/3/B/i","parentIdentifier":"/us/usc/t16/s3865a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F3%2FB%2Fi","sourceRelease":"119-100","text":"organized for, and at all times since the formation of the organization has been operated principally for, 1 or more of the conservation purposes specified in clause (i), (ii), (iii), or (iv) of ;section 170(h)(4)(A) of title 26","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s3865a/3/B/ii","parentIdentifier":"/us/usc/t16/s3865a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F3%2FB%2Fii","sourceRelease":"119-100","text":"an organization described in that is exempt from taxation under ; orsection 501(c)(3) of title 26section 501(a) of title 26","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s3865a/3/B/iii","parentIdentifier":"/us/usc/t16/s3865a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F3%2FB%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s3865a/3/B/iii/I","parentIdentifier":"/us/usc/t16/s3865a/3/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F3%2FB%2Fiii%2FI","sourceRelease":"119-100","text":"paragraph (1) or (2) of ; orsection 509(a) of title 26","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s3865a/3/B/iii/II","parentIdentifier":"/us/usc/t16/s3865a/3/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F3%2FB%2Fiii%2FII","sourceRelease":"119-100","text":"and is controlled by an organization described in .section 509(a)(3) of title 26section 509(a)(2) of title 26","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Eligible land","label":"4 Eligible land","identifier":"/us/usc/t16/s3865a/4","parentIdentifier":"/us/usc/t16/s3865a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s3865a/4/A","parentIdentifier":"/us/usc/t16/s3865a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s3865a/4/A/i","parentIdentifier":"/us/usc/t16/s3865a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s3865a/4/A/i/I","parentIdentifier":"/us/usc/t16/s3865a/4/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fi%2FI","sourceRelease":"119-100","text":"a pending offer for purchase of an agricultural land easement from an eligible entity; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s3865a/4/A/i/II","parentIdentifier":"/us/usc/t16/s3865a/4/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fi%2FII","sourceRelease":"119-100","text":"a buy-protect-sell transaction;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s3865a/4/A/ii","parentIdentifier":"/us/usc/t16/s3865a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s3865a/4/A/ii/I","parentIdentifier":"/us/usc/t16/s3865a/4/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fii%2FI","sourceRelease":"119-100","text":"that has prime, unique, or other productive soil;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s3865a/4/A/ii/II","parentIdentifier":"/us/usc/t16/s3865a/4/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fii%2FII","sourceRelease":"119-100","text":"that contains historical or archaeological resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s3865a/4/A/ii/III","parentIdentifier":"/us/usc/t16/s3865a/4/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fii%2FIII","sourceRelease":"119-100","text":"the enrollment of which would protect grazing uses and related conservation values by restoring and conserving land; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t16/s3865a/4/A/ii/IV","parentIdentifier":"/us/usc/t16/s3865a/4/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fii%2FIV","sourceRelease":"119-100","text":"the protection of which will further a State or local policy consistent with the purposes of the program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s3865a/4/A/iii","parentIdentifier":"/us/usc/t16/s3865a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s3865a/4/A/iii/I","parentIdentifier":"/us/usc/t16/s3865a/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"cropland;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s3865a/4/A/iii/II","parentIdentifier":"/us/usc/t16/s3865a/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"rangeland;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s3865a/4/A/iii/III","parentIdentifier":"/us/usc/t16/s3865a/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fiii%2FIII","sourceRelease":"119-100","text":"grassland or land that contains forbs, or shrubland for which grazing is the predominant use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t16/s3865a/4/A/iii/IV","parentIdentifier":"/us/usc/t16/s3865a/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fiii%2FIV","sourceRelease":"119-100","text":"located in an area that has been historically dominated by grassland, forbs, or shrubs and could provide habitat for animal or plant populations of significant ecological value;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t16/s3865a/4/A/iii/V","parentIdentifier":"/us/usc/t16/s3865a/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fiii%2FV","sourceRelease":"119-100","text":"pastureland; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VI","heading":null,"label":"VI","identifier":"/us/usc/t16/s3865a/4/A/iii/VI","parentIdentifier":"/us/usc/t16/s3865a/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FA%2Fiii%2FVI","sourceRelease":"119-100","text":"nonindustrial private forest land that contributes to the economic viability of an offered parcel or serves as a buffer to protect such land from development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s3865a/4/B","parentIdentifier":"/us/usc/t16/s3865a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s3865a/4/B/i","parentIdentifier":"/us/usc/t16/s3865a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s3865a/4/B/i/I","parentIdentifier":"/us/usc/t16/s3865a/4/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FB%2Fi%2FI","sourceRelease":"119-100","text":"is likely to be successfully restored in a cost-effective manner; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s3865a/4/B/i/II","parentIdentifier":"/us/usc/t16/s3865a/4/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FB%2Fi%2FII","sourceRelease":"119-100","text":"will maximize the wildlife benefits and wetland functions and values;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s3865a/4/B/ii","parentIdentifier":"/us/usc/t16/s3865a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s3865a/4/B/ii/I","parentIdentifier":"/us/usc/t16/s3865a/4/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FB%2Fii%2FI","sourceRelease":"119-100","text":"a closed basin lake and adjacent land that is functionally dependent upon it, if the State or other entity is willing to provide 50 percent share of the cost of an easement; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s3865a/4/B/ii/II","parentIdentifier":"/us/usc/t16/s3865a/4/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FB%2Fii%2FII","sourceRelease":"119-100","text":"a pothole and adjacent land that is functionally dependent on it;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s3865a/4/B/iii","parentIdentifier":"/us/usc/t16/s3865a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FB%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s3865a/4/B/iii/I","parentIdentifier":"/us/usc/t16/s3865a/4/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FB%2Fiii%2FI","sourceRelease":"119-100","text":"are enrolled in the conservation reserve program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s3865a/4/B/iii/II","parentIdentifier":"/us/usc/t16/s3865a/4/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FB%2Fiii%2FII","sourceRelease":"119-100","text":"have the highest wetland functions and values, as determined by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s3865a/4/B/iii/III","parentIdentifier":"/us/usc/t16/s3865a/4/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FB%2Fiii%2FIII","sourceRelease":"119-100","text":"are likely to return to production after they leave the conservation reserve program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s3865a/4/B/iv","parentIdentifier":"/us/usc/t16/s3865a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FB%2Fiv","sourceRelease":"119-100","text":"riparian areas that link wetlands that are protected by easements or some other device that achieves the same purpose as an easement; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t16/s3865a/4/B/v","parentIdentifier":"/us/usc/t16/s3865a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FB%2Fv","sourceRelease":"119-100","text":"other wetlands of an owner that would not otherwise be eligible, if the Secretary determines that the inclusion of such wetlands in a wetland reserve easement would significantly add to the functional value of the easement; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s3865a/4/C","parentIdentifier":"/us/usc/t16/s3865a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F4%2FC","sourceRelease":"119-100","text":"in the case of either an agricultural land easement or a wetland reserve easement, other land that is incidental to land described in subparagraph (A) or (B), if the Secretary determines that it is necessary for the efficient administration of an easement under the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Monitoring report","label":"5 Monitoring report","identifier":"/us/usc/t16/s3865a/5","parentIdentifier":"/us/usc/t16/s3865a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F5","sourceRelease":"119-100","text":"The term “monitoring report” means a report, the contents of which are formulated and prepared by the holder of an agricultural land easement, that accurately documents whether the land subject to the agricultural land easement is in compliance with the terms and conditions of the agricultural land easement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Program","label":"6 Program","identifier":"/us/usc/t16/s3865a/6","parentIdentifier":"/us/usc/t16/s3865a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F6","sourceRelease":"119-100","text":"The term “program” means the agricultural conservation easement program established by this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Wetland reserve easement","label":"7 Wetland reserve easement","identifier":"/us/usc/t16/s3865a/7","parentIdentifier":"/us/usc/t16/s3865a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s3865a/7/A","parentIdentifier":"/us/usc/t16/s3865a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F7%2FA","sourceRelease":"119-100","text":"is defined and delineated in a deed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s3865a/7/B","parentIdentifier":"/us/usc/t16/s3865a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F7%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s3865a/7/B/i","parentIdentifier":"/us/usc/t16/s3865a/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F7%2FB%2Fi","sourceRelease":"119-100","text":"the rights, title, and interests in land conveyed to the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s3865a/7/B/ii","parentIdentifier":"/us/usc/t16/s3865a/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3865a%2F7%2FB%2Fii","sourceRelease":"119-100","text":"the rights, title, and interests in land that are reserved to the landowner.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
