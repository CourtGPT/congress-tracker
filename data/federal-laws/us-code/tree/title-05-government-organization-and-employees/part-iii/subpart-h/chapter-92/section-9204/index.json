{"type":"section","nativeType":"section","number":"9204","heading":"Adverse action","label":"9204 Adverse action","identifier":"/us/usc/t5/s9204","parentIdentifier":"/us/usc/t5/ptIII/sptH/ch92","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9204","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—First Violation","label":"a .—First Violation","identifier":"/us/usc/t5/s9204/a","parentIdentifier":"/us/usc/t5/s9204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9204%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s9204/a/1","parentIdentifier":"/us/usc/t5/s9204/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9204%2Fa%2F1","sourceRelease":"119-100","text":"issue to the employee a written warning that includes a description of the violation and the additional penalties that may apply for subsequent violations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s9204/a/2","parentIdentifier":"/us/usc/t5/s9204/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9204%2Fa%2F2","sourceRelease":"119-100","text":"file such warning in the employee’s official personnel record file.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Subsequent Violations","label":"b .—Subsequent Violations","identifier":"/us/usc/t5/s9204/b","parentIdentifier":"/us/usc/t5/s9204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9204%2Fb","sourceRelease":"119-100","text":null,"notes":[