{"type":"section","nativeType":"section","number":"10365","heading":"Hydroelectric power assessment","label":"10365 Hydroelectric power assessment","identifier":"/us/usc/t42/s10365","parentIdentifier":"/us/usc/t42/ch109B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Duty of Secretary of Energy","label":"a Duty of Secretary of Energy","identifier":"/us/usc/t42/s10365/a","parentIdentifier":"/us/usc/t42/s10365","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fa","sourceRelease":"119-100","text":"The Secretary of Energy, in consultation with the Administrator of each Federal Power Marketing Administration, shall assess each effect of, and risk resulting from, global climate change with respect to water supplies that are required for the generation of hydroelectric power at each Federal water project that is applicable to a Federal Power Marketing Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Access to appropriate data","label":"b Access to appropriate data","identifier":"/us/usc/t42/s10365/b","parentIdentifier":"/us/usc/t42/s10365","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s10365/b/1","parentIdentifier":"/us/usc/t42/s10365/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fb%2F1","sourceRelease":"119-100","text":"In carrying out each assessment under subsection (a), the Secretary of Energy shall consult with the United States Geological Survey, the National Oceanic and Atmospheric Administration, the program, and each appropriate State water resource agency, to ensure that the Secretary of Energy has access to the best available scientific information with respect to presently observed impacts and projected future impacts of global climate change on water supplies that are used to produce hydroelectric power.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Access to data for certain assessments","label":"2 Access to data for certain assessments","identifier":"/us/usc/t42/s10365/b/2","parentIdentifier":"/us/usc/t42/s10365/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s10365/b/2/A","parentIdentifier":"/us/usc/t42/s10365/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fb%2F2%2FA","sourceRelease":"119-100","text":"is collected by the Commissioner; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s10365/b/2/B","parentIdentifier":"/us/usc/t42/s10365/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the Secretary of Energy determines to be necessary for the conduct of the assessment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Report","label":"c Report","identifier":"/us/usc/t42/s10365/c","parentIdentifier":"/us/usc/t42/s10365","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s10365/c/1","parentIdentifier":"/us/usc/t42/s10365/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s10365/c/1/A","parentIdentifier":"/us/usc/t42/s10365/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fc%2F1%2FA","sourceRelease":"119-100","text":"water supplies used for hydroelectric power generation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s10365/c/1/B","parentIdentifier":"/us/usc/t42/s10365/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s10365/c/1/B/i","parentIdentifier":"/us/usc/t42/s10365/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"long-term power contracts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s10365/c/1/B/ii","parentIdentifier":"/us/usc/t42/s10365/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"contingent capacity contracts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s10365/c/1/B/iii","parentIdentifier":"/us/usc/t42/s10365/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fc%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"short-term sales; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s10365/c/2","parentIdentifier":"/us/usc/t42/s10365/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fc%2F2","sourceRelease":"119-100","text":"each recommendation of the Administrator of each Federal Power Marketing Administration relating to any change in any operation or contracting practice of each Federal Power Marketing Administration to address each effect and risk described in paragraph (1), including the use of purchased power to meet long-term commitments of each Federal Power Marketing Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authority","label":"d Authority","identifier":"/us/usc/t42/s10365/d","parentIdentifier":"/us/usc/t42/s10365","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fd","sourceRelease":"119-100","text":"The Secretary of Energy may enter into contracts, grants, or other agreements with appropriate entities to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Costs","label":"e Costs","identifier":"/us/usc/t42/s10365/e","parentIdentifier":"/us/usc/t42/s10365","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Nonreimbursable","label":"1 Nonreimbursable","identifier":"/us/usc/t42/s10365/e/1","parentIdentifier":"/us/usc/t42/s10365/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fe%2F1","sourceRelease":"119-100","text":"Any costs incurred by the Secretary of Energy in carrying out this section shall be nonreimbursable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"PMA costs","label":"2 PMA costs","identifier":"/us/usc/t42/s10365/e/2","parentIdentifier":"/us/usc/t42/s10365/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Fe%2F2","sourceRelease":"119-100","text":"Each Federal Power Marketing Administration shall incur costs in carrying out this section only to the extent that appropriated funds are provided by the Secretary of Energy for that purpose.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorization of appropriations","label":"f Authorization of appropriations","identifier":"/us/usc/t42/s10365/f","parentIdentifier":"/us/usc/t42/s10365","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10365%2Ff","sourceRelease":"119-100","text":"There are authorized to be appropriated such sums as are necessary to carry out this section for each of fiscal years 2009 through 2023, to remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
