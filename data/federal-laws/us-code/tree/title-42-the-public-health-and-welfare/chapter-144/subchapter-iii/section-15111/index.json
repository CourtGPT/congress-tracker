{"type":"section","nativeType":"section","number":"15111","heading":"Findings","label":"15111 Findings","identifier":"/us/usc/t42/s15111","parentIdentifier":"/us/usc/t42/ch144/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15111","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15111/1","parentIdentifier":"/us/usc/t42/s15111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15111%2F1","sourceRelease":"119-100","text":"direct support workers, especially young adults, have played essential roles in providing the support needed by individuals with developmental disabilities and expanding community options for those individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15111/2","parentIdentifier":"/us/usc/t42/s15111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15111%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15111/2/A","parentIdentifier":"/us/usc/t42/s15111/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15111%2F2%2FA","sourceRelease":"119-100","text":"the small population of individuals who are age 18 through 25, an age group that has been attracted to direct support work in the past;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15111/2/B","parentIdentifier":"/us/usc/t42/s15111/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15111%2F2%2FB","sourceRelease":"119-100","text":"the rapid expansion of the service sector, which attracts individuals who previously would have elected to pursue employment as direct support workers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s15111/2/C","parentIdentifier":"/us/usc/t42/s15111/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15111%2F2%2FC","sourceRelease":"119-100","text":"the failure of wages in the human services sector to keep pace with wages in other service sectors; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s15111/2/D","parentIdentifier":"/us/usc/t42/s15111/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15111%2F2%2FD","sourceRelease":"119-100","text":"the lack of quality training and career advancement opportunities available to direct support workers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s15111/3","parentIdentifier":"/us/usc/t42/s15111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15111%2F3","sourceRelease":"119-100","text":"individuals with developmental disabilities benefit from assistance from direct support workers who are well trained, and benefit from receiving services from professionals who have spent time as direct support workers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
