{"type":"section","nativeType":"section","number":"1444a","heading":"Regulations regarding payment of annuity to a representative payee","label":"1444a Regulations regarding payment of annuity to a representative payee","identifier":"/us/usc/t10/s1444a","parentIdentifier":"/us/usc/t10/stA/ptII/ch73/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1444a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments1997—Subsec. (b). substituted “section 1455(d)(2)” for “section 1455(c)”.Pub. L. 105–85"],"amendments":["Amendments1997—Subsec. (b). substituted “section 1455(d)(2)” for “section 1455(c)”.Pub. L. 105–85"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t10/s1444a/a","parentIdentifier":"/us/usc/t10/s1444a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1444a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1444a/a/1","parentIdentifier":"/us/usc/t10/s1444a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1444a%2Fa%2F1","sourceRelease":"119-100","text":"a person for whom a guardian or other fiduciary has been appointed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1444a/a/2","parentIdentifier":"/us/usc/t10/s1444a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1444a%2Fa%2F2","sourceRelease":"119-100","text":"a minor, mentally incompetent, or otherwise legally disabled person for whom a guardian or other fiduciary has not been appointed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t10/s1444a/b","parentIdentifier":"/us/usc/t10/s1444a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1444a%2Fb","sourceRelease":"119-100","text":"Those regulations may include the provisions set out in .section 1455(d)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t10/s1444a/c","parentIdentifier":"/us/usc/t10/s1444a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1444a%2Fc","sourceRelease":"119-100","text":"An annuity paid to a person on behalf of an annuitant in accordance with the regulations prescribed pursuant to subsection (a) discharges the obligation of the United States for payment to the annuitant of the amount of the annuity so paid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
