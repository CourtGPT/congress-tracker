{"type":"section","nativeType":"section","number":"714","heading":"Arctic maritime domain awareness","label":"714 Arctic maritime domain awareness","identifier":"/us/usc/t14/s714","parentIdentifier":"/us/usc/t14/stI/ch7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2018— renumbered as this section.Pub. L. 115–282section 154 of this title"],"amendments":["Amendments2018— renumbered as this section.Pub. L. 115–282section 154 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t14/s714/a","parentIdentifier":"/us/usc/t14/s714","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s714/a/1","parentIdentifier":"/us/usc/t14/s714/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fa%2F1","sourceRelease":"119-100","text":"by promoting interagency cooperation and coordination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s714/a/2","parentIdentifier":"/us/usc/t14/s714/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fa%2F2","sourceRelease":"119-100","text":"by employing joint, interagency, and international capabilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t14/s714/a/3","parentIdentifier":"/us/usc/t14/s714/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fa%2F3","sourceRelease":"119-100","text":"by facilitating the sharing of information, intelligence, and data related to the Arctic maritime domain between the Coast Guard and departments and agencies listed in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Coordination","label":"b .—Coordination","identifier":"/us/usc/t14/s714/b","parentIdentifier":"/us/usc/t14/s714","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s714/b/1","parentIdentifier":"/us/usc/t14/s714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fb%2F1","sourceRelease":"119-100","text":"The Department of Homeland Security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s714/b/2","parentIdentifier":"/us/usc/t14/s714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fb%2F2","sourceRelease":"119-100","text":"The Department of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t14/s714/b/3","parentIdentifier":"/us/usc/t14/s714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fb%2F3","sourceRelease":"119-100","text":"The Department of Transportation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t14/s714/b/4","parentIdentifier":"/us/usc/t14/s714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fb%2F4","sourceRelease":"119-100","text":"The Department of State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t14/s714/b/5","parentIdentifier":"/us/usc/t14/s714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fb%2F5","sourceRelease":"119-100","text":"The Department of the Interior.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t14/s714/b/6","parentIdentifier":"/us/usc/t14/s714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fb%2F6","sourceRelease":"119-100","text":"The National Aeronautics and Space Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t14/s714/b/7","parentIdentifier":"/us/usc/t14/s714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fb%2F7","sourceRelease":"119-100","text":"The National Oceanic and Atmospheric Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t14/s714/b/8","parentIdentifier":"/us/usc/t14/s714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fb%2F8","sourceRelease":"119-100","text":"The Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t14/s714/b/9","parentIdentifier":"/us/usc/t14/s714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fb%2F9","sourceRelease":"119-100","text":"The National Science Foundation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t14/s714/b/10","parentIdentifier":"/us/usc/t14/s714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fb%2F10","sourceRelease":"119-100","text":"The Arctic Research Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t14/s714/b/11","parentIdentifier":"/us/usc/t14/s714/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fb%2F11","sourceRelease":"119-100","text":"Any Federal agency or commission or State the Commandant determines is appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Cooperation","label":"c .—Cooperation","identifier":"/us/usc/t14/s714/c","parentIdentifier":"/us/usc/t14/s714","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fc","sourceRelease":"119-100","text":"The Commandant and the head of a department or agency listed in subsection (b) may by agreement, on a reimbursable basis or otherwise, share personnel, services, equipment, and facilities to carry out the requirements of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"5.—-year Strategic Plan","label":"d 5.—-year Strategic Plan","identifier":"/us/usc/t14/s714/d","parentIdentifier":"/us/usc/t14/s714","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fd","sourceRelease":"119-100","text":"Not later than and every 5 years thereafter, the Commandant shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a 5-year strategic plan to guide interagency and international intergovernmental cooperation and coordination for the purpose of improving maritime domain awareness in the Arctic.January 1, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Definitions","label":"e .—Definitions","identifier":"/us/usc/t14/s714/e","parentIdentifier":"/us/usc/t14/s714","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs714%2Fe","sourceRelease":"119-100","text":"In this section the term “Arctic” has the meaning given that term in section 112 of the Arctic Research and Policy Act of 1984 ().15 U.S.C. 4111","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
