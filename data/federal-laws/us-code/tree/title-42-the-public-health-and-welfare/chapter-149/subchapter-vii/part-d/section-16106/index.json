{"type":"section","nativeType":"section","number":"16106","heading":"Ultra-efficient engine technology for aircraft","label":"16106 Ultra-efficient engine technology for aircraft","identifier":"/us/usc/t42/s16106","parentIdentifier":"/us/usc/t42/ch149/schVII/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16106","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Ultra-efficient engine technology partnership","label":"a Ultra-efficient engine technology partnership","identifier":"/us/usc/t42/s16106/a","parentIdentifier":"/us/usc/t42/s16106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16106%2Fa","sourceRelease":"119-100","text":"The Secretary shall enter into a cooperative agreement with the National Aeronautics and Space Administration for the development of ultra-efficient engine technology for aircraft.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Performance objective","label":"b Performance objective","identifier":"/us/usc/t42/s16106/b","parentIdentifier":"/us/usc/t42/s16106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16106%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16106/b/1","parentIdentifier":"/us/usc/t42/s16106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16106%2Fb%2F1","sourceRelease":"119-100","text":"A fuel efficiency increase of at least 10 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16106/b/2","parentIdentifier":"/us/usc/t42/s16106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16106%2Fb%2F2","sourceRelease":"119-100","text":"A reduction in the impact of landing and takeoff nitrogen oxides emissions on local air quality of 70 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16106/b/3","parentIdentifier":"/us/usc/t42/s16106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16106%2Fb%2F3","sourceRelease":"119-100","text":"Exploring advanced concepts, alternate propulsion, and power configurations, including hybrid fuel cell powered systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16106/b/4","parentIdentifier":"/us/usc/t42/s16106/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16106%2Fb%2F4","sourceRelease":"119-100","text":"Exploring the use of alternate fuel in conventional or nonconventional turbine-based systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t42/s16106/c","parentIdentifier":"/us/usc/t42/s16106","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16106%2Fc","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Secretary for carrying out this section $50,000,000 for each of the fiscal years 2006, 2007, 2008, 2009, and 2010.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
