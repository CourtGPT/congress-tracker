ildren":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t16/s8442/c/1/G","parentIdentifier":"/us/usc/t16/s8442/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fc%2F1%2FG","sourceRelease":"119-100","text":"permitted facilitated recreation providers; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t16/s8442/c/1/H","parentIdentifier":"/us/usc/t16/s8442/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fc%2F1%2FH","sourceRelease":"119-100","text":"other relevant stakeholders; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s8442/c/2","parentIdentifier":"/us/usc/t16/s8442/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8442/c/2/A","parentIdentifier":"/us/usc/t16/s8442/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fc%2F2%2FA","sourceRelease":"119-100","text":"technology companies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8442/c/2/B","parentIdentifier":"/us/usc/t16/s8442/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fc%2F2%2FB","sourceRelease":"119-100","text":"geospatial data companies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8442/c/2/C","parentIdentifier":"/us/usc/t16/s8442/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fc%2F2%2FC","sourceRelease":"119-100","text":"experts in data science, analytics, and operations research; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s8442/c/2/D","parentIdentifier":"/us/usc/t16/s8442/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fc%2F2%2FD","sourceRelease":"119-100","text":"data companies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Existing programs","label":"d Existing programs","identifier":"/us/usc/t16/s8442/d","parentIdentifier":"/us/usc/t16/s8442","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fd","sourceRelease":"119-100","text":"The Secretaries may use existing programs or products of the Secretaries to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Privacy clauses","label":"e Privacy clauses","identifier":"/us/usc/t16/s8442/e","parentIdentifier":"/us/usc/t16/s8442","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s8442/e/1","parentIdentifier":"/us/usc/t16/s8442/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fe%2F1","sourceRelease":"119-100","text":"to monitor or record the movements of a visitor to a unit of Federal recreational lands and waters;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s8442/e/2","parentIdentifier":"/us/usc/t16/s8442/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fe%2F2","sourceRelease":"119-100","text":"to restrict, interfere with, or monitor a private communication of a visitor to a unit of Federal recreational lands and waters; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s8442/e/3","parentIdentifier":"/us/usc/t16/s8442/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fe%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8442/e/3/A","parentIdentifier":"/us/usc/t16/s8442/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fe%2F3%2FA","sourceRelease":"119-100","text":"information from owners of land adjacent to a unit of Federal recreational lands and waters; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8442/e/3/B","parentIdentifier":"/us/usc/t16/s8442/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fe%2F3%2FB","sourceRelease":"119-100","text":"information on non-Federal land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Reports","label":"f Reports","identifier":"/us/usc/t16/s8442/f","parentIdentifier":"/us/usc/t16/s8442","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Ff","sourceRelease":"119-100","text":"Not later than 1 year after , and annually thereafter, the Secretaries shall publish on a website of the Secretaries a report that describes the annual visitation of each unit of Federal recreational lands and waters, including, to the maximum extent practicable, visitation categorized by recreational activity.January 4, 2025","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Definitions","label":"g Definitions","identifier":"/us/usc/t16/s8442/g","parentIdentifier":"/us/usc/t16/s8442","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Federal recreational lands and waters","label":"1 Federal recreational lands and waters","identifier":"/us/usc/t16/s8442/g/1","parentIdentifier":"/us/usc/t16/s8442/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fg%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8442/g/1/A","parentIdentifier":"/us/usc/t16/s8442/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fg%2F1%2FA","sourceRelease":"119-100","text":"has the meaning given the term in ; andsection 6801 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8442/g/1/B","parentIdentifier":"/us/usc/t16/s8442/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fg%2F1%2FB","sourceRelease":"119-100","text":"includes Federal lands and waters managed by the National Oceanic and Atmospheric Administration and the U.S. Army Corps of Engineers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Secretaries","label":"2 Secretaries","identifier":"/us/usc/t16/s8442/g/2","parentIdentifier":"/us/usc/t16/s8442/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fg%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8442/g/2/A","parentIdentifier":"/us/usc/t16/s8442/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fg%2F2%2FA","sourceRelease":"119-100","text":"the Secretary, with respect to lands under the jurisdiction of the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8442/g/2/B","parentIdentifier":"/us/usc/t16/s8442/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fg%2F2%2FB","sourceRelease":"119-100","text":"the Secretary of Agriculture, acting through the Chief of the Forest Service, with respect to lands under the jurisdiction of the Forest Service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8442/g/2/C","parentIdentifier":"/us/usc/t16/s8442/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fg%2F2%2FC","sourceRelease":"119-100","text":"the Secretary of Commerce, acting through the Administrator of the National Oceanic and Atmospheric Administration, with respect to Federal waters under the jurisdiction of the National Oceanic and Atmospheric Administration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s8442/g/2/D","parentIdentifier":"/us/usc/t16/s8442/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fg%2F2%2FD","sourceRelease":"119-100","text":"the Assistant Secretary of Army for Civil Works, with respect to lakes and reservoirs under the jurisdiction of the U.S. Army Corps of Engineers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
