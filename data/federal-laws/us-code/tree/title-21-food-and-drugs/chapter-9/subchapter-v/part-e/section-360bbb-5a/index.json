{"type":"section","nativeType":"section","number":"360bbb–5a","heading":"Emerging technology program","label":"360bbb–5a Emerging technology program","identifier":"/us/usc/t21/s360bbb–5a","parentIdentifier":"/us/usc/t21/ch9/schV/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Program establishment","label":"a Program establishment","identifier":"/us/usc/t21/s360bbb–5a/a","parentIdentifier":"/us/usc/t21/s360bbb–5a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t21/s360bbb–5a/a/1","parentIdentifier":"/us/usc/t21/s360bbb–5a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary shall establish a program to support the adoption of, and improve the development of, innovative approaches to drug design and manufacturing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Actions","label":"2 Actions","identifier":"/us/usc/t21/s360bbb–5a/a/2","parentIdentifier":"/us/usc/t21/s360bbb–5a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s360bbb–5a/a/2/A","parentIdentifier":"/us/usc/t21/s360bbb–5a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F2%2FA","sourceRelease":"119-100","text":"facilitate and increase communication between public and private entities, consortia, and individuals with respect to innovative drug product design and manufacturing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s360bbb–5a/a/2/B","parentIdentifier":"/us/usc/t21/s360bbb–5a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F2%2FB","sourceRelease":"119-100","text":"solicit information regarding, and conduct or support research on, innovative approaches to drug product design and manufacturing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t21/s360bbb–5a/a/2/C","parentIdentifier":"/us/usc/t21/s360bbb–5a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F2%2FC","sourceRelease":"119-100","text":"convene meetings with representatives of industry, academia, other Federal agencies, international agencies, and other interested persons, as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t21/s360bbb–5a/a/2/D","parentIdentifier":"/us/usc/t21/s360bbb–5a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F2%2FD","sourceRelease":"119-100","text":"convene working groups to support drug product design and manufacturing research and development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t21/s360bbb–5a/a/2/E","parentIdentifier":"/us/usc/t21/s360bbb–5a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F2%2FE","sourceRelease":"119-100","text":"support education and training for regulatory staff and scientists related to innovative approaches to drug product design and manufacturing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t21/s360bbb–5a/a/2/F","parentIdentifier":"/us/usc/t21/s360bbb–5a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F2%2FF","sourceRelease":"119-100","text":"advance regulatory science related to the development and review of innovative approaches to drug product design and manufacturing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t21/s360bbb–5a/a/2/G","parentIdentifier":"/us/usc/t21/s360bbb–5a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F2%2FG","sourceRelease":"119-100","text":"convene or participate in working groups to support the harmonization of international regulatory requirements related to innovative approaches to drug product design and manufacturing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t21/s360bbb–5a/a/2/H","parentIdentifier":"/us/usc/t21/s360bbb–5a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F2%2FH","sourceRelease":"119-100","text":"award grants or contracts to carry out or support the program under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Grants and contracts","label":"3 Grants and contracts","identifier":"/us/usc/t21/s360bbb–5a/a/3","parentIdentifier":"/us/usc/t21/s360bbb–5a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s360bbb–5a/a/3/A","parentIdentifier":"/us/usc/t21/s360bbb–5a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F3%2FA","sourceRelease":"119-100","text":"in such form and manner as the Secretary may require; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s360bbb–5a/a/3/B","parentIdentifier":"/us/usc/t21/s360bbb–5a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s360bbb–5a/a/3/B/i","parentIdentifier":"/us/usc/t21/s360bbb–5a/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F3%2FB%2Fi","sourceRelease":"119-100","text":"how the entity will conduct the activities to be supported through the grant or contract; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s360bbb–5a/a/3/B/ii","parentIdentifier":"/us/usc/t21/s360bbb–5a/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fa%2F3%2FB%2Fii","sourceRelease":"119-100","text":"how such activities will further research and development related to, or adoption of, innovative approaches to drug product design and manufacturing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Guidance","label":"b Guidance","identifier":"/us/usc/t21/s360bbb–5a/b","parentIdentifier":"/us/usc/t21/s360bbb–5a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s360bbb–5a/b/1","parentIdentifier":"/us/usc/t21/s360bbb–5a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fb%2F1","sourceRelease":"119-100","text":"issue or update guidance to help facilitate the adoption of, and advance the development of, innovative approaches to drug product design and manufacturing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s360bbb–5a/b/2","parentIdentifier":"/us/usc/t21/s360bbb–5a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s360bbb–5a/b/2/A","parentIdentifier":"/us/usc/t21/s360bbb–5a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fb%2F2%2FA","sourceRelease":"119-100","text":"any regulatory requirements related to the development or review of technologies related to innovative approaches to drug product design and manufacturing, including updates and improvements to such technologies after product approval; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s360bbb–5a/b/2/B","parentIdentifier":"/us/usc/t21/s360bbb–5a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fb%2F2%2FB","sourceRelease":"119-100","text":"data that can be used to demonstrate the identity, safety, purity, and potency of drugs manufactured using such technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Report to Congress","label":"c Report to Congress","identifier":"/us/usc/t21/s360bbb–5a/c","parentIdentifier":"/us/usc/t21/s360bbb–5a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s360bbb–5a/c/1","parentIdentifier":"/us/usc/t21/s360bbb–5a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fc%2F1","sourceRelease":"119-100","text":"an annual accounting of the allocation of funds made available to carry out this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s360bbb–5a/c/2","parentIdentifier":"/us/usc/t21/s360bbb–5a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fc%2F2","sourceRelease":"119-100","text":"a description of how Food and Drug Administration staff were utilized to carry out this section and, as applicable, any challenges or limitations related to staffing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t21/s360bbb–5a/c/3","parentIdentifier":"/us/usc/t21/s360bbb–5a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fc%2F3","sourceRelease":"119-100","text":"the number of public meetings held or participated in by the Food and Drug Administration pursuant to this section, including meetings convened as part of a working group described in subparagraph (D) or (G) of subsection (a)(2), and the topics of each such meeting; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t21/s360bbb–5a/c/4","parentIdentifier":"/us/usc/t21/s360bbb–5a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360bbb%E2%80%935a%2Fc%2F4","sourceRelease":"119-100","text":"the number of drug products approved or licensed, after , using an innovative approach to drug product design and manufacturing.December 29, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
