{"type":"section","nativeType":"section","number":"9814","heading":"Qualifications pay","label":"9814 Qualifications pay","identifier":"/us/usc/t5/s9814","parentIdentifier":"/us/usc/t5/ptIII/sptI/ch98","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe General Schedule, referred to in subsec. (a), is set out under .section 5332 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s9814/a","parentIdentifier":"/us/usc/t5/s9814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s9814/a/1","parentIdentifier":"/us/usc/t5/s9814/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fa%2F1","sourceRelease":"119-100","text":"possesses unusually high or unique qualifications; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s9814/a/2","parentIdentifier":"/us/usc/t5/s9814/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s9814/a/2/A","parentIdentifier":"/us/usc/t5/s9814/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fa%2F2%2FA","sourceRelease":"119-100","text":"new duties, without a change of position; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s9814/a/2/B","parentIdentifier":"/us/usc/t5/s9814/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fa%2F2%2FB","sourceRelease":"119-100","text":"to a new position.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s9814/b","parentIdentifier":"/us/usc/t5/s9814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fb","sourceRelease":"119-100","text":"If an exercise of the authority under this section relates to a current employee selected for another position within the Administration, a determination shall be made that the employee’s contribution in the new position will exceed that in the former position, before setting pay under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t5/s9814/c","parentIdentifier":"/us/usc/t5/s9814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fc","sourceRelease":"119-100","text":"Pay as set under this section is basic pay for such purposes as pay set under section 5334.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t5/s9814/d","parentIdentifier":"/us/usc/t5/s9814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fd","sourceRelease":"119-100","text":"If the employee serves for at least 1 year in the position for which the pay determination under this section was made, or a successor position, the pay earned under such position may be used in succeeding actions to set pay under chapter 53.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":null,"label":"e","identifier":"/us/usc/t5/s9814/e","parentIdentifier":"/us/usc/t5/s9814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s9814/e/1","parentIdentifier":"/us/usc/t5/s9814/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fe%2F1","sourceRelease":"119-100","text":"criteria for approval of actions to set pay under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s9814/e/2","parentIdentifier":"/us/usc/t5/s9814/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fe%2F2","sourceRelease":"119-100","text":"the level of approval required to set pay under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s9814/e/3","parentIdentifier":"/us/usc/t5/s9814/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fe%2F3","sourceRelease":"119-100","text":"all types of actions and positions to be covered;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t5/s9814/e/4","parentIdentifier":"/us/usc/t5/s9814/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fe%2F4","sourceRelease":"119-100","text":"the relationship between the exercise of authority under this section and the use of other pay incentives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t5/s9814/e/5","parentIdentifier":"/us/usc/t5/s9814/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9814%2Fe%2F5","sourceRelease":"119-100","text":"a process to evaluate the effectiveness of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
