(b)105 Stat. 607Pub. L. 105–17Apr. 13, 1970Dec. 2, 1983Oct. 8, 1986Nov. 7, 1988Oct. 30, 1990Oct. 7, 1991"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"At-risk infant or toddler","label":"1 At-risk infant or toddler","identifier":"/us/usc/t20/s1432/1","parentIdentifier":"/us/usc/t20/s1432","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F1","sourceRelease":"119-100","text":"The term “at-risk infant or toddler” means an individual under 3 years of age who would be at risk of experiencing a substantial developmental delay if early intervention services were not provided to the individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Council","label":"2 Council","identifier":"/us/usc/t20/s1432/2","parentIdentifier":"/us/usc/t20/s1432","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F2","sourceRelease":"119-100","text":"The term “council” means a State interagency coordinating council established under .section 1441 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Developmental delay","label":"3 Developmental delay","identifier":"/us/usc/t20/s1432/3","parentIdentifier":"/us/usc/t20/s1432","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F3","sourceRelease":"119-100","text":"The term “developmental delay”, when used with respect to an individual residing in a State, has the meaning given such term by the State under .section 1435(a)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Early intervention services","label":"4 Early intervention services","identifier":"/us/usc/t20/s1432/4","parentIdentifier":"/us/usc/t20/s1432","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1432/4/A","parentIdentifier":"/us/usc/t20/s1432/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FA","sourceRelease":"119-100","text":"are provided under public supervision;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1432/4/B","parentIdentifier":"/us/usc/t20/s1432/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FB","sourceRelease":"119-100","text":"are provided at no cost except where Federal or State law provides for a system of payments by families, including a schedule of sliding fees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1432/4/C","parentIdentifier":"/us/usc/t20/s1432/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1432/4/C/i","parentIdentifier":"/us/usc/t20/s1432/4/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FC%2Fi","sourceRelease":"119-100","text":"physical development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1432/4/C/ii","parentIdentifier":"/us/usc/t20/s1432/4/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FC%2Fii","sourceRelease":"119-100","text":"cognitive development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t20/s1432/4/C/iii","parentIdentifier":"/us/usc/t20/s1432/4/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FC%2Fiii","sourceRelease":"119-100","text":"communication development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t20/s1432/4/C/iv","parentIdentifier":"/us/usc/t20/s1432/4/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FC%2Fiv","sourceRelease":"119-100","text":"social or emotional development; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t20/s1432/4/C/v","parentIdentifier":"/us/usc/t20/s1432/4/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FC%2Fv","sourceRelease":"119-100","text":"adaptive development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1432/4/D","parentIdentifier":"/us/usc/t20/s1432/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FD","sourceRelease":"119-100","text":"meet the standards of the State in which the services are provided, including the requirements of this subchapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s1432/4/E","parentIdentifier":"/us/usc/t20/s1432/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1432/4/E/i","parentIdentifier":"/us/usc/t20/s1432/4/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FE%2Fi","sourceRelease":"119-100","text":"family training, counseling, and home visits;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1432/4/E/ii","parentIdentifier":"/us/usc/t20/s1432/4/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FE%2Fii","sourceRelease":"119-100","text":"special instruction;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t20/s1432/4/E/iii","parentIdentifier":"/us/usc/t20/s1432/4/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FE%2Fiii","sourceRelease":"119-100","text":"speech-language pathology and audiology services, and sign language and cued language services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t20/s1432/4/E/iv","parentIdentifier":"/us/usc/t20/s1432/4/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FE%2Fiv","sourceRelease":"119-100","text":"occupational therapy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t20/s1432/4/E/v","parentIdentifier":"/us/usc/t20/s1432/4/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FE%2Fv","sou