{"type":"section","nativeType":"section","number":"6122","heading":"Flexible schedules; agencies authorized to use","label":"6122 Flexible schedules; agencies authorized to use","identifier":"/us/usc/t5/s6122","parentIdentifier":"/us/usc/t5/ptIII/sptE/ch61/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6122","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s6122/a","parentIdentifier":"/us/usc/t5/s6122","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6122%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6122/a/1","parentIdentifier":"/us/usc/t5/s6122/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6122%2Fa%2F1","sourceRelease":"119-100","text":"designated hours and days during which an employee on such a schedule must be present for work; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6122/a/2","parentIdentifier":"/us/usc/t5/s6122/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6122%2Fa%2F2","sourceRelease":"119-100","text":"designated hours during which an employee on such a schedule may elect the time of such employee’s arrival at and departure from work, solely for such purpose or, if and to the extent permitted, for the purpose of accumulating credit hours to reduce the length of the workweek or another workday.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s6122/b","parentIdentifier":"/us/usc/t5/s6122","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6122%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6122/b/1","parentIdentifier":"/us/usc/t5/s6122/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6122%2Fb%2F1","sourceRelease":"119-100","text":"restrict the employees’ choice of arrival and departure time,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6122/b/2","parentIdentifier":"/us/usc/t5/s6122/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6122%2Fb%2F2","sourceRelease":"119-100","text":"restrict the use of credit hours, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s6122/b/3","parentIdentifier":"/us/usc/t5/s6122/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6122%2Fb%2F3","sourceRelease":"119-100","text":"exclude from such program any employee or group of employees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
