{"type":"section","nativeType":"section","number":"2932","heading":"Committee on Earth and Environmental Sciences","label":"2932 Committee on Earth and Environmental Sciences","identifier":"/us/usc/t15/s2932","parentIdentifier":"/us/usc/t15/ch56A/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t15/s2932/a","parentIdentifier":"/us/usc/t15/s2932","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fa","sourceRelease":"119-100","text":"The President, through the Council, shall establish a Committee on Earth and Environmental Sciences. The Committee shall carry out Council functions under relating to global change research, for the purpose of increasing the overall effectiveness and productivity of Federal global change research efforts.section 6651 of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Membership","label":"b Membership","identifier":"/us/usc/t15/s2932/b","parentIdentifier":"/us/usc/t15/s2932","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2932/b/1","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F1","sourceRelease":"119-100","text":"the National Science Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2932/b/2","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F2","sourceRelease":"119-100","text":"the National Aeronautics and Space Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s2932/b/3","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F3","sourceRelease":"119-100","text":"the National Oceanic and Atmospheric Administration of the Department of Commerce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s2932/b/4","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F4","sourceRelease":"119-100","text":"the Environmental Protection Agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s2932/b/5","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F5","sourceRelease":"119-100","text":"the Department of Energy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s2932/b/6","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F6","sourceRelease":"119-100","text":"the Department of State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t15/s2932/b/7","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F7","sourceRelease":"119-100","text":"the Department of Defense;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t15/s2932/b/8","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F8","sourceRelease":"119-100","text":"the Department of the Interior;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t15/s2932/b/9","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F9","sourceRelease":"119-100","text":"the Department of Agriculture;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t15/s2932/b/10","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F10","sourceRelease":"119-100","text":"the Department of Transportation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t15/s2932/b/11","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F11","sourceRelease":"119-100","text":"the Office of Management and Budget;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t15/s2932/b/12","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F12","sourceRelease":"119-100","text":"the Office of Science and Technology Policy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"13","heading":null,"label":"13","identifier":"/us/usc/t15/s2932/b/13","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F13","sourceRelease":"119-100","text":"the Council on Environmental Quality;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"14","heading":null,"label":"14","identifier":"/us/usc/t15/s2932/b/14","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F14","sourceRelease":"119-100","text":"the National Institute of Environmental Health Sciences of the National Institutes of Health; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"15","heading":null,"label":"15","identifier":"/us/usc/t15/s2932/b/15","parentIdentifier":"/us/usc/t15/s2932/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fb%2F15","sourceRelease":"119-100","text":"such other agencies and departments of the United States as the President or the Chairman of the Council considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Chairperson","label":"c Chairperson","identifier":"/us/usc/t15/s2932/c","parentIdentifier":"/us/usc/t15/s2932","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fc","sourceRelease":"119-100","text":"The Chairman of the Council, in consultation with the Committee, biennially shall select one of the Committee members to serve as Chairperson. The Chairperson shall be knowledgeable and experienced with regard to the administration of scientific research programs, and shall be a representative of an agency that contributes substantially, in terms of scientific research capability and budget, to the Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Support personnel","label":"d Support personnel","identifier":"/us/usc/t15/s2932/d","parentIdentifier":"/us/usc/t15/s2932","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fd","sourceRelease":"119-100","text":"An Executive Secretary shall be appointed by the Chairperson of the Committee, with the approval of the Committee. The Executive Secretary shall be a permanent employee of one of the agencies or departments represented on the Committee, and shall remain in the employ of such agency or department. The Chairman of the Council shall have the authority to make personnel decisions regarding any employees detailed to the Council for purposes of working on business of the Committee pursuant to .section 6651 of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Functions relative to global change","label":"e Functions relative to global change","identifier":"/us/usc/t15/s2932/e","parentIdentifier":"/us/usc/t15/s2932","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2932/e/1","parentIdentifier":"/us/usc/t15/s2932/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fe%2F1","sourceRelease":"119-100","text":"serve as the forum for developing the Plan and for overseeing its implementation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2932/e/2","parentIdentifier":"/us/usc/t15/s2932/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fe%2F2","sourceRelease":"119-100","text":"improve cooperation among Federal agencies and departments with respect to global change research activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s2932/e/3","parentIdentifier":"/us/usc/t15/s2932/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fe%2F3","sourceRelease":"119-100","text":"provide budgetary advice as specified in ;section 2935 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s2932/e/4","parentIdentifier":"/us/usc/t15/s2932/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fe%2F4","sourceRelease":"119-100","text":"work with academic, State, industry, and other groups conducting global change research, to provide for periodic public and peer review of the Program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s2932/e/5","parentIdentifier":"/us/usc/t15/s2932/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fe%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s2932/e/5/A","parentIdentifier":"/us/usc/t15/s2932/e/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fe%2F5%2FA","sourceRelease":"119-100","text":"providing representation at international meetings and conferences on global change research in which the United States participates; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s2932/e/5/B","parentIdentifier":"/us/usc/t15/s2932/e/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fe%2F5%2FB","sourceRelease":"119-100","text":"coordinating the Federal activities of the United States with programs of other nations and with international global change research activities such as the International Geosphere-Biosphere Program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s2932/e/6","parentIdentifier":"/us/usc/t15/s2932/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fe%2F6","sourceRelease":"119-100","text":"consult with actual and potential users of the results of the Program to ensure that such results are useful in developing national and international policy responses to global change; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t15/s2932/e/7","parentIdentifier":"/us/usc/t15/s2932/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2932%2Fe%2F7","sourceRelease":"119-100","text":"report at least annually to the President and the Congress, through the Chairman of the Council, on Federal global change research priorities, policies, and programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
