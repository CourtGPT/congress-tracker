{"type":"section","nativeType":"section","number":"19321","heading":"Special hiring authority for scientific, engineering, and project management personnel","label":"19321 Special hiring authority for scientific, engineering, and project management personnel","identifier":"/us/usc/t42/s19321","parentIdentifier":"/us/usc/t42/ch163/schVI/ptH/spt3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19321","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s19321/a","parentIdentifier":"/us/usc/t42/s19321","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19321%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19321/a/1","parentIdentifier":"/us/usc/t42/s19321/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19321%2Fa%2F1","sourceRelease":"119-100","text":"make appointments of not more than 60 scientific, engineering, and professional personnel, without regard to civil service laws, to assist the Department in meeting specific project or research needs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19321/a/2","parentIdentifier":"/us/usc/t42/s19321/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19321%2Fa%2F2","sourceRelease":"119-100","text":"fix the basic pay of any employee appointed under this section at a rate to be determined by the Under Secretary at rates not in excess of Level II of the Executive Schedule (EX–II) under without regard to the civil service laws; andsection 5311 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19321/a/3","parentIdentifier":"/us/usc/t42/s19321/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19321%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19321/a/3/A","parentIdentifier":"/us/usc/t42/s19321/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19321%2Fa%2F3%2FA","sourceRelease":"119-100","text":"$25,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19321/a/3/B","parentIdentifier":"/us/usc/t42/s19321/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19321%2Fa%2F3%2FB","sourceRelease":"119-100","text":"The amount equal to 25 percent of the annual rate of basic pay of that employee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s19321/a/3/C","parentIdentifier":"/us/usc/t42/s19321/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19321%2Fa%2F3%2FC","sourceRelease":"119-100","text":"The amount of the limitation that is applicable for a calendar year under .section 5307(a)(1) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Term","label":"b Term","identifier":"/us/usc/t42/s19321/b","parentIdentifier":"/us/usc/t42/s19321","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19321%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s19321/b/1","parentIdentifier":"/us/usc/t42/s19321/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19321%2Fb%2F1","sourceRelease":"119-100","text":"The term of any employee appointed under this section shall not exceed 3 years unless otherwise authorized in law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Termination","label":"2 Termination","identifier":"/us/usc/t42/s19321/b/2","parentIdentifier":"/us/usc/t42/s19321/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19321%2Fb%2F2","sourceRelease":"119-100","text":"The Under Secretary for Science shall have the authority to terminate any employee appointed under this section at any time based on performance or changing project or research needs of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
