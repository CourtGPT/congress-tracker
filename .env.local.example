# Copy to .env.local and set a valid Congress.gov API key.
CONGRESS_API_KEY=
CONGRESS=119
CONGRESS_LOOKBACK_HOURS=6
# Optional comma-separated resource filter for targeted recovery runs.
# CONGRESS_RESOURCES=bills
# Optional bounded historical relation backfill controls.
# CONGRESS_RELATIONS_MODE=full
# CONGRESS_RELATIONS_MAX_BILLS=250
# CONGRESS_RELATIONS_OFFSET=0
