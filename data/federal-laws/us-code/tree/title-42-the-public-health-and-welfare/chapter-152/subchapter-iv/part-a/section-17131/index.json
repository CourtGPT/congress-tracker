{"type":"section","nativeType":"section","number":"17131","heading":"Training Federal contracting officers to negotiate energy efficiency contracts","label":"17131 Training Federal contracting officers to negotiate energy efficiency contracts","identifier":"/us/usc/t42/s17131","parentIdentifier":"/us/usc/t42/ch152/schIV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Program","label":"a Program","identifier":"/us/usc/t42/s17131/a","parentIdentifier":"/us/usc/t42/s17131","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17131/a/1","parentIdentifier":"/us/usc/t42/s17131/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fa%2F1","sourceRelease":"119-100","text":"negotiate energy savings performance contracts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17131/a/2","parentIdentifier":"/us/usc/t42/s17131/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fa%2F2","sourceRelease":"119-100","text":"conclude effective and timely contracts for energy efficiency services with all companies offering energy efficiency services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17131/a/3","parentIdentifier":"/us/usc/t42/s17131/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fa%2F3","sourceRelease":"119-100","text":"review Federal contracts for all products and services for the potential energy efficiency opportunities and implications of the contracts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Schedule","label":"b Schedule","identifier":"/us/usc/t42/s17131/b","parentIdentifier":"/us/usc/t42/s17131","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fb","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary shall plan, staff, announce, and begin training under the Federal Energy Management Program.December 19, 2007","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Personnel to be trained","label":"c Personnel to be trained","identifier":"/us/usc/t42/s17131/c","parentIdentifier":"/us/usc/t42/s17131","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17131/c/1","parentIdentifier":"/us/usc/t42/s17131/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fc%2F1","sourceRelease":"119-100","text":"the Department of Defense;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17131/c/2","parentIdentifier":"/us/usc/t42/s17131/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fc%2F2","sourceRelease":"119-100","text":"the Department of Veterans Affairs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17131/c/3","parentIdentifier":"/us/usc/t42/s17131/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fc%2F3","sourceRelease":"119-100","text":"the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17131/c/4","parentIdentifier":"/us/usc/t42/s17131/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fc%2F4","sourceRelease":"119-100","text":"the General Services Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s17131/c/5","parentIdentifier":"/us/usc/t42/s17131/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fc%2F5","sourceRelease":"119-100","text":"the Department of Housing and Urban Development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s17131/c/6","parentIdentifier":"/us/usc/t42/s17131/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fc%2F6","sourceRelease":"119-100","text":"the United States Postal Service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s17131/c/7","parentIdentifier":"/us/usc/t42/s17131/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fc%2F7","sourceRelease":"119-100","text":"all other Federal agencies and departments that enter contracts for buildings, building services, electricity and electricity services, natural gas and natural gas services, heating and air conditioning services, building fuel purchases, and other types of procurement or service contracts determined by the Secretary, in carrying out the Federal Energy Management Program, to offer the potential for energy savings and greenhouse gas emission reductions if negotiated with taking into account those goals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Trainers","label":"d Trainers","identifier":"/us/usc/t42/s17131/d","parentIdentifier":"/us/usc/t42/s17131","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17131/d/1","parentIdentifier":"/us/usc/t42/s17131/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fd%2F1","sourceRelease":"119-100","text":"attorneys or contract officers with experience in negotiating and managing contracts described in subsection (c)(7) from any agency, except that the Secretary shall reimburse the related salaries and expenses of the attorneys or contract officers from amounts made available for carrying out this section to the extent the attorneys or contract officers are not employees of the Department; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17131/d/2","parentIdentifier":"/us/usc/t42/s17131/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fd%2F2","sourceRelease":"119-100","text":"private experts hired by the Secretary for the purposes of this section, except that the Secretary may not hire experts who are simultaneously employed by any company under contract to provide energy efficiency services to the Federal Government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s17131/e","parentIdentifier":"/us/usc/t42/s17131","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17131%2Fe","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Secretary to carry out this section $750,000 for each of fiscal years 2008 through 2012.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
