{"type":"section","nativeType":"section","number":"53208","heading":"Regulatory relief","label":"53208 Regulatory relief","identifier":"/us/usc/t46/s53208","parentIdentifier":"/us/usc/t46/stV/ptC/ch532","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs53208","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s53208/1","parentIdentifier":"/us/usc/t46/s53208","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs53208%2F1","sourceRelease":"119-100","text":"such equipment complies with all applicable international agreements and associated guidelines as determined by the country in which the vessel was documented immediately before becoming documented under the laws of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s53208/2","parentIdentifier":"/us/usc/t46/s53208","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs53208%2F2","sourceRelease":"119-100","text":"that country has not been identified by the Secretary of the Department in which the Coast Guard is operating as inadequately enforcing international regulations as to that vessel; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s53208/3","parentIdentifier":"/us/usc/t46/s53208","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs53208%2F3","sourceRelease":"119-100","text":"at the end of its useful life, such equipment shall be replaced with equipment that meets Federal Communication Commission equipment certification standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
