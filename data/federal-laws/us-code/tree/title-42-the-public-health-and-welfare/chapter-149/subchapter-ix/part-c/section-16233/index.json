{"type":"section","nativeType":"section","number":"16233","heading":"Low-cost renewable hydrogen and infrastructure for vehicle propulsion","label":"16233 Low-cost renewable hydrogen and infrastructure for vehicle propulsion","identifier":"/us/usc/t42/s16233","parentIdentifier":"/us/usc/t42/ch149/schIX/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16233","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16233/1","parentIdentifier":"/us/usc/t42/s16233","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16233%2F1","sourceRelease":"119-100","text":"establish a research, development, and demonstration program to determine the feasibility of using hydrogen propulsion in light-weight vehicles and the integration of the associated hydrogen production infrastructure using off-the-shelf components; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16233/2","parentIdentifier":"/us/usc/t42/s16233","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16233%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16233/2/A","parentIdentifier":"/us/usc/t42/s16233/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16233%2F2%2FA","sourceRelease":"119-100","text":"have expertise in researching and testing vehicles fueled by hydrogen, methane, and other fuels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16233/2/B","parentIdentifier":"/us/usc/t42/s16233/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16233%2F2%2FB","sourceRelease":"119-100","text":"have expertise in integrating off-the-shelf components to minimize cost; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16233/2/C","parentIdentifier":"/us/usc/t42/s16233/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16233%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16233/2/C/i","parentIdentifier":"/us/usc/t42/s16233/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16233%2F2%2FC%2Fi","sourceRelease":"119-100","text":"operates solely on hydrogen;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16233/2/C/ii","parentIdentifier":"/us/usc/t42/s16233/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16233%2F2%2FC%2Fii","sourceRelease":"119-100","text":"qualifies as a light-duty passenger vehicle; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16233/2/C/iii","parentIdentifier":"/us/usc/t42/s16233/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16233%2F2%2FC%2Fiii","sourceRelease":"119-100","text":"uses hydrogen produced from water using only solar energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
