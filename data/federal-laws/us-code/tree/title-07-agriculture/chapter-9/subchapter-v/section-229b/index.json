{"type":"section","nativeType":"section","number":"229b","heading":"Right to discuss terms of contract","label":"229b Right to discuss terms of contract","identifier":"/us/usc/t7/s229b","parentIdentifier":"/us/usc/t7/ch9/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Farm Security and Rural Investment Act of 2002, and not as part of the Packers and Stockyards Act, 1921, which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t7/s229b/a","parentIdentifier":"/us/usc/t7/s229b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Producer","label":"1 Producer","identifier":"/us/usc/t7/s229b/a/1","parentIdentifier":"/us/usc/t7/s229b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fa%2F1","sourceRelease":"119-100","text":"The term “producer” means any person engaged in the raising and caring for livestock or poultry for slaughter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Processor","label":"2 Processor","identifier":"/us/usc/t7/s229b/a/2","parentIdentifier":"/us/usc/t7/s229b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fa%2F2","sourceRelease":"119-100","text":"The term “processor” means any person engaged in the business of obtaining livestock or poultry for the purpose of slaughtering the livestock or poultry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"No prohibition of discussion","label":"b No prohibition of discussion","identifier":"/us/usc/t7/s229b/b","parentIdentifier":"/us/usc/t7/s229b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s229b/b/1","parentIdentifier":"/us/usc/t7/s229b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fb%2F1","sourceRelease":"119-100","text":"a Federal or State agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s229b/b/2","parentIdentifier":"/us/usc/t7/s229b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fb%2F2","sourceRelease":"119-100","text":"a legal adviser to the party;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s229b/b/3","parentIdentifier":"/us/usc/t7/s229b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fb%2F3","sourceRelease":"119-100","text":"a lender to the party;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s229b/b/4","parentIdentifier":"/us/usc/t7/s229b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fb%2F4","sourceRelease":"119-100","text":"an accountant hired by the party;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s229b/b/5","parentIdentifier":"/us/usc/t7/s229b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fb%2F5","sourceRelease":"119-100","text":"an executive or manager of the party;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s229b/b/6","parentIdentifier":"/us/usc/t7/s229b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fb%2F6","sourceRelease":"119-100","text":"a landlord of the party; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t7/s229b/b/7","parentIdentifier":"/us/usc/t7/s229b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fb%2F7","sourceRelease":"119-100","text":"a member of the immediate family of the party.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Effect on State laws","label":"c Effect on State laws","identifier":"/us/usc/t7/s229b/c","parentIdentifier":"/us/usc/t7/s229b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s229b/c/1","parentIdentifier":"/us/usc/t7/s229b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fc%2F1","sourceRelease":"119-100","text":"preempt any State law that addresses confidentiality provisions in contracts for the sale or production of livestock or poultry, except any provision of State law that makes lawful a contract provision that prohibits a party from, or limits a party in, engaging in discussion that subsection (b) requires to be permitted; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s229b/c/2","parentIdentifier":"/us/usc/t7/s229b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fc%2F2","sourceRelease":"119-100","text":"deprive any State court of jurisdiction under any such State law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Applicability","label":"d Applicability","identifier":"/us/usc/t7/s229b/d","parentIdentifier":"/us/usc/t7/s229b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs229b%2Fd","sourceRelease":"119-100","text":"This section applies to each contract described in subsection (b) that is entered into, amended, renewed, or extended after .May 13, 2002","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
