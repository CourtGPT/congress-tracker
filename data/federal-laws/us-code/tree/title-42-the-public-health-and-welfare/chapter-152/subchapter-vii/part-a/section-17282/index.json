ause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17282/a/1/A/i","parentIdentifier":"/us/usc/t42/s17282/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"in the State of Alaska;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17282/a/1/A/ii","parentIdentifier":"/us/usc/t42/s17282/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"without the use of a dam or impoundment of water; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s17282/a/1/A/iii","parentIdentifier":"/us/usc/t42/s17282/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F1%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s17282/a/1/A/iii/I","parentIdentifier":"/us/usc/t42/s17282/a/1/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F1%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"a lake tap (but not a perched alpine lake); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s17282/a/1/A/iii/II","parentIdentifier":"/us/usc/t42/s17282/a/1/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17282%2Fa%2F1%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"a run-of-river screened at the point of diversion; and","notes":[],"amendments":[],"effectiveDate":null,"c