","identifier":"/us/usc/t42/s18772/c/2/D","parentIdentifier":"/us/usc/t42/s18772/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fc%2F2%2FD","sourceRelease":"119-100","text":"utility-scale storage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s18772/c/2/E","parentIdentifier":"/us/usc/t42/s18772/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fc%2F2%2FE","sourceRelease":"119-100","text":"load response;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s18772/c/2/F","parentIdentifier":"/us/usc/t42/s18772/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fc%2F2%2FF","sourceRelease":"119-100","text":"aggregations of distributed energy resources at the distribution system level;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s18772/c/2/G","parentIdentifier":"/us/usc/t42/s18772/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fc%2F2%2FG","sourceRelease":"119-100","text":"power interchange between directly connected balancing authorities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t42/s18772/c/2/H","parentIdentifier":"/us/usc/t42/s18772/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fc%2F2%2FH","sourceRelease":"119-100","text":"expanding Regional Transmission Organization balancing authorities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s18772/c/2/I","parentIdentifier":"/us/usc/t42/s18772/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fc%2F2%2FI","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18772/c/2/I/i","parentIdentifier":"/us/usc/t42/s18772/c/2/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fc%2F2%2FI%2Fi","sourceRelease":"119-100","text":"accuracy of locational marginal prices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18772/c/2/I/ii","parentIdentifier":"/us/usc/t42/s18772/c/2/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fc%2F2%2FI%2Fii","sourceRelease":"119-100","text":"signals to flexible demand; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t42/s18772/c/2/J","parentIdentifier":"/us/usc/t42/s18772/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fc%2F2%2FJ","sourceRelease":"119-100","text":"disruptions to grid operations, including disruptions caused by cyber sources, physical sources, extreme weather events, or other sources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Distribution system operations","label":"d Distribution system operations","identifier":"/us/usc/t42/s18772/d","parentIdentifier":"/us/usc/t42/s18772","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18772/d/1","parentIdentifier":"/us/usc/t42/s18772/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F1","sourceRelease":"119-100","text":"Not later than 1 year after , the Administrator shall establish a system to provide to the public timely data on the operations of load-serving entities in the electricity grids of the United States.November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t42/s18772/d/2","parentIdentifier":"/us/usc/t42/s18772/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s18772/d/2/A","parentIdentifier":"/us/usc/t42/s18772/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18772/d/2/A/i","parentIdentifier":"/us/usc/t42/s18772/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s18772/d/2/A/i/I","parentIdentifier":"/us/usc/t42/s18772/d/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F2%2FA%2Fi%2FI","sourceRelease":"119-100","text":"the delivered generation resource mix for each load-serving entity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s18772/d/2/A/i/II","parentIdentifier":"/us/usc/t42/s18772/d/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F2%2FA%2Fi%2FII","sourceRelease":"119-100","text":"the distributed energy resources operating within each service area of a load-serving entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18772/d/2/A/ii","parentIdentifier":"/us/usc/t42/s18772/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":"harmonize the data on delivered generation resource mix described in clause (i)(I) with measurements of greenhouse gas emissions collected by the Environmental Protection Agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s18772/d/2/A/iii","parentIdentifier":"/us/usc/t42/s18772/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"to the maximum extent practicable, disseminate the data described in clause (i)(I) and the harmonized data described in clause (ii) on a real-time basis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s18772/d/2/A/iv","parentIdentifier":"/us/usc/t42/s18772/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"provide historical data, beginning with the earliest calendar year practicable, but not later than calendar year 2020, on the delivered generation resource mix described in clause (i)(I).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Data on the delivered generation resource mix","label":"B Data on the delivered generation resource mix","identifier":"/us/usc/t42/s18772/d/2/B","parentIdentifier":"/us/usc/t42/s18772/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18772/d/2/B/i","parentIdentifier":"/us/usc/t42/s18772/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F2%2FB%2Fi","sourceRelease":"119-100","text":"use existing voluntary industry methodologies, including reporting protocols, databases, and emissions and energy use tracking software that provide consistent, timely, and accessible carbon emissions intensity rates for delivered electricity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18772/d/2/B/ii","parentIdentifier":"/us/usc/t42/s18772/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F2%2FB%2Fii","sourceRelease":"119-100","text":"consider that generation and transmission entities may provide data on behalf of load-serving entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s18772/d/2/B/iii","parentIdentifier":"/us/usc/t42/s18772/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"to the extent that the Administrator determines necessary, and in a manner designed to protect confidential information, require each load-serving entity to submit additional information as needed to determine the delivered generation resource mix of the load-serving entity, including financial or contractual agreements for power and generation resource type attributes with respect to power owned by or retired by the load-serving entity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s18772/d/2/B/iv","parentIdentifier":"/us/usc/t42/s18772/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18772%2Fd%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"for any portion of the generation resource mix of a load-serving entity that is otherwise unaccounted for, develop a methodology to assign to the load-serving entity a share of the otherwise unaccounted for resource mix of the relevant balancing authority.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
