{"type":"section","nativeType":"section","number":"1906","heading":"Enforcement","label":"1906 Enforcement","identifier":"/us/usc/t21/s1906","parentIdentifier":"/us/usc/t21/ch24","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1906","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Criminal penalties","label":"a Criminal penalties","identifier":"/us/usc/t21/s1906/a","parentIdentifier":"/us/usc/t21/s1906","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1906%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s1906/a/1","parentIdentifier":"/us/usc/t21/s1906/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1906%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s1906/a/1/A","parentIdentifier":"/us/usc/t21/s1906/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1906%2Fa%2F1%2FA","sourceRelease":"119-100","text":"imprisoned for not more than 10 years,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s1906/a/1/B","parentIdentifier":"/us/usc/t21/s1906/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1906%2Fa%2F1%2FB","sourceRelease":"119-100","text":"fined in the amount provided in title 18 or, in the case of an entity, fined not more than $10,000,000,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s1906/a/2","parentIdentifier":"/us/usc/t21/s1906/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1906%2Fa%2F2","sourceRelease":"119-100","text":"Any officer, director, or agent of any entity who knowingly participates in a violation of the provisions of this chapter shall be imprisoned for not more than 30 years, fined not more than $5,000,000, or both.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Civil penalties","label":"b Civil penalties","identifier":"/us/usc/t21/s1906/b","parentIdentifier":"/us/usc/t21/s1906","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1906%2Fb","sourceRelease":"119-100","text":"A civil penalty not to exceed $1,000,000 may be imposed by the Secretary of the Treasury on any person who violates any license, order, rule, or regulation issued in compliance with the provisions of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Judicial review of civil penalty","label":"c Judicial review of civil penalty","identifier":"/us/usc/t21/s1906/c","parentIdentifier":"/us/usc/t21/s1906","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1906%2Fc","sourceRelease":"119-100","text":"Any penalty imposed under subsection (b) shall be subject to judicial review only to the extent provided in .section 702 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
