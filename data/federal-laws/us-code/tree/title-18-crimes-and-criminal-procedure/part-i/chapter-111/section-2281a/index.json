{"type":"section","nativeType":"section","number":"2281a","heading":"Additional offenses against maritime fixed platforms","label":"2281a Additional offenses against maritime fixed platforms","identifier":"/us/usc/t18/s2281a","parentIdentifier":"/us/usc/t18/ptI/ch111","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","DefinitionsFor definitions of terms used in this section, see .section 2280(d) of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Offenses.—","label":"a Offenses.—","identifier":"/us/usc/t18/s2281a/a","parentIdentifier":"/us/usc/t18/s2281a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t18/s2281a/a/1","parentIdentifier":"/us/usc/t18/s2281a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s2281a/a/1/A","parentIdentifier":"/us/usc/t18/s2281a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t18/s2281a/a/1/A/i","parentIdentifier":"/us/usc/t18/s2281a/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"uses against or on a fixed platform or discharges from a fixed platform any explosive or radioactive material, biological, chemical, or nuclear weapon in a manner that causes or is likely to cause death or serious injury or damage; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t18/s2281a/a/1/A/ii","parentIdentifier":"/us/usc/t18/s2281a/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"discharges from a fixed platform oil, liquefied natural gas, or another hazardous or noxious substance that is not covered by clause (i), in such quantity or concentration that causes or is likely to cause death or serious injury or damage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s2281a/a/1/B","parentIdentifier":"/us/usc/t18/s2281a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fa%2F1%2FB","sourceRelease":"119-100","text":"injures or kills any person in connection with the commission or the attempted commission of any of the offenses set forth in subparagraph (A); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t18/s2281a/a/1/C","parentIdentifier":"/us/usc/t18/s2281a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fa%2F1%2FC","sourceRelease":"119-100","text":"attempts or conspires to do anything prohibited under subparagraph (A) or (B),","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Threat to safety","label":"2 .—Threat to safety","identifier":"/us/usc/t18/s2281a/a/2","parentIdentifier":"/us/usc/t18/s2281a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fa%2F2","sourceRelease":"119-100","text":"A person who threatens, with apparent determination and will to carry the threat into execution, to do any act prohibited under paragraph (1)(A), shall be fined under this title, imprisoned not more than 5 years, or both.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Jurisdiction","label":"b .—Jurisdiction","identifier":"/us/usc/t18/s2281a/b","parentIdentifier":"/us/usc/t18/s2281a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2281a/b/1","parentIdentifier":"/us/usc/t18/s2281a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s2281a/b/1/A","parentIdentifier":"/us/usc/t18/s2281a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"that is located on the continental shelf of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s2281a/b/1/B","parentIdentifier":"/us/usc/t18/s2281a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fb%2F1%2FB","sourceRelease":"119-100","text":"that is located on the continental shelf of another country, by a national of the United States or by a stateless person whose habitual residence is in the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t18/s2281a/b/1/C","parentIdentifier":"/us/usc/t18/s2281a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fb%2F1%2FC","sourceRelease":"119-100","text":"in an attempt to compel the United States to do or abstain from doing any act;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2281a/b/2","parentIdentifier":"/us/usc/t18/s2281a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fb%2F2","sourceRelease":"119-100","text":"during the commission of such activity against or on board a fixed platform located on a continental shelf, a national of the United States is seized, threatened, injured, or killed; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s2281a/b/3","parentIdentifier":"/us/usc/t18/s2281a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fb%2F3","sourceRelease":"119-100","text":"such activity is committed against or on board a fixed platform located outside the United States and beyond the continental shelf of the United States and the offender is later found in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Exceptions","label":"c .—Exceptions","identifier":"/us/usc/t18/s2281a/c","parentIdentifier":"/us/usc/t18/s2281a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2281a/c/1","parentIdentifier":"/us/usc/t18/s2281a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fc%2F1","sourceRelease":"119-100","text":"the activities of armed forces during an armed conflict, as those terms are understood under the law of war, which are governed by that law; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2281a/c/2","parentIdentifier":"/us/usc/t18/s2281a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fc%2F2","sourceRelease":"119-100","text":"activities undertaken by military forces of a state in the exercise of their official duties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Definitions","label":"d .—Definitions","identifier":"/us/usc/t18/s2281a/d","parentIdentifier":"/us/usc/t18/s2281a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2281a/d/1","parentIdentifier":"/us/usc/t18/s2281a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fd%2F1","sourceRelease":"119-100","text":"“continental shelf” means the sea-bed and subsoil of the submarine areas that extend beyond a country’s territorial sea to the limits provided by customary international law as reflected in Article 76 of the 1982 Convention on the Law of the Sea; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2281a/d/2","parentIdentifier":"/us/usc/t18/s2281a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2281a%2Fd%2F2","sourceRelease":"119-100","text":"“fixed platform” means an artificial island, installation, or structure permanently attached to the sea-bed for the purpose of exploration or exploitation of resources or for other economic purposes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
