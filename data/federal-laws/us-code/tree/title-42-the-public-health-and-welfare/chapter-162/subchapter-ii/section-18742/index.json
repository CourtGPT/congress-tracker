/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F2%2FB","sourceRelease":"119-100","text":"in which, after , a coal-fired electricity generating unit had been retired; orDecember 31, 2009","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18742/a/2/C","parentIdentifier":"/us/usc/t42/s18742/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F2%2FC","sourceRelease":"119-100","text":"that is immediately adjacent to a census tract described in subparagraph (A) or (B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Eligible entity","label":"3 Eligible entity","identifier":"/us/usc/t42/s18742/a/3","parentIdentifier":"/us/usc/t42/s18742/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18742/a/3/A","parentIdentifier":"/us/usc/t42/s18742/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F3%2FA","sourceRelease":"119-100","text":"the gross annual sales of which are less than $100,000,000;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18742/a/3/B","parentIdentifier":"/us/usc/t42/s18742/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F3%2FB","sourceRelease":"119-100","text":"that has fewer than 500 employees at the plant site of the manufacturing firm; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18742/a/3/C","parentIdentifier":"/us/usc/t42/s18742/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F3%2FC","sourceRelease":"119-100","text":"the annual energy bills of which total more than $100,000 but less than $2,500,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Minority-owned","label":"4 Minority-owned","identifier":"/us/usc/t42/s18742/a/4","parentIdentifier":"/us/usc/t42/s18742/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18742/a/4/A","parentIdentifier":"/us/usc/t42/s18742/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F4%2FA","sourceRelease":"119-100","text":"citizens of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18742/a/4/B","parentIdentifier":"/us/usc/t42/s18742/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F4%2FB","sourceRelease":"119-100","text":"Asian American, Native Hawaiian, Pacific Islander, African American, Hispanic, Puerto Rican, Native American, or Alaska Native.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Program","label":"5 Program","identifier":"/us/usc/t42/s18742/a/5","parentIdentifier":"/us/usc/t42/s18742/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18742%2Fa%2F5","s