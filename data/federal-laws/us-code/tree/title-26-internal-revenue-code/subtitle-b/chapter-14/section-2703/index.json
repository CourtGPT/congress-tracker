{"type":"section","nativeType":"section","number":"2703","heading":"Certain rights and restrictions disregarded","label":"2703 Certain rights and restrictions disregarded","identifier":"/us/usc/t26/s2703","parentIdentifier":"/us/usc/t26/stB/ch14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2703","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"General rule","label":"a General rule","identifier":"/us/usc/t26/s2703/a","parentIdentifier":"/us/usc/t26/s2703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2703%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s2703/a/1","parentIdentifier":"/us/usc/t26/s2703/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2703%2Fa%2F1","sourceRelease":"119-100","text":"any option, agreement, or other right to acquire or use the property at a price less than the fair market value of the property (without regard to such option, agreement, or right), or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s2703/a/2","parentIdentifier":"/us/usc/t26/s2703/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2703%2Fa%2F2","sourceRelease":"119-100","text":"any restriction on the right to sell or use such property.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Exceptions","label":"b Exceptions","identifier":"/us/usc/t26/s2703/b","parentIdentifier":"/us/usc/t26/s2703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2703%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s2703/b/1","parentIdentifier":"/us/usc/t26/s2703/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2703%2Fb%2F1","sourceRelease":"119-100","text":"It is a bona fide business arrangement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s2703/b/2","parentIdentifier":"/us/usc/t26/s2703/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2703%2Fb%2F2","sourceRelease":"119-100","text":"It is not a device to transfer such property to members of the decedent’s family for less than full and adequate consideration in money or money’s worth.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t26/s2703/b/3","parentIdentifier":"/us/usc/t26/s2703/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2703%2Fb%2F3","sourceRelease":"119-100","text":"Its terms are comparable to similar arrangements entered into by persons in an arms’ length transaction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
