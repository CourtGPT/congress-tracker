{"type":"section","nativeType":"section","number":"1631","heading":"Definitions","label":"1631 Definitions","identifier":"/us/usc/t22/s1631","parentIdentifier":"/us/usc/t22/ch21/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1631","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s1631/1","parentIdentifier":"/us/usc/t22/s1631","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1631%2F1","sourceRelease":"119-100","text":"“Person” means a natural person, partnership, association, other unincorporated body, corporation, or body politic.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s1631/2","parentIdentifier":"/us/usc/t22/s1631","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1631%2F2","sourceRelease":"119-100","text":"“Property” means any property, right, or interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s1631/3","parentIdentifier":"/us/usc/t22/s1631","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1631%2F3","sourceRelease":"119-100","text":"“Treaty of peace”, with respect to a country, means the treaty of peace with that country signed at Paris, France, , which came into force between that country and the United States on .February 10, 1947September 15, 1947","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
