{"type":"section","nativeType":"section","number":"8595","heading":"United States Naval Community College: establishment and degree granting authority","label":"8595 United States Naval Community College: establishment and degree granting authority","identifier":"/us/usc/t10/s8595","parentIdentifier":"/us/usc/t10/stC/ptIII/ch859","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment and Function","label":"a .—Establishment and Function","identifier":"/us/usc/t10/s8595/a","parentIdentifier":"/us/usc/t10/s8595","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s8595/a/1","parentIdentifier":"/us/usc/t10/s8595/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8595/a/1/A","parentIdentifier":"/us/usc/t10/s8595/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fa%2F1%2FA","sourceRelease":"119-100","text":"academic and technical fields of the liberal arts and sciences which are relevant to the current and future needs of the Navy and Marine Corps, including in designated fields of national and economic importance such as cybersecurity, artificial intelligence, machine learning, data science, and software engineering; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8595/a/1/B","parentIdentifier":"/us/usc/t10/s8595/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fa%2F1%2FB","sourceRelease":"119-100","text":"their practical duties;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s8595/a/2","parentIdentifier":"/us/usc/t10/s8595/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fa%2F2","sourceRelease":"119-100","text":"remedial, developmental, or continuing education programs, as prescribed by the Secretary of the Navy, which are necessary to support, maintain, or extend programs under paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s8595/a/3","parentIdentifier":"/us/usc/t10/s8595/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fa%2F3","sourceRelease":"119-100","text":"support and advisement services for individuals pursuing such programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s8595/a/4","parentIdentifier":"/us/usc/t10/s8595/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fa%2F4","sourceRelease":"119-100","text":"continuous monitoring of the progress of such individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Individuals Eligible for Programs","label":"b .—Individuals Eligible for Programs","identifier":"/us/usc/t10/s8595/b","parentIdentifier":"/us/usc/t10/s8595","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s8595/b/1","parentIdentifier":"/us/usc/t10/s8595/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fb%2F1","sourceRelease":"119-100","text":"Enlisted members of the Navy and Marine Corps.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s8595/b/2","parentIdentifier":"/us/usc/t10/s8595/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fb%2F2","sourceRelease":"119-100","text":"Officers of the Navy and Marine Corps who hold a commission but have not completed a postsecondary degree.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s8595/b/3","parentIdentifier":"/us/usc/t10/s8595/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fb%2F3","sourceRelease":"119-100","text":"Civilian employees of the Department of the Navy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s8595/b/4","parentIdentifier":"/us/usc/t10/s8595/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8595/b/4/A","parentIdentifier":"/us/usc/t10/s8595/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fb%2F4%2FA","sourceRelease":"119-100","text":"in alignment with the mission of the United States Naval Community College; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8595/b/4/B","parentIdentifier":"/us/usc/t10/s8595/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fb%2F4%2FB","sourceRelease":"119-100","text":"determined to support the mission or needs of the Department of the Navy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Degree and Credential Granting Authority.—","label":"c Degree and Credential Granting Authority.—","identifier":"/us/usc/t10/s8595/c","parentIdentifier":"/us/usc/t10/s8595","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t10/s8595/c/1","parentIdentifier":"/us/usc/t10/s8595/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fc%2F1","sourceRelease":"119-100","text":"Under regulations prescribed by the Secretary of the Navy, the head of the United States Naval Community College may, upon the recommendation of the directors and faculty of the College, confer appropriate degrees or academic credentials upon graduates who meet the degree or credential requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Limitation","label":"2 .—Limitation","identifier":"/us/usc/t10/s8595/c/2","parentIdentifier":"/us/usc/t10/s8595/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8595/c/2/A","parentIdentifier":"/us/usc/t10/s8595/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the Secretary of Education has recommended approval of the degree or credential in accordance with the Federal Policy Governing Granting of Academic Degrees by Federal Agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8595/c/2/B","parentIdentifier":"/us/usc/t10/s8595/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the United States Naval Community College is accredited by the appropriate civilian academic accrediting agency or organization to award the degree or credential, as determined by the Secretary of Education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Congressional notification requirements.—","label":"3 Congressional notification requirements.—","identifier":"/us/usc/t10/s8595/c/3","parentIdentifier":"/us/usc/t10/s8595/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8595/c/3/A","parentIdentifier":"/us/usc/t10/s8595/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fc%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s8595/c/3/A/i","parentIdentifier":"/us/usc/t10/s8595/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fc%2F3%2FA%2Fi","sourceRelease":"119-100","text":"a copy of the self assessment questionnaire required by the Federal Policy Governing Granting of Academic Degrees by Federal Agencies, at the time the assessment is submitted to the Department of Education’s National Advisory Committee on Institutional Quality and Integrity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s8595/c/3/A/ii","parentIdentifier":"/us/usc/t10/s8595/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fc%2F3%2FA%2Fii","sourceRelease":"119-100","text":"the subsequent recommendations and rationale of the Secretary of Education regarding the establishment of the degree or credential granting authority.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8595/c/3/B","parentIdentifier":"/us/usc/t10/s8595/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fc%2F3%2FB","sourceRelease":"119-100","text":"Upon any modification or redesignation of existing degree or credential granting authority, the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and House of Representatives a report containing the rationale for the proposed modification or redesignation and any subsequent recommendation of the Secretary of Education on the proposed modification or redesignation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s8595/c/3/C","parentIdentifier":"/us/usc/t10/s8595/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fc%2F3%2FC","sourceRelease":"119-100","text":"The Secretary of Defense shall submit to the Committees on Armed Services of the Senate and House of Representatives a report containing an explanation of any action by the appropriate academic accrediting agency or organization not to accredit the United States Naval Community College to award any new or existing degree or credential.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Civilian Faculty Members.—","label":"d Civilian Faculty Members.—","identifier":"/us/usc/t10/s8595/d","parentIdentifier":"/us/usc/t10/s8595","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Authority of secretary","label":"1 .—Authority of secretary","identifier":"/us/usc/t10/s8595/d/1","parentIdentifier":"/us/usc/t10/s8595/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary of the Navy may employ as many civilians as professors, instructors, and lecturers at the United States Naval Community College as the Secretary considers necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Compensation","label":"2 .—Compensation","identifier":"/us/usc/t10/s8595/d/2","parentIdentifier":"/us/usc/t10/s8595/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8595%2Fd%2F2","sourceRelease":"119-100","text":"The compensation of persons employed under this subsection shall be prescribed by the Secretary of the Navy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
