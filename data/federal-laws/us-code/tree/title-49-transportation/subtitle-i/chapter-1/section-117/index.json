abel":"3 Chairperson and vice chairperson.—","identifier":"/us/usc/t49/s117/b/3","parentIdentifier":"/us/usc/t49/s117/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—Chairperson","label":"A .—Chairperson","identifier":"/us/usc/t49/s117/b/3/A","parentIdentifier":"/us/usc/t49/s117/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117%2Fb%2F3%2FA","sourceRelease":"119-100","text":"The Deputy Secretary of Transportation shall serve as the chairperson of the Council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Vice chairperson","label":"B .—Vice chairperson","identifier":"/us/usc/t49/s117/b/3/B","parentIdentifier":"/us/usc/t49/s117/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117%2Fb%2F3%2FB","sourceRelease":"119-100","text":"The Chief Financial Officer and Assistant Secretary for Budget and Programs shall serve as the vice chairperson of the Council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Executive director","label":"4 .—Executive director","identifier":"/us/usc/t49/s117/b/4","parentIdentifier":"/us/usc/t49/s117/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117%2Fb%2F4","sourceRelease":"119-100","text":"The Executive Director of the National Surface Transportation and Innovative Finance Bureau shall serve as a nonvoting member of the Council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Duties","label":"c .—Duties","identifier":"/us/usc/t49/s117/c","parentIdentifier":"/us/usc/t49/s117","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s117/c/1","parentIdentifier":"/us/usc/t49/s117/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117%2Fc%2F1","sourceRelease":"119-100","text":"review applications for assistance submitted under the programs referred to in subparagraphs (A), (B), and (C) of section 116(d)(1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s117/c/2","parentIdentifier":"/us/usc/t49/s117/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117%2Fc%2F2","sourceRelease":"119-100","text":"review applications for assistance submitted under the program referred to in section 116(d)(1)(D), as determined appropriate by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s117/c/3","parentIdentifier":"/us/usc/t49/s117/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117%2Fc%2F3","sourceRelease":"119-100","text":"make recommendations to the Secretary regarding the selection of projects to receive assistance under such programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s117/c/4","parentIdentifier":"/us/usc/t49/s117/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117%2Fc%2F4","sourceRelease":"119-100","text":"review, on a regular basis, projects that received assistance under such programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t49/s117/c/5","parentIdentifier":"/us/usc/t49/s117/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs117%2Fc%2F5","sourceRelease":"119-100","text":"carry out such additional duties as the Secretary may prescribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
