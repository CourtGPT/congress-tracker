 Vehicle Use Map; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s538a/b/2/B","parentIdentifier":"/us/usc/t16/s538a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F2%2FB","sourceRelease":"119-100","text":"a map depicting the authorized trails in the applicable unit of the National Forest System and the trail is not identified as a National Forest System trail on that map;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s538a/b/3","parentIdentifier":"/us/usc/t16/s538a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s538a/b/3/A","parentIdentifier":"/us/usc/t16/s538a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F3%2FA","sourceRelease":"119-100","text":"prevents motor vehicle use, as appropriate to conform to route designations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s538a/b/3/B","parentIdentifier":"/us/usc/t16/s538a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F3%2FB","sourceRelease":"119-100","text":"prevents the roads from damaging adjacent resources, including aquatic and wildlife resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s538a/b/3/C","parentIdentifier":"/us/usc/t16/s538a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F3%2FC","sourceRelease":"119-100","text":"reduces or eliminates the need for road maintenance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s538a/b/3/D","parentIdentifier":"/us/usc/t16/s538a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F3%2FD","sourceRelease":"119-100","text":"preserves the roads for future use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s538a/b/4","parentIdentifier":"/us/usc/t16/s538a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F4","sourceRelease":"119-100","text":"decommission previously closed National Forest System roads and trails in accordance with subsections (c)(1) and (d);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s538a/b/5","parentIdentifier":"/us/usc/t16/s538a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s538a/b/5/A","parentIdentifier":"/us/usc/t16/s538a/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F5%2FA","sourceRelease":"119-100","text":"to increase resilience to extreme weather events, flooding, and other natural disasters; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s538a/b/5/B","parentIdentifier":"/us/usc/t16/s538a/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F5%2FB","sourceRelease":"119-100","text":"to respond to changing resource conditions and public input;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s538a/b/6","parentIdentifier":"/us/usc/t16/s538a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F6","sourceRelease":"119-100","text":"convert National Forest System roads to National Forest System trails, while allowing for continued use for motorized and nonmotorized recreation, to the extent the use is compatible with the management status of the road or trail;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t16/s538a/b/7","parentIdentifier":"/us/usc/t16/s538a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s538a/b/7/A","parentIdentifier":"/us/usc/t16/s538a/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F7%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s538a/b/7/A/i","parentIdentifier":"/us/usc/t16/s538a/b/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb%2F7%2FA%2Fi","sourceRelease":"119-100","text":"for emergency operations; 