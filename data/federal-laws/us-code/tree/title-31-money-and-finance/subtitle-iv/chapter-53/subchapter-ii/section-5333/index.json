{"type":"section","nativeType":"section","number":"5333","heading":"Safe harbor with respect to keep open directives","label":"5333 Safe harbor with respect to keep open directives","identifier":"/us/usc/t31/s5333","parentIdentifier":"/us/usc/t31/stIV/ch53/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t31/s5333/a","parentIdentifier":"/us/usc/t31/s5333","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t31/s5333/a/1","parentIdentifier":"/us/usc/t31/s5333/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fa%2F1","sourceRelease":"119-100","text":"the financial institution shall not be liable under this subchapter for maintaining that account or transaction consistent with the parameters and timing of the request; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t31/s5333/a/2","parentIdentifier":"/us/usc/t31/s5333/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fa%2F2","sourceRelease":"119-100","text":"no Federal or State department or agency may take any adverse supervisory action under this subchapter with respect to the financial institution solely for maintaining that account or transaction consistent with the parameters of the request.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Rule of Construction","label":"b .—Rule of Construction","identifier":"/us/usc/t31/s5333/b","parentIdentifier":"/us/usc/t31/s5333","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t31/s5333/b/1","parentIdentifier":"/us/usc/t31/s5333/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fb%2F1","sourceRelease":"119-100","text":"to prevent a Federal or State department or agency from verifying the validity of a keep open request submitted under subsection (a) with the law enforcement agency submitting that request;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t31/s5333/b/2","parentIdentifier":"/us/usc/t31/s5333/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fb%2F2","sourceRelease":"119-100","text":"to relieve a financial institution from complying with any reporting requirements or any other provisions of this subchapter, including the reporting of suspicious transactions under section 5318(g); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t31/s5333/b/3","parentIdentifier":"/us/usc/t31/s5333/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t31/s5333/b/3/A","parentIdentifier":"/us/usc/t31/s5333/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fb%2F3%2FA","sourceRelease":"119-100","text":"before the date of the keep open request to maintain a customer account; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t31/s5333/b/3/B","parentIdentifier":"/us/usc/t31/s5333/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fb%2F3%2FB","sourceRelease":"119-100","text":"after the termination date stated in the keep open request.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Letter Termination Date","label":"c .—Letter Termination Date","identifier":"/us/usc/t31/s5333/c","parentIdentifier":"/us/usc/t31/s5333","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fc","sourceRelease":"119-100","text":"For the purposes of this section, any keep open request submitted under subsection (a) shall include a termination date after which that request shall no longer apply.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Record Keeping","label":"d .—Record Keeping","identifier":"/us/usc/t31/s5333/d","parentIdentifier":"/us/usc/t31/s5333","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t31/s5333/d/1","parentIdentifier":"/us/usc/t31/s5333/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fd%2F1","sourceRelease":"119-100","text":"submit to FinCEN a copy of the request; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t31/s5333/d/2","parentIdentifier":"/us/usc/t31/s5333/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fd%2F2","sourceRelease":"119-100","text":"alert FinCEN as to whether the financial institution has implemented the request.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Guidance","label":"e .—Guidance","identifier":"/us/usc/t31/s5333/e","parentIdentifier":"/us/usc/t31/s5333","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5333%2Fe","sourceRelease":"119-100","text":"The Secretary of the Treasury, in consultation with the Attorney General and Federal, State, Tribal, and local law enforcement agencies, shall issue guidance on the required elements of a keep open request.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
