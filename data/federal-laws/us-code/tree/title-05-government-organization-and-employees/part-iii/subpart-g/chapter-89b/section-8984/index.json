{"type":"section","nativeType":"section","number":"8984","heading":"Benefits","label":"8984 Benefits","identifier":"/us/usc/t5/s8984","parentIdentifier":"/us/usc/t5/ptIII/sptG/ch89B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8984","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , and applicable to contracts that take effect with respect to the calendar year 2006, see , set out as a note under .Dec. 23, 2004section 7 of Pub. L. 108–496section 8951 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s8984/a","parentIdentifier":"/us/usc/t5/s8984","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8984%2Fa","sourceRelease":"119-100","text":"The Office may prescribe reasonable minimum standards for enhanced vision benefits plans offered under this chapter and for qualified companies offering the plans.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s8984/b","parentIdentifier":"/us/usc/t5/s8984","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8984%2Fb","sourceRelease":"119-100","text":"Each contract may include more than 1 level of benefits that shall be made available to all eligible individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t5/s8984/c","parentIdentifier":"/us/usc/t5/s8984","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8984%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s8984/c/1","parentIdentifier":"/us/usc/t5/s8984/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8984%2Fc%2F1","sourceRelease":"119-100","text":"Diagnostic (to include refractive services).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s8984/c/2","parentIdentifier":"/us/usc/t5/s8984/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8984%2Fc%2F2","sourceRelease":"119-100","text":"Preventive.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s8984/c/3","parentIdentifier":"/us/usc/t5/s8984/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8984%2Fc%2F3","sourceRelease":"119-100","text":"Eyewear.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t5/s8984/d","parentIdentifier":"/us/usc/t5/s8984","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8984%2Fd","sourceRelease":"119-100","text":"A contract approved under this chapter shall require the qualified company to cover the geographic service delivery area specified by the Office. The Office shall require qualified companies to include visually underserved areas in their service delivery areas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":null,"label":"e","identifier":"/us/usc/t5/s8984/e","parentIdentifier":"/us/usc/t5/s8984","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8984%2Fe","sourceRelease":"119-100","text":"If an individual has vision coverage under a health benefits plan under chapter 89 and also has coverage under a plan under this chapter, the health benefits plan under chapter 89 shall be the first payor of any benefit payments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
