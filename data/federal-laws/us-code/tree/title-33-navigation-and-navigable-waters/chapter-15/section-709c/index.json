{"type":"section","nativeType":"section","number":"709c","heading":"Emergency communication of risk","label":"709c Emergency communication of risk","identifier":"/us/usc/t33/s709c","parentIdentifier":"/us/usc/t33/ch15","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs709c","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","“Secretary” DefinedSecretary means the Secretary of the Army, see , set out as a note under .section 2 of Pub. L. 113–121section 2201 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t33/s709c/a","parentIdentifier":"/us/usc/t33/s709c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs709c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Affected government","label":"1 Affected government","identifier":"/us/usc/t33/s709c/a/1","parentIdentifier":"/us/usc/t33/s709c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs709c%2Fa%2F1","sourceRelease":"119-100","text":"The term “affected government” means a State, local, or tribal government with jurisdiction over an area that will be affected by a flood.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Annual operating plan","label":"2 Annual operating plan","identifier":"/us/usc/t33/s709c/a/2","parentIdentifier":"/us/usc/t33/s709c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs709c%2Fa%2F2","sourceRelease":"119-100","text":"The term “annual operating plan” means a plan prepared by the Secretary that describes potential water condition scenarios for a river basin for a year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Communication","label":"b Communication","identifier":"/us/usc/t33/s709c/b","parentIdentifier":"/us/usc/t33/s709c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs709c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s709c/b/1","parentIdentifier":"/us/usc/t33/s709c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs709c%2Fb%2F1","sourceRelease":"119-100","text":"timely information regarding expected water levels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s709c/b/2","parentIdentifier":"/us/usc/t33/s709c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs709c%2Fb%2F2","sourceRelease":"119-100","text":"advice regarding appropriate preparedness actions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s709c/b/3","parentIdentifier":"/us/usc/t33/s709c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs709c%2Fb%2F3","sourceRelease":"119-100","text":"technical assistance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s709c/b/4","parentIdentifier":"/us/usc/t33/s709c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs709c%2Fb%2F4","sourceRelease":"119-100","text":"any other information or assistance determined appropriate by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Public availability of information","label":"c Public availability of information","identifier":"/us/usc/t33/s709c/c","parentIdentifier":"/us/usc/t33/s709c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs709c%2Fc","sourceRelease":"119-100","text":"To the maximum extent practicable, the Secretary, in coordination with the Administrator of the Federal Emergency Management Agency, shall make the information required under subsection (b) available to the public through widely used and readily available means, including on the Internet.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Procedures","label":"d Procedures","identifier":"/us/usc/t33/s709c/d","parentIdentifier":"/us/usc/t33/s709c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs709c%2Fd","sourceRelease":"119-100","text":"The Secretary shall use the procedures established under subsection (b) only when precipitation or runoff exceeds those calculations considered as the lowest risk to life and property contemplated by the annual operating plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
