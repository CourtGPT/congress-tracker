{"type":"section","nativeType":"section","number":"10607","heading":"Prohibition of support for certain governments","label":"10607 Prohibition of support for certain governments","identifier":"/us/usc/t22/s10607","parentIdentifier":"/us/usc/t22/ch113","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10607","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s10607/a","parentIdentifier":"/us/usc/t22/s10607","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10607%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10607/a/1","parentIdentifier":"/us/usc/t22/s10607/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10607%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10607/a/1/A","parentIdentifier":"/us/usc/t22/s10607/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10607%2Fa%2F1%2FA","sourceRelease":"119-100","text":";section 4813(c)(1)(A)(i) of title 50","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10607/a/1/B","parentIdentifier":"/us/usc/t22/s10607/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10607%2Fa%2F1%2FB","sourceRelease":"119-100","text":";section 2371(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10607/a/1/C","parentIdentifier":"/us/usc/t22/s10607/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10607%2Fa%2F1%2FC","sourceRelease":"119-100","text":"; orsection 2780(d) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s10607/a/1/D","parentIdentifier":"/us/usc/t22/s10607/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10607%2Fa%2F1%2FD","sourceRelease":"119-100","text":"any other relevant provision of law;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10607/a/2","parentIdentifier":"/us/usc/t22/s10607/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10607%2Fa%2F2","sourceRelease":"119-100","text":"has been identified pursuant to section 2151n(a) or 2304(a)(2) of this title or any other relevant provision of law; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s10607/a/3","parentIdentifier":"/us/usc/t22/s10607/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10607%2Fa%2F3","sourceRelease":"119-100","text":"has failed the “control of corruption” indicator, as determined by the Millennium Challenge Corporation, within any of the preceding 3 years of the intended grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Prohibition of support for sanctioned persons","label":"b Prohibition of support for sanctioned persons","identifier":"/us/usc/t22/s10607/b","parentIdentifier":"/us/usc/t22/s10607","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10607%2Fb","sourceRelease":"119-100","text":"The Foundation may not engage in any dealing prohibited under United States sanctions laws or regulations, including dealings with persons on the list of specially designated persons and blocked persons maintained by the Office of Foreign Assets Control of the Department of the Treasury, except to the extent otherwise authorized by the Secretary or by the Secretary of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Prohibition of support for activities subject to sanctions","label":"c Prohibition of support for activities subject to sanctions","identifier":"/us/usc/t22/s10607/c","parentIdentifier":"/us/usc/t22/s10607","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10607%2Fc","sourceRelease":"119-100","text":"The Foundation shall require any person receiving support to certify that such person, and any entity owned or controlled by such person, is in compliance with all United States sanctions laws and regulations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
