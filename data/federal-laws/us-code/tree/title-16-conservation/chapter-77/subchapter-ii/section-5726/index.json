{"type":"section","nativeType":"section","number":"5726","heading":"Yukon River salmon stock restoration and enhancement projects","label":"5726 Yukon River salmon stock restoration and enhancement projects","identifier":"/us/usc/t16/s5726","parentIdentifier":"/us/usc/t16/ch77/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs5726","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s5726/a","parentIdentifier":"/us/usc/t16/s5726","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs5726%2Fa","sourceRelease":"119-100","text":"The Secretary of the Interior, in consultation with the Secretary of Commerce, may carry out projects to restore or enhance salmon stocks originating from the Yukon River in Canada and the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Cooperation with Canada","label":"b Cooperation with Canada","identifier":"/us/usc/t16/s5726/b","parentIdentifier":"/us/usc/t16/s5726","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs5726%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s5726/b/1","parentIdentifier":"/us/usc/t16/s5726/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs5726%2Fb%2F1","sourceRelease":"119-100","text":"projects under this section shall be carried out in accordance with that agreement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s5726/b/2","parentIdentifier":"/us/usc/t16/s5726/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs5726%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s5726/b/2/A","parentIdentifier":"/us/usc/t16/s5726/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs5726%2Fb%2F2%2FA","sourceRelease":"119-100","text":"shall be expended in accordance with the agreement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s5726/b/2/B","parentIdentifier":"/us/usc/t16/s5726/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs5726%2Fb%2F2%2FB","sourceRelease":"119-100","text":"may be deposited in any joint account established by the agreement to fund such projects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
