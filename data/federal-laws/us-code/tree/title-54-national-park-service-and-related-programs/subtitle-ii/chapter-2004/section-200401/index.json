{"type":"section","nativeType":"section","number":"200401","heading":"Definitions","label":"200401 Definitions","identifier":"/us/usc/t54/s200401","parentIdentifier":"/us/usc/t54/stII/ch2004","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft54%2Fs200401","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Asset","label":"1 .—Asset","identifier":"/us/usc/t54/s200401/1","parentIdentifier":"/us/usc/t54/s200401","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft54%2Fs200401%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t54/s200401/1/A","parentIdentifier":"/us/usc/t54/s200401/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft54%2Fs200401%2F1%2FA","sourceRelease":"119-100","text":"has a specific service or function; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t54/s200401/1/B","parentIdentifier":"/us/usc/t54/s200401/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft54%2Fs200401%2F1%2FB","sourceRelease":"119-100","text":"is tracked and managed as a distinct, identifiable entity by the applicable covered agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Covered agency","label":"2 .—Covered agency","identifier":"/us/usc/t54/s200401/2","parentIdentifier":"/us/usc/t54/s200401","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft54%2Fs200401%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t54/s200401/2/A","parentIdentifier":"/us/usc/t54/s200401/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft54%2Fs200401%2F2%2FA","sourceRelease":"119-100","text":"the Service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t54/s200401/2/B","parentIdentifier":"/us/usc/t54/s200401/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft54%2Fs200401%2F2%2FB","sourceRelease":"119-100","text":"the United States Fish and Wildlife Service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t54/s200401/2/C","parentIdentifier":"/us/usc/t54/s200401/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft54%2Fs200401%2F2%2FC","sourceRelease":"119-100","text":"the Forest Service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t54/s200401/2/D","parentIdentifier":"/us/usc/t54/s200401/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft54%2Fs200401%2F2%2FD","sourceRelease":"119-100","text":"the Bureau of Land Management; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t54/s200401/2/E","parentIdentifier":"/us/usc/t54/s200401/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft54%2Fs200401%2F2%2FE","sourceRelease":"119-100","text":"the Bureau of Indian Education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Fund","label":"3 .—Fund","identifier":"/us/usc/t54/s200401/3","parentIdentifier":"/us/usc/t54/s200401","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft54%2Fs200401%2F3","sourceRelease":"119-100","text":"The term “Fund” means the National Parks and Public Land Legacy Restoration Fund established by section 200402(a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Project","label":"4 .—Project","identifier":"/us/usc/t54/s200401/4","parentIdentifier":"/us/usc/t54/s200401","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft54%2Fs200401%2F4","sourceRelease":"119-100","text":"The term “project” means any activity to reduce or eliminate deferred maintenance of an asset, which may include resolving directly related infrastructure deficiencies of the asset that would not by itself be classified as deferred maintenance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
