e":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"L","heading":null,"label":"L","identifier":"/us/usc/t16/s8203/a/2/L","parentIdentifier":"/us/usc/t16/s8203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FL","sourceRelease":"119-100","text":"1 shall be a representative of an agricultural production organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"M","heading":null,"label":"M","identifier":"/us/usc/t16/s8203/a/2/M","parentIdentifier":"/us/usc/t16/s8203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FM","sourceRelease":"119-100","text":"1 shall be a representative of local government interests involved in fish habitat restoration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"N","heading":null,"label":"N","identifier":"/us/usc/t16/s8203/a/2/N","parentIdentifier":"/us/usc/t16/s8203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FN","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8203/a/2/N/i","parentIdentifier":"/us/usc/t16/s8203/a/2/N","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FN%2Fi","sourceRelease":"119-100","text":"natural resource commodity interests, such as petroleum or mineral extraction;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8203/a/2/N/ii","parentIdentifier":"/us/usc/t16/s8203/a/2/N","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FN%2Fii","sourceRelease":"119-100","text":"natural resource user industries; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s8203/a/2/N/iii","parentIdentifier":"/us/usc/t16/s8203/a/2/N","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FN%2Fiii","sourceRelease":"119-100","text":"industries with an interest in fish and fish habitat conservation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"O","heading":null,"label":"O","identifier":"/us/usc/t16/s8203/a/2/O","parentIdentifier":"/us/usc/t16/s8203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FO","sourceRelease":"119-100","text":"1 shall be an individual in a leadership position in the private sector or landowner representative of an active partnership.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Compensation","label":"3 Compensation","identifier":"/us/usc/t16/s8203/a/3","parentIdentifier":"/us/usc/t16/s8203/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F3","sourceRelease":"119-100","text":"A member of the Board shall serve without compensation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Travel expenses","label":"4 Travel expenses","identifier":"/us/usc/t16/s8203/a/4","parentIdentifier":"/us/usc/t16/s8203/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F4","sourceRelease":"119-100","text":"A member of the Board may be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for an employee of an agency under subchapter I of chapter 57 of title 5, while away from the home or regular place of business of the member in the performance of the duties of the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Appointment and terms","label":"b Appointment and terms","identifier":"/us/usc/t16/s8203/b","parentIdentifier":"/us/usc/t16/s8203","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s8203/b/1","parentIdentifier":"/us/usc/t16/s8203/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F1","sourceRelease":"119-100","text":"Except as otherwise provided in this section, a member of the Board described in any of subparagraphs (F) through (O) of subsection (a)(2) shall serve for a term of 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Initial Board membership","label":"2 Initial Board membership","identifier":"/us/usc/t16/s8203/b/2","parentIdentifier":"/us/usc/t16/s8203/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s8203/b/2/A","parentIdentifier":"/us/usc/t16/s8203/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The initial Board shall consist of representatives as described in subparagraphs (A) through (F) of subsection (a)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Remaining members","label":"B Remaining members","identifier":"/us/usc/t16/s8203/b/2/B","parentIdentifier":"/us/usc/t16/s8203/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F2%2FB","sourceRelease":"119-100","text":"Not later than 60 days after , the representatives of the initial Board under subparagraph (A) shall appoint the remaining members of the Board described in subparagraphs (H) through (O) of subsection (a)(2).October 30, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Tribal representatives","label":"C Tribal representatives","identifier":"/us/usc/t16/s8203/b/2/C","parentIdentifier":"/us/usc/t16/s8203/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F2%2FC","sourceRelease":"119-100","text":"Not later than 60 days after , the Secretary shall provide to the Board a recommendation of not fewer than three Tribal representatives, from which the Board shall appoint one representative pursuant to subparagraph (G) of subsection (a)(2).October 30, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Staggered terms","label":"3 Staggered terms","identifier":"/us/usc/t16/s8203/b/3","parentIdentifier":"/us/usc/t16/s8203/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8203/b/3/A","parentIdentifier":"/us/usc/t16/s8203/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F3%2FA","sourceRelease":"119-100","text":"two shall be appointed for a term of 1 year;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8203/b/3/B","parentIdentifier":"/us/usc/t16/s8203/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F3%2FB","sourceRelease":"119-100","text":"two shall be appointed for a term of 2 years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8203/b/3/C","parentIdentifier":"/us/usc/t16/s8203/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F3%2FC","sourceRelease":"119-100","text":"three shall be appointed for a term of 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Vacancies","label":"4 Vacancies","identifier":"/us/usc/t16/s8203/b/4","parentIdentifier":"/us/usc/t16/s8203/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s8203/b/4/A","parentIdentifier":"/us/usc/t16/s8203/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F4%2FA","sourceRelease":"119-100","text":"A vacancy of a member of the Board described in subparagraph (H), (I), (J), (K), (L), (M), (N), or (O) of subsection (a)(2) shall be filled by an appointment made by the remaining members of the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Tribal representatives","label":"B Tribal representatives","identifier":"/us/usc/t16/s8203/b/4/B","parentIdentifier":"/us/usc/t16/s8203/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F4%2FB","sourceRelease":"119-100","text":"Following a vacancy of a member of the Board described in subparagraph (G) of subsection (a)(2), the Secretary shall recommend to the Board a list of not fewer than three Tribal representatives, from which the remaining members of the Board shall appoint a representative to fill the vacancy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Continuation of service","label":"5 Continuation of service","identifier":"/us/usc/t16/s8203/b/5","parentIdentifier":"/us/usc/t16/s8203/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F5","sourceRelease":"119-100","text":"An individual whose term of service as a member of the Board expires may continue to serve on the Board until a successor is appointed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Removal","label":"6 Removal","identifier":"/us/usc/t16/s8203/b/6","parentIdentifier":"/us/usc/t16/s8203/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8203/b/6/A","parentIdentifier":"/us/usc/t16/s8203/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F6%2FA","sourceRelease":"119-100","text":"vote to remove that member; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8203/b/6/B","parentIdentifier":"/us/usc/t16/s8203/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fb%2F6%2FB","sourceRelease":"119-100","text":"appoint another individual in accordance with paragraph (4).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Chairperson","label":"c Chairperson","identifier":"/us/usc/t16/s8203/c","parentIdentifier":"/us/usc/t16/s8203","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s8203/c/1","parentIdentifier":"/us/usc/t16/s8203/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fc%2F1","sourceRelease":"119-100","text":"The representative of the Association of Fish and Wildlife Agencies appointed under subsection (a)(2)(E) shall serve as Chairperson of the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Term","label":"2 Term","identifier":"/us/usc/t16/s8203/c/2","parentIdentifier":"/us/usc/t16/s8203/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fc%2F2","sourceRelease":"119-100","text":"The Chairperson of the Board shall serve for a term of 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Meetings","label":"d Meetings","identifier":"/us/usc/t16/s8203/d","parentIdentifier":"/us/usc/t16/s8203","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s8203/d/1","parentIdentifier":"/us/usc/t16/s8203/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8203/d/1/A","parentIdentifier":"/us/usc/t16/s8203/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fd%2F1%2FA","sourceRelease":"119-100","text":"at the call of the Chairperson; but","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8203/d/1/B","parentIdentifier":"/us/usc/t16/s8203/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fd%2F1%2FB","sourceRelease":"119-100","text":"not less frequently than twice each calendar year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Public access","label":"2 Public access","identifier":"/us/usc/t16/s8203/d/2","parentIdentifier":"/us/usc/t16/s8203/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fd%2F2","sourceRelease":"119-100","text":"All meetings of the Board shall be open to the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Procedures","label":"e Procedures","identifier":"/us/usc/t16/s8203/e","parentIdentifier":"/us/usc/t16/s8203","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s8203/e/1","parentIdentifier":"/us/usc/t16/s8203/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8203/e/1/A","parentIdentifier":"/us/usc/t16/s8203/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fe%2F1%2FA","sourceRelease":"119-100","text":"a requirement that a quorum of the members of the Board be present to transact business;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8203/e/1/B","parentIdentifier":"/us/usc/t16/s8203/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fe%2F1%2FB","sourceRelease":"119-100","text":"a requirement that no recommendations may be adopted by the Board, except by the vote of two-thirds of the members present;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8203/e/1/C","parentIdentifier":"/us/usc/t16/s8203/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fe%2F1%2FC","sourceRelease":"119-100","text":"procedures for establishing national goals and priorities for fish habitat conservation for the purposes of this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s8203/e/1/D","parentIdentifier":"/us/usc/t16/s8203/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fe%2F1%2FD","sourceRelease":"119-100","text":"procedures for designating Partnerships under ; andsection 8204 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s8203/e/1/E","parentIdentifier":"/us/usc/t16/s8203/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fe%2F1%2FE","sourceRelease":"119-100","text":"procedures for reviewing, evaluating, and making recommendations regarding fish habitat conservation projects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Quorum","label":"2 Quorum","identifier":"/us/usc/t16/s8203/e/2","parentIdentifier":"/us/usc/t16/s8203/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fe%2F2","sourceRelease":"119-100","text":"A majority of the members of the Board shall constitute a quorum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
