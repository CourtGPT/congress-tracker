{"type":"section","nativeType":"section","number":"290i–11","heading":"Sixth capital increase","label":"290i–11 Sixth capital increase","identifier":"/us/usc/t22/s290i–11","parentIdentifier":"/us/usc/t22/ch7/schXXIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290i%E2%80%9311","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Subscription authorized","label":"a Subscription authorized","identifier":"/us/usc/t22/s290i–11/a","parentIdentifier":"/us/usc/t22/s290i–11","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290i%E2%80%9311%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s290i–11/a/1","parentIdentifier":"/us/usc/t22/s290i–11/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290i%E2%80%9311%2Fa%2F1","sourceRelease":"119-100","text":"The United States Governor of the Bank may subscribe on behalf of the United States to 289,391 additional shares of the capital stock of the Bank.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s290i–11/a/2","parentIdentifier":"/us/usc/t22/s290i–11/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290i%E2%80%9311%2Fa%2F2","sourceRelease":"119-100","text":"Any subscription by the United States to the capital stock of the Bank shall be effective only to such extent and in such amounts as are provided in advance in appropriations Acts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitations on authorization of appropriations","label":"b Limitations on authorization of appropriations","identifier":"/us/usc/t22/s290i–11/b","parentIdentifier":"/us/usc/t22/s290i–11","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290i%E2%80%9311%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s290i–11/b/1","parentIdentifier":"/us/usc/t22/s290i–11/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290i%E2%80%9311%2Fb%2F1","sourceRelease":"119-100","text":"In order to pay for the increase in the United States subscription to the Bank under subsection (a), there are authorized to be appropriated, without fiscal year limitation, $4,322,228,221 for payment by the Secretary of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s290i–11/b/2","parentIdentifier":"/us/usc/t22/s290i–11/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290i%E2%80%9311%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s290i–11/b/2/A","parentIdentifier":"/us/usc/t22/s290i–11/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290i%E2%80%9311%2Fb%2F2%2FA","sourceRelease":"119-100","text":"$259,341,759 shall be for paid in shares of the Bank; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s290i–11/b/2/B","parentIdentifier":"/us/usc/t22/s290i–11/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs290i%E2%80%9311%2Fb%2F2%2FB","sourceRelease":"119-100","text":"$4,062,886,462 shall be for callable shares of the Bank.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
