{"type":"section","nativeType":"section","number":"6504","heading":"Incorporation of Department of Transportation research","label":"6504 Incorporation of Department of Transportation research","identifier":"/us/usc/t49/s6504","parentIdentifier":"/us/usc/t49/stIII/ch65","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6504","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Review","label":"a .—Review","identifier":"/us/usc/t49/s6504/a","parentIdentifier":"/us/usc/t49/s6504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6504%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s6504/a/1","parentIdentifier":"/us/usc/t49/s6504/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6504%2Fa%2F1","sourceRelease":"119-100","text":"conduct a review of research conducted by the Department of Transportation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s6504/a/2","parentIdentifier":"/us/usc/t49/s6504/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6504%2Fa%2F2","sourceRelease":"119-100","text":"to the maximum extent practicable and appropriate, identify modifications to laws, regulations, guidance, and other policy documents to incorporate any innovations resulting from the research described in paragraph (1) that have the potential to improve the safety or efficiency of the United States transportation system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Requirements","la