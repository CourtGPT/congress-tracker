{"type":"section","nativeType":"section","number":"2349cc–2","heading":"Review of emergency assistance capacity","label":"2349cc–2 Review of emergency assistance capacity","identifier":"/us/usc/t22/s2349cc–2","parentIdentifier":"/us/usc/t22/ch32/schII/ptX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2349cc%E2%80%932","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s2349cc–2/a","parentIdentifier":"/us/usc/t22/s2349cc–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2349cc%E2%80%932%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s2349cc–2/a/1","parentIdentifier":"/us/usc/t22/s2349cc–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2349cc%E2%80%932%2Fa%2F1","sourceRelease":"119-100","text":"analyzes the United States Government’s capacity to promptly and effectively deliver emergency support to countries experiencing major cybersecurity and ICT incidents;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s2349cc–2/a/2","parentIdentifier":"/us/usc/t22/s2349cc–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2349cc%E2%80%932%2Fa%2F2","sourceRelease":"119-100","text":"identifies relevant factors constraining the support referred to in paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s2349cc–2/a/3","parentIdentifier":"/us/usc/t22/s2349cc–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2349cc%E2%80%932%2Fa%2F3","sourceRelease":"119-100","text":"develops a strategy to improve coordination among relevant Federal agencies and to resolve such constraints.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report","label":"b Report","identifier":"/us/usc/t22/s2349cc–2/b","parentIdentifier":"/us/usc/t22/s2349cc–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2349cc%E2%80%932%2Fb","sourceRelease":"119-100","text":"Not later than one year after , the Secretary of State shall submit to the Committee on Foreign Relations and the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Foreign Affairs and the Committee on Oversight and Accountability of the House of Representatives a report that contains the results of the review conducted pursuant to subsection (a).December 22, 2023","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
