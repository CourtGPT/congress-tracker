{"type":"section","nativeType":"section","number":"2724","heading":"Civil action","label":"2724 Civil action","identifier":"/us/usc/t18/s2724","parentIdentifier":"/us/usc/t18/ptI/ch123","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2724","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 3 years after , with provisions relating to release of personal information before the effective date and compliance after such date, see , set out as a note under .Sept. 13, 1994section 300003 of Pub. L. 103–322section 2721 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Cause of Action","label":"a .—Cause of Action","identifier":"/us/usc/t18/s2724/a","parentIdentifier":"/us/usc/t18/s2724","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2724%2Fa","sourceRelease":"119-100","text":"A person who knowingly obtains, discloses or uses personal information, from a motor vehicle record, for a purpose not permitted under this chapter shall be liable to the individual to whom the information pertains, who may bring a civil action in a United States district court.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Remedies","label":"b .—Remedies","identifier":"/us/usc/t18/s2724/b","parentIdentifier":"/us/usc/t18/s2724","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2724%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s2724/b/1","parentIdentifier":"/us/usc/t18/s2724/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2724%2Fb%2F1","sourceRelease":"119-100","text":"actual damages, but not less than liquidated damages in the amount of $2,500;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s2724/b/2","parentIdentifier":"/us/usc/t18/s2724/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2724%2Fb%2F2","sourceRelease":"119-100","text":"punitive damages upon proof of willful or reckless disregard of the law;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s2724/b/3","parentIdentifier":"/us/usc/t18/s2724/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2724%2Fb%2F3","sourceRelease":"119-100","text":"reasonable attorneys’ fees and other litigation costs reasonably incurred; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t18/s2724/b/4","parentIdentifier":"/us/usc/t18/s2724/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs2724%2Fb%2F4","sourceRelease":"119-100","text":"such other preliminary and equitable relief as the court determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
