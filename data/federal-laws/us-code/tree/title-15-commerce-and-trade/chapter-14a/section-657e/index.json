"nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s657e/c/5","parentIdentifier":"/us/usc/t15/s657e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fc%2F5","sourceRelease":"119-100","text":"agree to reimburse volunteer mentors for out-of-pocket expenses related to service as a mentor under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Mentoring database","label":"d Mentoring database","identifier":"/us/usc/t15/s657e/d","parentIdentifier":"/us/usc/t15/s657e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s657e/d/1","parentIdentifier":"/us/usc/t15/s657e/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fd%2F1","sourceRelease":"119-100","text":"include in the database required by , in cooperation with the SBIR, STTR, and FAST programs, information on Mentoring Networks and mentors participating under this section, including a description of their areas of expertise;section 638(k)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s657e/d/2","parentIdentifier":"/us/usc/t15/s657e/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs657e%2Fd%2F2","sourceRelease":"119-100","text":"work cooperatively with Mentoring Networks to maintain and update the database;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s657e/d/3","parentIdentifier":