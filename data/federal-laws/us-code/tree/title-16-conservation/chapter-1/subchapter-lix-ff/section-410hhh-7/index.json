ype":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410hhh–7/b/1/A","parentIdentifier":"/us/usc/t16/s410hhh–7/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the use, allocation, ownership, or control, in existence on , of any water, water right, or any other valid existing right;November 22, 2000","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410hhh–7/b/1/B","parentIdentifier":"/us/usc/t16/s410hhh–7/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fb%2F1%2FB","sourceRelease":"119-100","text":"any vested absolute or decreed conditional water right in existence on , including any water right held by the United States;November 22, 2000","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s410hhh–7/b/1/C","parentIdentifier":"/us/usc/t16/s410hhh–7/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fb%2F1%2FC","sourceRelease":"119-100","text":"any interstate water compact in existence on ; orNovember 22, 2000","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s410hhh–7/b/1/D","parentIdentifier":"/us/usc/t16/s410hhh–7/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fb%2F1%2FD","sourceRelease":"119-100","text":"subject to the provisions of paragraph (2), State jurisdiction over any water law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Water rights for national park and national preserve","label":"2 Water rights for national park and national preserve","identifier":"/us/usc/t16/s410hhh–7/b/2","parentIdentifier":"/us/usc/t16/s410hhh–7/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410hhh–7/b/2/A","parentIdentifier":"/us/usc/t16/s410hhh–7/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fb%2F2%2FA","sourceRelease":"119-100","text":"Such water rights shall be appropriated, adjudicated, changed, and administered pursuant to the procedural requirements and priority system of the laws of the State of Colorado.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410hhh–7/b/2/B","parentIdentifier":"/us/usc/t16/s410hhh–7/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fb%2F2%2FB","sourceRelease":"119-100","text":"The purposes and other substantive characteristics of such water rights shall be established pursuant to State law, except that the Secretary is specifically authorized to appropriate water under this subchapter exclusively for the purpose of maintaining ground water levels, surface water levels, and stream flows on, across, and under the national park and national preserve, in order to accomplish the purposes of the national park and the national preserve and to protect park resources and park uses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s410hhh–7/b/2/C","parentIdentifier":"/us/usc/t16/s410hhh–7/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fb%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s410hhh–7/b/2/C/i","parentIdentifier":"/us/usc/t16/s410hhh–7/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fb%2F2%2FC%2Fi","sourceRelease":"119-100","text":"any exercise of a water right in existence on , for a non-Federal purpose in the San Luis Valley, Colorado; andNovember 22, 2000","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s410hhh–7/b/2/C/ii","parentIdentifier":"/us/usc/t16/s410hhh–7/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fb%2F2%2FC%2Fii","sourceRelease":"119-100","text":"the Closed Basin Division, San Luis Valley Project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s410hhh–7/b/2/D","parentIdentifier":"/us/usc/t16/s410hhh–7/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fb%2F2%2FD","sourceRelease":"119-100","text":"Except as provided in subsections (c) and (d), no Federal reservation of water may be claimed or established for the national park or the national preserve.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"National Forest water rights","label":"c National Forest water rights","identifier":"/us/usc/t16/s410hhh–7/c","parentIdentifier":"/us/usc/t16/s410hhh–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410hhh–7/c/1","parentIdentifier":"/us/usc/t16/s410hhh–7/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fc%2F1","sourceRelease":"119-100","text":"be considered to be of equal use and value for the national preserve; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410hhh–7/c/2","parentIdentifier":"/us/usc/t16/s410hhh–7/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fc%2F2","sourceRelease":"119-100","text":"retain its priority and purpose when included in the national preserve.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"National Monument water rights","label":"d National Monument water rights","identifier":"/us/usc/t16/s410hhh–7/d","parentIdentifier":"/us/usc/t16/s410hhh–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410hhh–7/d/1","parentIdentifier":"/us/usc/t16/s410hhh–7/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fd%2F1","sourceRelease":"119-100","text":"be considered to be of equal use and value for the national park; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410hhh–7/d/2","parentIdentifier":"/us/usc/t16/s410hhh–7/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fd%2F2","sourceRelease":"119-100","text":"retain its priority and purpose when included in the national park.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Acquired water rights and water resources","label":"e Acquired water rights and water resources","identifier":"/us/usc/t16/s410hhh–7/e","parentIdentifier":"/us/usc/t16/s410hhh–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s410hhh–7/e/1","parentIdentifier":"/us/usc/t16/s410hhh–7/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410hhh–7/e/1/A","parentIdentifier":"/us/usc/t16/s410hhh–7/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fe%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s410hhh–7/e/1/A/i","parentIdentifier":"/us/usc/t16/s410hhh–7/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fe%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the national park;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s410hhh–7/e/1/A/ii","parentIdentifier":"/us/usc/t16/s410hhh–7/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fe%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the preserve;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s410hhh–7/e/1/A/iii","parentIdentifier":"/us/usc/t16/s410hhh–7/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fe%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"the national wildlife refuge; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s410hhh–7/e/1/A/iv","parentIdentifier":"/us/usc/t16/s410hhh–7/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fe%2F1%2FA%2Fiv","sourceRelease":"119-100","text":"the immediately surrounding areas of Alamosa or Saguache Counties, Colorado.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Use","label":"B .—Use","identifier":"/us/usc/t16/s410hhh–7/e/1/B","parentIdentifier":"/us/usc/t16/s410hhh–7/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fe%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s410hhh–7/e/1/B/i","parentIdentifier":"/us/usc/t16/s410hhh–7/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fe%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the protection of resources and values for the national monument, the national park, the preserve, or the wildlife refuge;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s410hhh–7/e/1/B/ii","parentIdentifier":"/us/usc/t16/s410hhh–7/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fe%2F1%2FB%2Fii","sourceRelease":"119-100","text":"fish and wildlife management and protection; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s410hhh–7/e/1/B/iii","parentIdentifier":"/us/usc/t16/s410hhh–7/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fe%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"irrigation necessary to protect water resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"State authority","label":"2 State authority","identifier":"/us/usc/t16/s410hhh–7/e/2","parentIdentifier":"/us/usc/t16/s410hhh–7/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Fe%2F2","sourceRelease":"119-100","text":"If, and to the extent that, water rights associated with the Luis Maria Baca Grant No. 4 are acquired, the use of those water rights shall be changed only in accordance with the laws of the State of Colorado.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Disposal","label":"f Disposal","identifier":"/us/usc/t16/s410hhh–7/f","parentIdentifier":"/us/usc/t16/s410hhh–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410hhh%E2%80%937%2Ff","sourceRelease":"119-100","text":"The Secretary is authorized to sell the water resources and related appurtenances and fixtures as the Secretary deems necessary to obtain the termination of obligations specified in the memorandum of water service agreement and the water service agreement between the Cabeza de Vaca Land and Cattle Company, LLC and the Baca Grande Water and Sanitation District, dated . Prior to the sale, the Secretary shall determine that the sale is not detrimental to the protection of the resources of Great Sand Dunes National Monument, Great Sand Dunes National Park, and Great Sand Dunes National Preserve, and the Baca National Wildlife Refuge, and that appropriate measures to provide for such protection are included in the sale.August 28, 1997","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
