{"type":"section","nativeType":"section","number":"16157","heading":"Demonstration","label":"16157 Demonstration","identifier":"/us/usc/t42/s16157","parentIdentifier":"/us/usc/t42/ch149/schVIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s16157/a","parentIdentifier":"/us/usc/t42/s16157","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16157/a/1","parentIdentifier":"/us/usc/t42/s16157/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F1","sourceRelease":"119-100","text":"involve using hydrogen and related products at existing facilities or installations, such as existing office buildings, military bases, vehicle fleet centers, transit bus authorities, or units of the National Park System;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16157/a/2","parentIdentifier":"/us/usc/t42/s16157/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F2","sourceRelease":"119-100","text":"depend on reliable power from hydrogen to carry out essential activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16157/a/3","parentIdentifier":"/us/usc/t42/s16157/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F3","sourceRelease":"119-100","text":"lead to the replication of hydrogen technologies and draw such technologies into the marketplace;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16157/a/4","parentIdentifier":"/us/usc/t42/s16157/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F4","sourceRelease":"119-100","text":"include vehicle, portable, and stationary demonstrations of fuel cell and hydrogen-based energy technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16157/a/5","parentIdentifier":"/us/usc/t42/s16157/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F5","sourceRelease":"119-100","text":"address the interdependency of demand for hydrogen fuel cell applications and hydrogen fuel infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s16157/a/6","parentIdentifier":"/us/usc/t42/s16157/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F6","sourceRelease":"119-100","text":"raise awareness of hydrogen technology among the public;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s16157/a/7","parentIdentifier":"/us/usc/t42/s16157/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F7","sourceRelease":"119-100","text":"facilitate identification of an optimum technology among competing alternatives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s16157/a/8","parentIdentifier":"/us/usc/t42/s16157/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F8","sourceRelease":"119-100","text":"address distributed generation using renewable sources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t42/s16157/a/9","parentIdentifier":"/us/usc/t42/s16157/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F9","sourceRelease":"119-100","text":"carry out demonstrations of evolving hydrogen and fuel cell technologies in national parks, remote island areas, and on Indian tribal land, as selected by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t42/s16157/a/10","parentIdentifier":"/us/usc/t42/s16157/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F10","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16157/a/10/A","parentIdentifier":"/us/usc/t42/s16157/a/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F10%2FA","sourceRelease":"119-100","text":"light-duty vehicles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16157/a/10/B","parentIdentifier":"/us/usc/t42/s16157/a/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F10%2FB","sourceRelease":"119-100","text":"heavy-duty vehicles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16157/a/10/C","parentIdentifier":"/us/usc/t42/s16157/a/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F10%2FC","sourceRelease":"119-100","text":"fleet vehicles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16157/a/10/D","parentIdentifier":"/us/usc/t42/s16157/a/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F10%2FD","sourceRelease":"119-100","text":"specialty industrial and farm vehicles; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16157/a/10/E","parentIdentifier":"/us/usc/t42/s16157/a/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F10%2FE","sourceRelease":"119-100","text":"commercial and residential portable, continuous, and backup electric power generation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t42/s16157/a/11","parentIdentifier":"/us/usc/t42/s16157/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F11","sourceRelease":"119-100","text":"in accordance with any code or standards developed in a region, fund prototype, pilot fleet, and infrastructure regional hydrogen supply corridors along the interstate highway system in varied climates across the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t42/s16157/a/12","parentIdentifier":"/us/usc/t42/s16157/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fa%2F12","sourceRelease":"119-100","text":"fund demonstration programs that explore the use of hydrogen blends, hybrid hydrogen, and hydrogen reformed from renewable agricultural fuels, including the use of hydrogen in hybrid electric, heavier duty, and advanced internal combustion-powered vehicles.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"System demonstrations","label":"b System demonstrations","identifier":"/us/usc/t42/s16157/b","parentIdentifier":"/us/usc/t42/s16157","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general1So in original. No par. (2) has been enacted.1","label":"1 In general1So in original. No par. (2) has been enacted.1","identifier":"/us/usc/t42/s16157/b/1","parentIdentifier":"/us/usc/t42/s16157/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16157/b/1/A","parentIdentifier":"/us/usc/t42/s16157/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16157/b/1/A/i","parentIdentifier":"/us/usc/t42/s16157/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"have as a primary goal the reduction of drive energy requirements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16157/b/1/A/ii","parentIdentifier":"/us/usc/t42/s16157/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"after 2010, add another research and development phase, as defined in subsection (c), including the vehicle and infrastructure partnerships developed under the learning demonstrations program concept of the Department; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16157/b/1/A/iii","parentIdentifier":"/us/usc/t42/s16157/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fb%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"are managed through an enhanced FreedomCAR program within the Department that encourages involvement in cost-shared projects by manufacturers and governments; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16157/b/1/B","parentIdentifier":"/us/usc/t42/s16157/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16157/b/1/B/i","parentIdentifier":"/us/usc/t42/s16157/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"incorporates renewable hydrogen production, off-grid electricity production, and fleet applications in industrial or commercial service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16157/b/1/B/ii","parentIdentifier":"/us/usc/t42/s16157/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"integrates energy or applications described in clause (i), such as stationary, portable, micro, and mobile fuel cells, into a high-density commercial or residential building complex or agricultural community; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16157/b/1/B/iii","parentIdentifier":"/us/usc/t42/s16157/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fb%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"is managed in cooperation with industry, State, tribal, and local governments, agricultural organizations, and nonprofit generators and distributors of electricity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Identification of new program requirements","label":"c Identification of new program requirements","identifier":"/us/usc/t42/s16157/c","parentIdentifier":"/us/usc/t42/s16157","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16157/c/1","parentIdentifier":"/us/usc/t42/s16157/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fc%2F1","sourceRelease":"119-100","text":"after 2008 for stationary and portable applications, and after 2010 for vehicles, identify new requirements that refine technological concepts, planning, and applications; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16157/c/2","parentIdentifier":"/us/usc/t42/s16157/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fc%2F2","sourceRelease":"119-100","text":"during the second phase of the learning demonstrations under subsection (b)(1)(A)(ii), redesign subsequent program work to incorporate those requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s16157/d","parentIdentifier":"/us/usc/t42/s16157","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16157/d/1","parentIdentifier":"/us/usc/t42/s16157/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fd%2F1","sourceRelease":"119-100","text":"$185,000,000 for fiscal year 2006;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16157/d/2","parentIdentifier":"/us/usc/t42/s16157/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fd%2F2","sourceRelease":"119-100","text":"$200,000,000 for fiscal year 2007;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16157/d/3","parentIdentifier":"/us/usc/t42/s16157/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fd%2F3","sourceRelease":"119-100","text":"$250,000,000 for fiscal year 2008;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16157/d/4","parentIdentifier":"/us/usc/t42/s16157/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fd%2F4","sourceRelease":"119-100","text":"$300,000,000 for fiscal year 2009;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16157/d/5","parentIdentifier":"/us/usc/t42/s16157/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fd%2F5","sourceRelease":"119-100","text":"$375,000,000 for fiscal year 2010; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s16157/d/6","parentIdentifier":"/us/usc/t42/s16157/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16157%2Fd%2F6","sourceRelease":"119-100","text":"such sums as are necessary for each of fiscal years 2011 through 2020.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
