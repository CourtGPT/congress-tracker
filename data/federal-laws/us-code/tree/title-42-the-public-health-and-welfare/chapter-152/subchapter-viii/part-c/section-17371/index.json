{"type":"section","nativeType":"section","number":"17371","heading":"Energy diplomacy and security within the Department of State","label":"17371 Energy diplomacy and security within the Department of State","identifier":"/us/usc/t42/s17371","parentIdentifier":"/us/usc/t42/ch152/schVIII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"State Department Coordinator for International Energy Affairs","label":"a State Department Coordinator for International Energy Affairs","identifier":"/us/usc/t42/s17371/a","parentIdentifier":"/us/usc/t42/s17371","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17371/a/1","parentIdentifier":"/us/usc/t42/s17371/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary of State should ensure that energy security is integrated into the core mission of the Department of State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Coordinator for International Energy Affairs","label":"2 Coordinator for International Energy Affairs","identifier":"/us/usc/t42/s17371/a/2","parentIdentifier":"/us/usc/t42/s17371/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17371/a/2/A","parentIdentifier":"/us/usc/t42/s17371/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fa%2F2%2FA","sourceRelease":"119-100","text":"representing the Secretary of State in interagency efforts to develop the international energy policy of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17371/a/2/B","parentIdentifier":"/us/usc/t42/s17371/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fa%2F2%2FB","sourceRelease":"119-100","text":"ensuring that analyses of the national security implications of global energy and environmental developments are reflected in the decision making process within the Department of State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17371/a/2/C","parentIdentifier":"/us/usc/t42/s17371/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fa%2F2%2FC","sourceRelease":"119-100","text":"incorporating energy security priorities into the activities of the Department of State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17371/a/2/D","parentIdentifier":"/us/usc/t42/s17371/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fa%2F2%2FD","sourceRelease":"119-100","text":"coordinating energy activities of the Department of State with relevant Federal agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17371/a/2/E","parentIdentifier":"/us/usc/t42/s17371/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fa%2F2%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17371/a/2/E/i","parentIdentifier":"/us/usc/t42/s17371/a/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fa%2F2%2FE%2Fi","sourceRelease":"119-100","text":"the Bureau of Economic, Energy and Business Affairs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17371/a/2/E/ii","parentIdentifier":"/us/usc/t42/s17371/a/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fa%2F2%2FE%2Fii","sourceRelease":"119-100","text":"the Bureau of Oceans and International Environmental and Scientific Affairs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s17371/a/2/E/iii","parentIdentifier":"/us/usc/t42/s17371/a/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fa%2F2%2FE%2Fiii","sourceRelease":"119-100","text":"other offices within the Department of State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Authorization of appropriations","label":"3 Authorization of appropriations","identifier":"/us/usc/t42/s17371/a/3","parentIdentifier":"/us/usc/t42/s17371/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fa%2F3","sourceRelease":"119-100","text":"There are authorized to be appropriated such sums as may be necessary to carry out this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Energy experts in key embassies","label":"b Energy experts in key embassies","identifier":"/us/usc/t42/s17371/b","parentIdentifier":"/us/usc/t42/s17371","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17371/b/1","parentIdentifier":"/us/usc/t42/s17371/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fb%2F1","sourceRelease":"119-100","text":"a description of the Department of State personnel who are dedicated to energy matters and are stationed at embassies and consulates in countries that are major energy producers or consumers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17371/b/2","parentIdentifier":"/us/usc/t42/s17371/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fb%2F2","sourceRelease":"119-100","text":"an analysis of the need for Federal energy specialist personnel in United States embassies and other United States diplomatic missions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17371/b/3","parentIdentifier":"/us/usc/t42/s17371/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fb%2F3","sourceRelease":"119-100","text":"recommendations for increasing energy expertise within United States embassies among foreign service officers and options for assigning to such embassies energy attachés from the National Laboratories or other agencies within the Department of Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Energy advisors","label":"c Energy advisors","identifier":"/us/usc/t42/s17371/c","parentIdentifier":"/us/usc/t42/s17371","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fc","sourceRelease":"119-100","text":"The Secretary of Energy may make appropriate arrangements with the Secretary of State to assign personnel from the Department of Energy or the National Laboratories of the Department of Energy to serve as dedicated advisors on energy matters in embassies of the United States or other United States diplomatic missions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Report","label":"d Report","identifier":"/us/usc/t42/s17371/d","parentIdentifier":"/us/usc/t42/s17371","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17371/d/1","parentIdentifier":"/us/usc/t42/s17371/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17371/d/1/A","parentIdentifier":"/us/usc/t42/s17371/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the Bureau of Economic, Energy and Business Affairs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17371/d/1/B","parentIdentifier":"/us/usc/t42/s17371/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fd%2F1%2FB","sourceRelease":"119-100","text":"the Bureau of Oceans and Environmental and Scientific Affairs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17371/d/1/C","parentIdentifier":"/us/usc/t42/s17371/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fd%2F1%2FC","sourceRelease":"119-100","text":"other offices within the Department of State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17371/d/2","parentIdentifier":"/us/usc/t42/s17371/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fd%2F2","sourceRelease":"119-100","text":"the amount of funds spent on each activity within each office described in paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17371/d/3","parentIdentifier":"/us/usc/t42/s17371/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17371%2Fd%2F3","sourceRelease":"119-100","text":"the number and qualification of personnel in each embassy (or relevant foreign posting) of the United States whose work is dedicated exclusively to energy matters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
