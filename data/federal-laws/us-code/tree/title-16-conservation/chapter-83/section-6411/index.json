{"type":"section","nativeType":"section","number":"6411","heading":"Coral reef research","label":"6411 Coral reef research","identifier":"/us/usc/t16/s6411","parentIdentifier":"/us/usc/t16/ch83","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Reef research coordination institutes","label":"a Reef research coordination institutes","identifier":"/us/usc/t16/s6411/a","parentIdentifier":"/us/usc/t16/s6411","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t16/s6411/a/1","parentIdentifier":"/us/usc/t16/s6411/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F1","sourceRelease":"119-100","text":"The Administrator shall designate 2 reef research coordination institutes for the purpose of advancing and sustaining essential capabilities in coral reef research, one each in the Atlantic and Pacific basins, to be known as the “Atlantic Reef Research Coordination Institute” and the “Pacific Reef Research Coordination Institute”, respectively.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Membership","label":"2 Membership","identifier":"/us/usc/t16/s6411/a/2","parentIdentifier":"/us/usc/t16/s6411/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F2","sourceRelease":"119-100","text":"Each institute designated under paragraph (1) shall be housed within a single coral reef research center designated by the Administrator under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Functions","label":"3 Functions","identifier":"/us/usc/t16/s6411/a/3","parentIdentifier":"/us/usc/t16/s6411/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6411/a/3/A","parentIdentifier":"/us/usc/t16/s6411/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3%2FA","sourceRelease":"119-100","text":"conduct federally directed research to fill national and regional coral reef ecosystem research gaps and improve understanding of, and responses to, continuing and emerging threats to the resilience of United States coral reef ecosystems consistent with the National Coral Reef Resilience Strategy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6411/a/3/B","parentIdentifier":"/us/usc/t16/s6411/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3%2FB","sourceRelease":"119-100","text":"support ecological research and monitoring to study the effects of conservation and restoration activities funded by this chapter on promoting more effective coral reef management and restoration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6411/a/3/C","parentIdentifier":"/us/usc/t16/s6411/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s6411/a/3/C/i","parentIdentifier":"/us/usc/t16/s6411/a/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3%2FC%2Fi","sourceRelease":"119-100","text":"collaborate directly with States, covered Native entities, covered coral reef managers, nonprofit organizations, and other coral reef research centers designated under subsection (b);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s6411/a/3/C/ii","parentIdentifier":"/us/usc/t16/s6411/a/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3%2FC%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s6411/a/3/C/ii/I","parentIdentifier":"/us/usc/t16/s6411/a/3/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3%2FC%2Fii%2FI","sourceRelease":"119-100","text":"the National Coral Reef Resilience Strategy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s6411/a/3/C/ii/II","parentIdentifier":"/us/usc/t16/s6411/a/3/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3%2FC%2Fii%2FII","sourceRelease":"119-100","text":"coral reef action plans under ;section 6404 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s6411/a/3/C/iii","parentIdentifier":"/us/usc/t16/s6411/a/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3%2FC%2Fiii","sourceRelease":"119-100","text":"build capacity within non-Federal governmental resource management agencies to establish research priorities and translate and apply research findings to management and restoration practices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s6411/a/3/C/iv","parentIdentifier":"/us/usc/t16/s6411/a/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3%2FC%2Fiv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s6411/a/3/C/iv/I","parentIdentifier":"/us/usc/t16/s6411/a/3/C/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3%2FC%2Fiv%2FI","sourceRelease":"119-100","text":"coral reefs and coral reef ecosystems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s6411/a/3/C/iv/II","parentIdentifier":"/us/usc/t16/s6411/a/3/C/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3%2FC%2Fiv%2FII","sourceRelease":"119-100","text":"best practices for coral reef ecosystem management and restoration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s6411/a/3/C/iv/III","parentIdentifier":"/us/usc/t16/s6411/a/3/C/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3%2FC%2Fiv%2FIII","sourceRelease":"119-100","text":"the value of coral reefs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t16/s6411/a/3/C/iv/IV","parentIdentifier":"/us/usc/t16/s6411/a/3/C/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fa%2F3%2FC%2Fiv%2FIV","sourceRelease":"119-100","text":"the threats to the sustainability of coral reef ecosystems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Coral reef research centers","label":"b Coral reef research centers","identifier":"/us/usc/t16/s6411/b","parentIdentifier":"/us/usc/t16/s6411","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s6411/b/1","parentIdentifier":"/us/usc/t16/s6411/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6411/b/1/A","parentIdentifier":"/us/usc/t16/s6411/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fb%2F1%2FA","sourceRelease":"119-100","text":"periodically solicit applications for designation of qualifying institutions in covered States as coral reef research centers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6411/b/1/B","parentIdentifier":"/us/usc/t16/s6411/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fb%2F1%2FB","sourceRelease":"119-100","text":"designate all qualifying institutions in covered States as coral reef research centers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Qualifying institutions","label":"2 Qualifying institutions","identifier":"/us/usc/t16/s6411/b/2","parentIdentifier":"/us/usc/t16/s6411/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6411/b/2/A","parentIdentifier":"/us/usc/t16/s6411/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fb%2F2%2FA","sourceRelease":"119-100","text":"is operated by an institution of higher education or nonprofit marine research organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6411/b/2/B","parentIdentifier":"/us/usc/t16/s6411/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fb%2F2%2FB","sourceRelease":"119-100","text":"has established management-driven national or regional coral reef research or restoration programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6411/b/2/C","parentIdentifier":"/us/usc/t16/s6411/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fb%2F2%2FC","sourceRelease":"119-100","text":"has demonstrated abilities to coordinate closely with appropriate Federal and State agencies, and other academic and nonprofit organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s6411/b/2/D","parentIdentifier":"/us/usc/t16/s6411/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6411%2Fb%2F2%2FD","sourceRelease":"119-100","text":"maintains significant local community engagement and outreach programs related to coral reef ecosystems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
