{"type":"section","nativeType":"section","number":"9007","heading":"Minority Business Development Agency","label":"9007 Minority Business Development Agency","identifier":"/us/usc/t15/s9007","parentIdentifier":"/us/usc/t15/ch116/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t15/s9007/a","parentIdentifier":"/us/usc/t15/s9007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9007/a/1","parentIdentifier":"/us/usc/t15/s9007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fa%2F1","sourceRelease":"119-100","text":"the term “Agency” means the Minority Business Development Agency of the Department of Commerce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9007/a/2","parentIdentifier":"/us/usc/t15/s9007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fa%2F2","sourceRelease":"119-100","text":"the term “minority business center” means a Business Center of the Agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s9007/a/3","parentIdentifier":"/us/usc/t15/s9007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9007/a/3/A","parentIdentifier":"/us/usc/t15/s9007/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fa%2F3%2FA","sourceRelease":"119-100","text":"not less than 51 percent of which is owned by 1 or more socially disadvantaged individuals, as determined by the Agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9007/a/3/B","parentIdentifier":"/us/usc/t15/s9007/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fa%2F3%2FB","sourceRelease":"119-100","text":"the management and daily business operations of which are controlled by 1 or more socially disadvantaged individuals, as determined by the Agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s9007/a/4","parentIdentifier":"/us/usc/t15/s9007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fa%2F4","sourceRelease":"119-100","text":"the term “minority chamber of commerce” means a chamber of commerce developed specifically to support minority business enterprises.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Education, training, and advising grants","label":"b Education, training, and advising grants","identifier":"/us/usc/t15/s9007/b","parentIdentifier":"/us/usc/t15/s9007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s9007/b/1","parentIdentifier":"/us/usc/t15/s9007/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F1","sourceRelease":"119-100","text":"The Agency may provide financial assistance in the form of grants to minority business centers and minority chambers of commerce to provide education, training, and advising to minority business enterprises.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Use of funds","label":"2 Use of funds","identifier":"/us/usc/t15/s9007/b/2","parentIdentifier":"/us/usc/t15/s9007/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9007/b/2/A","parentIdentifier":"/us/usc/t15/s9007/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F2%2FA","sourceRelease":"119-100","text":"accessing and applying for resources provided by the Agency and other Federal resources relating to access to capital and business resiliency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9007/b/2/B","parentIdentifier":"/us/usc/t15/s9007/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the hazards and prevention of the transmission and communication of COVID–19 and other communicable diseases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9007/b/2/C","parentIdentifier":"/us/usc/t15/s9007/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F2%2FC","sourceRelease":"119-100","text":"the potential effects of COVID–19 on the supply chains, distribution, and sale of products of minority business enterprises and the mitigation of those effects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s9007/b/2/D","parentIdentifier":"/us/usc/t15/s9007/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F2%2FD","sourceRelease":"119-100","text":"the management and practice of telework to reduce possible transmission of COVID–19;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s9007/b/2/E","parentIdentifier":"/us/usc/t15/s9007/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F2%2FE","sourceRelease":"119-100","text":"the management and practice of remote customer service by electronic or other means;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t15/s9007/b/2/F","parentIdentifier":"/us/usc/t15/s9007/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F2%2FF","sourceRelease":"119-100","text":"the risks of and mitigation of cyber threats in remote customer service or telework practices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t15/s9007/b/2/G","parentIdentifier":"/us/usc/t15/s9007/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F2%2FG","sourceRelease":"119-100","text":"the mitigation of the effects of reduced travel or outside activities on minority business enterprises during COVID–19 or similar occurrences; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t15/s9007/b/2/H","parentIdentifier":"/us/usc/t15/s9007/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F2%2FH","sourceRelease":"119-100","text":"any other relevant business practices necessary to mitigate the economic effects of COVID–19 or similar occurrences.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"No matching funds required","label":"3 No matching funds required","identifier":"/us/usc/t15/s9007/b/3","parentIdentifier":"/us/usc/t15/s9007/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F3","sourceRelease":"119-100","text":"Matching funds shall not be required for any grant under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Goals and metrics","label":"4 Goals and metrics","identifier":"/us/usc/t15/s9007/b/4","parentIdentifier":"/us/usc/t15/s9007/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s9007/b/4/A","parentIdentifier":"/us/usc/t15/s9007/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9007/b/4/A/i","parentIdentifier":"/us/usc/t15/s9007/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F4%2FA%2Fi","sourceRelease":"119-100","text":"take into consideration the extent of the circumstances relating to the spread of COVID–19, or similar occurrences, that affect minority business enterprises located in the areas covered by minority business centers and minority chambers of commerce, particularly in rural areas or economically distressed areas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9007/b/4/A/ii","parentIdentifier":"/us/usc/t15/s9007/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F4%2FA%2Fii","sourceRelease":"119-100","text":"generally follow the use of funds outlined in paragraph (2), but shall not restrict the activities of minority business centers and minority chambers of commerce in responding to unique situations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s9007/b/4/A/iii","parentIdentifier":"/us/usc/t15/s9007/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F4%2FA%2Fiii","sourceRelease":"119-100","text":"encourage minority business centers and minority chambers of commerce to develop and provide services to minority business enterprises.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Public availability","label":"B Public availability","identifier":"/us/usc/t15/s9007/b/4/B","parentIdentifier":"/us/usc/t15/s9007/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fb%2F4%2FB","sourceRelease":"119-100","text":"The Agency shall make publicly available the methodology by which the Agency, minority business centers, and minority chambers of commerce jointly develop the metrics and goals described in subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Waivers","label":"c Waivers","identifier":"/us/usc/t15/s9007/c","parentIdentifier":"/us/usc/t15/s9007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s9007/c/1","parentIdentifier":"/us/usc/t15/s9007/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fc%2F1","sourceRelease":"119-100","text":"Notwithstanding any other provision of law or regulation, the Agency may, during the 3-month period that begins on , waive any matching requirement imposed on a minority business center or a specialty center of the Agency under a cooperative agreement between such a center and the Agency if the applicable center is unable to raise funds, or has suffered a loss of revenue, because of the effects of COVID–19.March 27, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Remaining compliant","label":"2 Remaining compliant","identifier":"/us/usc/t15/s9007/c/2","parentIdentifier":"/us/usc/t15/s9007/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9007/c/2/A","parentIdentifier":"/us/usc/t15/s9007/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the center notifies the Agency with respect to that decision, which the center may provide through electronic mail; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9007/c/2/B","parentIdentifier":"/us/usc/t15/s9007/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9007/c/2/B/i","parentIdentifier":"/us/usc/t15/s9007/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"confirms receipt of the notification under subparagraph (A); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9007/c/2/B/ii","parentIdentifier":"/us/usc/t15/s9007/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"accepts the decision of the center.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Report","label":"d Report","identifier":"/us/usc/t15/s9007/d","parentIdentifier":"/us/usc/t15/s9007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9007/d/1","parentIdentifier":"/us/usc/t15/s9007/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9007/d/1/A","parentIdentifier":"/us/usc/t15/s9007/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the programs and services developed and provided by the Agency, minority business centers, and minority chambers of commerce under subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9007/d/1/B","parentIdentifier":"/us/usc/t15/s9007/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fd%2F1%2FB","sourceRelease":"119-100","text":"the initial efforts to provide those services under subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9007/d/2","parentIdentifier":"/us/usc/t15/s9007/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9007/d/2/A","parentIdentifier":"/us/usc/t15/s9007/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9007/d/2/A/i","parentIdentifier":"/us/usc/t15/s9007/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the efforts of the Agency, minority business centers, and minority chambers of commerce to develop services to assist minority business enterprises;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9007/d/2/A/ii","parentIdentifier":"/us/usc/t15/s9007/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the challenges faced by owners of minority business enterprises in accessing services provided by the Agency, minority business centers, and minority chambers of commerce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s9007/d/2/A/iii","parentIdentifier":"/us/usc/t15/s9007/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fd%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"the number of unique minority business enterprises that were served by the Agency, minority business centers, or minority chambers of commerce; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t15/s9007/d/2/A/iv","parentIdentifier":"/us/usc/t15/s9007/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fd%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"other relevant outcome performance data with respect to minority business enterprises, including the number of employees affected, the effect on sales, the disruptions of supply chains, and the efforts made by the Agency, minority business centers, and minority chambers of commerce to mitigate these effects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t15/s9007/e","parentIdentifier":"/us/usc/t15/s9007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9007%2Fe","sourceRelease":"119-100","text":"There is authorized to be appropriated $10,000,000 to carry out this section, to remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
