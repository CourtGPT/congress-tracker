{"type":"section","nativeType":"section","number":"5353","heading":"Information collection and dissemination with respect to grant recipients","label":"5353 Information collection and dissemination with respect to grant recipients","identifier":"/us/usc/t31/s5353","parentIdentifier":"/us/usc/t31/stIV/ch53/schIII/pt2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5353","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Applicant and Grantee Information.—","label":"a Applicant and Grantee Information.—","identifier":"/us/usc/t31/s5353/a","parentIdentifier":"/us/usc/t31/s5353","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5353%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Application process","label":"1 .—Application process","identifier":"/us/usc/t31/s5353/a/1","parentIdentifier":"/us/usc/t31/s5353/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5353%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary shall issue requests for proposal, as necessary, regarding, with respect to the grants awarded under section 5352, the application process, grant renewal, and suspension or withholding of renewal grants. Each application under this paragraph shall be in writing and shall be subject to review by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Reporting","label":"2 .—Reporting","identifier":"/us/usc/t31/s5353/a/2","parentIdentifier":"/us/usc/t31/s5353/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5353%2Fa%2F2","sourceRelease":"119-100","text":"The Secretary shall, to the maximum extent practicable and in a manner consistent with applicable law, minimize reporting requirements by a grant recipient and expedite any application for a renewal grant made under this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Activities of Secretary","label":"b .—Activities of Secretary","identifier":"/us/usc/t31/s5353/b","parentIdentifier":"/us/usc/t31/s5353","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5353%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t31/s5353/b/1","parentIdentifier":"/us/usc/t31/s5353/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5353%2Fb%2F1","sourceRelease":"119-100","text":"evaluate the utility of specific initiatives relating to the purposes of the program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t31/s5353/b/2","parentIdentifier":"/us/usc/t31/s5353/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5353%2Fb%2F2","sourceRelease":"119-100","text":"conduct an evaluation of the program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t31/s5353/b/3","parentIdentifier":"/us/usc/t31/s5353/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5353%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t31/s5353/b/3/A","parentIdentifier":"/us/usc/t31/s5353/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5353%2Fb%2F3%2FA","sourceRelease":"119-100","text":"eligible State local law enforcement agencies or prosecutors; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t31/s5353/b/3/B","parentIdentifier":"/us/usc/t31/s5353/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5353%2Fb%2F3%2FB","sourceRelease":"119-100","text":"the general public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
