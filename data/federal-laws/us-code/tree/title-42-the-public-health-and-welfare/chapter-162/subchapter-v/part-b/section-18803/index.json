onmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Data","label":"d Data","identifier":"/us/usc/t42/s18803/d","parentIdentifier":"/us/usc/t42/s18803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18803%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18803/d/1","parentIdentifier":"/us/usc/t42/s18803/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18803%2Fd%2F1","sourceRelease":"119-100","text":"is collected through the Portfolio Manager database of the Environmental Protection Agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18803/d/2","parentIdentifier":"/us/usc/t42/s18803/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18803%2Fd%2F2","sourceRelease":"119-100","text":"is required to be publicly available on the internet under State and local government building energy disclosure laws (including regulations); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18803/d/3","parentIdentifier":"/us/usc/t42/s18803/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18803%2Fd%2F3","sourceRelease":"119-100","text":"includes information on private sector buildings that are not less than 250,000 square feet.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Protection of information","label":"e Protection of information","identifier":"/us/usc/t42/s18803/e","parentIdentifier":"/us/usc/t42/s18803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18803%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18803/e/1","parentIdentifier":"/us/usc/t42/s18803/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18803%2Fe%2F1","sourceRelease":"119-100","text":"(commonly known as the “Freedom of Information Act”);section 552(b)(4) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18803/e/2","parentIdentifier":"/us/usc/t42/s18803/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18803%2Fe%2F2","sourceRelease":"119-100","text":"subchapter III of chapter 35 of title 44; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18803/e/3","parentIdentifier":"/us/usc/t42/s18803/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18803%2Fe%2F3","sourceRelease":"119-100","text":"any other applicable law (including regulations).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
