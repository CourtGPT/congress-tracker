{"type":"section","nativeType":"section","number":"152404","heading":"Officers and employees","label":"152404 Officers and employees","identifier":"/us/usc/t36/s152404","parentIdentifier":"/us/usc/t36/stII/ptB/ch1524","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152404","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe General Schedule, referred to in subsec. (d)(3), is set out under , Government Organization and Employees.section 5332 of Title 5"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Secretary of the Board","label":"a .—Secretary of the Board","identifier":"/us/usc/t36/s152404/a","parentIdentifier":"/us/usc/t36/s152404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152404%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t36/s152404/a/1","parentIdentifier":"/us/usc/t36/s152404/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152404%2Fa%2F1","sourceRelease":"119-100","text":"The Librarian shall appoint a Secretary of the Board to serve as executive director of the corporation. The Librarian may remove the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t36/s152404/a/2","parentIdentifier":"/us/usc/t36/s152404/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152404%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t36/s152404/a/2/A","parentIdentifier":"/us/usc/t36/s152404/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152404%2Fa%2F2%2FA","sourceRelease":"119-100","text":"sound recording preservation and restoration activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t36/s152404/a/2/B","parentIdentifier":"/us/usc/t36/s152404/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152404%2Fa%2F2%2FB","sourceRelease":"119-100","text":"financial management; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t36/s152404/a/2/C","parentIdentifier":"/us/usc/t36/s152404/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152404%2Fa%2F2%2FC","sourceRelease":"119-100","text":"fundraising.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Appointment of Officers","label":"b .—Appointment of Officers","identifier":"/us/usc/t36/s152404/b","parentIdentifier":"/us/usc/t36/s152404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152404%2Fb","sourceRelease":"119-100","text":"Except as provided in subsection (a) of this section, the board of directors appoints, removes, and replaces officers of the corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Appointment of Employees","label":"c .—Appointment of Employees","identifier":"/us/usc/t36/s152404/c","parentIdentifier":"/us/usc/t36/s152404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152404%2Fc","sourceRelease":"119-100","text":"Except as provided in subsection (a) of this section, the Secretary appoints, removes, and replaces employees of the corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Status and Compensation of Employees","label":"d .—Status and Compensation of Employees","identifier":"/us/usc/t36/s152404/d","parentIdentifier":"/us/usc/t36/s152404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152404%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t36/s152404/d/1","parentIdentifier":"/us/usc/t36/s152404/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152404%2Fd%2F1","sourceRelease":"119-100","text":"are not employees of the Library of Congress;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t36/s152404/d/2","parentIdentifier":"/us/usc/t36/s152404/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152404%2Fd%2F2","sourceRelease":"119-100","text":"shall be appointed and removed without regard to the provisions of title 5 governing appointments in the competitive service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t36/s152404/d/3","parentIdentifier":"/us/usc/t36/s152404/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152404%2Fd%2F3","sourceRelease":"119-100","text":"may be paid without regard to chapter 51 and subchapter III of chapter 53 of title 5, except that an employee may not be paid more than the annual rate of basic pay for level 15 of the General Schedule under .section 5107 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
