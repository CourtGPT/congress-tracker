{"type":"section","nativeType":"section","number":"15928","heading":"Consultation regarding energy rights-of-way on public land","label":"15928 Consultation regarding energy rights-of-way on public land","identifier":"/us/usc/t42/s15928","parentIdentifier":"/us/usc/t42/ch149/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Memorandum of understanding","label":"a Memorandum of understanding","identifier":"/us/usc/t42/s15928/a","parentIdentifier":"/us/usc/t42/s15928","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s15928/a/1","parentIdentifier":"/us/usc/t42/s15928/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fa%2F1","sourceRelease":"119-100","text":"Not later than 6 months after , the Secretary of Energy, in consultation with the Secretary of the Interior, the Secretary of Agriculture, and the Secretary of Defense with respect to lands under their respective jurisdictions, shall enter into a memorandum of understanding to coordinate all applicable Federal authorizations and environmental reviews relating to a proposed or existing utility facility. To the maximum extent practicable under applicable law, the Secretary of Energy shall, to ensure timely review and permit decisions, coordinate such authorizations and reviews with any Indian tribes, multi-State entities, and State agencies that are responsible for conducting any separate permitting and environmental reviews of the affected utility facility.August 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t42/s15928/a/2","parentIdentifier":"/us/usc/t42/s15928/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15928/a/2/A","parentIdentifier":"/us/usc/t42/s15928/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s15928/a/2/A/i","parentIdentifier":"/us/usc/t42/s15928/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"a unified right-of-way application form; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s15928/a/2/A/ii","parentIdentifier":"/us/usc/t42/s15928/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"an administrative procedure for processing right-of-way applications, including lines of authority, steps in application processing, and timeframes for application processing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15928/a/2/B","parentIdentifier":"/us/usc/t42/s15928/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fa%2F2%2FB","sourceRelease":"119-100","text":"provide for coordination of planning relating to the granting of the rights-of-way;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s15928/a/2/C","parentIdentifier":"/us/usc/t42/s15928/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fa%2F2%2FC","sourceRelease":"119-100","text":"provide for an agreement among the affected Federal agencies to prepare a single environmental review document to be used as the basis for all Federal authorization decisions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s15928/a/2/D","parentIdentifier":"/us/usc/t42/s15928/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fa%2F2%2FD","sourceRelease":"119-100","text":"provide for coordination of use of right-of-way stipulations to achieve consistency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Natural gas pipelines","label":"b Natural gas pipelines","identifier":"/us/usc/t42/s15928/b","parentIdentifier":"/us/usc/t42/s15928","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s15928/b/1","parentIdentifier":"/us/usc/t42/s15928/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fb%2F1","sourceRelease":"119-100","text":"With respect to permitting activities for interstate natural gas pipelines, the May 2002 document entitled “Interagency Agreement On Early Coordination Of Required Environmental And Historic Preservation Reviews Conducted In Conjunction With The Issuance Of Authorizations To Construct And Operate Interstate Natural Gas Pipelines Certificated By The Federal Energy Regulatory Commission” shall constitute compliance with subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report","label":"2 Report","identifier":"/us/usc/t42/s15928/b/2","parentIdentifier":"/us/usc/t42/s15928/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s15928/b/2/A","parentIdentifier":"/us/usc/t42/s15928/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fb%2F2%2FA","sourceRelease":"119-100","text":"Not later than 1 year after , and every 2 years thereafter, agencies that are signatories to the document referred to in paragraph (1) shall transmit to Congress a report on how the agencies under the jurisdiction of the Secretaries are incorporating and implementing the provisions of the document referred to in paragraph (1).August 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Contents","label":"B Contents","identifier":"/us/usc/t42/s15928/b/2/B","parentIdentifier":"/us/usc/t42/s15928/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s15928/b/2/B/i","parentIdentifier":"/us/usc/t42/s15928/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"efforts to implement the provisions of the document referred to in paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s15928/b/2/B/ii","parentIdentifier":"/us/usc/t42/s15928/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"whether the efforts have had a streamlining effect;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s15928/b/2/B/iii","parentIdentifier":"/us/usc/t42/s15928/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"further improvements to the permitting process of the agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s15928/b/2/B/iv","parentIdentifier":"/us/usc/t42/s15928/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fb%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"recommendations for inclusion of State and tribal governments in a coordinated permitting process.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Definition of utility facility","label":"c Definition of utility facility","identifier":"/us/usc/t42/s15928/c","parentIdentifier":"/us/usc/t42/s15928","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15928/c/1","parentIdentifier":"/us/usc/t42/s15928/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15928/c/1/A","parentIdentifier":"/us/usc/t42/s15928/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fc%2F1%2FA","sourceRelease":"119-100","text":"oil, natural gas, synthetic liquid fuel, or gaseous fuel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15928/c/1/B","parentIdentifier":"/us/usc/t42/s15928/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fc%2F1%2FB","sourceRelease":"119-100","text":"any refined product produced from oil, natural gas, synthetic liquid fuel, or gaseous fuel; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s15928/c/1/C","parentIdentifier":"/us/usc/t42/s15928/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fc%2F1%2FC","sourceRelease":"119-100","text":"products in support of the production of material referred to in subparagraph (A) or (B);","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15928/c/2","parentIdentifier":"/us/usc/t42/s15928/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fc%2F2","sourceRelease":"119-100","text":"for storage and terminal facilities in connection with the production of material referred to in paragraph (1); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s15928/c/3","parentIdentifier":"/us/usc/t42/s15928/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15928%2Fc%2F3","sourceRelease":"119-100","text":"for the generation, transmission, and distribution of electric energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
