{"type":"section","nativeType":"section","number":"5352","heading":"Delivery of Congressional Pictorial Directory","label":"5352 Delivery of Congressional Pictorial Directory","identifier":"/us/usc/t2/s5352","parentIdentifier":"/us/usc/t2/ch53/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs5352","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t2/s5352/a","parentIdentifier":"/us/usc/t2/s5352","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs5352%2Fa","sourceRelease":"119-100","text":"None of the funds made available in any fiscal year may be used to deliver a printed copy of the Congressional Pictorial Directory to the office of a Member of the House of Representatives (including a Delegate or Resident Commissioner to the Congress).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t2/s5352/b","parentIdentifier":"/us/usc/t2/s5352","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs5352%2Fb","sourceRelease":"119-100","text":"This section shall apply with respect to fiscal year 2019 and each succeeding fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
