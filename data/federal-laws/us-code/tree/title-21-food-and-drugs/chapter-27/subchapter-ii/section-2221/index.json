{"type":"section","nativeType":"section","number":"2221","heading":"Food emergency response network","label":"2221 Food emergency response network","identifier":"/us/usc/t21/s2221","parentIdentifier":"/us/usc/t21/ch27/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2221","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe Secretary, referred to in text, probably means the Secretary of Health and Human Services."],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s2221/1","parentIdentifier":"/us/usc/t21/s2221","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2221%2F1","sourceRelease":"119-100","text":"provides ongoing surveillance, rapid detection, and surge capacity for large-scale food-related emergencies, including intentional adulteration of the food supply;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s2221/2","parentIdentifier":"/us/usc/t21/s2221","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2221%2F2","sourceRelease":"119-100","text":"coordinates the food laboratory capacities of State, local, and tribal food laboratories, including the adoption of novel surveillance and identification technologies and the sharing of data between Federal agencies and State laboratories to develop national situational awareness;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t21/s2221/3","parentIdentifier":"/us/usc/t21/s2221","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2221%2F3","sourceRelease":"119-100","text":"provides accessible, timely, accurate, and consistent food laboratory services throughout the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t21/s2221/4","parentIdentifier":"/us/usc/t21/s2221","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2221%2F4","sourceRelease":"119-100","text":"develops and implements a methods repository for use by Federal, State, and local officials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t21/s2221/5","parentIdentifier":"/us/usc/t21/s2221","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2221%2F5","sourceRelease":"119-100","text":"responds to food-related emergencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t21/s2221/6","parentIdentifier":"/us/usc/t21/s2221","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2221%2F6","sourceRelease":"119-100","text":"is integrated with relevant laboratory networks administered by other Federal agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
