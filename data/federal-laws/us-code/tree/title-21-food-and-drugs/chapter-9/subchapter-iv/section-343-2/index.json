{"type":"section","nativeType":"section","number":"343–2","heading":"Dietary supplement labeling exemptions","label":"343–2 Dietary supplement labeling exemptions","identifier":"/us/usc/t21/s343–2","parentIdentifier":"/us/usc/t21/ch9/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs343%E2%80%932","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t21/s343–2/a","parentIdentifier":"/us/usc/t21/s343–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs343%E2%80%932%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s343–2/a/1","parentIdentifier":"/us/usc/t21/s343–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs343%E2%80%932%2Fa%2F1","sourceRelease":"119-100","text":"is not false or misleading;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s343–2/a/2","parentIdentifier":"/us/usc/t21/s343–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs343%E2%80%932%2Fa%2F2","sourceRelease":"119-100","text":"does not promote a particular manufacturer or brand of a dietary supplement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t21/s343–2/a/3","parentIdentifier":"/us/usc/t21/s343–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs343%E2%80%932%2Fa%2F3","sourceRelease":"119-100","text":"is displayed or presented, or is displayed or presented with other such items on the same subject matter, so as to present a balanced view of the available scientific information on a dietary supplement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t21/s343–2/a/4","parentIdentifier":"/us/usc/t21/s343–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs343%E2%80%932%2Fa%2F4","sourceRelease":"119-100","text":"if displayed in an establishment, is physically separate from the dietary supplements; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t21/s343–2/a/5","parentIdentifier":"/us/usc/t21/s343–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs343%E2%80%932%2Fa%2F5","sourceRelease":"119-100","text":"does not have appended to it any information by sticker or any other method.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Application","label":"b Application","identifier":"/us/usc/t21/s343–2/b","parentIdentifier":"/us/usc/t21/s343–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs343%E2%80%932%2Fb","sourceRelease":"119-100","text":"Subsection (a) shall not apply to or restrict a retailer or wholesaler of dietary supplements in any way whatsoever in the sale of books or other publications as a part of the business of such retailer or wholesaler.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Burden of proof","label":"c Burden of proof","identifier":"/us/usc/t21/s343–2/c","parentIdentifier":"/us/usc/t21/s343–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs343%E2%80%932%2Fc","sourceRelease":"119-100","text":"In any proceeding brought under subsection (a), the burden of proof shall be on the United States to establish that an article or other such matter is false or misleading.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
