{"type":"section","nativeType":"section","number":"9672","heading":"Additionality and avoidance of market distortion","label":"9672 Additionality and avoidance of market distortion","identifier":"/us/usc/t22/s9672","parentIdentifier":"/us/usc/t22/ch103/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9672","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s9672/a","parentIdentifier":"/us/usc/t22/s9672","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9672%2Fa","sourceRelease":"119-100","text":"Before the Corporation provides support for a project under subchapter II of this chapter, the Corporation shall ensure that private sector entities are afforded an opportunity to support the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Safeguards, policies, and guidelines","label":"b Safeguards, policies, and guidelines","identifier":"/us/usc/t22/s9672/b","parentIdentifier":"/us/usc/t22/s9672","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9672%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9672/b/1","parentIdentifier":"/us/usc/t22/s9672/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9672%2Fb%2F1","sourceRelease":"119-100","text":"supplements and encourages, but does not compete with, private sector support;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9672/b/2","parentIdentifier":"/us/usc/t22/s9672/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9672%2Fb%2F2","sourceRelease":"119-100","text":"operates according to internationally recognized best practices and standards with respect to ensuring the avoidance of market distorting government subsidies and the crowding out of private sector lending; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s9672/b/3","parentIdentifier":"/us/usc/t22/s9672/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9672%2Fb%2F3","sourceRelease":"119-100","text":"does not have a significant adverse impact on United States employment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
