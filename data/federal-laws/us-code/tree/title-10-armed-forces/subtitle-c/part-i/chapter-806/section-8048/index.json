{"type":"section","nativeType":"section","number":"8048","heading":"Medical Officer of the Marine Corps","label":"8048 Medical Officer of the Marine Corps","identifier":"/us/usc/t10/s8048","parentIdentifier":"/us/usc/t10/stC/ptI/ch806","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8048","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t10/s8048/a","parentIdentifier":"/us/usc/t10/s8048","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8048%2Fa","sourceRelease":"119-100","text":"There is a Medical Officer of the Marine Corps who shall be appointed from among flag officers of the Navy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t10/s8048/b","parentIdentifier":"/us/usc/t10/s8048","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8048%2Fb","sourceRelease":"119-100","text":"The Medical Officer of the Marine Corps, while so serving, shall hold the grade of rear admiral (lower half).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
