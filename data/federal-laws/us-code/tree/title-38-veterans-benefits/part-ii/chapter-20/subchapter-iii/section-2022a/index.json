rganizations as the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Eligible Entities","label":"c .—Eligible Entities","identifier":"/us/usc/t38/s2022A/c","parentIdentifier":"/us/usc/t38/s2022A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s2022A/c/1","parentIdentifier":"/us/usc/t38/s2022A/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fc%2F1","sourceRelease":"119-100","text":"is a public or nonprofit private entity with the capacity (as determined by the Secretary) to effectively administer a grant under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s2022A/c/2","parentIdentifier":"/us/usc/t38/s2022A/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fc%2F2","sourceRelease":"119-100","text":"demonstrates that adequate financial support will be available to carry out the services for which the grant is sought consistent with the application;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s2022A/c/3","parentIdentifier":"/us/usc/t38/s2022A/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fc%2F3","sourceRelease":"119-100","text":"agrees to meet the applicable criteria and requirements established under subsection (b)(1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s2022A/c/4","parentIdentifier":"/us/usc/t38/s2022A/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fc%2F4","sourceRelease":"119-100","text":"has, as determined by the Secretary, demonstrated the capacity to meet such criteria and requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Use of Funds","label":"d .—Use of Funds","identifier":"/us/usc/t38/s2022A/d","parentIdentifier":"/us/usc/t38/s2022A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s2022A/d/1","parentIdentifier":"/us/usc/t38/s2022A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fd%2F1","sourceRelease":"119-100","text":"Legal services relating to housing, including eviction defense, representation in landlord-tenant cases, and representation in foreclosure cases.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s2022A/d/2","parentIdentifier":"/us/usc/t38/s2022A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fd%2F2","sourceRelease":"119-100","text":"Legal services relating to family law, including assistance in court proceedings for child support, divorce, estate planning, and family reconciliation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s2022A/d/3","parentIdentifier":"/us/usc/t38/s2022A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fd%2F3","sourceRelease":"119-100","text":"Legal services relating to income support, including assistance in obtaining public benefits.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s2022A/d/4","parentIdentifier":"/us/usc/t38/s2022A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fd%2F4","sourceRelease":"119-100","text":"Legal services relating to criminal defense, including defense in matters symptomatic of homelessness, such as outstanding warrants, fines, and driver’s license revocation, to reduce recidivism and facilitate the overcoming of reentry obstacles in employment or housing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t38/s2022A/d/5","parentIdentifier":"/us/usc/t38/s2022A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fd%2F5","sourceRelease":"119-100","text":"Legal services relating to requests to upgrade the characterization of a discharge or dismissal of a former member of the Armed Forces under .section 1553 of title 10","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t38/s2022A/d/6","parentIdentifier":"/us/usc/t38/s2022A/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fd%2F6","sourceRelease":"119-100","text":"Such other legal services as the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Funds for Women Veterans","label":"e .—Funds for Women Veterans","identifier":"/us/usc/t38/s2022A/e","parentIdentifier":"/us/usc/t38/s2022A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fe","sourceRelease":"119-100","text":"For any fiscal year, not less than 10 percent of the amount authorized to be appropriated for grants under this section shall be used to provide legal services described in subsection (d) to women veterans.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Locations","label":"f .—Locations","identifier":"/us/usc/t38/s2022A/f","parentIdentifier":"/us/usc/t38/s2022A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s2022A/f/1","parentIdentifier":"/us/usc/t38/s2022A/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Ff%2F1","sourceRelease":"119-100","text":"rural communities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s2022A/f/2","parentIdentifier":"/us/usc/t38/s2022A/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Ff%2F2","sourceRelease":"119-100","text":"trust lands (as defined in );section 3765 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s2022A/f/3","parentIdentifier":"/us/usc/t38/s2022A/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Ff%2F3","sourceRelease":"119-100","text":"Native Americans; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s2022A/f/4","parentIdentifier":"/us/usc/t38/s2022A/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Ff%2F4","sourceRelease":"119-100","text":"tribal organizations (as defined in section 4 of the Indian Self-Determination and Education Assistance Act ()).25 U.S.C. 5304","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":".—Biennial Reports","label":"g .—Biennial Reports","identifier":"/us/usc/t38/s2022A/g","parentIdentifier":"/us/usc/t38/s2022A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s2022A/g/1","parentIdentifier":"/us/usc/t38/s2022A/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fg%2F1","sourceRelease":"119-100","text":"Not less frequently than once every two years, the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report on grants awarded under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s2022A/g/2","parentIdentifier":"/us/usc/t38/s2022A/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fg%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s2022A/g/2/A","parentIdentifier":"/us/usc/t38/s2022A/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs2022A%2Fg%2F2%2FA"