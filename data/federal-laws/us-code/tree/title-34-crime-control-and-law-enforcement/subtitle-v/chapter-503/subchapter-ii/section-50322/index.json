{"type":"section","nativeType":"section","number":"50322","heading":"Nominations","label":"50322 Nominations","identifier":"/us/usc/t34/s50322","parentIdentifier":"/us/usc/t34/stV/ch503/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to , The Public Health and Welfare, prior to editorial reclassification and renumbering as this section.section 15252 of Title 42"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t34/s50322/a","parentIdentifier":"/us/usc/t34/s50322","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s50322/a/1","parentIdentifier":"/us/usc/t34/s50322/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fa%2F1","sourceRelease":"119-100","text":"who is a State or local law enforcement officer working within the agency of the State or local agency head making the nomination; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s50322/a/2","parentIdentifier":"/us/usc/t34/s50322/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50322/a/2/A","parentIdentifier":"/us/usc/t34/s50322/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s50322/a/2/A/i","parentIdentifier":"/us/usc/t34/s50322/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t34/s50322/a/2/A/i/I","parentIdentifier":"/us/usc/t34/s50322/a/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fa%2F2%2FA%2Fi%2FI","sourceRelease":"119-100","text":"engaged in the lawful duties of the individual; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t34/s50322/a/2/A/i/II","parentIdentifier":"/us/usc/t34/s50322/a/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fa%2F2%2FA%2Fi%2FII","sourceRelease":"119-100","text":"performing an act characterized as bravery by the State or local agency head making the nomination; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s50322/a/2/A/ii","parentIdentifier":"/us/usc/t34/s50322/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"put the individual at personal risk when the injury described in clause (i) occurred; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50322/a/2/B","parentIdentifier":"/us/usc/t34/s50322/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fa%2F2%2FB","sourceRelease":"119-100","text":"while not injured, performed an act characterized as bravery by the State or local agency head making the nomination that placed the individual at risk of serious physical injury or death.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Contents","label":"b Contents","identifier":"/us/usc/t34/s50322/b","parentIdentifier":"/us/usc/t34/s50322","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s50322/b/1","parentIdentifier":"/us/usc/t34/s50322/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fb%2F1","sourceRelease":"119-100","text":"a written narrative, of not more than 2 pages, describing the circumstances under which the nominee performed the act of bravery described in subsection (a) and how the circumstances meet the criteria described in such subsection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s50322/b/2","parentIdentifier":"/us/usc/t34/s50322/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fb%2F2","sourceRelease":"119-100","text":"the full name of the nominee;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s50322/b/3","parentIdentifier":"/us/usc/t34/s50322/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fb%2F3","sourceRelease":"119-100","text":"the home mailing address of the nominee;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t34/s50322/b/4","parentIdentifier":"/us/usc/t34/s50322/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fb%2F4","sourceRelease":"119-100","text":"the agency in which the nominee served on the date when such nominee performed the act of bravery described in subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t34/s50322/b/5","parentIdentifier":"/us/usc/t34/s50322/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fb%2F5","sourceRelease":"119-100","text":"the occupational title and grade or rank of the nominee;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t34/s50322/b/6","parentIdentifier":"/us/usc/t34/s50322/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fb%2F6","sourceRelease":"119-100","text":"the field office address of the nominee on the date when such nominee performed the act of bravery described in subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t34/s50322/b/7","parentIdentifier":"/us/usc/t34/s50322/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fb%2F7","sourceRelease":"119-100","text":"the number of years of government service by the nominee as of the date when such nominee performed the act of bravery described in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Submission deadline","label":"c Submission deadline","identifier":"/us/usc/t34/s50322/c","parentIdentifier":"/us/usc/t34/s50322","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50322%2Fc","sourceRelease":"119-100","text":"A State or local agency head shall submit each nomination under subsection (a) to the Office not later than February 15 of the year following the date on which the nominee performed the act of bravery described in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
