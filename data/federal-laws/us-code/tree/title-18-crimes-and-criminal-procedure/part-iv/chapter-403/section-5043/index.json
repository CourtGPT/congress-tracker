{"type":"section","nativeType":"section","number":"5043","heading":"Juvenile solitary confinement","label":"5043 Juvenile solitary confinement","identifier":"/us/usc/t18/s5043","parentIdentifier":"/us/usc/t18/ptIV/ch403","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Definitions","label":"a .—Definitions","identifier":"/us/usc/t18/s5043/a","parentIdentifier":"/us/usc/t18/s5043","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s5043/a/1","parentIdentifier":"/us/usc/t18/s5043/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s5043/a/1/A","parentIdentifier":"/us/usc/t18/s5043/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t18/s5043/a/1/A/i","parentIdentifier":"/us/usc/t18/s5043/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"is being proceeded against under this chapter for an alleged act of juvenile delinquency; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t18/s5043/a/1/A/ii","parentIdentifier":"/us/usc/t18/s5043/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"has been adjudicated delinquent under this chapter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s5043/a/1/B","parentIdentifier":"/us/usc/t18/s5043/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fa%2F1%2FB","sourceRelease":"119-100","text":"a juvenile who is being proceeded against as an adult in a district court of the United States for an alleged criminal offense;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s5043/a/2","parentIdentifier":"/us/usc/t18/s5043/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s5043/a/2/A","parentIdentifier":"/us/usc/t18/s5043/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fa%2F2%2FA","sourceRelease":"119-100","text":"committed pursuant to an adjudication of delinquency under this chapter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s5043/a/2/B","parentIdentifier":"/us/usc/t18/s5043/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fa%2F2%2FB","sourceRelease":"119-100","text":"detained prior to disposition or conviction; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s5043/a/3","parentIdentifier":"/us/usc/t18/s5043/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fa%2F3","sourceRelease":"119-100","text":"the term “room confinement” means the involuntary placement of a covered juvenile alone in a cell, room, or other area for any reason.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Prohibition on Room Confinement in Juvenile Facilities.—","label":"b Prohibition on Room Confinement in Juvenile Facilities.—","identifier":"/us/usc/t18/s5043/b","parentIdentifier":"/us/usc/t18/s5043","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t18/s5043/b/1","parentIdentifier":"/us/usc/t18/s5043/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F1","sourceRelease":"119-100","text":"The use of room confinement at a juvenile facility for discipline, punishment, retaliation, or any reason other than as a temporary response to a covered juvenile’s behavior that poses a serious and immediate risk of physical harm to any individual, including the covered juvenile, is prohibited.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Juveniles posing risk of harm.—","label":"2 Juveniles posing risk of harm.—","identifier":"/us/usc/t18/s5043/b/2","parentIdentifier":"/us/usc/t18/s5043/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Requirement to use least restrictive techniques.—","label":"A Requirement to use least restrictive techniques.—","identifier":"/us/usc/t18/s5043/b/2/A","parentIdentifier":"/us/usc/t18/s5043/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":".—In general","label":"i .—In general","identifier":"/us/usc/t18/s5043/b/2/A/i","parentIdentifier":"/us/usc/t18/s5043/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t18/s5043/b/2/A/i/I","parentIdentifier":"/us/usc/t18/s5043/b/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FA%2Fi%2FI","sourceRelease":"119-100","text":"talking with the covered juvenile in an attempt to de-escalate the situation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t18/s5043/b/2/A/i/II","parentIdentifier":"/us/usc/t18/s5043/b/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FA%2Fi%2FII","sourceRelease":"119-100","text":"permitting a qualified mental health professional to talk to the covered juvenile.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":".—Explanation","label":"ii .—Explanation","identifier":"/us/usc/t18/s5043/b/2/A/ii","parentIdentifier":"/us/usc/t18/s5043/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t18/s5043/b/2/A/ii/I","parentIdentifier":"/us/usc/t18/s5043/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FA%2Fii%2FI","sourceRelease":"119-100","text":"explain to the covered juvenile the reasons for the room confinement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t18/s5043/b/2/A/ii/II","parentIdentifier":"/us/usc/t18/s5043/b/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FA%2Fii%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t18/s5043/b/2/A/ii/II/aa","parentIdentifier":"/us/usc/t18/s5043/b/2/A/ii/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FA%2Fii%2FII%2Faa","sourceRelease":"119-100","text":"immediately when the covered juvenile regains self-control, as described in subparagraph (B)(i); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t18/s5043/b/2/A/ii/II/bb","parentIdentifier":"/us/usc/t18/s5043/b/2/A/ii/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FA%2Fii%2FII%2Fbb","sourceRelease":"119-100","text":"not later than after the expiration of the time period described in subclause (I) or (II) of subparagraph (B)(ii), as applicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Maximum period of confinement","label":"B .—Maximum period of confinement","identifier":"/us/usc/t18/s5043/b/2/B","parentIdentifier":"/us/usc/t18/s5043/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t18/s5043/b/2/B/i","parentIdentifier":"/us/usc/t18/s5043/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"immediately when the covered juvenile has sufficiently gained control so as to no longer engage in behavior that threatens serious and immediate risk of physical harm to himself or herself, or to others; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t18/s5043/b/2/B/ii","parentIdentifier":"/us/usc/t18/s5043/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t18/s5043/b/2/B/ii/I","parentIdentifier":"/us/usc/t18/s5043/b/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FB%2Fii%2FI","sourceRelease":"119-100","text":"3 hours after being placed in room confinement, in the case of a covered juvenile who poses a serious and immediate risk of physical harm to others; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t18/s5043/b/2/B/ii/II","parentIdentifier":"/us/usc/t18/s5043/b/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FB%2Fii%2FII","sourceRelease":"119-100","text":"30 minutes after being placed in room confinement, in the case of a covered juvenile who poses a serious and immediate risk of physical harm only to himself or herself.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":".—Risk of harm after maximum period of confinement","label":"C .—Risk of harm after maximum period of confinement","identifier":"/us/usc/t18/s5043/b/2/C","parentIdentifier":"/us/usc/t18/s5043/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t18/s5043/b/2/C/i","parentIdentifier":"/us/usc/t18/s5043/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FC%2Fi","sourceRelease":"119-100","text":"the covered juvenile shall be transferred to another juvenile facility or internal location where services can be provided to the covered juvenile without relying on room confinement; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t18/s5043/b/2/C/ii","parentIdentifier":"/us/usc/t18/s5043/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FC%2Fii","sourceRelease":"119-100","text":"if a qualified mental health professional believes the level of crisis service needed is not currently available, a staff member of the juvenile facility shall initiate a referral to a location that can meet the needs of the covered juvenile.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":".—Spirit and purpose","label":"D .—Spirit and purpose","identifier":"/us/usc/t18/s5043/b/2/D","parentIdentifier":"/us/usc/t18/s5043/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs5043%2Fb%2F2%2FD","sourceRelease":"119-100","text":"The use of consecutive periods of room confinement to evade the spirit and purpose of this subsection shall be prohibited.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
