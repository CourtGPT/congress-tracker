{"type":"section","nativeType":"section","number":"1121","heading":"Killing persons aiding Federal investigations or State correctional officers","label":"1121 Killing persons aiding Federal investigations or State correctional officers","identifier":"/us/usc/t18/s1121","parentIdentifier":"/us/usc/t18/ptI/ch51","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments1996—Subsec. (c). added subsec. (c).Pub. L. 104–294"],"amendments":["Amendments1996—Subsec. (c). added subsec. (c).Pub. L. 104–294"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t18/s1121/a","parentIdentifier":"/us/usc/t18/s1121","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s1121/a/1","parentIdentifier":"/us/usc/t18/s1121/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s1121/a/1/A","parentIdentifier":"/us/usc/t18/s1121/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121%2Fa%2F1%2FA","sourceRelease":"119-100","text":"while the victim is engaged in the performance of official duties;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s1121/a/1/B","parentIdentifier":"/us/usc/t18/s1121/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121%2Fa%2F1%2FB","sourceRelease":"119-100","text":"because of the performance of the victim’s official duties; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t18/s1121/a/1/C","parentIdentifier":"/us/usc/t18/s1121/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121%2Fa%2F1%2FC","sourceRelease":"119-100","text":"because of the victim’s status as a public servant; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s1121/a/2","parentIdentifier":"/us/usc/t18/s1121/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121%2Fa%2F2","sourceRelease":"119-100","text":"any person assisting a Federal criminal investigation, while that assistance is being rendered and because of it,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t18/s1121/b","parentIdentifier":"/us/usc/t18/s1121","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s1121/b/1","parentIdentifier":"/us/usc/t18/s1121/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121%2Fb%2F1","sourceRelease":"119-100","text":"Whoever, in a circumstance described in paragraph (3) of this subsection, while incarcerated, intentionally kills any State correctional officer engaged in, or on account of the performance of such officer’s official duties, shall be sentenced to a term of imprisonment which shall not be less than 20 years, and may be sentenced to life imprisonment or death.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s1121/b/2","parentIdentifier":"/us/usc/t18/s1121/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121%2Fb%2F2","sourceRelease":"119-100","text":"As used in this section, the term, “State correctional officer” includes any officer or employee of any prison, jail, or other detention facility, operated by, or under contract to, either a State or local governmental agency, whose job responsibilities include providing for the custody of incarcerated individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s1121/b/3","parentIdentifier":"/us/usc/t18/s1121/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s1121/b/3/A","parentIdentifier":"/us/usc/t18/s1121/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the correctional officer is engaged in transporting the incarcerated person interstate; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s1121/b/3/B","parentIdentifier":"/us/usc/t18/s1121/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121%2Fb%2F3%2FB","sourceRelease":"119-100","text":"the incarcerated person is incarcerated pursuant to a conviction for an offense against the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t18/s1121/c","parentIdentifier":"/us/usc/t18/s1121","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1121%2Fc","sourceRelease":"119-100","text":"For the purposes of this section, the term “State” means a State of the United States, the District of Columbia, and any commonwealth, territory, or possession of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
