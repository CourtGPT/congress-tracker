{"type":"section","nativeType":"section","number":"509a","heading":"Project beneficiaries","label":"509a Project beneficiaries","identifier":"/us/usc/t43/s509a","parentIdentifier":"/us/usc/t43/ch12/schXI–A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs509a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Notice of modification","label":"a Notice of modification","identifier":"/us/usc/t43/s509a/a","parentIdentifier":"/us/usc/t43/s509a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs509a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s509a/a/1","parentIdentifier":"/us/usc/t43/s509a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs509a%2Fa%2F1","sourceRelease":"119-100","text":"describing the need for the modification and the process for identifying and implementing the modification; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s509a/a/2","parentIdentifier":"/us/usc/t43/s509a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs509a%2Fa%2F2","sourceRelease":"119-100","text":"summarizing the administrative and legal requirements relating to the modification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Consultation","label":"b Consultation","identifier":"/us/usc/t43/s509a/b","parentIdentifier":"/us/usc/t43/s509a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs509a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s509a/b/1","parentIdentifier":"/us/usc/t43/s509a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs509a%2Fb%2F1","sourceRelease":"119-100","text":"provide project beneficiaries an opportunity to consult with the Bureau of Reclamation on the planning, design, and construction of the proposed modification; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s509a/b/2","parentIdentifier":"/us/usc/t43/s509a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs509a%2Fb%2F2","sourceRelease":"119-100","text":"in consultation with project beneficiaries, develop and provide timeframes for the consultation described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Alternatives","label":"c Alternatives","identifier":"/us/usc/t43/s509a/c","parentIdentifier":"/us/usc/t43/s509a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs509a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s509a/c/1","parentIdentifier":"/us/usc/t43/s509a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs509a%2Fc%2F1","sourceRelease":"119-100","text":"Prior to submitting the reports required under , the Secretary shall consider any alternative submitted in writing, in accordance with the timeframes established under subsection (b), by a project beneficiary that has elected to consult with the Bureau of Reclamation on a modification.section 509 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s509a/c/2","parentIdentifier":"/us/usc/t43/s509a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs509a%2Fc%2F2","sourceRelease":"119-100","text":"The Secretary shall provide to the project beneficiary a timely written response describing proposed actions, if any, to address the recommendation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s509a/c/3","parentIdentifier":"/us/usc/t43/s509a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs509a%2Fc%2F3","sourceRelease":"119-100","text":"The response of the Secretary shall be included in the reports required by .section 509 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Waiver","label":"d Waiver","identifier":"/us/usc/t43/s509a/d","parentIdentifier":"/us/usc/t43/s509a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs509a%2Fd","sourceRelease":"119-100","text":"The Secretary may waive 1 or more of the requirements of subsections (a), (b), and (c), if the Secretary determines that implementation of the requirement could have an adverse impact on dam safety or security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
