{"type":"section","nativeType":"section","number":"4802","heading":"Administrative consideration of burden with new regulations","label":"4802 Administrative consideration of burden with new regulations","identifier":"/us/usc/t12/s4802","parentIdentifier":"/us/usc/t12/ch48","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4802","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Agency considerations","label":"a Agency considerations","identifier":"/us/usc/t12/s4802/a","parentIdentifier":"/us/usc/t12/s4802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4802%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4802/a/1","parentIdentifier":"/us/usc/t12/s4802/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4802%2Fa%2F1","sourceRelease":"119-100","text":"any administrative burdens that such regulations would place on depository institutions, including small depository institutions and customers of depository institutions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4802/a/2","parentIdentifier":"/us/usc/t12/s4802/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4802%2Fa%2F2","sourceRelease":"119-100","text":"the benefits of such regulations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Adequate transition period for new regulations","label":"b Adequate transition period for new regulations","identifier":"/us/usc/t12/s4802/b","parentIdentifier":"/us/usc/t12/s4802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4802%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t12/s4802/b/1","parentIdentifier":"/us/usc/t12/s4802/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4802%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s4802/b/1/A","parentIdentifier":"/us/usc/t12/s4802/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4802%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the agency determines, for good cause published with the regulation, that the regulation should become effective before such time;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s4802/b/1/B","parentIdentifier":"/us/usc/t12/s4802/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4802%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the regulation is issued by the Board of Governors of the Federal Reserve System in connection with the implementation of monetary policy; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s4802/b/1/C","parentIdentifier":"/us/usc/t12/s4802/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4802%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the regulation is required to take effect on a date other than the date determined under this paragraph pursuant to any other Act of Congress.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Early compliance","label":"2 Early compliance","identifier":"/us/usc/t12/s4802/b/2","parentIdentifier":"/us/usc/t12/s4802/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4802%2Fb%2F2","sourceRelease":"119-100","text":"Any person who is subject to a regulation described in paragraph (1) may comply with the regulation before the effective date of the regulation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
