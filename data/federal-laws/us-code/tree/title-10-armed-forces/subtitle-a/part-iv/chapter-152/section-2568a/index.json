{"type":"section","nativeType":"section","number":"2568a","heading":"Damaged personal protective equipment: award to members separating from the Armed Forces and veterans","label":"2568a Damaged personal protective equipment: award to members separating from the Armed Forces and veterans","identifier":"/us/usc/t10/s2568a","parentIdentifier":"/us/usc/t10/stA/ptIV/ch152","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2568a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t10/s2568a/a","parentIdentifier":"/us/usc/t10/s2568a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2568a%2Fa","sourceRelease":"119-100","text":"The Secretary of a military department, acting through a disposition service distribution center of the Defense Logistics Agency, may award to a covered individual the demilitarized PPE of that covered individual. The award of PPE under this section shall be without cost to the covered individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Definitions","label":"b .—Definitions","identifier":"/us/usc/t10/s2568a/b","parentIdentifier":"/us/usc/t10/s2568a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2568a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2568a/b/1","parentIdentifier":"/us/usc/t10/s2568a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2568a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2568a/b/1/A","parentIdentifier":"/us/usc/t10/s2568a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2568a%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s2568a/b/1/A/i","parentIdentifier":"/us/usc/t10/s2568a/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2568a%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"under the jurisdiction of the Secretary concerned; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s2568a/b/1/A/ii","parentIdentifier":"/us/usc/t10/s2568a/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2568a%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"who is separating from the armed forces; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2568a/b/1/B","parentIdentifier":"/us/usc/t10/s2568a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2568a%2Fb%2F1%2FB","sourceRelease":"119-100","text":"a veteran who was under the jurisdiction of the Secretary concerned while a member of the armed forces.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2568a/b/2","parentIdentifier":"/us/usc/t10/s2568a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2568a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"su