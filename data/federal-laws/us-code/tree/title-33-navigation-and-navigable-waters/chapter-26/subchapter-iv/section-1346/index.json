{"type":"section","nativeType":"section","number":"1346","heading":"Coastal recreation water quality monitoring and notification","label":"1346 Coastal recreation water quality monitoring and notification","identifier":"/us/usc/t33/s1346","parentIdentifier":"/us/usc/t33/ch26/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Monitoring and notification","label":"a Monitoring and notification","identifier":"/us/usc/t33/s1346/a","parentIdentifier":"/us/usc/t33/s1346","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s1346/a/1","parentIdentifier":"/us/usc/t33/s1346/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1346/a/1/A","parentIdentifier":"/us/usc/t33/s1346/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fa%2F1%2FA","sourceRelease":"119-100","text":"monitoring and assessment (including specifying available methods for monitoring) of coastal recreation waters adjacent to beaches or similar points of access that are used by the public for attainment of applicable water quality standards for pathogens and pathogen indicators; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1346/a/1/B","parentIdentifier":"/us/usc/t33/s1346/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the prompt notification of the public, local governments, and the Administrator of any exceeding of or likelihood of exceeding applicable water quality standards for coastal recreation waters described in subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Level of protection","label":"2 Level of protection","identifier":"/us/usc/t33/s1346/a/2","parentIdentifier":"/us/usc/t33/s1346/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fa%2F2","sourceRelease":"119-100","text":"The performance criteria referred to in paragraph (1) shall provide that the activities described in subparagraphs (A) and (B) of that paragraph shall be carried out as necessary for the protection of public health and safety.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Program development and implementation grants","label":"b Program development and implementation grants","identifier":"/us/usc/t33/s1346/b","parentIdentifier":"/us/usc/t33/s1346","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s1346/b/1","parentIdentifier":"/us/usc/t33/s1346/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F1","sourceRelease":"119-100","text":"The Administrator may make grants to States and local governments to develop and implement programs for monitoring and notification for coastal recreation waters adjacent to beaches or similar points of access that are used by the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitations","label":"2 Limitations","identifier":"/us/usc/t33/s1346/b/2","parentIdentifier":"/us/usc/t33/s1346/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t33/s1346/b/2/A","parentIdentifier":"/us/usc/t33/s1346/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s1346/b/2/A/i","parentIdentifier":"/us/usc/t33/s1346/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the program is consistent with the performance criteria published by the Administrator under subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s1346/b/2/A/ii","parentIdentifier":"/us/usc/t33/s1346/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the State or local government prioritizes the use of grant funds for particular coastal recreation waters based on the use of the water and the risk to human health presented by pathogens or pathogen indicators;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t33/s1346/b/2/A/iii","parentIdentifier":"/us/usc/t33/s1346/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"the State or local government makes available to the Administrator the factors used to prioritize the use of funds under clause (ii);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t33/s1346/b/2/A/iv","parentIdentifier":"/us/usc/t33/s1346/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"the State or local government provides a list of discrete areas of coastal recreation waters that are subject to the program for monitoring and notification for which the grant is provided that specifies any coastal recreation waters for which fiscal constraints will prevent consistency with the performance criteria under subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t33/s1346/b/2/A/v","parentIdentifier":"/us/usc/t33/s1346/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F2%2FA%2Fv","sourceRelease":"119-100","text":"the public is provided an opportunity to review the program through a process that provides for public notice and an opportunity for comment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Grants to local governments","label":"B Grants to local governments","identifier":"/us/usc/t33/s1346/b/2/B","parentIdentifier":"/us/usc/t33/s1346/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F2%2FB","sourceRelease":"119-100","text":"The Administrator may make a grant to a local government under this subsection for implementation of a monitoring and notification program only if, after the 1-year period beginning on the date of publication of performance criteria under subsection (a)(1), the Administrator determines that the State is not implementing a program that meets the requirements of this subsection, regardless of whether the State has received a grant under this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Other requirements","label":"3 Other requirements","identifier":"/us/usc/t33/s1346/b/3","parentIdentifier":"/us/usc/t33/s1346/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Report","label":"A Report","identifier":"/us/usc/t33/s1346/b/3/A","parentIdentifier":"/us/usc/t33/s1346/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s1346/b/3/A/i","parentIdentifier":"/us/usc/t33/s1346/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F3%2FA%2Fi","sourceRelease":"119-100","text":"data collected as part of the program for monitoring and notification as described in subsection (c); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s1346/b/3/A/ii","parentIdentifier":"/us/usc/t33/s1346/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F3%2FA%2Fii","sourceRelease":"119-100","text":"actions taken to notify the public when water quality standards are exceeded.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Delegation","label":"B Delegation","identifier":"/us/usc/t33/s1346/b/3/B","parentIdentifier":"/us/usc/t33/s1346/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F3%2FB","sourceRelease":"119-100","text":"A State recipient of a grant under this subsection shall identify each local government to which the State has delegated or intends to delegate responsibility for implementing a monitoring and notification program consistent with the performance criteria published under subsection (a) (including any coastal recreation waters for which the authority to implement a monitoring and notification program would be subject to the delegation).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Federal share","label":"4 Federal share","identifier":"/us/usc/t33/s1346/b/4","parentIdentifier":"/us/usc/t33/s1346/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t33/s1346/b/4/A","parentIdentifier":"/us/usc/t33/s1346/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F4%2FA","sourceRelease":"119-100","text":"The Administrator, through grants awarded under this section, may pay up to 100 percent of the costs of developing and implementing a program for monitoring and notification under this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Non-Federal share","label":"B Non-Federal share","identifier":"/us/usc/t33/s1346/b/4/B","parentIdentifier":"/us/usc/t33/s1346/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s1346/b/4/B/i","parentIdentifier":"/us/usc/t33/s1346/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F4%2FB%2Fi","sourceRelease":"119-100","text":"in an amount not to exceed 50 percent, as determined by the Administrator in consultation with State, tribal, and local government representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s1346/b/4/B/ii","parentIdentifier":"/us/usc/t33/s1346/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fb%2F4%2FB%2Fii","sourceRelease":"119-100","text":"provided in cash or in kind.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Content of State and local government programs","label":"c Content of State and local government programs","identifier":"/us/usc/t33/s1346/c","parentIdentifier":"/us/usc/t33/s1346","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1346/c/1","parentIdentifier":"/us/usc/t33/s1346/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F1","sourceRelease":"119-100","text":"lists of coastal recreation waters in the State, including coastal recreation waters adjacent to beaches or similar points of access that are used by the public;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1346/c/2","parentIdentifier":"/us/usc/t33/s1346/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F2","sourceRelease":"119-100","text":"in the case of a State program for monitoring and notification, the process by which the State may delegate to local governments responsibility for implementing the monitoring and notification program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s1346/c/3","parentIdentifier":"/us/usc/t33/s1346/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1346/c/3/A","parentIdentifier":"/us/usc/t33/s1346/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F3%2FA","sourceRelease":"119-100","text":"the periods of recreational use of the waters;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1346/c/3/B","parentIdentifier":"/us/usc/t33/s1346/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F3%2FB","sourceRelease":"119-100","text":"the nature and extent of use during certain periods;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s1346/c/3/C","parentIdentifier":"/us/usc/t33/s1346/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F3%2FC","sourceRelease":"119-100","text":"the proximity of the waters to known point sources and nonpoint sources of pollution; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t33/s1346/c/3/D","parentIdentifier":"/us/usc/t33/s1346/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F3%2FD","sourceRelease":"119-100","text":"any effect of storm events on the waters;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s1346/c/4","parentIdentifier":"/us/usc/t33/s1346/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1346/c/4/A","parentIdentifier":"/us/usc/t33/s1346/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F4%2FA","sourceRelease":"119-100","text":"the methods to be used for detecting levels of pathogens and pathogen indicators that are harmful to human health; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1346/c/4/B","parentIdentifier":"/us/usc/t33/s1346/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F4%2FB","sourceRelease":"119-100","text":"the assessment procedures for identifying short-term increases in pathogens and pathogen indicators that are harmful to human health in coastal recreation waters (including increases in relation to storm events);","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t33/s1346/c/5","parentIdentifier":"/us/usc/t33/s1346/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1346/c/5/A","parentIdentifier":"/us/usc/t33/s1346/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F5%2FA","sourceRelease":"119-100","text":"the Administrator, in such form as the Administrator determines to be appropriate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1346/c/5/B","parentIdentifier":"/us/usc/t33/s1346/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F5%2FB","sourceRelease":"119-100","text":"a designated official of a local government having jurisdiction over land adjoining the coastal recreation waters for which the failure to meet applicable standards is identified;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t33/s1346/c/6","parentIdentifier":"/us/usc/t33/s1346/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F6","sourceRelease":"119-100","text":"measures for the posting of signs at beaches or similar points of access, or functionally equivalent communication measures that are sufficient to give notice to the public that the coastal recreation waters are not meeting or are not expected to meet applicable water quality standards for pathogens and pathogen indicators; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t33/s1346/c/7","parentIdentifier":"/us/usc/t33/s1346/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fc%2F7","sourceRelease":"119-100","text":"measures that inform the public of the potential risks associated with water contact activities in the coastal recreation waters that do not meet applicable water quality standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Federal agency programs","label":"d Federal agency programs","identifier":"/us/usc/t33/s1346/d","parentIdentifier":"/us/usc/t33/s1346","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1346/d/1","parentIdentifier":"/us/usc/t33/s1346/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fd%2F1","sourceRelease":"119-100","text":"protects the public health and safety;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1346/d/2","parentIdentifier":"/us/usc/t33/s1346/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fd%2F2","sourceRelease":"119-100","text":"is consistent with the performance criteria published under subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s1346/d/3","parentIdentifier":"/us/usc/t33/s1346/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fd%2F3","sourceRelease":"119-100","text":"includes a completed report on the information specified in subsection (b)(3)(A), to be submitted to the Administrator; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s1346/d/4","parentIdentifier":"/us/usc/t33/s1346/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fd%2F4","sourceRelease":"119-100","text":"addresses the matters specified in subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Database","label":"e Database","identifier":"/us/usc/t33/s1346/e","parentIdentifier":"/us/usc/t33/s1346","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1346/e/1","parentIdentifier":"/us/usc/t33/s1346/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fe%2F1","sourceRelease":"119-100","text":"the data reported to the Administrator under subsections (b)(3)(A)(i) and (d)(3); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1346/e/2","parentIdentifier":"/us/usc/t33/s1346/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1346/e/2/A","parentIdentifier":"/us/usc/t33/s1346/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fe%2F2%2FA","sourceRelease":"119-100","text":"is made available to the Administrator by a State or local government, from a coastal water quality monitoring program of the State or local government; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1346/e/2/B","parentIdentifier":"/us/usc/t33/s1346/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fe%2F2%2FB","sourceRelease":"119-100","text":"the Administrator determines should be included.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Technical assistance for monitoring floatable material","label":"f Technical assistance for monitoring floatable material","identifier":"/us/usc/t33/s1346/f","parentIdentifier":"/us/usc/t33/s1346","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Ff","sourceRelease":"119-100","text":"The Administrator shall provide technical assistance to States and local governments for the development of assessment and monitoring procedures for floatable material to protect public health and safety in coastal recreation waters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"List of waters","label":"g List of waters","identifier":"/us/usc/t33/s1346/g","parentIdentifier":"/us/usc/t33/s1346","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s1346/g/1","parentIdentifier":"/us/usc/t33/s1346/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fg%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1346/g/1/A","parentIdentifier":"/us/usc/t33/s1346/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fg%2F1%2FA","sourceRelease":"119-100","text":"specifies any waters described in this paragraph that are subject to a monitoring and notification program consistent with the performance criteria established under subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1346/g/1/B","parentIdentifier":"/us/usc/t33/s1346/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fg%2F1%2FB","sourceRelease":"119-100","text":"specifies any waters described in this paragraph for which there is no monitoring and notification program (including waters for which fiscal constraints will prevent the State or the Administrator from performing monitoring and notification consistent with the performance criteria established under subsection (a)).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Availability","label":"2 Availability","identifier":"/us/usc/t33/s1346/g/2","parentIdentifier":"/us/usc/t33/s1346/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fg%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1346/g/2/A","parentIdentifier":"/us/usc/t33/s1346/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fg%2F2%2FA","sourceRelease":"119-100","text":"publication in the Federal Register; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1346/g/2/B","parentIdentifier":"/us/usc/t33/s1346/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fg%2F2%2FB","sourceRelease":"119-100","text":"electronic media.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Updates","label":"3 Updates","identifier":"/us/usc/t33/s1346/g/3","parentIdentifier":"/us/usc/t33/s1346/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fg%2F3","sourceRelease":"119-100","text":"The Administrator shall update the list described in paragraph (1) periodically as new information becomes available.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"EPA implementation","label":"h EPA implementation","identifier":"/us/usc/t33/s1346/h","parentIdentifier":"/us/usc/t33/s1346","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1346/h/1","parentIdentifier":"/us/usc/t33/s1346/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fh%2F1","sourceRelease":"119-100","text":"to conduct monitoring and notification; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1346/h/2","parentIdentifier":"/us/usc/t33/s1346/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fh%2F2","sourceRelease":"119-100","text":"for related salaries, expenses, and travel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Authorization of appropriations","label":"i Authorization of appropriations","identifier":"/us/usc/t33/s1346/i","parentIdentifier":"/us/usc/t33/s1346","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1346%2Fi","sourceRelease":"119-100","text":"There is authorized to be appropriated for making grants under subsection (b), including implementation of monitoring and notification programs by the Administrator under subsection (h), $30,000,000 for each of fiscal years 2001 through 2005.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
