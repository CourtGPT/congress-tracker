{"type":"section","nativeType":"section","number":"17014","heading":"Research and development into integrating electric vehicles onto the electric grid","label":"17014 Research and development into integrating electric vehicles onto the electric grid","identifier":"/us/usc/t42/s17014","parentIdentifier":"/us/usc/t42/ch152/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s17014/a","parentIdentifier":"/us/usc/t42/s17014","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish a research, development, and demonstration program to advance the integration of electric vehicles, including plug-in hybrid electric vehicles, onto the electric grid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Vehicles-to-grid integration assessment report","label":"b Vehicles-to-grid integration assessment report","identifier":"/us/usc/t42/s17014/b","parentIdentifier":"/us/usc/t42/s17014","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Report requirements","label":"1 Report requirements","identifier":"/us/usc/t42/s17014/b/1","parentIdentifier":"/us/usc/t42/s17014/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17014/b/1/A","parentIdentifier":"/us/usc/t42/s17014/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17014/b/1/A/i","parentIdentifier":"/us/usc/t42/s17014/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the use of electric vehicles for demand response, load shaping, emergency power, and frequency regulation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17014/b/1/A/ii","parentIdentifier":"/us/usc/t42/s17014/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the potential for the reuse of spent electric vehicle batteries for stationary grid storage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17014/b/1/B","parentIdentifier":"/us/usc/t42/s17014/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17014/b/1/B/i","parentIdentifier":"/us/usc/t42/s17014/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the impact of bi-directional electricity flow on battery degradation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17014/b/1/B/ii","parentIdentifier":"/us/usc/t42/s17014/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the implications of the use of electric vehicles for grid services on original equipment manufacturer warranties;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17014/b/1/C","parentIdentifier":"/us/usc/t42/s17014/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s17014/b/1/C/i","parentIdentifier":"/us/usc/t42/s17014/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FC%2Fi","sourceRelease":"119-100","text":"the distribution grid infrastructure needed to support an increase in charging capacity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s17014/b/1/C/ii","parentIdentifier":"/us/usc/t42/s17014/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FC%2Fii","sourceRelease":"119-100","text":"strategies for integrating electric vehicles onto the distribution grid while limiting infrastructure upgrades;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s17014/b/1/C/iii","parentIdentifier":"/us/usc/t42/s17014/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"the changes in electricity demand over a 24-hour cycle due to electric vehicle charging behavior;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s17014/b/1/C/iv","parentIdentifier":"/us/usc/t42/s17014/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FC%2Fiv","sourceRelease":"119-100","text":"the load increases expected from electrifying the transportation sector;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s17014/b/1/C/v","parentIdentifier":"/us/usc/t42/s17014/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FC%2Fv","sourceRelease":"119-100","text":"the potential for customer incentives and other managed charging stations strategies to shift charging off-peak;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s17014/b/1/C/vi","parentIdentifier":"/us/usc/t42/s17014/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FC%2Fvi","sourceRelease":"119-100","text":"the technology needed to achieve bi-directional power flow on the distribution grid; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t42/s17014/b/1/C/vii","parentIdentifier":"/us/usc/t42/s17014/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FC%2Fvii","sourceRelease":"119-100","text":"the implementation of smart charging techniques;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17014/b/1/D","parentIdentifier":"/us/usc/t42/s17014/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FD","sourceRelease":"119-100","text":"research on the standards needed to integrate electric vehicles with the grid, including communications systems, protocols, and charging stations, in collaboration with the National Institute for Standards and Technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17014/b/1/E","parentIdentifier":"/us/usc/t42/s17014/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FE","sourceRelease":"119-100","text":"the cybersecurity challenges and needs associated with electrifying the transportation sector; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17014/b/1/F","parentIdentifier":"/us/usc/t42/s17014/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F1%2FF","sourceRelease":"119-100","text":"an assessment of the feasibility of adopting technologies developed under the program established under subsection (a) at Department facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Recommendations","label":"2 Recommendations","identifier":"/us/usc/t42/s17014/b/2","parentIdentifier":"/us/usc/t42/s17014/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F2","sourceRelease":"119-100","text":"As part of the Vehicles-to-Grid Integration Assessment Report, the Secretary shall develop a 10-year roadmap to guide the research, development, and demonstration program to integrate electric vehicles onto the electric grid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Consultation","label":"3 Consultation","identifier":"/us/usc/t42/s17014/b/3","parentIdentifier":"/us/usc/t42/s17014/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17014/b/3/A","parentIdentifier":"/us/usc/t42/s17014/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F3%2FA","sourceRelease":"119-100","text":"electric vehicle manufacturers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17014/b/3/B","parentIdentifier":"/us/usc/t42/s17014/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F3%2FB","sourceRelease":"119-100","text":"electric utilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17014/b/3/C","parentIdentifier":"/us/usc/t42/s17014/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F3%2FC","sourceRelease":"119-100","text":"public utility commissions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17014/b/3/D","parentIdentifier":"/us/usc/t42/s17014/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F3%2FD","sourceRelease":"119-100","text":"vehicle battery manufacturers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17014/b/3/E","parentIdentifier":"/us/usc/t42/s17014/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F3%2FE","sourceRelease":"119-100","text":"electric vehicle supply equipment manufacturers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17014/b/3/F","parentIdentifier":"/us/usc/t42/s17014/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F3%2FF","sourceRelease":"119-100","text":"charging infrastructure manufacturers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s17014/b/3/G","parentIdentifier":"/us/usc/t42/s17014/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F3%2FG","sourceRelease":"119-100","text":"the National Laboratories; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t42/s17014/b/3/H","parentIdentifier":"/us/usc/t42/s17014/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F3%2FH","sourceRelease":"119-100","text":"other Federal agencies, as the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Updates","label":"4 Updates","identifier":"/us/usc/t42/s17014/b/4","parentIdentifier":"/us/usc/t42/s17014/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fb%2F4","sourceRelease":"119-100","text":"The Secretary shall update the report required under this section every 3 years for the duration of the program under section (a) and shall submit the updated report to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.1So in original. Probably should be “subsection”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Program implementation","label":"c Program implementation","identifier":"/us/usc/t42/s17014/c","parentIdentifier":"/us/usc/t42/s17014","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17014/c/1","parentIdentifier":"/us/usc/t42/s17014/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fc%2F1","sourceRelease":"119-100","text":"implement the recommendations set forth in the report in subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17014/c/2","parentIdentifier":"/us/usc/t42/s17014/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fc%2F2","sourceRelease":"119-100","text":"coordinate across all relevant program offices at the Department to achieve the goals established in this section, including the Office of Electricity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Testing capabilities","label":"d Testing capabilities","identifier":"/us/usc/t42/s17014/d","parentIdentifier":"/us/usc/t42/s17014","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17014%2Fd","sourceRelease":"119-100","text":"The Secretary shall coordinate with the National Laboratories to develop testing capabilities for the evaluation, rapid prototyping, and optimization of technologies enabling integration of electric vehicles onto the electric grid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
