{"type":"section","nativeType":"section","number":"14302","heading":"Promotion zones","label":"14302 Promotion zones","identifier":"/us/usc/t10/s14302","parentIdentifier":"/us/usc/t10/stE/ptIII/ch1405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2006—Subsec. (a)(1)(A). substituted “Navy Reserve” for “Naval Reserve”.Pub. L. 109–163","Statutory Notes and Related Subsidiaries","Effective DateSection effective , see , set out as a note under .Oct. 1, 1996section 1691(b)(1) of Pub. L. 103–337section 10001 of this title"],"amendments":["Amendments2006—Subsec. (a)(1)(A). substituted “Navy Reserve” for “Naval Reserve”.Pub. L. 109–163"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Promotion Zones Generally","label":"a .—Promotion Zones Generally","identifier":"/us/usc/t10/s14302/a","parentIdentifier":"/us/usc/t10/s14302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s14302/a/1","parentIdentifier":"/us/usc/t10/s14302/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s14302/a/1/A","parentIdentifier":"/us/usc/t10/s14302/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fa%2F1%2FA","sourceRelease":"119-100","text":"In the case of officers in grades below colonel, for reserve officers of the Army, Air Force, and Marine Corps, or captain, for officers of the Navy Reserve, those who have neither (i) failed of selection for promotion to the next higher grade, nor (ii) been removed from a list of officers recommended for promotion to that grade.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s14302/a/1/B","parentIdentifier":"/us/usc/t10/s14302/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fa%2F1%2FB","sourceRelease":"119-100","text":"In the case of officers in the grade of colonel or brigadier general, for reserve officers of the Army and Marine Corps, or in the grade of captain or rear admiral (lower half), for reserve officers of the Navy, those who have neither (i) been recommended for promotion to the next higher grade when considered in the promotion zone, nor (ii) been removed from a list of officers recommended for promotion to that grade.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s14302/a/2","parentIdentifier":"/us/usc/t10/s14302/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fa%2F2","sourceRelease":"119-100","text":"Those officers who are senior to the officer designated by the Secretary of the military department concerned to be the junior officer in the promotion zone eligible for consideration for promotion to the next higher grade and the officer so designated.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s14302/a/3","parentIdentifier":"/us/usc/t10/s14302/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s14302/a/3/A","parentIdentifier":"/us/usc/t10/s14302/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fa%2F3%2FA","sourceRelease":"119-100","text":"have been selected from below the zone for promotion to the next higher grade or by a vacancy promotion board, but whose names were removed from the list of officers recommended for promotion to that next higher grade resulting from that selection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s14302/a/3/B","parentIdentifier":"/us/usc/t10/s14302/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fa%2F3%2FB","sourceRelease":"119-100","text":"have not failed of selection for promotion to that next higher grade; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s14302/a/3/C","parentIdentifier":"/us/usc/t10/s14302/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fa%2F3%2FC","sourceRelease":"119-100","text":"are senior to the officer designated by the Secretary of the military department concerned to be the junior officer in the promotion zone eligible for consideration for promotion to that next higher grade and the officer so designated.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Officers Above the Zone","label":"b .—Officers Above the Zone","identifier":"/us/usc/t10/s14302/b","parentIdentifier":"/us/usc/t10/s14302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s14302/b/1","parentIdentifier":"/us/usc/t10/s14302/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fb%2F1","sourceRelease":"119-100","text":"are eligible for consideration for promotion to the next higher grade;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s14302/b/2","parentIdentifier":"/us/usc/t10/s14302/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fb%2F2","sourceRelease":"119-100","text":"are in the same grade as those officers in the promotion zone for that competitive category; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s14302/b/3","parentIdentifier":"/us/usc/t10/s14302/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fb%2F3","sourceRelease":"119-100","text":"are senior to the senior officer in the promotion zone for that competitive category.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Officers Below the Zone","label":"c .—Officers Below the Zone","identifier":"/us/usc/t10/s14302/c","parentIdentifier":"/us/usc/t10/s14302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s14302/c/1","parentIdentifier":"/us/usc/t10/s14302/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fc%2F1","sourceRelease":"119-100","text":"are eligible for consideration for promotion to the next higher grade;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s14302/c/2","parentIdentifier":"/us/usc/t10/s14302/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fc%2F2","sourceRelease":"119-100","text":"are in the same grade as those officers in the promotion zone for that competitive category; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s14302/c/3","parentIdentifier":"/us/usc/t10/s14302/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs14302%2Fc%2F3","sourceRelease":"119-100","text":"are junior to the junior officer in the promotion zone for that competitive category.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
