:"subsection","number":"b","heading":"Contents","label":"b Contents","identifier":"/us/usc/t25/s5364/b","parentIdentifier":"/us/usc/t25/s5364","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5364%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s5364/b/1","parentIdentifier":"/us/usc/t25/s5364/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5364%2Fb%2F1","sourceRelease":"119-100","text":"specify and affirm the general terms of the government-to-government relationship between the Indian Tribe and the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s5364/b/2","parentIdentifier":"/us/usc/t25/s5364/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5364%2Fb%2F2","sourceRelease":"119-100","text":"include such terms as the parties intend shall control during the term of the compact.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Amendment","label":"c Amendment","identifier":"/us/usc/t25/s5364/c","parentIdentifier":"/us/usc/t25/s5364","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5364%2Fc","sourceRelease":"119-100","text":"A compact under subsection (a) may be amended only by agreement of the parties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Effective date","label":"d Effective date","identifier":"/us/usc/t25/s5364/d","parentIdentifier":"/us/usc/t25/s5364","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5364%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s5364/d/1","parentIdentifier":"/us/usc/t25/s5364/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5364%2Fd%2F1","sourceRelease":"119-100","text":"the date of the execution of the compact by the parties; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s5364/d/2","parentIdentifier":"/us/usc/t25/s5364/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5364%2Fd%2F2","sourceRelease":"119-100","text":"such date as is mutually agreed upon by the parties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Duration","label":"e Duration","identifier":"/us/usc/t25/s5364/e","parentIdentifier":"/us/usc/t25/s5364","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5364%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s5364/e/1","parentIdentifier":"/us/usc/t25/s5364/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5364%2Fe%2F1","sourceRelease":"119-100","text":"for so long as permitted by Federal law; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s5364/e/2","parentIdentifier":"/us/usc/t25/s5364/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5364%2Fe%2F2","sourceRelease":"119-100","text":"until termination by written agreement, retrocession, or reassumption.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Existing compacts","label":"f Existing compacts","identifier":"/us/usc/t25/s5364/f","parentIdentifier":"/us/usc/t25/s5364","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5364%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s5364/f/1","parentIdentifier":"/us/usc/t25/s5364/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5364%2Ff%2F1","sourceRelease":"119-100","text":"to retain its negotiated compact (in whole or in part) to the extent that the provisions of the compact are not directly contrary to any express provision of this subchapter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s5364/f/2","parentIdentifier":"/us/usc/t25/s5364/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs5364%2Ff%2F2","sourceRelease":"119-100","text":"to negotiate a new compact in a manner consistent with this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
