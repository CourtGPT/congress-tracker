{"type":"section","nativeType":"section","number":"5851","heading":"Findings","label":"5851 Findings","identifier":"/us/usc/t22/s5851","parentIdentifier":"/us/usc/t22/ch67/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5851","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s5851/1","parentIdentifier":"/us/usc/t22/s5851","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5851%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s5851/1/A","parentIdentifier":"/us/usc/t22/s5851/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5851%2F1%2FA","sourceRelease":"119-100","text":"the transportation, storage, safeguarding, and destruction of nuclear and other weapons of mass destruction of the independent states of the former Soviet Union;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s5851/1/B","parentIdentifier":"/us/usc/t22/s5851/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5851%2F1%2FB","sourceRelease":"119-100","text":"the prevention of proliferation of weapons of mass destruction and destabilizing conventional weapons of the independent states, and the establishment of verifiable safeguards against the proliferation of such weapons;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s5851/1/C","parentIdentifier":"/us/usc/t22/s5851/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5851%2F1%2FC","sourceRelease":"119-100","text":"the prevention of diversion of weapons-related scientific expertise of the former Soviet Union to terrorist groups or third countries; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s5851/1/D","parentIdentifier":"/us/usc/t22/s5851/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5851%2F1%2FD","sourceRelease":"119-100","text":"other efforts designed to reduce the military threat from the former Soviet Union;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s5851/2","parentIdentifier":"/us/usc/t22/s5851","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5851%2F2","sourceRelease":"119-100","text":"to support the conversion of the massive defense-related industry and equipment of the independent states of the former Soviet Union for civilian purposes and uses; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s5851/3","parentIdentifier":"/us/usc/t22/s5851","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5851%2F3","sourceRelease":"119-100","text":"to expand military-to-military contacts between the United States and the independent states.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
