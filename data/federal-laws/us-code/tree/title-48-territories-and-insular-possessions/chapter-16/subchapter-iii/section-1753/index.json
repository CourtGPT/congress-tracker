{"type":"section","nativeType":"section","number":"1753","heading":"Qualifications for office of Delegate","label":"1753 Qualifications for office of Delegate","identifier":"/us/usc/t48/s1753","parentIdentifier":"/us/usc/t48/ch16/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1753","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t48/s1753/1","parentIdentifier":"/us/usc/t48/s1753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1753%2F1","sourceRelease":"119-100","text":"be at least 25 years of age on the date of the election;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t48/s1753/2","parentIdentifier":"/us/usc/t48/s1753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1753%2F2","sourceRelease":"119-100","text":"have been a citizen of the United States for at least 7 years prior to the date of the election;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t48/s1753/3","parentIdentifier":"/us/usc/t48/s1753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1753%2F3","sourceRelease":"119-100","text":"be a resident and domiciliary of the Commonwealth of the Northern Mariana Islands for at least 7 years prior to the date of the election;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t48/s1753/4","parentIdentifier":"/us/usc/t48/s1753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1753%2F4","sourceRelease":"119-100","text":"be qualified to vote in the Commonwealth of the Northern Mariana Islands on the date of the election; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t48/s1753/5","parentIdentifier":"/us/usc/t48/s1753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs1753%2F5","sourceRelease":"119-100","text":"not be, on the date of the election, a candidate for any other office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
