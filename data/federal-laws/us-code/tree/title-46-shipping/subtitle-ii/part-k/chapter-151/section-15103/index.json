{"type":"section","nativeType":"section","number":"15103","heading":"National Merchant Marine Personnel Advisory Committee","label":"15103 National Merchant Marine Personnel Advisory Committee","identifier":"/us/usc/t46/s15103","parentIdentifier":"/us/usc/t46/stII/ptK/ch151","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t46/s15103/a","parentIdentifier":"/us/usc/t46/s15103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fa","sourceRelease":"119-100","text":"There is established a National Merchant Marine Personnel Advisory Committee (in this section referred to as the “Committee”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Function","label":"b .—Function","identifier":"/us/usc/t46/s15103/b","parentIdentifier":"/us/usc/t46/s15103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fb","sourceRelease":"119-100","text":"The Committee shall advise the Secretary on matters relating to personnel in the United States merchant marine, including the training, qualifications, certification, documentation, and fitness of mariners.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Membership.—","label":"c Membership.—","identifier":"/us/usc/t46/s15103/c","parentIdentifier":"/us/usc/t46/s15103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t46/s15103/c/1","parentIdentifier":"/us/usc/t46/s15103/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F1","sourceRelease":"119-100","text":"The Committee shall consist of 19 members appointed by the Secretary in accordance with this section and section 15109 of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Expertise","label":"2 .—Expertise","identifier":"/us/usc/t46/s15103/c/2","parentIdentifier":"/us/usc/t46/s15103/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F2","sourceRelease":"119-100","text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Representation","label":"3 .—Representation","identifier":"/us/usc/t46/s15103/c/3","parentIdentifier":"/us/usc/t46/s15103/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s15103/c/3/A","parentIdentifier":"/us/usc/t46/s15103/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t46/s15103/c/3/A/i","parentIdentifier":"/us/usc/t46/s15103/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t46/s15103/c/3/A/i/I","parentIdentifier":"/us/usc/t46/s15103/c/3/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fi%2FI","sourceRelease":"119-100","text":"be a citizen of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t46/s15103/c/3/A/i/II","parentIdentifier":"/us/usc/t46/s15103/c/3/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fi%2FII","sourceRelease":"119-100","text":"hold an active license or certificate issued under chapter 71 of this title or a merchant mariner document issued under chapter 73 of this title;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t46/s15103/c/3/A/ii","parentIdentifier":"/us/usc/t46/s15103/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t46/s15103/c/3/A/ii/I","parentIdentifier":"/us/usc/t46/s15103/c/3/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fii%2FI","sourceRelease":"119-100","text":"2 shall be licensed for oceans any gross tons;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t46/s15103/c/3/A/ii/II","parentIdentifier":"/us/usc/t46/s15103/c/3/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fii%2FII","sourceRelease":"119-100","text":"1 shall be licensed for inland river route with a limited or unlimited tonnage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t46/s15103/c/3/A/ii/III","parentIdentifier":"/us/usc/t46/s15103/c/3/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fii%2FIII","sourceRelease":"119-100","text":"2 shall have a master’s license or a master of towing vessels license;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t46/s15103/c/3/A/ii/IV","parentIdentifier":"/us/usc/t46/s15103/c/3/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fii%2FIV","sourceRelease":"119-100","text":"1 shall have significant tanker experience; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t46/s15103/c/3/A/ii/V","parentIdentifier":"/us/usc/t46/s15103/c/3/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fii%2FV","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t46/s15103/c/3/A/ii/V/aa","parentIdentifier":"/us/usc/t46/s15103/c/3/A/ii/V","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fii%2FV%2Faa","sourceRelease":"119-100","text":"1 shall represent labor; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t46/s15103/c/3/A/ii/V/bb","parentIdentifier":"/us/usc/t46/s15103/c/3/A/ii/V","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fii%2FV%2Fbb","sourceRelease":"119-100","text":"1 shall represent management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t46/s15103/c/3/A/iii","parentIdentifier":"/us/usc/t46/s15103/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t46/s15103/c/3/A/iii/I","parentIdentifier":"/us/usc/t46/s15103/c/3/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"2 shall be licensed as chief engineer any horsepower;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t46/s15103/c/3/A/iii/II","parentIdentifier":"/us/usc/t46/s15103/c/3/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"1 shall be licensed as either a limited chief engineer or a designated duty engineer; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t46/s15103/c/3/A/iii/III","parentIdentifier":"/us/usc/t46/s15103/c/3/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fiii%2FIII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t46/s15103/c/3/A/iii/III/aa","parentIdentifier":"/us/usc/t46/s15103/c/3/A/iii/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fiii%2FIII%2Faa","sourceRelease":"119-100","text":"1 shall represent labor; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t46/s15103/c/3/A/iii/III/bb","parentIdentifier":"/us/usc/t46/s15103/c/3/A/iii/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fiii%2FIII%2Fbb","sourceRelease":"119-100","text":"1 shall represent management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t46/s15103/c/3/A/iv","parentIdentifier":"/us/usc/t46/s15103/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fiv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t46/s15103/c/3/A/iv/I","parentIdentifier":"/us/usc/t46/s15103/c/3/A/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fiv%2FI","sourceRelease":"119-100","text":"1 shall represent able-bodied seamen; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t46/s15103/c/3/A/iv/II","parentIdentifier":"/us/usc/t46/s15103/c/3/A/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fiv%2FII","sourceRelease":"119-100","text":"1 shall represent qualified members of the engine department; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t46/s15103/c/3/A/v","parentIdentifier":"/us/usc/t46/s15103/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FA%2Fv","sourceRelease":"119-100","text":"1 shall be a pilot who represents merchant marine pilots.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s15103/c/3/B","parentIdentifier":"/us/usc/t46/s15103/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t46/s15103/c/3/B/i","parentIdentifier":"/us/usc/t46/s15103/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t46/s15103/c/3/B/i/I","parentIdentifier":"/us/usc/t46/s15103/c/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FB%2Fi%2FI","sourceRelease":"119-100","text":"2 shall represent State maritime academies (and are jointly recommended by such academies); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t46/s15103/c/3/B/i/II","parentIdentifier":"/us/usc/t46/s15103/c/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FB%2Fi%2FII","sourceRelease":"119-100","text":"1 shall represent either State maritime academies or the United States Merchant Marine Academy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t46/s15103/c/3/B/ii","parentIdentifier":"/us/usc/t46/s15103/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":"3 shall be marine educators who represent other maritime training institutions and, of the 3, 1 shall represent the small vessel industry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t46/s15103/c/3/C","parentIdentifier":"/us/usc/t46/s15103/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FC","sourceRelease":"119-100","text":"2 members shall represent shipping companies employed in ship operation management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t46/s15103/c/3/D","parentIdentifier":"/us/usc/t46/s15103/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15103%2Fc%2F3%2FD","sourceRelease":"119-100","text":"2 members shall represent the general public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
