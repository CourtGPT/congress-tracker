{"type":"section","nativeType":"section","number":"4331","heading":"Interagency Import Safety Working Group","label":"4331 Interagency Import Safety Working Group","identifier":"/us/usc/t19/s4331","parentIdentifier":"/us/usc/t19/ch28/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t19/s4331/a","parentIdentifier":"/us/usc/t19/s4331","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fa","sourceRelease":"119-100","text":"There is established an interagency Import Safety Working Group.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Membership","label":"b Membership","identifier":"/us/usc/t19/s4331/b","parentIdentifier":"/us/usc/t19/s4331","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4331/b/1","parentIdentifier":"/us/usc/t19/s4331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary of Homeland Security, who shall serve as the Chair.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4331/b/2","parentIdentifier":"/us/usc/t19/s4331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary of Health and Human Services, who shall serve as the Vice Chair.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s4331/b/3","parentIdentifier":"/us/usc/t19/s4331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fb%2F3","sourceRelease":"119-100","text":"The Secretary of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t19/s4331/b/4","parentIdentifier":"/us/usc/t19/s4331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fb%2F4","sourceRelease":"119-100","text":"The Secretary of Commerce.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t19/s4331/b/5","parentIdentifier":"/us/usc/t19/s4331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fb%2F5","sourceRelease":"119-100","text":"The Secretary of Agriculture.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t19/s4331/b/6","parentIdentifier":"/us/usc/t19/s4331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fb%2F6","sourceRelease":"119-100","text":"The United States Trade Representative.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t19/s4331/b/7","parentIdentifier":"/us/usc/t19/s4331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fb%2F7","sourceRelease":"119-100","text":"The Director of the Office of Management and Budget.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t19/s4331/b/8","parentIdentifier":"/us/usc/t19/s4331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fb%2F8","sourceRelease":"119-100","text":"The Commissioner of Food and Drugs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t19/s4331/b/9","parentIdentifier":"/us/usc/t19/s4331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fb%2F9","sourceRelease":"119-100","text":"The Commissioner of U.S. Customs and Border Protection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t19/s4331/b/10","parentIdentifier":"/us/usc/t19/s4331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fb%2F10","sourceRelease":"119-100","text":"The Chairman of the Consumer Product Safety Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t19/s4331/b/11","parentIdentifier":"/us/usc/t19/s4331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fb%2F11","sourceRelease":"119-100","text":"The Director of U.S. Immigration and Customs Enforcement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t19/s4331/b/12","parentIdentifier":"/us/usc/t19/s4331/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fb%2F12","sourceRelease":"119-100","text":"The head of any other Federal agency designated by the President to participate in the interagency Import Safety Working Group, as appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duties","label":"c Duties","identifier":"/us/usc/t19/s4331/c","parentIdentifier":"/us/usc/t19/s4331","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4331/c/1","parentIdentifier":"/us/usc/t19/s4331/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fc%2F1","sourceRelease":"119-100","text":"consulting on the development of the joint import safety rapid response plan required by ;section 4332 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4331/c/2","parentIdentifier":"/us/usc/t19/s4331/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s4331/c/2/A","parentIdentifier":"/us/usc/t19/s4331/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fc%2F2%2FA","sourceRelease":"119-100","text":"minimizing the duplication of efforts among Federal agencies the heads of which are members of the interagency Import Safety Working Group and ensuring the compatibility of the policies and regulations of those agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s4331/c/2/B","parentIdentifier":"/us/usc/t19/s4331/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fc%2F2%2FB","sourceRelease":"119-100","text":"recommending additional administrative actions, as appropriate, designed to ensure the safety of merchandise imported into the United States and the expeditious entry of such merchandise and considering the impact of those actions on private sector entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s4331/c/3","parentIdentifier":"/us/usc/t19/s4331/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fc%2F3","sourceRelease":"119-100","text":"reviewing the engagement and cooperation of foreign governments and foreign manufacturers in facilitating the inspection and certification, as appropriate, of such merchandise to be imported into the United States and the facilities producing such merchandise to ensure the safety of the merchandise and the expeditious entry of the merchandise into the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t19/s4331/c/4","parentIdentifier":"/us/usc/t19/s4331/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s4331/c/4/A","parentIdentifier":"/us/usc/t19/s4331/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fc%2F4%2FA","sourceRelease":"119-100","text":"the inspection of manufacturing facilities in foreign countries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s4331/c/4/B","parentIdentifier":"/us/usc/t19/s4331/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fc%2F4%2FB","sourceRelease":"119-100","text":"the inspection of merchandise destined for the United States before exportation from a foreign country or before distribution in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t19/s4331/c/4/C","parentIdentifier":"/us/usc/t19/s4331/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fc%2F4%2FC","sourceRelease":"119-100","text":"the protection of the international supply chain (as defined in );section 901 of title 6","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t19/s4331/c/5","parentIdentifier":"/us/usc/t19/s4331/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fc%2F5","sourceRelease":"119-100","text":"identifying best practices to assist Federal, State, and local governments and agencies, and port authorities, to improve communication and coordination among such agencies and authorities with respect to ensuring the safety of merchandise imported into the United States and the expeditious entry of such merchandise; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t19/s4331/c/6","parentIdentifier":"/us/usc/t19/s4331/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4331%2Fc%2F6","sourceRelease":"119-100","text":"otherwise identifying appropriate steps to increase the accountability of United States importers and the engagement of foreign government agencies with respect to ensuring the safety of merchandise imported into the United States and the expeditious entry of such merchandise.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
