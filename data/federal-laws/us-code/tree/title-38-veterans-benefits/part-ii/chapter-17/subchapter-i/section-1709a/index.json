{"type":"section","nativeType":"section","number":"1709A","heading":"Teleconsultation","label":"1709A Teleconsultation","identifier":"/us/usc/t38/s1709A","parentIdentifier":"/us/usc/t38/ptII/ch17/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709A","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Teleconsultation","label":"a .—Teleconsultation","identifier":"/us/usc/t38/s1709A/a","parentIdentifier":"/us/usc/t38/s1709A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709A%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1709A/a/1","parentIdentifier":"/us/usc/t38/s1709A/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709A%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary shall carry out an initiative of teleconsultation for the provision of remote mental health and traumatic brain injury assessments in facilities of the Department that are not otherwise able to provide such assessments without contracting with third-party providers or reimbursing providers through a fee basis system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1709A/a/2","parentIdentifier":"/us/usc/t38/s1709A/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709A%2Fa%2F2","sourceRelease":"119-100","text":"The Secretary shall, in consultation with appropriate professional societies, promulgate technical and clinical care standards for the use of teleconsultation services within facilities of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1709A/a/3","parentIdentifier":"/us/usc/t38/s1709A/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709A%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1709A/a/3/A","parentIdentifier":"/us/usc/t38/s1709A/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709A%2Fa%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t38/s1709A/a/3/A/i","parentIdentifier":"/us/usc/t38/s1709A/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709A%2Fa%2F3%2FA%2Fi","sourceRelease":"119-100","text":"such contracting or reimbursement; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t38/s1709A/a/3/A/ii","parentIdentifier":"/us/usc/t38/s1709A/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709A%2Fa%2F3%2FA%2Fii","sourceRelease":"119-100","text":"teleconsultation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1709A/a/3/B","parentIdentifier":"/us/usc/t38/s1709A/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709A%2Fa%2F3%2FB","sourceRelease":"119-100","text":"providing such assessment with such contracting or reimbursement is more clinically appropriate for the veteran than providing such assessment with teleconsultation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Teleconsultation Defined","label":"b .—Teleconsultation Defined","identifier":"/us/usc/t38/s1709A/b","parentIdentifier":"/us/usc/t38/s1709A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1709A%2Fb","sourceRelease":"119-100","text":"In this section, the term “teleconsultation” means the use by a health care specialist of telecommunications to assist another health care provider in rendering a diagnosis or treatment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
