{"type":"section","nativeType":"section","number":"78pp","heading":"Investor Advisory Committee","label":"78pp Investor Advisory Committee","identifier":"/us/usc/t15/s78pp","parentIdentifier":"/us/usc/t15/ch2B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2022—Subsec. (i). substituted “Chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text.Pub. L. 117–286","Statutory Notes and Related Subsidiaries","Effective DateSection effective 1 day after , except as otherwise provided, see , set out as a note under , Banks and Banking.July 21, 2010section 4 of Pub. L. 111–203section 5301 of Title 12"],"amendments":["Amendments2022—Subsec. (i). substituted “Chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text.Pub. L. 117–286"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment and purpose","label":"a Establishment and purpose","identifier":"/us/usc/t15/s78pp/a","parentIdentifier":"/us/usc/t15/s78pp","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t15/s78pp/a/1","parentIdentifier":"/us/usc/t15/s78pp/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fa%2F1","sourceRelease":"119-100","text":"There is established within the Commission the Investor Advisory Committee (referred to in this section as the “Committee”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Purpose","label":"2 Purpose","identifier":"/us/usc/t15/s78pp/a/2","parentIdentifier":"/us/usc/t15/s78pp/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s78pp/a/2/A","parentIdentifier":"/us/usc/t15/s78pp/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s78pp/a/2/A/i","parentIdentifier":"/us/usc/t15/s78pp/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"regulatory priorities of the Commission;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s78pp/a/2/A/ii","parentIdentifier":"/us/usc/t15/s78pp/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"issues relating to the regulation of securities products, trading strategies, and fee structures, and the effectiveness of disclosure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s78pp/a/2/A/iii","parentIdentifier":"/us/usc/t15/s78pp/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fa%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"initiatives to protect investor interest; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t15/s78pp/a/2/A/iv","parentIdentifier":"/us/usc/t15/s78pp/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fa%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"initiatives to promote investor confidence and the integrity of the securities marketplace; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s78pp/a/2/B","parentIdentifier":"/us/usc/t15/s78pp/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fa%2F2%2FB","sourceRelease":"119-100","text":"submit to the Commission such findings and recommendations as the Committee determines are appropriate, including recommendations for proposed legislative changes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Membership","label":"b Membership","identifier":"/us/usc/t15/s78pp/b","parentIdentifier":"/us/usc/t15/s78pp","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s78pp/b/1","parentIdentifier":"/us/usc/t15/s78pp/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s78pp/b/1/A","parentIdentifier":"/us/usc/t15/s78pp/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the Investor Advocate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s78pp/b/1/B","parentIdentifier":"/us/usc/t15/s78pp/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fb%2F1%2FB","sourceRelease":"119-100","text":"a representative of State securities commissions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s78pp/b/1/C","parentIdentifier":"/us/usc/t15/s78pp/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fb%2F1%2FC","sourceRelease":"119-100","text":"a representative of the interests of senior citizens; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s78pp/b/1/D","parentIdentifier":"/us/usc/t15/s78pp/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fb%2F1%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s78pp/b/1/D/i","parentIdentifier":"/us/usc/t15/s78pp/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fb%2F1%2FD%2Fi","sourceRelease":"119-100","text":"represent the interests of individual equity and debt investors, including investors in mutual funds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s78pp/b/1/D/ii","parentIdentifier":"/us/usc/t15/s78pp/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fb%2F1%2FD%2Fii","sourceRelease":"119-100","text":"represent the interests of institutional investors, including the interests of pension funds and registered investment companies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s78pp/b/1/D/iii","parentIdentifier":"/us/usc/t15/s78pp/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fb%2F1%2FD%2Fiii","sourceRelease":"119-100","text":"are knowledgeable about investment issues and decisions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t15/s78pp/b/1/D/iv","parentIdentifier":"/us/usc/t15/s78pp/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fb%2F1%2FD%2Fiv","sourceRelease":"119-100","text":"have reputations of integrity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Term","label":"2 Term","identifier":"/us/usc/t15/s78pp/b/2","parentIdentifier":"/us/usc/t15/s78pp/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fb%2F2","sourceRelease":"119-100","text":"Each member of the Committee appointed under paragraph (1)(B) shall serve for a term of 4 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Members not Commission employees","label":"3 Members not Commission employees","identifier":"/us/usc/t15/s78pp/b/3","parentIdentifier":"/us/usc/t15/s78pp/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fb%2F3","sourceRelease":"119-100","text":"Members appointed under paragraph (1)(B) shall not be deemed to be employees or agents of the Commission solely because of membership on the Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Chairman; vice chairman; secretary; assistant secretary","label":"c Chairman; vice chairman; secretary; assistant secretary","identifier":"/us/usc/t15/s78pp/c","parentIdentifier":"/us/usc/t15/s78pp","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s78pp/c/1","parentIdentifier":"/us/usc/t15/s78pp/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s78pp/c/1/A","parentIdentifier":"/us/usc/t15/s78pp/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fc%2F1%2FA","sourceRelease":"119-100","text":"a chairman, who may not be employed by an issuer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s78pp/c/1/B","parentIdentifier":"/us/usc/t15/s78pp/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fc%2F1%2FB","sourceRelease":"119-100","text":"a vice chairman, who may not be employed by an issuer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s78pp/c/1/C","parentIdentifier":"/us/usc/t15/s78pp/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fc%2F1%2FC","sourceRelease":"119-100","text":"a secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s78pp/c/1/D","parentIdentifier":"/us/usc/t15/s78pp/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fc%2F1%2FD","sourceRelease":"119-100","text":"an assistant secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Term","label":"2 Term","identifier":"/us/usc/t15/s78pp/c/2","parentIdentifier":"/us/usc/t15/s78pp/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fc%2F2","sourceRelease":"119-100","text":"Each member elected under paragraph (1) shall serve for a term of 3 years in the capacity for which the member was elected under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Meetings","label":"d Meetings","identifier":"/us/usc/t15/s78pp/d","parentIdentifier":"/us/usc/t15/s78pp","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Frequency of meetings","label":"1 Frequency of meetings","identifier":"/us/usc/t15/s78pp/d/1","parentIdentifier":"/us/usc/t15/s78pp/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s78pp/d/1/A","parentIdentifier":"/us/usc/t15/s78pp/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fd%2F1%2FA","sourceRelease":"119-100","text":"not less frequently than twice annually, at the call of the chairman of the Committee; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s78pp/d/1/B","parentIdentifier":"/us/usc/t15/s78pp/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fd%2F1%2FB","sourceRelease":"119-100","text":"from time to time, at the call of the Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Notice","label":"2 Notice","identifier":"/us/usc/t15/s78pp/d/2","parentIdentifier":"/us/usc/t15/s78pp/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fd%2F2","sourceRelease":"119-100","text":"The chairman of the Committee shall give the members of the Committee written notice of each meeting, not later than 2 weeks before the date of the meeting.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Compensation and travel expenses","label":"e Compensation and travel expenses","identifier":"/us/usc/t15/s78pp/e","parentIdentifier":"/us/usc/t15/s78pp","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s78pp/e/1","parentIdentifier":"/us/usc/t15/s78pp/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fe%2F1","sourceRelease":"119-100","text":"be entitled to receive compensation at a rate not to exceed the daily equivalent of the annual rate of basic pay in effect for a position at level V of the Executive Schedule under for each day during which the member is engaged in the actual performance of the duties of the Committee; andsection 5316 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s78pp/e/2","parentIdentifier":"/us/usc/t15/s78pp/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fe%2F2","sourceRelease":"119-100","text":"while away from the home or regular place of business of the member in the performance of services for the Committee, be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as persons employed intermittently in the Government service are allowed expenses under section 5703(b) of title 5.1So in original. does not contain a subsec. (b).1Section 5703 of Title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Staff","label":"f Staff","identifier":"/us/usc/t15/s78pp/f","parentIdentifier":"/us/usc/t15/s78pp","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Ff","sourceRelease":"119-100","text":"The Commission shall make available to the Committee such staff as the chairman of the Committee determines are necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Review by Commission","label":"g Review by Commission","identifier":"/us/usc/t15/s78pp/g","parentIdentifier":"/us/usc/t15/s78pp","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s78pp/g/1","parentIdentifier":"/us/usc/t15/s78pp/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fg%2F1","sourceRelease":"119-100","text":"review the findings and recommendations of the Committee; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s78pp/g/2","parentIdentifier":"/us/usc/t15/s78pp/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fg%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s78pp/g/2/A","parentIdentifier":"/us/usc/t15/s78pp/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fg%2F2%2FA","sourceRelease":"119-100","text":"assessing the finding or recommendation of the Committee; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s78pp/g/2/B","parentIdentifier":"/us/usc/t15/s78pp/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fg%2F2%2FB","sourceRelease":"119-100","text":"disclosing the action, if any, the Commission intends to take with respect to the finding or recommendation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Committee findings","label":"h Committee findings","identifier":"/us/usc/t15/s78pp/h","parentIdentifier":"/us/usc/t15/s78pp","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fh","sourceRelease":"119-100","text":"Nothing in this section shall require the Commission to agree to or act upon any finding or recommendation of the Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Chapter 10 of title 5","label":"i Chapter 10 of title 5","identifier":"/us/usc/t15/s78pp/i","parentIdentifier":"/us/usc/t15/s78pp","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fi","sourceRelease":"119-100","text":"Chapter 10 of title 5 shall not apply with respect to the Committee and its activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"j","heading":"Authorization of appropriations","label":"j Authorization of appropriations","identifier":"/us/usc/t15/s78pp/j","parentIdentifier":"/us/usc/t15/s78pp","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs78pp%2Fj","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Commission such sums as are necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
