{"type":"section","nativeType":"section","number":"1161v","heading":"Modeling and simulation","label":"1161v Modeling and simulation","identifier":"/us/usc/t20/s1161v","parentIdentifier":"/us/usc/t20/ch28/schIX/ptV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purpose; definition","label":"a Purpose; definition","identifier":"/us/usc/t20/s1161v/a","parentIdentifier":"/us/usc/t20/s1161v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Purpose","label":"1 Purpose","identifier":"/us/usc/t20/s1161v/a/1","parentIdentifier":"/us/usc/t20/s1161v/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161v/a/1/A","parentIdentifier":"/us/usc/t20/s1161v/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fa%2F1%2FA","sourceRelease":"119-100","text":"establishing a task force at the Department of Education to raise awareness of and define the study of modeling and simulation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161v/a/1/B","parentIdentifier":"/us/usc/t20/s1161v/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fa%2F1%2FB","sourceRelease":"119-100","text":"providing grants to institutions of higher education to develop new modeling and simulation degree programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161v/a/1/C","parentIdentifier":"/us/usc/t20/s1161v/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fa%2F1%2FC","sourceRelease":"119-100","text":"providing grants for institutions of higher education to enhance existing modeling and simulation degree programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Definition","label":"2 Definition","identifier":"/us/usc/t20/s1161v/a/2","parentIdentifier":"/us/usc/t20/s1161v/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fa%2F2","sourceRelease":"119-100","text":"In this section, the term “modeling and simulation” means a field of study related to the application of computer science and mathematics to develop a level of understanding of the interaction of the parts of a system and of a system as a whole.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment of task force","label":"b Establishment of task force","identifier":"/us/usc/t20/s1161v/b","parentIdentifier":"/us/usc/t20/s1161v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t20/s1161v/b/1","parentIdentifier":"/us/usc/t20/s1161v/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161v/b/1/A","parentIdentifier":"/us/usc/t20/s1161v/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F1%2FA","sourceRelease":"119-100","text":"helping to define the study of modeling and simulation (including the content of modeling and simulation classes and programs);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161v/b/1/B","parentIdentifier":"/us/usc/t20/s1161v/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F1%2FB","sourceRelease":"119-100","text":"identifying best practices for such study;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161v/b/1/C","parentIdentifier":"/us/usc/t20/s1161v/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F1%2FC","sourceRelease":"119-100","text":"identifying core knowledge and skills that individuals who participate in modeling and simulation programs should acquire; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1161v/b/1/D","parentIdentifier":"/us/usc/t20/s1161v/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F1%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1161v/b/1/D/i","parentIdentifier":"/us/usc/t20/s1161v/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F1%2FD%2Fi","sourceRelease":"119-100","text":"the information described in subparagraphs (A) through (C); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1161v/b/1/D/ii","parentIdentifier":"/us/usc/t20/s1161v/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F1%2FD%2Fii","sourceRelease":"119-100","text":"a system by which grants under this section will be distributed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Task force membership","label":"2 Task force membership","identifier":"/us/usc/t20/s1161v/b/2","parentIdentifier":"/us/usc/t20/s1161v/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161v/b/2/A","parentIdentifier":"/us/usc/t20/s1161v/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F2%2FA","sourceRelease":"119-100","text":"institutions of higher education with established modeling and simulation degree programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161v/b/2/B","parentIdentifier":"/us/usc/t20/s1161v/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the National Science Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161v/b/2/C","parentIdentifier":"/us/usc/t20/s1161v/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F2%2FC","sourceRelease":"119-100","text":"Federal Government agencies that use modeling and simulation extensively, including the Department of Defense, the National Institutes of Health, the Department of Homeland Security, the Department of Health and Human Services, the Department of Energy, and the Department of Transportation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1161v/b/2/D","parentIdentifier":"/us/usc/t20/s1161v/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F2%2FD","sourceRelease":"119-100","text":"private industries with a primary focus on modeling and simulation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s1161v/b/2/E","parentIdentifier":"/us/usc/t20/s1161v/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F2%2FE","sourceRelease":"119-100","text":"national modeling and simulation organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t20/s1161v/b/2/F","parentIdentifier":"/us/usc/t20/s1161v/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fb%2F2%2FF","sourceRelease":"119-100","text":"the Office of Science and Technology Policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Enhancing modeling and simulation at institutions of higher education","label":"c Enhancing modeling and simulation at institutions of higher education","identifier":"/us/usc/t20/s1161v/c","parentIdentifier":"/us/usc/t20/s1161v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Enhancement grants authorized","label":"1 Enhancement grants authorized","identifier":"/us/usc/t20/s1161v/c/1","parentIdentifier":"/us/usc/t20/s1161v/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t20/s1161v/c/1/A","parentIdentifier":"/us/usc/t20/s1161v/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F1%2FA","sourceRelease":"119-100","text":"The Secretary is authorized to award grants, on a competitive basis, to eligible institutions to enhance modeling and simulation degree programs at such eligible institutions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Duration of grant","label":"B Duration of grant","identifier":"/us/usc/t20/s1161v/c/1/B","parentIdentifier":"/us/usc/t20/s1161v/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F1%2FB","sourceRelease":"119-100","text":"A grant awarded under this subsection shall be awarded for a three-year period, and such grant period may be extended for not more than two years if the Secretary determines that an eligible institution has demonstrated success in enhancing the modeling and simulation degree program at such eligible institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Minimum grant amount","label":"C Minimum grant amount","identifier":"/us/usc/t20/s1161v/c/1/C","parentIdentifier":"/us/usc/t20/s1161v/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F1%2FC","sourceRelease":"119-100","text":"Subject to the availability of appropriations, a grant awarded to an eligible institution under this subsection shall not be less than $750,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Non-Federal share","label":"D Non-Federal share","identifier":"/us/usc/t20/s1161v/c/1/D","parentIdentifier":"/us/usc/t20/s1161v/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F1%2FD","sourceRelease":"119-100","text":"Each eligible institution receiving a grant under this subsection shall provide, from non-Federal sources, in cash or in-kind, an amount equal to 25 percent of the amount of the grant to carry out the activities supported by the grant. The Secretary may waive the non-Federal share requirement under this subparagraph for an eligible institution if the Secretary determines a waiver to be appropriate based on the financial ability of the institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible institutions","label":"2 Eligible institutions","identifier":"/us/usc/t20/s1161v/c/2","parentIdentifier":"/us/usc/t20/s1161v/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161v/c/2/A","parentIdentifier":"/us/usc/t20/s1161v/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F2%2FA","sourceRelease":"119-100","text":"has an established modeling and simulation degree program, including a major, minor, or career-track program; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161v/c/2/B","parentIdentifier":"/us/usc/t20/s1161v/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F2%2FB","sourceRelease":"119-100","text":"has an established modeling and simulation certificate or concentration program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Application","label":"3 Application","identifier":"/us/usc/t20/s1161v/c/3","parentIdentifier":"/us/usc/t20/s1161v/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161v/c/3/A","parentIdentifier":"/us/usc/t20/s1161v/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F3%2FA","sourceRelease":"119-100","text":"a letter from the president or provost of the eligible institution that demonstrates the institution’s commitment to the enhancement of the modeling and simulation program at the institution of higher education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161v/c/3/B","parentIdentifier":"/us/usc/t20/s1161v/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F3%2FB","sourceRelease":"119-100","text":"an identification of designated faculty responsible for the enhancement of the institution’s modeling and simulation program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161v/c/3/C","parentIdentifier":"/us/usc/t20/s1161v/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F3%2FC","sourceRelease":"119-100","text":"a detailed plan for how the grant funds will be used to enhance the modeling and simulation program of the institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Uses of funds","label":"4 Uses of funds","identifier":"/us/usc/t20/s1161v/c/4","parentIdentifier":"/us/usc/t20/s1161v/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161v/c/4/A","parentIdentifier":"/us/usc/t20/s1161v/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F4%2FA","sourceRelease":"119-100","text":"in the case of an institution that is eligible under paragraph (2)(B), activities to assist in the establishment of a major, minor, or career-track modeling and simulation program at the eligible institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161v/c/4/B","parentIdentifier":"/us/usc/t20/s1161v/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F4%2FB","sourceRelease":"119-100","text":"expanding the multidisciplinary nature of the institution’s modeling and simulation programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161v/c/4/C","parentIdentifier":"/us/usc/t20/s1161v/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F4%2FC","sourceRelease":"119-100","text":"recruiting students into the field of modeling and simulation through the provision of fellowships or assistantships;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1161v/c/4/D","parentIdentifier":"/us/usc/t20/s1161v/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F4%2FD","sourceRelease":"119-100","text":"creating new courses to complement existing courses and reflect emerging developments in the modeling and simulation field;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s1161v/c/4/E","parentIdentifier":"/us/usc/t20/s1161v/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F4%2FE","sourceRelease":"119-100","text":"conducting research to support new methodologies and techniques in modeling and simulation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t20/s1161v/c/4/F","parentIdentifier":"/us/usc/t20/s1161v/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fc%2F4%2FF","sourceRelease":"119-100","text":"purchasing equipment necessary for modeling and simulation programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Establishing modeling and simulation programs","label":"d Establishing modeling and simulation programs","identifier":"/us/usc/t20/s1161v/d","parentIdentifier":"/us/usc/t20/s1161v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment grants authorized","label":"1 Establishment grants authorized","identifier":"/us/usc/t20/s1161v/d/1","parentIdentifier":"/us/usc/t20/s1161v/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t20/s1161v/d/1/A","parentIdentifier":"/us/usc/t20/s1161v/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd%2F1%2FA","sourceRelease":"119-100","text":"The Secretary is authorized to award grants to institutions of higher education to establish a modeling and simulation program, including a major, minor, career-track, certificate, or concentration program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Duration of grant","label":"B Duration of grant","identifier":"/us/usc/t20/s1161v/d/1/B","parentIdentifier":"/us/usc/t20/s1161v/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd%2F1%2FB","sourceRelease":"119-100","text":"A grant awarded under this subsection shall be awarded for a three-year period, and such grant period may be extended for not more than two years if the Secretary determines that an eligible institution has demonstrated success in establishing a modeling and simulation degree program at such eligible institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Minimum grant amount","label":"C Minimum grant amount","identifier":"/us/usc/t20/s1161v/d/1/C","parentIdentifier":"/us/usc/t20/s1161v/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd%2F1%2FC","sourceRelease":"119-100","text":"Subject to the availability of appropriations, a grant awarded to an eligible institution under this subsection shall not be less than $750,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Non-Federal share","label":"D Non-Federal share","identifier":"/us/usc/t20/s1161v/d/1/D","parentIdentifier":"/us/usc/t20/s1161v/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd%2F1%2FD","sourceRelease":"119-100","text":"Each eligible institution receiving a grant under this subsection shall provide, from non-Federal sources, in cash or in-kind, an amount equal to 25 percent of the amount of the grant to carry out the activities supported by the grant. The Secretary may waive the non-Federal share requirement under this subparagraph for an eligible institution if the Secretary determines a waiver to be appropriate based on the financial ability of the institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Application","label":"2 Application","identifier":"/us/usc/t20/s1161v/d/2","parentIdentifier":"/us/usc/t20/s1161v/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161v/d/2/A","parentIdentifier":"/us/usc/t20/s1161v/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd%2F2%2FA","sourceRelease":"119-100","text":"a letter from the president or provost of the eligible institution that demonstrates the institution’s commitment to the establishment of a modeling and simulation program at the institution of higher education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161v/d/2/B","parentIdentifier":"/us/usc/t20/s1161v/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd%2F2%2FB","sourceRelease":"119-100","text":"a detailed plan for how the grant funds will be used to establish a modeling and simulation program at the institution; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161v/d/2/C","parentIdentifier":"/us/usc/t20/s1161v/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd%2F2%2FC","sourceRelease":"119-100","text":"a description of how the modeling and simulation program established under this subsection will complement existing programs and fit into the institution’s current program and course offerings.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Uses of funds","label":"3 Uses of funds","identifier":"/us/usc/t20/s1161v/d/3","parentIdentifier":"/us/usc/t20/s1161v/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161v/d/3/A","parentIdentifier":"/us/usc/t20/s1161v/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd%2F3%2FA","sourceRelease":"119-100","text":"establish, or work toward the establishment of, a modeling and simulation program, including a major, minor, career-track, certificate, or concentration program at the eligible institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161v/d/3/B","parentIdentifier":"/us/usc/t20/s1161v/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd%2F3%2FB","sourceRelease":"119-100","text":"provide adequate staffing to ensure the successful establishment of the modeling and simulation program, which may include the assignment of full-time dedicated or supportive faculty; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161v/d/3/C","parentIdentifier":"/us/usc/t20/s1161v/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fd%2F3%2FC","sourceRelease":"119-100","text":"purchase equipment necessary for a modeling and simulation program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t20/s1161v/e","parentIdentifier":"/us/usc/t20/s1161v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1161v/e/1","parentIdentifier":"/us/usc/t20/s1161v/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fe%2F1","sourceRelease":"119-100","text":"$1,000,000 is authorized to carry out the activities of the task force established pursuant to subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1161v/e/2","parentIdentifier":"/us/usc/t20/s1161v/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161v/e/2/A","parentIdentifier":"/us/usc/t20/s1161v/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fe%2F2%2FA","sourceRelease":"119-100","text":"50 percent is authorized to carry out the grant program under subsection (c); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161v/e/2/B","parentIdentifier":"/us/usc/t20/s1161v/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161v%2Fe%2F2%2FB","sourceRelease":"119-100","text":"50 percent is authorized to carry out the grant program under subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
