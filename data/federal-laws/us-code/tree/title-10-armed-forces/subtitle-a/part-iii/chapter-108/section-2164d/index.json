{"type":"section","nativeType":"section","number":"2164d","heading":"Limitation on school closures and certain other actions with respect to schools operated by the Department of Defense Education Activity","label":"2164d Limitation on school closures and certain other actions with respect to schools operated by the Department of Defense Education Activity","identifier":"/us/usc/t10/s2164d","parentIdentifier":"/us/usc/t10/stA/ptIII/ch108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2164d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Limitation","label":"a .—Limitation","identifier":"/us/usc/t10/s2164d/a","parentIdentifier":"/us/usc/t10/s2164d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2164d%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2164d/a/1","parentIdentifier":"/us/usc/t10/s2164d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2164d%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2164d/a/1/A","parentIdentifier":"/us/usc/t10/s2164d/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2164d%2Fa%2F1%2FA","sourceRelease":"119-100","text":"written notice of the intent of the Secretary to take such action with respect to such school;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2164d/a/1/B","parentIdentifier":"/us/usc/t10/s2164d/a/1","sourceUrl":"https://