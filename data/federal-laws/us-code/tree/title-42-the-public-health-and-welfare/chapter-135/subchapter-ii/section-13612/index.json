{"type":"section","nativeType":"section","number":"13612","heading":"Reservation of units for disabled families","label":"13612 Reservation of units for disabled families","identifier":"/us/usc/t42/s13612","parentIdentifier":"/us/usc/t42/ch135/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13612","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Requirement","label":"a Requirement","identifier":"/us/usc/t42/s13612/a","parentIdentifier":"/us/usc/t42/s13612","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13612%2Fa","sourceRelease":"119-100","text":"Notwithstanding any other provision of law, for any project for which an owner gives preference in occupancy to elderly families pursuant to , such owner shall (subject to sections 13613, 13614, and 13615 of this title) reserve units in the project for occupancy only by disabled families who are not elderly or near-elderly families (and who have applied for occupancy in the housing) in the number determined under subsection (b).section 13611 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Number of units","label":"b Number of units","identifier":"/us/usc/t42/s13612/b","parentIdentifier":"/us/usc/t42/s13612","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13612%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13612/b/1","parentIdentifier":"/us/usc/t42/s13612/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13612%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13612/b/1/A","parentIdentifier":"/us/usc/t42/s13612/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13612%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the percentage of units in the project that were occupied by such disabled families upon ; orOctober 28, 1992","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13612/b/1/B","parentIdentifier":"/us/usc/t42/s13612/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13612%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the percentage of units in the project that were occupied by such families upon ; orJanuary 1, 1992","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13612/b/2","parentIdentifier":"/us/usc/t42/s13612/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13612%2Fb%2F2","sourceRelease":"119-100","text":"10 percent of the number of units in the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
