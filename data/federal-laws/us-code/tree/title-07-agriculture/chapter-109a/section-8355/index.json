:null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Eligibility","label":"3 Eligibility","identifier":"/us/usc/t7/s8355/b/3","parentIdentifier":"/us/usc/t7/s8355/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s8355/b/3/A","parentIdentifier":"/us/usc/t7/s8355/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fb%2F3%2FA","sourceRelease":"119-100","text":"designate an appropriate agency of the State or Indian Tribe to administer the 1 or more programs supplemented by the grant funds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s8355/b/3/B","parentIdentifier":"/us/usc/t7/s8355/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fb%2F3%2FB","sourceRelease":"119-100","text":"establish 1 or more accounts to receive grant funds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s8355/b/3/C","parentIdentifier":"/us/usc/t7/s8355/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fb%2F3%2FC","sourceRelease":"119-100","text":"maintain files of all claims received and paid under grant-funded programs, including supporting documentation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s8355/b/3/D","parentIdentifier":"/us/usc/t7/s8355/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fb%2F3%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s8355/b/3/D/i","parentIdentifier":"/us/usc/t7/s8355/b/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fb%2F3%2FD%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s8355/b/3/D/i/I","parentIdentifier":"/us/usc/t7/s8355/b/3/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fb%2F3%2FD%2Fi%2FI","sourceRelease":"119-100","text":"a summary of claims and expenditures under the program during the year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s8355/b/3/D/i/II","parentIdentifier":"/us/usc/t7/s8355/b/3/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fb%2F3%2FD%2Fi%2FII","sourceRelease":"119-100","text":"a description of any action taken on the claims; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s8355/b/3/D/ii","parentIdentifier":"/us/usc/t7/s8355/b/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fb%2F3%2FD%2Fii","sourceRelease":"119-100","text":"such other reports as the Secretaries may require to assist the Secretaries in determining the effectiveness of assisted activities under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Sense of Congress","label":"c Sense of Congress","identifier":"/us/usc/t7/s8355/c","parentIdentifier":"/us/usc/t7/s8355","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s8355/c/1","parentIdentifier":"/us/usc/t7/s8355/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fc%2F1","sourceRelease":"119-100","text":"no State or Indian Tribe is required to participate in the program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s8355/c/2","parentIdentifier":"/us/usc/t7/s8355/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fc%2F2","sourceRelease":"119-100","text":"the program supplements, and does not replace or supplant, any State compensation programs for depredation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t7/s8355/d","parentIdentifier":"/us/usc/t7/s8355","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s8355/d/1","parentIdentifier":"/us/usc/t7/s8355/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fd%2F1","sourceRelease":"119-100","text":"$5,000,000 shall be used to provide grants for the purposes described in subsection (b)(1)(A); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s8355/d/2","parentIdentifier":"/us/usc/t7/s8355/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8355%2Fd%2F2","sourceRelease":"119-100","text":"$10,000,000 shall be used to provide grants for the purpose described in subsection (b)(1)(B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
