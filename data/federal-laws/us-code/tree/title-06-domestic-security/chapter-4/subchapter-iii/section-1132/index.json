{"type":"section","nativeType":"section","number":"1132","heading":"Findings","label":"1132 Findings","identifier":"/us/usc/t6/s1132","parentIdentifier":"/us/usc/t6/ch4/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1132","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s1132/1","parentIdentifier":"/us/usc/t6/s1132","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1132%2F1","sourceRelease":"119-100","text":"182 public transportation systems throughout the world have been primary targets of terrorist attacks;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s1132/2","parentIdentifier":"/us/usc/t6/s1132","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1132%2F2","sourceRelease":"119-100","text":"more than 6,000 public transportation agencies operate in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s1132/3","parentIdentifier":"/us/usc/t6/s1132","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1132%2F3","sourceRelease":"119-100","text":"people use public transportation vehicles 33,000,000 times each day;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s1132/4","parentIdentifier":"/us/usc/t6/s1132","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1132%2F4","sourceRelease":"119-100","text":"the Federal Transit Administration has invested $93,800,000,000 since 1992 for construction and improvements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s1132/5","parentIdentifier":"/us/usc/t6/s1132","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1132%2F5","sourceRelease":"119-100","text":"the Federal investment in transit security has been insufficient; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t6/s1132/6","parentIdentifier":"/us/usc/t6/s1132","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1132%2F6","sourceRelease":"119-100","text":"greater Federal investment in transit security improvements per passenger boarding is necessary to better protect the American people, given transit’s vital importance in creating mobility and promoting our Nation’s economy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
