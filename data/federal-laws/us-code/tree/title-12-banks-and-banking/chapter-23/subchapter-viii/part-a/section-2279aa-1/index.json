{"type":"section","nativeType":"section","number":"2279aa–1","heading":"Federal Agricultural Mortgage Corporation","label":"2279aa–1 Federal Agricultural Mortgage Corporation","identifier":"/us/usc/t12/s2279aa–1","parentIdentifier":"/us/usc/t12/ch23/schVIII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%931","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments1996—Subsec. (b)(4). added par. (4).Pub. L. 104–105"],"amendments":["Amendments1996—Subsec. (b)(4). added par. (4).Pub. L. 104–105"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t12/s2279aa–1/a","parentIdentifier":"/us/usc/t12/s2279aa–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%931%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t12/s2279aa–1/a/1","parentIdentifier":"/us/usc/t12/s2279aa–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%931%2Fa%2F1","sourceRelease":"119-100","text":"There is hereby established a corporation to be known as the Federal Agricultural Mortgage Corporation, which shall be a federally chartered instrumentality of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Institution within Farm Credit System","label":"2 Institution within Farm Credit System","identifier":"/us/usc/t12/s2279aa–1/a/2","parentIdentifier":"/us/usc/t12/s2279aa–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%931%2Fa%2F2","sourceRelease":"119-100","text":"The Corporation shall be an institution of the Farm Credit System.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Liability","label":"3 Liability","identifier":"/us/usc/t12/s2279aa–1/a/3","parentIdentifier":"/us/usc/t12/s2279aa–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%931%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Corporation","label":"A Corporation","identifier":"/us/usc/t12/s2279aa–1/a/3/A","parentIdentifier":"/us/usc/t12/s2279aa–1/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%931%2Fa%2F3%2FA","sourceRelease":"119-100","text":"The Corporation shall not be liable for any debt or obligation of any other institution of the Farm Credit System.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"System institutions","label":"B System institutions","identifier":"/us/usc/t12/s2279aa–1/a/3/B","parentIdentifier":"/us/usc/t12/s2279aa–1/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%931%2Fa%2F3%2FB","sourceRelease":"119-100","text":"The Farm Credit System and System institutions (other than the Corporation) shall not be liable for any debt or obligation of the Corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties","label":"b Duties","identifier":"/us/usc/t12/s2279aa–1/b","parentIdentifier":"/us/usc/t12/s2279aa–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%931%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s2279aa–1/b/1","parentIdentifier":"/us/usc/t12/s2279aa–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%931%2Fb%2F1","sourceRelease":"119-100","text":"in consultation with originators, develop uniform underwriting, security appraisal, and repayment standards for qualified loans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s2279aa–1/b/2","parentIdentifier":"/us/usc/t12/s2279aa–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%931%2Fb%2F2","sourceRelease":"119-100","text":"determine the eligibility of agricultural mortgage marketing facilities to contract with the Corporation for the provision of guarantees for specific mortgage pools;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t12/s2279aa–1/b/3","parentIdentifier":"/us/usc/t12/s2279aa–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%931%2Fb%2F3","sourceRelease":"119-100","text":"provide guarantees for the timely repayment of principal and interest on securities representing interests in, or obligations backed by, pools of qualified loans; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t12/s2279aa–1/b/4","parentIdentifier":"/us/usc/t12/s2279aa–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2279aa%E2%80%931%2Fb%2F4","sourceRelease":"119-100","text":"purchase qualified loans and issue securities representing interests in, or obligations backed by, the qualified loans, guaranteed for the timely repayment of principal and interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
