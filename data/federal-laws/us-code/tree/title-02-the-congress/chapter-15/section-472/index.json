{"type":"section","nativeType":"section","number":"472","heading":"Office of Technology Assessment","label":"472 Office of Technology Assessment","identifier":"/us/usc/t2/s472","parentIdentifier":"/us/usc/t2/ch15","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Creation","label":"a Creation","identifier":"/us/usc/t2/s472/a","parentIdentifier":"/us/usc/t2/s472","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fa","sourceRelease":"119-100","text":"In accordance with the findings and declaration of purpose in , there is hereby created the Office of Technology Assessment (hereinafter referred to as the “Office”) which shall be within and responsible to the legislative branch of the Government.section 471 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Composition","label":"b Composition","identifier":"/us/usc/t2/s472/b","parentIdentifier":"/us/usc/t2/s472","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fb","sourceRelease":"119-100","text":"The Office shall consist of a Technology Assessment Board (hereinafter referred to as the “Board”) which shall formulate and promulgate the policies of the Office, and a Director who shall carry out such policies and administer the operations of the Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Functions and duties","label":"c Functions and duties","identifier":"/us/usc/t2/s472/c","parentIdentifier":"/us/usc/t2/s472","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s472/c/1","parentIdentifier":"/us/usc/t2/s472/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fc%2F1","sourceRelease":"119-100","text":"identify existing or probable impacts of technology or technological programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s472/c/2","parentIdentifier":"/us/usc/t2/s472/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fc%2F2","sourceRelease":"119-100","text":"where possible, ascertain cause-and-effect relationships;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t2/s472/c/3","parentIdentifier":"/us/usc/t2/s472/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fc%2F3","sourceRelease":"119-100","text":"identify alternative technological methods of implementing specific programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t2/s472/c/4","parentIdentifier":"/us/usc/t2/s472/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fc%2F4","sourceRelease":"119-100","text":"identify alternative programs for achieving requisite goals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t2/s472/c/5","parentIdentifier":"/us/usc/t2/s472/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fc%2F5","sourceRelease":"119-100","text":"make estimates and comparisons of the impacts of alternative methods and programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t2/s472/c/6","parentIdentifier":"/us/usc/t2/s472/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fc%2F6","sourceRelease":"119-100","text":"present findings of completed analyses to the appropriate legislative authorities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t2/s472/c/7","parentIdentifier":"/us/usc/t2/s472/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fc%2F7","sourceRelease":"119-100","text":"identify areas where additional research or data collection is required to provide adequate support for the assessments and estimates described in paragraph (1) through (5) of this subsection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t2/s472/c/8","parentIdentifier":"/us/usc/t2/s472/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fc%2F8","sourceRelease":"119-100","text":"undertake such additional associated activities as the appropriate authorities specified under subsection (d) may direct.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Initiation of assessment activities","label":"d Initiation of assessment activities","identifier":"/us/usc/t2/s472/d","parentIdentifier":"/us/usc/t2/s472","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s472/d/1","parentIdentifier":"/us/usc/t2/s472/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fd%2F1","sourceRelease":"119-100","text":"the chairman of any standing, special, or select committee of either House of the Congress, or of any joint committee of the Congress, acting for himself or at the request of the ranking minority member or a majority of the committee members;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s472/d/2","parentIdentifier":"/us/usc/t2/s472/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fd%2F2","sourceRelease":"119-100","text":"the Board; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t2/s472/d/3","parentIdentifier":"/us/usc/t2/s472/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fd%2F3","sourceRelease":"119-100","text":"the Director, in consultation with the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Availability of information","label":"e Availability of information","identifier":"/us/usc/t2/s472/e","parentIdentifier":"/us/usc/t2/s472","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s472/e/1","parentIdentifier":"/us/usc/t2/s472/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fe%2F1","sourceRelease":"119-100","text":"to do so would violate security statutes; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s472/e/2","parentIdentifier":"/us/usc/t2/s472/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs472%2Fe%2F2","sourceRelease":"119-100","text":"the Board considers it necessary or advisable to withhold such information in accordance with one or more of the numbered paragraphs in .section 552(b) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
