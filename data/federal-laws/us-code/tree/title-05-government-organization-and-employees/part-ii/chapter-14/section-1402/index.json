{"type":"section","nativeType":"section","number":"1402","heading":"Authority and functions of agency Chief Human Capital Officers","label":"1402 Authority and functions of agency Chief Human Capital Officers","identifier":"/us/usc/t5/s1402","parentIdentifier":"/us/usc/t5/ptII/ch14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs1402","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s1402/a","parentIdentifier":"/us/usc/t5/s1402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs1402%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s1402/a/1","parentIdentifier":"/us/usc/t5/s1402/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs1402%2Fa%2F1","sourceRelease":"119-100","text":"setting the workforce development strategy of the agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s1402/a/2","parentIdentifier":"/us/usc/t5/s1402/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs1402%2Fa%2F2","sourceRelease":"119-100","text":"assessing workforce characteristics and future needs based on the agency’s mission and strategic plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s1402/a/3","parentIdentifier":"/us/usc/t5/s1402/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs1402%2Fa%2F3","sourceRelease":"119-100","text":"aligning the agency’s human resources policies and programs with