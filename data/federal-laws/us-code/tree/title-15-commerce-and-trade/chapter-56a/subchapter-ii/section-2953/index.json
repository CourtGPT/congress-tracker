{"type":"section","nativeType":"section","number":"2953","heading":"Global Change Research Information Office","label":"2953 Global Change Research Information Office","identifier":"/us/usc/t15/s2953","parentIdentifier":"/us/usc/t15/ch56A/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2953","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2953/1","parentIdentifier":"/us/usc/t15/s2953","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2953%2F1","sourceRelease":"119-100","text":"reducing energy consumption through conservation and energy efficiency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2953/2","parentIdentifier":"/us/usc/t15/s2953","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2953%2F2","sourceRelease":"119-100","text":"promoting the use of solar and renewable energy sources which reduce the amount of greenhouse gases released into the atmosphere;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s2953/3","parentIdentifier":"/us/usc/t15/s2953","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2953%2F3","sourceRelease":"119-100","text":"developing replacements for chlorofluorocarbons, halons, and other ozone-depleting substances which exhibit a significantly reduced potential for depleting stratospheric ozone;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s2953/4","parentIdentifier":"/us/usc/t15/s2953","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2953%2F4","sourceRelease":"119-100","text":"promoting the conservation of forest resources which help reduce the amount of carbon dioxide in the atmosphere;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s2953/5","parentIdentifier":"/us/usc/t15/s2953","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2953%2F5","sourceRelease":"119-100","text":"assisting developing countries in ecological pest management practices and in the proper use of agricultural, and industrial chemicals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s2953/6","parentIdentifier":"/us/usc/t15/s2953","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2953%2F6","sourceRelease":"119-100","text":"promoting recycling and source reduction of pollutants in order to reduce the volume of waste which must be disposed of, thus decreasing energy use and greenhouse gas emissions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
