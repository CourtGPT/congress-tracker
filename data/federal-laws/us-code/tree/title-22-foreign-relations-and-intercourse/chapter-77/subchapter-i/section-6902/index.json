{"type":"section","nativeType":"section","number":"6902","heading":"Policy","label":"6902 Policy","identifier":"/us/usc/t22/s6902","parentIdentifier":"/us/usc/t22/ch77/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s6902/1","parentIdentifier":"/us/usc/t22/s6902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F1","sourceRelease":"119-100","text":"to develop trade relations that broaden the benefits of trade, and lead to a leveling up, rather than a leveling down, of labor, environmental, commercial rule of law, market access, anticorruption, and other standards across national borders;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s6902/2","parentIdentifier":"/us/usc/t22/s6902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F2","sourceRelease":"119-100","text":"to pursue effective enforcement of trade-related and other international commitments by foreign governments through enforcement mechanisms of international organizations and through the application of United States law as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s6902/3","parentIdentifier":"/us/usc/t22/s6902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F3","sourceRelease":"119-100","text":"to encourage foreign governments to conduct both commercial and noncommercial affairs according to the rule of law developed through democratic processes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s6902/4","parentIdentifier":"/us/usc/t22/s6902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F4","sourceRelease":"119-100","text":"to encourage the Government of the People’s Republic of China to afford its workers internationally recognized worker rights;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s6902/5","parentIdentifier":"/us/usc/t22/s6902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s6902/5/A","parentIdentifier":"/us/usc/t22/s6902/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F5%2FA","sourceRelease":"119-100","text":"ratifying the International Covenant on Civil and Political Rights;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s6902/5/B","parentIdentifier":"/us/usc/t22/s6902/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F5%2FB","sourceRelease":"119-100","text":"protecting the right to liberty of movement and freedom to choose a residence within the People’s Republic of China and the right to leave from and return to the People’s Republic of China; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s6902/5/C","parentIdentifier":"/us/usc/t22/s6902/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F5%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s6902/5/C/i","parentIdentifier":"/us/usc/t22/s6902/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F5%2FC%2Fi","sourceRelease":"119-100","text":"the right to be tried in his or her presence, and to defend himself or herself in person or through legal assistance of his or her own choosing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s6902/5/C/ii","parentIdentifier":"/us/usc/t22/s6902/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F5%2FC%2Fii","sourceRelease":"119-100","text":"the right to be informed, if he or she does not have legal assistance, of the right set forth in clause (i);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t22/s6902/5/C/iii","parentIdentifier":"/us/usc/t22/s6902/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F5%2FC%2Fiii","sourceRelease":"119-100","text":"the right to have legal assistance assigned to him or her in any case in which the interests of justice so require and without payment by him or her in any such case if he or she does not have sufficient means to pay for it;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t22/s6902/5/C/iv","parentIdentifier":"/us/usc/t22/s6902/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F5%2FC%2Fiv","sourceRelease":"119-100","text":"the right to a fair and public hearing by a competent, independent, and impartial tribunal established by the law;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t22/s6902/5/C/v","parentIdentifier":"/us/usc/t22/s6902/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F5%2FC%2Fv","sourceRelease":"119-100","text":"the right to be presumed innocent until proved guilty according to law; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t22/s6902/5/C/vi","parentIdentifier":"/us/usc/t22/s6902/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F5%2FC%2Fvi","sourceRelease":"119-100","text":"the right to be tried without undue delay; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s6902/6","parentIdentifier":"/us/usc/t22/s6902","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6902%2F6","sourceRelease":"119-100","text":"to highlight in the United Nations Human Rights Commission and in other appropriate fora violations of human rights by foreign governments and to seek the support of other governments in urging improvements in human rights practices.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
