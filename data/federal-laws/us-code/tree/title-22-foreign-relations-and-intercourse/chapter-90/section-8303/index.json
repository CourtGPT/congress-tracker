{"type":"section","nativeType":"section","number":"8303","heading":"Office of Volunteers for Prosperity","label":"8303 Office of Volunteers for Prosperity","identifier":"/us/usc/t22/s8303","parentIdentifier":"/us/usc/t22/ch90","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , see , set out as an Effective Date of 2009 Amendment note under , The Public Health and Welfare.Oct. 1, 2009section 6101(a) of Pub. L. 111–13section 4950 of Title 42"],"amendments":["Effective DateSection effective , see , set out as an Effective Date of 2009 Amendment note under , The Public Health and Welfare.Oct. 1, 2009section 6101(a) of Pub. L. 111–13section 4950 of Title 42"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Functions","label":"a Functions","identifier":"/us/usc/t22/s8303/a","parentIdentifier":"/us/usc/t22/s8303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s8303/a/1","parentIdentifier":"/us/usc/t22/s8303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fa%2F1","sourceRelease":"119-100","text":"implementing the VfPServe Program to provide eligible skilled professionals with matching grants to offset the travel and living expenses of volunteering abroad with nonprofit organizations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s8303/a/2","parentIdentifier":"/us/usc/t22/s8303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fa%2F2","sourceRelease":"119-100","text":"otherwise promoting short- and long-term international volunteer service by skilled American professionals, including connecting such professionals with nonprofit organizations, to achieve such objectives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s8303/a/3","parentIdentifier":"/us/usc/t22/s8303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fa%2F3","sourceRelease":"119-100","text":"helping nonprofit organizations in the United States recruit and effectively manage additional skilled American professionals for volunteer assignments throughout the developing world;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s8303/a/4","parentIdentifier":"/us/usc/t22/s8303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fa%2F4","sourceRelease":"119-100","text":"providing recognition for skilled American volunteers and the organizations deploying them;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s8303/a/5","parentIdentifier":"/us/usc/t22/s8303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fa%2F5","sourceRelease":"119-100","text":"helping nonprofit organizations and corporations in the United States to identify resources and opportunities in international volunteer service utilizing skilled Americans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s8303/a/6","parentIdentifier":"/us/usc/t22/s8303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fa%2F6","sourceRelease":"119-100","text":"encouraging the establishment of international volunteer programs for employees of United States corporations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t22/s8303/a/7","parentIdentifier":"/us/usc/t22/s8303/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fa%2F7","sourceRelease":"119-100","text":"encouraging international voluntary service by highly skilled Americans to promote health and prosperity throughout the world.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"VfP Program objectives","label":"b VfP Program objectives","identifier":"/us/usc/t22/s8303/b","parentIdentifier":"/us/usc/t22/s8303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s8303/b/1","parentIdentifier":"/us/usc/t22/s8303/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fb%2F1","sourceRelease":"119-100","text":"eliminating extreme poverty;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s8303/b/2","parentIdentifier":"/us/usc/t22/s8303/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fb%2F2","sourceRelease":"119-100","text":"reducing world hunger and malnutrition;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s8303/b/3","parentIdentifier":"/us/usc/t22/s8303/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fb%2F3","sourceRelease":"119-100","text":"increasing access to safe potable water;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s8303/b/4","parentIdentifier":"/us/usc/t22/s8303/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fb%2F4","sourceRelease":"119-100","text":"enacting universal education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s8303/b/5","parentIdentifier":"/us/usc/t22/s8303/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fb%2F5","sourceRelease":"119-100","text":"reducing child mortality and childhood diseases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s8303/b/6","parentIdentifier":"/us/usc/t22/s8303/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fb%2F6","sourceRelease":"119-100","text":"combating the spread of preventable diseases, including HIV, malaria, and tuberculosis;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t22/s8303/b/7","parentIdentifier":"/us/usc/t22/s8303/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fb%2F7","sourceRelease":"119-100","text":"providing educational and work skill support for girls and empowering women to achieve independence;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t22/s8303/b/8","parentIdentifier":"/us/usc/t22/s8303/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fb%2F8","sourceRelease":"119-100","text":"creating sustainable business and entrepreneurial opportunities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t22/s8303/b/9","parentIdentifier":"/us/usc/t22/s8303/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fb%2F9","sourceRelease":"119-100","text":"increasing access to information technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Volunteers for Prosperity Service Incentive Program","label":"c Volunteers for Prosperity Service Incentive Program","identifier":"/us/usc/t22/s8303/c","parentIdentifier":"/us/usc/t22/s8303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s8303/c/1","parentIdentifier":"/us/usc/t22/s8303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s8303/c/1/A","parentIdentifier":"/us/usc/t22/s8303/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fc%2F1%2FA","sourceRelease":"119-100","text":"has members who possess skills relevant to addressing any objective described in subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s8303/c/1/B","parentIdentifier":"/us/usc/t22/s8303/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s8303/c/1/B/i","parentIdentifier":"/us/usc/t22/s8303/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"through the organization with which the individual is serving; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s8303/c/1/B/ii","parentIdentifier":"/us/usc/t22/s8303/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"by raising private funds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Nondiscrimination requirement","label":"2 Nondiscrimination requirement","identifier":"/us/usc/t22/s8303/c/2","parentIdentifier":"/us/usc/t22/s8303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fc%2F2","sourceRelease":"119-100","text":"The VfP Office may not provide a stipend to an individual under paragraph (1) unless the nonprofit organization to which the individual is assigned has certified to the VfP Office that it does not discriminate with respect to any project or activity receiving Federal financial assistance, including a stipend under this chapter, because of race, religion, color, national origin, sex, political affiliation, or beliefs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Compliance with ineligible service categories","label":"3 Compliance with ineligible service categories","identifier":"/us/usc/t22/s8303/c/3","parentIdentifier":"/us/usc/t22/s8303/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s8303/c/3/A","parentIdentifier":"/us/usc/t22/s8303/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fc%2F3%2FA","sourceRelease":"119-100","text":"business organized for profit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s8303/c/3/B","parentIdentifier":"/us/usc/t22/s8303/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fc%2F3%2FB","sourceRelease":"119-100","text":"labor union;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s8303/c/3/C","parentIdentifier":"/us/usc/t22/s8303/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fc%2F3%2FC","sourceRelease":"119-100","text":"partisan political organization; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s8303/c/3/D","parentIdentifier":"/us/usc/t22/s8303/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fc%2F3%2FD","sourceRelease":"119-100","text":"religious or faith-based organization for the purpose of proselytization, worship or any other explicitly religious activity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Funding","label":"d Funding","identifier":"/us/usc/t22/s8303/d","parentIdentifier":"/us/usc/t22/s8303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s8303/d/1","parentIdentifier":"/us/usc/t22/s8303/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fd%2F1","sourceRelease":"119-100","text":"The Administrator of the United States Agency for International Development shall make available the amounts appropriated pursuant to to the VfP Office to pursue the objectives described in subsection (b) by carrying out the functions described in subsection (a).section 8304 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Use of funds","label":"2 Use of funds","identifier":"/us/usc/t22/s8303/d/2","parentIdentifier":"/us/usc/t22/s8303/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fd%2F2","sourceRelease":"119-100","text":"Amounts made available under paragraph (1) may be used by the VfP Office to provide personnel and other resources to develop, manage, and expand the VfP Program, under the supervision of the United States Agency for International Development.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Coordination","label":"e Coordination","identifier":"/us/usc/t22/s8303/e","parentIdentifier":"/us/usc/t22/s8303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Fe","sourceRelease":"119-100","text":"The VfP Office shall coordinate its efforts with other public and private efforts that aim to send skilled professionals to serve in developing nations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Report","label":"f Report","identifier":"/us/usc/t22/s8303/f","parentIdentifier":"/us/usc/t22/s8303","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8303%2Ff","sourceRelease":"119-100","text":"The VfP Office shall submit an annual report to Congress on the activities of the VfP Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
