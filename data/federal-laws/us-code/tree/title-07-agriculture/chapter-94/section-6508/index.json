{"type":"section","nativeType":"section","number":"6508","heading":"Prohibited crop production practices and materials","label":"6508 Prohibited crop production practices and materials","identifier":"/us/usc/t7/s6508","parentIdentifier":"/us/usc/t7/ch94","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6508","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Seed, seedlings and planting practices","label":"a Seed, seedlings and planting practices","identifier":"/us/usc/t7/s6508/a","parentIdentifier":"/us/usc/t7/s6508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6508%2Fa","sourceRelease":"119-100","text":"For a farm to be certified under this chapter, producers on such farm shall not apply materials to, or engage in practices on, seeds or seedlings that are contrary to, or inconsistent with, the applicable organic certification program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Soil amendments","label":"b Soil amendments","identifier":"/us/usc/t7/s6508/b","parentIdentifier":"/us/usc/t7/s6508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6508%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s6508/b/1","parentIdentifier":"/us/usc/t7/s6508/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6508%2Fb%2F1","sourceRelease":"119-100","text":"use any fertilizers containing synthetic ingredients or any commercially blended fertilizers containing materials prohibited under this chapter or under the applicable State organic certification program; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s6508/b/2","parentIdentifier":"/us/usc/t7/s6508/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6508%2Fb%2F2","sourceRelease":"119-100","text":"use as a source of nitrogen: phosphorous, lime, potash, or any materials that are inconsistent with the applicable organic certification program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Crop management","label":"c Crop management","identifier":"/us/usc/t7/s6508/c","parentIdentifier":"/us/usc/t7/s6508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6508%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s6508/c/1","parentIdentifier":"/us/usc/t7/s6508/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6508%2Fc%2F1","sourceRelease":"119-100","text":"use natural poisons such as arsenic or lead salts that have long-term effects and persist in the environment, as determined by the applicable governing State official or the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s6508/c/2","parentIdentifier":"/us/usc/t7/s6508/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6508%2Fc%2F2","sourceRelease":"119-100","text":"use plastic mulches, unless such mulches are removed at the end of each growing or harvest season; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s6508/c/3","parentIdentifier":"/us/usc/t7/s6508/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6508%2Fc%2F3","sourceRelease":"119-100","text":"use transplants that are treated with any synthetic or prohibited material.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
