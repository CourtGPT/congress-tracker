null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t43/s390h–34/a/2/C","parentIdentifier":"/us/usc/t43/s390h–34/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fa%2F2%2FC","sourceRelease":"119-100","text":"water reclamation and reuse;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t43/s390h–34/a/2/D","parentIdentifier":"/us/usc/t43/s390h–34/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fa%2F2%2FD","sourceRelease":"119-100","text":"groundwater recharge and protection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t43/s390h–34/a/2/E","parentIdentifier":"/us/usc/t43/s390h–34/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fa%2F2%2FE","sourceRelease":"119-100","text":"surface water augmentation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t43/s390h–34/a/2/F","parentIdentifier":"/us/usc/t43/s390h–34/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fa%2F2%2FF","sourceRelease":"119-100","text":"other related improvements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"State","label":"3 State","identifier":"/us/usc/t43/s390h–34/a/3","parentIdentifier":"/us/usc/t43/s390h–34/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fa%2F3","sourceRelease":"119-100","text":"The term “State” means the State of California.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"North Bay Water Reuse Program","label":"b North Bay Water Reuse Program","identifier":"/us/usc/t43/s390h–34/b","parentIdentifier":"/us/usc/t43/s390h–34","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s390h–34/b/1","parentIdentifier":"/us/usc/t43/s390h–34/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F1","sourceRelease":"119-100","text":"Contingent upon a finding of feasibility, the Secretary, acting through a cooperative agreement with the State or a subdivision of the State, is authorized to enter into cooperative agreements with eligible entities for the planning, design, and construction of water reclamation and reuse facilities and recycled water conveyance and distribution systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Coordination with other Federal agencies","label":"2 Coordination with other Federal agencies","identifier":"/us/usc/t43/s390h–34/b/2","parentIdentifier":"/us/usc/t43/s390h–34/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s390h–34/b/2/A","parentIdentifier":"/us/usc/t43/s390h–34/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F2%2FA","sourceRelease":"119-100","text":"non-Federal entities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s390h–34/b/2/B","parentIdentifier":"/us/usc/t43/s390h–34/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the Corps of Engineers in the San Pablo Bay Watershed of the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Phased project","label":"3 Phased project","identifier":"/us/usc/t43/s390h–34/b/3","parentIdentifier":"/us/usc/t43/s390h–34/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"First phase","label":"A First phase","identifier":"/us/usc/t43/s390h–34/b/3/A","parentIdentifier":"/us/usc/t43/s390h–34/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F3%2FA","sourceRelease":"119-100","text":"During the first phase, the Secretary and an eligible entity shall complete the planning, design, and construction of the main treatment and main conveyance systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Second phase","label":"B Second phase","identifier":"/us/usc/t43/s390h–34/b/3/B","parentIdentifier":"/us/usc/t43/s390h–34/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F3%2FB","sourceRelease":"119-100","text":"During the second phase, the Secretary and an eligible entity shall complete the planning, design, and construction of the sub-regional distribution systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Cost sharing","label":"4 Cost sharing","identifier":"/us/usc/t43/s390h–34/b/4","parentIdentifier":"/us/usc/t43/s390h–34/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Federal share","label":"A Federal share","identifier":"/us/usc/t43/s390h–34/b/4/A","parentIdentifier":"/us/usc/t43/s390h–34/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F4%2FA","sourceRelease":"119-100","text":"The Federal share of the cost of the first phase of the project authorized by this section shall not exceed 25 percent of the total cost of the first phase of the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Form of non-Federal share","label":"B Form of non-Federal share","identifier":"/us/usc/t43/s390h–34/b/4/B","parentIdentifier":"/us/usc/t43/s390h–34/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s390h–34/b/4/B/i","parentIdentifier":"/us/usc/t43/s390h–34/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F4%2FB%2Fi","sourceRelease":"119-100","text":"reasonable costs incurred by the eligible entity relating to the planning, design, and construction of the water reclamation and reuse project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s390h–34/b/4/B/ii","parentIdentifier":"/us/usc/t43/s390h–34/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F4%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s390h–34/b/4/B/ii/I","parentIdentifier":"/us/usc/t43/s390h–34/b/4/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F4%2FB%2Fii%2FI","sourceRelease":"119-100","text":"used for planning, design, and construction of the water reclamation and reuse project facilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s390h–34/b/4/B/ii/II","parentIdentifier":"/us/usc/t43/s390h–34/b/4/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F4%2FB%2Fii%2FII","sourceRelease":"119-100","text":"owned by an eligible entity and directly related to the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Limitation","label":"C Limitation","identifier":"/us/usc/t43/s390h–34/b/4/C","parentIdentifier":"/us/usc/t43/s390h–34/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F4%2FC","sourceRelease":"119-100","text":"The Secretary shall not provide funds for the operation and maintenance of the project authorized by this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Effect","label":"5 Effect","identifier":"/us/usc/t43/s390h–34/b/5","parentIdentifier":"/us/usc/t43/s390h–34/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s390h–34/b/5/A","parentIdentifier":"/us/usc/t43/s390h–34/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F5%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s390h–34/b/5/A/i","parentIdentifier":"/us/usc/t43/s390h–34/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F5%2FA%2Fi","sourceRelease":"119-100","text":"State water law; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s390h–34/b/5/A/ii","parentIdentifier":"/us/usc/t43/s390h–34/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F5%2FA%2Fii","sourceRelease":"119-100","text":"an interstate compact relating to the allocation of water; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s390h–34/b/5/B","parentIdentifier":"/us/usc/t43/s390h–34/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F5%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s390h–34/b/5/B/i","parentIdentifier":"/us/usc/t43/s390h–34/b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F5%2FB%2Fi","sourceRelease":"119-100","text":"the water of a stream; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s390h–34/b/5/B/ii","parentIdentifier":"/us/usc/t43/s390h–34/b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F5%2FB%2Fii","sourceRelease":"119-100","text":"any groundwater resource.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Authorization of appropriations","label":"6 Authorization of appropriations","identifier":"/us/usc/t43/s390h–34/b/6","parentIdentifier":"/us/usc/t43/s390h–34/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390h%E2%80%9334%2Fb%2F6","sourceRelease":"119-100","text":"There is authorized to be appropriated for the Federal share of the total cost of the first phase of the project authorized by this section $25,000,000, to remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
