{"type":"section","nativeType":"section","number":"1275","heading":"Columbia River Basin Restoration","label":"1275 Columbia River Basin Restoration","identifier":"/us/usc/t33/s1275","parentIdentifier":"/us/usc/t33/ch26/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2018—Subsec. (d)(6). added par. (6).Pub. L. 115–270"],"amendments":["Amendments2018—Subsec. (d)(6). added par. (6).Pub. L. 115–270"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t33/s1275/a","parentIdentifier":"/us/usc/t33/s1275","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Columbia River Basin","label":"1 Columbia River Basin","identifier":"/us/usc/t33/s1275/a/1","parentIdentifier":"/us/usc/t33/s1275/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fa%2F1","sourceRelease":"119-100","text":"The term “Columbia River Basin” means the entire United States portion of the Columbia River watershed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Estuary Partnership","label":"2 Estuary Partnership","identifier":"/us/usc/t33/s1275/a/2","parentIdentifier":"/us/usc/t33/s1275/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fa%2F2","sourceRelease":"119-100","text":"The term “Estuary Partnership” means the Lower Columbia Estuary Partnership, an entity created by the States of Oregon and Washington and the Environmental Protection Agency under .section 1330 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Estuary Plan","label":"3 Estuary Plan","identifier":"/us/usc/t33/s1275/a/3","parentIdentifier":"/us/usc/t33/s1275/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t33/s1275/a/3/A","parentIdentifier":"/us/usc/t33/s1275/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fa%2F3%2FA","sourceRelease":"119-100","text":"The term “Estuary Plan” means the Estuary Partnership Comprehensive Conservation and Management Plan adopted by the Environmental Protection Agency and the Governors of Oregon and Washington on , under .October 20, 1999section 1330 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Inclusion","label":"B Inclusion","identifier":"/us/usc/t33/s1275/a/3/B","parentIdentifier":"/us/usc/t33/s1275/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fa%2F3%2FB","sourceRelease":"119-100","text":"The term “Estuary Plan” includes any amendments to the plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Lower Columbia River Estuary","label":"4 Lower Columbia River Estuary","identifier":"/us/usc/t33/s1275/a/4","parentIdentifier":"/us/usc/t33/s1275/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fa%2F4","sourceRelease":"119-100","text":"The term “Lower Columbia River Estuary” means the mainstem Columbia River from the Bonneville Dam to the Pacific Ocean and tidally influenced portions of tributaries to the Columbia River in that region.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Middle and Upper Columbia River Basin","label":"5 Middle and Upper Columbia River Basin","identifier":"/us/usc/t33/s1275/a/5","parentIdentifier":"/us/usc/t33/s1275/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fa%2F5","sourceRelease":"119-100","text":"The term “Middle and Upper Columbia River Basin” means the region consisting of the United States portion of the Columbia River Basin above Bonneville Dam.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Program","label":"6 Program","identifier":"/us/usc/t33/s1275/a/6","parentIdentifier":"/us/usc/t33/s1275/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fa%2F6","sourceRelease":"119-100","text":"The term “Program” means the Columbia River Basin Restoration Program established under subsection (b)(1)(A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Columbia River Basin Restoration Program","label":"b Columbia River Basin Restoration Program","identifier":"/us/usc/t33/s1275/b","parentIdentifier":"/us/usc/t33/s1275","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t33/s1275/b/1","parentIdentifier":"/us/usc/t33/s1275/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t33/s1275/b/1/A","parentIdentifier":"/us/usc/t33/s1275/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F1%2FA","sourceRelease":"119-100","text":"The Administrator shall establish within the Environmental Protection Agency a Columbia River Basin Restoration Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Effect","label":"B Effect","identifier":"/us/usc/t33/s1275/b/1/B","parentIdentifier":"/us/usc/t33/s1275/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s1275/b/1/B/i","parentIdentifier":"/us/usc/t33/s1275/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"The establishment of the Program does not modify any legal or regulatory authority or program in effect as of , including the roles of Federal agencies in the Columbia River Basin.December 16, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s1275/b/1/B/ii","parentIdentifier":"/us/usc/t33/s1275/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"This section does not create any new regulatory authority.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Scope of Program","label":"2 Scope of Program","identifier":"/us/usc/t33/s1275/b/2","parentIdentifier":"/us/usc/t33/s1275/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F2","sourceRelease":"119-100","text":"The Program shall consist of a collaborative stakeholder-based program for environmental protection and restoration activities throughout the Columbia River Basin.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Duties","label":"3 Duties","identifier":"/us/usc/t33/s1275/b/3","parentIdentifier":"/us/usc/t33/s1275/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1275/b/3/A","parentIdentifier":"/us/usc/t33/s1275/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F3%2FA","sourceRelease":"119-100","text":"assess trends in water quality, including trends that affect uses of the water of the Columbia River Basin;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1275/b/3/B","parentIdentifier":"/us/usc/t33/s1275/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F3%2FB","sourceRelease":"119-100","text":"collect, characterize, and assess data on water quality to identify possible causes of environmental problems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s1275/b/3/C","parentIdentifier":"/us/usc/t33/s1275/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s1275/b/3/C/i","parentIdentifier":"/us/usc/t33/s1275/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F3%2FC%2Fi","sourceRelease":"119-100","text":"eliminating or reducing pollution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s1275/b/3/C/ii","parentIdentifier":"/us/usc/t33/s1275/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F3%2FC%2Fii","sourceRelease":"119-100","text":"cleaning up contaminated sites;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t33/s1275/b/3/C/iii","parentIdentifier":"/us/usc/t33/s1275/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F3%2FC%2Fiii","sourceRelease":"119-100","text":"improving water quality;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t33/s1275/b/3/C/iv","parentIdentifier":"/us/usc/t33/s1275/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F3%2FC%2Fiv","sourceRelease":"119-100","text":"monitoring to evaluate trends;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t33/s1275/b/3/C/v","parentIdentifier":"/us/usc/t33/s1275/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F3%2FC%2Fv","sourceRelease":"119-100","text":"reducing runoff;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t33/s1275/b/3/C/vi","parentIdentifier":"/us/usc/t33/s1275/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F3%2FC%2Fvi","sourceRelease":"119-100","text":"protecting habitat; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t33/s1275/b/3/C/vii","parentIdentifier":"/us/usc/t33/s1275/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fb%2F3%2FC%2Fvii","sourceRelease":"119-100","text":"promoting citizen engagement or knowledge.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Stakeholder Working Group","label":"c Stakeholder Working Group","identifier":"/us/usc/t33/s1275/c","parentIdentifier":"/us/usc/t33/s1275","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t33/s1275/c/1","parentIdentifier":"/us/usc/t33/s1275/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F1","sourceRelease":"119-100","text":"The Administrator shall establish a Columbia River Basin Restoration Working Group (referred to in this subsection as the “Working Group”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Membership","label":"2 Membership","identifier":"/us/usc/t33/s1275/c/2","parentIdentifier":"/us/usc/t33/s1275/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t33/s1275/c/2/A","parentIdentifier":"/us/usc/t33/s1275/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2%2FA","sourceRelease":"119-100","text":"Membership in the Working Group shall be on a voluntary basis and any person invited by the Administrator under this subsection may decline membership.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Invited representatives","label":"B Invited representatives","identifier":"/us/usc/t33/s1275/c/2/B","parentIdentifier":"/us/usc/t33/s1275/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s1275/c/2/B/i","parentIdentifier":"/us/usc/t33/s1275/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"each State located in whole or in part in the Columbia River Basin;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s1275/c/2/B/ii","parentIdentifier":"/us/usc/t33/s1275/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the Governors of each State located in whole or in part in the Columbia River Basin;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t33/s1275/c/2/B/iii","parentIdentifier":"/us/usc/t33/s1275/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"each federally recognized Indian tribe in the Columbia River Basin;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t33/s1275/c/2/B/iv","parentIdentifier":"/us/usc/t33/s1275/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"local governments in the Columbia River Basin;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t33/s1275/c/2/B/v","parentIdentifier":"/us/usc/t33/s1275/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2%2FB%2Fv","sourceRelease":"119-100","text":"industries operating in the Columbia River Basin that affect or could affect water quality;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t33/s1275/c/2/B/vi","parentIdentifier":"/us/usc/t33/s1275/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2%2FB%2Fvi","sourceRelease":"119-100","text":"electric, water, and wastewater utilities operating in the Columba River Basin;1So in original. Probably should be “Columbia”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t33/s1275/c/2/B/vii","parentIdentifier":"/us/usc/t33/s1275/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2%2FB%2Fvii","sourceRelease":"119-100","text":"private landowners in the Columbia River Basin;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t33/s1275/c/2/B/viii","parentIdentifier":"/us/usc/t33/s1275/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2%2FB%2Fviii","sourceRelease":"119-100","text":"soil and water conservation districts in the Columbia River Basin;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ix","heading":null,"label":"ix","identifier":"/us/usc/t33/s1275/c/2/B/ix","parentIdentifier":"/us/usc/t33/s1275/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2%2FB%2Fix","sourceRelease":"119-100","text":"nongovernmental organizations that have a presence in the Columbia River Basin;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"x","heading":null,"label":"x","identifier":"/us/usc/t33/s1275/c/2/B/x","parentIdentifier":"/us/usc/t33/s1275/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2%2FB%2Fx","sourceRelease":"119-100","text":"the general public in the Columbia River Basin; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xi","heading":null,"label":"xi","identifier":"/us/usc/t33/s1275/c/2/B/xi","parentIdentifier":"/us/usc/t33/s1275/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F2%2FB%2Fxi","sourceRelease":"119-100","text":"the Estuary Partnership.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Geographic representation","label":"3 Geographic representation","identifier":"/us/usc/t33/s1275/c/3","parentIdentifier":"/us/usc/t33/s1275/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1275/c/3/A","parentIdentifier":"/us/usc/t33/s1275/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F3%2FA","sourceRelease":"119-100","text":"each State located in whole or in part in the Columbia River Basin; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1275/c/3/B","parentIdentifier":"/us/usc/t33/s1275/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F3%2FB","sourceRelease":"119-100","text":"each of the lower, middle, and upper basins of the Columbia River.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Duties and responsibilities","label":"4 Duties and responsibilities","identifier":"/us/usc/t33/s1275/c/4","parentIdentifier":"/us/usc/t33/s1275/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1275/c/4/A","parentIdentifier":"/us/usc/t33/s1275/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F4%2FA","sourceRelease":"119-100","text":"recommend and prioritize projects and actions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1275/c/4/B","parentIdentifier":"/us/usc/t33/s1275/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F4%2FB","sourceRelease":"119-100","text":"review the progress and effectiveness of projects and actions implemented.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Lower Columbia River Estuary","label":"5 Lower Columbia River Estuary","identifier":"/us/usc/t33/s1275/c/5","parentIdentifier":"/us/usc/t33/s1275/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Estuary Partnership","label":"A Estuary Partnership","identifier":"/us/usc/t33/s1275/c/5/A","parentIdentifier":"/us/usc/t33/s1275/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F5%2FA","sourceRelease":"119-100","text":"The Estuary Partnership shall perform the duties and fulfill the responsibilities of the Working Group described in paragraph (4) as those duties and responsibilities relate to the Lower Columbia River Estuary for such time as the Estuary Partnership is the management conference for the Lower Columbia River National Estuary Program under .section 1330 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Designation","label":"B Designation","identifier":"/us/usc/t33/s1275/c/5/B","parentIdentifier":"/us/usc/t33/s1275/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F5%2FB","sourceRelease":"119-100","text":"If the Estuary Partnership ceases to be the management conference for the Lower Columbia River National Estuary Program under , the Administrator may designate the new management conference to assume the duties and responsibilities of the Working Group described in paragraph (4) as those duties and responsibilities relate to the Lower Columbia River Estuary.section 1330 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Incorporation","label":"C Incorporation","identifier":"/us/usc/t33/s1275/c/5/C","parentIdentifier":"/us/usc/t33/s1275/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fc%2F5%2FC","sourceRelease":"119-100","text":"If the Estuary Partnership is removed from the National Estuary Program, the duties and responsibilities for the lower 146 miles of the Columbia River pursuant to this section shall be incorporated into the duties of the Working Group.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Grants","label":"d Grants","identifier":"/us/usc/t33/s1275/d","parentIdentifier":"/us/usc/t33/s1275","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s1275/d/1","parentIdentifier":"/us/usc/t33/s1275/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F1","sourceRelease":"119-100","text":"The Administrator shall establish a voluntary, competitive Columbia River Basin program to provide grants to State governments, tribal governments, regional water pollution control agencies and entities, local government entities, nongovernmental entities, or soil and water conservation districts to develop or implement projects authorized under this section for the purpose of environmental protection and restoration activities throughout the Columbia River Basin.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Federal share","label":"2 Federal share","identifier":"/us/usc/t33/s1275/d/2","parentIdentifier":"/us/usc/t33/s1275/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t33/s1275/d/2/A","parentIdentifier":"/us/usc/t33/s1275/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s1275/d/2/A/i","parentIdentifier":"/us/usc/t33/s1275/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":"shall not exceed 75 percent of the total cost of the project or activity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s1275/d/2/A/ii","parentIdentifier":"/us/usc/t33/s1275/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":"shall be made on condition that the non-Federal share of such total cost shall be provided from non-Federal sources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exceptions","label":"B Exceptions","identifier":"/us/usc/t33/s1275/d/2/B","parentIdentifier":"/us/usc/t33/s1275/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s1275/d/2/B/i","parentIdentifier":"/us/usc/t33/s1275/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F2%2FB%2Fi","sourceRelease":"119-100","text":"a tribal government may use Federal funds for the non-Federal share; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s1275/d/2/B/ii","parentIdentifier":"/us/usc/t33/s1275/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the Administrator may increase the Federal share under such circumstances as the Administrator determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Allocation","label":"3 Allocation","identifier":"/us/usc/t33/s1275/d/3","parentIdentifier":"/us/usc/t33/s1275/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1275/d/3/A","parentIdentifier":"/us/usc/t33/s1275/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F3%2FA","sourceRelease":"119-100","text":"provide not less than 25 percent of the funds to make grants for projects, programs, and studies in the Lower Columbia River Estuary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1275/d/3/B","parentIdentifier":"/us/usc/t33/s1275/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F3%2FB","sourceRelease":"119-100","text":"provide not less than 25 percent of the funds to make grants for projects, programs, and studies in the Middle and Upper Columbia River Basin, including the Snake River Basin; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s1275/d/3/C","parentIdentifier":"/us/usc/t33/s1275/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F3%2FC","sourceRelease":"119-100","text":"retain not more than 5 percent of the funds for the Environmental Protection Agency for purposes of implementing this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Reporting","label":"4 Reporting","identifier":"/us/usc/t33/s1275/d/4","parentIdentifier":"/us/usc/t33/s1275/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t33/s1275/d/4/A","parentIdentifier":"/us/usc/t33/s1275/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F4%2FA","sourceRelease":"119-100","text":"Each grant recipient under this subsection shall submit to the Administrator reports on progress being made in achieving the purposes of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Requirements","label":"B Requirements","identifier":"/us/usc/t33/s1275/d/4/B","parentIdentifier":"/us/usc/t33/s1275/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F4%2FB","sourceRelease":"119-100","text":"The Administrator shall establish requirements and timelines for recipients of grants under this subsection to report on progress made in achieving the purposes of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Relationship to other funding","label":"5 Relationship to other funding","identifier":"/us/usc/t33/s1275/d/5","parentIdentifier":"/us/usc/t33/s1275/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t33/s1275/d/5/A","parentIdentifier":"/us/usc/t33/s1275/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F5%2FA","sourceRelease":"119-100","text":"Nothing in this subsection limits the eligibility of the Estuary Partnership to receive funding under .section 1330(g) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Limitation","label":"B Limitation","identifier":"/us/usc/t33/s1275/d/5/B","parentIdentifier":"/us/usc/t33/s1275/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F5%2FB","sourceRelease":"119-100","text":"None of the funds made available under this subsection may be used for the administration of a management conference under .section 1330 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Authorization of appropriations","label":"6 Authorization of appropriations","identifier":"/us/usc/t33/s1275/d/6","parentIdentifier":"/us/usc/t33/s1275/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fd%2F6","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this subsection $30,000,000 for each of fiscal years 2020 and 2021.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Annual budget plan","label":"e Annual budget plan","identifier":"/us/usc/t33/s1275/e","parentIdentifier":"/us/usc/t33/s1275","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1275/e/1","parentIdentifier":"/us/usc/t33/s1275/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fe%2F1","sourceRelease":"119-100","text":"the amounts obligated for the preceding fiscal year for protection and restoration projects, programs, and studies relating to the Columbia River Basin;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1275/e/2","parentIdentifier":"/us/usc/t33/s1275/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fe%2F2","sourceRelease":"119-100","text":"the estimated budget for the current fiscal year for protection and restoration projects, programs, and studies relating to the Columbia River Basin; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s1275/e/3","parentIdentifier":"/us/usc/t33/s1275/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1275%2Fe%2F3","sourceRelease":"119-100","text":"the proposed budget for protection and restoration projects, programs, and studies relating to the Columbia River Basin.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
