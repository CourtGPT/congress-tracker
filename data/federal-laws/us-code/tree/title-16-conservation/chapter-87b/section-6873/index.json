:null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6873/c/2","parentIdentifier":"/us/usc/t16/s6873/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fc%2F2","sourceRelease":"119-100","text":"Federal fishing restrictions on the use of specific types of equipment or bait; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s6873/c/3","parentIdentifier":"/us/usc/t16/s6873/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fc%2F3","sourceRelease":"119-100","text":"Federal requirements with respect to catch and release.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Public comment","label":"d Public comment","identifier":"/us/usc/t16/s6873/d","parentIdentifier":"/us/usc/t16/s6873","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fd","sourceRelease":"119-100","text":"The Secretaries shall develop a process to allow members of the public to submit questions or comments regarding the information described in subsections (a) and (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Updates","label":"e Updates","identifier":"/us/usc/t16/s6873/e","parentIdentifier":"/us/usc/t16/s6873","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s6873/e/1","parentIdentifier":"/us/usc/t16/s6873/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fe%2F1","sourceRelease":"119-100","text":"the data described in subsections (a) and (b) not less frequently than 2 times per year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6873/e/2","parentIdentifier":"/us/usc/t16/s6873/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fe%2F2","sourceRelease":"119-100","text":"the data described in subsection (c) in real time as changes go into effect.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Exclusion","label":"f Exclusion","identifier":"/us/usc/t16/s6873/f","parentIdentifier":"/us/usc/t16/s6873","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Ff","sourceRelease":"119-100","text":"This section shall not apply to irrigation canals and flowage easements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Disclosure","label":"g Disclosure","identifier":"/us/usc/t16/s6873/g","parentIdentifier":"/us/usc/t16/s6873","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fg","sourceRelease":"119-100","text":"Any geographic information system data made publicly available under this section shall not disclose information regarding the nature, location, character, or ownership of historic, paleontological, or archaeological resources, consistent with applicable law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
