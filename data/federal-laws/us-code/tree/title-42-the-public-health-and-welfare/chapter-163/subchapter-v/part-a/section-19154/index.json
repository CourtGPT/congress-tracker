{"type":"section","nativeType":"section","number":"19154","heading":"Collection of data on demographics of faculty","label":"19154 Collection of data on demographics of faculty","identifier":"/us/usc/t42/s19154","parentIdentifier":"/us/usc/t42/ch163/schV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Collection of data","label":"a Collection of data","identifier":"/us/usc/t42/s19154/a","parentIdentifier":"/us/usc/t42/s19154","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s19154/a/1","parentIdentifier":"/us/usc/t42/s19154/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fa%2F1","sourceRelease":"119-100","text":"Not later than 5 years after , and at least every five years thereafter, the Director of the National Science Foundation shall carry out a survey to collect data from award recipients on the demographics of STEM faculty, by broad fields of STEM, at different types of institutions of higher education that receive Federal research funding.August 9, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Survey considerations","label":"2 Survey considerations","identifier":"/us/usc/t42/s19154/a/2","parentIdentifier":"/us/usc/t42/s19154/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19154/a/2/A","parentIdentifier":"/us/usc/t42/s19154/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the number and percentage of faculty;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19154/a/2/B","parentIdentifier":"/us/usc/t42/s19154/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the number and percentage of faculty at each rank;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s19154/a/2/C","parentIdentifier":"/us/usc/t42/s19154/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fa%2F2%2FC","sourceRelease":"119-100","text":"the number and percentage of faculty who are in nontenure-track positions, including teaching and research;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s19154/a/2/D","parentIdentifier":"/us/usc/t42/s19154/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fa%2F2%2FD","sourceRelease":"119-100","text":"the number and percentage of faculty who are reviewed for promotion, including tenure, and the percentage of that number who are promoted, including being awarded tenure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s19154/a/2/E","parentIdentifier":"/us/usc/t42/s19154/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fa%2F2%2FE","sourceRelease":"119-100","text":"faculty years in rank;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s19154/a/2/F","parentIdentifier":"/us/usc/t42/s19154/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fa%2F2%2FF","sourceRelease":"119-100","text":"the number and percentage of faculty to leave tenure-track positions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s19154/a/2/G","parentIdentifier":"/us/usc/t42/s19154/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fa%2F2%2FG","sourceRelease":"119-100","text":"the number and percentage of faculty hired, by rank; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t42/s19154/a/2/H","parentIdentifier":"/us/usc/t42/s19154/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fa%2F2%2FH","sourceRelease":"119-100","text":"the number and percentage of faculty in leadership positions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Existing surveys","label":"b Existing surveys","identifier":"/us/usc/t42/s19154/b","parentIdentifier":"/us/usc/t42/s19154","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19154/b/1","parentIdentifier":"/us/usc/t42/s19154/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fb%2F1","sourceRelease":"119-100","text":"take into account the considerations under subsection (a)(2) by collaborating with statistical centers at other Federal agencies; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19154/b/2","parentIdentifier":"/us/usc/t42/s19154/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fb%2F2","sourceRelease":"119-100","text":"make an award to an institution of higher education or nonprofit organization (or consortia thereof) to take such considerations into account.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Reporting data","label":"c Reporting data","identifier":"/us/usc/t42/s19154/c","parentIdentifier":"/us/usc/t42/s19154","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fc","sourceRelease":"119-100","text":"The Director of the National Science Foundation shall publish statistical summary data collected under this section, including as part of the National Science Foundation’s report required by .section 1885d of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s19154/d","parentIdentifier":"/us/usc/t42/s19154","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19154%2Fd","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Director of the National Science Foundation $4,000,000 in each of fiscal years 2023 through 2025 to develop and carry out the initial survey required under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
