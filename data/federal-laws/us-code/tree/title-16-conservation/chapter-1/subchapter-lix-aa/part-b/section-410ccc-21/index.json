{"type":"section","nativeType":"section","number":"410ccc–21","heading":"Establishment","label":"410ccc–21 Establishment","identifier":"/us/usc/t16/s410ccc–21","parentIdentifier":"/us/usc/t16/ch1/schLIX–AA/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410ccc%E2%80%9321","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s410ccc–21/a","parentIdentifier":"/us/usc/t16/s410ccc–21","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410ccc%E2%80%9321%2Fa","sourceRelease":"119-100","text":"There is hereby established the Cane River National Heritage Area (hereinafter in this part referred to as the “heritage area”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purpose","label":"b Purpose","identifier":"/us/usc/t16/s410ccc–21/b","parentIdentifier":"/us/usc/t16/s410ccc–21","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410ccc%E2%80%9321%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410ccc–21/b/1","parentIdentifier":"/us/usc/t16/s410ccc–21/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410ccc%E2%80%9321%2Fb%2F1","sourceRelease":"119-100","text":"recognizing areas important to the Nation’s heritage and identity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410ccc–21/b/2","parentIdentifier":"/us/usc/t16/s410ccc–21/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410ccc%E2%80%9321%2Fb%2F2","sourceRelease":"119-100","text":"assisting in the preservation and enhancement of the cultural landscape and traditions of the Cane River region;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s410ccc–21/b/3","parentIdentifier":"/us/usc/t16/s410ccc–21/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410ccc%E2%80%9321%2Fb%2F3","sourceRelease":"119-100","text":"providing a framework for those who live within this important dynamic cultural landscape to assist in preservation and educational actions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s410ccc–21/b/4","parentIdentifier":"/us/usc/t16/s410ccc–21/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410ccc%E2%80%9321%2Fb%2F4","sourceRelease":"119-100","text":"minimizing the need for Federal land acquisition and management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Area included","label":"c Area included","identifier":"/us/usc/t16/s410ccc–21/c","parentIdentifier":"/us/usc/t16/s410ccc–21","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410ccc%E2%80%9321%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410ccc–21/c/1","parentIdentifier":"/us/usc/t16/s410ccc–21/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410ccc%E2%80%9321%2Fc%2F1","sourceRelease":"119-100","text":"an area approximately 1 mile on both sides of the Cane River as depicted on map CARI, 80,000A, dated May 1994;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410ccc–21/c/2","parentIdentifier":"/us/usc/t16/s410ccc–21/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410ccc%E2%80%9321%2Fc%2F2","sourceRelease":"119-100","text":"those properties within the Natchitoches National Historic Landmark District which are the subject of cooperative agreements pursuant to ;section 410ccc–2(d) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s410ccc–21/c/3","parentIdentifier":"/us/usc/t16/s410ccc–21/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410ccc%E2%80%9321%2Fc%2F3","sourceRelease":"119-100","text":"the Los Adaes State Commemorative Area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s410ccc–21/c/4","parentIdentifier":"/us/usc/t16/s410ccc–21/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410ccc%E2%80%9321%2Fc%2F4","sourceRelease":"119-100","text":"the Fort Jesup State Commemorative Area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s410ccc–21/c/5","parentIdentifier":"/us/usc/t16/s410ccc–21/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410ccc%E2%80%9321%2Fc%2F5","sourceRelease":"119-100","text":"the Fort St. Jean Baptiste State Commemorative Area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s410ccc–21/c/6","parentIdentifier":"/us/us