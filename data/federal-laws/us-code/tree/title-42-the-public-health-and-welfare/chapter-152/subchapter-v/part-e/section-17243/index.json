{"type":"section","nativeType":"section","number":"17243","heading":"Bright Tomorrow Lighting Prizes","label":"17243 Bright Tomorrow Lighting Prizes","identifier":"/us/usc/t42/s17243","parentIdentifier":"/us/usc/t42/ch152/schV/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t42/s17243/a","parentIdentifier":"/us/usc/t42/s17243","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fa","sourceRelease":"119-100","text":"Not later than 1 year after , as part of the program carried out under , the Secretary shall establish and award Bright Tomorrow Lighting Prizes for solid state lighting in accordance with this section.December 19, 2007section 16396 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Prize specifications","label":"b Prize specifications","identifier":"/us/usc/t42/s17243/b","parentIdentifier":"/us/usc/t42/s17243","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"60-Watt Incandescent Replacement Lamp Prize","label":"1 60-Watt Incandescent Replacement Lamp Prize","identifier":"/us/usc/t42/s17243/b/1","parentIdentifier":"/us/usc/t42/s17243/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17243/b/1/A","parentIdentifier":"/us/usc/t42/s17243/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F1%2FA","sourceRelease":"119-100","text":"producing a luminous flux greater than 900 lumens;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17243/b/1/B","parentIdentifier":"/us/usc/t42/s17243/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F1%2FB","sourceRelease":"119-100","text":"consuming less than or equal to 10 watts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17243/b/1/C","parentIdentifier":"/us/usc/t42/s17243/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F1%2FC","sourceRelease":"119-100","text":"having an efficiency greater than 90 lumens per watt;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17243/b/1/D","parentIdentifier":"/us/usc/t42/s17243/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F1%2FD","sourceRelease":"119-100","text":"having a color rendering index greater than 90;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17243/b/1/E","parentIdentifier":"/us/usc/t42/s17243/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F1%2FE","sourceRelease":"119-100","text":"having a correlated color temperature of not less than 2,750, and not more than 3,000, degrees Kelvin;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17243/b/1/F","parentIdentifier":"/us/usc/t42/s17243/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F1%2FF","sourceRelease":"119-100","text":"having 70 percent of the lumen value under subparagraph (A) exceeding 25,000 hours under typical conditions expected in residential use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s17243/b/1/G","parentIdentifier":"/us/usc/t42/s17243/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F1%2FG","sourceRelease":"119-100","text":"having a light distribution pattern similar to a soft 60-watt incandescent A19 bulb;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t42/s17243/b/1/H","parentIdentifier":"/us/usc/t42/s17243/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F1%2FH","sourceRelease":"119-100","text":"having a size and shape that fits within the maximum dimensions of an A19 bulb in accordance with American National Standards Institute standard C78.20–2003, figure C78.20–211;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s17243/b/1/I","parentIdentifier":"/us/usc/t42/s17243/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F1%2FI","sourceRelease":"119-100","text":"using a single contact medium screw socket; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t42/s17243/b/1/J","parentIdentifier":"/us/usc/t42/s17243/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F1%2FJ","sourceRelease":"119-100","text":"mass production for a competitive sales commercial market satisfied by producing commercially accepted quality control lots of such units equal to or exceeding the criteria described in subparagraphs (A) through (I).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"PAR Type 38 Halogen Replacement Lamp Prize","label":"2 PAR Type 38 Halogen Replacement Lamp Prize","identifier":"/us/usc/t42/s17243/b/2","parentIdentifier":"/us/usc/t42/s17243/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17243/b/2/A","parentIdentifier":"/us/usc/t42/s17243/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F2%2FA","sourceRelease":"119-100","text":"producing a luminous flux greater than or equal to 1,350 lumens;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17243/b/2/B","parentIdentifier":"/us/usc/t42/s17243/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F2%2FB","sourceRelease":"119-100","text":"consuming less than or equal to 11 watts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17243/b/2/C","parentIdentifier":"/us/usc/t42/s17243/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F2%2FC","sourceRelease":"119-100","text":"having an efficiency greater than 123 lumens per watt;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17243/b/2/D","parentIdentifier":"/us/usc/t42/s17243/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F2%2FD","sourceRelease":"119-100","text":"having a color rendering index greater than or equal to 90;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17243/b/2/E","parentIdentifier":"/us/usc/t42/s17243/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F2%2FE","sourceRelease":"119-100","text":"having a correlated color coordinate temperature of not less than 2,750, and not more than 3,000, degrees Kelvin;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17243/b/2/F","parentIdentifier":"/us/usc/t42/s17243/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F2%2FF","sourceRelease":"119-100","text":"having 70 percent of the lumen value under subparagraph (A) exceeding 25,000 hours under typical conditions expected in residential use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s17243/b/2/G","parentIdentifier":"/us/usc/t42/s17243/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F2%2FG","sourceRelease":"119-100","text":"having a light distribution pattern similar to a PAR 38 halogen lamp;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t42/s17243/b/2/H","parentIdentifier":"/us/usc/t42/s17243/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F2%2FH","sourceRelease":"119-100","text":"having a size and shape that fits within the maximum dimensions of a PAR 38 halogen lamp in accordance with American National Standards Institute standard C78–21–2003, figure C78.21–238;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s17243/b/2/I","parentIdentifier":"/us/usc/t42/s17243/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F2%2FI","sourceRelease":"119-100","text":"using a single contact medium screw socket; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t42/s17243/b/2/J","parentIdentifier":"/us/usc/t42/s17243/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F2%2FJ","sourceRelease":"119-100","text":"mass production for a competitive sales commercial market satisfied by producing commercially accepted quality control lots of such units equal to or exceeding the criteria described in subparagraphs (A) through (I).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Twenty-First Century Lamp Prize","label":"3 Twenty-First Century Lamp Prize","identifier":"/us/usc/t42/s17243/b/3","parentIdentifier":"/us/usc/t42/s17243/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17243/b/3/A","parentIdentifier":"/us/usc/t42/s17243/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F3%2FA","sourceRelease":"119-100","text":"producing a light output greater than 1,200 lumens;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17243/b/3/B","parentIdentifier":"/us/usc/t42/s17243/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F3%2FB","sourceRelease":"119-100","text":"having an efficiency greater than 150 lumens per watt;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17243/b/3/C","parentIdentifier":"/us/usc/t42/s17243/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F3%2FC","sourceRelease":"119-100","text":"having a color rendering index greater than 90;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17243/b/3/D","parentIdentifier":"/us/usc/t42/s17243/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F3%2FD","sourceRelease":"119-100","text":"having a color coordinate temperature between 2,800 and 3,000 degrees Kelvin; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17243/b/3/E","parentIdentifier":"/us/usc/t42/s17243/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fb%2F3%2FE","sourceRelease":"119-100","text":"having a lifetime exceeding 25,000 hours.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Private funds","label":"c Private funds","identifier":"/us/usc/t42/s17243/c","parentIdentifier":"/us/usc/t42/s17243","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17243/c/1","parentIdentifier":"/us/usc/t42/s17243/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17243/c/1/A","parentIdentifier":"/us/usc/t42/s17243/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fc%2F1%2FA","sourceRelease":"119-100","text":"without further appropriation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17243/c/1/B","parentIdentifier":"/us/usc/t42/s17243/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fc%2F1%2FB","sourceRelease":"119-100","text":"without fiscal year limitation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Prize competition","label":"2 Prize competition","identifier":"/us/usc/t42/s17243/c/2","parentIdentifier":"/us/usc/t42/s17243/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fc%2F2","sourceRelease":"119-100","text":"A private source of funding may not participate in the competition for prizes awarded under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Technical review","label":"d Technical review","identifier":"/us/usc/t42/s17243/d","parentIdentifier":"/us/usc/t42/s17243","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fd","sourceRelease":"119-100","text":"The Secretary shall establish a technical review committee composed of non-Federal officers to review entrant data submitted under this section to determine whether the data meets the prize specifications described in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Third party administration","label":"e Third party administration","identifier":"/us/usc/t42/s17243/e","parentIdentifier":"/us/usc/t42/s17243","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fe","sourceRelease":"119-100","text":"The Secretary may competitively select a third party to administer awards under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Eligibility for prizes","label":"f Eligibility for prizes","identifier":"/us/usc/t42/s17243/f","parentIdentifier":"/us/usc/t42/s17243","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17243/f/1","parentIdentifier":"/us/usc/t42/s17243/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Ff%2F1","sourceRelease":"119-100","text":"in the case of a private entity, the entity shall be incorporated in and maintain a primary place of business in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17243/f/2","parentIdentifier":"/us/usc/t42/s17243/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Ff%2F2","sourceRelease":"119-100","text":"in the case of an individual (whether participating as a single individual or in a group), the individual shall be a citizen or lawful permanent resident of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Award amounts","label":"g Award amounts","identifier":"/us/usc/t42/s17243/g","parentIdentifier":"/us/usc/t42/s17243","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17243/g/1","parentIdentifier":"/us/usc/t42/s17243/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fg%2F1","sourceRelease":"119-100","text":"the 60-Watt Incandescent Replacement Lamp Prize described in subsection (b)(1) shall be $10,000,000;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17243/g/2","parentIdentifier":"/us/usc/t42/s17243/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fg%2F2","sourceRelease":"119-100","text":"the PAR Type 38 Halogen Replacement Lamp Prize described in subsection (b)(2) shall be $5,000,000; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17243/g/3","parentIdentifier":"/us/usc/t42/s17243/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fg%2F3","sourceRelease":"119-100","text":"the Twenty-First Century Lamp Prize described in subsection (b)(3) shall be $5,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Federal procurement of solid-state-lights","label":"h Federal procurement of solid-state-lights","identifier":"/us/usc/t42/s17243/h","parentIdentifier":"/us/usc/t42/s17243","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"60-watt incandescent replacement","label":"1 60-watt incandescent replacement","identifier":"/us/usc/t42/s17243/h/1","parentIdentifier":"/us/usc/t42/s17243/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fh%2F1","sourceRelease":"119-100","text":"Subject to paragraph (3), as soon as practicable after the successful award of the 60-Watt Incandescent Replacement Lamp Prize under subsection (b)(1), the Secretary (in consultation with the Administrator of General Services) shall develop governmentwide Federal purchase guidelines with a goal of replacing the use of 60-watt incandescent lamps in Federal Government buildings with a solid-state-light package described in subsection (b)(1) by not later than the date that is 5 years after the date the award is made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"PAR 38 halogen replacement lamp replacement1","label":"2 PAR 38 halogen replacement lamp replacement1","identifier":"/us/usc/t42/s17243/h/2","parentIdentifier":"/us/usc/t42/s17243/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fh%2F2","sourceRelease":"119-100","text":"Subject to paragraph (3), as soon as practicable after the successful award of the PAR Type 38 Halogen Replacement Lamp Prize under subsection (b)(2), the Secretary (in consultation with the Administrator of General Services) shall develop governmentwide Federal purchase guidelines with the goal of replacing the use of PAR 38 halogen lamps in Federal Government buildings with a solid-state-light package described in subsection (b)(2) by not later than the date that is 5 years after the date the award is made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Waivers","label":"3 Waivers","identifier":"/us/usc/t42/s17243/h/3","parentIdentifier":"/us/usc/t42/s17243/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fh%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s17243/h/3/A","parentIdentifier":"/us/usc/t42/s17243/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fh%2F3%2FA","sourceRelease":"119-100","text":"The Secretary or the Administrator of General Services may waive the application of paragraph (1) or (2) if the Secretary or Administrator determines that the return on investment from the purchase of a solid-state-light package described in paragraph (1) or (2) of subsection (b), respectively, is cost prohibitive.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Report of waiver","label":"B Report of waiver","identifier":"/us/usc/t42/s17243/h/3/B","parentIdentifier":"/us/usc/t42/s17243/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fh%2F3%2FB","sourceRelease":"119-100","text":"If the Secretary or Administrator waives the application of paragraph (1) or (2), the Secretary or Administrator, respectively, shall submit to Congress an annual report that describes the waiver and provides a detailed justification for the waiver.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Report","label":"i Report","identifier":"/us/usc/t42/s17243/i","parentIdentifier":"/us/usc/t42/s17243","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fi","sourceRelease":"119-100","text":"Not later than 2 years after , and annually thereafter, the Administrator of General Services shall submit to the Energy Information Agency a report describing the quantity, type, and cost of each lighting product purchased by the Federal Government.December 19, 2007","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"j","heading":"Bright Tomorrow Lighting Award Fund","label":"j Bright Tomorrow Lighting Award Fund","identifier":"/us/usc/t42/s17243/j","parentIdentifier":"/us/usc/t42/s17243","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fj","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t42/s17243/j/1","parentIdentifier":"/us/usc/t42/s17243/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fj%2F1","sourceRelease":"119-100","text":"There is established in the United States Treasury a Bright Tomorrow Lighting permanent fund without fiscal year limitation to award prizes under paragraphs (1), (2), and (3) of subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Sources of funding","label":"2 Sources of funding","identifier":"/us/usc/t42/s17243/j/2","parentIdentifier":"/us/usc/t42/s17243/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fj%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17243/j/2/A","parentIdentifier":"/us/usc/t42/s17243/j/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fj%2F2%2FA","sourceRelease":"119-100","text":"fiscal year appropriations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17243/j/2/B","parentIdentifier":"/us/usc/t42/s17243/j/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fj%2F2%2FB","sourceRelease":"119-100","text":"private contributions authorized under subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"k","heading":"Authorization of appropriations","label":"k Authorization of appropriations","identifier":"/us/usc/t42/s17243/k","parentIdentifier":"/us/usc/t42/s17243","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17243%2Fk","sourceRelease":"119-100","text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
