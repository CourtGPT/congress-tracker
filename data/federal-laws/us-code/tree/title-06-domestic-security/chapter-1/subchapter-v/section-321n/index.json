{"type":"section","nativeType":"section","number":"321n","heading":"Acceptance of gifts","label":"321n Acceptance of gifts","identifier":"/us/usc/t6/s321n","parentIdentifier":"/us/usc/t6/ch1/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs321n","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authority","label":"a Authority","identifier":"/us/usc/t6/s321n/a","parentIdentifier":"/us/usc/t6/s321n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs321n%2Fa","sourceRelease":"119-100","text":"The Secretary may accept and use gifts of property, both real and personal, and may accept gifts of services, including from guest lecturers, for otherwise authorized activities of the Center for Domestic Preparedness that are related to efforts to prevent, prepare for, protect against, or respond to a natural disaster, act of terrorism, or other man-made disaster, including the use of a weapon of mass destruction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Prohibition","label":"b Prohibition","identifier":"/us/usc/t6/s321n/b","parentIdentifier":"/us/usc/t6/s321n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs321n%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s321n/b/1","parentIdentifier":"/us/usc/t6/s321n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs321n%2Fb%2F1","sourceRelease":"119-100","text":"a program of the Department; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s321n/b/2","parentIdentifier":"/us/usc/t6/s321n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs321n%2Fb%2F2","sourceRelease":"119-100","text":"an individual involved in a program of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Report","label":"c Report","identifier":"/us/usc/t6/s321n/c","parentIdentifier":"/us/usc/t6/s321n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs321n%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s321n/c/1","parentIdentifier":"/us/usc/t6/s321n/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs321n%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s321n/c/1/A","parentIdentifier":"/us/usc/t6/s321n/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs321n%2Fc%2F1%2FA","sourceRelease":"119-100","text":"any gifts that were accepted under this section during the year covered by the report;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s321n/c/1/B","parentIdentifier":"/us/usc/t6/s321n/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs321n%2Fc%2F1%2FB","sourceRelease":"119-100","text":"how the gifts contribute to the mission of the Center for Domestic Preparedness; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s321n/c/1/C","parentIdentifier":"/us/usc/t6/s321n/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs321n%2Fc%2F1%2FC","sourceRelease":"119-100","text":"the amount of Federal savings that were generated from the acceptance of the gifts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Publication","label":"2 Publication","identifier":"/us/usc/t6/s321n/c/2","parentIdentifier":"/us/usc/t6/s321n/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs321n%2Fc%2F2","sourceRelease":"119-100","text":"Each report required under paragraph (1) shall be made publically available.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
