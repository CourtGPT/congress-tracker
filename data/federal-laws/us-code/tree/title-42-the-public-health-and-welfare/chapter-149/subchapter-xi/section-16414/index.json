{"type":"section","nativeType":"section","number":"16414","heading":"National Power Plant Operations Technology and Educational Center","label":"16414 National Power Plant Operations Technology and Educational Center","identifier":"/us/usc/t42/s16414","parentIdentifier":"/us/usc/t42/ch149/schXI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16414","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t42/s16414/a","parentIdentifier":"/us/usc/t42/s16414","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16414%2Fa","sourceRelease":"119-100","text":"The Secretary shall support the establishment of a National Power Plant Operations Technology and Education Center (referred to in this section as the “Center”), to address the need for training and educating certified operators and technicians for the electric power industry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Location of Center","label":"b Location of Center","identifier":"/us/usc/t42/s16414/b","parentIdentifier":"/us/usc/t42/s16414","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16414%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16414/b/1","parentIdentifier":"/us/usc/t42/s16414/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16414%2Fb%2F1","sourceRelease":"119-100","text":"expertise in providing degree programs in electric power generation, transmission, and distribution technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16414/b/2","parentIdentifier":"/us/usc/t42/s16414/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16414%2Fb%2F2","sourceRelease":"119-100","text":"expertise in providing onsite and Internet-based training; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16414/b/3","parentIdentifier":"/us/usc/t42/s16414/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16414%2Fb%2F3","sourceRelease":"119-100","text":"demonstrated responsiveness to workforce and training requirements in the electric power industry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Training and continuing education","label":"c Training and continuing education","identifier":"/us/usc/t42/s16414/c","parentIdentifier":"/us/usc/t42/s16414","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16414%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16414/c/1","parentIdentifier":"/us/usc/t42/s16414/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16414%2Fc%2F1","sourceRelease":"119-100","text":"The Center shall provide training and continuing education in electric power generation, transmission, and distribution technologies and operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Location","label":"2 Location","identifier":"/us/usc/t42/s16414/c/2","parentIdentifier":"/us/usc/t42/s16414/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16414%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16414/c/2/A","parentIdentifier":"/us/usc/t42/s16414/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16414%2Fc%2F2%2FA","sourceRelease":"119-100","text":"at the Center; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16414/c/2/B","parentIdentifier":"/us/usc/t42/s16414/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16414%2Fc%2F2%2FB","sourceRelease":"119-100","text":"through Internet-based information technologies that allow for learning at remote sites.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
