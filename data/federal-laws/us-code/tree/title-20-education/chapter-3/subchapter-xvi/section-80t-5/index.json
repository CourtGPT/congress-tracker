{"type":"section","nativeType":"section","number":"80t–5","heading":"Building","label":"80t–5 Building","identifier":"/us/usc/t20/s80t–5","parentIdentifier":"/us/usc/t20/ch3/schXVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Location","label":"a Location","identifier":"/us/usc/t20/s80t–5/a","parentIdentifier":"/us/usc/t20/s80t–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t20/s80t–5/a/1","parentIdentifier":"/us/usc/t20/s80t–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F1","sourceRelease":"119-100","text":"Not later than 2 years after , the Board of Regents shall designate a site for the Museum.December 27, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Sites for consideration","label":"2 Sites for consideration","identifier":"/us/usc/t20/s80t–5/a/2","parentIdentifier":"/us/usc/t20/s80t–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s80t–5/a/2/A","parentIdentifier":"/us/usc/t20/s80t–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F2%2FA","sourceRelease":"119-100","text":"select a site in the District of Columbia; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s80t–5/a/2/B","parentIdentifier":"/us/usc/t20/s80t–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s80t–5/a/2/B/i","parentIdentifier":"/us/usc/t20/s80t–5/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"The site known as the “South Monument site”, located on the National Mall and bordered by 14th Street Northwest, Jefferson Drive Southwest, Raoul Wallenberg Place Southwest, and Independence Ave Southwest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s80t–5/a/2/B/ii","parentIdentifier":"/us/usc/t20/s80t–5/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"The Northwest United States Capitol site, bordered by 3rd Street Northwest, Constitution Avenue Northwest, 1st Street Northwest, and Pennsylvania Ave Northwest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Factors considered","label":"3 Factors considered","identifier":"/us/usc/t20/s80t–5/a/3","parentIdentifier":"/us/usc/t20/s80t–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s80t–5/a/3/A","parentIdentifier":"/us/usc/t20/s80t–5/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F3%2FA","sourceRelease":"119-100","text":"An estimate of the costs associated with each potential site.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s80t–5/a/3/B","parentIdentifier":"/us/usc/t20/s80t–5/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F3%2FB","sourceRelease":"119-100","text":"An assessment of the suitability of the space of each potential site, including size, proximity to other buildings and transportation, and other external environmental conditions, as appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s80t–5/a/3/C","parentIdentifier":"/us/usc/t20/s80t–5/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F3%2FC","sourceRelease":"119-100","text":"The recommendations of the Congressional Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Consultation","label":"4 Consultation","identifier":"/us/usc/t20/s80t–5/a/4","parentIdentifier":"/us/usc/t20/s80t–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s80t–5/a/4/A","parentIdentifier":"/us/usc/t20/s80t–5/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FA","sourceRelease":"119-100","text":"The Chair of the National Capital Planning Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s80t–5/a/4/B","parentIdentifier":"/us/usc/t20/s80t–5/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FB","sourceRelease":"119-100","text":"The Director of the National Park Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s80t–5/a/4/C","parentIdentifier":"/us/usc/t20/s80t–5/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FC","sourceRelease":"119-100","text":"The Chair of the National Capital Memorial Advisory Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s80t–5/a/4/D","parentIdentifier":"/us/usc/t20/s80t–5/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FD","sourceRelease":"119-100","text":"The Chair of the Commission on Fine Arts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s80t–5/a/4/E","parentIdentifier":"/us/usc/t20/s80t–5/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FE","sourceRelease":"119-100","text":"The Chair of the Congressional Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t20/s80t–5/a/4/F","parentIdentifier":"/us/usc/t20/s80t–5/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FF","sourceRelease":"119-100","text":"The Architect of the Capitol.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t20/s80t–5/a/4/G","parentIdentifier":"/us/usc/t20/s80t–5/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FG","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s80t–5/a/4/G/i","parentIdentifier":"/us/usc/t20/s80t–5/a/4/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FG%2Fi","sourceRelease":"119-100","text":"The Committee on Rules and Administration of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s80t–5/a/4/G/ii","parentIdentifier":"/us/usc/t20/s80t–5/a/4/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FG%2Fii","sourceRelease":"119-100","text":"The Committee on House Administration of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t20/s80t–5/a/4/G/iii","parentIdentifier":"/us/usc/t20/s80t–5/a/4/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FG%2Fiii","sourceRelease":"119-100","text":"The Committee on Energy and Natural Resources of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t20/s80t–5/a/4/G/iv","parentIdentifier":"/us/usc/t20/s80t–5/a/4/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FG%2Fiv","sourceRelease":"119-100","text":"The Committee on Natural Resources of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t20/s80t–5/a/4/G/v","parentIdentifier":"/us/usc/t20/s80t–5/a/4/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FG%2Fv","sourceRelease":"119-100","text":"The Committee on Transportation and Infrastructure of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t20/s80t–5/a/4/G/vi","parentIdentifier":"/us/usc/t20/s80t–5/a/4/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FG%2Fvi","sourceRelease":"119-100","text":"The Committee on Appropriations of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t20/s80t–5/a/4/G/vii","parentIdentifier":"/us/usc/t20/s80t–5/a/4/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F4%2FG%2Fvii","sourceRelease":"119-100","text":"The Committee on Appropriations of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Intent of Congress","label":"5 Intent of Congress","identifier":"/us/usc/t20/s80t–5/a/5","parentIdentifier":"/us/usc/t20/s80t–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fa%2F5","sourceRelease":"119-100","text":"It is the intent of Congress that the Museum be located on or near the National Mall, to the maximum extent practicable, in accordance with this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Site under the jurisdiction of another Federal agency","label":"b Site under the jurisdiction of another Federal agency","identifier":"/us/usc/t20/s80t–5/b","parentIdentifier":"/us/usc/t20/s80t–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Written notification of agreement","label":"1 Written notification of agreement","identifier":"/us/usc/t20/s80t–5/b/1","parentIdentifier":"/us/usc/t20/s80t–5/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fb%2F1","sourceRelease":"119-100","text":"The Board of Regents shall not designate a site for the Museum that is under the administrative jurisdiction of another Federal agency or entity unless the head of the Federal agency or entity submits to each of the committees described in subsection (a)(4)(G) written notification stating that the head of the Federal agency or entity concurs with locating the Museum on the land or in the structure that is under the administrative jurisdiction of the Federal agency or entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Transfer","label":"2 Transfer","identifier":"/us/usc/t20/s80t–5/b/2","parentIdentifier":"/us/usc/t20/s80t–5/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fb%2F2","sourceRelease":"119-100","text":"As soon as practicable after the date on which Congress receives the written notification described in paragraph (1), the head of the Federal agency or entity shall transfer to the Smithsonian Institution its administrative jurisdiction over the land or structure that has been designated as the site for the Museum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Construction of building","label":"c Construction of building","identifier":"/us/usc/t20/s80t–5/c","parentIdentifier":"/us/usc/t20/s80t–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fc","sourceRelease":"119-100","text":"The Board of Regents, in consultation with the council established under , may plan, design, and construct a building for the Museum, which shall be located at the site designated by the Board of Regents under subsection (a), in accordance with this section.section 80t–2 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Commemorative Works Act","label":"d Commemorative Works Act","identifier":"/us/usc/t20/s80t–5/d","parentIdentifier":"/us/usc/t20/s80t–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fd","sourceRelease":"119-100","text":"Chapter 89 of title 40 shall not apply with respect to the Museum, except that the Museum shall not be located in the Reserve (as defined in section 8902(a) of that title).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Cost sharing","label":"e Cost sharing","identifier":"/us/usc/t20/s80t–5/e","parentIdentifier":"/us/usc/t20/s80t–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s80t–5/e/1","parentIdentifier":"/us/usc/t20/s80t–5/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fe%2F1","sourceRelease":"119-100","text":"50 percent of the costs of carrying out this section from Federal funds; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s80t–5/e/2","parentIdentifier":"/us/usc/t20/s80t–5/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs80t%E2%80%935%2Fe%2F2","sourceRelease":"119-100","text":"50 percent of the costs of carrying out this section from non-Federal sources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
