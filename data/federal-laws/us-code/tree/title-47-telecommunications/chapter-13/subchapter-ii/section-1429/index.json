{"type":"section","nativeType":"section","number":"1429","heading":"Audit and report","label":"1429 Audit and report","identifier":"/us/usc/t47/s1429","parentIdentifier":"/us/usc/t47/ch13/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Audit","label":"a Audit","identifier":"/us/usc/t47/s1429/a","parentIdentifier":"/us/usc/t47/s1429","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t47/s1429/a/1","parentIdentifier":"/us/usc/t47/s1429/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary of Commerce shall enter into a contract with an independent auditor to conduct an audit, on an annual basis, of the First Responder Network Authority in accordance with general accounting principles and procedures applicable to commercial corporate transactions. Each audit conducted under this paragraph shall be made available to the appropriate committees of Congress.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Location","label":"2 Location","identifier":"/us/usc/t47/s1429/a/2","parentIdentifier":"/us/usc/t47/s1429/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fa%2F2","sourceRelease":"119-100","text":"Any audit conducted under paragraph (1) shall be conducted at the place or places where accounts of the First Responder Network Authority are normally kept.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Access to First Responder Network Authority books and documents","label":"3 Access to First Responder Network Authority books and documents","identifier":"/us/usc/t47/s1429/a/3","parentIdentifier":"/us/usc/t47/s1429/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t47/s1429/a/3/A","parentIdentifier":"/us/usc/t47/s1429/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fa%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1429/a/3/A/i","parentIdentifier":"/us/usc/t47/s1429/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fa%2F3%2FA%2Fi","sourceRelease":"119-100","text":"have access to all books, accounts, records, reports, files, and all other papers, things, or property belonging to or in use by the First Responder Network Authority that pertain to the financial transactions of the First Responder Network Authority and are necessary to facilitate the audit; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1429/a/3/A/ii","parentIdentifier":"/us/usc/t47/s1429/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fa%2F3%2FA%2Fii","sourceRelease":"119-100","text":"be afforded full facilities for verifying transactions with the balances or securities held by depositories, fiscal agents, and custodians.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Requirement","label":"B Requirement","identifier":"/us/usc/t47/s1429/a/3/B","parentIdentifier":"/us/usc/t47/s1429/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fa%2F3%2FB","sourceRelease":"119-100","text":"All books, accounts, records, reports, files, papers, and property of the First Responder Network Authority shall remain in the possession and custody of the First Responder Network Authority.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report","label":"b Report","identifier":"/us/usc/t47/s1429/b","parentIdentifier":"/us/usc/t47/s1429","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t47/s1429/b/1","parentIdentifier":"/us/usc/t47/s1429/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1429/b/1/A","parentIdentifier":"/us/usc/t47/s1429/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the appropriate committees of Congress;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1429/b/1/B","parentIdentifier":"/us/usc/t47/s1429/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the President; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t47/s1429/b/1/C","parentIdentifier":"/us/usc/t47/s1429/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the First Responder Network Authority.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t47/s1429/b/2","parentIdentifier":"/us/usc/t47/s1429/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1429/b/2/A","parentIdentifier":"/us/usc/t47/s1429/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fb%2F2%2FA","sourceRelease":"119-100","text":"such comments and information as the independent auditor determines necessary to inform Congress of the financial operations and condition of the First Responder Network Authority;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1429/b/2/B","parentIdentifier":"/us/usc/t47/s1429/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fb%2F2%2FB","sourceRelease":"119-100","text":"any recommendations of the independent auditor relating to the financial operations and condition of the First Responder Network Authority; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t47/s1429/b/2/C","parentIdentifier":"/us/usc/t47/s1429/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1429%2Fb%2F2%2FC","sourceRelease":"119-100","text":"a description of any program, expenditure, or other financial transaction or undertaking of the First Responder Network Authority that was observed during the course of the audit, which, in the opinion of the independent auditor, has been carried on or made without the authority of law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
