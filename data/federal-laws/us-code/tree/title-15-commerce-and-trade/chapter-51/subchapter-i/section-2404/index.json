{"type":"section","nativeType":"section","number":"2404","heading":"Definitions","label":"2404 Definitions","identifier":"/us/usc/t15/s2404","parentIdentifier":"/us/usc/t15/ch51/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2404","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2404/1","parentIdentifier":"/us/usc/t15/s2404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2404%2F1","sourceRelease":"119-100","text":"the term “Center” means the National Center for Productivity and Quality of Working Life;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2404/2","parentIdentifier":"/us/usc/t15/s2404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2404%2F2","sourceRelease":"119-100","text":"the term “Board” means the Board of Directors of the Center;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s2404/3","parentIdentifier":"/us/usc/t15/s2404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2404%2F3","sourceRelease":"119-100","text":"the terms “productivity growth” and “improved productivity” shall be interpreted to include, but not be limited to, improvements in technology, management techniques, and the quality of working life; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s2404/4","parentIdentifier":"/us/usc/t15/s2404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2404%2F4","sourceRelease":"119-100","text":"the term “quality of working life” shall be interpreted to mean the conditions of work relating to the role of the worker in the production process.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
