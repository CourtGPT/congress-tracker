ew.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2655/a/2/A","parentIdentifier":"/us/usc/t7/s2655/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fa%2F2%2FA","sourceRelease":"119-100","text":"an emergency medical technician or the equivalent (as determined by the State);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2655/a/2/B","parentIdentifier":"/us/usc/t7/s2655/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fa%2F2%2FB","sourceRelease":"119-100","text":"a registered nurse;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s2655/a/2/C","parentIdentifier":"/us/usc/t7/s2655/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fa%2F2%2FC","sourceRelease":"119-100","text":"a physician assistant; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s2655/a/2/D","parentIdentifier":"/us/usc/t7/s2655/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fa%2F2%2FD","sourceRelease":"119-100","text":"a physician that provides services similar to services provided by such an emergency medical services provider.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Grants","label":"b Grants","identifier":"/us/usc/t7/s2655/b","parentIdentifier":"/us/usc/t7/s2655","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2655/b/1","parentIdentifier":"/us/usc/t7/s2655/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fb%2F1","sourceRelease":"119-100","text":"to enable the entities to provide for improved emergency medical services in rural areas; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2655/b/2","parentIdentifier":"/us/usc/t7/s2655/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fb%2F2","sourceRelease":"119-100","text":"to pay the cost of training firefighters and emergency medical personnel in firefighting, emergency medical practices, and responding to hazardous materials and bioagents in rural areas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Eligibility","label":"c Eligibility","identifier":"/us/usc/t7/s2655/c","parentIdentifier":"/us/usc/t7/s2655","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2655/c/1","parentIdentifier":"/us/usc/t7/s2655/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2655/c/1/A","parentIdentifier":"/us/usc/t7/s2655/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fc%2F1%2FA","sourceRelease":"119-100","text":"a State emergency medical services office;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2655/c/1/B","parentIdentifier":"/us/usc/t7/s2655/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fc%2F1%2FB","sourceRelease":"119-100","text":"a State emergency medical services association;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s2655/c/1/C","parentIdentifier":"/us/usc/t7/s2655/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fc%2F1%2FC","sourceRelease":"119-100","text":"a State office of rural health or an equivalent agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s2655/c/1/D","parentIdentifier":"/us/usc/t7/s2655/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fc%2F1%2FD","sourceRelease":"119-100","text":"a local government entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s2655/c/1/E","parentIdentifier":"/us/usc/t7/s2655/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fc%2F1%2FE","sourceRelease":"119-100","text":"an Indian tribe (as defined in );section 5304 of title 25","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t7/s2655/c/1/F","parentIdentifier":"/us/usc/t7/s2655/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fc%2F1%2FF","sourceRelease":"119-100","text":"a State or local ambulance provider; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t7/s2655/c/1/G","parentIdentifier":"/us/usc/t7/s2655/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fc%2F1%2FG","sourceRelease":"119-100","text":"any other public or nonprofit entity determined appropriate by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2655/c/2","parentIdentifier":"/us/usc/t7/s2655/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2655/c/2/A","parentIdentifier":"/us/usc/t7/s2655/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fc%2F2%2FA","sourceRelease":"119-100","text":"a description of the activities to be carried out under the grant; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2655/c/2/B","parentIdentifier":"/us/usc/t7/s2655/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fc%2F2%2FB","sourceRelease":"119-100","text":"an assurance that the applicant will comply with the matching requirement of subsection (f).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Use of funds","label":"d Use of funds","identifier":"/us/usc/t7/s2655/d","parentIdentifier":"/us/usc/t7/s2655","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2655/d/1","parentIdentifier":"/us/usc/t7/s2655/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fd%2F1","sourceRelease":"119-100","text":"to hire or recruit emergency medical service personnel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2655/d/2","parentIdentifier":"/us/usc/t7/s2655/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fd%2F2","sourceRelease":"119-100","text":"to recruit or retain volunteer emergency medical service personnel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s2655/d/3","parentIdentifier":"/us/usc/t7/s2655/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fd%2F3","sourceRelease":"119-100","text":"to train emergency medical service personnel in emergency response, injury prevention, safety awareness, or other topics relevant to the delivery of emergency medical services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s2655/d/4","parentIdentifier":"/us/usc/t7/s2655/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fd%2F4","sourceRelease":"119-100","text":"to fund training to meet State or Federal certification requirements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s2655/d/5","parentIdentifier":"/us/usc/t7/s2655/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fd%2F5","sourceRelease":"119-100","text":"to provide training for firefighters or emergency medical personnel for improvements to the training facility, equipment, curricula, or personnel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s2655/d/6","parentIdentifier":"/us/usc/t7/s2655/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fd%2F6","sourceRelease":"119-100","text":"to develop new ways to educate emergency health care providers through the use of technology-enhanced educational methods (such as distance learning);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t7/s2655/d/7","parentIdentifier":"/us/usc/t7/s2655/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fd%2F7","sourceRelease":"119-100","text":"to acquire emergency medical services vehicles, including ambulances;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t7/s2655/d/8","parentIdentifier":"/us/usc/t7/s2655/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fd%2F8","sourceRelease":"119-100","text":"to acquire emergency medical services equipment, including cardiac defibrillators;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t7/s2655/d/9","parentIdentifier":"/us/usc/t7/s2655/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fd%2F9","sourceRelease":"119-100","text":"to acquire personal protective equipment for emergency medical services personnel as required by the Occupational Safety and Health Administration; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t7/s2655/d/10","parentIdentifier":"/us/usc/t7/s2655/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fd%2F10","sourceRelease":"119-100","text":"to educate the public concerning cardiopulmonary resuscitation (CPR), first aid, injury prevention, safety awareness, illness prevention, or other related emergency preparedness topics.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Preference","label":"e Preference","identifier":"/us/usc/t7/s2655/e","parentIdentifier":"/us/usc/t7/s2655","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2655/e/1","parentIdentifier":"/us/usc/t7/s2655/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fe%2F1","sourceRelease":"119-100","text":"applications that reflect a collaborative effort by 2 or more of the entities described in subparagraphs (A) through (G) of subsection (c)(1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2655/e/2","parentIdentifier":"/us/usc/t7/s2655/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fe%2F2","sourceRelease":"119-100","text":"applications submitted by entities that intend to use amounts provided under the grant to fund activities described in any of paragraphs (1) through (5) of subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Matching requirement","label":"f Matching requirement","identifier":"/us/usc/t7/s2655/f","parentIdentifier":"/us/usc/t7/s2655","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Ff","sourceRelease":"119-100","text":"The Secretary may not make a grant under this section to an entity unless the entity makes available (directly or through contributions from other public or private entities) non-Federal contributions toward the activities to be carried out under the grant in an amount equal to at least 5 percent of the amount received under the grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Authorization of appropriations","label":"g Authorization of appropriations","identifier":"/us/usc/t7/s2655/g","parentIdentifier":"/us/usc/t7/s2655","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s2655/g/1","parentIdentifier":"/us/usc/t7/s2655/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fg%2F1","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary to carry out this section not more than $30,000,000 for each of fiscal years 2008 through 2012.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Administrative costs","label":"2 Administrative costs","identifier":"/us/usc/t7/s2655/g/2","parentIdentifier":"/us/usc/t7/s2655/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2655%2Fg%2F2","sourceRelease":"119-100","text":"Not more than 5 percent of the amount appropriated under paragraph (1) for a fiscal year may be used for administrative expenses incurred in carrying out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
