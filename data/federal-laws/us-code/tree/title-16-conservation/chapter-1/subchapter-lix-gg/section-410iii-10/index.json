{"type":"section","nativeType":"section","number":"410iii–10","heading":"Cooperative agreements","label":"410iii–10 Cooperative agreements","identifier":"/us/usc/t16/s410iii–10","parentIdentifier":"/us/usc/t16/ch1/schLIX–GG","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iii%E2%80%9310","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s410iii–10/a","parentIdentifier":"/us/usc/t16/s410iii–10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iii%E2%80%9310%2Fa","sourceRelease":"119-100","text":"In order to further the purposes of this subchapter, the Secretary is authorized to enter into cooperative agreements with interested public and private entities and individuals (including the National Trust for Historic Preservation, Belle Grove, Inc., the Cedar Creek Battlefield Foundation, the Shenandoah Valley Battlefields Foundation, and the Counties of Frederick, Shenandoah, and Warren), through technical and financial assistance, including encouraging the conservation of historic and natural resources of the Park.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Technical and financial assistance","label":"b Technical and financial assistance","identifier":"/us/usc/t16/s410iii–10/b","parentIdentifier":"/us/usc/t16/s410iii–10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iii%E2%80%9310%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410iii–10/b/1","parentIdentifier":"/us/usc/t16/s410iii–10/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iii%E2%80%9310%2Fb%2F1","sourceRelease":"119-100","text":"Preserving historic structures within the Park.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410iii–10/b/2","parentIdentifier":"/us/usc/t16/s410iii–10/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iii%E2%80%9310%2Fb%2F2","sourceRelease":"119-100","text":"Maintaining the natural or cultural landscape of the Park.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s410iii–10/b/3","parentIdentifier":"/us/usc/t16/s410iii–10/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iii%E2%80%9310%2Fb%2F3","sourceRelease":"119-100","text":"Local preservation planning, interpretation, and management of public visitation for the Park.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s410iii–10/b/4","parentIdentifier":"/us/usc/t16/s410iii–10/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iii%E2%80%9310%2Fb%2F4","sourceRelease":"119-100","text":"Furthering the goals of the Shenandoah Valley Battlefields Foundation related to the Park.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
