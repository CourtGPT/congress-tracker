{"type":"section","nativeType":"section","number":"21903","heading":"Ashanti Alert Coordinator","label":"21903 Ashanti Alert Coordinator","identifier":"/us/usc/t34/s21903","parentIdentifier":"/us/usc/t34/stII/ch219","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"National coordinator within Department of Justice","label":"a National coordinator within Department of Justice","identifier":"/us/usc/t34/s21903/a","parentIdentifier":"/us/usc/t34/s21903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fa","sourceRelease":"119-100","text":"The Attorney General shall designate an employee of the Office of Justice Programs of the Department of Justice to act as the national coordinator of the Ashanti Alert communications network.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties of the Coordinator","label":"b Duties of the Coordinator","identifier":"/us/usc/t34/s21903/b","parentIdentifier":"/us/usc/t34/s21903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s21903/b/1","parentIdentifier":"/us/usc/t34/s21903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F1","sourceRelease":"119-100","text":"work with States and Indian Tribes to encourage the development of additional Ashanti Alert plans in the network;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s21903/b/2","parentIdentifier":"/us/usc/t34/s21903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s21903/b/2/A","parentIdentifier":"/us/usc/t34/s21903/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F2%2FA","sourceRelease":"119-100","text":"a list of the resources necessary to establish an Ashanti Alert plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s21903/b/2/B","parentIdentifier":"/us/usc/t34/s21903/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s21903/b/2/B/i","parentIdentifier":"/us/usc/t34/s21903/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"whether the mental capacity of an adult who is missing, and the circumstances of his or her disappearance, including any history of domestic violence, sexual assault, child abuse, or human trafficking, warrant the issuance of an Ashanti Alert; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s21903/b/2/B/ii","parentIdentifier":"/us/usc/t34/s21903/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"whether the individual who reports that an adult is missing is an appropriate and credible source on which to base the issuance of an Ashanti Alert;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s21903/b/2/C","parentIdentifier":"/us/usc/t34/s21903/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F2%2FC","sourceRelease":"119-100","text":"a description of the appropriate uses of the Ashanti Alert name to readily identify the nature of search efforts for missing adults; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s21903/b/2/D","parentIdentifier":"/us/usc/t34/s21903/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F2%2FD","sourceRelease":"119-100","text":"recommendations on how to protect the privacy, dignity, independence, autonomy, and safety of any missing adult who may be the subject of an Ashanti Alert;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s21903/b/3","parentIdentifier":"/us/usc/t34/s21903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s21903/b/3/A","parentIdentifier":"/us/usc/t34/s21903/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F3%2FA","sourceRelease":"119-100","text":"public safety communications protocol;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s21903/b/3/B","parentIdentifier":"/us/usc/t34/s21903/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F3%2FB","sourceRelease":"119-100","text":"case management protocol;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s21903/b/3/C","parentIdentifier":"/us/usc/t34/s21903/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F3%2FC","sourceRelease":"119-100","text":"command center operations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s21903/b/3/D","parentIdentifier":"/us/usc/t34/s21903/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F3%2FD","sourceRelease":"119-100","text":"reunification protocol;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t34/s21903/b/3/E","parentIdentifier":"/us/usc/t34/s21903/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F3%2FE","sourceRelease":"119-100","text":"incident review, evaluation, debriefing, and public information procedures; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t34/s21903/b/3/F","parentIdentifier":"/us/usc/t34/s21903/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F3%2FF","sourceRelease":"119-100","text":"protocols for declining to issue an Ashanti Alert;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t34/s21903/b/4","parentIdentifier":"/us/usc/t34/s21903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F4","sourceRelease":"119-100","text":"work with States and Indian Tribes to ensure appropriate regional coordination of various elements of the network;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t34/s21903/b/5","parentIdentifier":"/us/usc/t34/s21903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s21903/b/5/A","parentIdentifier":"/us/usc/t34/s21903/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F5%2FA","sourceRelease":"119-100","text":"to the maximum extent practicable, representation from the various geographic regions of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s21903/b/5/B","parentIdentifier":"/us/usc/t34/s21903/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F5%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s21903/b/5/B/i","parentIdentifier":"/us/usc/t34/s21903/b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F5%2FB%2Fi","sourceRelease":"119-100","text":"representatives of adult citizen advocacy groups, law enforcement agencies, victim service providers (as defined in ), and public safety communications;section 12291(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s21903/b/5/B/ii","parentIdentifier":"/us/usc/t34/s21903/b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F5%2FB%2Fii","sourceRelease":"119-100","text":"broadcasters, first responders, dispatchers, and radio station personnel; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s21903/b/5/B/iii","parentIdentifier":"/us/usc/t34/s21903/b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F5%2FB%2Fiii","sourceRelease":"119-100","text":"representatives of any other individuals or organizations that the Coordinator determines are necessary to the success of the Ashanti Alert communications network; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t34/s21903/b/6","parentIdentifier":"/us/usc/t34/s21903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s21903/b/6/A","parentIdentifier":"/us/usc/t34/s21903/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F6%2FA","sourceRelease":"119-100","text":"the development of the network; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s21903/b/6/B","parentIdentifier":"/us/usc/t34/s21903/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fb%2F6%2FB","sourceRelease":"119-100","text":"regional coordination of alerts for missing adults through the network.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Coordination","label":"c Coordination","identifier":"/us/usc/t34/s21903/c","parentIdentifier":"/us/usc/t34/s21903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Coordination with other agencies","label":"1 Coordination with other agencies","identifier":"/us/usc/t34/s21903/c/1","parentIdentifier":"/us/usc/t34/s21903/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fc%2F1","sourceRelease":"119-100","text":"The Coordinator shall coordinate and consult with the Secretary of Transportation, the Federal Communications Commission, the Assistant Secretary for Aging of the Department of Health and Human Services, and other appropriate offices of the Department of Justice, including the Office on Violence Against Women, in carrying out activities under this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"State, tribal, and local coordination","label":"2 State, tribal, and local coordination","identifier":"/us/usc/t34/s21903/c/2","parentIdentifier":"/us/usc/t34/s21903/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fc%2F2","sourceRelease":"119-100","text":"The Coordinator shall consult with local broadcasters and State, Tribal, and local law enforcement agencies in establishing minimum standards under and in carrying out other activities under this chapter, as appropriate.section 21904 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Annual reports","label":"d Annual reports","identifier":"/us/usc/t34/s21903/d","parentIdentifier":"/us/usc/t34/s21903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t34/s21903/d/1","parentIdentifier":"/us/usc/t34/s21903/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s21903/d/1/A","parentIdentifier":"/us/usc/t34/s21903/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the activities of the Coordinator; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s21903/d/1/B","parentIdentifier":"/us/usc/t34/s21903/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F1%2FB","sourceRelease":"119-100","text":"the effectiveness and status of the Ashanti Alert plan of each State or Indian Tribe that has established or is in the process of establishing such a plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t34/s21903/d/2","parentIdentifier":"/us/usc/t34/s21903/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s21903/d/2/A","parentIdentifier":"/us/usc/t34/s21903/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2%2FA","sourceRelease":"119-100","text":"a list of each State or Indian Tribe that has established an Ashanti Alert plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s21903/d/2/B","parentIdentifier":"/us/usc/t34/s21903/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2%2FB","sourceRelease":"119-100","text":"a list of each State or Indian Tribe that is in the process of establishing an Ashanti Alert plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s21903/d/2/C","parentIdentifier":"/us/usc/t34/s21903/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s21903/d/2/C/i","parentIdentifier":"/us/usc/t34/s21903/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2%2FC%2Fi","sourceRelease":"119-100","text":"the number of Ashanti Alerts issued;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s21903/d/2/C/ii","parentIdentifier":"/us/usc/t34/s21903/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2%2FC%2Fii","sourceRelease":"119-100","text":"the number of missing adults located successfully;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s21903/d/2/C/iii","parentIdentifier":"/us/usc/t34/s21903/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2%2FC%2Fiii","sourceRelease":"119-100","text":"the average period of time between the issuance of an Ashanti Alert and the location of the missing adult for whom the Alert was issued;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t34/s21903/d/2/C/iv","parentIdentifier":"/us/usc/t34/s21903/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2%2FC%2Fiv","sourceRelease":"119-100","text":"the State or Tribal agency or authority issuing Ashanti Alerts, and the process by which Ashanti Alerts are disseminated;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t34/s21903/d/2/C/v","parentIdentifier":"/us/usc/t34/s21903/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2%2FC%2Fv","sourceRelease":"119-100","text":"the cost of establishing and operating the Ashanti Alert plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t34/s21903/d/2/C/vi","parentIdentifier":"/us/usc/t34/s21903/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2%2FC%2Fvi","sourceRelease":"119-100","text":"the criteria used by the State or Indian Tribe to determine whether to issue an Ashanti Alert; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t34/s21903/d/2/C/vii","parentIdentifier":"/us/usc/t34/s21903/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2%2FC%2Fvii","sourceRelease":"119-100","text":"the extent to which missing adults for whom Ashanti Alerts were issued crossed State lines or territorial borders of an Indian Tribe;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s21903/d/2/D","parentIdentifier":"/us/usc/t34/s21903/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2%2FD","sourceRelease":"119-100","text":"actions States and Indian Tribes have taken to protect the privacy and dignity of the missing adults for whom Ashanti Alerts are issued;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t34/s21903/d/2/E","parentIdentifier":"/us/usc/t34/s21903/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2%2FE","sourceRelease":"119-100","text":"ways that States and Indian Tribes have facilitated and improved communication about missing adults between families, caregivers, law enforcement officials, and other authorities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t34/s21903/d/2/F","parentIdentifier":"/us/usc/t34/s21903/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21903%2Fd%2F2%2FF","sourceRelease":"119-100","text":"any other information the Coordinator determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
