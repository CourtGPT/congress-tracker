{"type":"section","nativeType":"section","number":"13342","heading":"Oil substitution through coal liquefaction","label":"13342 Oil substitution through coal liquefaction","identifier":"/us/usc/t42/s13342","parentIdentifier":"/us/usc/t42/ch134/schVI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13342","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Program direction","label":"a Program direction","identifier":"/us/usc/t42/s13342/a","parentIdentifier":"/us/usc/t42/s13342","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13342%2Fa","sourceRelease":"119-100","text":"The Secretary shall conduct a program of research, development, demonstration, and commercial application for the purpose of developing economically and environmentally acceptable advanced technologies for oil substitution through coal liquefaction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Program goals","label":"b Program goals","identifier":"/us/usc/t42/s13342/b","parentIdentifier":"/us/usc/t42/s13342","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13342%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13342/b/1","parentIdentifier":"/us/usc/t42/s13342/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13342%2Fb%2F1","sourceRelease":"119-100","text":"improved resource selection and product quality;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13342/b/2","parentIdentifier":"/us/usc/t42/s13342/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13342%2Fb%2F2","sourceRelease":"119-100","text":"the development of technologies to increase net yield of liquid fuel product per ton of coal;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13342/b/3","parentIdentifier":"/us/usc/t42/s13342/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13342%2Fb%2F3","sourceRelease":"119-100","text":"an increase in overall thermal efficiency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s13342/b/4","parentIdentifier":"/us/usc/t42/s13342/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13342%2Fb%2F4","sourceRelease":"119-100","text":"a reduction in capital and operating costs through technology improvements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Proposals","label":"c Proposals","identifier":"/us/usc/t42/s13342/c","parentIdentifier":"/us/usc/t42/s13342","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13342%2Fc","sourceRelease":"119-100","text":"Within 180 days after , the Secretary shall solicit proposals for conducting activities under this section.October 24, 1992","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
