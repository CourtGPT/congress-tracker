{"type":"section","nativeType":"section","number":"3905","heading":"Accounting for fees on international loans","label":"3905 Accounting for fees on international loans","identifier":"/us/usc/t12/s3905","parentIdentifier":"/us/usc/t12/ch40","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3905","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t12/s3905/a","parentIdentifier":"/us/usc/t12/s3905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3905%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s3905/a/1","parentIdentifier":"/us/usc/t12/s3905/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3905%2Fa%2F1","sourceRelease":"119-100","text":"In order to avoid excessive debt service burdens on debtor countries, no banking institution shall charge, in connection with the restructuring of an international loan, any fee exceeding the administrative cost of the restructuring unless it amortizes such fee over the effective life of each such loan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s3905/a/2","parentIdentifier":"/us/usc/t12/s3905/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3905%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s3905/a/2/A","parentIdentifier":"/us/usc/t12/s3905/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3905%2Fa%2F2%2FA","sourceRelease":"119-100","text":"Each appropriate Federal banking agency shall promulgate such regulations as are necessary to further carry out the provisions of this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s3905/a/2/B","parentIdentifier":"/us/usc/t12/s3905/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3905%2Fa%2F2%2FB","sourceRelease":"119-100","text":"The requirement of paragraph (1) shall take effect on .November 30, 1983","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t12/s3905/b","parentIdentifier":"/us/usc/t12/s3905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3905%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s3905/b/1","parentIdentifier":"/us/usc/t12/s3905/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3905%2Fb%2F1","sourceRelease":"119-100","text":"Subject to subsection (a), the appropriate Federal banking agencies shall promulgate regulations for accounting for agency, commitment, management and other fees charged by a banking institution in connection with an international loan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s3905/b/2","parentIdentifier":"/us/usc/t12/s3905/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3905%2Fb%2F2","sourceRelease":"119-100","text":"Such regulations shall establish the accounting treatment of such fees for regulatory, supervisory, and disclosure purposes to assure that the appropriate portion of such fees is accrued in income over the effective life of each such loan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t12/s3905/b/3","parentIdentifier":"/us/usc/t12/s3905/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3905%2Fb%2F3","sourceRelease":"119-100","text":"The appropriate Federal banking agencies shall promulgate regulations or orders necessary to implement this subsection within one hundred and twenty days after .November 30, 1983","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
