{"type":"section","nativeType":"section","number":"284r","heading":"Basic research","label":"284r Basic research","identifier":"/us/usc/t42/s284r","parentIdentifier":"/us/usc/t42/ch6A/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextSection 2039, referred to in par. (1), is , which is set out as a note under .section 2039 of Pub. L. 114–255section 282 of this title","CodificationSection was enacted as part of the 21st Century Cures Act, and not as part of the Public Health Service Act which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Developing policies","label":"1 Developing policies","identifier":"/us/usc/t42/s284r/1","parentIdentifier":"/us/usc/t42/s284r","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s284r/1/A","parentIdentifier":"/us/usc/t42/s284r/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r%2F1%2FA","sourceRelease":"119-100","text":"relevant biological variables including sex, as appropriate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s284r/1/B","parentIdentifier":"/us/usc/t42/s284r/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r%2F1%2FB","sourceRelease":"119-100","text":"how differences between male and female cells, tissues, or animals may be examined and analyzed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Revising policies","label":"2 Revising policies","identifier":"/us/usc/t42/s284r/2","parentIdentifier":"/us/usc/t42/s284r","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r%2F2","sourceRelease":"119-100","text":"The Director of the National Institutes of Health may update or revise the policies developed under paragraph (1) as appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Consultation and outreach","label":"3 Consultation and outreach","identifier":"/us/usc/t42/s284r/3","parentIdentifier":"/us/usc/t42/s284r","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s284r/3/A","parentIdentifier":"/us/usc/t42/s284r/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s284r/3/A/i","parentIdentifier":"/us/usc/t42/s284r/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r%2F3%2FA%2Fi","sourceRelease":"119-100","text":"the Office of Research on Women’s Health;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s284r/3/A/ii","parentIdentifier":"/us/usc/t42/s284r/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r%2F3%2FA%2Fii","sourceRelease":"119-100","text":"the Office of Laboratory Animal Welfare; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s284r/3/A/iii","parentIdentifier":"/us/usc/t42/s284r/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"appropriate members of the scientific and academic communities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s284r/3/B","parentIdentifier":"/us/usc/t42/s284r/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r%2F3%2FB","sourceRelease":"119-100","text":"conduct outreach to solicit feedback from members of the scientific and academic communities on the influence of sex as a variable in basic research, including feedback on when it is appropriate for projects of basic research involving cells, tissues, or animals to include both male and female cells, tissues, or animals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Additional requirements","label":"4 Additional requirements","identifier":"/us/usc/t42/s284r/4","parentIdentifier":"/us/usc/t42/s284r","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s284r/4/A","parentIdentifier":"/us/usc/t42/s284r/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r%2F4%2FA","sourceRelease":"119-100","text":"ensure that projects of basic research funded by the National Institutes of Health are conducted in accordance with the policies developed, updated, or revised under this section, as applicable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s284r/4/B","parentIdentifier":"/us/usc/t42/s284r/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs284r%2F4%2FB","sourceRelease":"119-100","text":"encourage that the results of such research, when published or reported, be disaggregated as appropriate with respect to the analysis of any sex differences.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
