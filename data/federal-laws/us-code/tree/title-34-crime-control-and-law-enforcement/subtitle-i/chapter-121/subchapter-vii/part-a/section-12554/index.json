gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12554%2Fb%2F4","sourceRelease":"119-100","text":"meet the requirements of .section 12559 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
