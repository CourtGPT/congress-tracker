{"type":"section","nativeType":"section","number":"13105","heading":"Source Reduction Clearinghouse","label":"13105 Source Reduction Clearinghouse","identifier":"/us/usc/t42/s13105","parentIdentifier":"/us/usc/t42/ch133","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13105","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authority","label":"a Authority","identifier":"/us/usc/t42/s13105/a","parentIdentifier":"/us/usc/t42/s13105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13105%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13105/a/1","parentIdentifier":"/us/usc/t42/s13105/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13105%2Fa%2F1","sourceRelease":"119-100","text":"serve as a center for source reduction technology transfer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13105/a/2","parentIdentifier":"/us/usc/t42/s13105/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13105%2Fa%2F2","sourceRelease":"119-100","text":"mount active outreach and education programs by the States to further the adoption of source reduction technologies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13105/a/3","parentIdentifier":"/us/usc/t42/s13105/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13105%2Fa%2F3","sourceRelease":"119-100","text":"collect and compile information reported by States receiving grants under on the operation and success of State source reduction programs.section 13104 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Public availability","label":"b Public availability","identifier":"/us/usc/t42/s13105/b","parentIdentifier":"/us/usc/t42/s13105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13105%2Fb","sourceRelease":"119-100","text":"The Administrator shall make available to the public such information on source reduction as is gathered pursuant to this chapter and such other pertinent information and analysis regarding source reduction as may be available to the Administrator. The data base shall permit entry and retrieval of information to any person.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
