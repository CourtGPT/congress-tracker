{"type":"section","nativeType":"section","number":"355e","heading":"Pharmaceutical security","label":"355e Pharmaceutical security","identifier":"/us/usc/t21/s355e","parentIdentifier":"/us/usc/t21/ch9/schV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t21/s355e/a","parentIdentifier":"/us/usc/t21/s355e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fa","sourceRelease":"119-100","text":"The Secretary shall develop standards and identify and validate effective technologies for the purpose of securing the drug supply chain against counterfeit, diverted, subpotent, substandard, adulterated, misbranded, or expired drugs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Standards development","label":"b Standards development","identifier":"/us/usc/t21/s355e/b","parentIdentifier":"/us/usc/t21/s355e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t21/s355e/b/1","parentIdentifier":"/us/usc/t21/s355e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall, in consultation with the agencies specified in paragraph (4), manufacturers, distributors, pharmacies, and other supply chain stakeholders, prioritize and develop standards for the identification, validation, authentication, and tracking and tracing of prescription drugs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Standardized numeral identifier","label":"2 Standardized numeral identifier","identifier":"/us/usc/t21/s355e/b/2","parentIdentifier":"/us/usc/t21/s355e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fb%2F2","sourceRelease":"119-100","text":"Not later than 30 months after , the Secretary shall develop a standardized numerical identifier (which, to the extent practicable, shall be harmonized with international consensus standards for such an identifier) to be applied to a prescription drug at the point of manufacturing and repackaging (in which case the numerical identifier shall be linked to the numerical identifier applied at the point of manufacturing) at the package or pallet level, sufficient to facilitate the identification, validation, authentication, and tracking and tracing of the prescription drug.September 27, 2007","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Promising technologies","label":"3 Promising technologies","identifier":"/us/usc/t21/s355e/b/3","parentIdentifier":"/us/usc/t21/s355e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s355e/b/3/A","parentIdentifier":"/us/usc/t21/s355e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fb%2F3%2FA","sourceRelease":"119-100","text":"radio frequency identification technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s355e/b/3/B","parentIdentifier":"/us/usc/t21/s355e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fb%2F3%2FB","sourceRelease":"119-100","text":"nanotechnology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t21/s355e/b/3/C","parentIdentifier":"/us/usc/t21/s355e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fb%2F3%2FC","sourceRelease":"119-100","text":"encryption technologies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t21/s355e/b/3/D","parentIdentifier":"/us/usc/t21/s355e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fb%2F3%2FD","sourceRelease":"119-100","text":"other track-and-trace or authentication technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Interagency collaboration","label":"4 Interagency collaboration","identifier":"/us/usc/t21/s355e/b/4","parentIdentifier":"/us/usc/t21/s355e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s355e/b/4/A","parentIdentifier":"/us/usc/t21/s355e/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fb%2F4%2FA","sourceRelease":"119-100","text":"the Department of Justice;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s355e/b/4/B","parentIdentifier":"/us/usc/t21/s355e/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fb%2F4%2FB","sourceRelease":"119-100","text":"the Department of Homeland Security;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t21/s355e/b/4/C","parentIdentifier":"/us/usc/t21/s355e/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fb%2F4%2FC","sourceRelease":"119-100","text":"the Department of Commerce; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t21/s355e/b/4/D","parentIdentifier":"/us/usc/t21/s355e/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fb%2F4%2FD","sourceRelease":"119-100","text":"other appropriate Federal and State agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Inspection and enforcement","label":"c Inspection and enforcement","identifier":"/us/usc/t21/s355e/c","parentIdentifier":"/us/usc/t21/s355e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t21/s355e/c/1","parentIdentifier":"/us/usc/t21/s355e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary shall expand and enhance the resources and facilities of agency components of the Food and Drug Administration involved with regulatory and criminal enforcement of this chapter to secure the drug supply chain against counterfeit, diverted, subpotent, substandard, adulterated, misbranded, or expired drugs including biological products and active pharmaceutical ingredients from domestic and foreign sources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Activities","label":"2 Activities","identifier":"/us/usc/t21/s355e/c/2","parentIdentifier":"/us/usc/t21/s355e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fc%2F2","sourceRelease":"119-100","text":"The Secretary shall undertake enhanced and joint enforcement activities with other Federal and State agencies, and establish regional capacities for the validation of prescription drugs and the inspection of the prescription drug supply chain.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definition","label":"d Definition","identifier":"/us/usc/t21/s355e/d","parentIdentifier":"/us/usc/t21/s355e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355e%2Fd","sourceRelease":"119-100","text":"In this section, the term “prescription drug” means a drug subject to .section 353(b)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
