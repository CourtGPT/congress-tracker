{"type":"section","nativeType":"section","number":"5193","heading":"Amount of assistance","label":"5193 Amount of assistance","identifier":"/us/usc/t42/s5193","parentIdentifier":"/us/usc/t42/ch68/schIV–A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5193","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Federal share","label":"a Federal share","identifier":"/us/usc/t42/s5193/a","parentIdentifier":"/us/usc/t42/s5193","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5193%2Fa","sourceRelease":"119-100","text":"The Federal share for assistance provided under this subchapter shall be equal to not less than 75 percent of the eligible costs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limit on amount of assistance","label":"b Limit on amount of assistance","identifier":"/us/usc/t42/s5193/b","parentIdentifier":"/us/usc/t42/s5193","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5193%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s5193/b/1","parentIdentifier":"/us/usc/t42/s5193/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5193%2Fb%2F1","sourceRelease":"119-100","text":"Except as provided in paragraph (2), total assistance provided under this subchapter for a single emergency shall not exceed $5,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Additional assistance","label":"2 Additional assistance","identifier":"/us/usc/t42/s5193/b/2","parentIdentifier":"/us/usc/t42/s5193/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5193%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s5193/b/2/A","parentIdentifier":"/us/usc/t42/s5193/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5193%2Fb%2F2%2FA","sourceRelease":"119-100","text":"continued emergency assistance is immediately required;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s5193/b/2/B","parentIdentifier":"/us/usc/t42/s5193/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5193%2Fb%2F2%2FB","sourceRelease":"119-100","text":"there is a continuing and immediate risk to lives, property, public health or safety; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s5193/b/2/C","parentIdentifier":"/us/usc/t42/s5193/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5193%2Fb%2F2%2FC","sourceRelease":"119-100","text":"necessary assistance will not otherwise be provided on a timely basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Report","label":"3 Report","identifier":"/us/usc/t42/s5193/b/3","parentIdentifier":"/us/usc/t42/s5193/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs5193%2Fb%2F3","sourceRelease":"119-100","text":"Whenever the limitation described in paragraph (1) is exceeded, the President shall report to the Congress on the nature and extent of emergency assistance requirements and shall propose additional legislation if necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
