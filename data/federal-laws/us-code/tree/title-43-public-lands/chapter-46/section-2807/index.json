{"type":"section","nativeType":"section","number":"2807","heading":"Geoplatform","label":"2807 Geoplatform","identifier":"/us/usc/t43/s2807","parentIdentifier":"/us/usc/t43/ch46","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t43/s2807/a","parentIdentifier":"/us/usc/t43/s2807","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fa","sourceRelease":"119-100","text":"The Committee shall operate an electronic service that provides access to geospatial data and metadata for geospatial data to the general public, to be known as the GeoPlatform.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Implementation","label":"b Implementation","identifier":"/us/usc/t43/s2807/b","parentIdentifier":"/us/usc/t43/s2807","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s2807/b/1","parentIdentifier":"/us/usc/t43/s2807/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2807/b/1/A","parentIdentifier":"/us/usc/t43/s2807/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s2807/b/1/A/i","parentIdentifier":"/us/usc/t43/s2807/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"be available through the internet and other communications means;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s2807/b/1/A/ii","parentIdentifier":"/us/usc/t43/s2807/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"be accessible through a common interface;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t43/s2807/b/1/A/iii","parentIdentifier":"/us/usc/t43/s2807/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fb%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"include metadata for all geospatial data collected by covered agencies, directly or indirectly;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t43/s2807/b/1/A/iv","parentIdentifier":"/us/usc/t43/s2807/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fb%2F1%2FA%2Fiv","sourceRelease":"119-100","text":"include download access to all open geospatial data directly or indirectly collected by covered agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t43/s2807/b/1/A/v","parentIdentifier":"/us/usc/t43/s2807/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fb%2F1%2FA%2Fv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s2807/b/1/A/v/I","parentIdentifier":"/us/usc/t43/s2807/b/1/A/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fb%2F1%2FA%2Fv%2FI","sourceRelease":"119-100","text":"harmonize sources and data standards associated with geospatial data, including metadata; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s2807/b/1/A/v/II","parentIdentifier":"/us/usc/t43/s2807/b/1/A/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fb%2F1%2FA%2Fv%2FII","sourceRelease":"119-100","text":"to the maximum extent practicable, as determined by the Chairperson of the Committee, shall be made publicly available;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2807/b/1/B","parentIdentifier":"/us/usc/t43/s2807/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fb%2F1%2FB","sourceRelease":"119-100","text":"may include geospatial data from a source other than a covered agency, if determined appropriate by the Committee; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t43/s2807/b/1/C","parentIdentifier":"/us/usc/t43/s2807/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fb%2F1%2FC","sourceRelease":"119-100","text":"shall not store or serve proprietary information or data acquired under a license by the Federal Government, unless authorized by the data provider.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Managing partner","label":"2 Managing partner","identifier":"/us/usc/t43/s2807/b/2","parentIdentifier":"/us/usc/t43/s2807/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fb%2F2","sourceRelease":"119-100","text":"The Chairperson of the Committee shall designate an agency to serve as the managing partner for developing and operating the GeoPlatform, taking direction from the Committee on the scope, functionality, and performance of the GeoPlatform.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Clarification","label":"c Clarification","identifier":"/us/usc/t43/s2807/c","parentIdentifier":"/us/usc/t43/s2807","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2807/c/1","parentIdentifier":"/us/usc/t43/s2807/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fc%2F1","sourceRelease":"119-100","text":"specific to the functions of the covered agency; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2807/c/2","parentIdentifier":"/us/usc/t43/s2807/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2807%2Fc%2F2","sourceRelease":"119-100","text":"targeted to information consumers that directly interface with the services, portals, or other mechanisms of the covered agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
