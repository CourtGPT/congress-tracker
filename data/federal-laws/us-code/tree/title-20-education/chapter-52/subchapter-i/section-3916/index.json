{"type":"section","nativeType":"section","number":"3916","heading":"Other functional activities","label":"3916 Other functional activities","identifier":"/us/usc/t20/s3916","parentIdentifier":"/us/usc/t20/ch52/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3916","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t20/s3916/a","parentIdentifier":"/us/usc/t20/s3916","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3916%2Fa","sourceRelease":"119-100","text":"The Foundation is authorized to expend up to 15 per centum of the funds available for science and engineering education for applications which the Foundation determines will meet one or more of the functional objectives described in .section 3912(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t20/s3916/b","parentIdentifier":"/us/usc/t20/s3916","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3916%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s3916/b/1","parentIdentifier":"/us/usc/t20/s3916/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3916%2Fb%2F1","sourceRelease":"119-100","text":"has an enrollment which includes a substantial percentage of students who are members of a minority group, or who are economically or educationally disadvantaged; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s3916/b/2","parentIdentifier":"/us/usc/t20/s3916/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3916%2Fb%2F2","sourceRelease":"119-100","text":"is located in a community that is not within commuting distance of a major institution of higher education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s3916/b/3","parentIdentifier":"/us/usc/t20/s3916/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3916%2Fb%2F3","sourceRelease":"119-100","text":"demonstrates a commitment to meet the special educational needs of students who are members of a minority group or are economically or educationally disadvantaged.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
