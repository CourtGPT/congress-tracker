{"type":"section","nativeType":"section","number":"18444","heading":"Counterfeit parts","label":"18444 Counterfeit parts","identifier":"/us/usc/t42/s18444","parentIdentifier":"/us/usc/t42/ch159/schXI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s18444/a","parentIdentifier":"/us/usc/t42/s18444","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fa","sourceRelease":"119-100","text":"The Administrator shall plan, develop, and implement a program, in coordination with other Federal agencies, to detect, track, catalog, and reduce the number of counterfeit electronic parts in the NASA supply chain.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirements","label":"b Requirements","identifier":"/us/usc/t42/s18444/b","parentIdentifier":"/us/usc/t42/s18444","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18444/b/1","parentIdentifier":"/us/usc/t42/s18444/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18444/b/1/A","parentIdentifier":"/us/usc/t42/s18444/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb%2F1%2FA","sourceRelease":"119-100","text":"teach employees how to identify counterfeit parts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18444/b/1/B","parentIdentifier":"/us/usc/t42/s18444/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb%2F1%2FB","sourceRelease":"119-100","text":"educate employees on procedures to follow if they suspect a part is counterfeit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18444/b/1/C","parentIdentifier":"/us/usc/t42/s18444/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb%2F1%2FC","sourceRelease":"119-100","text":"regularly update employees on new threats, identification techniques, and reporting requirements; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s18444/b/1/D","parentIdentifier":"/us/usc/t42/s18444/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb%2F1%2FD","sourceRelease":"119-100","text":"integrate industry associations, manufacturers, suppliers, and other Federal agencies, as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18444/b/2","parentIdentifier":"/us/usc/t42/s18444/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18444/b/2/A","parentIdentifier":"/us/usc/t42/s18444/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb%2F2%2FA","sourceRelease":"119-100","text":"companies and individuals known and suspected of selling counterfeit parts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18444/b/2/B","parentIdentifier":"/us/usc/t42/s18444/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb%2F2%2FB","sourceRelease":"119-100","text":"parts known and suspected of being counterfeit, including lot and date codes, part numbers, and part images;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18444/b/2/C","parentIdentifier":"/us/usc/t42/s18444/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb%2F2%2FC","sourceRelease":"119-100","text":"countries of origin;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s18444/b/2/D","parentIdentifier":"/us/usc/t42/s18444/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb%2F2%2FD","sourceRelease":"119-100","text":"sources of reporting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s18444/b/2/E","parentIdentifier":"/us/usc/t42/s18444/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb%2F2%2FE","sourceRelease":"119-100","text":"United States Customs seizures; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s18444/b/2/F","parentIdentifier":"/us/usc/t42/s18444/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb%2F2%2FF","sourceRelease":"119-100","text":"Government-Industry Data Exchange Program reports and other public or private sector database notifications; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18444/b/3","parentIdentifier":"/us/usc/t42/s18444/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fb%2F3","sourceRelease":"119-100","text":"a mechanism to report all information on suspected and confirmed counterfeit electronic parts to law enforcement agencies, industry associations, and other databases, and to issue bulletins to industry on counterfeit electronic parts and related counterfeit activity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Review of procurement and acquisition policy","label":"c Review of procurement and acquisition policy","identifier":"/us/usc/t42/s18444/c","parentIdentifier":"/us/usc/t42/s18444","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18444/c/1","parentIdentifier":"/us/usc/t42/s18444/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fc%2F1","sourceRelease":"119-100","text":"In establishing the program, the Administrator shall amend existing acquisition and procurement policy to purchase electronic parts from trusted or approved manufacturers. To determine trusted or approved manufacturers, the Administrator shall establish a list, assessed and adjusted at least annually, and create criteria for manufacturers to meet in order to be placed onto the list.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Criteria","label":"2 Criteria","identifier":"/us/usc/t42/s18444/c/2","parentIdentifier":"/us/usc/t42/s18444/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18444/c/2/A","parentIdentifier":"/us/usc/t42/s18444/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fc%2F2%2FA","sourceRelease":"119-100","text":"authentication or encryption codes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18444/c/2/B","parentIdentifier":"/us/usc/t42/s18444/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fc%2F2%2FB","sourceRelease":"119-100","text":"embedded security markings in parts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18444/c/2/C","parentIdentifier":"/us/usc/t42/s18444/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fc%2F2%2FC","sourceRelease":"119-100","text":"unique, harder to copy labels and markings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s18444/c/2/D","parentIdentifier":"/us/usc/t42/s18444/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fc%2F2%2FD","sourceRelease":"119-100","text":"identifying distinct lot and serial codes on external packaging;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s18444/c/2/E","parentIdentifier":"/us/usc/t42/s18444/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fc%2F2%2FE","sourceRelease":"119-100","text":"radio frequency identification embedded into high-value parts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s18444/c/2/F","parentIdentifier":"/us/usc/t42/s18444/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fc%2F2%2FF","sourceRelease":"119-100","text":"physical destruction of all defective, damaged, and sub-standard parts that are by-products of the manufacturing process;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s18444/c/2/G","parentIdentifier":"/us/usc/t42/s18444/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fc%2F2%2FG","sourceRelease":"119-100","text":"testing certifications;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t42/s18444/c/2/H","parentIdentifier":"/us/usc/t42/s18444/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fc%2F2%2FH","sourceRelease":"119-100","text":"maintenance of procedures for handling any counterfeit parts that slip through;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s18444/c/2/I","parentIdentifier":"/us/usc/t42/s18444/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fc%2F2%2FI","sourceRelease":"119-100","text":"maintenance of secure facilities to prevent unauthorized access to proprietary information; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t42/s18444/c/2/J","parentIdentifier":"/us/usc/t42/s18444/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fc%2F2%2FJ","sourceRelease":"119-100","text":"maintenance of product return, buy back, and inventory control practices that limit counterfeiting.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Report to Congress","label":"d Report to Congress","identifier":"/us/usc/t42/s18444/d","parentIdentifier":"/us/usc/t42/s18444","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18444%2Fd","sourceRelease":"119-100","text":"Within one year after , the Administrator shall report on the progress of implementing this section to the appropriate committees of Congress.October 11, 2010","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
