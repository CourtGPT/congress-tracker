{"type":"section","nativeType":"section","number":"2653","heading":"Evacuation of family pets and contract working dogs during noncombatant evacuations of foreign countries","label":"2653 Evacuation of family pets and contract working dogs during noncombatant evacuations of foreign countries","identifier":"/us/usc/t10/s2653","parentIdentifier":"/us/usc/t10/stA/ptIV/ch157","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2653","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Authority to Evacuate","label":"a .—Authority to Evacuate","identifier":"/us/usc/t10/s2653/a","parentIdentifier":"/us/usc/t10/s2653","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2653%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2653/a/1","parentIdentifier":"/us/usc/t10/s2653/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2653%2Fa%2F1","sourceRelease":"119-100","text":"the family pets of citizens of the United States who are evacuated by the Department; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2653/a/2","parentIdentifier":"/us/usc/t10/s2653/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2653%2Fa%2F2","sourceRelease":"119-100","text":"contract working dogs located in such country.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Limitations","label":"b .—Limitations","identifier":"/us/usc/t10/s2653/b","parentIdentifier":"/us/usc/t10/s2653","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2653%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2653/b/1","parentIdentifier":"/us/usc/t10/s2653/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2653%2Fb%2F1","sourceRelease":"119-100","text":"The Department of Defense is not responsible for providing veterinary care for a family pet or contract working dog by reason of the evacuation of the pet or dog pursuant to subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2653/b/2","parentIdentifier":"/us/usc/t10/s2653/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2653%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary may not exercise the authority under subsection (a) if the exercise of such authority would result in a reduction in the number of individuals who would otherwise be evacuated.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2653/b/3","parentIdentifier":"/us/usc/t10/s2653/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2653%2Fb%2F3","sourceRelease":"119-100","text":"The operator of a vehicle used for evacuation may refuse to evacuate a family pet or contract working dog if the operator determines that the evacuation would create a safety risk to other passengers or personnel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
