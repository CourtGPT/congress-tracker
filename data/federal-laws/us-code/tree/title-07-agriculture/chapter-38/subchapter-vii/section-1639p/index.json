{"type":"section","nativeType":"section","number":"1639p","heading":"State and tribal plans","label":"1639p State and tribal plans","identifier":"/us/usc/t7/s1639p","parentIdentifier":"/us/usc/t7/ch38/schVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Submission","label":"a Submission","identifier":"/us/usc/t7/s1639p/a","parentIdentifier":"/us/usc/t7/s1639p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1639p/a/1","parentIdentifier":"/us/usc/t7/s1639p/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F1","sourceRelease":"119-100","text":"A State or Indian tribe desiring to have primary regulatory authority over the production of hemp in the State or territory of the Indian tribe shall submit to the Secretary, through the State department of agriculture (in consultation with the Governor and chief law enforcement officer of the State) or the Tribal government, as applicable, a plan under which the State or Indian tribe monitors and regulates that production as described in paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t7/s1639p/a/2","parentIdentifier":"/us/usc/t7/s1639p/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1639p/a/2/A","parentIdentifier":"/us/usc/t7/s1639p/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1639p/a/2/A/i","parentIdentifier":"/us/usc/t7/s1639p/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"a practice to maintain relevant information regarding land on which hemp is produced in the State or territory of the Indian tribe, including a legal description of the land, for a period of not less than 3 calendar years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1639p/a/2/A/ii","parentIdentifier":"/us/usc/t7/s1639p/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"a procedure for testing, using post-decarboxylation or other similarly reliable methods, delta-9 tetrahydrocannabinol concentration levels of hemp produced in the State or territory of the Indian tribe;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s1639p/a/2/A/iii","parentIdentifier":"/us/usc/t7/s1639p/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F2%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s1639p/a/2/A/iii/I","parentIdentifier":"/us/usc/t7/s1639p/a/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F2%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"plants, whether growing or not, that are produced in violation of this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s1639p/a/2/A/iii/II","parentIdentifier":"/us/usc/t7/s1639p/a/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F2%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"products derived from those plants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s1639p/a/2/A/iv","parentIdentifier":"/us/usc/t7/s1639p/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"a procedure to comply with the enforcement procedures under subsection (e);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t7/s1639p/a/2/A/v","parentIdentifier":"/us/usc/t7/s1639p/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F2%2FA%2Fv","sourceRelease":"119-100","text":"a procedure for conducting annual inspections of, at a minimum, a random sample of hemp producers to verify that hemp is not produced in violation of this subchapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t7/s1639p/a/2/A/vi","parentIdentifier":"/us/usc/t7/s1639p/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F2%2FA%2Fvi","sourceRelease":"119-100","text":"a procedure for submitting the information described in , as applicable, to the Secretary not more than 30 days after the date on which the information is received; andsection 1639q(d)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t7/s1639p/a/2/A/vii","parentIdentifier":"/us/usc/t7/s1639p/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F2%2FA%2Fvii","sourceRelease":"119-100","text":"a certification that the State or Indian tribe has the resources and personnel to carry out the practices and procedures described in clauses (i) through (vi); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1639p/a/2/B","parentIdentifier":"/us/usc/t7/s1639p/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F2%2FB","sourceRelease":"119-100","text":"may include any other practice or procedure established by a State or Indian tribe, as applicable, to the extent that the practice or procedure is consistent with this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Relation to State and tribal law","label":"3 Relation to State and tribal law","identifier":"/us/usc/t7/s1639p/a/3","parentIdentifier":"/us/usc/t7/s1639p/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"No preemption","label":"A No preemption","identifier":"/us/usc/t7/s1639p/a/3/A","parentIdentifier":"/us/usc/t7/s1639p/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1639p/a/3/A/i","parentIdentifier":"/us/usc/t7/s1639p/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F3%2FA%2Fi","sourceRelease":"119-100","text":"regulates the production of hemp; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1639p/a/3/A/ii","parentIdentifier":"/us/usc/t7/s1639p/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F3%2FA%2Fii","sourceRelease":"119-100","text":"is more stringent than this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"References in plans","label":"B References in plans","identifier":"/us/usc/t7/s1639p/a/3/B","parentIdentifier":"/us/usc/t7/s1639p/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fa%2F3%2FB","sourceRelease":"119-100","text":"A State or Tribal plan referred to in paragraph (1) may include a reference to a law of the State or Indian tribe regulating the production of hemp, to the extent that law is consistent with this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Approval","label":"b Approval","identifier":"/us/usc/t7/s1639p/b","parentIdentifier":"/us/usc/t7/s1639p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1639p/b/1","parentIdentifier":"/us/usc/t7/s1639p/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1639p/b/1/A","parentIdentifier":"/us/usc/t7/s1639p/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fb%2F1%2FA","sourceRelease":"119-100","text":"approve the State or Tribal plan if the State or Tribal plan complies with subsection (a); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1639p/b/1/B","parentIdentifier":"/us/usc/t7/s1639p/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fb%2F1%2FB","sourceRelease":"119-100","text":"disapprove the State or Tribal plan only if the State or Tribal plan does not comply with subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Amended plans","label":"2 Amended plans","identifier":"/us/usc/t7/s1639p/b/2","parentIdentifier":"/us/usc/t7/s1639p/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fb%2F2","sourceRelease":"119-100","text":"If the Secretary disapproves a State or Tribal plan under paragraph (1)(B), the State, through the State department of agriculture (in consultation with the Governor and chief law enforcement officer of the State) or the Tribal government, as applicable, may submit to the Secretary an amended State or Tribal plan that complies with subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Consultation","label":"3 Consultation","identifier":"/us/usc/t7/s1639p/b/3","parentIdentifier":"/us/usc/t7/s1639p/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fb%2F3","sourceRelease":"119-100","text":"The Secretary shall consult with the Attorney General in carrying out this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Audit of State compliance","label":"c Audit of State compliance","identifier":"/us/usc/t7/s1639p/c","parentIdentifier":"/us/usc/t7/s1639p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1639p/c/1","parentIdentifier":"/us/usc/t7/s1639p/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary may conduct an audit of the compliance of a State or Indian tribe with a State or Tribal plan approved under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Noncompliance","label":"2 Noncompliance","identifier":"/us/usc/t7/s1639p/c/2","parentIdentifier":"/us/usc/t7/s1639p/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1639p/c/2/A","parentIdentifier":"/us/usc/t7/s1639p/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the Secretary shall collaborate with the State or Indian tribe to develop a corrective action plan in the case of a first instance of noncompliance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1639p/c/2/B","parentIdentifier":"/us/usc/t7/s1639p/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the Secretary may revoke approval of the State or Tribal plan in the case of a second or subsequent instance of noncompliance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Technical assistance","label":"d Technical assistance","identifier":"/us/usc/t7/s1639p/d","parentIdentifier":"/us/usc/t7/s1639p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fd","sourceRelease":"119-100","text":"The Secretary may provide technical assistance to a State or Indian tribe in the development of a State or Tribal plan under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Violations","label":"e Violations","identifier":"/us/usc/t7/s1639p/e","parentIdentifier":"/us/usc/t7/s1639p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1639p/e/1","parentIdentifier":"/us/usc/t7/s1639p/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F1","sourceRelease":"119-100","text":"A violation of a State or Tribal plan approved under subsection (b) shall be subject to enforcement solely in accordance with this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Negligent violation","label":"2 Negligent violation","identifier":"/us/usc/t7/s1639p/e/2","parentIdentifier":"/us/usc/t7/s1639p/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s1639p/e/2/A","parentIdentifier":"/us/usc/t7/s1639p/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1639p/e/2/A/i","parentIdentifier":"/us/usc/t7/s1639p/e/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F2%2FA%2Fi","sourceRelease":"119-100","text":"failing to provide a legal description of land on which the producer produces hemp;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1639p/e/2/A/ii","parentIdentifier":"/us/usc/t7/s1639p/e/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F2%2FA%2Fii","sourceRelease":"119-100","text":"failing to obtain a license or other required authorization from the State department of agriculture or Tribal government, as applicable; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s1639p/e/2/A/iii","parentIdentifier":"/us/usc/t7/s1639p/e/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"producing Cannabis sativa L. with a delta-9 tetrahydrocannabinol concentration of more than 0.3 percent on a dry weight basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Corrective action plan","label":"B Corrective action plan","identifier":"/us/usc/t7/s1639p/e/2/B","parentIdentifier":"/us/usc/t7/s1639p/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1639p/e/2/B/i","parentIdentifier":"/us/usc/t7/s1639p/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F2%2FB%2Fi","sourceRelease":"119-100","text":"a reasonable date by which the hemp producer shall correct the negligent violation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1639p/e/2/B/ii","parentIdentifier":"/us/usc/t7/s1639p/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F2%2FB%2Fii","sourceRelease":"119-100","text":"a requirement that the hemp producer shall periodically report to the State department of agriculture or Tribal government, as applicable, on the compliance of the hemp producer with the State or Tribal plan for a period of not less than the next 2 calendar years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Result of negligent violation","label":"C Result of negligent violation","identifier":"/us/usc/t7/s1639p/e/2/C","parentIdentifier":"/us/usc/t7/s1639p/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F2%2FC","sourceRelease":"119-100","text":"A hemp producer that negligently violates a State or Tribal plan under subparagraph (A) shall not as a result of that violation be subject to any criminal enforcement action by the Federal Government or any State government, Tribal government, or local government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Repeat violations","label":"D Repeat violations","identifier":"/us/usc/t7/s1639p/e/2/D","parentIdentifier":"/us/usc/t7/s1639p/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F2%2FD","sourceRelease":"119-100","text":"A hemp producer that negligently violates a State or Tribal plan under subparagraph (A) 3 times in a 5-year period shall be ineligible to produce hemp for a period of 5 years beginning on the date of the third violation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Other violations","label":"3 Other violations","identifier":"/us/usc/t7/s1639p/e/3","parentIdentifier":"/us/usc/t7/s1639p/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s1639p/e/3/A","parentIdentifier":"/us/usc/t7/s1639p/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1639p/e/3/A/i","parentIdentifier":"/us/usc/t7/s1639p/e/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F3%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s1639p/e/3/A/i/I","parentIdentifier":"/us/usc/t7/s1639p/e/3/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F3%2FA%2Fi%2FI","sourceRelease":"119-100","text":"the Attorney General; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s1639p/e/3/A/i/II","parentIdentifier":"/us/usc/t7/s1639p/e/3/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F3%2FA%2Fi%2FII","sourceRelease":"119-100","text":"the chief law enforcement officer of the State or Indian tribe, as applicable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1639p/e/3/A/ii","parentIdentifier":"/us/usc/t7/s1639p/e/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F3%2FA%2Fii","sourceRelease":"119-100","text":"paragraph (1) of this subsection shall not apply to the violation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Felony","label":"B Felony","identifier":"/us/usc/t7/s1639p/e/3/B","parentIdentifier":"/us/usc/t7/s1639p/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t7/s1639p/e/3/B/i","parentIdentifier":"/us/usc/t7/s1639p/e/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F3%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s1639p/e/3/B/i/I","parentIdentifier":"/us/usc/t7/s1639p/e/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F3%2FB%2Fi%2FI","sourceRelease":"119-100","text":"to participate in the program established under this section or ; andsection 1639q of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s1639p/e/3/B/i/II","parentIdentifier":"/us/usc/t7/s1639p/e/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F3%2FB%2Fi%2FII","sourceRelease":"119-100","text":"to produce hemp under any regulations or guidelines issued under .section 1639r(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Exception","label":"ii Exception","identifier":"/us/usc/t7/s1639p/e/3/B/ii","parentIdentifier":"/us/usc/t7/s1639p/e/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F3%2FB%2Fii","sourceRelease":"119-100","text":"Clause (i) shall not apply to any person growing hemp lawfully with a license, registration, or authorization under a pilot program authorized by before .section 5940 of this titleDecember 20, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"False statement","label":"C False statement","identifier":"/us/usc/t7/s1639p/e/3/C","parentIdentifier":"/us/usc/t7/s1639p/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Fe%2F3%2FC","sourceRelease":"119-100","text":"Any person who materially falsifies any information contained in an application to participate in the program established under this section shall be ineligible to participate in that program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Effect","label":"f Effect","identifier":"/us/usc/t7/s1639p/f","parentIdentifier":"/us/usc/t7/s1639p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s1639p/f/1","parentIdentifier":"/us/usc/t7/s1639p/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Ff%2F1","sourceRelease":"119-100","text":"for which a State or Tribal plan is not approved under this section, if the production of hemp is in accordance with or other Federal laws (including regulations); andsection 1639q of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s1639p/f/2","parentIdentifier":"/us/usc/t7/s1639p/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1639p%2Ff%2F2","sourceRelease":"119-100","text":"if the production of hemp is not otherwise prohibited by the State or Indian tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
