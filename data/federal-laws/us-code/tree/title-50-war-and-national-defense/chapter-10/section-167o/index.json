{"type":"section","nativeType":"section","number":"167o","heading":"Low-Btu gas separation and helium conservation","label":"167o Low-Btu gas separation and helium conservation","identifier":"/us/usc/t50/s167o","parentIdentifier":"/us/usc/t50/ch10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsA prior section 17 of , was redesignated section 20 and is set out as a Separability note under .act Mar. 3, 1925, ch. 426section 167 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authorization","label":"a Authorization","identifier":"/us/usc/t50/s167o/a","parentIdentifier":"/us/usc/t50/s167o","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s167o/a/1","parentIdentifier":"/us/usc/t50/s167o/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o%2Fa%2F1","sourceRelease":"119-100","text":"to expand the domestic production of low-Btu gas and helium resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s167o/a/2","parentIdentifier":"/us/usc/t50/s167o/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o%2Fa%2F2","sourceRelease":"119-100","text":"to separate and capture helium from natural gas streams; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s167o/a/3","parentIdentifier":"/us/usc/t50/s167o/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o%2Fa%2F3","sourceRelease":"119-100","text":"to reduce the venting of helium and helium-bearing low-Btu gas during natural gas exploration and production.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Programs","label":"b Programs","identifier":"/us/usc/t50/s167o/b","parentIdentifier":"/us/usc/t50/s167o","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Membrane technology research","label":"1 Membrane technology research","identifier":"/us/usc/t50/s167o/b/1","parentIdentifier":"/us/usc/t50/s167o/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary of Energy, in consultation with other appropriate agencies, shall support a civilian research program to develop advanced membrane technology that is used in the separation of low-Btu gases, including technologies that remove helium and other constituent gases that lower the Btu content of natural gas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Helium separation technology","label":"2 Helium separation technology","identifier":"/us/usc/t50/s167o/b/2","parentIdentifier":"/us/usc/t50/s167o/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s167o/b/2/A","parentIdentifier":"/us/usc/t50/s167o/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o%2Fb%2F2%2FA","sourceRelease":"119-100","text":"low-Btu gas production streams; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s167o/b/2/B","parentIdentifier":"/us/usc/t50/s167o/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o%2Fb%2F2%2FB","sourceRelease":"119-100","text":"technologies that minimize the atmospheric venting of helium gas during natural gas production.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Industrial helium program","label":"3 Industrial helium program","identifier":"/us/usc/t50/s167o/b/3","parentIdentifier":"/us/usc/t50/s167o/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s167o/b/3/A","parentIdentifier":"/us/usc/t50/s167o/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o%2Fb%2F3%2FA","sourceRelease":"119-100","text":"to develop low-cost technologies and technology systems for recycling, reprocessing, and reusing helium for all medical, scientific, industrial, commercial, aerospace, and other uses of helium in the United States, including Federal uses; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s167o/b/3/B","parentIdentifier":"/us/usc/t50/s167o/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o%2Fb%2F3%2FB","sourceRelease":"119-100","text":"to develop industrial gathering technologies to capture helium from other chemical processing, including ammonia processing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t50/s167o/c","parentIdentifier":"/us/usc/t50/s167o","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs167o%2Fc","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $3,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
