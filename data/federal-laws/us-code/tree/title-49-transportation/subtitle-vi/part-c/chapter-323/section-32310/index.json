:[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s32310/c/3/C","parentIdentifier":"/us/usc/t49/s32310/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32310%2Fc%2F3%2FC","sourceRelease":"119-100","text":"any developments or information that would be necessary for the Secretary to consider including such a safety opportunity or technology in a future roadmap; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s32310/c/4","parentIdentifier":"/us/usc/t49/s32310/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32310%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s32310/c/4/A","parentIdentifier":"/us/usc/t49/s32310/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32310%2Fc%2F4%2FA","sourceRelease":"119-100","text":"within the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s32310/c/4/B","parentIdentifier":"/us/usc/t49/s32310/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32310%2Fc%2F4%2FB","sourceRelease":"119-100","text":"internationally.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Considerations","label":"d .—Considerations","identifier":"/us/usc/t49/s32310/d","parentIdentifier":"/us/usc/t49/s32310","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs32310%2Fd","sourceRelease":"119-100","text":null,"notes":[],"am