ffectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t49/s70204/c/1/J","parentIdentifier":"/us/usc/t49/s70204/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fc%2F1%2FJ","sourceRelease":"119-100","text":"units of local government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Activities","label":"2 .—Activities","identifier":"/us/usc/t49/s70204/c/2","parentIdentifier":"/us/usc/t49/s70204/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s70204/c/2/A","parentIdentifier":"/us/usc/t49/s70204/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s70204/c/2/A/i","parentIdentifier":"/us/usc/t49/s70204/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"freight mobility; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s70204/c/2/A/ii","parentIdentifier":"/us/usc/t49/s70204/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":"supply chains;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s70204/c/2/B","parentIdentifier":"/us/usc/t49/s70204/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fc%2F2%2FB","sourceRelease":"119-100","text":"serve as a forum for States, Indian Tribes, and other public entities to discuss decisions affecting freight mobility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s70204/c/2/C","parentIdentifier":"/us/usc/t49/s70204/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fc%2F2%2FC","sourceRelease":"119-100","text":"communicate and coordinate multi-State freight priorities with other organizations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t49/s70204/c/2/D","parentIdentifier":"/us/usc/t49/s70204/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fc%2F2%2FD","sourceRelease":"119-100","text":"promote the sharing of information between the private and public sectors with respect to freight issues; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t49/s70204/c/2/E","parentIdentifier":"/us/usc/t49/s70204/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fc%2F2%2FE","sourceRelease":"119-100","text":"provide information for consideration in the development of State freight plans under section 70202.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Grants.—","label":"d Grants.—","identifier":"/us/usc/t49/s70204/d","parentIdentifier":"/us/usc/t49/s70204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Establishment","label":"1 .—Establishment","identifier":"/us/usc/t49/s70204/d/1","parentIdentifier":"/us/usc/t49/s70204/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary of Transportation (referred to in this section as the “Secretary”) shall establish a program under which the Secretary shall provide grants to multi-State freight compacts, or States seeking to form a multi-State freight compact, that seek to improve a route or corridor that is a part of the National Multimodal Freight Network established under section 70103.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"New compacts.—","label":"2 New compacts.—","identifier":"/us/usc/t49/s70204/d/2","parentIdentifier":"/us/usc/t49/s70204/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t49/s70204/d/2/A","parentIdentifier":"/us/usc/t49/s70204/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s70204/d/2/A/i","parentIdentifier":"/us/usc/t49/s70204/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":"a multi-State freight compact established under subsection (a) during the 2-year period beginning on the date of establishment of the multi-State freight compact; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s70204/d/2/A/ii","parentIdentifier":"/us/usc/t49/s70204/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":"States seeking to form a multi-State freight compact described in that subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Eligibility.—","label":"B Eligibility.—","identifier":"/us/usc/t49/s70204/d/2/B","parentIdentifier":"/us/usc/t49/s70204/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":".—New multi-state freight compacts","label":"i .—New multi-state freight compacts","identifier":"/us/usc/t49/s70204/d/2/B/i","parentIdentifier":"/us/usc/t49/s70204/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F2%2FB%2Fi","sourceRelease":"119-100","text":"A multi-State freight compact shall be eligible for a grant under this paragraph only during the initial 2 years of operation of the compact.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":".—States seeking to form a compact","label":"ii .—States seeking to form a compact","identifier":"/us/usc/t49/s70204/d/2/B/ii","parentIdentifier":"/us/usc/t49/s70204/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t49/s70204/d/2/B/ii/I","parentIdentifier":"/us/usc/t49/s70204/d/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F2%2FB%2Fii%2FI","sourceRelease":"119-100","text":"the 2-year period beginning on the date on which an application for a grant under this paragraph with respect to the proposed compact is submitted to the Secretary; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t49/s70204/d/2/B/ii/II","parentIdentifier":"/us/usc/t49/s70204/d/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F2%2FB%2Fii%2FII","sourceRelease":"119-100","text":"if the compact is formed before the date on which a grant under this paragraph is awarded in accordance with subclause (I), the initial 2 years of operation of the compact.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":".—Requirements","label":"C .—Requirements","identifier":"/us/usc/t49/s70204/d/2/C","parentIdentifier":"/us/usc/t49/s70204/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s70204/d/2/C/i","parentIdentifier":"/us/usc/t49/s70204/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F2%2FC%2Fi","sourceRelease":"119-100","text":"submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s70204/d/2/C/ii","parentIdentifier":"/us/usc/t49/s70204/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F2%2FC%2Fii","sourceRelease":"119-100","text":"provide a non-Federal match equal to not less than 25 percent of the operating costs of the multi-State freight compact; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t49/s70204/d/2/C/iii","parentIdentifier":"/us/usc/t49/s70204/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F2%2FC%2Fiii","sourceRelease":"119-100","text":"commit to establishing a multi-State freight corridor advisory committee under subsection (c)(1) during the initial 2-year period of operation of the compact.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Existing compacts.—","label":"3 Existing compacts.—","identifier":"/us/usc/t49/s70204/d/3","parentIdentifier":"/us/usc/t49/s70204/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t49/s70204/d/3/A","parentIdentifier":"/us/usc/t49/s70204/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F3%2FA","sourceRelease":"119-100","text":"The Secretary may award a grant to multi-State freight compacts that are not eligible to receive a grant under paragraph (2) for operations costs in an amount of not more than $1,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Requirements","label":"B .—Requirements","identifier":"/us/usc/t49/s70204/d/3/B","parentIdentifier":"/us/usc/t49/s70204/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s70204/d/3/B/i","parentIdentifier":"/us/usc/t49/s70204/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F3%2FB%2Fi","sourceRelease":"119-100","text":"submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s70204/d/3/B/ii","parentIdentifier":"/us/usc/t49/s70204/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F3%2FB%2Fii","sourceRelease":"119-100","text":"provide a non-Federal match of not less than 50 percent of the operating costs of the compact; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t49/s70204/d/3/B/iii","parentIdentifier":"/us/usc/t49/s70204/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"demonstrate that the compact has established a multi-State freight corridor advisory committee under subsection (c)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Authorization of appropriations","label":"4 .—Authorization of appropriations","identifier":"/us/usc/t49/s70204/d/4","parentIdentifier":"/us/usc/t49/s70204/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fd%2F4","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary $5,000,000 for each fiscal year to carry out this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
