{"type":"section","nativeType":"section","number":"4724","heading":"Trade shows","label":"4724 Trade shows","identifier":"/us/usc/t15/s4724","parentIdentifier":"/us/usc/t15/ch73/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authority of Secretary of Commerce","label":"a Authority of Secretary of Commerce","identifier":"/us/usc/t15/s4724/a","parentIdentifier":"/us/usc/t15/s4724","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fa","sourceRelease":"119-100","text":"In order to facilitate exporting by United States businesses, the Secretary of Commerce shall provide assistance for trade shows in the United States which bring together representatives of United States businesses seeking to export goods or services produced in the United States and representatives of foreign companies or governments seeking to buy such goods or services from these United States businesses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Recipients of assistance","label":"b Recipients of assistance","identifier":"/us/usc/t15/s4724/b","parentIdentifier":"/us/usc/t15/s4724","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s4724/b/1","parentIdentifier":"/us/usc/t15/s4724/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fb%2F1","sourceRelease":"119-100","text":"nonprofit industry organizations,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s4724/b/2","parentIdentifier":"/us/usc/t15/s4724/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fb%2F2","sourceRelease":"119-100","text":"trade associations,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s4724/b/3","parentIdentifier":"/us/usc/t15/s4724/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fb%2F3","sourceRelease":"119-100","text":"foreign trade zones, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s4724/b/4","parentIdentifier":"/us/usc/t15/s4724/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fb%2F4","sourceRelease":"119-100","text":"private industry firms or groups of firms in cases where no entity described in paragraph (1), (2), or (3) represents that industry,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Assistance to small businesses","label":"c Assistance to small businesses","identifier":"/us/usc/t15/s4724/c","parentIdentifier":"/us/usc/t15/s4724","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fc","sourceRelease":"119-100","text":"In providing assistance under this section, the Secretary of Commerce shall, in consultation with the Administrator of the Small Business Administration, make special efforts to facilitate participation by small businesses and companies new to export.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Uses of assistance","label":"d Uses of assistance","identifier":"/us/usc/t15/s4724/d","parentIdentifier":"/us/usc/t15/s4724","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s4724/d/1","parentIdentifier":"/us/usc/t15/s4724/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fd%2F1","sourceRelease":"119-100","text":"identify potential participants for trade show organizers,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s4724/d/2","parentIdentifier":"/us/usc/t15/s4724/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fd%2F2","sourceRelease":"119-100","text":"provide information on trade shows to potential participants,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s4724/d/3","parentIdentifier":"/us/usc/t15/s4724/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fd%2F3","sourceRelease":"119-100","text":"supply language services for participants, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s4724/d/4","parentIdentifier":"/us/usc/t15/s4724/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fd%2F4","sourceRelease":"119-100","text":"provide information on trade shows to small businesses and companies new to export.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Definitions","label":"e Definitions","identifier":"/us/usc/t15/s4724/e","parentIdentifier":"/us/usc/t15/s4724","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s4724/e/1","parentIdentifier":"/us/usc/t15/s4724/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s4724/e/1/A","parentIdentifier":"/us/usc/t15/s4724/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fe%2F1%2FA","sourceRelease":"119-100","text":"a United States citizen;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s4724/e/1/B","parentIdentifier":"/us/usc/t15/s4724/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fe%2F1%2FB","sourceRelease":"119-100","text":"a corporation, partnership, or other association created under the laws of the United States or of any State (including the District of Columbia or any commonwealth, territory, or possession of the United States); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s4724/e/1/C","parentIdentifier":"/us/usc/t15/s4724/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fe%2F1%2FC","sourceRelease":"119-100","text":"a foreign corporation, partnership, or other association, more than 95 percent of which is owned by persons described in subparagraphs (A) and (B); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s4724/e/2","parentIdentifier":"/us/usc/t15/s4724/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4724%2Fe%2F2","sourceRelease":"119-100","text":"the term “small business” means any small business concern as defined under .section 632 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
