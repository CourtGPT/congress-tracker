s://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3221%2Fb%2F1","sourceRelease":"119-100","text":"Not later than 1 year after , the Comptroller General shall prepare a report that evaluates the grants made by the Economic Development Administration for the economic development of brownfield sites.October 27, 2004","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t42/s3221/b/2","parentIdentifier":"/us/usc/t42/s3221/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3221%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s3221/b/2/A","parentIdentifier":"/us/usc/t42/s3221/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3221%2Fb%2F2%2FA","sourceRelease":"119-100","text":"identify each project conducted during the previous 10-year period in which grant funds have been used for brownfield sites redevelopment activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s3221/b/2/B","parentIdentifier":"/us/usc/t42/s3221/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3221%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s3221/b/2/B/i","parentIdentifier":"/us/usc/t42/s3221/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3221%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the type of economic development activities conducted;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s3221/b/2/B/ii","parentIdentifier":"/us/usc/t42/s3221/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3221%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s3221/b/2/B/ii/I","parentIdentifier":"/us/usc/t42/s3221/b/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3221%2Fb%2F2%2FB%2Fii%2FI","sourceRelease":"119-100","text":"the type of remediation activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s3221/b/2/B/ii/II","parentIdentifier":"/us/usc/t42/s3221/b/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3221%2Fb%2F2%2FB%2Fii%2FII","sourceRelease":"119-100","text":"the amount of grant money used for those activities in dollars and as a percentage of the total grant award;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s3221/b/2/B/iii","parentIdentifier":"/us/usc/t42/s3221/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3221%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"the economic development and environmental standards applied, if applicable;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s3221/b/2/B/iv","parentIdentifier":"/us/usc/t42/s3221/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3221%2Fb%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"the economic development impact of the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s3221/b/2/B/v","parentIdentifier":"/us/usc/t42/s3221/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3221%2Fb%2F2%2FB%2Fv","sourceRelease":"119-100","text":"the role of Federal, State, or local environmental agencies, if any; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s3221/b/2/B/vi","parentIdentifier":"/us/usc/t42/s3221/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3221%2Fb%2F2%2FB%2Fvi","sourceRelease":"119-100","text":"public participation in the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Submission of report","label":"3 Submission of report","identifier":"/us/usc/t42/s3221/b/3","parentIdentifier":"/us/usc/t42/s3221/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3221%2Fb%2F3","sourceRelease":"119-100","text":"The Comptroller General shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a copy of the report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
