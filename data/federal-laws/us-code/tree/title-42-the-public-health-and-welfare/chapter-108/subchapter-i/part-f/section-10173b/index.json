{"type":"section","nativeType":"section","number":"10173b","heading":"Review Panel","label":"10173b Review Panel","identifier":"/us/usc/t42/s10173b","parentIdentifier":"/us/usc/t42/ch108/schI/ptF","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Codificationand added identical sections.Pub. L. 100–202Pub. L. 100–203","Amendments2022—Subsec. (e). substituted “Chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “chapter 10 of title 5” for “the Federal Advisory Committee Act” in text.Pub. L. 117–286"],"amendments":["Amendments2022—Subsec. (e). substituted “Chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “chapter 10 of title 5” for “the Federal Advisory Committee Act” in text.Pub. L. 117–286"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s10173b/a","parentIdentifier":"/us/usc/t42/s10173b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s10173b/a/1","parentIdentifier":"/us/usc/t42/s10173b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fa%2F1","sourceRelease":"119-100","text":"2 members selected by the Governor of such State or governing body of such Indian tribe;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s10173b/a/2","parentIdentifier":"/us/usc/t42/s10173b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fa%2F2","sourceRelease":"119-100","text":"2 members selected by units of local government affected by the repository or monitored retrievable storage facility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s10173b/a/3","parentIdentifier":"/us/usc/t42/s10173b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fa%2F3","sourceRelease":"119-100","text":"1 member to represent persons making payments into the Waste Fund, to be selected by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s10173b/a/4","parentIdentifier":"/us/usc/t42/s10173b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fa%2F4","sourceRelease":"119-100","text":"1 member to represent other public interests, to be selected by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Terms","label":"b Terms","identifier":"/us/usc/t42/s10173b/b","parentIdentifier":"/us/usc/t42/s10173b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s10173b/b/1","parentIdentifier":"/us/usc/t42/s10173b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fb%2F1","sourceRelease":"119-100","text":"The members of the Review Panel shall serve for terms of 4 years each.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s10173b/b/2","parentIdentifier":"/us/usc/t42/s10173b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fb%2F2","sourceRelease":"119-100","text":"Members of the Review Panel who are not full-time employees of the Federal Government, shall receive a per diem compensation for each day spent conducting work of the Review Panel, including their necessary travel or other expenses while engaged in the work of the Review Panel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s10173b/b/3","parentIdentifier":"/us/usc/t42/s10173b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fb%2F3","sourceRelease":"119-100","text":"Expenses of the Panel shall be paid by the Secretary from the Waste Fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duties","label":"c Duties","identifier":"/us/usc/t42/s10173b/c","parentIdentifier":"/us/usc/t42/s10173b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s10173b/c/1","parentIdentifier":"/us/usc/t42/s10173b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fc%2F1","sourceRelease":"119-100","text":"advise the Secretary on matters relating to the proposed repository or monitored retrievable storage facility, including issues relating to design, construction, operation, and decommissioning of the facility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s10173b/c/2","parentIdentifier":"/us/usc/t42/s10173b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fc%2F2","sourceRelease":"119-100","text":"evaluate performance of the repository or monitored retrievable storage facility, as it considers appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s10173b/c/3","parentIdentifier":"/us/usc/t42/s10173b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fc%2F3","sourceRelease":"119-100","text":"recommend corrective actions to the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s10173b/c/4","parentIdentifier":"/us/usc/t42/s10173b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fc%2F4","sourceRelease":"119-100","text":"assist in the presentation of State or affected Indian tribe and local perspectives to the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s10173b/c/5","parentIdentifier":"/us/usc/t42/s10173b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fc%2F5","sourceRelease":"119-100","text":"participate in the planning for and the review of preoperational data on environmental, demographic, and socioeconomic conditions of the site and the local community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Information","label":"d Information","identifier":"/us/usc/t42/s10173b/d","parentIdentifier":"/us/usc/t42/s10173b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fd","sourceRelease":"119-100","text":"The Secretary shall promptly make available promptly any information in the Secretary’s possession requested by the Panel or its Chairman.11So in original.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Chapter 10 of title 5","label":"e Chapter 10 of title 5","identifier":"/us/usc/t42/s10173b/e","parentIdentifier":"/us/usc/t42/s10173b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs10173b%2Fe","sourceRelease":"119-100","text":"The requirements of chapter 10 of title 5 shall not apply to a Review Panel established under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
