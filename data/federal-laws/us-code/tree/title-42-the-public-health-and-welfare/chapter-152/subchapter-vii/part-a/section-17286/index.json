{"type":"section","nativeType":"section","number":"17286","heading":"Geothermal assessment, exploration information, and priority activities","label":"17286 Geothermal assessment, exploration information, and priority activities","identifier":"/us/usc/t42/s17286","parentIdentifier":"/us/usc/t42/ch152/schVII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17286","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s17286/a","parentIdentifier":"/us/usc/t42/s17286","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17286%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17286/a/1","parentIdentifier":"/us/usc/t42/s17286/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17286%2Fa%2F1","sourceRelease":"119-100","text":"complete a comprehensive nationwide geothermal resource assessment that examines the full range of geothermal resources in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17286/a/2","parentIdentifier":"/us/usc/t42/s17286/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17286%2Fa%2F2","sourceRelease":"119-100","text":"submit to the the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a report describing the results of the assessment.1So in original.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Periodic updates","label":"b Periodic updates","identifier":"/us/usc/t42/s17286/b","parentIdentifier":"/us/usc/t42/s17286","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17286%2Fb","sourceRelease":"119-100","text":"At least once every 10 years, the Secretary shall update the national assessment required under this section to support public and private sector decisionmaking.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t42/s17286/c","parentIdentifier":"/us/usc/t42/s17286","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17286%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17286/c/1","parentIdentifier":"/us/usc/t42/s17286/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17286%2Fc%2F1","sourceRelease":"119-100","text":"$15,000,000 for each of fiscal years 2008 through 2012; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17286/c/2","parentIdentifier":"/us/usc/t42/s17286/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17286%2Fc%2F2","sourceRelease":"119-100","text":"such sums as are necessary for each of fiscal years 2013 through 2022.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
