,"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16411/a/1/C","parentIdentifier":"/us/usc/t42/s16411/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fa%2F1%2FC","sourceRelease":"119-100","text":"the oil and gas industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16411/a/1/D","parentIdentifier":"/us/usc/t42/s16411/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fa%2F1%2FD","sourceRelease":"119-100","text":"the nuclear power industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16411/a/1/E","parentIdentifier":"/us/usc/t42/s16411/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fa%2F1%2FE","sourceRelease":"119-100","text":"the coal industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s16411/a/1/F","parentIdentifier":"/us/usc/t42/s16411/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fa%2F1%2FF","sourceRelease":"119-100","text":"the electric utility industry; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s16411/a/1/G","parentIdentifier":"/us/usc/t42/s16411/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fa%2F1%2FG","sourceRelease":"119-100","text":"any other industrial sector, as the Secretary determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Skilled technical personnel","label":"2 Skilled technical personnel","identifier":"/us/usc/t42/s16411/a/2","parentIdentifier":"/us/usc/t42/s16411/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16411/a/2/A","parentIdentifier":"/us/usc/t42/s16411/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fa%2F2%2FA","sourceRelease":"119-100","text":"journey- and apprentice-level workers who are enrolled in, or have completed, a federally-recognized or State-recognized apprenticeship program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16411/a/2/B","parentIdentifier":"/us/usc/t42/s16411/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fa%2F2%2FB","sourceRelease":"119-100","text":"other skilled workers in energy technology industries, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Workforce trends","label":"b Workforce trends","identifier":"/us/usc/t42/s16411/b","parentIdentifier":"/us/usc/t42/s16411","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Monitoring","label":"1 Monitoring","identifier":"/us/usc/t42/s16411/b/1","parentIdentifier":"/us/usc/t42/s16411/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16411/b/1/A","parentIdentifier":"/us/usc/t42/s16411/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fb%2F1%2FA","sourceRelease":"119-100","text":"skilled technical personnel that support energy technology industries; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16411/b/1/B","parentIdentifier":"/us/usc/t42/s16411/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fb%2F1%2FB","sourceRelease":"119-100","text":"electric power and transmission engineers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report on trends","label":"2 Report on trends","identifier":"/us/usc/t42/s16411/b/2","parentIdentifier":"/us/usc/t42/s16411/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fb%2F2","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary shall submit to Congress a report on current trends under paragraph (1), with recommendations (as appropriate) to meet the future labor requirements for the energy technology industries.August 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Report on shortage","label":"3 Report on shortage","identifier":"/us/usc/t42/s16411/b/3","parentIdentifier":"/us/usc/t42/s16411/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fb%2F3","sourceRelease":"119-100","text":"As soon as practicable after the date on which the Secretary identifies or predicts a significant national shortage of skilled technical personnel in one or more energy technology industries, the Secretary shall submit to Congress a report describing the shortage.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Traineeship grants for skilled technical personnel","label":"c Traineeship grants for skilled technical personnel","identifier":"/us/usc/t42/s16411/c","parentIdentifier":"/us/usc/t42/s16411","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fc","sourceRelease":"119-100","text":"The Secretary, in consultation with the Secretary of Labor, may establish programs in the appropriate offices of the Department under which the Secretary provides grants to enhance training (including distance learning) for any workforce category for which a shortage is identified or predicted under subsection (b)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s16411/d","parentIdentifier":"/us/usc/t42/s16411","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16411%2Fd","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $20,000,000 for each of fiscal years 2006 through 2008.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
