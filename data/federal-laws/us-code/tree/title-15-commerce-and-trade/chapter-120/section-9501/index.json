=%2Fus%2Fusc%2Ft15%2Fs9501%2F4","sourceRelease":"119-100","text":"The term “Federal agency” has the meaning given the term “agency” in .section 551 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Federally recognized area of economic distress","label":"5 Federally recognized area of economic distress","identifier":"/us/usc/t15/s9501/5","parentIdentifier":"/us/usc/t15/s9501","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9501/5/A","parentIdentifier":"/us/usc/t15/s9501/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F5%2FA","sourceRelease":"119-100","text":"a HUBZone, as that term is defined in ;section 657a(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9501/5/B","parentIdentifier":"/us/usc/t15/s9501/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F5%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9501/5/B/i","parentIdentifier":"/us/usc/t15/s9501/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F5%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s9501/5/B/i/I","parentIdentifier":"/us/usc/t15/s9501/5/B/i","sourceUrl":"https://uscode.house.gov/view.x