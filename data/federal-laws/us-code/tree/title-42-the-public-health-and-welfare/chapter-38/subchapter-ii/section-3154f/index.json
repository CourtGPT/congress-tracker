{"type":"section","nativeType":"section","number":"3154f","heading":"Congressional notification requirements","label":"3154f Congressional notification requirements","identifier":"/us/usc/t42/s3154f","parentIdentifier":"/us/usc/t42/ch38/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s3154f/a","parentIdentifier":"/us/usc/t42/s3154f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fa","sourceRelease":"119-100","text":"In the case of a project described in subsection (b), the Secretary shall provide to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives notice, in accordance with subsection (c), of the award of a grant for the project not less than 3 business days before notifying an eligible recipient of their selection for that award.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Projects described","label":"b Projects described","identifier":"/us/usc/t42/s3154f/b","parentIdentifier":"/us/usc/t42/s3154f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fb","sourceRelease":"119-100","text":"A project referred to in subsection (a) is a project that the Secretary has selected to receive a grant administered by the Economic Development Administration in an amount not less than $100,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Requirements","label":"c Requirements","identifier":"/us/usc/t42/s3154f/c","parentIdentifier":"/us/usc/t42/s3154f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s3154f/c/1","parentIdentifier":"/us/usc/t42/s3154f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fc%2F1","sourceRelease":"119-100","text":"the name of the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s3154f/c/2","parentIdentifier":"/us/usc/t42/s3154f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fc%2F2","sourceRelease":"119-100","text":"the name of the applicant;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s3154f/c/3","parentIdentifier":"/us/usc/t42/s3154f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fc%2F3","sourceRelease":"119-100","text":"the region in which the project is to be carried out;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s3154f/c/4","parentIdentifier":"/us/usc/t42/s3154f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fc%2F4","sourceRelease":"119-100","text":"the State in which the project is to be carried out;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s3154f/c/5","parentIdentifier":"/us/usc/t42/s3154f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fc%2F5","sourceRelease":"119-100","text":"the 1 or more counties or political subdivisions in which the project is to be carried out;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s3154f/c/6","parentIdentifier":"/us/usc/t42/s3154f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fc%2F6","sourceRelease":"119-100","text":"the number of jobs expected to be created or retained as a result of the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s3154f/c/7","parentIdentifier":"/us/usc/t42/s3154f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fc%2F7","sourceRelease":"119-100","text":"the estimated date of completion of the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s3154f/c/8","parentIdentifier":"/us/usc/t42/s3154f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fc%2F8","sourceRelease":"119-100","text":"the amount of the grant awarded;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t42/s3154f/c/9","parentIdentifier":"/us/usc/t42/s3154f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fc%2F9","sourceRelease":"119-100","text":"a description of the project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t42/s3154f/c/10","parentIdentifier":"/us/usc/t42/s3154f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fc%2F10","sourceRelease":"119-100","text":"any additional information, as determined to be appropriate by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Public availability","label":"d Public availability","identifier":"/us/usc/t42/s3154f/d","parentIdentifier":"/us/usc/t42/s3154f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3154f%2Fd","sourceRelease":"119-100","text":"The Secretary shall make a notification under subsection (a) publicly available not later than 60 days after the date on which the Secretary provides the notice.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
