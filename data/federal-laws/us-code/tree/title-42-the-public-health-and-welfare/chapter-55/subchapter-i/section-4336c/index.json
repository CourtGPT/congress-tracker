ifier":"/us/usc/t42/s4336c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs4336c%2F4","sourceRelease":"119-100","text":"document adoption of the categorical exclusion.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
