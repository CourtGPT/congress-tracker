{"type":"section","nativeType":"section","number":"7433","heading":"Grants to reduce air pollution at ports","label":"7433 Grants to reduce air pollution at ports","identifier":"/us/usc/t42/s7433","parentIdentifier":"/us/usc/t42/ch85/schI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Appropriations","label":"a Appropriations","identifier":"/us/usc/t42/s7433/a","parentIdentifier":"/us/usc/t42/s7433","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"General assistance","label":"1 General assistance","identifier":"/us/usc/t42/s7433/a/1","parentIdentifier":"/us/usc/t42/s7433/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7433/a/1/A","parentIdentifier":"/us/usc/t42/s7433/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fa%2F1%2FA","sourceRelease":"119-100","text":"to purchase or install zero-emission port equipment or technology for use at, or to directly serve, one or more ports;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7433/a/1/B","parentIdentifier":"/us/usc/t42/s7433/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fa%2F1%2FB","sourceRelease":"119-100","text":"to conduct any relevant planning or permitting in connection with the purchase or installation of such zero-emission port equipment or technology; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s7433/a/1/C","parentIdentifier":"/us/usc/t42/s7433/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fa%2F1%2FC","sourceRelease":"119-100","text":"to develop qualified climate action plans.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Nonattainment areas","label":"2 Nonattainment areas","identifier":"/us/usc/t42/s7433/a/2","parentIdentifier":"/us/usc/t42/s7433/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fa%2F2","sourceRelease":"119-100","text":"In addition to amounts otherwise available, there is appropriated to the Administrator for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, $750,000,000, to remain available until , to award rebates and grants to eligible recipients to carry out activities described in paragraph (1) with respect to ports located in air quality areas designated pursuant to as nonattainment for an air pollutant.September 30, 2027section 7407 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitation","label":"b Limitation","identifier":"/us/usc/t42/s7433/b","parentIdentifier":"/us/usc/t42/s7433","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fb","sourceRelease":"119-100","text":"Funds awarded under this section shall not be used by any recipient or subrecipient to purchase or install zero-emission port equipment or technology that will not be located at, or directly serve, the one or more ports involved.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Administration of funds","label":"c Administration of funds","identifier":"/us/usc/t42/s7433/c","parentIdentifier":"/us/usc/t42/s7433","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fc","sourceRelease":"119-100","text":"Of the funds made available by this section, the Administrator shall reserve 2 percent for administrative costs necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definitions","label":"d Definitions","identifier":"/us/usc/t42/s7433/d","parentIdentifier":"/us/usc/t42/s7433","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible recipient","label":"1 Eligible recipient","identifier":"/us/usc/t42/s7433/d/1","parentIdentifier":"/us/usc/t42/s7433/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7433/d/1/A","parentIdentifier":"/us/usc/t42/s7433/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F1%2FA","sourceRelease":"119-100","text":"a port authority;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7433/d/1/B","parentIdentifier":"/us/usc/t42/s7433/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F1%2FB","sourceRelease":"119-100","text":"a State, regional, local, or Tribal agency that has jurisdiction over a port authority or a port;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s7433/d/1/C","parentIdentifier":"/us/usc/t42/s7433/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F1%2FC","sourceRelease":"119-100","text":"an air pollution control agency; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s7433/d/1/D","parentIdentifier":"/us/usc/t42/s7433/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F1%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s7433/d/1/D/i","parentIdentifier":"/us/usc/t42/s7433/d/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F1%2FD%2Fi","sourceRelease":"119-100","text":"applies for a grant under this section in partnership with an entity described in any of subparagraphs (A) through (C); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s7433/d/1/D/ii","parentIdentifier":"/us/usc/t42/s7433/d/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F1%2FD%2Fii","sourceRelease":"119-100","text":"owns, operates, or uses the facilities, cargo-handling equipment, transportation equipment, or related technology of a port.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Greenhouse gas","label":"2 Greenhouse gas","identifier":"/us/usc/t42/s7433/d/2","parentIdentifier":"/us/usc/t42/s7433/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F2","sourceRelease":"119-100","text":"The term “greenhouse gas” means the air pollutants carbon dioxide, hydrofluorocarbons, methane, nitrous oxide, perfluorocarbons, and sulfur hexafluoride.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Qualified climate action plan","label":"3 Qualified climate action plan","identifier":"/us/usc/t42/s7433/d/3","parentIdentifier":"/us/usc/t42/s7433/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7433/d/3/A","parentIdentifier":"/us/usc/t42/s7433/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s7433/d/3/A/i","parentIdentifier":"/us/usc/t42/s7433/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F3%2FA%2Fi","sourceRelease":"119-100","text":"greenhouse gases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s7433/d/3/A/ii","parentIdentifier":"/us/usc/t42/s7433/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F3%2FA%2Fii","sourceRelease":"119-100","text":"an air pollutant that is listed pursuant to (or any precursor to such an air pollutant); andsection 7408(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s7433/d/3/A/iii","parentIdentifier":"/us/usc/t42/s7433/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"hazardous air pollutants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7433/d/3/B","parentIdentifier":"/us/usc/t42/s7433/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F3%2FB","sourceRelease":"119-100","text":"includes a strategy to collaborate with, communicate with, and address potential effects on low-income and disadvantaged near-port communities and other stakeholders that may be affected by implementation of the plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s7433/d/3/C","parentIdentifier":"/us/usc/t42/s7433/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F3%2FC","sourceRelease":"119-100","text":"describes how an eligible recipient has implemented or will implement measures to increase the resilience of the one or more ports involved.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Zero-emission port equipment or technology","label":"4 Zero-emission port equipment or technology","identifier":"/us/usc/t42/s7433/d/4","parentIdentifier":"/us/usc/t42/s7433/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7433/d/4/A","parentIdentifier":"/us/usc/t42/s7433/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F4%2FA","sourceRelease":"119-100","text":"produces zero emissions of any air pollutant that is listed pursuant to (or any precursor to such an air pollutant) and any greenhouse gas other than water vapor; orsection 7408(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7433/d/4/B","parentIdentifier":"/us/usc/t42/s7433/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7433%2Fd%2F4%2FB","sourceRelease":"119-100","text":"captures 100 percent of the emissions described in subparagraph (A) that are produced by an ocean-going vessel at berth.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
