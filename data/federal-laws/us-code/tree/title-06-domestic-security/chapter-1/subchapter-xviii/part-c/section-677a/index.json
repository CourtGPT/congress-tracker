{"type":"section","nativeType":"section","number":"677a","heading":"Definitions","label":"677a Definitions","identifier":"/us/usc/t6/s677a","parentIdentifier":"/us/usc/t6/ch1/schXVIII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Asset response activity","label":"1 Asset response activity","identifier":"/us/usc/t6/s677a/1","parentIdentifier":"/us/usc/t6/s677a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s677a/1/A","parentIdentifier":"/us/usc/t6/s677a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F1%2FA","sourceRelease":"119-100","text":"furnishing technical and advisory assistance to the entity to protect the assets of the entity, mitigate vulnerabilities, and reduce the related impacts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s677a/1/B","parentIdentifier":"/us/usc/t6/s677a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F1%2FB","sourceRelease":"119-100","text":"assessing potential risks to the critical infrastructure sector or geographic region impacted by the incident, including potential cascading effects of the incident on other critical infrastructure sectors or geographic regions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s677a/1/C","parentIdentifier":"/us/usc/t6/s677a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F1%2FC","sourceRelease":"119-100","text":"developing courses of action to mitigate the risks assessed under subparagraph (B);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s677a/1/D","parentIdentifier":"/us/usc/t6/s677a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F1%2FD","sourceRelease":"119-100","text":"facilitating information sharing and operational coordination with entities performing threat response activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t6/s677a/1/E","parentIdentifier":"/us/usc/t6/s677a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F1%2FE","sourceRelease":"119-100","text":"providing guidance on how best to use Federal resources and capabilities in a timely, effective manner to speed recovery from the incident.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Declaration","label":"2 Declaration","identifier":"/us/usc/t6/s677a/2","parentIdentifier":"/us/usc/t6/s677a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F2","sourceRelease":"119-100","text":"The term “declaration” means a declaration of the Secretary under .section 677b(a)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Director","label":"3 Director","identifier":"/us/usc/t6/s677a/3","parentIdentifier":"/us/usc/t6/s677a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F3","sourceRelease":"119-100","text":"The term “Director” means the Director of the Cybersecurity and Infrastructure Security Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Federal agency","label":"4 Federal agency","identifier":"/us/usc/t6/s677a/4","parentIdentifier":"/us/usc/t6/s677a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F4","sourceRelease":"119-100","text":"The term “Federal agency” has the meaning given the term “agency” in .section 3502 of title 44","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Fund","label":"5 Fund","identifier":"/us/usc/t6/s677a/5","parentIdentifier":"/us/usc/t6/s677a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F5","sourceRelease":"119-100","text":"The term “Fund” means the Cyber Response and Recovery Fund established under .section 677c(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Incident","label":"6 Incident","identifier":"/us/usc/t6/s677a/6","parentIdentifier":"/us/usc/t6/s677a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F6","sourceRelease":"119-100","text":"The term “incident” has the meaning given the term in .section 3552 of title 44","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Renewal","label":"7 Renewal","identifier":"/us/usc/t6/s677a/7","parentIdentifier":"/us/usc/t6/s677a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F7","sourceRelease":"119-100","text":"The term “renewal” means a renewal of a declaration under .section 677b(d) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Significant incident","label":"8 Significant incident","identifier":"/us/usc/t6/s677a/8","parentIdentifier":"/us/usc/t6/s677a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s677a/8/A","parentIdentifier":"/us/usc/t6/s677a/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F8%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s677a/8/A/i","parentIdentifier":"/us/usc/t6/s677a/8/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F8%2FA%2Fi","sourceRelease":"119-100","text":"the national security interests, foreign relations, or economy of the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s677a/8/A/ii","parentIdentifier":"/us/usc/t6/s677a/8/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F8%2FA%2Fii","sourceRelease":"119-100","text":"the public confidence, civil liberties, or public health and safety of the people of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s677a/8/B","parentIdentifier":"/us/usc/t6/s677a/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F8%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s677a/8/B/i","parentIdentifier":"/us/usc/t6/s677a/8/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F8%2FB%2Fi","sourceRelease":"119-100","text":"a national security system (as defined in ); orsection 3552 of title 44","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s677a/8/B/ii","parentIdentifier":"/us/usc/t6/s677a/8/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677a%2F8%2FB%2Fii","sourceRelease":"119-100","text":"an information system described in paragraph (2) or (3) of .section 3553(e) of title 44","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
