dentifier":"/us/usc/t15/s70j/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs70j%2Fa%2F7","sourceRelease":"119-100","text":"sewing and handicraft threads;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t15/s70j/a/8","parentIdentifier":"/us/usc/t15/s70j/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs70j%2Fa%2F8","sourceRelease":"119-100","text":"bandages, surgical dressings, and other textile fiber products, the labeling of which is subject to the requirements of the Federal Food, Drug and Cosmetic Act of 1938, as amended [ et seq.];21 U.S.C. 301","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t15/s70j/a/9","parentIdentifier":"/us/usc/t15/s70j/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs70j%2Fa%2F9","sourceRelease":"119-100","text":"waste materials not intended for use in a textile fiber product;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t15/s70j/a/10","parentIdentifier":"/us/usc/t15/s70j/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs70j%2Fa%2F10","sourceRelease":"119-100","text":"textile fiber products incorporated in shoes or overshoes or similar outer footwear;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t15/s70j/a/11","parentIdentifier":"/us/usc/t15/s70j/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs70j%2Fa%2F11","sourceRelease":"119-100","text":"textile fiber products incorporated in headwear, handbags, luggage, brushes, lampshades, or toys, catamenial devices, adhesive tapes and adhesive sheets, cleaning cloths impregnated with chemicals, or diapers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t15/s70j/b","parentIdentifier":"/us/usc/t15/s70j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs70j%2Fb","sourceRelease":"119-100","text":"The Commission may exclude from the provisions of this subchapter other textile fiber products (1) which have an insignificant or inconsequential textile fiber content, or (2) with respect to which the disclosure of textile fiber content is not necessary for the protection of the ultimate consumer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
