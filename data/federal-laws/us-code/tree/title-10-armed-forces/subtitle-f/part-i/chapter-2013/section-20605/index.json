{"type":"section","nativeType":"section","number":"20605","heading":"Applicability of other provisions of law relating to retirement","label":"20605 Applicability of other provisions of law relating to retirement","identifier":"/us/usc/t10/s20605","parentIdentifier":"/us/usc/t10/stF/ptI/ch2013","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Applicability to Members of the Space Force","label":"a .—Applicability to Members of the Space Force","identifier":"/us/usc/t10/s20605/a","parentIdentifier":"/us/usc/t10/s20605","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s20605/a/1","parentIdentifier":"/us/usc/t10/s20605/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fa%2F1","sourceRelease":"119-100","text":"Provisions pertaining to an officer of the Air Force shall apply to an officer of the Space Force.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s20605/a/2","parentIdentifier":"/us/usc/t10/s20605/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fa%2F2","sourceRelease":"119-100","text":"Provisions pertaining to an enlisted member of the Air Force shall apply to an enlisted member of the Space Force.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s20605/a/3","parentIdentifier":"/us/usc/t10/s20605/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fa%2F3","sourceRelease":"119-100","text":"Provisions pertaining to a regular officer shall apply to an officer who is on sustained duty in the Space Force.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s20605/a/4","parentIdentifier":"/us/usc/t10/s20605/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fa%2F4","sourceRelease":"119-100","text":"Provisions pertaining to a regular enlisted member shall apply to an enlisted member who is on sustained duty in the Space Force.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s20605/a/5","parentIdentifier":"/us/usc/t10/s20605/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fa%2F5","sourceRelease":"119-100","text":"Provisions pertaining to a reserve officer shall apply to an officer who is in a space force active status but not on sustained duty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t10/s20605/a/6","parentIdentifier":"/us/usc/t10/s20605/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fa%2F6","sourceRelease":"119-100","text":"Provisions pertaining to a reserve enlisted member shall apply to an enlisted member who is in a space force active status but not on sustained duty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t10/s20605/a/7","parentIdentifier":"/us/usc/t10/s20605/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fa%2F7","sourceRelease":"119-100","text":"Provisions pertaining to service in a regular component shall apply to service on sustained duty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t10/s20605/a/8","parentIdentifier":"/us/usc/t10/s20605/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fa%2F8","sourceRelease":"119-100","text":"Provisions pertaining to service in a reserve component shall apply to service in a space force active status not on sustained duty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t10/s20605/a/9","parentIdentifier":"/us/usc/t10/s20605/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fa%2F9","sourceRelease":"119-100","text":"Provisions pertaining to a member of the Ready Reserve shall apply to a member of the Space Force who is in a space force active status prior to being ordered to active duty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t10/s20605/a/10","parentIdentifier":"/us/usc/t10/s20605/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fa%2F10","sourceRelease":"119-100","text":"Provisions pertaining to a member of the Retired Reserve shall apply to a member of the Space Force who has retired under chapter 1223 of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Provisions of Law","label":"b .—Provisions of Law","identifier":"/us/usc/t10/s20605/b","parentIdentifier":"/us/usc/t10/s20605","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s20605/b/1","parentIdentifier":"/us/usc/t10/s20605/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fb%2F1","sourceRelease":"119-100","text":"Chapter 61, relating to retirement or separation for physical disability.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s20605/b/2","parentIdentifier":"/us/usc/t10/s20605/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fb%2F2","sourceRelease":"119-100","text":"Chapter 63, relating to retirement for age.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s20605/b/3","parentIdentifier":"/us/usc/t10/s20605/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fb%2F3","sourceRelease":"119-100","text":"Chapter 69, relating to retired grade.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s20605/b/4","parentIdentifier":"/us/usc/t10/s20605/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fb%2F4","sourceRelease":"119-100","text":"Chapter 71, relating to computation of retired pay.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s20605/b/5","parentIdentifier":"/us/usc/t10/s20605/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fb%2F5","sourceRelease":"119-100","text":"Chapter 941, relating to retirement from the Air Force for length of service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t10/s20605/b/6","parentIdentifier":"/us/usc/t10/s20605/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fb%2F6","sourceRelease":"119-100","text":"Chapter 945, relating to computation of retired pay.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t10/s20605/b/7","parentIdentifier":"/us/usc/t10/s20605/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fb%2F7","sourceRelease":"119-100","text":"Chapter 1223, relating to retired pay for non-regular service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t10/s20605/b/8","parentIdentifier":"/us/usc/t10/s20605/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs20605%2Fb%2F8","sourceRelease":"119-100","text":"Chapter 1225, relating to retired grade.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
