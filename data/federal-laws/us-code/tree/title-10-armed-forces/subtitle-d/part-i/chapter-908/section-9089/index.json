{"type":"section","nativeType":"section","number":"9089","heading":"Program Executive Officer for Assured Access to Space","label":"9089 Program Executive Officer for Assured Access to Space","identifier":"/us/usc/t10/s9089","parentIdentifier":"/us/usc/t10/stD/ptI/ch908","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9089","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t10/s9089/a","parentIdentifier":"/us/usc/t10/s9089","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9089%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s9089/a/1","parentIdentifier":"/us/usc/t10/s9089/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9089%2Fa%2F1","sourceRelease":"119-100","text":"There is a Program Executive Officer for Assured Access to Space within the Space Force.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s9089/a/2","parentIdentifier":"/us/usc/t10/s9089/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9089%2Fa%2F2","sourceRelease":"119-100","text":"The Program Executive Officer for Assured Access to Space shall serve a term of four years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Grade","label":"b .—Grade","identifier":"/us/usc/t10/s9089/b","parentIdentifier":"/us/usc/t10/s9089","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9089%2Fb","sourceRelease":"119-100","text":"The Program Executive Officer for Assured Access to Space, while so serving, shall have the grade of brigadier general, major general, lieutenant general, or general.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Additional Duties","label":"c .—Additional Duties","identifier":"/us/usc/t10/s9089/c","parentIdentifier":"/us/usc/t10/s9089","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs9089%2Fc","sourceRelease":"119-100","text":"The Program Executive Officer for Assured Access to Space, while serving as the Program Executive Officer, shall also serve as the Commander of Space Launch Delta 45.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
