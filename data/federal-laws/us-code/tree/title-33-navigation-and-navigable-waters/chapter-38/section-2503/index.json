{"type":"section","nativeType":"section","number":"2503","heading":"Prohibition","label":"2503 Prohibition","identifier":"/us/usc/t33/s2503","parentIdentifier":"/us/usc/t33/ch38","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2503","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s2503/1","parentIdentifier":"/us/usc/t33/s2503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2503%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s2503/1/A","parentIdentifier":"/us/usc/t33/s2503/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2503%2F1%2FA","sourceRelease":"119-100","text":"the health or safety of individuals on board the vessel is threatened; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s2503/1/B","parentIdentifier":"/us/usc/t33/s2503/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2503%2F1%2FB","sourceRelease":"119-100","text":"during time of war or a declared national emergency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s2503/2","parentIdentifier":"/us/usc/t33/s2503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2503%2F2","sourceRelease":"119-100","text":"the waste is disposed of beyond 50 nautical miles from the nearest land; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s2503/3","parentIdentifier":"/us/usc/t33/s2503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2503%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s2503/3/A","parentIdentifier":"/us/usc/t33/s2503/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2503%2F3%2FA","sourceRelease":"119-100","text":"in the case of a public vessel which is not a submersible, the waste is sterilized, properly packaged, and sufficiently weighted to prevent the waste from coming ashore after disposal; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s2503/3/B","parentIdentifier":"/us/usc/t33/s2503/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2503%2F3%2FB","sourceRelease":"119-100","text":"in the case of a public vessel which is a submersible, the waste is properly packaged and sufficiently weighted to prevent the waste from coming ashore after disposal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
