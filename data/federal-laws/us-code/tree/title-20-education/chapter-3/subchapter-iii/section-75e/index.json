{"type":"section","nativeType":"section","number":"75e","heading":"Powers of Board","label":"75e Powers of Board","identifier":"/us/usc/t20/s75e","parentIdentifier":"/us/usc/t20/ch3/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs75e","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s75e/1","parentIdentifier":"/us/usc/t20/s75e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs75e%2F1","sourceRelease":"119-100","text":"purchase, accept, borrow, or otherwise acquire portraiture, statuary, and other items for preservation, exhibition, or study. The Board may acquire any such item on the basis of its general historical interest, its artistic merit, or the historical significance of the individual to which it relates, or any combination of any such factors. The Board may acquire period furniture and other items to enhance its displays of portraiture and statuary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s75e/2","parentIdentifier":"/us/usc/t20/s75e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs75e%2F2","sourceRelease":"119-100","text":"preserve or restore any item acquired pursuant to paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s75e/3","parentIdentifier":"/us/usc/t20/s75e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs75e%2F3","sourceRelease":"119-100","text":"display, loan, store, or otherwise hold any such item.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s75e/4","parentIdentifier":"/us/usc/t20/s75e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs75e%2F4","sourceRelease":"119-100","text":"sell, exchange, donate, return, or otherwise dispose of any such item.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
