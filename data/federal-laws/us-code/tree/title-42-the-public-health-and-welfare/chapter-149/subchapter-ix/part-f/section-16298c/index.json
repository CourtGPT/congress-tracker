{"type":"section","nativeType":"section","number":"16298c","heading":"National Energy Technology Laboratory reforms","label":"16298c National Energy Technology Laboratory reforms","identifier":"/us/usc/t42/s16298c","parentIdentifier":"/us/usc/t42/ch149/schIX/ptF","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Special hiring authority for scientific, engineering, and project management personnel","label":"a Special hiring authority for scientific, engineering, and project management personnel","identifier":"/us/usc/t42/s16298c/a","parentIdentifier":"/us/usc/t42/s16298c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16298c/a/1","parentIdentifier":"/us/usc/t42/s16298c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16298c/a/1/A","parentIdentifier":"/us/usc/t42/s16298c/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16298c/a/1/A/i","parentIdentifier":"/us/usc/t42/s16298c/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"have an advanced scientific or engineering background; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16298c/a/1/A/ii","parentIdentifier":"/us/usc/t42/s16298c/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"have a business background and can assist in specific technology-to-market needs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16298c/a/1/B","parentIdentifier":"/us/usc/t42/s16298c/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fa%2F1%2FB","sourceRelease":"119-100","text":"fix the basic pay of any employee appointed under subparagraph (A) at a rate not to exceed level II of the Executive Schedule under ; andsection 5313 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16298c/a/1/C","parentIdentifier":"/us/usc/t42/s16298c/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fa%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16298c/a/1/C/i","parentIdentifier":"/us/usc/t42/s16298c/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fa%2F1%2FC%2Fi","sourceRelease":"119-100","text":"$25,000;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16298c/a/1/C/ii","parentIdentifier":"/us/usc/t42/s16298c/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fa%2F1%2FC%2Fii","sourceRelease":"119-100","text":"the amount equal to 25 percent of the annual rate of basic pay of that employee; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16298c/a/1/C/iii","parentIdentifier":"/us/usc/t42/s16298c/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fa%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"the amount of the limitation that is applicable for a calendar year under .section 5307(a)(1) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitations","label":"2 Limitations","identifier":"/us/usc/t42/s16298c/a/2","parentIdentifier":"/us/usc/t42/s16298c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16298c/a/2/A","parentIdentifier":"/us/usc/t42/s16298c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fa%2F2%2FA","sourceRelease":"119-100","text":"The term of any employee appointed under paragraph (1)(A) shall not exceed 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Full-time employees","label":"B Full-time employees","identifier":"/us/usc/t42/s16298c/a/2/B","parentIdentifier":"/us/usc/t42/s16298c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fa%2F2%2FB","sourceRelease":"119-100","text":"Not more than 10 full-time employees appointed under paragraph (1)(A) may be employed at the National Energy Technology Laboratory at any given time.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Laboratory-directed research and development","label":"b Laboratory-directed research and development","identifier":"/us/usc/t42/s16298c/b","parentIdentifier":"/us/usc/t42/s16298c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16298c/b/1","parentIdentifier":"/us/usc/t42/s16298c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fb%2F1","sourceRelease":"119-100","text":"Beginning in fiscal year 2021, the National Energy Technology Laboratory shall be eligible for laboratory-directed research and development funding.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Authorization of funding","label":"2 Authorization of funding","identifier":"/us/usc/t42/s16298c/b/2","parentIdentifier":"/us/usc/t42/s16298c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16298c/b/2/A","parentIdentifier":"/us/usc/t42/s16298c/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fb%2F2%2FA","sourceRelease":"119-100","text":"Each fiscal year, of funds made available to the National Energy Technology Laboratory, the Secretary may deposit an amount, not to exceed the rate made available to the National Laboratories for laboratory-directed research and development, in a special fund account.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Use","label":"B Use","identifier":"/us/usc/t42/s16298c/b/2/B","parentIdentifier":"/us/usc/t42/s16298c/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fb%2F2%2FB","sourceRelease":"119-100","text":"Amounts in the account under subparagraph (A) shall only be available for laboratory-directed research and development.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Requirements","label":"C Requirements","identifier":"/us/usc/t42/s16298c/b/2/C","parentIdentifier":"/us/usc/t42/s16298c/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fb%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16298c/b/2/C/i","parentIdentifier":"/us/usc/t42/s16298c/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fb%2F2%2FC%2Fi","sourceRelease":"119-100","text":"shall be administered by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16298c/b/2/C/ii","parentIdentifier":"/us/usc/t42/s16298c/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fb%2F2%2FC%2Fii","sourceRelease":"119-100","text":"shall be available without fiscal year limitation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16298c/b/2/C/iii","parentIdentifier":"/us/usc/t42/s16298c/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fb%2F2%2FC%2Fiii","sourceRelease":"119-100","text":"shall not be subject to appropriation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Requirement","label":"3 Requirement","identifier":"/us/usc/t42/s16298c/b/3","parentIdentifier":"/us/usc/t42/s16298c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fb%2F3","sourceRelease":"119-100","text":"The Director shall carry out laboratory-directed research and development activities at the National Energy Technology Laboratory consistent with Department of Energy Order 413.2C, dated (or a successor order).August 2, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Annual report on use of authority","label":"4 Annual report on use of authority","identifier":"/us/usc/t42/s16298c/b/4","parentIdentifier":"/us/usc/t42/s16298c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fb%2F4","sourceRelease":"119-100","text":"Annually, the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Science, Space, and Technology of the House of Representatives a report on the use of the authority provided under this subsection during the preceding fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Laboratory operations","label":"c Laboratory operations","identifier":"/us/usc/t42/s16298c/c","parentIdentifier":"/us/usc/t42/s16298c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fc","sourceRelease":"119-100","text":"The Secretary shall delegate human resources operations of the National Energy Technology Laboratory to the Director to assist in carrying out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Review","label":"d Review","identifier":"/us/usc/t42/s16298c/d","parentIdentifier":"/us/usc/t42/s16298c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16298c/d/1","parentIdentifier":"/us/usc/t42/s16298c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fd%2F1","sourceRelease":"119-100","text":"an assessment of the quality of science and research at the National Energy Technology Laboratory, relative to similar work at other National Laboratories;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16298c/d/2","parentIdentifier":"/us/usc/t42/s16298c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fd%2F2","sourceRelease":"119-100","text":"a review of the effectiveness of authorities provided in subsections (a) and (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16298c/d/3","parentIdentifier":"/us/usc/t42/s16298c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16298c%2Fd%2F3","sourceRelease":"119-100","text":"recommendations for policy changes within the Department and legislative changes to provide the National Energy Technology Laboratory with the necessary tools and resources to advance the research mission of the National Energy Technology Laboratory.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
