{"type":"section","nativeType":"section","number":"8542","heading":"Identification of countries of concern with respect to the diversion of certain goods, services, and technologies to or through Iran","label":"8542 Identification of countries of concern with respect to the diversion of certain goods, services, and technologies to or through Iran","identifier":"/us/usc/t22/s8542","parentIdentifier":"/us/usc/t22/ch92/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542","sourceRelease":"119-100","text":null,"notes":["Termination of SectionFor termination of section, see .section 8551(a) of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s8542/a","parentIdentifier":"/us/usc/t22/s8542","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fa","sourceRelease":"119-100","text":"Not later than 180 days after , the Director of National Intelligence shall submit to the President, the Secretary of Defense, the Secretary of Commerce, the Secretary of State, the Secretary of the Treasury, and the appropriate congressional committees a report that identifies each country the government of which the Director believes, based on all information available to the Director, is allowing the diversion through the country of goods, services, or technologies described in subsection (b) to Iranian end-users or Iranian intermediaries.July 1, 2010","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Goods, services, and technologies described","label":"b Goods, services, and technologies described","identifier":"/us/usc/t22/s8542/b","parentIdentifier":"/us/usc/t22/s8542","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s8542/b/1","parentIdentifier":"/us/usc/t22/s8542/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s8542/b/1/A","parentIdentifier":"/us/usc/t22/s8542/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fb%2F1%2FA","sourceRelease":"119-100","text":"originated in the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s8542/b/1/B","parentIdentifier":"/us/usc/t22/s8542/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s8542/b/1/B/i","parentIdentifier":"/us/usc/t22/s8542/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"development of nuclear, chemical, or biological weapons;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s8542/b/1/B/ii","parentIdentifier":"/us/usc/t22/s8542/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"ballistic missile or advanced conventional weapons capabilities; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t22/s8542/b/1/B/iii","parentIdentifier":"/us/usc/t22/s8542/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fb%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"support for international terrorism; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s8542/b/1/C","parentIdentifier":"/us/usc/t22/s8542/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fb%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s8542/b/1/C/i","parentIdentifier":"/us/usc/t22/s8542/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fb%2F1%2FC%2Fi","sourceRelease":"119-100","text":"items on the Commerce Control List or services related to those items; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s8542/b/1/C/ii","parentIdentifier":"/us/usc/t22/s8542/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fb%2F1%2FC%2Fii","sourceRelease":"119-100","text":"defense articles or defense services on the United States Munitions List; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s8542/b/2","parentIdentifier":"/us/usc/t22/s8542/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fb%2F2","sourceRelease":"119-100","text":"that are prohibited for export to Iran under a resolution of the United Nations Security Council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Updates","label":"c Updates","identifier":"/us/usc/t22/s8542/c","parentIdentifier":"/us/usc/t22/s8542","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s8542/c/1","parentIdentifier":"/us/usc/t22/s8542/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fc%2F1","sourceRelease":"119-100","text":"as new information becomes available; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s8542/c/2","parentIdentifier":"/us/usc/t22/s8542/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fc%2F2","sourceRelease":"119-100","text":"not less frequently than annually.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Form","label":"d Form","identifier":"/us/usc/t22/s8542/d","parentIdentifier":"/us/usc/t22/s8542","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8542%2Fd","sourceRelease":"119-100","text":"The report required by subsection (a) and the updates required by subsection (c) may be submitted in classified form.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
