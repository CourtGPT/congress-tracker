,"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s4801/a/1/B/ii","parentIdentifier":"/us/usc/t15/s4801/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"research, science, and technology,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s4801/a/1/B/iii","parentIdentifier":"/us/usc/t15/s4801/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fa%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"education, labor retraining, and adjustment,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t15/s4801/a/1/B/iv","parentIdentifier":"/us/usc/t15/s4801/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fa%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"macroeconomic and budgetary issues,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t15/s4801/a/1/B/v","parentIdentifier":"/us/usc/t15/s4801/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fa%2F1%2FB%2Fv","sourceRelease":"119-100","text":"antitrust and regulation, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t15/s4801/a/1/B/vi","parentIdentifier":"/us/usc/t15/s4801/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fa%2F1%2FB%2Fvi","sourceRelease":"119-100","text":"government procurement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s4801/a/2","parentIdentifier":"/us/usc/t15/s4801/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fa%2F2","sourceRelease":"119-100","text":"the United States economy benefits when business, labor, government, academia, and public interest groups work together cooperatively;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s4801/a/3","parentIdentifier":"/us/usc/t15/s4801/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fa%2F3","sourceRelease":"119-100","text":"the decline of United States economic competitiveness endangers the ability of the United States to maintain the defense industrial base which is necessary to the national security of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s4801/a/4","parentIdentifier":"/us/usc/t15/s4801/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fa%2F4","sourceRelease":"119-100","text":"the world is moving rapidly toward the creation of an integrated and interdependent economy, a world economy in which the policies of one nation have a major impact on other nations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s4801/a/5","parentIdentifier":"/us/usc/t15/s4801/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fa%2F5","sourceRelease":"119-100","text":"integrated solutions to such issues as trade and investment research, science, and technology, education, and labor retraining and adjustments help the United States compete more effectively in the world economy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s4801/a/6","parentIdentifier":"/us/usc/t15/s4801/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fa%2F6","sourceRelease":"119-100","text":"government, business, labor, academia, and public interest groups shall cooperate to develop and coordinate long-range strategies to help assure the international competitiveness of the United States economy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purpose","label":"b Purpose","identifier":"/us/usc/t15/s4801/b","parentIdentifier":"/us/usc/t15/s4801","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s4801/b/1","parentIdentifier":"/us/usc/t15/s4801/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fb%2F1","sourceRelease":"119-100","text":"to develop recommendations for long-range strategies for promoting the international competitiveness of the United States industries; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s4801/b/2","parentIdentifier":"/us/usc/t15/s4801/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s4801/b/2/A","parentIdentifier":"/us/usc/t15/s4801/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fb%2F2%2FA","sourceRelease":"119-100","text":"analyze information regarding the competitiveness of United States industries and business and trade policy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s4801/b/2/B","parentIdentifier":"/us/usc/t15/s4801/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s4801/b/2/B/i","parentIdentifier":"/us/usc/t15/s4801/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"identify economic problems inhibiting the competitiveness of United States agriculture, business, and industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s4801/b/2/B/ii","parentIdentifier":"/us/usc/t15/s4801/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"develop long-term strategies to address such problem; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s4801/b/2/C","parentIdentifier":"/us/usc/t15/s4801/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fb%2F2%2FC","sourceRelease":"119-100","text":"make recommendations on issues crucial to the development of coordinated competitiveness strategies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s4801/b/2/D","parentIdentifier":"/us/usc/t15/s4801/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs4801%2Fb%2F2%2FD","sourceRelease":"119-100","text":"publish analysis in the form of periodic reports and recommendations concerning the United States business and trade policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
