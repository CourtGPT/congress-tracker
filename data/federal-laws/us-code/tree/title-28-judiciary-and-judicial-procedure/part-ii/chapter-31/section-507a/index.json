507A%2Fb%2F2","sourceRelease":"119-100","text":"serve as primary liaison to the Director of National Intelligence for the Department of Justice; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t28/s507A/b/3","parentIdentifier":"/us/usc/t28/s507A/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs507A%2Fb%2F3","sourceRelease":"119-100","text":"perform such other duties as the Attorney General may prescribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
