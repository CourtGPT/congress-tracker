subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161a/h/3/B","parentIdentifier":"/us/usc/t20/s1161a/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161a%2Fh%2F3%2FB","sourceRelease":"119-100","text":"the authorizing committees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Authorization of appropriations","label":"i Authorization of appropriations","identifier":"/us/usc/t20/s1161a/i","parentIdentifier":"/us/usc/t20/s1161a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161a%2Fi","sourceRelease":"119-100","text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
