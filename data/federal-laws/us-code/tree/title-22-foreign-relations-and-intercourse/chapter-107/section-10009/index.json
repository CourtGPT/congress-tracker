{"type":"section","nativeType":"section","number":"10009","heading":"Coordinated support to recover assets stolen from the Sudanese people","label":"10009 Coordinated support to recover assets stolen from the Sudanese people","identifier":"/us/usc/t22/s10009","parentIdentifier":"/us/usc/t22/ch107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10009","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10009/1","parentIdentifier":"/us/usc/t22/s10009","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10009%2F1","sourceRelease":"119-100","text":"to identify and track assets taken from the people and institutions of Sudan through theft, corruption, money laundering, or other illicit means; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10009/2","parentIdentifier":"/us/usc/t22/s10009","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10009%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10009/2/A","parentIdentifier":"/us/usc/t22/s10009/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10009%2F2%2FA","sourceRelease":"119-100","text":"to share financial investigations intelligence, as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10009/2/B","parentIdentifier":"/us/usc/t22/s10009/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10009%2F2%2FB","sourceRelease":"119-100","text":"to oversee and manage the assets identified pursuant to paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10009/2/C","parentIdentifier":"/us/usc/t22/s10009/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10009%2F2%2FC","sourceRelease":"119-100","text":"to advance civil forfeiture litigation, as appropriate, including providing technical assistance to help governments establish the necessary legal framework to carry out asset forfeitures; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s10009/2/D","parentIdentifier":"/us/usc/t22/s10009/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10009%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s10009/2/D/i","parentIdentifier":"/us/usc/t22/s10009/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10009%2F2%2FD%2Fi","sourceRelease":"119-100","text":"returned assets are not used for partisan political purposes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s10009/2/D/ii","parentIdentifier":"/us/usc/t22/s10009/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10009%2F2%2FD%2Fii","sourceRelease":"119-100","text":"there are robust financial management and oversight measures to safeguard repatriated assets.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
