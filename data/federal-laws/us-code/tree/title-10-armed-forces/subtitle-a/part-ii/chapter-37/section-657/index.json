{"type":"section","nativeType":"section","number":"657","heading":"Prohibition on service in the armed forces by individuals convicted of certain sexual offenses","label":"657 Prohibition on service in the armed forces by individuals convicted of certain sexual offenses","identifier":"/us/usc/t10/s657","parentIdentifier":"/us/usc/t10/stA/ptII/ch37","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs657","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Prohibition on Commissioning or Enlistment","label":"a .—Prohibition on Commissioning or Enlistment","identifier":"/us/usc/t10/s657/a","parentIdentifier":"/us/usc/t10/s657","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs657%2Fa","sourceRelease":"119-100","text":"A person who has been convicted of an offense specified in subsection (b) under Federal or State law may not be processed for commissioning or permitted to enlist in the armed forces.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Covered Offenses","label":"b .—Covered Offenses","identifier":"/us/usc/t10/s657/b","parentIdentifier":"/us/usc/t10/s657","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs657%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s657/b/1","parentIdentifier":"/us/usc/t10/s657/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs657%2Fb%2F1","sourceRelease":"119-100","text":"Rape or sexual assault.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s657/b/2","parentIdentifier":"/us/usc/t10/s657/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs657%2Fb%2F2","sourceRelease":"119-100","text":"Forcible sodomy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s657/b/3","parentIdentifier":"/us/usc/t10/s657/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs657%2Fb%2F3","sourceRelease":"119-100","text":"Incest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s657/b/4","parentIdentifier":"/us/usc/t10/s657/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs657%2Fb%2F4","sourceRelease":"119-100","text":"An attempt to commit an offense specified in paragraph (1) through (3), as punishable under applicable Federal or State law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
