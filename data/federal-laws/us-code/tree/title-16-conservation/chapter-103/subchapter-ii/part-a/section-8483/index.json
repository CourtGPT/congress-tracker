raph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8483/a/3/A","parentIdentifier":"/us/usc/t16/s8483/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8483%2Fa%2F3%2FA","sourceRelease":"119-100","text":"in compliance with all applicable land use and management plans of the Federal recreational lands and waters on which the accessible trail is located; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8483/a/3/B","parentIdentifier":"/us/usc/t16/s8483/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8483%2Fa%2F3%2FB","sourceRelease":"119-100","text":"in consultation with stakeholders, including veterans organizations and organizations with expertise or experience providing outdoor recreation opportunities to individuals with disabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Locations","label":"b Locations","identifier":"/us/usc/t16/s8483/b","parentIdentifier":"/us/usc/t16/s8483","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8483%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s8483/b/1","parentIdentifier":"/us/usc/t16/s8483/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8483%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary concerned shall select no fewer than 5 units or subunits under the jurisdiction of the respective Secretary concerned to carry out the pilot program established under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph