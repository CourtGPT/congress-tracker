{"type":"section","nativeType":"section","number":"8514b","heading":"Imposition of sanctions with respect to persons who engage in censorship or other related activities against citizens of Iran","label":"8514b Imposition of sanctions with respect to persons who engage in censorship or other related activities against citizens of Iran","identifier":"/us/usc/t22/s8514b","parentIdentifier":"/us/usc/t22/ch92/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8514b","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s8514b/a","parentIdentifier":"/us/usc/t22/s8514b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8514b%2Fa","sourceRelease":"119-100","text":"The President shall impose sanctions described in with respect to each person on the list required by subsection (b).section 8514(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"List of persons who engage in censorship","label":"b List of persons who engage in censorship","identifier":"/us/usc/t22/s8514b/b","parentIdentifier":"/us/usc/t22/s8514b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8514b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s8514b/b/1","parentIdentifier":"/us/usc/t22/s8514b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8514b%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s8514b/b/1/A","parentIdentifier":"/us/usc/t22/s8514b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8514b%2Fb%2F1%2FA","sourceRelease":"119-100","text":"prohibit, limit, or penalize the exercise of freedom of expression or assembly by citizens of Iran; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s8514b/b/1/B","parentIdentifier":"/us/usc/t22/s8514b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8514b%2Fb%2F1%2FB","sourceRelease":"119-100","text":"limit access to print or broadcast media, including the facilitation or support of intentional frequency manipulation by the Government of Iran or an entity owned or controlled by that Government that would jam or restrict an international signal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Updates of list","label":"2 Updates of list","identifier":"/us/usc/t22/s8514b/b/2","parentIdentifier":"/us/usc/t22/s8514b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8514b%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s8514b/b/2/A","parentIdentifier":"/us/usc/t22/s8514b/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8514b%2Fb%2F2%2FA","sourceRelease":"119-100","text":"each time the President is required to submit an updated list to those committees under ; andsection 8514(b)(2)(A) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s8514b/b/2/B","parentIdentifier":"/us/usc/t22/s8514b/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8514b%2Fb%2F2%2FB","sourceRelease":"119-100","text":"as new information becomes available.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Form of report; public availability","label":"3 Form of report; public availability","identifier":"/us/usc/t22/s8514b/b/3","parentIdentifier":"/us/usc/t22/s8514b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8514b%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Form","label":"A Form","identifier":"/us/usc/t22/s8514b/b/3/A","parentIdentifier":"/us/usc/t22/s8514b/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8514b%2Fb%2F3%2FA","sourceRelease":"119-100","text":"The list required by paragraph (1) shall be submitted in unclassified form but may contain a classified annex.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Public availability","label":"B Public availability","identifier":"/us/usc/t22/s8514b/b/3/B","parentIdentifier":"/us/usc/t22/s8514b/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8514b%2Fb%2F3%2FB","sourceRelease":"119-100","text":"The unclassified portion of the list required by paragraph (1) shall be made available to the public and posted on the websites of the Department of the Treasury and the Department of State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
