{"type":"section","nativeType":"section","number":"6873","heading":"Data consolidation and publication","label":"6873 Data consolidation and publication","identifier":"/us/usc/t16/s6873","parentIdentifier":"/us/usc/t16/ch87B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Federal waterway restrictions","label":"a Federal waterway restrictions","identifier":"/us/usc/t16/s6873/a","parentIdentifier":"/us/usc/t16/s6873","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s6873/a/1","parentIdentifier":"/us/usc/t16/s6873/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fa%2F1","sourceRelease":"119-100","text":"status information with respect to the conditions under which Federal waterways are open or closed to entry or watercraft, including watercraft inspection, decontamination requirements, low-elevation aircraft, or diving;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6873/a/2","parentIdentifier":"/us/usc/t16/s6873/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fa%2F2","sourceRelease":"119-100","text":"the dates on which Federal waterways are seasonally closed to entry or watercraft;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s6873/a/3","parentIdentifier":"/us/usc/t16/s6873/a","sourceUrl":"https://uscode.hou