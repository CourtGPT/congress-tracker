9-100","text":"net investment income for such taxable year, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s1411/a/1/B","parentIdentifier":"/us/usc/t26/s1411/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s1411/a/1/B/i","parentIdentifier":"/us/usc/t26/s1411/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the modified adjusted gross income for such taxable year, over","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s1411/a/1/B/ii","parentIdentifier":"/us/usc/t26/s1411/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the threshold amount.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Application to estates and trusts","label":"2 Application to estates and trusts","identifier":"/us/usc/t26/s1411/a/2","parentIdentifier":"/us/usc/t26/s1411/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s1411/a/2/A","parentIdentifier":"/us/usc/t26/s1411/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the undistributed net investment income for such taxable year, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s1411/a/2/B","parentIdentifier":"/us/usc/t26/s1411/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s1411/a/2/B/i","parentIdentifier":"/us/usc/t26/s1411/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the adjusted gross income (as defined in section 67(e)) for such taxable year, over","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s1411/a/2/B/ii","parentIdentifier":"/us/usc/t26/s1411/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the dollar amount at which the highest tax bracket in section 1(e) begins for such taxable year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Threshold amount","label":"b Threshold amount","identifier":"/us/usc/t26/s1411/b","parentIdentifier":"/us/usc/t26/s1411","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s1411/b/1","parentIdentifier":"/us/usc/t26/s1411/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fb%2F1","sourceRelease":"119-100","text":"in the case of a taxpayer making a joint return under section 6013 or a surviving spouse (as defined in section 2(a)), $250,000,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s1411/b/2","parentIdentifier":"/us/usc/t26/s1411/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fb%2F2","sourceRelease":"119-100","text":"in the case of a married taxpayer (as defined in section 7703) filing a separate return, ½ of the dollar amount determined under paragraph (1), and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t26/s1411/b/3","parentIdentifier":"/us/usc/t26/s1411/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fb%2F3","sourceRelease":"119-100","text":"in any other case, $200,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Net investment income","label":"c Net investment income","identifier":"/us/usc/t26/s1411/c","parentIdentifier":"/us/usc/t26/s1411","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t26/s1411/c/1","parentIdentifier":"/us/usc/t26/s1411/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s1411/c/1/A","parentIdentifier":"/us/usc/t26/s1411/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s1411/c/1/A/i","parentIdentifier":"/us/usc/t26/s1411/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"gross income from interest, dividends, annuities, royalties, and rents, other than such income which is derived in the ordinary course of a trade or business not described in paragraph (2),","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s1411/c/1/A/ii","parentIdentifier":"/us/usc/t26/s1411/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"other gross income derived from a trade or business described in paragraph (2), and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t26/s1411/c/1/A/iii","parentIdentifier":"/us/usc/t26/s1411/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"net gain (to the extent taken into account in computing taxable income) attributable to the disposition of property other than property held in a trade or business not described in paragraph (2), over","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s1411/c/1/B","parentIdentifier":"/us/usc/t26/s1411/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F1%2FB","sourceRelease":"119-100","text":"the deductions allowed by this subtitle which are properly allocable to such gross income or net gain.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Trades and businesses to which tax applies","label":"2 Trades and businesses to which tax applies","identifier":"/us/usc/t26/s1411/c/2","parentIdentifier":"/us/usc/t26/s1411/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s1411/c/2/A","parentIdentifier":"/us/usc/t26/s1411/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F2%2FA","sourceRelease":"119-100","text":"a passive activity (within the meaning of section 469) with respect to the taxpayer, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s1411/c/2/B","parentIdentifier":"/us/usc/t26/s1411/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F2%2FB","sourceRelease":"119-100","text":"a trade or business of trading in financial instruments or commodities (as defined in section 475(e)(2)).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Income on investment of working capital subject to tax","label":"3 Income on investment of working capital subject to tax","identifier":"/us/usc/t26/s1411/c/3","parentIdentifier":"/us/usc/t26/s1411/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F3","sourceRelease":"119-100","text":"A rule similar to the rule of section 469(e)(1)(B) shall apply for purposes of this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Exception for certain active interests in partnerships and S corporations","label":"4 Exception for certain active interests in partnerships and S corporations","identifier":"/us/usc/t26/s1411/c/4","parentIdentifier":"/us/usc/t26/s1411/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s1411/c/4/A","parentIdentifier":"/us/usc/t26/s1411/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F4%2FA","sourceRelease":"119-100","text":"gain from such disposition shall be taken into account under clause (iii) of paragraph (1)(A) only to the extent of the net gain which would be so taken into account by the transferor if all property of the partnership or S corporation were sold for fair market value immediately before the disposition of such interest, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s1411/c/4/B","parentIdentifier":"/us/usc/t26/s1411/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F4%2FB","sourceRelease":"119-100","text":"a rule similar to the rule of subparagraph (A) shall apply to a loss from such disposition.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Exception for distributions from qualified plans","label":"5 Exception for distributions from qualified plans","identifier":"/us/usc/t26/s1411/c/5","parentIdentifier":"/us/usc/t26/s1411/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F5","sourceRelease":"119-100","text":"The term “net investment income” shall not include any distribution from a plan or arrangement described in section 401(a), 403(a), 403(b), 408, 408A, or 457(b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Special rule","label":"6 Special rule","identifier":"/us/usc/t26/s1411/c/6","parentIdentifier":"/us/usc/t26/s1411/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fc%2F6","sourceRelease":"119-100","text":"Net investment income shall not include any item taken into account in determining self-employment income for such taxable year on which a tax is imposed by section 1401(b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Modified adjusted gross income","label":"d Modified adjusted gross income","identifier":"/us/usc/t26/s1411/d","parentIdentifier":"/us/usc/t26/s1411","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s1411/d/1","parentIdentifier":"/us/usc/t26/s1411/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fd%2F1","sourceRelease":"119-100","text":"the amount excluded from gross income under section 911(a)(1), over","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s1411/d/2","parentIdentifier":"/us/usc/t26/s1411/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fd%2F2","sourceRelease":"119-100","text":"the amount of any deductions (taken into account in computing adjusted gross income) or exclusions disallowed under section 911(d)(6) with respect to the amounts described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Nonapplication of section","label":"e Nonapplication of section","identifier":"/us/usc/t26/s1411/e","parentIdentifier":"/us/usc/t26/s1411","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s1411/e/1","parentIdentifier":"/us/usc/t26/s1411/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fe%2F1","sourceRelease":"119-100","text":"a nonresident alien, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s1411/e/2","parentIdentifier":"/us/usc/t26/s1411/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs1411%2Fe%2F2","sourceRelease":"119-100","text":"a trust all of the unexpired interests in which are devoted to one or more of the purposes described in section 170(c)(2)(B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
