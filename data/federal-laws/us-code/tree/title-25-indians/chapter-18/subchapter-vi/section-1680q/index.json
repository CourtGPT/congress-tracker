{"type":"section","nativeType":"section","number":"1680q","heading":"Prescription drug monitoring","label":"1680q Prescription drug monitoring","identifier":"/us/usc/t25/s1680q","parentIdentifier":"/us/usc/t25/ch18/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Codificationis based on section 196 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by .Section 827 of Pub. L. 94–437section 10221(a) of Pub. L. 111–148"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Monitoring","label":"a Monitoring","identifier":"/us/usc/t25/s1680q/a","parentIdentifier":"/us/usc/t25/s1680q","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t25/s1680q/a/1","parentIdentifier":"/us/usc/t25/s1680q/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary, in coordination with the Secretary of the Interior and the Attorney General, shall establish a prescription drug monitoring program, to be carried out at health care facilities of the Service, tribal health care facilities, and urban Indian health care facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report","label":"2 Report","identifier":"/us/usc/t25/s1680q/a/2","parentIdentifier":"/us/usc/t25/s1680q/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1680q/a/2/A","parentIdentifier":"/us/usc/t25/s1680q/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the needs of the Service, tribal health care facilities, and urban Indian health care facilities with respect to the prescription drug monitoring program under paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1680q/a/2/B","parentIdentifier":"/us/usc/t25/s1680q/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the planned development of that program, including any relevant statutory or administrative limitations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1680q/a/2/C","parentIdentifier":"/us/usc/t25/s1680q/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fa%2F2%2FC","sourceRelease":"119-100","text":"the means by which the program could be carried out in coordination with any State prescription drug monitoring program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Abuse","label":"b Abuse","identifier":"/us/usc/t25/s1680q/b","parentIdentifier":"/us/usc/t25/s1680q","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s1680q/b/1","parentIdentifier":"/us/usc/t25/s1680q/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1680q/b/1/A","parentIdentifier":"/us/usc/t25/s1680q/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s1680q/b/1/A/i","parentIdentifier":"/us/usc/t25/s1680q/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"to carry out data collection and analysis regarding incidents of prescription drug abuse in Indian communities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s1680q/b/1/A/ii","parentIdentifier":"/us/usc/t25/s1680q/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"to exchange among those agencies and Indian health programs information relating to prescription drug abuse in Indian communities, including statutory and administrative requirements and limitations relating to that abuse; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1680q/b/1/B","parentIdentifier":"/us/usc/t25/s1680q/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fb%2F1%2FB","sourceRelease":"119-100","text":"training for Indian health care providers, tribal leaders, law enforcement officers, and school officials regarding awareness and prevention of prescription drug abuse and strategies for improving agency responses to addressing prescription drug abuse in Indian communities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report","label":"2 Report","identifier":"/us/usc/t25/s1680q/b/2","parentIdentifier":"/us/usc/t25/s1680q/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1680q/b/2/A","parentIdentifier":"/us/usc/t25/s1680q/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the capacity of Federal and tribal agencies to carry out data collection and analysis and information exchanges as described in paragraph (1)(A);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1680q/b/2/B","parentIdentifier":"/us/usc/t25/s1680q/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the training conducted pursuant to paragraph (1)(B);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1680q/b/2/C","parentIdentifier":"/us/usc/t25/s1680q/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fb%2F2%2FC","sourceRelease":"119-100","text":"infrastructure enhancements required to carry out the activities described in paragraph (1), if any; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s1680q/b/2/D","parentIdentifier":"/us/usc/t25/s1680q/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680q%2Fb%2F2%2FD","sourceRelease":"119-100","text":"any statutory or administrative barriers to carrying out those activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
