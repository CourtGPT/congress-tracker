orth Korea; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s7802/5","parentIdentifier":"/us/usc/t22/s7802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7802%2F5","sourceRelease":"119-100","text":"to promote progress toward the peaceful reunification of the Korean peninsula under a democratic system of government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
