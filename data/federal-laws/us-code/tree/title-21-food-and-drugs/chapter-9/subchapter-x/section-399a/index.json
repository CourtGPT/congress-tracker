{"type":"section","nativeType":"section","number":"399a","heading":"Office of the Chief Scientist","label":"399a Office of the Chief Scientist","identifier":"/us/usc/t21/s399a","parentIdentifier":"/us/usc/t21/ch9/schX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs399a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment; appointment","label":"a Establishment; appointment","identifier":"/us/usc/t21/s399a/a","parentIdentifier":"/us/usc/t21/s399a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs399a%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish within the Office of the Commissioner an office to be known as the Office of the Chief Scientist. The Secretary shall appoint a Chief Scientist to lead such Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties of the Office","label":"b Duties of the Office","identifier":"/us/usc/t21/s399a/b","parentIdentifier":"/us/usc/t21/s399a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs399a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s399a/b/1","parentIdentifier":"/us/usc/t21/s399a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs399a%2Fb%2F1","sourceRelease":"119-100","text":"oversee, coordinate, and ensure quality and regulatory focus of the intramural research programs of the Food and Drug Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s399a/b/2","parentIdentifier":"/us/usc/t21/s399a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs399a%2Fb%2F2","sourceRelease":"119-100","text":"track and, to the extent necessary, coordinate intramural research awards made by each center of the Administration or science-based office within the Office of the Commissioner, and ensure that there is no duplication of research efforts supported by the Reagan-Udall Foundation for the Food and Drug Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t21/s399a/b/3","parentIdentifier":"/us/usc/t21/s399a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs399a%2Fb%2F3","sourceRelease":"119-100","text":"develop and advocate for a budget to support intramural research;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t21/s399a/b/4","parentIdentifier":"/us/usc/t21/s399a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs399a%2Fb%2F4","sourceRelease":"119-100","text":"develop a peer review process by which intramural research can be evaluated;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t21/s399a/b/5","parentIdentifier":"/us/usc/t21/s399a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs399a%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s399a/b/5/A","parentIdentifier":"/us/usc/t21/s399a/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs399a%2Fb%2F5%2FA","sourceRelease":"119-100","text":"representatives of each of the centers and the science-based offices within the Office of the Commissioner; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s399a/b/5/B","parentIdentifier":"/us/usc/t21/s399a/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs399a%2Fb%2F5%2FB","sourceRelease":"119-100","text":"experts on trial design, epidemiology, demographics, pharmacovigilance, basic science, and public health; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t21/s399a/b/6","parentIdentifier":"/us/usc/t21/s399a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs399a%2Fb%2F6","sourceRelease":"119-100","text":"develop postmarket safety performance measures that are as measurable and rigorous as the ones already developed for premarket review.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
