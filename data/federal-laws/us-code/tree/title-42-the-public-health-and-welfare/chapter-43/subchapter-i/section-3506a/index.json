{"type":"section","nativeType":"section","number":"3506a","heading":"Scientific engagement","label":"3506a Scientific engagement","identifier":"/us/usc/t42/s3506a","parentIdentifier":"/us/usc/t42/ch43/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s3506a/a","parentIdentifier":"/us/usc/t42/s3506a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s3506a/a/1","parentIdentifier":"/us/usc/t42/s3506a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fa%2F1","sourceRelease":"119-100","text":"shall not be considered conferences for the purposes of complying with Federal reporting requirements contained in annual appropriations Acts or in this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s3506a/a/2","parentIdentifier":"/us/usc/t42/s3506a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fa%2F2","sourceRelease":"119-100","text":"shall not be considered conferences for purposes of a restriction contained in an annual appropriations Act, based on Office of Management and Budget Memorandum M-12-12 or any other regulation restricting travel to such meeting.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitation","label":"b Limitation","identifier":"/us/usc/t42/s3506a/b","parentIdentifier":"/us/usc/t42/s3506a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fb","sourceRelease":"119-100","text":"Nothing in this section shall be construed to exempt travel for scientific meetings from Federal regulations relating to travel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Reports","label":"c Reports","identifier":"/us/usc/t42/s3506a/c","parentIdentifier":"/us/usc/t42/s3506a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s3506a/c/1","parentIdentifier":"/us/usc/t42/s3506a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fc%2F1","sourceRelease":"119-100","text":"general information concerning the scientific meeting activities involved;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s3506a/c/2","parentIdentifier":"/us/usc/t42/s3506a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fc%2F2","sourceRelease":"119-100","text":"information concerning the total amount expended for such meetings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s3506a/c/3","parentIdentifier":"/us/usc/t42/s3506a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s3506a/c/3/A","parentIdentifier":"/us/usc/t42/s3506a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fc%2F3%2FA","sourceRelease":"119-100","text":"the total amount of meeting expenses incurred by the operating division for such meeting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s3506a/c/3/B","parentIdentifier":"/us/usc/t42/s3506a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fc%2F3%2FB","sourceRelease":"119-100","text":"the location of such meeting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s3506a/c/3/C","parentIdentifier":"/us/usc/t42/s3506a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fc%2F3%2FC","sourceRelease":"119-100","text":"the date of such meeting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s3506a/c/3/D","parentIdentifier":"/us/usc/t42/s3506a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fc%2F3%2FD","sourceRelease":"119-100","text":"a brief explanation on how such meeting advanced the mission of the operating division; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s3506a/c/3/E","parentIdentifier":"/us/usc/t42/s3506a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fc%2F3%2FE","sourceRelease":"119-100","text":"the total number of individuals whose travel expenses or other scientific meeting expenses were paid by the operating division; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s3506a/c/4","parentIdentifier":"/us/usc/t42/s3506a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3506a%2Fc%2F4","sourceRelease":"119-100","text":"with respect to any such meeting where the total expenses to the operating division exceeded $150,000, a description of the exceptional circumstances that necessitated the expenditure of such amounts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
