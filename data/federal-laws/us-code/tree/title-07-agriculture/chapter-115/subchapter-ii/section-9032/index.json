req=%2Fus%2Fusc%2Ft7%2Fs9032%2Fc%2F18","sourceRelease":"119-100","text":"In the case of mohair, $5.00 per pound.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"19","heading":null,"label":"19","identifier":"/us/usc/t7/s9032/c/19","parentIdentifier":"/us/usc/t7/s9032/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9032%2Fc%2F19","sourceRelease":"119-100","text":"In the case of honey, $1.50 per pound.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"20","heading":null,"label":"20","identifier":"/us/usc/t7/s9032/c/20","parentIdentifier":"/us/usc/t7/s9032/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9032%2Fc%2F20","sourceRelease":"119-100","text":"In the case of peanuts, $390 per ton.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Single county loan rate for other oilseeds","label":"d Single county loan rate for other oilseeds","identifier":"/us/usc/t7/s9032/d","parentIdentifier":"/us/usc/t7/s9032","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9032%2Fd","sourceRelease":"119-100","text":"The Secretary shall establish a single loan rate in each county for each kind of other oilseeds described in subsections (a)(11), (b)(11), and (c)(11).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Seed cotton","label":"e Seed cotton","identifier":"/us/usc/t7/s9032/e","parentIdentifier":"/us/usc/t7/s9032","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9032%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s9032/e/1","parentIdentifier":"/us/usc/t7/s9032/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9032%2Fe%2F1","sourceRelease":"119-100","text":"For purposes of section 9016 (b)(2) of this title and paragraphs (1)(B)(ii) and (2)(A)(ii)(II) of , the loan rate for seed cotton shall be deemed to be equal to $0.30 per pound.section 9017(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Effect","label":"2 Effect","identifier":"/us/usc/t7/s9032/e/2","parentIdentifier":"/us/usc/t7/s9032/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs9032%2Fe%2F2","sourceRelease":"119-100","text":"Nothing in this subsection authorizes any nonrecourse marketing assistance loan under this subchapter for seed cotton.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
