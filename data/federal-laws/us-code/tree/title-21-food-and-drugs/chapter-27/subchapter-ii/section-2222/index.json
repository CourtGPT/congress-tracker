{"type":"section","nativeType":"section","number":"2222","heading":"Integrated consortium of laboratory networks","label":"2222 Integrated consortium of laboratory networks","identifier":"/us/usc/t21/s2222","parentIdentifier":"/us/usc/t21/ch27/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2222","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t21/s2222/a","parentIdentifier":"/us/usc/t21/s2222","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2222%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s2222/a/1","parentIdentifier":"/us/usc/t21/s2222/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2222%2Fa%2F1","sourceRelease":"119-100","text":"agree on common laboratory methods in order to reduce the time required to detect and respond to foodborne illness outbreaks and facilitate the sharing of knowledge and information relating to animal health, agriculture, and human health;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s2222/a/2","parentIdentifier":"/us/usc/t21/s2222/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2222%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s2222/a/2/A","parentIdentifier":"/us/usc/t21/s2222/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2222%2Fa%2F2%2FA","sourceRelease":"119-100","text":"to optimize national laboratory preparedness; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s2222/a/2/B","parentIdentifier":"/us/usc/t21/s2222/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2222%2Fa%2F2%2FB","sourceRelease":"119-100","text":"to provide surge capacity during emergencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t21/s2222/a/3","parentIdentifier":"/us/usc/t21/s2222/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2222%2Fa%2F3","sourceRelease":"119-100","text":"engage in ongoing dialogue and build relationships that will support a more effective and integrated response during emergencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Reporting requirement","label":"b Reporting requirement","identifier":"/us/usc/t21/s2222/b","parentIdentifier":"/us/usc/t21/s2222","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs2222%2Fb","sourceRelease":"119-100","text":"The Secretary of Homeland Security shall, on a biennial basis, submit to the relevant committees of Congress, and make publicly available on the Internet Web site of the Department of Homeland Security, a report on the progress of the integrated consortium of laboratory networks, as established under subsection (a), in carrying out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
