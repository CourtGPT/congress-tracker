{"type":"section","nativeType":"section","number":"6215","heading":"Major fuel burning stationary source","label":"6215 Major fuel burning stationary source","identifier":"/us/usc/t42/s6215","parentIdentifier":"/us/usc/t42/ch77/schI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2000— inserted section catchline.Pub. L. 106–469"],"amendments":["Amendments2000— inserted section catchline.Pub. L. 106–469"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Restrictions on issuance of orders or rules by Governor pursuant tosection 7425 of this title","label":"a Restrictions on issuance of orders or rules by Governor pursuant tosection 7425 of this title","identifier":"/us/usc/t42/s6215/a","parentIdentifier":"/us/usc/t42/s6215","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6215/a/1","parentIdentifier":"/us/usc/t42/s6215/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fa%2F1","sourceRelease":"119-100","text":"prohibiting such source from using fuels other than locally or regionally available coal or coal derivatives, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6215/a/2","parentIdentifier":"/us/usc/t42/s6215/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fa%2F2","sourceRelease":"119-100","text":"requiring such source to enter into a contract (or contracts) for supplies of locally or regionally available coal or coal derivatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Petition to President","label":"b Petition to President","identifier":"/us/usc/t42/s6215/b","parentIdentifier":"/us/usc/t42/s6215","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6215/b/1","parentIdentifier":"/us/usc/t42/s6215/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fb%2F1","sourceRelease":"119-100","text":"The Governor of any State may petition the President to exercise the President’s authorities pursuant to with respect to any major fuel burning stationary source located in such State.section 7425 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6215/b/2","parentIdentifier":"/us/usc/t42/s6215/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6215/b/2/A","parentIdentifier":"/us/usc/t42/s6215/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fb%2F2%2FA","sourceRelease":"119-100","text":"coal or coal derivatives other than locally or regionally available coal,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6215/b/2/B","parentIdentifier":"/us/usc/t42/s6215/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fb%2F2%2FB","sourceRelease":"119-100","text":"petroleum products,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6215/b/2/C","parentIdentifier":"/us/usc/t42/s6215/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fb%2F2%2FC","sourceRelease":"119-100","text":"natural gas, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6215/b/2/D","parentIdentifier":"/us/usc/t42/s6215/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fb%2F2%2FD","sourceRelease":"119-100","text":"any combination of fuels referred to in subparagraphs (A) through (C), to comply with the requirements of a State implementation plan pursuant to .section 7410 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Action to be taken by President","label":"c Action to be taken by President","identifier":"/us/usc/t42/s6215/c","parentIdentifier":"/us/usc/t42/s6215","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6215/c/1","parentIdentifier":"/us/usc/t42/s6215/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fc%2F1","sourceRelease":"119-100","text":"be consistent with ;section 7425 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6215/c/2","parentIdentifier":"/us/usc/t42/s6215/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fc%2F2","sourceRelease":"119-100","text":"result in no significant increase in the consumption of energy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s6215/c/3","parentIdentifier":"/us/usc/t42/s6215/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fc%2F3","sourceRelease":"119-100","text":"not subject the ultimate consumer to significantly higher energy costs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s6215/c/4","parentIdentifier":"/us/usc/t42/s6215/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fc%2F4","sourceRelease":"119-100","text":"not violate any contractual relationship between such source and any supplier or transporter of fuel to such source.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Effect on authority of President to allocate coal or coal derivatives","label":"d Effect on authority of President to allocate coal or coal derivatives","identifier":"/us/usc/t42/s6215/d","parentIdentifier":"/us/usc/t42/s6215","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fd","sourceRelease":"119-100","text":"Nothing in subsection (a) or (b) of this section shall affect the authority of the President or the Secretary of the Department of Energy to allocate coal or coal derivatives under any provision of law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Definitions","label":"e Definitions","identifier":"/us/usc/t42/s6215/e","parentIdentifier":"/us/usc/t42/s6215","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6215%2Fe","sourceRelease":"119-100","text":"The terms “major fuel burning stationary source (or class or category thereof)” and “locally or regionally available coal or coal derivatives” shall have the meanings assigned to them for the purposes of .section 7425 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
