/t12/s3309/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3309%2Fb%2F2","sourceRelease":"119-100","text":"report to the Congress the results of such study.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
