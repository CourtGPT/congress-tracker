{"type":"section","nativeType":"section","number":"70204","heading":"Multi-State freight corridor planning","label":"70204 Multi-State freight corridor planning","identifier":"/us/usc/t49/s70204","parentIdentifier":"/us/usc/t49/stIX/ch702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsA prior section 70204 was renumbered .section 70206 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Consent to Multi-State Freight Mobility Compacts","label":"a .—Consent to Multi-State Freight Mobility Compacts","identifier":"/us/usc/t49/s70204/a","parentIdentifier":"/us/usc/t49/s70204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s70204/a/1","parentIdentifier":"/us/usc/t49/s70204/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fa%2F1","sourceRelease":"119-100","text":"identifying projects along the corridor that benefit multiple States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s70204/a/2","parentIdentifier":"/us/usc/t49/s70204/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fa%2F2","sourceRelease":"119-100","text":"assembling rights-of-way; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s70204/a/3","parentIdentifier":"/us/usc/t49/s70204/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fa%2F3","sourceRelease":"119-100","text":"performing capital improvements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Financing","label":"b .—Financing","identifier":"/us/usc/t49/s70204/b","parentIdentifier":"/us/usc/t49/s70204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s70204/b/1","parentIdentifier":"/us/usc/t49/s70204/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fb%2F1","sourceRelease":"119-100","text":"accept contributions from a unit of State or local government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s70204/b/2","parentIdentifier":"/us/usc/t49/s70204/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fb%2F2","sourceRelease":"119-100","text":"use any Federal or State funds made available for freight mobility infrastructure planning or construction, including applying for grants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s70204/b/3","parentIdentifier":"/us/usc/t49/s70204/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs70204%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s70204/b/3/A","parentIdentifier":"/us/usc/t49/s70204/b/3","sourceUrl":"https://uscode.house.gov/view.x