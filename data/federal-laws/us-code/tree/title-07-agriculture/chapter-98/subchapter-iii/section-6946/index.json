{"type":"section","nativeType":"section","number":"6946","heading":"Rural Health Liaison","label":"6946 Rural Health Liaison","identifier":"/us/usc/t7/s6946","parentIdentifier":"/us/usc/t7/ch98/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6946","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authorization","label":"a Authorization","identifier":"/us/usc/t7/s6946/a","parentIdentifier":"/us/usc/t7/s6946","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6946%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish in the Department the position of Rural Health Liaison.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties","label":"b Duties","identifier":"/us/usc/t7/s6946/b","parentIdentifier":"/us/usc/t7/s6946","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6946%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s6946/b/1","parentIdentifier":"/us/usc/t7/s6946/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6946%2Fb%2F1","sourceRelease":"119-100","text":"in consultation with the Secretary of Health and Human Services, coordinate the role of the Department with respect to rural health;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s6946/b/2","parentIdentifier":"/us/usc/t7/s6946/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6946%2Fb%2F2","sourceRelease":"119-100","text":"integrate across the Department the strategic planning and activities relating to rural health;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s6946/b/3","parentIdentifier":"/us/usc/t7/s6946/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6946%2Fb%2F3","sourceRelease":"119-100","text":"improve communication relating to rural health within the Department and between Federal agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s6946/b/4","parentIdentifier":"/us/usc/t7/s6946/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6946%2Fb%2F4","sourceRelease":"119-100","text":"advocate on behalf of the health care and relevant infrastructure needs in rural areas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s6946/b/5","parentIdentifier":"/us/usc/t7/s6946/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6946%2Fb%2F5","sourceRelease":"119-100","text":"provide to stakeholders, potential grant applicants, Federal agencies, State agencies, Indian Tribes, private organizations, and academic institutions relevant data and information, including the eligibility requirements for, and availability and outcomes of, Department programs applicable to the advancement of rural health;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s6946/b/6","parentIdentifier":"/us/usc/t7/s6946/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6946%2Fb%2F6","sourceRelease":"119-100","text":"maintain communication with public health, medical, occupational safety, and telecommunication associations, research entities, and other stakeholders to ensure that the Department is aware of current and upcoming issues relating to rural health;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t7/s6946/b/7","parentIdentifier":"/us/usc/t7/s6946/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6946%2Fb%2F7","sourceRelease":"119-100","text":"consult on programs, pilot projects, research, training, and other affairs relating to rural health at the Department and other Federal agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t7/s6946/b/8","parentIdentifier":"/us/usc/t7/s6946/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6946%2Fb%2F8","sourceRelease":"119-100","text":"provide expertise on rural health to support the activities of the Secretary as Chair of the Council on Rural Community Innovation and Economic Development; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t7/s6946/b/9","parentIdentifier":"/us/usc/t7/s6946/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6946%2Fb%2F9","sourceRelease":"119-100","text":"provide technical assistance and guidance with respect to activities relating to rural health to the outreach, extension, and county offices of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
