{"type":"section","nativeType":"section","number":"21","heading":"Stolen or counterfeit nature of property for certain crimes defined","label":"21 Stolen or counterfeit nature of property for certain crimes defined","identifier":"/us/usc/t18/s21","parentIdentifier":"/us/usc/t18/ptI/ch1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs21","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t18/s21/a","parentIdentifier":"/us/usc/t18/s21","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs21%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s21/a/1","parentIdentifier":"/us/usc/t18/s21/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs21%2Fa%2F1","sourceRelease":"119-100","text":"any property was embezzled, robbed, stolen, converted, taken, altered, counterfeited, falsely made, forged, or obliterated; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s21/a/2","parentIdentifier":"/us/usc/t18/s21/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs21%2Fa%2F2","sourceRelease":"119-100","text":"the defendant knew that the property was of such character;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t18/s21/b","parentIdentifier":"/us/usc/t18/s21","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs21%2Fb","sourceRelease":"119-100","text":"For purposes of this section, the term “official r