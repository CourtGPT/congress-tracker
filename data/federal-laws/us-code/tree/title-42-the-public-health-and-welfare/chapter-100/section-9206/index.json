{"type":"section","nativeType":"section","number":"9206","heading":"Wind resource assessment","label":"9206 Wind resource assessment","identifier":"/us/usc/t42/s9206","parentIdentifier":"/us/usc/t42/ch100","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9206","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s9206/1","parentIdentifier":"/us/usc/t42/s9206","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9206%2F1","sourceRelease":"119-100","text":"conduct activities to validate existing assessments of known wind resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s9206/2","parentIdentifier":"/us/usc/t42/s9206","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9206%2F2","sourceRelease":"119-100","text":"perform wind resource assessments in regions of the United States where the use of wind energy may prove feasible;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s9206/3","parentIdentifier":"/us/usc/t42/s9206","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9206%2F3","sourceRelease":"119-100","text":"initiate a general site prospecting program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s9206/4","parentIdentifier":"/us/usc/t42/s9206","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9206%2F4","sourceRelease":"119-100","text":"establish standard wind data collection and siting techniques; and","notes":[],