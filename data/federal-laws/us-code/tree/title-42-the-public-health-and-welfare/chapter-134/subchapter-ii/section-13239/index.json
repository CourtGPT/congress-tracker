{"type":"section","nativeType":"section","number":"13239","heading":"Low interest loan program","label":"13239 Low interest loan program","identifier":"/us/usc/t42/s13239","parentIdentifier":"/us/usc/t42/ch134/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13239","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t42/s13239/a","parentIdentifier":"/us/usc/t42/s13239","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13239%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13239/a/1","parentIdentifier":"/us/usc/t42/s13239/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13239%2Fa%2F1","sourceRelease":"119-100","text":"the conversion of motor vehicles to operation on alternative fuels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13239/a/2","parentIdentifier":"/us/usc/t42/s13239/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13239%2Fa%2F2","sourceRelease":"119-100","text":"covering the incremental costs of the purchase of motor vehicles which operate on alternative fuels, when compared with purchase costs of comparable conventionally fueled motor vehicles; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13239/a/3","parentIdentifier":"/us/usc/t42/s13239/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13239%2Fa%2F3","sourceRelease":"119-100","text":"covering the incremental costs of purchase of non-road vehicles and engines designated by the Secretary pursuant to .section 13238(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Loan terms","label":"b Loan terms","identifier":"/us/usc/t42/s13239/b","parentIdentifier":"/us/usc/t42/s13239","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13239%2Fb","sourceRelease":"119-100","text":"The Secretary, to the extent practicable, shall establish reasonable terms for loans made under this subsection, with preference given to repayment schedules that enable such loans to be repaid by the borrower from the cost differential between gasoline and the alternative fuel on which the motor vehicle operates.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Criteria","label":"c Criteria","identifier":"/us/usc/t42/s13239/c","parentIdentifier":"/us/usc/t42/s13239","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13239%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13239/c/1","parentIdentifier":"/us/usc/t42/s13239/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13239%2Fc%2F1","sourceRelease":"119-100","text":"the financial need of the applicant;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13239/c/2","parentIdentifier":"/us/usc/t42/s13239/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13239%2Fc%2F2","sourceRelease":"119-100","text":"the goal of assisting the greatest number of applicants; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13239/c/3","parentIdentifier":"/us/usc/t42/s13239/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13239%2Fc%2F3","sourceRelease":"119-100","text":"the ability of an applicant to repay the loan, taking into account the fuel cost savings likely to accrue to the applicant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Priorities","label":"d Priorities","identifier":"/us/usc/t42/s13239/d","parentIdentifier":"/us/usc/t42/s13239","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13239%2Fd","sourceRelease":"119-100","text":"Priority shall be given under this section to fleets where the use of alternative fuels would have a significant beneficial effect on energy security and the environment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s13239/e","parentIdentifier":"/us/usc/t42/s13239","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13239%2Fe","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Secretary for carrying out this section, $25,000,000 for each of the fiscal years 1993, 1994, and 1995.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
