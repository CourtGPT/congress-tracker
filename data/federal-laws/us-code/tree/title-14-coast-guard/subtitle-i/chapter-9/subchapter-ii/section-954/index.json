{"type":"section","nativeType":"section","number":"954","heading":"Mixed-funded athletic and recreational extracurricular programs","label":"954 Mixed-funded athletic and recreational extracurricular programs","identifier":"/us/usc/t14/s954","parentIdentifier":"/us/usc/t14/stI/ch9/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs954","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Authority","label":"a .—Authority","identifier":"/us/usc/t14/s954/a","parentIdentifier":"/us/usc/t14/s954","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs954%2Fa","sourceRelease":"119-100","text":"In the case of a Coast Guard Academy mixed-funded athletic or recreational extracurricular program, the Commandant may designate funds appropriated to the Coast Guard and available for that program to be treated as nonappropriated funds and expended for that program in accordance with laws applicable to the expenditure of nonappropriated funds. Appropriated funds so designated shall be considered to be nonappropriated funds for all purposes and shall remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Covered Programs","label":"b .—Covered Programs","identifier":"/us/usc/t14/s954/b","parentIdentifier":"/us/usc/t14/s954","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs954%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s954/b/1","parentIdentifier":"/us/usc/t14/s954/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs954%2Fb%2F1","sourceRelease":"119-100","text":"The program is not considered a morale, welfare, or recreation program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s954/b/2","parentIdentifier":"/us/usc/t14/s954/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs954%2Fb%2F2","sourceRelease":"119-100","text":"The program is supported through appropriated funds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t14/s954/b/3","parentIdentifier":"/us/usc/t14/s954/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs954%2Fb%2F3","sourceRelease":"119-100","text":"The program is supported by a nonappropriated fund instrumentality.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t14/s954/b/4","parentIdentifier":"/us/usc/t14/s954/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs954%2Fb%2F4","sourceRelease":"119-100","text":"The program is not a private organization and is not operated by a private organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
