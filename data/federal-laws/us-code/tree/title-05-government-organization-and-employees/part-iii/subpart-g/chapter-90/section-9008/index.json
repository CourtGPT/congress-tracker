{"type":"section","nativeType":"section","number":"9008","heading":"Administrative functions","label":"9008 Administrative functions","identifier":"/us/usc/t5/s9008","parentIdentifier":"/us/usc/t5/ptIII/sptG/ch90","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t5/s9008/a","parentIdentifier":"/us/usc/t5/s9008","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fa","sourceRelease":"119-100","text":"The Office of Personnel Management shall prescribe regulations necessary to carry out this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Enrollment Periods","label":"b .—Enrollment Periods","identifier":"/us/usc/t5/s9008/b","parentIdentifier":"/us/usc/t5/s9008","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fb","sourceRelease":"119-100","text":"The Office shall provide for periodic coordinated enrollment, promotion, and education efforts in consultation with the carriers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Consultation","label":"c .—Consultation","identifier":"/us/usc/t5/s9008/c","parentIdentifier":"/us/usc/t5/s9008","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fc","sourceRelease":"119-100","text":"Any regulations necessary to effect the application and operation of this chapter with respect to an eligible individual described in paragraph (3) or (4) of section 9001, or a qualified relative thereof, shall be prescribed by the Office in consultation with the appropriate Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Informed Decisionmaking","label":"d .—Informed Decisionmaking","identifier":"/us/usc/t5/s9008/d","parentIdentifier":"/us/usc/t5/s9008","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s9008/d/1","parentIdentifier":"/us/usc/t5/s9008/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fd%2F1","sourceRelease":"119-100","text":"The principal long-term care benefits and coverage available under this chapter, and how those benefits and coverage compare to the range of long-term care benefits and coverage otherwise generally available.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s9008/d/2","parentIdentifier":"/us/usc/t5/s9008/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s9008/d/2/A","parentIdentifier":"/us/usc/t5/s9008/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fd%2F2%2FA","sourceRelease":"119-100","text":"the projected effect of inflation on the value of those benefits; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s9008/d/2/B","parentIdentifier":"/us/usc/t5/s9008/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fd%2F2%2FB","sourceRelease":"119-100","text":"a comparison of the inflation-adjusted value of those benefits to the projected future costs of long-term care.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s9008/d/3","parentIdentifier":"/us/usc/t5/s9008/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s9008/d/3/A","parentIdentifier":"/us/usc/t5/s9008/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fd%2F3%2FA","sourceRelease":"119-100","text":"the projected number or percentage of individuals likely to fail to maintain their coverage (determined based on lapse rates experienced under similar group long-term care insurance programs and, when available, this chapter); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s9008/d/3/B","parentIdentifier":"/us/usc/t5/s9008/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fd%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t5/s9008/d/3/B/i","parentIdentifier":"/us/usc/t5/s9008/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fd%2F3%2FB%2Fi","sourceRelease":"119-100","text":"a summary description of how and when premiums for long-term care insurance under this chapter may be raised;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t5/s9008/d/3/B/ii","parentIdentifier":"/us/usc/t5/s9008/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fd%2F3%2FB%2Fii","sourceRelease":"119-100","text":"the premium history during the last 10 years for each qualified carrier offering long-term care insurance under this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t5/s9008/d/3/B/iii","parentIdentifier":"/us/usc/t5/s9008/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fd%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"if cost increases are anticipated, the projected premiums for a typical insured individual at various ages.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t5/s9008/d/4","parentIdentifier":"/us/usc/t5/s9008/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs9008%2Fd%2F4","sourceRelease":"119-100","text":"The advantages and disadvantages of long-term care insurance generally, relative to other means of accumulating or otherwise acquiring the assets that may be needed to meet the costs of long-term care, such as through tax-qualified retirement programs or other investment vehicles.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
