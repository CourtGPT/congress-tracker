{"type":"section","nativeType":"section","number":"1383","heading":"Complete withdrawal","label":"1383 Complete withdrawal","identifier":"/us/usc/t29/s1383","parentIdentifier":"/us/usc/t29/ch18/schIII/stE/pt1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Determinative factors","label":"a Determinative factors","identifier":"/us/usc/t29/s1383/a","parentIdentifier":"/us/usc/t29/s1383","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s1383/a/1","parentIdentifier":"/us/usc/t29/s1383/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fa%2F1","sourceRelease":"119-100","text":"permanently ceases to have an obligation to contribute under the plan, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s1383/a/2","parentIdentifier":"/us/usc/t29/s1383/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fa%2F2","sourceRelease":"119-100","text":"permanently ceases all covered operations under the plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Building and construction industry","label":"b Building and construction industry","identifier":"/us/usc/t29/s1383/b","parentIdentifier":"/us/usc/t29/s1383","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s1383/b/1","parentIdentifier":"/us/usc/t29/s1383/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s1383/b/1/A","parentIdentifier":"/us/usc/t29/s1383/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fb%2F1%2FA","sourceRelease":"119-100","text":"substantially all the employees with respect to whom the employer has an obligation to contribute under the plan perform work in the building and construction industry, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s1383/b/1/B","parentIdentifier":"/us/usc/t29/s1383/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t29/s1383/b/1/B/i","parentIdentifier":"/us/usc/t29/s1383/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"primarily covers employees in the building and construction industry, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t29/s1383/b/1/B/ii","parentIdentifier":"/us/usc/t29/s1383/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"is amended to provide that this subsection applies to employers described in this paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s1383/b/2","parentIdentifier":"/us/usc/t29/s1383/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s1383/b/2/A","parentIdentifier":"/us/usc/t29/s1383/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fb%2F2%2FA","sourceRelease":"119-100","text":"an employer ceases to have an obligation to contribute under the plan, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s1383/b/2/B","parentIdentifier":"/us/usc/t29/s1383/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t29/s1383/b/2/B/i","parentIdentifier":"/us/usc/t29/s1383/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"continues to perform work in the jurisdiction of the collective bargaining agreement of the type for which contributions were previously required, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t29/s1383/b/2/B/ii","parentIdentifier":"/us/usc/t29/s1383/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"resumes such work within 5 years after the date on which the obligation to contribute under the plan ceases, and does not renew the obligation at the time of the resumption.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t29/s1383/b/3","parentIdentifier":"/us/usc/t29/s1383/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fb%2F3","sourceRelease":"119-100","text":"In the case of a plan terminated by mass withdrawal (within the meaning of ), paragraph (2) shall be applied by substituting “3 years” for “5 years” in subparagraph (B)(ii).section 1341a(a)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Entertainment industry","label":"c Entertainment industry","identifier":"/us/usc/t29/s1383/c","parentIdentifier":"/us/usc/t29/s1383","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s1383/c/1","parentIdentifier":"/us/usc/t29/s1383/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fc%2F1","sourceRelease":"119-100","text":"Notwithstanding subsection (a), in the case of an employer that has an obligation to contribute under a plan for work performed in the entertainment industry, primarily on a temporary or project-by-project basis, if the plan primarily covers employees in the entertainment industry, a complete withdrawal occurs only as described in subsection (b)(2) applied by substituting “plan” for “collective bargaining agreement” in subparagraph (B)(i) thereof.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s1383/c/2","parentIdentifier":"/us/usc/t29/s1383/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s1383/c/2/A","parentIdentifier":"/us/usc/t29/s1383/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fc%2F2%2FA","sourceRelease":"119-100","text":"theater, motion picture (except to the extent provided in regulations prescribed by the corporation), radio, television, sound or visual recording, music, and dance, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s1383/c/2/B","parentIdentifier":"/us/usc/t29/s1383/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fc%2F2%2FB","sourceRelease":"119-100","text":"such other entertainment activities as the corporation may determine to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t29/s1383/c/3","parentIdentifier":"/us/usc/t29/s1383/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s1383/c/3/A","parentIdentifier":"/us/usc/t29/s1383/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fc%2F3%2FA","sourceRelease":"119-100","text":"to protect the interest of the plan’s participants and beneficiaries, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s1383/c/3/B","parentIdentifier":"/us/usc/t29/s1383/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fc%2F3%2FB","sourceRelease":"119-100","text":"to prevent a significant risk of loss to the corporation with respect to the plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t29/s1383/c/4","parentIdentifier":"/us/usc/t29/s1383/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fc%2F4","sourceRelease":"119-100","text":"A plan may be amended to provide that this subsection shall not apply to a group or class of employers under the plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Other determinative factors","label":"d Other determinative factors","identifier":"/us/usc/t29/s1383/d","parentIdentifier":"/us/usc/t29/s1383","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s1383/d/1","parentIdentifier":"/us/usc/t29/s1383/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s1383/d/1/A","parentIdentifier":"/us/usc/t29/s1383/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F1%2FA","sourceRelease":"119-100","text":"has an obligation to contribute under a plan described in paragraph (2) primarily for work described in such paragraph, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s1383/d/1/B","parentIdentifier":"/us/usc/t29/s1383/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F1%2FB","sourceRelease":"119-100","text":"does not continue to perform work within the jurisdiction of the plan,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s1383/d/2","parentIdentifier":"/us/usc/t29/s1383/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F2","sourceRelease":"119-100","text":"A plan is described in this paragraph if substantially all of the contributions required under the plan are made by employers primarily engaged in the long and short haul trucking industry, the household goods moving industry, or the public warehousing industry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t29/s1383/d/3","parentIdentifier":"/us/usc/t29/s1383/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s1383/d/3/A","parentIdentifier":"/us/usc/t29/s1383/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F3%2FA","sourceRelease":"119-100","text":"an employer permanently ceases to have an obligation to contribute under the plan or permanently ceases all covered operations under the plan, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s1383/d/3/B","parentIdentifier":"/us/usc/t29/s1383/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t29/s1383/d/3/B/i","parentIdentifier":"/us/usc/t29/s1383/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F3%2FB%2Fi","sourceRelease":"119-100","text":"the corporation determines that the plan has suffered substantial damage to its contribution base as a result of such cessation, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t29/s1383/d/3/B/ii","parentIdentifier":"/us/usc/t29/s1383/d/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F3%2FB%2Fii","sourceRelease":"119-100","text":"the employer fails to furnish a bond issued by a corporate surety company that is an acceptable surety for purposes of , or an amount held in escrow by a bank or similar financial institution satisfactory to the plan, in an amount equal to 50 percent of the withdrawal liability of the employer.section 1112 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t29/s1383/d/4","parentIdentifier":"/us/usc/t29/s1383/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F4","sourceRelease":"119-100","text":"If, after an employer furnishes a bond or escrow to a plan under paragraph (3)(B)(ii), the corporation determines that the cessation of the employer’s obligation to contribute under the plan (considered together with any cessations by other employers), or cessation of covered operations under the plan, has resulted in substantial damage to the contribution base of the plan, the employer shall be treated as having withdrawn from the plan on the date on which the obligation to contribute or covered operations ceased, and such bond or escrow shall be paid to the plan. The corporation shall not make a determination under this paragraph more than 60 months after the date on which such obligation to contribute or covered operations ceased.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t29/s1383/d/5","parentIdentifier":"/us/usc/t29/s1383/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s1383/d/5/A","parentIdentifier":"/us/usc/t29/s1383/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F5%2FA","sourceRelease":"119-100","text":"because it determines that the contribution base of the plan has not suffered substantial damage as a result of the cessation of the employer’s obligation to contribute or cessation of covered operations (considered together with any cessation of contribution obligation, or of covered operations, with respect to other employers), or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s1383/d/5/B","parentIdentifier":"/us/usc/t29/s1383/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F5%2FB","sourceRelease":"119-100","text":"because it may not make a determination under paragraph (4) because of the last sentence thereof,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t29/s1383/d/6","parentIdentifier":"/us/usc/t29/s1383/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fd%2F6","sourceRelease":"119-100","text":"Nothing in this subsection shall be construed as a limitation on the amount of the withdrawal liability of any employer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Date of complete withdrawal","label":"e Date of complete withdrawal","identifier":"/us/usc/t29/s1383/e","parentIdentifier":"/us/usc/t29/s1383","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Fe","sourceRelease":"119-100","text":"For purposes of this part, the date of a complete withdrawal is the date of the cessation of the obligation to contribute or the cessation of covered operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Special liability withdrawal rules for industries other than construction and entertainment industries; procedures applicable to amend plans","label":"f Special liability withdrawal rules for industries other than construction and entertainment industries; procedures applicable to amend plans","identifier":"/us/usc/t29/s1383/f","parentIdentifier":"/us/usc/t29/s1383","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s1383/f/1","parentIdentifier":"/us/usc/t29/s1383/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Ff%2F1","sourceRelease":"119-100","text":"The corporation may prescribe regulations under which plans in industries other than the construction or entertainment industries may be amended to provide for special withdrawal liability rules similar to the rules described in subsections (b) and (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s1383/f/2","parentIdentifier":"/us/usc/t29/s1383/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s1383/f/2/A","parentIdentifier":"/us/usc/t29/s1383/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Ff%2F2%2FA","sourceRelease":"119-100","text":"only in industries (or portions thereof) in which, as determined by the corporation, the characteristics that would make use of such rules appropriate are clearly shown, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s1383/f/2/B","parentIdentifier":"/us/usc/t29/s1383/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1383%2Ff%2F2%2FB","sourceRelease":"119-100","text":"only if the corporation determines, in each instance in which special withdrawal liability rules are permitted, that use of such rules will not pose a significant risk to the corporation under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
