entifier":"/us/usc/t21/s360h–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360h%E2%80%931%2Fb%2F1","sourceRelease":"119-100","text":"trends in the number and types of device recalls;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s360h–1/b/2","parentIdentifier":"/us/usc/t21/s360h–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360h%E2%80%931%2Fb%2F2","sourceRelease":"119-100","text":"devices that are most frequently the subject of a recall; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t21/s360h–1/b/3","parentIdentifier":"/us/usc/t21/s360h–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360h%E2%80%931%2Fb%2F3","sourceRelease":"119-100","text":"underlying causes of device recalls.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Definition","label":"c Definition","identifier":"/us/usc/t21/s360h–1/c","parentIdentifier":"/us/usc/t21/s360h–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360h%E2%80%931%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s360h–1/c/1","parentIdentifier":"/us/usc/t21/s360h–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360h%E2%80%931%2Fc%2F1","sourceRelease":"119-100","text":"the removal from the market of a device pursuant to an order of the Secretary under subsection (b) or (e) of ; orsection 360h of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s360h–1/c/2","parentIdentifier":"/us/usc/t21/s360h–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs360h%E2%80%931%2Fc%2F2","sourceRelease":"119-100","text":"the correction or removal from the market of a device at the initiative of the manufacturer or importer of the device that is required to be reported to the Secretary under .section 360i(g) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
