l":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6683%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s6683/c/2/A","parentIdentifier":"/us/usc/t20/s6683/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6683%2Fc%2F2%2FA","sourceRelease":"119-100","text":"Work performance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s6683/c/2/B","parentIdentifier":"/us/usc/t20/s6683/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6683%2Fc%2F2%2FB","sourceRelease":"119-100","text":"School and community involvement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s6683/c/2/C","parentIdentifier":"/us/usc/t20/s6683/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6683%2Fc%2F2%2FC","sourceRelease":"119-100","text":"Leadership and commitment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s6683/c/2/D","parentIdentifier":"/us/usc/t20/s6683/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6683%2Fc%2F2%2FD","sourceRelease":"119-100","text":"Local support.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s6683/c/2/E","parentIdentifier":"/us/usc/t20/s6683/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6683%2Fc%2F2%2FE","sourceRelease":"119-100","text":"Enhancement of classified school employees’ image in the community and schools.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Selection","label":"3 Selection","identifier":"/us/usc/t20/s6683/c/3","parentIdentifier":"/us/usc/t20/s6683/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs6683%2Fc%2F3","sourceRelease":"119-100","text":"The Secretary shall develop uniform national guidelines for evaluating nominations submitted under paragraph (2) in order to select the most deserving nominees based on the demonstrations made in the areas described in such paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
