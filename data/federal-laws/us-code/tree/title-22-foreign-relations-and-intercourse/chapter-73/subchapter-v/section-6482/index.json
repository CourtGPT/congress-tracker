{"type":"section","nativeType":"section","number":"6482","heading":"Voluntary codes of conduct for United States institutions of higher education outside the United States","label":"6482 Voluntary codes of conduct for United States institutions of higher education outside the United States","identifier":"/us/usc/t22/s6482","parentIdentifier":"/us/usc/t22/ch73/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6482","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Finding","label":"a Finding","identifier":"/us/usc/t22/s6482/a","parentIdentifier":"/us/usc/t22/s6482","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6482%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s6482/a/1","parentIdentifier":"/us/usc/t22/s6482/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6482%2Fa%2F1","sourceRelease":"119-100","text":"for their potential for shaping positive leadership and new educational models in host countries; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s6482/a/2","parentIdentifier":"/us/usc/t22/s6482/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6482%2Fa%2F2","sourceRelease":"119-100","text":"for their emphasis on teaching universally recognized rights of free inquiry and academic freedom.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Sense of Congress","label":"b Sense of Congress","identifier":"/us/usc/t22/s6482/b","parentIdentifier":"/us/usc/t22/s6482","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6482%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s6482/b/1","parentIdentifier":"/us/usc/t22/s6482/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6482%2Fb%2F1","sourceRelease":"119-100","text":"uphold the right of freedom of religion of their employees and students, including the right to manifest that religion peacefully as protected in international law;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s6482/b/2","parentIdentifier":"/us/usc/t22/s6482/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6482%2Fb%2F2","sourceRelease":"119-100","text":"ensure that the religious views and peaceful practice of religion in no way affect, or be allowed to affect, the status of a worker’s or faculty member’s employment or a student’s enrollment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s6482/b/3","parentIdentifier":"/us/usc/t22/s6482/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6482%2Fb%2F3","sourceRelease":"119-100","text":"make every effort in all negotiations, contracts, or memoranda of understanding engaged in or constructed with a foreign government to protect academic freedom and the rights enshrined in the United Nations Declaration of Human Rights.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
