{"type":"section","nativeType":"section","number":"460nnn–52","heading":"Advisory role in management activities","label":"460nnn–52 Advisory role in management activities","identifier":"/us/usc/t16/s460nnn–52","parentIdentifier":"/us/usc/t16/ch1/schCXXV/ptA/spt4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9352","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Management recommendations","label":"a Management recommendations","identifier":"/us/usc/t16/s460nnn–52/a","parentIdentifier":"/us/usc/t16/s460nnn–52","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9352%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460nnn–52/a/1","parentIdentifier":"/us/usc/t16/s460nnn–52/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9352%2Fa%2F1","sourceRelease":"119-100","text":"new and unique approaches to the management of lands within the boundaries of the Cooperative Management and Protection Area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460nnn–52/a/2","parentIdentifier":"/us/usc/t16/s460nnn–52/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9352%2Fa%2F2","sourceRelease":"119-100","text":"cooperative programs and incentives for seamless landscape management that meets human needs and maintains and improves the ecological and economic integrity of the Cooperative Management and Protection Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Preparation of management plan","label":"b Preparation of management plan","identifier":"/us/usc/t16/s460nnn–52/b","parentIdentifier":"/us/usc/t16/s460nnn–52","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9352%2Fb","sourceRelease":"119-100","text":"The Secretary shall consult with the advisory committee as part of the preparation and implementation of the management plan.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Submission of recommendations","label":"c Submission of recommendations","identifier":"/us/usc/t16/s460nnn–52/c","parentIdentifier":"/us/usc/t16/s460nnn–52","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460nnn%E2%80%9352%2Fc","sourceRelease":"119-100","text":"No recommendations may be presented to the Secretary by the advisory council without the agreement of at least nine members of the advisory council.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
