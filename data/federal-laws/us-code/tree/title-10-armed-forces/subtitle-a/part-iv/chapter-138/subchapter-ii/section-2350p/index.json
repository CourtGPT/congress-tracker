{"type":"section","nativeType":"section","number":"2350p","heading":"Reciprocal patient movement agreements","label":"2350p Reciprocal patient movement agreements","identifier":"/us/usc/t10/s2350p","parentIdentifier":"/us/usc/t10/stA/ptIV/ch138/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Authority","label":"a .—Authority","identifier":"/us/usc/t10/s2350p/a","parentIdentifier":"/us/usc/t10/s2350p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2350p/a/1","parentIdentifier":"/us/usc/t10/s2350p/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fa%2F1","sourceRelease":"119-100","text":"the interchangeable, nonreimbursable use of patient movement personnel, either individually or as members of a patient movement crew or team, and equipment, belonging to one partner country to perform patient movement services aboard the aircraft, vessels, or vehicles of another partner country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2350p/a/2","parentIdentifier":"/us/usc/t10/s2350p/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2350p/a/2/A","parentIdentifier":"/us/usc/t10/s2350p/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fa%2F2%2FA","sourceRelease":"119-100","text":"national professional credentials, certifications, and licenses of patient movement personnel; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2350p/a/2/B","parentIdentifier":"/us/usc/t10/s2350p/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fa%2F2%2FB","sourceRelease":"119-100","text":"national certifications, approvals, and licenses of equipment used in the provision of patient movement services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2350p/a/3","parentIdentifier":"/us/usc/t10/s2350p/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fa%2F3","sourceRelease":"119-100","text":"the acceptance of agreed-upon standards for the provision of patient movement services by aircraft, vessel, or vehicle, including, as determined to be beneficial and otherwise permitted by law, the harmonization of patient treatment standards and procedures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Certification","label":"b .—Certification","identifier":"/us/usc/t10/s2350p/b","parentIdentifier":"/us/usc/t10/s2350p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2350p/b/1","parentIdentifier":"/us/usc/t10/s2350p/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2350p/b/1/A","parentIdentifier":"/us/usc/t10/s2350p/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fb%2F1%2FA","sourceRelease":"119-100","text":"meet or exceed the equivalent standards of the United States for similar personnel and equipment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2350p/b/1/B","parentIdentifier":"/us/usc/t10/s2350p/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fb%2F1%2FB","sourceRelease":"119-100","text":"will provide for a level of care comparable to, or better than, the level of care provided by the Department of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2350p/b/2","parentIdentifier":"/us/usc/t10/s2350p/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2350p/b/2/A","parentIdentifier":"/us/usc/t10/s2350p/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fb%2F2%2FA","sourceRelease":"119-100","text":"submitted to the appropriate committees of Congress not later than 15 days after the date on which the Secretary of Defense makes the certification; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2350p/b/2/B","parentIdentifier":"/us/usc/t10/s2350p/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fb%2F2%2FB","sourceRelease":"119-100","text":"reviewed and recertified by the Secretary of Defense not less frequently than annually.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Suspension","label":"c .—Suspension","identifier":"/us/usc/t10/s2350p/c","parentIdentifier":"/us/usc/t10/s2350p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fc","sourceRelease":"119-100","text":"If the Secretary of Defense is unable to recertify a partner country as required by subsection (b)(2)(B), use of the personnel or equipment of the partner country by the Department of Defense under a memorandum of understanding or other formal agreement concluded pursuant to subsection (a) shall be suspended until the date on which the Secretary of Defense is able to recertify the partner country.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Definitions","label":"d .—Definitions","identifier":"/us/usc/t10/s2350p/d","parentIdentifier":"/us/usc/t10/s2350p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Appropriate committees of congress","label":"1 .—Appropriate committees of congress","identifier":"/us/usc/t10/s2350p/d/1","parentIdentifier":"/us/usc/t10/s2350p/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2350p/d/1/A","parentIdentifier":"/us/usc/t10/s2350p/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the congressional defense committees; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2350p/d/1/B","parentIdentifier":"/us/usc/t10/s2350p/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fd%2F1%2FB","sourceRelease":"119-100","text":"the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Partner country","label":"2 .—Partner country","identifier":"/us/usc/t10/s2350p/d/2","parentIdentifier":"/us/usc/t10/s2350p/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2350p/d/2/A","parentIdentifier":"/us/usc/t10/s2350p/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fd%2F2%2FA","sourceRelease":"119-100","text":"A member country of the North Atlantic Treaty Organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2350p/d/2/B","parentIdentifier":"/us/usc/t10/s2350p/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fd%2F2%2FB","sourceRelease":"119-100","text":"Australia.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s2350p/d/2/C","parentIdentifier":"/us/usc/t10/s2350p/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fd%2F2%2FC","sourceRelease":"119-100","text":"Japan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s2350p/d/2/D","parentIdentifier":"/us/usc/t10/s2350p/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fd%2F2%2FD","sourceRelease":"119-100","text":"New Zealand.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t10/s2350p/d/2/E","parentIdentifier":"/us/usc/t10/s2350p/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fd%2F2%2FE","sourceRelease":"119-100","text":"The Republic of Korea.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t10/s2350p/d/2/F","parentIdentifier":"/us/usc/t10/s2350p/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fd%2F2%2FF","sourceRelease":"119-100","text":"Any other country designated as a partner country by the Secretary of Defense, with the concurrence of the Secretary of State, for purposes of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Patient movement","label":"3 .—Patient movement","identifier":"/us/usc/t10/s2350p/d/3","parentIdentifier":"/us/usc/t10/s2350p/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350p%2Fd%2F3","sourceRelease":"119-100","text":"The term “patient movement” means the act or process of moving wounded, ill, injured, or other persons (including contaminated, contagious, and potentially exposed patients) to obtain medical, surgical, mental health, or dental care or treatment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
