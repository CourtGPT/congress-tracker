322/c/3","parentIdentifier":"/us/usc/t6/s322/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fc%2F3","sourceRelease":"119-100","text":"The President may include the information described in paragraph (2)(B) in the budget required to be submitted by the President under .section 1105(a) of title 31","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definitions","label":"d Definitions","identifier":"/us/usc/t6/s322/d","parentIdentifier":"/us/usc/t6/s322","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s322/d/1","parentIdentifier":"/us/usc/t6/s322/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fd%2F1","sourceRelease":"119-100","text":"The term “agency” has the meaning given the term in .section 551 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s322/d/2","parentIdentifier":"/us/usc/t6/s322/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fd%2F2","sourceRelease":"119-100","text":"The term “economic sector” means a sector of the economy of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s322/d/3","parentIdentifier":"/us/usc/t6/s322/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s322/d/3/A","parentIdentifier":"/us/usc/t6/s322/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fd%2F3%2FA","sourceRelease":"119-100","text":"the Federal Government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s322/d/3/B","parentIdentifier":"/us/usc/t6/s322/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fd%2F3%2FB","sourceRelease":"119-100","text":"a State, local, or Tribal government; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s322/d/3/C","parentIdentifier":"/us/usc/t6/s322/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fd%2F3%2FC","sourceRelease":"119-100","text":"the private sector.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s322/d/4","parentIdentifier":"/us/usc/t6/s322/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fd%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s322/d/4/A","parentIdentifier":"/us/usc/t6/s322/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fd%2F4%2FA","sourceRelease":"119-100","text":"a cyber attack; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s322/d/4/B","parentIdentifier":"/us/usc/t6/s322/d/4","sourceUrl":"ht