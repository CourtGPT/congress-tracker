{"type":"section","nativeType":"section","number":"2805","heading":"National Geospatial Data Asset data themes","label":"2805 National Geospatial Data Asset data themes","identifier":"/us/usc/t43/s2805","parentIdentifier":"/us/usc/t43/ch46","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t43/s2805/a","parentIdentifier":"/us/usc/t43/s2805","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2805/a/1","parentIdentifier":"/us/usc/t43/s2805/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fa%2F1","sourceRelease":"119-100","text":"be representations of conceptual topics describing digital spatial information for the Nation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2805/a/2","parentIdentifier":"/us/usc/t43/s2805/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2805/a/2/A","parentIdentifier":"/us/usc/t43/s2805/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fa%2F2%2FA","sourceRelease":"119-100","text":"that are documented, verifiable, and officially designated to meet recognized standards;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2805/a/2/B","parentIdentifier":"/us/usc/t43/s2805/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fa%2F2%2FB","sourceRelease":"119-100","text":"that may be used in common; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t43/s2805/a/2/C","parentIdentifier":"/us/usc/t43/s2805/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fa%2F2%2FC","sourceRelease":"119-100","text":"from which other datasets may be derived.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Lead covered agencies","label":"b Lead covered agencies","identifier":"/us/usc/t43/s2805/b","parentIdentifier":"/us/usc/t43/s2805","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s2805/b/1","parentIdentifier":"/us/usc/t43/s2805/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F1","sourceRelease":"119-100","text":"For each National Geospatial Data Asset data theme, the Committee shall designate one or more covered agencies as the lead covered agencies for the National Geospatial Data Asset data theme.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"General responsibility","label":"2 General responsibility","identifier":"/us/usc/t43/s2805/b/2","parentIdentifier":"/us/usc/t43/s2805/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F2","sourceRelease":"119-100","text":"The lead covered agencies for a National Geospatial Data Asset data theme shall be responsible for ensuring the coordinated management of the data, supporting resources (including technology and personnel), and related services and products of the National Geospatial Data Asset data theme.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Specific responsibilities","label":"3 Specific responsibilities","identifier":"/us/usc/t43/s2805/b/3","parentIdentifier":"/us/usc/t43/s2805/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2805/b/3/A","parentIdentifier":"/us/usc/t43/s2805/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s2805/b/3/A/i","parentIdentifier":"/us/usc/t43/s2805/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FA%2Fi","sourceRelease":"119-100","text":"assessing existing standards;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s2805/b/3/A/ii","parentIdentifier":"/us/usc/t43/s2805/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FA%2Fii","sourceRelease":"119-100","text":"identifying anticipated or needed data standards; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t43/s2805/b/3/A/iii","parentIdentifier":"/us/usc/t43/s2805/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s2805/b/3/A/iii/I","parentIdentifier":"/us/usc/t43/s2805/b/3/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"in accordance with Office of Management and Budget Circular A–119, or any successor thereto; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s2805/b/3/A/iii/II","parentIdentifier":"/us/usc/t43/s2805/b/3/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"consistent with or as a part of the plan described in subparagraph (B);","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2805/b/3/B","parentIdentifier":"/us/usc/t43/s2805/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s2805/b/3/B/i","parentIdentifier":"/us/usc/t43/s2805/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"include developing partnership programs with States, Indian tribes, institutions of higher education, private sector entities, other Federal agencies, and local governments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s2805/b/3/B/ii","parentIdentifier":"/us/usc/t43/s2805/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"meet the needs of users of geospatial data;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t43/s2805/b/3/B/iii","parentIdentifier":"/us/usc/t43/s2805/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"address human and financial resource needs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t43/s2805/b/3/B/iv","parentIdentifier":"/us/usc/t43/s2805/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FB%2Fiv","sourceRelease":"119-100","text":"identify needs relating to standards, metadata for geospatial data within the National Geospatial Data Asset data theme, and the GeoPlatform; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t43/s2805/b/3/B/v","parentIdentifier":"/us/usc/t43/s2805/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FB%2Fv","sourceRelease":"119-100","text":"expedite the development of necessary National Geospatial Data Asset data themes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t43/s2805/b/3/C","parentIdentifier":"/us/usc/t43/s2805/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FC","sourceRelease":"119-100","text":"establish goals that support the strategic plan for the National Spatial Data Infrastructure prepared under ;section 2804(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t43/s2805/b/3/D","parentIdentifier":"/us/usc/t43/s2805/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FD","sourceRelease":"119-100","text":"as necessary, collect and analyze information from users of geospatial data within the National Geospatial Data Asset data theme regarding the needs of the users for geospatial data and incorporate the needs of users in strategies relating to the National Geospatial Data Asset data theme; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t43/s2805/b/3/E","parentIdentifier":"/us/usc/t43/s2805/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s2805/b/3/E/i","parentIdentifier":"/us/usc/t43/s2805/b/3/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FE%2Fi","sourceRelease":"119-100","text":"designate a point of contact within the lead covered agency who shall be responsible for developing, maintaining, coordination relating to, and disseminating data using the GeoPlatform;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s2805/b/3/E/ii","parentIdentifier":"/us/usc/t43/s2805/b/3/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FE%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s2805/b/3/E/ii/I","parentIdentifier":"/us/usc/t43/s2805/b/3/E/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FE%2Fii%2FI","sourceRelease":"119-100","text":"a performance report, at least annually, that documents the activities relating to and implementation of the National Geospatial Data Asset data theme, including progress in achieving the requirements under subparagraphs (A), (B), (C), and (D); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s2805/b/3/E/ii/II","parentIdentifier":"/us/usc/t43/s2805/b/3/E/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FE%2Fii%2FII","sourceRelease":"119-100","text":"comments, as appropriate, regarding the summary and evaluation of the performance report provided by the Committee under ;section 2802(c)(12) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t43/s2805/b/3/E/iii","parentIdentifier":"/us/usc/t43/s2805/b/3/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FE%2Fiii","sourceRelease":"119-100","text":"publish maps or comparable graphics online (in accordance with the mapping conventions specified by the Committee) showing the extent and status of the National Geospatial Data Asset data themes for which the covered agency is a lead covered agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t43/s2805/b/3/E/iv","parentIdentifier":"/us/usc/t43/s2805/b/3/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FE%2Fiv","sourceRelease":"119-100","text":"encourage individuals and entities that are a source of geospatial data or metadata for geospatial data for the National Geospatial Data Asset data theme to provide access to such data through the GeoPlatform;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t43/s2805/b/3/E/v","parentIdentifier":"/us/usc/t43/s2805/b/3/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FE%2Fv","sourceRelease":"119-100","text":"coordinate with the GeoPlatform; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t43/s2805/b/3/E/vi","parentIdentifier":"/us/usc/t43/s2805/b/3/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2805%2Fb%2F3%2FE%2Fvi","sourceRelease":"119-100","text":"identify and publish proven practices for the use and application of geospatial data of the lead covered agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
