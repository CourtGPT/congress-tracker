{"type":"section","nativeType":"section","number":"690d","heading":"Debentures","label":"690d Debentures","identifier":"/us/usc/t15/s690d","parentIdentifier":"/us/usc/t15/ch14B/schIII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s690d/a","parentIdentifier":"/us/usc/t15/s690d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d%2Fa","sourceRelease":"119-100","text":"The Administrator may guarantee the timely payment of principal and interest, as scheduled, on debentures issued by any Renewable Fuel Capital Investment company.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Terms and conditions","label":"b Terms and conditions","identifier":"/us/usc/t15/s690d/b","parentIdentifier":"/us/usc/t15/s690d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s690d/b/1","parentIdentifier":"/us/usc/t15/s690d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d%2Fb%2F1","sourceRelease":"119-100","text":"the term of any debenture guaranteed under this section shall not exceed 15 years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s690d/b/2","parentIdentifier":"/us/usc/t15/s690d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s690d/b/2/A","parentIdentifier":"/us/usc/t15/s690d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d%2Fb%2F2%2FA","sourceRelease":"119-100","text":"shall carry no front-end or annual fees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s690d/b/2/B","parentIdentifier":"/us/usc/t15/s690d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d%2Fb%2F2%2FB","sourceRelease":"119-100","text":"shall be issued at a discount;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s690d/b/2/C","parentIdentifier":"/us/usc/t15/s690d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d%2Fb%2F2%2FC","sourceRelease":"119-100","text":"shall require no interest payments during the 5-year period beginning on the date the debenture is issued;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s690d/b/2/D","parentIdentifier":"/us/usc/t15/s690d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d%2Fb%2F2%2FD","sourceRelease":"119-100","text":"shall be prepayable without penalty after the end of the 1-year period beginning on the date the debenture is issued; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s690d/b/2/E","parentIdentifier":"/us/usc/t15/s690d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d%2Fb%2F2%2FE","sourceRelease":"119-100","text":"shall require semiannual interest payments after the period described in subparagraph (C).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Full faith and credit of the United States","label":"c Full faith and credit of the United States","identifier":"/us/usc/t15/s690d/c","parentIdentifier":"/us/usc/t15/s690d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d%2Fc","sourceRelease":"119-100","text":"The full faith and credit of the United States is pledged to pay all amounts that may be required to be paid under any guarantee under this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Maximum guarantee","label":"d Maximum guarantee","identifier":"/us/usc/t15/s690d/d","parentIdentifier":"/us/usc/t15/s690d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s690d/d/1","parentIdentifier":"/us/usc/t15/s690d/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d%2Fd%2F1","sourceRelease":"119-100","text":"Under this section, the Administrator may guarantee the debentures issued by a Renewable Fuel Capital Investment company only to the extent that the total face amount of outstanding guaranteed debentures of such company does not exceed 150 percent of the private capital of the company, as determined by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Treatment of certain Federal funds","label":"2 Treatment of certain Federal funds","identifier":"/us/usc/t15/s690d/d/2","parentIdentifier":"/us/usc/t15/s690d/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs690d%2Fd%2F2","sourceRelease":"119-100","text":"For the purposes of paragraph (1), private capital shall include capital that is considered to be Federal funds, if such capital is contributed by an investor other than a department or agency of the Federal Government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
