{"type":"section","nativeType":"section","number":"7462","heading":"International cybersecurity technical standards","label":"7462 International cybersecurity technical standards","identifier":"/us/usc/t15/s7462","parentIdentifier":"/us/usc/t15/ch100A/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7462","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t15/s7462/a","parentIdentifier":"/us/usc/t15/s7462","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7462%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7462/a/1","parentIdentifier":"/us/usc/t15/s7462/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7462%2Fa%2F1","sourceRelease":"119-100","text":"as appropriate, ensure coordination of Federal agencies engaged in the development of international technical standards related to information system security; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7462/a/2","parentIdentifier":"/us/usc/t15/s7462/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7462%2Fa%2F2","sourceRelease":"119-100","text":"not later than 1 year after , develop and transmit to Congress a plan for ensuring such Federal agency coordination.December 18, 2014","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Consultation with the private sector","label":"b Consultation with the private sector","identifier":"/us/usc/t15/s7462/b","parentIde