{"type":"section","nativeType":"section","number":"4966","heading":"Taxes on taxable distributions","label":"4966 Taxes on taxable distributions","identifier":"/us/usc/t26/s4966","parentIdentifier":"/us/usc/t26/stD/ch42/schG","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection applicable to taxable years beginning after , see , set out as an Effective Date of 2006 Amendment note under .Aug. 17, 2006section 1231(c) of Pub. L. 109–280section 4963 of this title"],"amendments":["Effective DateSection applicable to taxable years beginning after , see , set out as an Effective Date of 2006 Amendment note under .Aug. 17, 2006section 1231(c) of Pub. L. 109–280section 4963 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Imposition of taxes","label":"a Imposition of taxes","identifier":"/us/usc/t26/s4966/a","parentIdentifier":"/us/usc/t26/s4966","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"On the sponsoring organization","label":"1 On the sponsoring organization","identifier":"/us/usc/t26/s4966/a/1","parentIdentifier":"/us/usc/t26/s4966/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fa%2F1","sourceRelease":"119-100","text":"There is hereby imposed on each taxable distribution a tax equal to 20 percent of the amount thereof. The tax imposed by this paragraph shall be paid by the sponsoring organization with respect to the donor advised fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"On the fund management","label":"2 On the fund management","identifier":"/us/usc/t26/s4966/a/2","parentIdentifier":"/us/usc/t26/s4966/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fa%2F2","sourceRelease":"119-100","text":"There is hereby imposed on the agreement of any fund manager to the making of a distribution, knowing that it is a taxable distribution, a tax equal to 5 percent of the amount thereof. The tax imposed by this paragraph shall be paid by any fund manager who agreed to the making of the distribution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Special rules","label":"b Special rules","identifier":"/us/usc/t26/s4966/b","parentIdentifier":"/us/usc/t26/s4966","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Joint and several liability","label":"1 Joint and several liability","identifier":"/us/usc/t26/s4966/b/1","parentIdentifier":"/us/usc/t26/s4966/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fb%2F1","sourceRelease":"119-100","text":"If more than one person is liable under subsection (a)(2) with respect to the making of a taxable distribution, all such persons shall be jointly and severally liable under such paragraph with respect to such distribution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limit for management","label":"2 Limit for management","identifier":"/us/usc/t26/s4966/b/2","parentIdentifier":"/us/usc/t26/s4966/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fb%2F2","sourceRelease":"119-100","text":"With respect to any one taxable distribution, the maximum amount of the tax imposed by subsection (a)(2) shall not exceed $10,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Taxable distribution","label":"c Taxable distribution","identifier":"/us/usc/t26/s4966/c","parentIdentifier":"/us/usc/t26/s4966","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t26/s4966/c/1","parentIdentifier":"/us/usc/t26/s4966/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s4966/c/1/A","parentIdentifier":"/us/usc/t26/s4966/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fc%2F1%2FA","sourceRelease":"119-100","text":"to any natural person, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s4966/c/1/B","parentIdentifier":"/us/usc/t26/s4966/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s4966/c/1/B/i","parentIdentifier":"/us/usc/t26/s4966/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"such distribution is for any purpose other than one specified in section 170(c)(2)(B), or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s4966/c/1/B/ii","parentIdentifier":"/us/usc/t26/s4966/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the sponsoring organization does not exercise expenditure responsibility with respect to such distribution in accordance with section 4945(h).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Exceptions","label":"2 Exceptions","identifier":"/us/usc/t26/s4966/c/2","parentIdentifier":"/us/usc/t26/s4966/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s4966/c/2/A","parentIdentifier":"/us/usc/t26/s4966/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fc%2F2%2FA","sourceRelease":"119-100","text":"to any organization described in section 170(b)(1)(A) (other than a disqualified supporting organization),","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s4966/c/2/B","parentIdentifier":"/us/usc/t26/s4966/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fc%2F2%2FB","sourceRelease":"119-100","text":"to the sponsoring organization of such donor advised fund, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t26/s4966/c/2/C","parentIdentifier":"/us/usc/t26/s4966/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fc%2F2%2FC","sourceRelease":"119-100","text":"to any other donor advised fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definitions","label":"d Definitions","identifier":"/us/usc/t26/s4966/d","parentIdentifier":"/us/usc/t26/s4966","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Sponsoring organization","label":"1 Sponsoring organization","identifier":"/us/usc/t26/s4966/d/1","parentIdentifier":"/us/usc/t26/s4966/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s4966/d/1/A","parentIdentifier":"/us/usc/t26/s4966/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F1%2FA","sourceRelease":"119-100","text":"is described in section 170(c) (other than in paragraph (1) thereof, and without regard to paragraph (2)(A) thereof),","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s4966/d/1/B","parentIdentifier":"/us/usc/t26/s4966/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F1%2FB","sourceRelease":"119-100","text":"is not a private foundation (as defined in section 509(a)), and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t26/s4966/d/1/C","parentIdentifier":"/us/usc/t26/s4966/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F1%2FC","sourceRelease":"119-100","text":"maintains 1 or more donor advised funds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Donor advised fund","label":"2 Donor advised fund","identifier":"/us/usc/t26/s4966/d/2","parentIdentifier":"/us/usc/t26/s4966/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t26/s4966/d/2/A","parentIdentifier":"/us/usc/t26/s4966/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s4966/d/2/A/i","parentIdentifier":"/us/usc/t26/s4966/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":"which is separately identified by reference to contributions of a donor or donors,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s4966/d/2/A/ii","parentIdentifier":"/us/usc/t26/s4966/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":"which is owned and controlled by a sponsoring organization, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t26/s4966/d/2/A/iii","parentIdentifier":"/us/usc/t26/s4966/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"with respect to which a donor (or any person appointed or designated by such donor) has, or reasonably expects to have, advisory privileges with respect to the distribution or investment of amounts held in such fund or account by reason of the donor’s status as a donor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exceptions","label":"B Exceptions","identifier":"/us/usc/t26/s4966/d/2/B","parentIdentifier":"/us/usc/t26/s4966/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s4966/d/2/B/i","parentIdentifier":"/us/usc/t26/s4966/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2%2FB%2Fi","sourceRelease":"119-100","text":"which makes distributions only to a single identified organization or governmental entity, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s4966/d/2/B/ii","parentIdentifier":"/us/usc/t26/s4966/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t26/s4966/d/2/B/ii/I","parentIdentifier":"/us/usc/t26/s4966/d/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2%2FB%2Fii%2FI","sourceRelease":"119-100","text":"such person’s advisory privileges are performed exclusively by such person in the person’s capacity as a member of a committee all of the members of which are appointed by the sponsoring organization,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t26/s4966/d/2/B/ii/II","parentIdentifier":"/us/usc/t26/s4966/d/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2%2FB%2Fii%2FII","sourceRelease":"119-100","text":"no combination of persons described in subparagraph (A)(iii) (or persons related to such persons) control, directly or indirectly, such committee, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t26/s4966/d/2/B/ii/III","parentIdentifier":"/us/usc/t26/s4966/d/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2%2FB%2Fii%2FIII","sourceRelease":"119-100","text":"all grants from such fund or account are awarded on an objective and nondiscriminatory basis pursuant to a procedure approved in advance by the board of directors of the sponsoring organization, and such procedure is designed to ensure that all such grants meet the requirements of paragraph (1), (2), or (3) of section 4945(g).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Secretarial authority","label":"C Secretarial authority","identifier":"/us/usc/t26/s4966/d/2/C","parentIdentifier":"/us/usc/t26/s4966/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s4966/d/2/C/i","parentIdentifier":"/us/usc/t26/s4966/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2%2FC%2Fi","sourceRelease":"119-100","text":"if such fund or account is advised by a committee not directly or indirectly controlled by the donor or any person appointed or designated by the donor for the purpose of advising with respect to distributions from such fund (and any related parties), or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s4966/d/2/C/ii","parentIdentifier":"/us/usc/t26/s4966/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F2%2FC%2Fii","sourceRelease":"119-100","text":"if such fund benefits a single identified charitable purpose.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Fund manager","label":"3 Fund manager","identifier":"/us/usc/t26/s4966/d/3","parentIdentifier":"/us/usc/t26/s4966/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s4966/d/3/A","parentIdentifier":"/us/usc/t26/s4966/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F3%2FA","sourceRelease":"119-100","text":"an officer, director, or trustee of such sponsoring organization (or an individual having powers or responsibilities similar to those of officers, directors, or trustees of the sponsoring organization), and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s4966/d/3/B","parentIdentifier":"/us/usc/t26/s4966/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F3%2FB","sourceRelease":"119-100","text":"with respect to any act (or failure to act), the employees of the sponsoring organization having authority or responsibility with respect to such act (or failure to act).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Disqualified supporting organization","label":"4 Disqualified supporting organization","identifier":"/us/usc/t26/s4966/d/4","parentIdentifier":"/us/usc/t26/s4966/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t26/s4966/d/4/A","parentIdentifier":"/us/usc/t26/s4966/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s4966/d/4/A/i","parentIdentifier":"/us/usc/t26/s4966/d/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F4%2FA%2Fi","sourceRelease":"119-100","text":"any type III supporting organization (as defined in section 4943(f)(5)(A)) which is not a functionally integrated type III supporting organization (as defined in section 4943(f)(5)(B)), and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s4966/d/4/A/ii","parentIdentifier":"/us/usc/t26/s4966/d/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F4%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t26/s4966/d/4/A/ii/I","parentIdentifier":"/us/usc/t26/s4966/d/4/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F4%2FA%2Fii%2FI","sourceRelease":"119-100","text":"the donor or any person designated by the donor for the purpose of advising with respect to distributions from a donor advised fund (and any related parties) directly or indirectly controls a supported organization (as defined in section 509(f)(3)) of such organization, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t26/s4966/d/4/A/ii/II","parentIdentifier":"/us/usc/t26/s4966/d/4/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F4%2FA%2Fii%2FII","sourceRelease":"119-100","text":"the Secretary determines by regulations that a distribution to such organization otherwise is inappropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Type I and type II supporting organizations","label":"B Type I and type II supporting organizations","identifier":"/us/usc/t26/s4966/d/4/B","parentIdentifier":"/us/usc/t26/s4966/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s4966/d/4/B/i","parentIdentifier":"/us/usc/t26/s4966/d/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F4%2FB%2Fi","sourceRelease":"119-100","text":"operated, supervised, or controlled by one or more organizations described in paragraph (1) or (2) of section 509(a), or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s4966/d/4/B/ii","parentIdentifier":"/us/usc/t26/s4966/d/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F4%2FB%2Fii","sourceRelease":"119-100","text":"supervised or controlled in connection with one or more such organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Functionally integrated type III supporting organizations","label":"C Functionally integrated type III supporting organizations","identifier":"/us/usc/t26/s4966/d/4/C","parentIdentifier":"/us/usc/t26/s4966/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs4966%2Fd%2F4%2FC","sourceRelease":"119-100","text":"An organization is described in this subparagraph if the organization is a functionally integrated type III supporting organization (as defined under section 4943(f)(5)(B)).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
