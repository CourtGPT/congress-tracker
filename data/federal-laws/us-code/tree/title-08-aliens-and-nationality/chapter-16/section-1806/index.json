{"type":"section","nativeType":"section","number":"1806","heading":"Visa integrity fee","label":"1806 Visa integrity fee","identifier":"/us/usc/t8/s1806","parentIdentifier":"/us/usc/t8/ch16","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Visa integrity fee","label":"a Visa integrity fee","identifier":"/us/usc/t8/s1806/a","parentIdentifier":"/us/usc/t8/s1806","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t8/s1806/a/1","parentIdentifier":"/us/usc/t8/s1806/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fa%2F1","sourceRelease":"119-100","text":"In addition to any other fee authorized by law, the Secretary of Homeland Security shall require the payment of a fee, equal to the amount specified in this subsection, by any alien issued a nonimmigrant visa at the time of such issuance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Initial amount","label":"2 Initial amount","identifier":"/us/usc/t8/s1806/a/2","parentIdentifier":"/us/usc/t8/s1806/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1806/a/2/A","parentIdentifier":"/us/usc/t8/s1806/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fa%2F2%2FA","sourceRelease":"119-100","text":"$250; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1806/a/2/B","parentIdentifier":"/us/usc/t8/s1806/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fa%2F2%2FB","sourceRelease":"119-100","text":"such amount as the Secretary of Homeland Security may establish, by rule.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Annual adjustments for inflation","label":"3 Annual adjustments for inflation","identifier":"/us/usc/t8/s1806/a/3","parentIdentifier":"/us/usc/t8/s1806/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1806/a/3/A","parentIdentifier":"/us/usc/t8/s1806/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fa%2F3%2FA","sourceRelease":"119-100","text":"the amount of the fee required under this subsection for the most recently concluded fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1806/a/3/B","parentIdentifier":"/us/usc/t8/s1806/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fa%2F3%2FB","sourceRelease":"119-100","text":"the product resulting from the multiplication of the amount referred to in subparagraph (A) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded down to the nearest dollar.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Disposition of visa integrity fees","label":"4 Disposition of visa integrity fees","identifier":"/us/usc/t8/s1806/a/4","parentIdentifier":"/us/usc/t8/s1806/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fa%2F4","sourceRelease":"119-100","text":"All of the fees collected pursuant to this section that are not reimbursed pursuant to subsection (b) shall be deposited into the general fund of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"No fee waiver","label":"5 No fee waiver","identifier":"/us/usc/t8/s1806/a/5","parentIdentifier":"/us/usc/t8/s1806/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fa%2F5","sourceRelease":"119-100","text":"Fees required to be paid under this subsection shall not be waived or reduced.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Fee reimbursement","label":"b Fee reimbursement","identifier":"/us/usc/t8/s1806/b","parentIdentifier":"/us/usc/t8/s1806","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t8/s1806/b/1","parentIdentifier":"/us/usc/t8/s1806/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fb%2F1","sourceRelease":"119-100","text":"after admission to the United States pursuant to such nonimmigrant visa, complied with all conditions of such nonimmigrant visa, including the condition that an alien shall not accept unauthorized employment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t8/s1806/b/2","parentIdentifier":"/us/usc/t8/s1806/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1806/b/2/A","parentIdentifier":"/us/usc/t8/s1806/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fb%2F2%2FA","sourceRelease":"119-100","text":"has not sought to extend his or her period of admission during such period of validity and departed the United States not later than 5 days after the last day of such period; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1806/b/2/B","parentIdentifier":"/us/usc/t8/s1806/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1806%2Fb%2F2%2FB","sourceRelease":"119-100","text":"during such period of validity, was granted an extension of such nonimmigrant status or an adjustment to the status of a lawful permanent resident.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
