{"type":"section","nativeType":"section","number":"1242","heading":"Enrollment by Board; standards and qualifications; suspension or termination of enrollment","label":"1242 Enrollment by Board; standards and qualifications; suspension or termination of enrollment","identifier":"/us/usc/t29/s1242","parentIdentifier":"/us/usc/t29/ch18/schII/stC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1242","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThis chapter, referred to in subsecs. (a) and (b), was in the original “this Act”, meaning , known as the Employee Retirement Income Security Act of 1974. Titles I, III, and IV of such Act are classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under and Tables.Pub. L. 93–406section 1001 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t29/s1242/a","parentIdentifier":"/us/usc/t29/s1242","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1242%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s1242/a/1","parentIdentifier":"/us/usc/t29/s1242/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1242%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t29/s1242/a/1/A","parentIdentifier":"/us/usc/t29/s1242/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1242%2Fa%2F1%2FA","sourceRelease":"119-100","text":"a degree in actuarial mathematics or its equivalent from an accredited college or university,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t29/s1242/a/1/B","parentIdentifier":"/us/usc/t29/s1242/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1242%2Fa%2F1%2FB","sourceRelease":"119-100","text":"successful completion of an examination in actuarial mathematics and methodology to be given by the Joint Board, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t29/s1242/a/1/C","parentIdentifier":"/us/usc/t29/s1242/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1242%2Fa%2F1%2FC","sourceRelease":"119-100","text":"successful completion of other actuarial examinations deemed adequate by the Joint Board, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s1242/a/2","parentIdentifier":"/us/usc/t29/s1242/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1242%2Fa%2F2","sourceRelease":"119-100","text":"an appropriate period of responsible actuarial experience.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t29/s1242/b","parentIdentifier":"/us/usc/t29/s1242","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1242%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s1242/b/1","parentIdentifier":"/us/usc/t29/s1242/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1242%2Fb%2F1","sourceRelease":"119-100","text":"has failed to discharge his duties under this chapter, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s1242/b/2","parentIdentifier":"/us/usc/t29/s1242/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs1242%2Fb%2F2","sourceRelease":"119-100","text":"does not satisfy the requirements for enrollment as in effect at the time of his enrollment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
