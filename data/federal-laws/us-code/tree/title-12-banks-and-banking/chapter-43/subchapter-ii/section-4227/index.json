{"type":"section","nativeType":"section","number":"4227","heading":"Unreviewed declarations; petition to pursue action as private contractor","label":"4227 Unreviewed declarations; petition to pursue action as private contractor","identifier":"/us/usc/t12/s4227","parentIdentifier":"/us/usc/t12/ch43/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4227","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Notification","label":"a Notification","identifier":"/us/usc/t12/s4227/a","parentIdentifier":"/us/usc/t12/s4227","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4227%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4227/a/1","parentIdentifier":"/us/usc/t12/s4227/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4227%2Fa%2F1","sourceRelease":"119-100","text":"If, pursuant to , the Attorney General notifies a declarant that the declarant’s allegations have not yet been addressed, the declarant may notify the Attorney General to award a contract pursuant to subchapter III to pursue the case.section 4226(d)(1)(B) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4227/a/2","parentIdentifier":"/us/usc/t12/s4227/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4227%2Fa%2F2","sourceRelease":"119-100","text":"A declarant’s notification under paragraph (1) shall be filed with the Attorney General not later than 30 days after the date of service of notice under , and the Attorney General shall respond to the notification not later than 30 days after receipt.section 4226(d)(1)(B) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Contents of response","label":"b Contents of response","identifier":"/us/usc/t12/s4227/b","parentIdentifier":"/us/usc/t12/s4227","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4227%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4227/b/1","parentIdentifier":"/us/usc/t12/s4227/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4227%2Fb%2F1","sourceRelease":"119-100","text":"grant a contract pursuant to subchapter III; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4227/b/2","parentIdentifier":"/us/usc/t12/s4227/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4227%2Fb%2F2","sourceRelease":"119-100","text":"proceed with an action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Grant of contract","label":"c Grant of contract","identifier":"/us/usc/t12/s4227/c","parentIdentifier":"/us/usc/t12/s4227","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4227%2Fc","sourceRelease":"119-100","text":"If the Attorney General decides to grant a contract, the declarant, after consultation with the Attorney General, shall have the right to select counsel to prosecute an action, and the declarant and the declarant’s counsel shall act in accordance with subchapter III.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
