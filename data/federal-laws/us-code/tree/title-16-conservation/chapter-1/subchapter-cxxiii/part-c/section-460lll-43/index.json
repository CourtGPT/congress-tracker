{"type":"section","nativeType":"section","number":"460lll–43","heading":"Memorandum of agreement","label":"460lll–43 Memorandum of agreement","identifier":"/us/usc/t16/s460lll–43","parentIdentifier":"/us/usc/t16/ch1/schCXXIII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9343","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s460lll–43/a","parentIdentifier":"/us/usc/t16/s460lll–43","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9343%2Fa","sourceRelease":"119-100","text":"Not later than 30 days after the date of transfer pursuant to section 460–41 of this title, the Secretary and the Tennessee Valley Authority shall enter into a memorandum of agreement concerning implementation of this subchapter.lll","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Provisions","label":"b Provisions","identifier":"/us/usc/t16/s460lll–43/b","parentIdentifier":"/us/usc/t16/s460lll–43","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9343%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460lll–43/b/1","parentIdentifier":"/us/usc/t16/s460lll–43/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9343%2Fb%2F1","sourceRelease":"119-100","text":"the orderly withdrawal of officers and employees of the Tennessee Valley Authority;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460lll–43/b/2","parentIdentifier":"/us/usc/t16/s460lll–43/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9343%2Fb%2F2","sourceRelease":"119-100","text":"the transfer of property, fixtures, and facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s460lll–43/b/3","parentIdentifier":"/us/usc/t16/s460lll–43/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9343%2Fb%2F3","sourceRelease":"119-100","text":"the interagency transfer of officers and employees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s460lll–43/b/4","parentIdentifier":"/us/usc/t16/s460lll–43/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9343%2Fb%2F4","sourceRelease":"119-100","text":"the transfer of records; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s460lll–43/b/5","parentIdentifier":"/us/usc/t16/s460lll–43/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9343%2Fb%2F5","sourceRelease":"119-100","text":"other transfer issues.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Transition team","label":"c Transition team","identifier":"/us/usc/t16/s460lll–43/c","parentIdentifier":"/us/usc/t16/s460lll–43","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9343%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s460lll–43/c/1","parentIdentifier":"/us/usc/t16/s460lll–43/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9343%2Fc%2F1","sourceRelease":"119-100","text":"The memorandum of understanding may provide for a transition team consisting of the Tennessee Valley Authority and Forest Service employees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Duration","label":"2 Duration","identifier":"/us/usc/t16/s460lll–43/c/2","parentIdentifier":"/us/usc/t16/s460lll–43/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9343%2Fc%2F2","sourceRelease":"119-100","text":"The team may continue in existence after the date of transfer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Personnel costs","label":"3 Personnel costs","identifier":"/us/usc/t16/s460lll–43/c/3","parentIdentifier":"/us/usc/t16/s460lll–43/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460lll%E2%80%9343%2Fc%2F3","sourceRelease":"119-100","text":"The Tennessee Valley Authority and the Forest Service shall pay personnel costs of their respective team members.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
