{"type":"section","nativeType":"section","number":"6591","heading":"Forest stands inventory and monitoring program to improve detection of and response to environmental threats","label":"6591 Forest stands inventory and monitoring program to improve detection of and response to environmental threats","identifier":"/us/usc/t16/s6591","parentIdentifier":"/us/usc/t16/ch84/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s6591/a","parentIdentifier":"/us/usc/t16/s6591","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s6591/a/1","parentIdentifier":"/us/usc/t16/s6591/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591%2Fa%2F1","sourceRelease":"119-100","text":"in units of the National Forest System (other than those units created from the public domain); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6591/a/2","parentIdentifier":"/us/usc/t16/s6591/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591%2Fa%2F2","sourceRelease":"119-100","text":"on private forest land, with the consent of the owner of the land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Issues to be addressed","label":"b Issues to be addressed","identifier":"/us/usc/t16/s6591/b","parentIdentifier":"/us/usc/t16/s6591","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s6591/b/1","parentIdentifier":"/us/usc/t16/s6591/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591%2Fb%2F1","sourceRelease":"119-100","text":"early detection, identification, and assessment of environmental threats (including insect, disease, invasive species, fire, and weather-related risks and other episodic events);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6591/b/2","parentIdentifier":"/us/usc/t16/s6591/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591%2Fb%2F2","sourceRelease":"119-100","text":"loss or degradation of forests;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s6591/b/3","parentIdentifier":"/us/usc/t16/s6591/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591%2Fb%2F3","sourceRelease":"119-100","text":"degradation of the quality forest stands caused by inadequate forest regeneration practices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s6591/b/4","parentIdentifier":"/us/usc/t16/s6591/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591%2Fb%2F4","sourceRelease":"119-100","text":"quantification of carbon uptake rates; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s6591/b/5","parentIdentifier":"/us/usc/t16/s6591/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591%2Fb%2F5","sourceRelease":"119-100","text":"management practices that focus on preventing further forest degradation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Early warning system","label":"c Early warning system","identifier":"/us/usc/t16/s6591/c","parentIdentifier":"/us/usc/t16/s6591","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s6591/c/1","parentIdentifier":"/us/usc/t16/s6591/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591%2Fc%2F1","sourceRelease":"119-100","text":"isolate and treat a threat before the threat gets out of control; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6591/c/2","parentIdentifier":"/us/usc/t16/s6591/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591%2Fc%2F2","sourceRelease":"119-100","text":"prevent epidemics, such as the American chestnut blight in the first half of the twentieth century, that could be environmentally and economically devastating to forests.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t16/s6591/d","parentIdentifier":"/us/usc/t16/s6591","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591%2Fd","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2004 through 2008.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
