{"type":"section","nativeType":"section","number":"18631","heading":"Crosscutting research and development","label":"18631 Crosscutting research and development","identifier":"/us/usc/t42/s18631","parentIdentifier":"/us/usc/t42/ch161/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18631","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s18631/a","parentIdentifier":"/us/usc/t42/s18631","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18631%2Fa","sourceRelease":"119-100","text":"The Secretary shall use the capabilities of the Department to identify strategic opportunities for collaborative research, development, demonstration, and commercial application of innovative science and technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Existing programs; coordination of activities","label":"b Existing programs; coordination of activities","identifier":"/us/usc/t42/s18631/b","parentIdentifier":"/us/usc/t42/s18631","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18631%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18631/b/1","parentIdentifier":"/us/usc/t42/s18631/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18631%2Fb%2F1","sourceRelease":"119-100","text":"to leverage existing programs of the Department; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18631/b/2","parentIdentifier":"/us/usc/t42/s18631/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18631%2Fb%2F2","sourceRelease":"119-100","text":"to consolidate and coordinate activities throughout the Department to promote collaboration and crosscutting approaches within programs of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Additional actions","label":"c Additional actions","identifier":"/us/usc/t42/s18631/c","parentIdentifier":"/us/usc/t42/s18631","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18631%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18631/c/1","parentIdentifier":"/us/usc/t42/s18631/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18631%2Fc%2F1","sourceRelease":"119-100","text":"prioritize activities that use all affordable domestic resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18631/c/2","parentIdentifier":"/us/usc/t42/s18631/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18631%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18631/c/2/A","parentIdentifier":"/us/usc/t42/s18631/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18631%2Fc%2F2%2FA","sourceRelease":"119-100","text":"ensures integrity and independence; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18631/c/2/B","parentIdentifier":"/us/usc/t42/s18631/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18631%2Fc%2F2%2FB","sourceRelease":"119-100","text":"provides the flexibility to adapt to market dynamics;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18631/c/3","parentIdentifier":"/us/usc/t42/s18631/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18631%2Fc%2F3","sourceRelease":"119-100","text":"ensure that activities shall be undertaken in a manner that does not duplicate other activities within the Department or other Federal Government activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18631/c/4","parentIdentifier":"/us/usc/t42/s18631/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18631%2Fc%2F4","sourceRelease":"119-100","text":"identify programs that may be more effectively left to the States, industry, nongovernmental organizations, institutions of higher education, or other stakeholders.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
