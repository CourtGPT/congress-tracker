{"type":"section","nativeType":"section","number":"3039","heading":"Assistance to United States law enforcement agencies","label":"3039 Assistance to United States law enforcement agencies","identifier":"/us/usc/t50/s3039","parentIdentifier":"/us/usc/t50/ch44/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to prior to editorial reclassification and renumbering as this section.section 403–5a of this title","Amendments2003—Subsec. (b)(1)(C). substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency”.Pub. L. 108–136"],"amendments":["Amendments2003—Subsec. (b)(1)(C). substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency”.Pub. L. 108–136"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authority to provide assistance","label":"a Authority to provide assistance","identifier":"/us/usc/t50/s3039/a","parentIdentifier":"/us/usc/t50/s3039","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fa","sourceRelease":"119-100","text":"Subject to subsection (b), elements of the intelligence community may, upon the request of a United States law enforcement agency, collect information outside the United States about individuals who are not United States persons. Such elements may collect such information notwithstanding that the law enforcement agency intends to use the information collected for purposes of a law enforcement investigation or counterintelligence investigation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitation on assistance by elements of Department of Defense","label":"b Limitation on assistance by elements of Department of Defense","identifier":"/us/usc/t50/s3039/b","parentIdentifier":"/us/usc/t50/s3039","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3039/b/1","parentIdentifier":"/us/usc/t50/s3039/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3039/b/1/A","parentIdentifier":"/us/usc/t50/s3039/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fb%2F1%2FA","sourceRelease":"119-100","text":"The National Security Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3039/b/1/B","parentIdentifier":"/us/usc/t50/s3039/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fb%2F1%2FB","sourceRelease":"119-100","text":"The National Reconnaissance Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t50/s3039/b/1/C","parentIdentifier":"/us/usc/t50/s3039/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fb%2F1%2FC","sourceRelease":"119-100","text":"The National Geospatial-Intelligence Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t50/s3039/b/1/D","parentIdentifier":"/us/usc/t50/s3039/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fb%2F1%2FD","sourceRelease":"119-100","text":"The Defense Intelligence Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3039/b/2","parentIdentifier":"/us/usc/t50/s3039/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fb%2F2","sourceRelease":"119-100","text":"Assistance provided under this section by elements of the Department of Defense may not include the direct participation of a member of the Army, Navy, Air Force, or Marine Corps in an arrest or similar activity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s3039/b/3","parentIdentifier":"/us/usc/t50/s3039/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fb%2F3","sourceRelease":"119-100","text":"Assistance may not be provided under this section by an element of the Department of Defense if the provision of such assistance will adversely affect the military preparedness of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t50/s3039/b/4","parentIdentifier":"/us/usc/t50/s3039/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fb%2F4","sourceRelease":"119-100","text":"The Secretary of Defense shall prescribe regulations governing the exercise of authority under this section by elements of the Department of Defense, including regulations relating to the protection of sources and methods in the exercise of such authority.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Definitions","label":"c Definitions","identifier":"/us/usc/t50/s3039/c","parentIdentifier":"/us/usc/t50/s3039","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3039/c/1","parentIdentifier":"/us/usc/t50/s3039/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fc%2F1","sourceRelease":"119-100","text":"The term “United States law enforcement agency” means any department or agency of the Federal Government that the Attorney General designates as law enforcement agency for purposes of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3039/c/2","parentIdentifier":"/us/usc/t50/s3039/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3039/c/2/A","parentIdentifier":"/us/usc/t50/s3039/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fc%2F2%2FA","sourceRelease":"119-100","text":"A United States citizen.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3039/c/2/B","parentIdentifier":"/us/usc/t50/s3039/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fc%2F2%2FB","sourceRelease":"119-100","text":"An alien known by the intelligence agency concerned to be a permanent resident alien.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t50/s3039/c/2/C","parentIdentifier":"/us/usc/t50/s3039/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fc%2F2%2FC","sourceRelease":"119-100","text":"An unincorporated association substantially composed of United States citizens or permanent resident aliens.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t50/s3039/c/2/D","parentIdentifier":"/us/usc/t50/s3039/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3039%2Fc%2F2%2FD","sourceRelease":"119-100","text":"A corporation incorporated in the United States, except for a corporation directed and controlled by a foreign government or governments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
