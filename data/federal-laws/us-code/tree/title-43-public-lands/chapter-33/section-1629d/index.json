{"type":"section","nativeType":"section","number":"1629d","heading":"Dissenters rights","label":"1629d Dissenters rights","identifier":"/us/usc/t43/s1629d","parentIdentifier":"/us/usc/t43/ch33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Coverage","label":"a Coverage","identifier":"/us/usc/t43/s1629d/a","parentIdentifier":"/us/usc/t43/s1629d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s1629d/a/1","parentIdentifier":"/us/usc/t43/s1629d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s1629d/a/1/A","parentIdentifier":"/us/usc/t43/s1629d/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fa%2F1%2FA","sourceRelease":"119-100","text":"fail to approve an amendment authorized by to terminate alienability restrictions, a shareholder who voted for the amendment may demand payment from the corporation for all of his or her shares of Settlement Common Stock; orsection 1629c(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s1629d/a/1/B","parentIdentifier":"/us/usc/t43/s1629d/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fa%2F1%2FB","sourceRelease":"119-100","text":"approve an amendment authorized by to continue alienability restrictions without issuing alienable common stock pursuant to , a shareholder who voted against the amendment may demand payment from the corporation for all of his or her shares of Settlement Common Stock.section 1629c(d) of this titlesection 1629c(d)(6) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s1629d/a/2","parentIdentifier":"/us/usc/t43/s1629d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s1629d/a/2/A","parentIdentifier":"/us/usc/t43/s1629d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fa%2F2%2FA","sourceRelease":"119-100","text":"A demand for payment made pursuant to paragraph (1)(A) shall be honored only if at the same time as the vote giving rise to the demand, the shareholders of the corporation approved a resolution providing for the purchase of Settlement Common Stock from dissenting shareholders.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s1629d/a/2/B","parentIdentifier":"/us/usc/t43/s1629d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fa%2F2%2FB","sourceRelease":"119-100","text":"A demand for payment made pursuant to paragraph (1)(B) shall be honored.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Relationship to State procedure","label":"b Relationship to State procedure","identifier":"/us/usc/t43/s1629d/b","parentIdentifier":"/us/usc/t43/s1629d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s1629d/b/1","parentIdentifier":"/us/usc/t43/s1629d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fb%2F1","sourceRelease":"119-100","text":"Except as otherwise provided in this section, the laws of the State governing the right of a dissenting shareholder to demand and receive payment for his or her shares shall apply to demands for payment honored pursuant to subsection (a)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s1629d/b/2","parentIdentifier":"/us/usc/t43/s1629d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fb%2F2","sourceRelease":"119-100","text":"The board of directors of a Native Corporation may approve a resolution to provide a dissenting shareholder periods of time longer than those provided under the laws of the State to take actions required to demand and receive payment for his or her shares.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Valuation of stock","label":"c Valuation of stock","identifier":"/us/usc/t43/s1629d/c","parentIdentifier":"/us/usc/t43/s1629d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s1629d/c/1","parentIdentifier":"/us/usc/t43/s1629d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s1629d/c/1/A","parentIdentifier":"/us/usc/t43/s1629d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the Settlement Common Stock shall be valued as restricted stock; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s1629d/c/1/B","parentIdentifier":"/us/usc/t43/s1629d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s1629d/c/1/B/i","parentIdentifier":"/us/usc/t43/s1629d/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"any land conveyed to the corporation pursuant to or any other land used as a cemetery; andsection 1613(h)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s1629d/c/1/B/ii","parentIdentifier":"/us/usc/t43/s1629d/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s1629d/c/1/B/ii/I","parentIdentifier":"/us/usc/t43/s1629d/c/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fc%2F1%2FB%2Fii%2FI","sourceRelease":"119-100","text":"exempt from real estate taxation pursuant to , andsection 1636(d)(1)(A) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s1629d/c/1/B/ii/II","parentIdentifier":"/us/usc/t43/s1629d/c/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fc%2F1%2FB%2Fii%2FII","sourceRelease":"119-100","text":"used by the shareholders of the corporation for subsistence uses (as defined in ); orsection 3113 of title 16","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t43/s1629d/c/1/B/iii","parentIdentifier":"/us/usc/t43/s1629d/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fc%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"any land or interest in land which the board of directors believes to be only of speculative value;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s1629d/c/2","parentIdentifier":"/us/usc/t43/s1629d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fc%2F2","sourceRelease":"119-100","text":"No person shall have a claim against a Native Corporation or its board of directors based upon the failure of the board to approve a resolution authorized by this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Form of payment","label":"d Form of payment","identifier":"/us/usc/t43/s1629d/d","parentIdentifier":"/us/usc/t43/s1629d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s1629d/d/1","parentIdentifier":"/us/usc/t43/s1629d/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s1629d/d/1/A","parentIdentifier":"/us/usc/t43/s1629d/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fd%2F1%2FA","sourceRelease":"119-100","text":"a payment bond issued by an insurance company or financial institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s1629d/d/1/B","parentIdentifier":"/us/usc/t43/s1629d/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fd%2F1%2FB","sourceRelease":"119-100","text":"the deposit in escrow of securities or property having a fair market value equal to at least 125 per centum of the face value of the note; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t43/s1629d/d/1/C","parentIdentifier":"/us/usc/t43/s1629d/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fd%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s1629d/d/1/C/i","parentIdentifier":"/us/usc/t43/s1629d/d/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fd%2F1%2FC%2Fi","sourceRelease":"119-100","text":"land conveyed to the corporation pursuant to , or any other land used as a cemetery;section 1613(h)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s1629d/d/1/C/ii","parentIdentifier":"/us/usc/t43/s1629d/d/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fd%2F1%2FC%2Fii","sourceRelease":"119-100","text":"the percentage interest in the corporation’s timber resources and subsurface estate that exceeds its percentage interest in revenues from such property under ; orsection 1606(i) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t43/s1629d/d/1/C/iii","parentIdentifier":"/us/usc/t43/s1629d/d/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fd%2F1%2FC%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s1629d/d/1/C/iii/I","parentIdentifier":"/us/usc/t43/s1629d/d/1/C/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fd%2F1%2FC%2Fiii%2FI","sourceRelease":"119-100","text":"exempt from real estate taxation pursuant to ; andsection 1636(d)(1)(A) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s1629d/d/1/C/iii/II","parentIdentifier":"/us/usc/t43/s1629d/d/1/C/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fd%2F1%2FC%2Fiii%2FII","sourceRelease":"119-100","text":"used by the shareholders of the corporation for subsistence uses (as defined in ),section 3113 of title 16","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s1629d/d/2","parentIdentifier":"/us/usc/t43/s1629d/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s1629d/d/2/A","parentIdentifier":"/us/usc/t43/s1629d/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fd%2F2%2FA","sourceRelease":"119-100","text":"interest shall be paid semi-annually, beginning as of the date on which the vote described in subsection (a)(1) occurred, at the rate applicable on such date to obligations of the United States having a maturity date of one year, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s1629d/d/2/B","parentIdentifier":"/us/usc/t43/s1629d/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fd%2F2%2FB","sourceRelease":"119-100","text":"the principal amount and accrued interest on such note shall be payable to the holder at a time specified by the corporation but in no event later than the date that is five years after the date of the vote described in subsection (a)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Dividend adjustment","label":"e Dividend adjustment","identifier":"/us/usc/t43/s1629d/e","parentIdentifier":"/us/usc/t43/s1629d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s1629d/e/1","parentIdentifier":"/us/usc/t43/s1629d/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fe%2F1","sourceRelease":"119-100","text":"The cash payment made pursuant to subsection (a) or the principal amount of a note issued pursuant to subsection (d) to a dissenting shareholder shall be reduced by the amount of dividends paid to such shareholder with respect to his or her Settlement Common Stock after the date of the vote described in subsection (a)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s1629d/e/2","parentIdentifier":"/us/usc/t43/s1629d/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629d%2Fe%2F2","sourceRelease":"119-100","text":"Upon receipt of a cash payment pursuant to subsection (a) or a note pursuant to subsection (d), a dissenting shareholder shall no longer have an interest in the shares of Settlement Common Stock or in the Native Corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
