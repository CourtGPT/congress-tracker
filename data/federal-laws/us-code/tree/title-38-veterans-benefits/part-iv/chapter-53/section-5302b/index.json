{"type":"section","nativeType":"section","number":"5302B","heading":"Prohibition of debt arising from overpayment due to delay in processing","label":"5302B Prohibition of debt arising from overpayment due to delay in processing","identifier":"/us/usc/t38/s5302B","parentIdentifier":"/us/usc/t38/ptIV/ch53","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Regulations, , , provided that:Pub. L. 117–328, div. U, title II, § 252(a)(3)136 Stat. 5463Dec. 29, 2022“The Secretary of Veterans Affairs shall prescribe regulations to establish standards under section 5302B(a)(2) of such title, as added by subsection (a), not later than 180 days after the date of the enactment of this Act [].”Dec. 29, 2022"],"amendments":["Regulations, , , provided that:Pub. L. 117–328, div. U, title II, § 252(a)(3)136 Stat. 5463Dec. 29, 2022“The Secretary of Veterans Affairs shall prescribe regulations to establish standards under section 5302B(a)(2) of such title, as added by subsection (a), not later than 180 days after the date of the enactment of this Act [].”Dec. 29, 2022"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Limitation","label":"a .—Limitation","identifier":"/us/usc/t38/s5302B/a","parentIdentifier":"/us/usc/t38/s5302B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s5302B/a/1","parentIdentifier":"/us/usc/t38/s5302B/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s5302B/a/1/A","parentIdentifier":"/us/usc/t38/s5302B/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fa%2F1%2FA","sourceRelease":"119-100","text":"arises from the participation of the individual in a program or benefit administered by the Under Secretary for Benefits; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s5302B/a/1/B","parentIdentifier":"/us/usc/t38/s5302B/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fa%2F1%2FB","sourceRelease":"119-100","text":"is attributable to the failure of an employee or official of the Department to process information provided by or on behalf of that individual within applicable timeliness standards established by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s5302B/a/2","parentIdentifier":"/us/usc/t38/s5302B/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fa%2F2","sourceRelease":"119-100","text":"Nothing in this section shall be construed to affect the penal and forfeiture provisions for fiduciaries set forth in chapter 61 of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Notice","label":"b .—Notice","identifier":"/us/usc/t38/s5302B/b","parentIdentifier":"/us/usc/t38/s5302B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s5302B/b/1","parentIdentifier":"/us/usc/t38/s5302B/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fb%2F1","sourceRelease":"119-100","text":"If the Secretary determines that the Secretary has made an overpayment to an individual, the Secretary shall provide notice to the individual of the overpayment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s5302B/b/2","parentIdentifier":"/us/usc/t38/s5302B/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s5302B/b/2/A","parentIdentifier":"/us/usc/t38/s5302B/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fb%2F2%2FA","sourceRelease":"119-100","text":"to dispute the overpayment, including a detailed explanation of the process by which to dispute the overpayment; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s5302B/b/2/B","parentIdentifier":"/us/usc/t38/s5302B/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fb%2F2%2FB","sourceRelease":"119-100","text":"to request a waiver of indebtedness.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Delay on Collection","label":"c .—Delay on Collection","identifier":"/us/usc/t38/s5302B/c","parentIdentifier":"/us/usc/t38/s5302B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s5302B/c/1","parentIdentifier":"/us/usc/t38/s5302B/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fc%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2), the Secretary may not take any action under regarding an overpayment described in a notice under subsection (b) of this section until the date that is 90 days after the date the Secretary issues such notice.section 3711 of title 31","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s5302B/c/2","parentIdentifier":"/us/usc/t38/s5302B/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s5302B/c/2/A","parentIdentifier":"/us/usc/t38/s5302B/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fc%2F2%2FA","sourceRelease":"119-100","text":"likely to make repayment of such overpayment more difficult for an individual;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s5302B/c/2/B","parentIdentifier":"/us/usc/t38/s5302B/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fc%2F2%2FB","sourceRelease":"119-100","text":"likely to cause an unpaid debt to be referred to the Treasury Offset Program; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s5302B/c/2/C","parentIdentifier":"/us/usc/t38/s5302B/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5302B%2Fc%2F2%2FC","sourceRelease":"119-100","text":"not in the best interest of the individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
