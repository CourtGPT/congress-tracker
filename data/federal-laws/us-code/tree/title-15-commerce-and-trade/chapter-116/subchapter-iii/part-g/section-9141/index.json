item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t15/s9141/a/5/D/iv/II/bb","parentIdentifier":"/us/usc/t15/s9141/a/5/D/iv/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F5%2FD%2Fiv%2FII%2Fbb","sourceRelease":"119-100","text":"50 percent of the excess over $3,000,000 of the total compensation received by the officer or employee from the contractor in calendar year 2019.3So in original. The period probably should be “; and”.3","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s9141/a/6","parentIdentifier":"/us/usc/t15/s9141/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fa%2F6","sourceRelease":"119-100","text":"the term “Secretary” means the Secretary of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Payroll support grants","label":"b Payroll support grants","identifier":"/us/usc/t15/s9141/b","parentIdentifier":"/us/usc/t15/s9141","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s9141/b/1","parentIdentifier":"/us/usc/t15/s9141/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9141/b/1/A","parentIdentifier":"/us/usc/t15/s9141/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F1%2FA","sourceRelease":"119-100","text":"eligible air carriers, in an aggregate amount of $14,000,000,000; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9141/b/1/B","parentIdentifier":"/us/usc/t15/s9141/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F1%2FB","sourceRelease":"119-100","text":"eligible contractors, in an aggregate amount of $1,000,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Apportionments","label":"2 Apportionments","identifier":"/us/usc/t15/s9141/b/2","parentIdentifier":"/us/usc/t15/s9141/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s9141/b/2/A","parentIdentifier":"/us/usc/t15/s9141/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The Secretary shall apportion funds to eligible air carriers and eligible contractors in accordance with the requirements of this section not later than .April 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Eligible air carriers","label":"B Eligible air carriers","identifier":"/us/usc/t15/s9141/b/2/B","parentIdentifier":"/us/usc/t15/s9141/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9141/b/2/B/i","parentIdentifier":"/us/usc/t15/s9141/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the amount received by the air carrier pursuant to bears tosection 9093(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9141/b/2/B/ii","parentIdentifier":"/us/usc/t15/s9141/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"$15,000,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Eligible contractors","label":"C Eligible contractors","identifier":"/us/usc/t15/s9141/b/2/C","parentIdentifier":"/us/usc/t15/s9141/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F2%2FC","sourceRelease":"119-100","text":"The Secretary shall apportion, to each eligible contractor, an amount equal to the total amount such contractor received pursuant to .section 9093(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"In general","label":"3 In general","identifier":"/us/usc/t15/s9141/b/3","parentIdentifier":"/us/usc/t15/s9141/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Forms; terms and conditions","label":"A Forms; terms and conditions","identifier":"/us/usc/t15/s9141/b/3/A","parentIdentifier":"/us/usc/t15/s9141/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F3%2FA","sourceRelease":"119-100","text":"The Secretary shall provide financial assistance to an eligible air carrier or eligible contractor under this section in the same form and on the same terms and conditions as determined by pursuant to .4section 9093(b)(1)(A) of this titleSo in original.4","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Procedures","label":"B Procedures","identifier":"/us/usc/t15/s9141/b/3/B","parentIdentifier":"/us/usc/t15/s9141/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F3%2FB","sourceRelease":"119-100","text":"The Secretary shall publish streamlined and expedited procedures not later than 5 days after , for eligible air carriers and eligible contractors to submit requests for financial assistance under this section.March 11, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Deadline for immediate payroll assistance","label":"C Deadline for immediate payroll assistance","identifier":"/us/usc/t15/s9141/b/3/C","parentIdentifier":"/us/usc/t15/s9141/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F3%2FC","sourceRelease":"119-100","text":"Not later than 10 days after , the Secretary shall make initial payments to air carriers and contractors that submit requests for financial assistance approved by the Secretary.March 11, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Taxpayer protection","label":"4 Taxpayer protection","identifier":"/us/usc/t15/s9141/b/4","parentIdentifier":"/us/usc/t15/s9141/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F4","sourceRelease":"119-100","text":"The Secretary shall receive financial instruments issued by recipients of financial assistance under this section in the same form and amount, and under the same terms and conditions, as determined by the Secretary under .section 9098 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Administrative expenses","label":"5 Administrative expenses","identifier":"/us/usc/t15/s9141/b/5","parentIdentifier":"/us/usc/t15/s9141/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fb%2F5","sourceRelease":"119-100","text":"Of the amounts made available under paragraph (1)(A), $10,000,000 shall be made available to the Secretary for costs and administrative expenses associated with providing financial assistance under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Funding","label":"c Funding","identifier":"/us/usc/t15/s9141/c","parentIdentifier":"/us/usc/t15/s9141","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9141%2Fc","sourceRelease":"119-100","text":"In addition to amounts otherwise available, there is appropriated for fiscal year 2021, out of any money in the Treasury not otherwise appropriated, $15,000,000,000, to remain available until expended, to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
