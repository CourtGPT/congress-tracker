{"type":"section","nativeType":"section","number":"4814","heading":"Petition and review","label":"4814 Petition and review","identifier":"/us/usc/t7/s4814","parentIdentifier":"/us/usc/t7/ch79","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4814","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , see , set out as a note under .Jan. 1, 1986section 1631 of Pub. L. 99–198section 4801 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t7/s4814/a","parentIdentifier":"/us/usc/t7/s4814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4814%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s4814/a/1","parentIdentifier":"/us/usc/t7/s4814/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4814%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s4814/a/1/A","parentIdentifier":"/us/usc/t7/s4814/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4814%2Fa%2F1%2FA","sourceRelease":"119-100","text":"stating that such order, a provision of such order, or an obligation imposed in connection with such order is not in accordance with law; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s4814/a/1/B","parentIdentifier":"/us/usc/t7/s4814/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4814%2Fa%2F1%2FB","sourceRelease":"119-100","text":"requesting a modification of such order or an exemption from such order.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s4814/a/2","parentIdentifier":"/us/usc/t7/s4814/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4814%2Fa%2F2","sourceRelease":"119-100","text":"Such person shall be given an opportunity for a hearing on the petition, in accordance with regulations issued by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s4814/a/3","parentIdentifier":"/us/usc/t7/s4814/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4814%2Fa%2F3","sourceRelease":"119-100","text":"After such hearing, the Secretary shall make a determination granting or denying such petition.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t7/s4814/b","parentIdentifier":"/us/usc/t7/s4814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4814%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s4814/b/1","parentIdentifier":"/us/usc/t7/s4814/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4814%2Fb%2F1","sourceRelease":"119-100","text":"A district court of the United States in the district in which such person resides or does business shall have jurisdiction to review such determination if a complaint for such purpose is filed not later than 20 days after the date such person receives notice of such determination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s4814/b/2","parentIdentifier":"/us/usc/t7/s4814/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4814%2Fb%2F2","sourceRelease":"119-100","text":"Service of process in such proceeding may be made on the Secretary by delivering a copy of the complaint to the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s4814/b/3","parentIdentifier":"/us/usc/t7/s4814/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4814%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s4814/b/3/A","parentIdentifier":"/us/usc/t7/s4814/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4814%2Fb%2F3%2FA","sourceRelease":"119-100","text":"make such ruling as the court shall determine to be in accordance with law; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s4814/b/3/B","parentIdentifier":"/us/usc/t7/s4814/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4814%2Fb%2F3%2FB","sourceRelease":"119-100","text":"take such further proceedings as, in the opinion of the court, the law requires.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
