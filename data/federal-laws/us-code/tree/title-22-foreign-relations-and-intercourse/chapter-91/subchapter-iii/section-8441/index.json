":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"M","heading":null,"label":"M","identifier":"/us/usc/t22/s8441/a/6/M","parentIdentifier":"/us/usc/t22/s8441/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fa%2F6%2FM","sourceRelease":"119-100","text":"Land rights and access.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"N","heading":null,"label":"N","identifier":"/us/usc/t22/s8441/a/6/N","parentIdentifier":"/us/usc/t22/s8441/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fa%2F6%2FN","sourceRelease":"119-100","text":"Trade policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"O","heading":null,"label":"O","identifier":"/us/usc/t22/s8441/a/6/O","parentIdentifier":"/us/usc/t22/s8441/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fa%2F6%2FO","sourceRelease":"119-100","text":"Regulatory quality.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"P","heading":null,"label":"P","identifier":"/us/usc/t22/s8441/a/6/P","parentIdentifier":"/us/usc/t22/s8441/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fa%2F6%2FP","sourceRelease":"119-100","text":"Inflation control.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"Q","heading":null,"label":"Q","identifier":"/us/usc/t22/s8441/a/6/Q","parentIdentifier":"/us/usc/t22/s8441/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fa%2F6%2FQ","sourceRelease":"119-100","text":"Fiscal policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t22/s8441/a/7","parentIdentifier":"/us/usc/t22/s8441/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fa%2F7","sourceRelease":"119-100","text":"An analysis for the suitable replacement for existing Pakistani helicopters, including recommendations for sustainment and training.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Comprehensive regional strategy report","label":"b Comprehensive regional strategy report","identifier":"/us/usc/t22/s8441/b","parentIdentifier":"/us/usc/t22/s8441","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Sense of Congress","label":"1 Sense of Congress","identifier":"/us/usc/t22/s8441/b/1","parentIdentifier":"/us/usc/t22/s8441/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fb%2F1","sourceRelease":"119-100","text":"It is the sense of Congress that the achievement of United States national security goals to eliminate terrorist threats and close safe havens in Pakistan requires the development of a comprehensive plan that utilizes all elements of national power, including in coordination and cooperation with other concerned governments, and that it is critical to Pakistan’s long-term prosperity and security to strengthen regional relationships among India, Pakistan, and Afghanistan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Comprehensive regional security strategy","label":"2 Comprehensive regional security strategy","identifier":"/us/usc/t22/s8441/b/2","parentIdentifier":"/us/usc/t22/s8441/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fb%2F2","sourceRelease":"119-100","text":"The President shall develop a comprehensive interagency regional security strategy to eliminate terrorist threats and close safe havens in Pakistan, including by working with the Government of Pakistan and other relevant governments and organizations in the region and elsewhere, as appropriate, to best implement effective counterinsurgency and counterterrorism efforts in and near the border areas of Pakistan and Afghanistan, including the FATA, the NWFP, parts of Balochistan, and parts of Punjab.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Report","label":"3 Report","identifier":"/us/usc/t22/s8441/b/3","parentIdentifier":"/us/usc/t22/s8441/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t22/s8441/b/3/A","parentIdentifier":"/us/usc/t22/s8441/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fb%2F3%2FA","sourceRelease":"119-100","text":"Not later than 180 days after , the President shall submit to the appropriate congressional committees a report on the comprehensive regional security strategy required under paragraph (2).October 15, 2009","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Contents","label":"B Contents","identifier":"/us/usc/t22/s8441/b/3/B","parentIdentifier":"/us/usc/t22/s8441/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fb%2F3%2FB","sourceRelease":"119-100","text":"The report shall include a copy of the comprehensive regional security strategy, including specifications of goals, and proposed timelines and budgets for implementation of the strategy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Appropriate congressional committees defined","label":"C Appropriate congressional committees defined","identifier":"/us/usc/t22/s8441/b/3/C","parentIdentifier":"/us/usc/t22/s8441/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fb%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s8441/b/3/C/i","parentIdentifier":"/us/usc/t22/s8441/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fb%2F3%2FC%2Fi","sourceRelease":"119-100","text":"the Committee on Appropriations, the Committee on Armed Services, the Committee on Foreign Affairs, and the Permanent Select Committee on Intelligence of the House of Representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s8441/b/3/C/ii","parentIdentifier":"/us/usc/t22/s8441/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fb%2F3%2FC%2Fii","sourceRelease":"119-100","text":"the Committee on Appropriations, the Committee on Armed Services, the Committee on Foreign Relations, and the Select Committee on Intelligence of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Security-related assistance plan","label":"c Security-related assistance plan","identifier":"/us/usc/t22/s8441/c","parentIdentifier":"/us/usc/t22/s8441","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8441%2Fc","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary of State shall submit to the appropriate congressional committees a plan for the proposed use of amounts authorized for security-related assistance for each of the fiscal years 2010 through 2014. Such plan shall include an assessment of how the use of such amounts complements or otherwise is related to amounts described in .October 15, 2009section 8424 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
