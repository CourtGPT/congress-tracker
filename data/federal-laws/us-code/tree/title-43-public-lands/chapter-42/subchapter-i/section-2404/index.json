{"type":"section","nativeType":"section","number":"2404","heading":"Appraisal investigations","label":"2404 Appraisal investigations","identifier":"/us/usc/t43/s2404","parentIdentifier":"/us/usc/t43/ch42/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t43/s2404/a","parentIdentifier":"/us/usc/t43/s2404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2404/a/1","parentIdentifier":"/us/usc/t43/s2404/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2404/a/1/A","parentIdentifier":"/us/usc/t43/s2404/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fa%2F1%2FA","sourceRelease":"119-100","text":"developed by the non-Federal project entity, with or without support from the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2404/a/1/B","parentIdentifier":"/us/usc/t43/s2404/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fa%2F1%2FB","sourceRelease":"119-100","text":"submitted to the Secretary by the non-Federal project entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2404/a/2","parentIdentifier":"/us/usc/t43/s2404/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fa%2F2","sourceRelease":"119-100","text":"conduct an appraisal investigation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s2404/a/3","parentIdentifier":"/us/usc/t43/s2404/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2404/a/3/A","parentIdentifier":"/us/usc/t43/s2404/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fa%2F3%2FA","sourceRelease":"119-100","text":"the non-Federal project entity is qualified to complete the appraisal investigation in accordance with the criteria published under ; andsection 2402(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2404/a/3/B","parentIdentifier":"/us/usc/t43/s2404/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fa%2F3%2FB","sourceRelease":"119-100","text":"using the non-Federal project entity to conduct the appraisal investigation is a cost-effective alternative for completing the appraisal investigation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Deadline","label":"b Deadline","identifier":"/us/usc/t43/s2404/b","parentIdentifier":"/us/usc/t43/s2404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fb","sourceRelease":"119-100","text":"An appraisal investigation conducted under subsection (a) shall be scheduled for completion not later than 2 years after the date on which the appraisal investigation is initiated.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Appraisal report","label":"c Appraisal report","identifier":"/us/usc/t43/s2404/c","parentIdentifier":"/us/usc/t43/s2404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2404/c/1","parentIdentifier":"/us/usc/t43/s2404/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2404/c/1/A","parentIdentifier":"/us/usc/t43/s2404/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s2404/c/1/A/i","parentIdentifier":"/us/usc/t43/s2404/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the appraisal criteria developed under subsection (d); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s2404/c/1/A/ii","parentIdentifier":"/us/usc/t43/s2404/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the eligibility criteria developed under ;section 2402(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2404/c/1/B","parentIdentifier":"/us/usc/t43/s2404/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FB","sourceRelease":"119-100","text":"whether viable water supplies and water rights exist to supply the project, including all practicable water sources such as lower quality waters, nonpotable waters, and water reuse-based water supplies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t43/s2404/c/1/C","parentIdentifier":"/us/usc/t43/s2404/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FC","sourceRelease":"119-100","text":"whether the project has a positive effect on public health and safety;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t43/s2404/c/1/D","parentIdentifier":"/us/usc/t43/s2404/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FD","sourceRelease":"119-100","text":"whether the project will meet water demand, including projected future needs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t43/s2404/c/1/E","parentIdentifier":"/us/usc/t43/s2404/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FE","sourceRelease":"119-100","text":"the extent to which the project provides environmental benefits, including source water protection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t43/s2404/c/1/F","parentIdentifier":"/us/usc/t43/s2404/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FF","sourceRelease":"119-100","text":"whether the project applies a regional or watershed perspective and promotes benefits in the region in which the project is carried out;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t43/s2404/c/1/G","parentIdentifier":"/us/usc/t43/s2404/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FG","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s2404/c/1/G/i","parentIdentifier":"/us/usc/t43/s2404/c/1/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FG%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s2404/c/1/G/i/I","parentIdentifier":"/us/usc/t43/s2404/c/1/G/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FG%2Fi%2FI","sourceRelease":"119-100","text":"implements an integrated resources management approach; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s2404/c/1/G/i/II","parentIdentifier":"/us/usc/t43/s2404/c/1/G/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FG%2Fi%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t43/s2404/c/1/G/i/II/aa","parentIdentifier":"/us/usc/t43/s2404/c/1/G/i/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FG%2Fi%2FII%2Faa","sourceRelease":"119-100","text":"local control to manage water supplies under varying water supply conditions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t43/s2404/c/1/G/i/II/bb","parentIdentifier":"/us/usc/t43/s2404/c/1/G/i/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FG%2Fi%2FII%2Fbb","sourceRelease":"119-100","text":"participation in water banking and markets for domestic and environmental purposes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s2404/c/1/G/ii","parentIdentifier":"/us/usc/t43/s2404/c/1/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FG%2Fii","sourceRelease":"119-100","text":"promotes long-term protection of water supplies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t43/s2404/c/1/H","parentIdentifier":"/us/usc/t43/s2404/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FH","sourceRelease":"119-100","text":"preliminary cost estimates for the project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s2404/c/1/I","parentIdentifier":"/us/usc/t43/s2404/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F1%2FI","sourceRelease":"119-100","text":"whether the non-Federal project entity has the capability to pay 100 percent of the costs associated with the operations, maintenance, and replacement of the facilities constructed or developed as part of the rural water supply project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2404/c/2","parentIdentifier":"/us/usc/t43/s2404/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fc%2F2","sourceRelease":"119-100","text":"provides recommendations on whether a feasibility study should be initiated under .section 2405(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Appraisal criteria","label":"d Appraisal criteria","identifier":"/us/usc/t43/s2404/d","parentIdentifier":"/us/usc/t43/s2404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s2404/d/1","parentIdentifier":"/us/usc/t43/s2404/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fd%2F1","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary shall promulgate criteria (including appraisal factors listed under subsection (c)) against which the appraisal investigations shall be assessed for completeness and appropriateness for a feasibility study.December 22, 2006","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Inclusions","label":"2 Inclusions","identifier":"/us/usc/t43/s2404/d/2","parentIdentifier":"/us/usc/t43/s2404/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fd%2F2","sourceRelease":"119-100","text":"To minimize the cost of a rural water supply project to a non-Federal project entity, the Secretary shall include in the criteria methods to scale the level of effort needed to complete the appraisal investigation relative to the total size and cost of the proposed rural water supply project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Review of appraisal investigation","label":"e Review of appraisal investigation","identifier":"/us/usc/t43/s2404/e","parentIdentifier":"/us/usc/t43/s2404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s2404/e/1","parentIdentifier":"/us/usc/t43/s2404/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fe%2F1","sourceRelease":"119-100","text":"Not later than 90 days after the date of submission of an appraisal investigation under paragraph (1) or (3) of subsection (a), the Secretary shall provide to the non-Federal entity that conducted the investigation a determination of whether the investigation has included the information necessary to determine whether the proposed rural water supply project satisfies the criteria promulgated under subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"No satisfaction of criteria","label":"2 No satisfaction of criteria","identifier":"/us/usc/t43/s2404/e/2","parentIdentifier":"/us/usc/t43/s2404/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fe%2F2","sourceRelease":"119-100","text":"If the Secretary determines that the appraisal investigation submitted by a non-Federal entity does not satisfy the criteria promulgated under subsection (d), the Secretary shall inform the non-Federal entity of the reasons why the appraisal investigation is deficient.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Responsibility of Secretary","label":"3 Responsibility of Secretary","identifier":"/us/usc/t43/s2404/e/3","parentIdentifier":"/us/usc/t43/s2404/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fe%2F3","sourceRelease":"119-100","text":"If an appraisal investigation as first submitted by a non-Federal entity does not provide all necessary information, as defined by the Secretary, the Secretary shall have no obligation to conduct further analysis until the non-Federal project entity submitting the appraisal study conducts additional investigation and resubmits the appraisal investigation under this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Appraisal report","label":"f Appraisal report","identifier":"/us/usc/t43/s2404/f","parentIdentifier":"/us/usc/t43/s2404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2404/f/1","parentIdentifier":"/us/usc/t43/s2404/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Ff%2F1","sourceRelease":"119-100","text":"complete the appraisal report required under subsection (c);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2404/f/2","parentIdentifier":"/us/usc/t43/s2404/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Ff%2F2","sourceRelease":"119-100","text":"make available to the public, on request, the appraisal report prepared under this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s2404/f/3","parentIdentifier":"/us/usc/t43/s2404/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Ff%2F3","sourceRelease":"119-100","text":"promptly publish in the Federal Register a notice of the availability of the results.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Costs","label":"g Costs","identifier":"/us/usc/t43/s2404/g","parentIdentifier":"/us/usc/t43/s2404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Federal share","label":"1 Federal share","identifier":"/us/usc/t43/s2404/g/1","parentIdentifier":"/us/usc/t43/s2404/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fg%2F1","sourceRelease":"119-100","text":"The Federal share of an appraisal investigation conducted under subsection (a) shall be 100 percent of the total cost of the appraisal investigation, up to $200,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Non-Federal share","label":"2 Non-Federal share","identifier":"/us/usc/t43/s2404/g/2","parentIdentifier":"/us/usc/t43/s2404/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fg%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t43/s2404/g/2/A","parentIdentifier":"/us/usc/t43/s2404/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fg%2F2%2FA","sourceRelease":"119-100","text":"Except as provided in subparagraph (B), if the cost of conducting an appraisal investigation is more than $200,000, the non-Federal share of the costs in excess of $200,000 shall be 50 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exception","label":"B Exception","identifier":"/us/usc/t43/s2404/g/2/B","parentIdentifier":"/us/usc/t43/s2404/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fg%2F2%2FB","sourceRelease":"119-100","text":"The Secretary may reduce the non-Federal share required under subparagraph (A) if the Secretary determines that there is an overwhelming Federal interest in the appraisal investigation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Form","label":"C Form","identifier":"/us/usc/t43/s2404/g/2/C","parentIdentifier":"/us/usc/t43/s2404/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fg%2F2%2FC","sourceRelease":"119-100","text":"The non-Federal share under subparagraph (A) may be in the form of any in-kind services that the Secretary determines would contribute substantially toward the conduct and completion of the appraisal investigation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Consultation; identification of funding sources","label":"h Consultation; identification of funding sources","identifier":"/us/usc/t43/s2404/h","parentIdentifier":"/us/usc/t43/s2404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2404/h/1","parentIdentifier":"/us/usc/t43/s2404/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fh%2F1","sourceRelease":"119-100","text":"consult and cooperate with the non-Federal project entity and appropriate State, tribal, regional, and local authorities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2404/h/2","parentIdentifier":"/us/usc/t43/s2404/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fh%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2404/h/2/A","parentIdentifier":"/us/usc/t43/s2404/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fh%2F2%2FA","sourceRelease":"119-100","text":"ensure that the proposed rural water supply project does not duplicate a project carried out under the authority of the agency head; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2404/h/2/B","parentIdentifier":"/us/usc/t43/s2404/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fh%2F2%2FB","sourceRelease":"119-100","text":"if a duplicate project is being carried out, identify the authority under which the duplicate project is being carried out; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s2404/h/3","parentIdentifier":"/us/usc/t43/s2404/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2404%2Fh%2F3","sourceRelease":"119-100","text":"identify what funding sources are available for the proposed rural water supply project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
