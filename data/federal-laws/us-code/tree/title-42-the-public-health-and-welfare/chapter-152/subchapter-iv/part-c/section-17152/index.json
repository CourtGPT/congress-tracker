{"type":"section","nativeType":"section","number":"17152","heading":"Energy Efficiency and Conservation Block Grant Program","label":"17152 Energy Efficiency and Conservation Block Grant Program","identifier":"/us/usc/t42/s17152","parentIdentifier":"/us/usc/t42/ch152/schIV/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17152","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t42/s17152/a","parentIdentifier":"/us/usc/t42/s17152","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17152%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish a program, to be known as the “Energy Efficiency and Conservation Block Grant Program”, under which the Secretary shall provide grants to eligible entities in accordance with this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purpose","label":"b Purpose","identifier":"/us/usc/t42/s17152/b","parentIdentifier":"/us/usc/t42/s17152","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17152%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17152/b/1","parentIdentifier":"/us/usc/t42/s17152/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17152%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph