{"type":"section","nativeType":"section","number":"16198","heading":"Smart energy and water efficiency pilot program","label":"16198 Smart energy and water efficiency pilot program","identifier":"/us/usc/t42/s16198","parentIdentifier":"/us/usc/t42/ch149/schIX/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s16198/a","parentIdentifier":"/us/usc/t42/s16198","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible entity","label":"1 Eligible entity","identifier":"/us/usc/t42/s16198/a/1","parentIdentifier":"/us/usc/t42/s16198/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16198/a/1/A","parentIdentifier":"/us/usc/t42/s16198/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fa%2F1%2FA","sourceRelease":"119-100","text":"a utility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16198/a/1/B","parentIdentifier":"/us/usc/t42/s16198/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fa%2F1%2FB","sourceRelease":"119-100","text":"a municipality;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16198/a/1/C","parentIdentifier":"/us/usc/t42/s16198/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fa%2F1%2FC","sourceRelease":"119-100","text":"a water district;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16198/a/1/D","parentIdentifier":"/us/usc/t42/s16198/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fa%2F1%2FD","sourceRelease":"119-100","text":"an Indian Tribe or Alaska Native village; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16198/a/1/E","parentIdentifier":"/us/usc/t42/s16198/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fa%2F1%2FE","sourceRelease":"119-100","text":"any other authority that provides water, wastewater, or water reuse services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Smart energy and water efficiency pilot program","label":"2 Smart energy and water efficiency pilot program","identifier":"/us/usc/t42/s16198/a/2","parentIdentifier":"/us/usc/t42/s16198/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fa%2F2","sourceRelease":"119-100","text":"The term “smart energy and water efficiency pilot program” or “pilot program” means the pilot program established under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Smart energy and water efficiency pilot program","label":"b Smart energy and water efficiency pilot program","identifier":"/us/usc/t42/s16198/b","parentIdentifier":"/us/usc/t42/s16198","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16198/b/1","parentIdentifier":"/us/usc/t42/s16198/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall establish and carry out a smart energy and water efficiency pilot program in accordance with this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Purpose","label":"2 Purpose","identifier":"/us/usc/t42/s16198/b/2","parentIdentifier":"/us/usc/t42/s16198/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16198/b/2/A","parentIdentifier":"/us/usc/t42/s16198/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F2%2FA","sourceRelease":"119-100","text":"improve the net energy balance of water, wastewater, and water reuse systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16198/b/2/B","parentIdentifier":"/us/usc/t42/s16198/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F2%2FB","sourceRelease":"119-100","text":"improve the net energy balance of water, wastewater, and water reuse systems to help communities across the United States make measurable progress in conserving water, saving energy, and reducing costs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16198/b/2/C","parentIdentifier":"/us/usc/t42/s16198/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F2%2FC","sourceRelease":"119-100","text":"support the implementation of innovative and unique processes and the installation of established advanced automated systems that provide real-time data on energy and water; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16198/b/2/D","parentIdentifier":"/us/usc/t42/s16198/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F2%2FD","sourceRelease":"119-100","text":"improve energy-water conservation and quality and predictive maintenance through technologies that utilize internet connected technologies, including sensors, intelligent gateways, and security embedded in hardware.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Project selection","label":"3 Project selection","identifier":"/us/usc/t42/s16198/b/3","parentIdentifier":"/us/usc/t42/s16198/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16198/b/3/A","parentIdentifier":"/us/usc/t42/s16198/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FA","sourceRelease":"119-100","text":"The Secretary shall make competitive, merit-reviewed grants under the pilot program to not less than 3, but not more than 5, eligible entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Selection criteria","label":"B Selection criteria","identifier":"/us/usc/t42/s16198/b/3/B","parentIdentifier":"/us/usc/t42/s16198/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16198/b/3/B/i","parentIdentifier":"/us/usc/t42/s16198/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"energy and cost savings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16198/b/3/B/ii","parentIdentifier":"/us/usc/t42/s16198/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"the uniqueness, commercial viability, and reliability of the technology to be used;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16198/b/3/B/iii","parentIdentifier":"/us/usc/t42/s16198/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"the degree to which the project integrates next-generation sensors software, analytics, and management tools;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s16198/b/3/B/iv","parentIdentifier":"/us/usc/t42/s16198/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FB%2Fiv","sourceRelease":"119-100","text":"the anticipated cost-effectiveness of the pilot project through measurable energy savings, water savings or reuse, and infrastructure costs averted;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s16198/b/3/B/v","parentIdentifier":"/us/usc/t42/s16198/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FB%2Fv","sourceRelease":"119-100","text":"whether the technology can be deployed in a variety of geographic regions and the degree to which the technology can be implemented in a wide range of applications ranging in scale from small towns to large cities, including Tribal communities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s16198/b/3/B/vi","parentIdentifier":"/us/usc/t42/s16198/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FB%2Fvi","sourceRelease":"119-100","text":"whether the technology has been successfully deployed elsewhere;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t42/s16198/b/3/B/vii","parentIdentifier":"/us/usc/t42/s16198/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FB%2Fvii","sourceRelease":"119-100","text":"whether the technology was sourced from a manufacturer based in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t42/s16198/b/3/B/viii","parentIdentifier":"/us/usc/t42/s16198/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FB%2Fviii","sourceRelease":"119-100","text":"whether the project will be completed in 5 years or less.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Applications","label":"C Applications","identifier":"/us/usc/t42/s16198/b/3/C","parentIdentifier":"/us/usc/t42/s16198/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t42/s16198/b/3/C/i","parentIdentifier":"/us/usc/t42/s16198/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FC%2Fi","sourceRelease":"119-100","text":"Subject to clause (ii), an eligible entity seeking a grant under the pilot program shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary determines to be necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Contents","label":"ii Contents","identifier":"/us/usc/t42/s16198/b/3/C/ii","parentIdentifier":"/us/usc/t42/s16198/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FC%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s16198/b/3/C/ii/I","parentIdentifier":"/us/usc/t42/s16198/b/3/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FC%2Fii%2FI","sourceRelease":"119-100","text":"a description of the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s16198/b/3/C/ii/II","parentIdentifier":"/us/usc/t42/s16198/b/3/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FC%2Fii%2FII","sourceRelease":"119-100","text":"a description of the technology to be used in the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t42/s16198/b/3/C/ii/III","parentIdentifier":"/us/usc/t42/s16198/b/3/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FC%2Fii%2FIII","sourceRelease":"119-100","text":"the anticipated results, including energy and water savings, of the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t42/s16198/b/3/C/ii/IV","parentIdentifier":"/us/usc/t42/s16198/b/3/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FC%2Fii%2FIV","sourceRelease":"119-100","text":"a comprehensive budget for the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t42/s16198/b/3/C/ii/V","parentIdentifier":"/us/usc/t42/s16198/b/3/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FC%2Fii%2FV","sourceRelease":"119-100","text":"the names of the project lead organization and any partners;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VI","heading":null,"label":"VI","identifier":"/us/usc/t42/s16198/b/3/C/ii/VI","parentIdentifier":"/us/usc/t42/s16198/b/3/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FC%2Fii%2FVI","sourceRelease":"119-100","text":"the number of users to be served by the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VII","heading":null,"label":"VII","identifier":"/us/usc/t42/s16198/b/3/C/ii/VII","parentIdentifier":"/us/usc/t42/s16198/b/3/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FC%2Fii%2FVII","sourceRelease":"119-100","text":"a description of the ways in which the proposal would meet performance measures established by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VIII","heading":null,"label":"VIII","identifier":"/us/usc/t42/s16198/b/3/C/ii/VIII","parentIdentifier":"/us/usc/t42/s16198/b/3/C/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F3%2FC%2Fii%2FVIII","sourceRelease":"119-100","text":"any other information that the Secretary determines to be necessary to complete the review and selection of a grant recipient.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Administration","label":"4 Administration","identifier":"/us/usc/t42/s16198/b/4","parentIdentifier":"/us/usc/t42/s16198/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16198/b/4/A","parentIdentifier":"/us/usc/t42/s16198/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F4%2FA","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary shall select grant recipients under this section.December 27, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Evaluations","label":"B Evaluations","identifier":"/us/usc/t42/s16198/b/4/B","parentIdentifier":"/us/usc/t42/s16198/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"Annual evaluations","label":"i Annual evaluations","identifier":"/us/usc/t42/s16198/b/4/B/i","parentIdentifier":"/us/usc/t42/s16198/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F4%2FB%2Fi","sourceRelease":"119-100","text":"The Secretary shall annually carry out an evaluation of each project for which a grant is provided under this section that meets performance measures and benchmarks developed by the Secretary, consistent with the purposes of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Requirements","label":"ii Requirements","identifier":"/us/usc/t42/s16198/b/4/B/ii","parentIdentifier":"/us/usc/t42/s16198/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F4%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s16198/b/4/B/ii/I","parentIdentifier":"/us/usc/t42/s16198/b/4/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F4%2FB%2Fii%2FI","sourceRelease":"119-100","text":"evaluate the progress and impact of the project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s16198/b/4/B/ii/II","parentIdentifier":"/us/usc/t42/s16198/b/4/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F4%2FB%2Fii%2FII","sourceRelease":"119-100","text":"assess the degree to which the project is meeting the goals of the pilot program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Technical and policy assistance","label":"C Technical and policy assistance","identifier":"/us/usc/t42/s16198/b/4/C","parentIdentifier":"/us/usc/t42/s16198/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F4%2FC","sourceRelease":"119-100","text":"On the request of a grant recipient, the Secretary shall provide technical and policy assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Best practices","label":"D Best practices","identifier":"/us/usc/t42/s16198/b/4/D","parentIdentifier":"/us/usc/t42/s16198/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F4%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16198/b/4/D/i","parentIdentifier":"/us/usc/t42/s16198/b/4/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F4%2FD%2Fi","sourceRelease":"119-100","text":"a copy of each evaluation carried out under subparagraph (B); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16198/b/4/D/ii","parentIdentifier":"/us/usc/t42/s16198/b/4/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F4%2FD%2Fii","sourceRelease":"119-100","text":"a description of any best practices identified by the Secretary as a result of those evaluations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":"Report to Congress","label":"E Report to Congress","identifier":"/us/usc/t42/s16198/b/4/E","parentIdentifier":"/us/usc/t42/s16198/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fb%2F4%2FE","sourceRelease":"119-100","text":"The Secretary shall submit to Congress a report containing the results of each evaluation carried out under subparagraph (B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t42/s16198/c","parentIdentifier":"/us/usc/t42/s16198","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16198%2Fc","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary to carry out this section $15,000,000, to remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
