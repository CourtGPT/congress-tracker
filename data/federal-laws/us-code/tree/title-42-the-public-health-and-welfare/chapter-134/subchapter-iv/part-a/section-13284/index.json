{"type":"section","nativeType":"section","number":"13284","heading":"Cost-sharing","label":"13284 Cost-sharing","identifier":"/us/usc/t42/s13284","parentIdentifier":"/us/usc/t42/ch134/schIV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13284","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Requirement","label":"a Requirement","identifier":"/us/usc/t42/s13284/a","parentIdentifier":"/us/usc/t42/s13284","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13284%2Fa","sourceRelease":"119-100","text":"The Secretary shall require at least 50 percent of the costs directly and specifically related to any project under this part to be from non-Federal sources. Such share may be in the form of cash, personnel, services, equipment, and other resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Reduction","label":"b Reduction","identifier":"/us/usc/t42/s13284/b","parentIdentifier":"/us/usc/t42/s13284","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13284%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13284/b/1","parentIdentifier":"/us/usc/t42/s13284/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13284%2Fb%2F1","sourceRelease":"119-100","text":"considering the technological risks involved in the project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13284/b/2","parentIdentifier":"/us/usc/t42/s13284/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13284%2Fb%2F2","sourceRelease":"119-100","text":"in order to meet the objectives of this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
