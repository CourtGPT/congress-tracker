"heading":null,"label":"B","identifier":"/us/usc/t10/s5514/a/1/B","parentIdentifier":"/us/usc/t10/s5514/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fa%2F1%2FB","sourceRelease":"119-100","text":"each designated major subprogram of such program elements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s5514/a/2","parentIdentifier":"/us/usc/t10/s5514/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s5514/a/2/A","parentIdentifier":"/us/usc/t10/s5514/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fa%2F2%2FA","sourceRelease":"119-100","text":"engineering and manufacturing development (or its equivalent); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s5514/a/2/B","parentIdentifier":"/us/usc/t10/s5514/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fa%2F2%2FB","sourceRelease":"119-100","text":"production and deployment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s5514/a/3","parentIdentifier":"/us/usc/t10/s5514/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fa%2F3","sourceRelease":"119-100","text":"Except as provided by subsection (c), the Director may not adjust or revise an acquisition baseline established under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Elements of Baselines","label":"b .—Elements of Baselines","identifier":"/us/usc/t10/s5514/b","parentIdentifier":"/us/usc/t10/s5514","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s5514/b/1","parentIdentifier":"/us/usc/t10/s5514/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s5514/b/1/A","parentIdentifier":"/us/usc/t10/s5514/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F1%2FA","sourceRelease":"119-100","text":"research and development milestones;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s5514/b/1/B","parentIdentifier":"/us/usc/t10/s5514/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F1%2FB","sourceRelease":"119-100","text":"acquisition milestones, including design reviews and key decision points;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s5514/b/1/C","parentIdentifier":"/us/usc/t10/s5514/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F1%2FC","sourceRelease":"119-100","text":"key test events, including ground, flight, and cybersecurity tests and ballistic missile defense system tests;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s5514/b/1/D","parentIdentifier":"/us/usc/t10/s5514/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F1%2FD","sourceRelease":"119-100","text":"delivery and fielding schedules;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t10/s5514/b/1/E","parentIdentifier":"/us/usc/t10/s5514/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F1%2FE","sourceRelease":"119-100","text":"quantities of assets planned for acquisition and delivery in total and by fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t10/s5514/b/1/F","parentIdentifier":"/us/usc/t10/s5514/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F1%2FF","sourceRelease":"119-100","text":"planned contract award dates.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s5514/b/2","parentIdentifier":"/us/usc/t10/s5514/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s5514/b/2/A","parentIdentifier":"/us/usc/t10/s5514/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the capability to be developed, including hardware and software;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s5514/b/2/B","parentIdentifier":"/us/usc/t10/s5514/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F2%2FB","sourceRelease":"119-100","text":"system requirements, including performance requirements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s5514/b/2/C","parentIdentifier":"/us/usc/t10/s5514/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s5514/b/2/C/i","parentIdentifier":"/us/usc/t10/s5514/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F2%2FC%2Fi","sourceRelease":"119-100","text":"the missile defense warfighter involvement process, as governed by United States Strategic Command Instruction 538–03, or such successor document; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s5514/b/2/C/ii","parentIdentifier":"/us/usc/t10/s5514/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F2%2FC%2Fii","sourceRelease":"119-100","text":"processes and products reviewed by the Joint Chiefs of Staff or Joint Requirements Oversight Council;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s5514/b/2/D","parentIdentifier":"/us/usc/t10/s5514/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F2%2FD","sourceRelease":"119-100","text":"key knowledge points that must be achieved to permit continuation of the program and to inform production and deployment decisions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t10/s5514/b/2/E","parentIdentifier":"/us/usc/t10/s5514/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F2%2FE","sourceRelease":"119-100","text":"how the Director plans to improve the capability over time.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s5514/b/3","parentIdentifier":"/us/usc/t10/s5514/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s5514/b/3/A","parentIdentifier":"/us/usc/t10/s5514/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F3%2FA","sourceRelease":"119-100","text":"a life-cycle cost estimate that separately identifies the costs regarding research and development, procurement, military construction, operations and sustainment, and disposal;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s5514/b/3/B","parentIdentifier":"/us/usc/t10/s5514/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F3%2FB","sourceRelease":"119-100","text":"program acquisition unit costs for the program element;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s5514/b/3/C","parentIdentifier":"/us/usc/t10/s5514/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F3%2FC","sourceRelease":"119-100","text":"average procurement unit costs and program acquisition costs for the program element;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s5514/b/3/D","parentIdentifier":"/us/usc/t10/s5514/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F3%2FD","sourceRelease":"119-100","text":"an identification of when the document regarding the program joint cost analysis requirements description is scheduled to be approved; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t10/s5514/b/3/E","parentIdentifier":"/us/usc/t10/s5514/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F3%2FE","sourceRelease":"119-100","text":"an explanation for why a program joint cost analysis requirements description has not been prepared and approved, and, if a program joint cost analysis requirements description is not applicable, the rationale for such inapplicability.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s5514/b/4","parentIdentifier":"/us/usc/t10/s5514/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fb%2F4","sourceRelease":"119-100","text":"A test baseline summarizing the comprehensive test program for the program element or major subprogram outlined in the integrated master test plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Exception to Limitation on Revision","label":"c .—Exception to Limitation on Revision","identifier":"/us/usc/t10/s5514/c","parentIdentifier":"/us/usc/t10/s5514","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s5514/c/1","parentIdentifier":"/us/usc/t10/s5514/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fc%2F1","sourceRelease":"119-100","text":"a justification for such adjustment or revision;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s5514/c/2","parentIdentifier":"/us/usc/t10/s5514/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fc%2F2","sourceRelease":"119-100","text":"the specific adjustments or revisions made to the acquisition baseline, including to the elements described in subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s5514/c/3","parentIdentifier":"/us/usc/t10/s5514/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fc%2F3","sourceRelease":"119-100","text":"the effective date of the adjusted or revised acquisition baseline.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Operations and Sustainment Cost Estimates","label":"d .—Operations and Sustainment Cost Estimates","identifier":"/us/usc/t10/s5514/d","parentIdentifier":"/us/usc/t10/s5514","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s5514/d/1","parentIdentifier":"/us/usc/t10/s5514/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fd%2F1","sourceRelease":"119-100","text":"all of the operations and sustainment costs for which the Director is responsible;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s5514/d/2","parentIdentifier":"/us/usc/t10/s5514/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fd%2F2","sourceRelease":"119-100","text":"a description of the operations and sustainment functions and costs for which a military department is responsible;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s5514/d/3","parentIdentifier":"/us/usc/t10/s5514/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fd%2F3","sourceRelease":"119-100","text":"the amount of operations and sustainment costs (dollar value and base year) for which the military department or other element of the Department of Defense is responsible; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s5514/d/4","parentIdentifier":"/us/usc/t10/s5514/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fd%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s5514/d/4/A","parentIdentifier":"/us/usc/t10/s5514/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fd%2F4%2FA","sourceRelease":"119-100","text":"a citation to the source (such as a joint cost estimate or one or more military department estimates) that captures the operations and sustainment costs for which a military department or other element of the Department of Defense is responsible;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s5514/d/4/B","parentIdentifier":"/us/usc/t10/s5514/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fd%2F4%2FB","sourceRelease":"119-100","text":"the date the source was prepared; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s5514/d/4/C","parentIdentifier":"/us/usc/t10/s5514/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs5514%2Fd%2F4%2FC","sourceRelease":"119-100","text":"if and when the source was independently verified by the Office for Cost Assessment and Program Evaluation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
