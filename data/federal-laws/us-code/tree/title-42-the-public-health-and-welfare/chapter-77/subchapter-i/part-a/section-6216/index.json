{"type":"section","nativeType":"section","number":"6216","heading":"Annual Home Heating Readiness Reports","label":"6216 Annual Home Heating Readiness Reports","identifier":"/us/usc/t42/s6216","parentIdentifier":"/us/usc/t42/ch77/schI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s6216/a","parentIdentifier":"/us/usc/t42/s6216","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fa","sourceRelease":"119-100","text":"On or before September 1 of each year, the Secretary, acting through the Administrator of the Energy Information Agency, shall submit to Congress a Home Heating Readiness Report on the readiness of the natural gas, heating oil and propane industries to supply fuel under various weather conditions, including rapid decreases in temperature.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Contents","label":"b Contents","identifier":"/us/usc/t42/s6216/b","parentIdentifier":"/us/usc/t42/s6216","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s6216/b/1","parentIdentifier":"/us/usc/t42/s6216/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fb%2F1","sourceRelease":"119-100","text":"estimates of the consumption, expenditures, and average price per gallon of heating oil and propane and thousand cubic feet of natural gas for the upcoming period of October through March for various weather conditions, with special attention to extreme weather, and various regions of the country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s6216/b/2","parentIdentifier":"/us/usc/t42/s6216/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6216/b/2/A","parentIdentifier":"/us/usc/t42/s6216/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fb%2F2%2FA","sourceRelease":"119-100","text":"global and regional crude oil and refined product supplies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6216/b/2/B","parentIdentifier":"/us/usc/t42/s6216/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the adequacy and utilization of refinery capacity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s6216/b/2/C","parentIdentifier":"/us/usc/t42/s6216/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fb%2F2%2FC","sourceRelease":"119-100","text":"the adequacy, utilization, and distribution of regional refined product storage capacity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s6216/b/2/D","parentIdentifier":"/us/usc/t42/s6216/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fb%2F2%2FD","sourceRelease":"119-100","text":"weather conditions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s6216/b/2/E","parentIdentifier":"/us/usc/t42/s6216/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fb%2F2%2FE","sourceRelease":"119-100","text":"the refined product transportation system;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s6216/b/2/F","parentIdentifier":"/us/usc/t42/s6216/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fb%2F2%2FF","sourceRelease":"119-100","text":"market inefficiencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s6216/b/2/G","parentIdentifier":"/us/usc/t42/s6216/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fb%2F2%2FG","sourceRelease":"119-100","text":"any other factor affecting the functional capability of the heating oil industry and propane industry that has the potential to affect national or regional supplies and prices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s6216/b/3","parentIdentifier":"/us/usc/t42/s6216/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fb%2F3","sourceRelease":"119-100","text":"recommendations on steps that the Federal, State, and local governments can take to prevent or alleviate the impact of sharp and sustained increases in the price of natural gas, heating oil, and propane; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s6216/b/4","parentIdentifier":"/us/usc/t42/s6216/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fb%2F4","sourceRelease":"119-100","text":"recommendations on steps that companies engaged in the production, refining, storage, transportation of heating oil or propane, or any other activity related to the heating oil industry or propane industry, can take to prevent or alleviate the impact of sharp and sustained increases in the price of heating oil and propane.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Information requests","label":"c Information requests","identifier":"/us/usc/t42/s6216/c","parentIdentifier":"/us/usc/t42/s6216","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6216%2Fc","sourceRelease":"119-100","text":"The Secretary may request information necessary to prepare the Home Heating Readiness Report from companies described in subsection (b)(4).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
