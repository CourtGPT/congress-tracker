{"type":"section","nativeType":"section","number":"4907","heading":"Moratoria for species not covered by Convention","label":"4907 Moratoria for species not covered by Convention","identifier":"/us/usc/t16/s4907","parentIdentifier":"/us/usc/t16/ch69","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4907","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s4907/a","parentIdentifier":"/us/usc/t16/s4907","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4907%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s4907/a/1","parentIdentifier":"/us/usc/t16/s4907/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4907%2Fa%2F1","sourceRelease":"119-100","text":"review periodically the trade in species of exotic birds that are not listed in any Appendix to the Convention; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s4907/a/2","parentIdentifier":"/us/usc/t16/s4907/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4907%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s4907/a/2/A","parentIdentifier":"/us/usc/t16/s4907/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4907%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s4907/a/2/A/i","parentIdentifier":"/us/usc/t16/s4907/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4907%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the findings described in section 4905(c)(2), (3), and (4) of this title cannot be made with respect to the species; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s4907/a/2/A/ii","parentIdentifier":"/us/usc/t16/s4907/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4907%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the moratorium or quota is necessary for the conservation of the species or is otherwise consistent with the purpose of this chapter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s4907/a/2/B","parentIdentifier":"/us/usc/t16/s4907/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4907%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s4907/a/2/B/i","parentIdentifier":"/us/usc/t16/s4907/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4907%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the country has not developed and implemented a management program for exotic birds in trade generally, that ensures both the conservation and the humane treatment of exotic birds during capture, transport, and maintenance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s4907/a/2/B/ii","parentIdentifier":"/us/usc/t16/s4907/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4907%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the Secretary finds that the moratorium or quota is necessary for the conservation of the species or is otherwise consistent with the purpose of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Termination of quota or moratorium","label":"b Termination of quota or moratorium","identifier":"/us/usc/t16/s4907/b","parentIdentifier":"/us/usc/t16/s4907","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4907%2Fb","sourceRelease":"119-100","text":"The Secretary shall terminate a quota or moratorium established under subsection (a) if the Secretary finds that the reasons for establishing the quota or moratorium no longer exist.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
