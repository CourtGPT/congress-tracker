73/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fa%2F6%2FG","sourceRelease":"119-100","text":"hovercraft;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t16/s6873/a/6/H","parentIdentifier":"/us/usc/t16/s6873/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fa%2F6%2FH","sourceRelease":"119-100","text":"oversnow vehicles and other motorized vehicles on frozen bodies of water;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s6873/a/6/I","parentIdentifier":"/us/usc/t16/s6873/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fa%2F6%2FI","sourceRelease":"119-100","text":"oceangoing ships;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t16/s6873/a/6/J","parentIdentifier":"/us/usc/t16/s6873/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fa%2F6%2FJ","sourceRelease":"119-100","text":"swimming; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"K","heading":null,"label":"K","identifier":"/us/usc/t16/s6873/a/6/K","parentIdentifier":"/us/usc/t16/s6873/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fa%2F6%2FK","sourceRelease":"119-100","text":"other applicable recreational activities, as determined to be appropriate by the Secretaries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Federal waterway access and navigation information","label":"b Federal waterway access and navigation information","identifier":"/us/usc/t16/s6873/b","parentIdentifier":"/us/usc/t16/s6873","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s6873/b/1","parentIdentifier":"/us/usc/t16/s6873/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6873/b/1/A","parentIdentifier":"/us/usc/t16/s6873/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the location of boat ramps, portages, and fishing access sites under the authority of the Federal land or water management agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6873/b/1/B","parentIdentifier":"/us/usc/t16/s6873/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the identification of the dates on which the facilities and sites identified under subparagraph (A) are open or closed, as applicable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6873/b/2","parentIdentifier":"/us/usc/t16/s6873/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6873%2Fb%2F2","sourceRelease":"119-100","text":"bathymetric information and depth charts, as feasible.",