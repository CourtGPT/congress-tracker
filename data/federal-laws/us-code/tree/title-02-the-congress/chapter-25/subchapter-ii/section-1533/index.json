{"type":"section","nativeType":"section","number":"1533","heading":"Small government agency plan","label":"1533 Small government agency plan","identifier":"/us/usc/t2/s1533","parentIdentifier":"/us/usc/t2/ch25/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1533","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Effects on small governments","label":"a Effects on small governments","identifier":"/us/usc/t2/s1533/a","parentIdentifier":"/us/usc/t2/s1533","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1533%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s1533/a/1","parentIdentifier":"/us/usc/t2/s1533/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1533%2Fa%2F1","sourceRelease":"119-100","text":"provide notice of the requirements to potentially affected small governments, if any;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s1533/a/2","parentIdentifier":"/us/usc/t2/s1533/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1533%2Fa%2F2","sourceRelease":"119-100","text":"enable officials of affected small governments to provide meaningful and timely input in the development of regulatory proposals containing significant Federal intergovernmental mandates; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t2/s1533/a/3","parentIdentifier":"/us/usc/t2/s1533/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1533%2Fa%2F3","sourceRelease":"119-100","text":"inform, educate, and advise small governments on compliance with the requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Authorization of appropriations","label":"b Authorization of appropriations","identifier":"/us/usc/t2/s1533/b","parentIdentifier":"/us/usc/t2/s1533","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1533%2Fb","sourceRelease":"119-100","text":"There are authorized to be appropriated to each agency to carry out the provisions of this section and for no other purpose, such sums as are necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
