{"type":"section","nativeType":"section","number":"60551","heading":"Offender reentry research","label":"60551 Offender reentry research","identifier":"/us/usc/t34/s60551","parentIdentifier":"/us/usc/t34/stVI/ch605/schII/ptC/spt2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60551","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to , The Public Health and Welfare, prior to editorial reclassification and renumbering as this section.section 17551 of Title 42"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"National Institute of Justice","label":"a National Institute of Justice","identifier":"/us/usc/t34/s60551/a","parentIdentifier":"/us/usc/t34/s60551","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60551%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s60551/a/1","parentIdentifier":"/us/usc/t34/s60551/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60551%2Fa%2F1","sourceRelease":"119-100","text":"a study identifying the number and characteristics of minor children who have had a parent incarcerated, and the likelihood of such minor children becoming adversely involved in the criminal justice system some time in their lifetime;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s60551/a/2","parentIdentifier":"/us/usc/t34/s60551/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60551%2Fa%2F2","sourceRelease":"119-100","text":"a study identifying a mechanism to compare rates of recidivism (including rearrest, violations of parole, probation, post-incarceration supervision, and reincarceration) among States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s60551/a/3","parentIdentifier":"/us/usc/t34/s60551/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60551%2Fa%2F3","sourceRelease":"119-100","text":"a study on the population of offenders released from custody who do not engage in recidivism and the characteristics (housing, employment, treatment, family connection) of that population.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Bureau of Justice Statistics","label":"b Bureau of Justice Statistics","identifier":"/us/usc/t34/s60551/b","parentIdentifier":"/us/usc/t34/s60551","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60551%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s60551/b/1","parentIdentifier":"/us/usc/t34/s60551/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60551%2Fb%2F1","sourceRelease":"119-100","text":"an analysis of special populations (including prisoners with mental illness or substance abuse disorders, female offenders, juvenile offenders, offenders with limited English proficiency, and the elderly) that present unique reentry challenges;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s60551/b/2","parentIdentifier":"/us/usc/t34/s60551/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60551%2Fb%2F2","sourceRelease":"119-100","text":"studies to determine which offenders are returning to prison, jail, or a juvenile facility and which of those returning offenders represent the greatest risk to victims and community safety;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s60551/b/3","parentIdentifier":"/us/usc/t34/s60551/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60551%2Fb%2F3","sourceRelease":"119-100","text":"annual reports on the demographic characteristics of the population reentering society from prisons, jails, and juvenile facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t34/s60551/b/4","parentIdentifier":"/us/usc/t34/s60551/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60551%2Fb%2F4","sourceRelease":"119-100","text":"a national recidivism study every 3 years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t34/s60551/b/5","parentIdentifier":"/us/usc/t34/s60551/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60551%2Fb%2F5","sourceRelease":"119-100","text":"a study of parole, probation, or post-incarceration supervision violations and revocations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t34/s60551/b/6","parentIdentifier":"/us/usc/t34/s60551/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs60551%2Fb%2F6","sourceRelease":"119-100","text":"a study concerning the most appropriate measure to be used when reporting recidivism rates (whether rearrest, reincarceration, or any other valid, evidence-based measure).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
