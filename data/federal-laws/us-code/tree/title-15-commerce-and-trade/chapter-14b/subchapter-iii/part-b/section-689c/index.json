{"type":"section","nativeType":"section","number":"689c","heading":"Selection of New Markets Venture Capital companies","label":"689c Selection of New Markets Venture Capital companies","identifier":"/us/usc/t15/s689c","parentIdentifier":"/us/usc/t15/ch14B/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Eligibility","label":"a Eligibility","identifier":"/us/usc/t15/s689c/a","parentIdentifier":"/us/usc/t15/s689c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s689c/a/1","parentIdentifier":"/us/usc/t15/s689c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fa%2F1","sourceRelease":"119-100","text":"the company is a newly formed for-profit entity or a newly formed for-profit subsidiary of an existing entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s689c/a/2","parentIdentifier":"/us/usc/t15/s689c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fa%2F2","sourceRelease":"119-100","text":"the company has a management team with experience in community development financing or relevant venture capital financing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s689c/a/3","parentIdentifier":"/us/usc/t15/s689c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fa%2F3","sourceRelease":"119-100","text":"the company has a primary objective of economic development of low-income geographic areas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Application","label":"b Application","identifier":"/us/usc/t15/s689c/b","parentIdentifier":"/us/usc/t15/s689c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s689c/b/1","parentIdentifier":"/us/usc/t15/s689c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fb%2F1","sourceRelease":"119-100","text":"a business plan describing how the company intends to make successful developmental venture capital investments in identified low-income geographic areas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s689c/b/2","parentIdentifier":"/us/usc/t15/s689c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fb%2F2","sourceRelease":"119-100","text":"information regarding the community development finance or relevant venture capital qualifications and general reputation of the company’s management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s689c/b/3","parentIdentifier":"/us/usc/t15/s689c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fb%2F3","sourceRelease":"119-100","text":"a description of how the company intends to work with community organizations and to seek to address the unmet capital needs of the communities served;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s689c/b/4","parentIdentifier":"/us/usc/t15/s689c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fb%2F4","sourceRelease":"119-100","text":"a proposal describing how the company intends to use the grant funds provided under this part to provide operational assistance to smaller enterprises financed by the company, including information regarding whether the company intends to use licensed professionals, when necessary, on the company’s staff or from an outside entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s689c/b/5","parentIdentifier":"/us/usc/t15/s689c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fb%2F5","sourceRelease":"119-100","text":"with respect to binding commitments to be made to the company under this part, an estimate of the ratio of cash to in-kind contributions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s689c/b/6","parentIdentifier":"/us/usc/t15/s689c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fb%2F6","sourceRelease":"119-100","text":"a description of the criteria to be used to evaluate whether and to what extent the company meets the objectives of the program established under this part;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t15/s689c/b/7","parentIdentifier":"/us/usc/t15/s689c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fb%2F7","sourceRelease":"119-100","text":"information regarding the management and financial strength of any parent firm, affiliated firm, or any other firm essential to the success of the company’s business plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t15/s689c/b/8","parentIdentifier":"/us/usc/t15/s689c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fb%2F8","sourceRelease":"119-100","text":"such other information as the Administrator may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Conditional approval","label":"c Conditional approval","identifier":"/us/usc/t15/s689c/c","parentIdentifier":"/us/usc/t15/s689c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s689c/c/1","parentIdentifier":"/us/usc/t15/s689c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fc%2F1","sourceRelease":"119-100","text":"From among companies submitting applications under subsection (b), the Administrator shall, in accordance with this subsection, conditionally approval companies to participate in the New Markets Venture Capital Program.1So in original. Probably should be “approve”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Selection criteria","label":"2 Selection criteria","identifier":"/us/usc/t15/s689c/c/2","parentIdentifier":"/us/usc/t15/s689c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s689c/c/2/A","parentIdentifier":"/us/usc/t15/s689c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fc%2F2%2FA","sourceRelease":"119-100","text":"The likelihood that the company will meet the goal of its business plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s689c/c/2/B","parentIdentifier":"/us/usc/t15/s689c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fc%2F2%2FB","sourceRelease":"119-100","text":"The experience and background of the company’s management team.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s689c/c/2/C","parentIdentifier":"/us/usc/t15/s689c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fc%2F2%2FC","sourceRelease":"119-100","text":"The need for developmental venture capital investments in the geographic areas in which the company intends to invest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s689c/c/2/D","parentIdentifier":"/us/usc/t15/s689c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fc%2F2%2FD","sourceRelease":"119-100","text":"The extent to which the company will concentrate its activities on serving the geographic areas in which it intends to invest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s689c/c/2/E","parentIdentifier":"/us/usc/t15/s689c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fc%2F2%2FE","sourceRelease":"119-100","text":"The likelihood that the company will be able to satisfy the conditions under subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t15/s689c/c/2/F","parentIdentifier":"/us/usc/t15/s689c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fc%2F2%2FF","sourceRelease":"119-100","text":"The extent to which the activities proposed by the company will expand economic opportunities in the geographic areas in which the company intends to invest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t15/s689c/c/2/G","parentIdentifier":"/us/usc/t15/s689c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fc%2F2%2FG","sourceRelease":"119-100","text":"The strength of the company’s proposal to provide operational assistance under this part as the proposal relates to the ability of the applicant to meet applicable cash requirements and properly utilize in-kind contributions, including the use of resources for the services of licensed professionals, when necessary, whether provided by persons on the company’s staff or by persons outside of the company.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t15/s689c/c/2/H","parentIdentifier":"/us/usc/t15/s689c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fc%2F2%2FH","sourceRelease":"119-100","text":"Any other factors deemed appropriate by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Nationwide distribution","label":"3 Nationwide distribution","identifier":"/us/usc/t15/s689c/c/3","parentIdentifier":"/us/usc/t15/s689c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fc%2F3","sourceRelease":"119-100","text":"The Administrator shall select companies under paragraph (1) in such a way that promotes investment nationwide.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Requirements to be met for final approval","label":"d Requirements to be met for final approval","identifier":"/us/usc/t15/s689c/d","parentIdentifier":"/us/usc/t15/s689c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Capital requirement","label":"1 Capital requirement","identifier":"/us/usc/t15/s689c/d/1","parentIdentifier":"/us/usc/t15/s689c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F1","sourceRelease":"119-100","text":"Each conditionally approved company shall raise not less than $5,000,000 of private capital or binding capital commitments from one or more investors (other than agencies or departments of the Federal Government) who met criteria established by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Nonadministration resources for operational assistance","label":"2 Nonadministration resources for operational assistance","identifier":"/us/usc/t15/s689c/d/2","parentIdentifier":"/us/usc/t15/s689c/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s689c/d/2/A","parentIdentifier":"/us/usc/t15/s689c/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s689c/d/2/A/i","parentIdentifier":"/us/usc/t15/s689c/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s689c/d/2/A/i/I","parentIdentifier":"/us/usc/t15/s689c/d/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FA%2Fi%2FI","sourceRelease":"119-100","text":"from any sources other than the Small Business Administration that meet criteria established by the Administrator;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t15/s689c/d/2/A/i/II","parentIdentifier":"/us/usc/t15/s689c/d/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FA%2Fi%2FII","sourceRelease":"119-100","text":"payable or available over a multiyear period acceptable to the Administrator (not to exceed 10 years); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t15/s689c/d/2/A/i/III","parentIdentifier":"/us/usc/t15/s689c/d/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FA%2Fi%2FIII","sourceRelease":"119-100","text":"in an amount not less than 30 percent of the total amount of capital and commitments raised under paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s689c/d/2/A/ii","parentIdentifier":"/us/usc/t15/s689c/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t15/s689c/d/2/A/ii/I","parentIdentifier":"/us/usc/t15/s689c/d/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FA%2Fii%2FI","sourceRelease":"119-100","text":"from an insurance company acceptable to the Administrator;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t15/s689c/d/2/A/ii/II","parentIdentifier":"/us/usc/t15/s689c/d/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FA%2Fii%2FII","sourceRelease":"119-100","text":"using funds (other than the funds raised under paragraph (1)), from any source other than the Administrator; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t15/s689c/d/2/A/ii/III","parentIdentifier":"/us/usc/t15/s689c/d/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FA%2Fii%2FIII","sourceRelease":"119-100","text":"that yields cash payments over a multiyear period acceptable to the Administrator (not to exceed 10 years) in an amount not less than 30 percent of the total amount of capital and commitments raised under paragraph (1); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s689c/d/2/A/iii","parentIdentifier":"/us/usc/t15/s689c/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"shall have binding commitments (for contributions in cash or in kind) of the type described in clause (i) and shall have purchased an annuity of the type described in clause (ii), which in the aggregate make available, over a multiyear period acceptable to the Administrator (not to exceed 10 years), an amount not less than 30 percent of the total amount of capital and commitments raised under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Exception","label":"B Exception","identifier":"/us/usc/t15/s689c/d/2/B","parentIdentifier":"/us/usc/t15/s689c/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s689c/d/2/B/i","parentIdentifier":"/us/usc/t15/s689c/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FB%2Fi","sourceRelease":"119-100","text":"a viable plan that reasonably projects the capacity of the applicant to raise the amount (in cash or in-kind) required under subparagraph (A); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s689c/d/2/B/ii","parentIdentifier":"/us/usc/t15/s689c/d/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FB%2Fii","sourceRelease":"119-100","text":"binding commitments in an amount equal to not less than 20 percent of the total amount required under paragraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Limitation","label":"C Limitation","identifier":"/us/usc/t15/s689c/d/2/C","parentIdentifier":"/us/usc/t15/s689c/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fd%2F2%2FC","sourceRelease":"119-100","text":"In order to comply with the requirements of subparagraphs (A) and (B), the total amount of a company’s in-kind contributions may not exceed 50 percent of the company’s total contributions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Final approval; designation","label":"e Final approval; designation","identifier":"/us/usc/t15/s689c/e","parentIdentifier":"/us/usc/t15/s689c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s689c/e/1","parentIdentifier":"/us/usc/t15/s689c/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s689c/e/1/A","parentIdentifier":"/us/usc/t15/s689c/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fe%2F1%2FA","sourceRelease":"119-100","text":"satisfies the requirements of subsection (d) on or before the expiration of the time period described in that subsection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s689c/e/1/B","parentIdentifier":"/us/usc/t15/s689c/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fe%2F1%2FB","sourceRelease":"119-100","text":"enters into a participation agreement with the Administrator; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s689c/e/2","parentIdentifier":"/us/usc/t15/s689c/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs689c%2Fe%2F2","sourceRelease":"119-100","text":"if the applicant fails to satisfy the requirements of subsection (d) on or before the expiration of the time period described in that subsection, revoke the conditional approval granted under that subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
