{"type":"section","nativeType":"section","number":"12555","heading":"Scholarship assistance","label":"12555 Scholarship assistance","identifier":"/us/usc/t34/s12555","parentIdentifier":"/us/usc/t34/stI/ch121/schVII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to , The Public Health and Welfare, prior to editorial reclassification and renumbering as this section.section 14095 of Title 42","Amendments2002—Subsecs. (a)(2), (b)(2). substituted “$10,000” for “$7,500” in subpar. (A)(i), “$13,333” for “$10,000” in subpar. (B), and “$40,000” for “$30,000” in subpar. (C).Pub. L. 107–273"],"amendments":["Amendments2002—Subsecs. (a)(2), (b)(2). substituted “$10,000” for “$7,500” in subpar. (A)(i), “$13,333” for “$10,000” in subpar. (B), and “$40,000” for “$30,000” in subpar. (C).Pub. L. 107–273"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Scholarships authorized","label":"a Scholarships authorized","identifier":"/us/usc/t34/s12555/a","parentIdentifier":"/us/usc/t34/s12555","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s12555/a/1","parentIdentifier":"/us/usc/t34/s12555/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fa%2F1","sourceRelease":"119-100","text":"The Director may award scholarships to participants who agree to work in a State or local police force in accordance with agreements entered into pursuant to subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s12555/a/2","parentIdentifier":"/us/usc/t34/s12555/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s12555/a/2/A","parentIdentifier":"/us/usc/t34/s12555/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s12555/a/2/A/i","parentIdentifier":"/us/usc/t34/s12555/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"$10,000; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s12555/a/2/A/ii","parentIdentifier":"/us/usc/t34/s12555/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the cost of the educational expenses related to attending an institution of higher education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s12555/a/2/B","parentIdentifier":"/us/usc/t34/s12555/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fa%2F2%2FB","sourceRelease":"119-100","text":"In the case of a participant who is pursuing a course of educational study during substantially an entire calendar year, the amount of scholarship payments made during such year shall not exceed $13,333.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s12555/a/2/C","parentIdentifier":"/us/usc/t34/s12555/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fa%2F2%2FC","sourceRelease":"119-100","text":"The total amount of scholarship assistance received by any one student under this section shall not exceed $40,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s12555/a/3","parentIdentifier":"/us/usc/t34/s12555/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fa%2F3","sourceRelease":"119-100","text":"Recipients of scholarship assistance under this section shall continue to receive such scholarship payments only during such periods as the Director finds that the recipient is maintaining satisfactory progress as determined by the institution of higher education the recipient is attending.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t34/s12555/a/4","parentIdentifier":"/us/usc/t34/s12555/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s12555/a/4/A","parentIdentifier":"/us/usc/t34/s12555/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fa%2F4%2FA","sourceRelease":"119-100","text":"The Director shall make scholarship payments under this section directly to the institution of higher education that the student is attending.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s12555/a/4/B","parentIdentifier":"/us/usc/t34/s12555/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fa%2F4%2FB","sourceRelease":"119-100","text":"Each institution of higher education receiving a payment on behalf of a participant pursuant to subparagraph (A) shall remit to such student any funds in excess of the costs of tuition, fees, and room and board payable to the institution.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Reimbursement authorized","label":"b Reimbursement authorized","identifier":"/us/usc/t34/s12555/b","parentIdentifier":"/us/usc/t34/s12555","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s12555/b/1","parentIdentifier":"/us/usc/t34/s12555/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fb%2F1","sourceRelease":"119-100","text":"The Director may make payments to a participant to reimburse such participant for the costs of educational expenses if the student agrees to work in a State or local police force in accordance with the agreement entered into pursuant to subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s12555/b/2","parentIdentifier":"/us/usc/t34/s12555/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s12555/b/2/A","parentIdentifier":"/us/usc/t34/s12555/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s12555/b/2/A/i","parentIdentifier":"/us/usc/t34/s12555/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"$10,000; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s12555/b/2/A/ii","parentIdentifier":"/us/usc/t34/s12555/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the cost of educational expenses related to attending an institution of higher education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s12555/b/2/B","parentIdentifier":"/us/usc/t34/s12555/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fb%2F2%2FB","sourceRelease":"119-100","text":"In the case of a participant who is pursuing a course of educational study during substantially an entire calendar year, the amount of scholarship payments made during such year shall not exceed $13,333.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s12555/b/2/C","parentIdentifier":"/us/usc/t34/s12555/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fb%2F2%2FC","sourceRelease":"119-100","text":"The total amount of payments made pursuant to subparagraph (A) to any 1 student shall not exceed $40,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Use of scholarship","label":"c Use of scholarship","identifier":"/us/usc/t34/s12555/c","parentIdentifier":"/us/usc/t34/s12555","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s12555/c/1","parentIdentifier":"/us/usc/t34/s12555/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fc%2F1","sourceRelease":"119-100","text":"scholarships may be used for graduate and professional study; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s12555/c/2","parentIdentifier":"/us/usc/t34/s12555/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fc%2F2","sourceRelease":"119-100","text":"if a participant has enrolled in the program upon or after transfer to a 4-year institution of higher education, the Director may reimburse the participant for the participant’s prior educational expenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Agreement","label":"d Agreement","identifier":"/us/usc/t34/s12555/d","parentIdentifier":"/us/usc/t34/s12555","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s12555/d/1","parentIdentifier":"/us/usc/t34/s12555/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s12555/d/1/A","parentIdentifier":"/us/usc/t34/s12555/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F1%2FA","sourceRelease":"119-100","text":"Each participant receiving a scholarship or a payment under this section shall enter into an agreement with the Director.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s12555/d/1/B","parentIdentifier":"/us/usc/t34/s12555/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s12555/d/1/B/i","parentIdentifier":"/us/usc/t34/s12555/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F1%2FB%2Fi","sourceRelease":"119-100","text":"after successful completion of a baccalaureate program and training as prescribed in , work for 4 years in a State or local police force without there having arisen sufficient cause for the participant’s dismissal under the rules applicable to members of the police force of which the participant is a member;section 12557 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s12555/d/1/B/ii","parentIdentifier":"/us/usc/t34/s12555/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F1%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t34/s12555/d/1/B/ii/I","parentIdentifier":"/us/usc/t34/s12555/d/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F1%2FB%2Fii%2FI","sourceRelease":"119-100","text":"an educational course of study and receipt of a baccalaureate degree (in the case of undergraduate study) or the reward of credit to the participant for having completed one or more graduate courses (in the case of graduate study); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t34/s12555/d/1/B/ii/II","parentIdentifier":"/us/usc/t34/s12555/d/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F1%2FB%2Fii%2FII","sourceRelease":"119-100","text":"Police Corps training and certification by the Director that the participant has met such performance standards as may be established pursuant to ; andsection 12557 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s12555/d/1/B/iii","parentIdentifier":"/us/usc/t34/s12555/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"repay all of the scholarship or payment received plus interest at the rate of 10 percent if the conditions of clauses (i) and (ii) are not complied with.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s12555/d/2","parentIdentifier":"/us/usc/t34/s12555/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s12555/d/2/A","parentIdentifier":"/us/usc/t34/s12555/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s12555/d/2/A/i","parentIdentifier":"/us/usc/t34/s12555/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F2%2FA%2Fi","sourceRelease":"119-100","text":"dies; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s12555/d/2/A/ii","parentIdentifier":"/us/usc/t34/s12555/d/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F2%2FA%2Fii","sourceRelease":"119-100","text":"becomes permanently and totally disabled as established by the sworn affidavit of a qualified physician.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s12555/d/2/B","parentIdentifier":"/us/usc/t34/s12555/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F2%2FB","sourceRelease":"119-100","text":"If a scholarship recipient is unable to comply with the repayment provision set forth in paragraph (1)(B)(ii) because of a physical or emotional disability or for good cause as determined by the Director, the Director may substitute community service in a form prescribed by the Director for the required repayment.2So in original. Probably should be paragraph “(1)(B)(iii)”.2","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s12555/d/2/C","parentIdentifier":"/us/usc/t34/s12555/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fd%2F2%2FC","sourceRelease":"119-100","text":"The Director shall expeditiously seek repayment from a participant who violates an agreement described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Dependent child","label":"e Dependent child","identifier":"/us/usc/t34/s12555/e","parentIdentifier":"/us/usc/t34/s12555","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s12555/e/1","parentIdentifier":"/us/usc/t34/s12555/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fe%2F1","sourceRelease":"119-100","text":"who is a member of a State or local police force or is a Federal criminal investigator or uniformed police officer,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s12555/e/2","parentIdentifier":"/us/usc/t34/s12555/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fe%2F2","sourceRelease":"119-100","text":"who is not a participant in the Police Corps program, but","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s12555/e/3","parentIdentifier":"/us/usc/t34/s12555/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fe%2F3","sourceRelease":"119-100","text":"who serves in a State for which the Director has approved a Police Corps plan, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t34/s12555/e/4","parentIdentifier":"/us/usc/t34/s12555/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Fe%2F4","sourceRelease":"119-100","text":"who is killed in the course of performing police duties,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Application","label":"f Application","identifier":"/us/usc/t34/s12555/f","parentIdentifier":"/us/usc/t34/s12555","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12555%2Ff","sourceRelease":"119-100","text":"Each participant desiring a scholarship or payment under this section shall submit an application as prescribed by the Director in such manner and accompanied by such information as the Director may reasonably require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
