{"type":"section","nativeType":"section","number":"10505","heading":"Designation of embassy anti-corruption points of contact","label":"10505 Designation of embassy anti-corruption points of contact","identifier":"/us/usc/t22/s10505","parentIdentifier":"/us/usc/t22/ch112","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10505","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s10505/a","parentIdentifier":"/us/usc/t22/s10505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10505%2Fa","sourceRelease":"119-100","text":"The Secretary of State shall annually designate an anti-corruption point of contact at the United States diplomatic post to each country identified pursuant to , or which the Secretary otherwise determines is in need of such a point of contact. The point of contact shall be the chief of mission or the chief of mission’s designee.section 10502(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Responsibilities","label":"b Responsibilities","identifier":"/us/usc/t22/s10505/b","parentIdentifier":"/us/usc/t22/s10505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10505%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10505/b/1","parentIdentifier":"/us/usc/t22/s10505/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10505%2Fb%2F1","sourceRelease":"119-100","text":"promote good governance in foreign countries; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10505/b/2","parentIdentifier":"/us/usc/t22/s10505/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10505%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10505/b/2/A","parentIdentifier":"/us/usc/t22/s10505/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10505%2Fb%2F2%2FA","sourceRelease":"119-100","text":"to combat public corruption; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10505/b/2/B","parentIdentifier":"/us/usc/t22/s10505/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10505%2Fb%2F2%2FB","sourceRelease":"119-100","text":"to develop and implement corruption risk assessment tools and mitigation strategies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Training","label":"c Training","identifier":"/us/usc/t22/s10505/c","parentIdentifier":"/us/usc/t22/s10505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10505%2Fc","sourceRelease":"119-100","text":"The Secretary of State shall implement appropriate training for anti-corruption points of contact designated under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
