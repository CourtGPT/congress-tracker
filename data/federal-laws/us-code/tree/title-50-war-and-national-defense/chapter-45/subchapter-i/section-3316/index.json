req=%2Fus%2Fusc%2Ft50%2Fs3316%2Fb%2F1","sourceRelease":"119-100","text":"Not later than 180 days after , the Director of National Intelligence shall submit to the congressional intelligence committees using the electronic repository all nonpublicly available policies issued by the Director of National Intelligence for the intelligence community that are in effect as of the date of the submission.December 20, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Continuous updates","label":"2 Continuous updates","identifier":"/us/usc/t50/s3316/b/2","parentIdentifier":"/us/usc/t50/s3316/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3316%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3316/b/2/A","parentIdentifier":"/us/usc/t50/s3316/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3316%2Fb%2F2%2FA","sourceRelease":"119-100","text":"notify the congressional intelligence committees of such addition, modification, or removal; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3316/b/2/B","parentIdentifier":"/us/usc/t50/s3316/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3316%2Fb%2F2%2FB","sourceRelease":"119-100","text":"update the electronic repository with respect to such addition, modification, or removal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
