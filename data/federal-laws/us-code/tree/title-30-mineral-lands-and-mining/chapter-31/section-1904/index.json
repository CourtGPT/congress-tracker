{"type":"section","nativeType":"section","number":"1904","heading":"Marine mineral research centers","label":"1904 Marine mineral research centers","identifier":"/us/usc/t30/s1904","parentIdentifier":"/us/usc/t30/ch31","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t30/s1904/a","parentIdentifier":"/us/usc/t30/s1904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fa","sourceRelease":"119-100","text":"No later than 90 days after , the Secretary shall designate 3 centers for marine mineral research and related activities.October 19, 1996","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Concentration","label":"b Concentration","identifier":"/us/usc/t30/s1904/b","parentIdentifier":"/us/usc/t30/s1904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fb","sourceRelease":"119-100","text":"One center shall concentrate primarily on research in the continental shelf regions of the United States, 1 center shall concentrate primarily on research in deep seabed and near-shore environments of islands, and 1 center shall concentrate primarily on research in arctic and cold water regions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Criteria","label":"c Criteria","identifier":"/us/usc/t30/s1904/c","parentIdentifier":"/us/usc/t30/s1904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t30/s1904/c/1","parentIdentifier":"/us/usc/t30/s1904/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fc%2F1","sourceRelease":"119-100","text":"administers a federally funded center for marine minerals research;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t30/s1904/c/2","parentIdentifier":"/us/usc/t30/s1904/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fc%2F2","sourceRelease":"119-100","text":"matriculates students for advanced degrees in marine geological sciences, nonenergy natural resources, and related fields of science and engineering;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t30/s1904/c/3","parentIdentifier":"/us/usc/t30/s1904/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fc%2F3","sourceRelease":"119-100","text":"is a United States university with established programs and facilities that primarily focus on marine mineral resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t30/s1904/c/4","parentIdentifier":"/us/usc/t30/s1904/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fc%2F4","sourceRelease":"119-100","text":"has engaged in collaboration and cooperation with industry, governmental agencies, and other universities in the field of marine mineral resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t30/s1904/c/5","parentIdentifier":"/us/usc/t30/s1904/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t30/s1904/c/5/A","parentIdentifier":"/us/usc/t30/s1904/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fc%2F5%2FA","sourceRelease":"119-100","text":"seabed exploration systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t30/s1904/c/5/B","parentIdentifier":"/us/usc/t30/s1904/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fc%2F5%2FB","sourceRelease":"119-100","text":"marine mining systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t30/s1904/c/5/C","parentIdentifier":"/us/usc/t30/s1904/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fc%2F5%2FC","sourceRelease":"119-100","text":"marine mineral processing systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t30/s1904/c/6","parentIdentifier":"/us/usc/t30/s1904/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fc%2F6","sourceRelease":"119-100","text":"has been designated by the Secretary as a State Mining and Mineral Resources Research Institute.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Center activities","label":"d Center activities","identifier":"/us/usc/t30/s1904/d","parentIdentifier":"/us/usc/t30/s1904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t30/s1904/d/1","parentIdentifier":"/us/usc/t30/s1904/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fd%2F1","sourceRelease":"119-100","text":"provide technical assistance to the Secretary concerning marine mineral resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t30/s1904/d/2","parentIdentifier":"/us/usc/t30/s1904/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fd%2F2","sourceRelease":"119-100","text":"advise the Secretary on pertinent international activities in marine mineral resources development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t30/s1904/d/3","parentIdentifier":"/us/usc/t30/s1904/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fd%2F3","sourceRelease":"119-100","text":"engage in research, training, and education transfer associated with the characterization and utilization of marine mineral resources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t30/s1904/d/4","parentIdentifier":"/us/usc/t30/s1904/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fd%2F4","sourceRelease":"119-100","text":"promote the efficient identification, assessment, exploration, and management of marine mineral resources in an environmentally sound manner.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Allocation of funds","label":"e Allocation of funds","identifier":"/us/usc/t30/s1904/e","parentIdentifier":"/us/usc/t30/s1904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Fe","sourceRelease":"119-100","text":"In distributing funds to the centers designated under subsection (a), the Secretary shall, to the extent practicable, allocate an equal amount to each center.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Limitations","label":"f Limitations","identifier":"/us/usc/t30/s1904/f","parentIdentifier":"/us/usc/t30/s1904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Administrative expenses","label":"1 Administrative expenses","identifier":"/us/usc/t30/s1904/f/1","parentIdentifier":"/us/usc/t30/s1904/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Ff%2F1","sourceRelease":"119-100","text":"Not more than 5 percent of the amount made available to carry out this section during a fiscal year may be used by the Secretary for expenses associated with administration of the program authorized by this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Construction costs","label":"2 Construction costs","identifier":"/us/usc/t30/s1904/f/2","parentIdentifier":"/us/usc/t30/s1904/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1904%2Ff%2F2","sourceRelease":"119-100","text":"None of the funds made available under this section may be used for the construction of a new building or the acquisition, expansion, remodeling, or alteration of an existing building (including site grading and improvement and architect fees).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
