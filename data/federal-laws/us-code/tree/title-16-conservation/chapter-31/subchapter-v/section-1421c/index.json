{"type":"section","nativeType":"section","number":"1421c","heading":"Unusual mortality event response","label":"1421c Unusual mortality event response","identifier":"/us/usc/t16/s1421c","parentIdentifier":"/us/usc/t16/ch31/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2022—Subsec. (a)(1)(B). substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 App. U.S.C.)”.Pub. L. 117–286"],"amendments":["Amendments2022—Subsec. (a)(1)(B). substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 App. U.S.C.)”.Pub. L. 117–286"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Response","label":"a Response","identifier":"/us/usc/t16/s1421c/a","parentIdentifier":"/us/usc/t16/s1421c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Working group","label":"1 Working group","identifier":"/us/usc/t16/s1421c/a/1","parentIdentifier":"/us/usc/t16/s1421c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1421c/a/1/A","parentIdentifier":"/us/usc/t16/s1421c/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s1421c/a/1/A/i","parentIdentifier":"/us/usc/t16/s1421c/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"determining whether an unusual mortality event is occurring;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s1421c/a/1/A/ii","parentIdentifier":"/us/usc/t16/s1421c/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"determining, after an unusual mortality event has begun, if response actions with respect to that event are no longer necessary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s1421c/a/1/A/iii","parentIdentifier":"/us/usc/t16/s1421c/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fa%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"developing the contingency plan in accordance with subsection (b), to assist the Secretary in responding to unusual mortality events.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1421c/a/1/B","parentIdentifier":"/us/usc/t16/s1421c/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fa%2F1%2FB","sourceRelease":"119-100","text":"Chapter 10 of title 5 shall not apply to the marine mammal unusual mortality event working group established under this paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Response timing","label":"2 Response timing","identifier":"/us/usc/t16/s1421c/a/2","parentIdentifier":"/us/usc/t16/s1421c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1421c/a/2/A","parentIdentifier":"/us/usc/t16/s1421c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fa%2F2%2FA","sourceRelease":"119-100","text":"within 24 hours after receiving notification from a stranding network participant that an unusual mortality event might be occurring, contact as many members as is possible of the unusual mortality event working group for guidance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1421c/a/2/B","parentIdentifier":"/us/usc/t16/s1421c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s1421c/a/2/B/i","parentIdentifier":"/us/usc/t16/s1421c/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"make a determination as to whether an unusual mortality event is occurring;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s1421c/a/2/B/ii","parentIdentifier":"/us/usc/t16/s1421c/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"inform the stranding network participant of that determination; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s1421c/a/2/B/iii","parentIdentifier":"/us/usc/t16/s1421c/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fa%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"if the Secretary has determined an unusual mortality event is occurring, designate an Onsite Coordinator for the event, in accordance with subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Contingency plan","label":"b Contingency plan","identifier":"/us/usc/t16/s1421c/b","parentIdentifier":"/us/usc/t16/s1421c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s1421c/b/1","parentIdentifier":"/us/usc/t16/s1421c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall, in consultation with the Secretary of the Interior and the unusual mortality event working group, and after an opportunity for public review and comment, issue a detailed contingency plan for responding to any unusual mortality event.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t16/s1421c/b/2","parentIdentifier":"/us/usc/t16/s1421c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1421c/b/2/A","parentIdentifier":"/us/usc/t16/s1421c/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fb%2F2%2FA","sourceRelease":"119-100","text":"a list of persons, including stranding network participants, at a regional, State, and local level, who can assist the Secretary in implementing a coordinated and effective response to an unusual mortality event;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1421c/b/2/B","parentIdentifier":"/us/usc/t16/s1421c/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the types of marine mammal tissues and analyses necessary to assist in diagnosing causes of unusual mortality events;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s1421c/b/2/C","parentIdentifier":"/us/usc/t16/s1421c/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fb%2F2%2FC","sourceRelease":"119-100","text":"training, mobilization, and utilization procedures for available personnel, facilities, and other resources necessary to conduct a rapid and effective response to unusual mortality events; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s1421c/b/2/D","parentIdentifier":"/us/usc/t16/s1421c/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fb%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s1421c/b/2/D/i","parentIdentifier":"/us/usc/t16/s1421c/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fb%2F2%2FD%2Fi","sourceRelease":"119-100","text":"minimize death of marine mammals in the wild and provide appropriate care of marine mammals during an unusual mortality event;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s1421c/b/2/D/ii","parentIdentifier":"/us/usc/t16/s1421c/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fb%2F2%2FD%2Fii","sourceRelease":"119-100","text":"assist in identifying the cause or causes of an unusual mortality event;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s1421c/b/2/D/iii","parentIdentifier":"/us/usc/t16/s1421c/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fb%2F2%2FD%2Fiii","sourceRelease":"119-100","text":"determine the effects of an unusual mortality event on the size estimates of the affected populations of marine mammals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s1421c/b/2/D/iv","parentIdentifier":"/us/usc/t16/s1421c/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fb%2F2%2FD%2Fiv","sourceRelease":"119-100","text":"identify any roles played in an unusual mortality event by physical, chemical, and biological factors, including contaminants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Onsite coordinators","label":"c Onsite coordinators","identifier":"/us/usc/t16/s1421c/c","parentIdentifier":"/us/usc/t16/s1421c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Designation","label":"1 Designation","identifier":"/us/usc/t16/s1421c/c/1","parentIdentifier":"/us/usc/t16/s1421c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1421c/c/1/A","parentIdentifier":"/us/usc/t16/s1421c/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fc%2F1%2FA","sourceRelease":"119-100","text":"The Secretary shall, in consultation with the Secretary of the Interior, designate one or more Onsite Coordinators for an unusual mortality event, who shall make immediate recommendations to the stranding network participants on how to proceed with response activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1421c/c/1/B","parentIdentifier":"/us/usc/t16/s1421c/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fc%2F1%2FB","sourceRelease":"119-100","text":"An Onsite Coordinator so designated shall be one or more appropriate Regional Directors of the National Marine Fisheries Service or the United States Fish and Wildlife Service, or their designees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s1421c/c/1/C","parentIdentifier":"/us/usc/t16/s1421c/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fc%2F1%2FC","sourceRelease":"119-100","text":"If, because of the wide geographic distribution, multiple species of marine mammals involved, or magnitude of an unusual mortality event, more than one Onsite Coordinator is designated, the Secretary shall, in consultation with the Secretary of the Interior, designate which of the Onsite Coordinators shall have primary responsibility with respect to the event.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Functions","label":"2 Functions","identifier":"/us/usc/t16/s1421c/c/2","parentIdentifier":"/us/usc/t16/s1421c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1421c/c/2/A","parentIdentifier":"/us/usc/t16/s1421c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s1421c/c/2/A/i","parentIdentifier":"/us/usc/t16/s1421c/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"with respect to any matter that is not covered by the contingency plan, an Onsite Coordinator shall use his or her best professional judgment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s1421c/c/2/A/ii","parentIdentifier":"/us/usc/t16/s1421c/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the contingency plan may be temporarily modified by an Onsite Coordinator, consulting as expeditiously as possible with the Secretary, the Secretary of the Interior, and the unusual mortality event working group.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1421c/c/2/B","parentIdentifier":"/us/usc/t16/s1421c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421c%2Fc%2F2%2FB","sourceRelease":"119-100","text":"An Onsite Coordinator may delegate to any qualified person authority to act as an Onsite Coordinator under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
