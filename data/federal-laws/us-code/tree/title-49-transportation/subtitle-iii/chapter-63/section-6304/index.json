{"type":"section","nativeType":"section","number":"6304","heading":"National Transportation Library","label":"6304 National Transportation Library","identifier":"/us/usc/t49/s6304","parentIdentifier":"/us/usc/t49/stIII/ch63","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Change of Name“Office of the Assistant Secretary for Research and Technology of the Department of Transportation’s” substituted for “Research and Innovative Technology Administration’s” in subsec. (c)(3) on authority of title I of div. L of , set out in part as a Transfer of Duties and Powers note under former .Pub. L. 113–76section 112 of this title","Effective DateSection effective , see , set out as an Effective and Termination Dates of 2012 Amendment note under , Highways.Oct. 1, 2012section 3(a) of Pub. L. 112–141section 101 of Title 23"],"amendments":["Effective DateSection effective , see , set out as an Effective and Termination Dates of 2012 Amendment note under , Highways.Oct. 1, 2012section 3(a) of Pub. L. 112–141section 101 of Title 23"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Purpose and Establishment","label":"a .—Purpose and Establishment","identifier":"/us/usc/t49/s6304/a","parentIdentifier":"/us/usc/t49/s6304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s6304/a/1","parentIdentifier":"/us/usc/t49/s6304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa%2F1","sourceRelease":"119-100","text":"be headed by an individual who is highly qualified in library and information science;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s6304/a/2","parentIdentifier":"/us/usc/t49/s6304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa%2F2","sourceRelease":"119-100","text":"acquire, preserve, and manage transportation information and information products and services for use by the Department, other Federal agencies, and the general public;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s6304/a/3","parentIdentifier":"/us/usc/t49/s6304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa%2F3","sourceRelease":"119-100","text":"provide reference and research assistance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s6304/a/4","parentIdentifier":"/us/usc/t49/s6304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa%2F4","sourceRelease":"119-100","text":"serve as a central depository for research results and technical publications of the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t49/s6304/a/5","parentIdentifier":"/us/usc/t49/s6304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa%2F5","sourceRelease":"119-100","text":"provide a central clearinghouse for transportation data and information of the Federal Government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t49/s6304/a/6","parentIdentifier":"/us/usc/t49/s6304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa%2F6","sourceRelease":"119-100","text":"serve as coordinator and policy lead for transportation information access;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t49/s6304/a/7","parentIdentifier":"/us/usc/t49/s6304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s6304/a/7/A","parentIdentifier":"/us/usc/t49/s6304/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa%2F7%2FA","sourceRelease":"119-100","text":"the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s6304/a/7/B","parentIdentifier":"/us/usc/t49/s6304/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa%2F7%2FB","sourceRelease":"119-100","text":"other Federal agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s6304/a/7/C","parentIdentifier":"/us/usc/t49/s6304/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa%2F7%2FC","sourceRelease":"119-100","text":"public and private organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t49/s6304/a/7/D","parentIdentifier":"/us/usc/t49/s6304/a/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa%2F7%2FD","sourceRelease":"119-100","text":"individuals, within the United States and internationally;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t49/s6304/a/8","parentIdentifier":"/us/usc/t49/s6304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa%2F8","sourceRelease":"119-100","text":"coordinate efforts among, and cooperate with, transportation libraries, information providers, and technical assistance centers, in conjunction with private industry and other transportation library and information centers, with the goal of developing a comprehensive transportation information and knowledge network that supports the activities described in section 6302(b)(3)(B)(vi); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t49/s6304/a/9","parentIdentifier":"/us/usc/t49/s6304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fa%2F9","sourceRelease":"119-100","text":"engage in such other activities as the Director determines to be necessary and as the resources of the Library permit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Access","label":"b .—Access","identifier":"/us/usc/t49/s6304/b","parentIdentifier":"/us/usc/t49/s6304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fb","sourceRelease":"119-100","text":"The Director shall publicize, facilitate, and promote access to the information products and services described in subsection (a), to improve the ability of the transportation community to share information and the ability of the Director to make statistics and other information readily accessible as required under section 6302(b)(3)(B)(x).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Agreements.—","label":"c Agreements.—","identifier":"/us/usc/t49/s6304/c","parentIdentifier":"/us/usc/t49/s6304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s6304/c/1","parentIdentifier":"/us/usc/t49/s6304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s6304/c/1/A","parentIdentifier":"/us/usc/t49/s6304/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fc%2F1%2FA","sourceRelease":"119-100","text":"State or local government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s6304/c/1/B","parentIdentifier":"/us/usc/t49/s6304/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fc%2F1%2FB","sourceRelease":"119-100","text":"organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s6304/c/1/C","parentIdentifier":"/us/usc/t49/s6304/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fc%2F1%2FC","sourceRelease":"119-100","text":"business; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t49/s6304/c/1/D","parentIdentifier":"/us/usc/t49/s6304/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fc%2F1%2FD","sourceRelease":"119-100","text":"individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Contracts, grants, and agreements","label":"2 .—Contracts, grants, and agreements","identifier":"/us/usc/t49/s6304/c/2","parentIdentifier":"/us/usc/t49/s6304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fc%2F2","sourceRelease":"119-100","text":"The Library may initiate and support specific information and data management, access, and exchange activities in connection with matters relating to the Department’s strategic goals, knowledge networking, and national and international cooperation, by entering into contracts or other agreements or awarding grants for the conduct of such activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Amounts","label":"3 .—Amounts","identifier":"/us/usc/t49/s6304/c/3","parentIdentifier":"/us/usc/t49/s6304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs6304%2Fc%2F3","sourceRelease":"119-100","text":"Any amounts received by the Library as payment for library products and services or other activities shall be made available to the Director to carry out this section, deposited in the Office of the Assistant Secretary for Research and Technology of the Department of Transportation’s general fund account, and remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
