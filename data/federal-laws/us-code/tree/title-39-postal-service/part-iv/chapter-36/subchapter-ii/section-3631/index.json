/s3631/a/4","parentIdentifier":"/us/usc/t39/s3631/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3631%2Fa%2F4","sourceRelease":"119-100","text":"bulk international mail; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t39/s3631/a/5","parentIdentifier":"/us/usc/t39/s3631/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3631%2Fa%2F5","sourceRelease":"119-100","text":"mailgrams;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Definition","label":"b .—Definition","identifier":"/us/usc/t39/s3631/b","parentIdentifier":"/us/usc/t39/s3631","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3631%2Fb","sourceRelease":"119-100","text":"For purposes of this subchapter, the term “costs attributable”, as used with respect to a product, means the direct and indirect postal costs attributable to such product through reliably identified causal relationships.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Rule of Construction","label":"c .—Rule of Construction","identifier":"/us/usc/t39/s3631/c","parentIdentifier":"/us/usc/t39/s3631","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3631%2Fc","sourceRelease":"119-100","text":"Mail matter referred to in subsection (a) shall, for purposes of this subchapter, be considered to have the meaning given to such mail matter under the mail classification schedule.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
