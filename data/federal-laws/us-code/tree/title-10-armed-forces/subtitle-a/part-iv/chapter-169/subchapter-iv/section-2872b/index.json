{"type":"section","nativeType":"section","number":"2872b","heading":"Treatment of breach of contract","label":"2872b Treatment of breach of contract","identifier":"/us/usc/t10/s2872b","parentIdentifier":"/us/usc/t10/stA/ptIV/ch169/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2872b","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Response to Material Breach","label":"a .—Response to Material Breach","identifier":"/us/usc/t10/s2872b/a","parentIdentifier":"/us/usc/t10/s2872b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2872b%2Fa","sourceRelease":"119-100","text":"In the case of a material breach of contract under this subchapter by a party to the contract, the Secretary concerned shall use the authorities available to the Secretary, including withholding amounts to be paid under the contract, to encourage the party to cure the breach.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Rescinding of Contract","label":"b .—Rescinding of Contract","identifier":"/us/usc/t10/s2872b/b","parentIdentifier":"/us/usc/t10/s2872b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2872b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2872b/b/1","parentIdentifier":"/us/usc/t10/s2872b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2872b%2Fb%2F1","sourceRelease":"119-100","text":"rescind the contract pursuant to the terms of the contract; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2872b/b/2","parentIdentifier":"/us/usc/t10/s2872b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2872b%2Fb%2F2","sourceRelease":"119-100","text":"prohibit the offending party from entering into a new contract or undertaking expansions of other existing contracts, or both, with the Secretary under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
