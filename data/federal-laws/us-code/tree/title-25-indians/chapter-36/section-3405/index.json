{"type":"section","nativeType":"section","number":"3405","heading":"Plan requirements","label":"3405 Plan requirements","identifier":"/us/usc/t25/s3405","parentIdentifier":"/us/usc/t25/ch36","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3405","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2017— amended section generally. Prior to amendment, section related to plan requirements, consisting of eight pars.Pub. L. 115–93"],"amendments":["Amendments2017— amended section generally. Prior to amendment, section related to plan requirements, consisting of eight pars.Pub. L. 115–93"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s3405/1","parentIdentifier":"/us/usc/t25/s3405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3405%2F1","sourceRelease":"119-100","text":"identify the programs to be integrated and consolidated;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s3405/2","parentIdentifier":"/us/usc/t25/s3405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3405%2F2","sourceRelease":"119-100","text":"be consistent with the purposes of this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s3405/3","parentIdentifier":"/us/usc/t25/s3405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3405%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3405/3/A","parentIdentifier":"/us/usc/t25/s3405/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3405%2F3%2FA","sourceRelease":"119-100","text":"a comprehensive strategy identifying the full range of potential employment opportunities on and near the service area of the Indian tribe;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3405/3/B","parentIdentifier":"/us/usc/t25/s3405/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3405%2F3%2FB","sourceRelease":"119-100","text":"the education, training, and related services to be provided to assist Indians to access those employment opportunities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s3405/3/C","parentIdentifier":"/us/usc/t25/s3405/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3405%2F3%2FC","sourceRelease":"119-100","text":"the way in which services and program funds are to be integrated, consolidated, and delivered; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s3405/3/D","parentIdentifier":"/us/usc/t25/s3405/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3405%2F3%2FD","sourceRelease":"119-100","text":"the results expected, including the expected number of program participants in unsubsidized employment during the second quarter after exit from the program, from the plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s3405/4","parentIdentifier":"/us/usc/t25/s3405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3405%2F4","sourceRelease":"119-100","text":"identify the projected expenditures under the plan in a single budget covering all consolidated funds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s3405/5","parentIdentifier":"/us/usc/t25/s3405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3405%2F5","sourceRelease":"119-100","text":"identify any agency of the Indian tribe to be involved in the delivery of the services integrated under the plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t25/s3405/6","parentIdentifier":"/us/usc/t25/s3405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3405%2F6","sourceRelease":"119-100","text":"identify any statutory provisions, regulations, policies, or procedures that the Indian tribe believes need to be waived to implement the plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t25/s3405/7","parentIdentifier":"/us/usc/t25/s3405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3405%2F7","sourceRelease":"119-100","text":"be approved by the governing body of the Indian tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
