{"type":"section","nativeType":"section","number":"1603","heading":"General requirements; applicability; preemption","label":"1603 General requirements; applicability; preemption","identifier":"/us/usc/t21/s1603","parentIdentifier":"/us/usc/t21/ch21","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection applicable to all civil actions covered under this chapter commenced on or after , including any in which the harm or harmful conduct occurred before such date, see , set out as a note under .Aug. 13, 1998section 8 of Pub. L. 105–230section 1601 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"General requirements","label":"a General requirements","identifier":"/us/usc/t21/s1603/a","parentIdentifier":"/us/usc/t21/s1603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t21/s1603/a/1","parentIdentifier":"/us/usc/t21/s1603/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s1603/a/1/A","parentIdentifier":"/us/usc/t21/s1603/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fa%2F1%2FA","sourceRelease":"119-100","text":"raise any exclusion from liability set forth in ; andsection 1604 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s1603/a/1/B","parentIdentifier":"/us/usc/t21/s1603/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fa%2F1%2FB","sourceRelease":"119-100","text":"make a motion for dismissal or for summary judgment as set forth in .section 1605 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Procedures","label":"2 Procedures","identifier":"/us/usc/t21/s1603/a/2","parentIdentifier":"/us/usc/t21/s1603/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fa%2F2","sourceRelease":"119-100","text":"Notwithstanding any other provision of law, a Federal or State court in which an action covered by this chapter is pending shall, in connection with a motion under section 1605 or 1606 of this title, use the procedures set forth in this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Applicability","label":"b Applicability","identifier":"/us/usc/t21/s1603/b","parentIdentifier":"/us/usc/t21/s1603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t21/s1603/b/1","parentIdentifier":"/us/usc/t21/s1603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fb%2F1","sourceRelease":"119-100","text":"Except as provided in paragraph (2), this chapter applies to any civil action brought by a claimant, whether in a Federal or State court, on the basis of any legal theory, for harm allegedly caused, directly or indirectly, by an implant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Exclusion","label":"2 Exclusion","identifier":"/us/usc/t21/s1603/b/2","parentIdentifier":"/us/usc/t21/s1603/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s1603/b/2/A","parentIdentifier":"/us/usc/t21/s1603/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fb%2F2%2FA","sourceRelease":"119-100","text":"shall not be considered an action that is subject to this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s1603/b/2/B","parentIdentifier":"/us/usc/t21/s1603/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fb%2F2%2FB","sourceRelease":"119-100","text":"shall be governed by applicable commercial or contract law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Scope of preemption","label":"c Scope of preemption","identifier":"/us/usc/t21/s1603/c","parentIdentifier":"/us/usc/t21/s1603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t21/s1603/c/1","parentIdentifier":"/us/usc/t21/s1603/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fc%2F1","sourceRelease":"119-100","text":"This chapter supersedes any State law regarding recovery for harm caused by an implant and any rule of procedure applicable to a civil action to recover damages for such harm only to the extent that this chapter establishes a rule of law applicable to the recovery of such damages.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Applicability of other laws","label":"2 Applicability of other laws","identifier":"/us/usc/t21/s1603/c/2","parentIdentifier":"/us/usc/t21/s1603/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fc%2F2","sourceRelease":"119-100","text":"Any issue that arises under this chapter and that is not governed by a rule of law applicable to the recovery of damages described in paragraph (1) shall be governed by applicable Federal or State law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Statutory construction","label":"d Statutory construction","identifier":"/us/usc/t21/s1603/d","parentIdentifier":"/us/usc/t21/s1603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s1603/d/1","parentIdentifier":"/us/usc/t21/s1603/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fd%2F1","sourceRelease":"119-100","text":"to affect any defense available to a defendant under any other provisions of Federal or State law in an action alleging harm caused by an implant; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s1603/d/2","parentIdentifier":"/us/usc/t21/s1603/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs1603%2Fd%2F2","sourceRelease":"119-100","text":"to create a cause of action or Federal court jurisdiction pursuant to section 1331 or 1337 of title 28 that otherwise would not exist under applicable Federal or State law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
