{"type":"section","nativeType":"section","number":"3652","heading":"Annual reports to the Commission","label":"3652 Annual reports to the Commission","identifier":"/us/usc/t39/s3652","parentIdentifier":"/us/usc/t39/ptIV/ch36/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Costs, Revenues, Rates, and Service","label":"a .—Costs, Revenues, Rates, and Service","identifier":"/us/usc/t39/s3652/a","parentIdentifier":"/us/usc/t39/s3652","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t39/s3652/a/1","parentIdentifier":"/us/usc/t39/s3652/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fa%2F1","sourceRelease":"119-100","text":"which shall analyze costs, revenues, rates, and quality of service, using such methodologies as the Commission shall by regulation prescribe, and in sufficient detail to demonstrate that all products during such year complied with all applicable requirements of this title; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t39/s3652/a/2","parentIdentifier":"/us/usc/t39/s3652/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t39/s3652/a/2/A","parentIdentifier":"/us/usc/t39/s3652/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fa%2F2%2FA","sourceRelease":"119-100","text":"product information, including mail volumes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t39/s3652/a/2/B","parentIdentifier":"/us/usc/t39/s3652/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t39/s3652/a/2/B/i","parentIdentifier":"/us/usc/t39/s3652/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the level of service (described in terms of speed of delivery and reliability) provided; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t39/s3652/a/2/B/ii","parentIdentifier":"/us/usc/t39/s3652/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the degree of customer satisfaction with the service provided.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Information Relating to Workshare Discounts","label":"b .—Information Relating to Workshare Discounts","identifier":"/us/usc/t39/s3652/b","parentIdentifier":"/us/usc/t39/s3652","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t39/s3652/b/1","parentIdentifier":"/us/usc/t39/s3652/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fb%2F1","sourceRelease":"119-100","text":"The per-item cost avoided by the Postal Service by virtue of such discount.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t39/s3652/b/2","parentIdentifier":"/us/usc/t39/s3652/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fb%2F2","sourceRelease":"119-100","text":"The percentage of such per-item cost avoided that the per-item workshare discount represents.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t39/s3652/b/3","parentIdentifier":"/us/usc/t39/s3652/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fb%2F3","sourceRelease":"119-100","text":"The per-item contribution made to institutional costs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Market Tests","label":"c .—Market Tests","identifier":"/us/usc/t39/s3652/c","parentIdentifier":"/us/usc/t39/s3652","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t39/s3652/c/1","parentIdentifier":"/us/usc/t39/s3652/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fc%2F1","sourceRelease":"119-100","text":"report data on the costs, revenues, and quality of service by market test, which may be reported in summary form; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t39/s3652/c/2","parentIdentifier":"/us/usc/t39/s3652/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fc%2F2","sourceRelease":"119-100","text":"report such data as the Postal Regulatory Commission requires.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Supporting Matter","label":"d .—Supporting Matter","identifier":"/us/usc/t39/s3652/d","parentIdentifier":"/us/usc/t39/s3652","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fd","sourceRelease":"119-100","text":"The Postal Regulatory Commission shall have access, in accordance with such regulations as the Commission shall prescribe, to the working papers and any other supporting matter of the Postal Service and the Inspector General in connection with any information submitted under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Content and Form of Reports.—","label":"e Content and Form of Reports.—","identifier":"/us/usc/t39/s3652/e","parentIdentifier":"/us/usc/t39/s3652","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t39/s3652/e/1","parentIdentifier":"/us/usc/t39/s3652/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t39/s3652/e/1/A","parentIdentifier":"/us/usc/t39/s3652/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fe%2F1%2FA","sourceRelease":"119-100","text":"providing the public with timely, adequate information to assess the lawfulness of rates charged;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t39/s3652/e/1/B","parentIdentifier":"/us/usc/t39/s3652/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fe%2F1%2FB","sourceRelease":"119-100","text":"avoiding unnecessary or unwarranted administrative effort and expense on the part of the Postal Service; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t39/s3652/e/1/C","parentIdentifier":"/us/usc/t39/s3652/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fe%2F1%2FC","sourceRelease":"119-100","text":"protecting the confidentiality of commercially sensitive information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Revised requirements","label":"2 .—Revised requirements","identifier":"/us/usc/t39/s3652/e/2","parentIdentifier":"/us/usc/t39/s3652/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t39/s3652/e/2/A","parentIdentifier":"/us/usc/t39/s3652/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fe%2F2%2FA","sourceRelease":"119-100","text":"the attribution of costs or revenues to products has become significantly inaccurate or can be significantly improved;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t39/s3652/e/2/B","parentIdentifier":"/us/usc/t39/s3652/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fe%2F2%2FB","sourceRelease":"119-100","text":"the quality of service data has become significantly inaccurate or can be significantly improved; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t39/s3652/e/2/C","parentIdentifier":"/us/usc/t39/s3652/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fe%2F2%2FC","sourceRelease":"119-100","text":"such revisions are, in the judgment of the Commission, otherwise necessitated by the public interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Confidential Information.—","label":"f Confidential Information.—","identifier":"/us/usc/t39/s3652/f","parentIdentifier":"/us/usc/t39/s3652","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t39/s3652/f/1","parentIdentifier":"/us/usc/t39/s3652/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Ff%2F1","sourceRelease":"119-100","text":"If the Postal Service determines that any document or portion of a document, or other matter, which it provides to the Postal Regulatory Commission in a nonpublic annex under this section or under subsection (d) contains information which is described in , or exempt from public disclosure under , the Postal Service shall, at the time of providing such matter to the Commission, notify the Commission of its determination, in writing, and describe with particularity the documents (or portions of documents) or other matter for which confidentiality is sought and the reasons therefor.section 410(c) of this titlesection 552(b) of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Treatment","label":"2 .—Treatment","identifier":"/us/usc/t39/s3652/f/2","parentIdentifier":"/us/usc/t39/s3652/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Ff%2F2","sourceRelease":"119-100","text":"Any information or other matter described in paragraph (1) to which the Commission gains access under this section shall be subject to paragraphs (2) and (3) of section 504(g) in the same way as if the Commission had received notification with respect to such matter under section 504(g)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":".—Other Reports","label":"g .—Other Reports","identifier":"/us/usc/t39/s3652/g","parentIdentifier":"/us/usc/t39/s3652","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t39/s3652/g/1","parentIdentifier":"/us/usc/t39/s3652/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fg%2F1","sourceRelease":"119-100","text":"comprehensive statement under section 2401(e);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t39/s3652/g/2","parentIdentifier":"/us/usc/t39/s3652/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fg%2F2","sourceRelease":"119-100","text":"performance plan under section 2803; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t39/s3652/g/3","parentIdentifier":"/us/usc/t39/s3652/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs3652%2Fg%2F3","sourceRelease":"119-100","text":"program performance reports under section 2804.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
