{"type":"section","nativeType":"section","number":"3921","heading":"National wetlands priority conservation plan","label":"3921 National wetlands priority conservation plan","identifier":"/us/usc/t16/s3921","parentIdentifier":"/us/usc/t16/ch59/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3921","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s3921/a","parentIdentifier":"/us/usc/t16/s3921","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3921%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish, and periodically review and revise, a national wetlands priority conservation plan which shall specify, on a region-by-region basis or other basis considered appropriate by the Secretary, the types of wetlands and interests in wetlands which should be given priority with respect to Federal and State acquisition.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Consultation","label":"b Consultation","identifier":"/us/usc/t16/s3921/b","parentIdentifier":"/us/usc/t16/s3921","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3921%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s3921/b/1","parentIdentifier":"/us/usc/t16/s3921/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3921%2Fb%2F1","sourceRelease":"119-100","text":"the Administrator of the Environmental Protection Agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","iden