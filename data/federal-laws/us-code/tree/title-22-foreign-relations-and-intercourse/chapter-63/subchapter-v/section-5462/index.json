{"type":"section","nativeType":"section","number":"5462","heading":"SEED Information Center System","label":"5462 SEED Information Center System","identifier":"/us/usc/t22/s5462","parentIdentifier":"/us/usc/t22/ch63/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5462","sourceRelease":"119-100","text":null,"notes":["Executive Documents","Delegation of FunctionsFunctions of President under this section delegated to Secretary of Commerce by section 3 of Ex. Ord. No. 12703, , 55 F.R. 6351, set out as a note under .Feb. 20, 1990section 5401 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t22/s5462/a","parentIdentifier":"/us/usc/t22/s5462","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5462%2Fa","sourceRelease":"119-100","text":"The President shall establish a SEED Information Center System, using existing Executive branch agencies and acting in cooperation with the Government of Poland and the Government of Hungary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Functions","label":"b Functions","identifier":"/us/usc/t22/s5462/b","parentIdentifier":"/us/usc/t22/s5462","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5462%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s5462/b/1","parentIdentifier":"/us/usc/t22/s5462/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5462%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s5462/b/1/A","parentIdentifier":"/us/usc/t22/s5462/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5462%2Fb%2F1%2FA","sourceRelease":"119-100","text":"business needs and opportunities in Eastern Europe, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s5462/b/1/B","parentIdentifier":"/us/usc/t22/s5462/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5462%2Fb%2F1%2FB","sourceRelease":"119-100","text":"voluntary assistance to countries in Eastern Europe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Private enterprise development","label":"2 Private enterprise development","identifier":"/us/usc/t22/s5462/b/2","parentIdentifier":"/us/usc/t22/s5462/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5462%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s5462/b/2/A","parentIdentifier":"/us/usc/t22/s5462/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5462%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the submission of economically sound proposals to the Polish-American Enterprise Fund and Hungarian-American Enterprise Fund, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s5462/b/2/B","parentIdentifier":"/us/usc/t22/s5462/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5462%2Fb%2F2%2FB","sourceRelease":"119-100","text":"other sources of finance for the development of private enterprise in Eastern Europe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Location","label":"c Location","identifier":"/us/usc/t22/s5462/c","parentIdentifier":"/us/usc/t22/s5462","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs5462%2Fc","sourceRelease":"119-100","text":"The SEED Information Center System shall be based jointly in Washington, District of Columbia; Warsaw, Poland; and Budapest, Hungary; and should it become appropriate, the capitals of other East European countries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
