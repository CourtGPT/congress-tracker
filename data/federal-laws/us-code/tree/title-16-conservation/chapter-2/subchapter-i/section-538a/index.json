{"type":"section","nativeType":"section","number":"538a","heading":"Forest Service Legacy Road and Trail Remediation Program","label":"538a Forest Service Legacy Road and Trail Remediation Program","identifier":"/us/usc/t16/s538a","parentIdentifier":"/us/usc/t16/ch2/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Wage Rate RequirementsFor provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of , including authority of Secretary of Labor, see , The Public Health and Welfare.Pub. L. 117–58section 18851 of Title 42"],"amendments":["Wage Rate RequirementsFor provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of , including authority of Secretary of Labor, see , The Public Health and Welfare.Pub. L. 117–58section 18851 of Title 42"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t16/s538a/a","parentIdentifier":"/us/usc/t16/s538a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish the Forest Service Legacy Road and Trail Remediation Program (referred to in this section as the “Program”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Activities","label":"b Activities","identifier":"/us/usc/t16/s538a/b","parentIdentifier":"/us/usc/t16/s538a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs538a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDa