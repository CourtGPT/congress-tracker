{"type":"section","nativeType":"section","number":"966","heading":"Tier 3 participants in C–TPAT","label":"966 Tier 3 participants in C–TPAT","identifier":"/us/usc/t6/s966","parentIdentifier":"/us/usc/t6/ch3/schII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t6/s966/a","parentIdentifier":"/us/usc/t6/s966","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966%2Fa","sourceRelease":"119-100","text":"The Secretary, acting through the Commissioner, shall establish a third tier of C–TPAT participation that offers additional benefits to participants who demonstrate a sustained commitment to maintaining security measures and supply chain security practices that exceed the guidelines established for validation as a Tier 2 participant in C–TPAT under .section 965 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Criteria","label":"b Criteria","identifier":"/us/usc/t6/s966/b","parentIdentifier":"/us/usc/t6/s966","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s966/b/1","parentIdentifier":"/us/usc/t6/s966/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966%2Fb%2F1","sourceRelease":"119-100","text":"compliance with any additional guidelines established by the Secretary that exceed the guidelines established pursuant to for validating a C–TPAT participant as a Tier 2 participant, particularly with respect to controls over access to cargo throughout the supply chain;section 965 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s966/b/2","parentIdentifier":"/us/usc/t6/s966/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966%2Fb%2F2","sourceRelease":"119-100","text":"submission of additional information regarding cargo prior to loading, as determined by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s966/b/3","parentIdentifier":"/us/usc/t6/s966/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966%2Fb%2F3","sourceRelease":"119-100","text":"utilization of container security devices, technologies, policies, or practices that meet standards and criteria established by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s966/b/4","parentIdentifier":"/us/usc/t6/s966/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966%2Fb%2F4","sourceRelease":"119-100","text":"compliance with any other cargo requirements established by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Benefits","label":"c Benefits","identifier":"/us/usc/t6/s966/c","parentIdentifier":"/us/usc/t6/s966","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s966/c/1","parentIdentifier":"/us/usc/t6/s966/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966%2Fc%2F1","sourceRelease":"119-100","text":"the expedited release of a Tier 3 participant’s cargo in destination ports within the United States during all threat levels designated by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s966/c/2","parentIdentifier":"/us/usc/t6/s966/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966%2Fc%2F2","sourceRelease":"119-100","text":"further reduction in examinations of cargo;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s966/c/3","parentIdentifier":"/us/usc/t6/s966/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966%2Fc%2F3","sourceRelease":"119-100","text":"priority for examinations of cargo; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s966/c/4","parentIdentifier":"/us/usc/t6/s966/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966%2Fc%2F4","sourceRelease":"119-100","text":"further reduction in the risk score assigned pursuant to the Automated Targeting System; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s966/c/5","parentIdentifier":"/us/usc/t6/s966/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966%2Fc%2F5","sourceRelease":"119-100","text":"inclusion in joint incident management exercises, as appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Deadline","label":"d Deadline","identifier":"/us/usc/t6/s966/d","parentIdentifier":"/us/usc/t6/s966","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs966%2Fd","sourceRelease":"119-100","text":"Not later than 2 years after , the Secretary, acting through the Commissioner, shall designate appropriate criteria pursuant to subsection (b) and provide benefits to validated Tier 3 participants pursuant to subsection (c).October 13, 2006","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
