{"type":"section","nativeType":"section","number":"16342","heading":"International energy training","label":"16342 International energy training","identifier":"/us/usc/t42/s16342","parentIdentifier":"/us/usc/t42/ch149/schIX/ptH","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16342","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s16342/a","parentIdentifier":"/us/usc/t42/s16342","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16342%2Fa","sourceRelease":"119-100","text":"The Secretary, in consultation with the Secretary of Commerce, the Secretary of the Interior, and Secretary of State, and the Federal Energy Regulatory Commission, shall coordinate training and outreach efforts for international commercial energy markets in countries with developing and restructuring economies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Components","label":"b Components","identifier":"/us/usc/t42/s16342/b","parentIdentifier":"/us/usc/t42/s16342","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16342%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16342/b/1","parentIdentifier":"/us/usc/t42/s16342/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16342%2Fb%2F1","sourceRelease":"119-100","text":"production-related fiscal regimes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16342/b/2","parentIdentifier":"/us/usc/t42/s16342/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16342%2Fb%2F2","sourceRelease":"119-100","text":"grid and network issues;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16342/b/3","parentIdentifier":"/us/usc/t42/s16342/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16342%2Fb%2F3","sourceRelease":"119-100","text":"energy user and demand side response;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16342/b/4","parentIdentifier":"/us/usc/t42/s16342/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16342%2Fb%2F4","sourceRelease":"119-100","text":"international trade of energy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16342/b/5","parentIdentifier":"/us/usc/t42/s16342/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16342%2Fb%2F5","sourceRelease":"119-100","text":"international transportation of energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t42/s16342/c","parentIdentifier":"/us/usc/t42/s16342","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16342%2Fc","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $1,500,000 for each of fiscal years 2007 through 2010.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
