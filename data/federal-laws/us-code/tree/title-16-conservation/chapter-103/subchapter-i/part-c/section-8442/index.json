[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Categories of use","label":"2 Categories of use","identifier":"/us/usc/t16/s8442/a/2","parentIdentifier":"/us/usc/t16/s8442/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8442/a/2/A","parentIdentifier":"/us/usc/t16/s8442/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fa%2F2%2FA","sourceRelease":"119-100","text":"establish multiple categories of different recreation activities that are reported consistently across agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8442/a/2/B","parentIdentifier":"/us/usc/t16/s8442/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fa%2F2%2FB","sourceRelease":"119-100","text":"provide an estimate of the number of visitors for each applicable category established under subparagraph (A) for each unit of Federal recreational lands and waters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Real-Time Data Pilot Program","label":"b Real-Time Data Pilot Program","identifier":"/us/usc/t16/s8442/b","parentIdentifier":"/us/usc/t16/s8442","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s8442/b/1","parentIdentifier":"/us/usc/t16/s8442/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8442/b/1/A","parentIdentifier":"/us/usc/t16/s8442/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8442/b/1/A/i","parentIdentifier":"/us/usc/t16/s8442/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the unit of Federal recreational lands and waters;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8442/b/1/A/ii","parentIdentifier":"/us/usc/t16/s8442/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"to the extent practicable, areas within the unit of Federal recreational lands and waters; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s8442/b/1/A/iii","parentIdentifier":"/us/usc/t16/s8442/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"to the extent practicable, recreation sites managed by any other Federal agency, a State agency, or a local agency that are located near the unit of Federal recreational lands and waters; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s8442/b/1/B","parentIdentifier":"/us/usc/t16/s8442/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F1%2FB","sourceRelease":"119-100","text":"through multiple media platforms, information about lesser-known recreation sites located near the unit of Federal recreational lands and waters (including recreation sites managed by any other Federal agency, a State agency, or a local agency), in an effort to encourage visitation among recreational sites.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Locations","label":"2 Locations","identifier":"/us/usc/t16/s8442/b/2","parentIdentifier":"/us/usc/t16/s8442/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Initial number of units","label":"A Initial number of units","identifier":"/us/usc/t16/s8442/b/2/A","parentIdentifier":"/us/usc/t16/s8442/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8442/b/2/A/i","parentIdentifier":"/us/usc/t16/s8442/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"10 units of Federal recreational lands and waters managed by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8442/b/2/A/ii","parentIdentifier":"/us/usc/t16/s8442/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"5 units of Federal recreational lands and waters managed by the Secretary of Agriculture (acting through the Chief of the Forest Service);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s8442/b/2/A/iii","parentIdentifier":"/us/usc/t16/s8442/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"1 unit of Federal recreational lands and waters managed by the Secretary of Commerce (acting through the Administrator of the National Oceanic and Atmospheric Administration); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s8442/b/2/A/iv","parentIdentifier":"/us/usc/t16/s8442/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"1 unit of Federal recreational lands and waters managed by the Assistant Secretary of Army for Civil Works.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Report","label":"B Report","identifier":"/us/usc/t16/s8442/b/2/B","parentIdentifier":"/us/usc/t16/s8442/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F2%2FB","sourceRelease":"119-100","text":"Not later than 6 years after , the Secretaries shall submit a report to Congress regarding the implementation of the pilot program, including policy recommendations to expand the pilot program to additional units managed by the Secretaries.January 4, 2025","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Feedback; support of gateway communities","label":"C Feedback; support of gateway communities","identifier":"/us/usc/t16/s8442/b/2/C","parentIdentifier":"/us/usc/t16/s8442/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s8442/b/2/C/i","parentIdentifier":"/us/usc/t16/s8442/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F2%2FC%2Fi","sourceRelease":"119-100","text":"solicit feedback regarding participation in the Pilot Program from communities adjacent to units of Federal recreational lands and waters and the public; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s8442/b/2/C/ii","parentIdentifier":"/us/usc/t16/s8442/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F2%2FC%2Fii","sourceRelease":"119-100","text":"in carrying out subparagraphs (A) and (B), select a unit of Federal recreation lands and waters to participate in the Pilot Program only if the community adjacent to the unit of Federal recreational lands and waters is supportive of the participation of the unit of Federal recreational lands and waters in the Pilot Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Dissemination of information","label":"3 Dissemination of information","identifier":"/us/usc/t16/s8442/b/3","parentIdentifier":"/us/usc/t16/s8442/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F3","sourceRelease":"119-100","text":"The Secretaries may disseminate the information described in paragraph (1) directly or through an entity or organization referred to in subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Inclusion of current assessments","label":"4 Inclusion of current assessments","identifier":"/us/usc/t16/s8442/b/4","parentIdentifier":"/us/usc/t16/s8442/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fb%2F4","sourceRelease":"119-100","text":"In carrying out the Pilot Program, the Secretaries may, to the extent practicable, rely on assessments completed or data gathered prior to .January 4, 2025","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Community partners and third-party providers","label":"c Community partners and third-party providers","identifier":"/us/usc/t16/s8442/c","parentIdentifier":"/us/usc/t16/s8442","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s8442/c/1","parentIdentifier":"/us/usc/t16/s8442/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s8442/c/1/A","parentIdentifier":"/us/usc/t16/s8442/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8442%2Fc%2F1%2FA","sourceRelease":"119-100","text":"communities adjacent to units of Federal recreational lands and waters;","notes":[],"amendments":[]