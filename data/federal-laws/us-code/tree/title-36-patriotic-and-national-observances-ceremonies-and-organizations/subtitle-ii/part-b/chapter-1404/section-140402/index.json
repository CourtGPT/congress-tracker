{"type":"section","nativeType":"section","number":"140402","heading":"Purposes","label":"140402 Purposes","identifier":"/us/usc/t36/s140402","parentIdentifier":"/us/usc/t36/stII/ptB/ch1404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs140402","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2014— struck out subsec. (a) designation and heading “” before “The purposes” in introductory provisions.Pub. L. 113–237General"],"amendments":["Amendments2014— struck out subsec. (a) designation and heading “” before “The purposes” in introductory provisions.Pub. L. 113–237General"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t36/s140402/1","parentIdentifier":"/us/usc/t36/s140402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs140402%2F1","sourceRelease":"119-100","text":"to inculcate and stimulate love of the United States and the flag;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t36/s140402/2","parentIdentifier":"/us/usc/t36/s140402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs140402%2F2","sourceRelease":"119-100","text":"to defend the honor, integrity, and supremacy of the Constitution of the United States and the United States Government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t36/s140402/3","parentIdentifier":"/us/usc/t36/s140402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs140402%2F3","sourceRelease":"119-100","text":"to advocate military forces adequate to the defense of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t36/s140402/4","parentIdentifier":"/us/usc/t36/s140402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs140402%2F4","sourceRelease":"119-100","text":"to foster the integrity and prestige of the Armed Forces;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t36/s140402/5","parentIdentifier":"/us/usc/t36/s140402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs140402%2F5","sourceRelease":"119-100","text":"to foster fraternal relations between all branches of the various Armed Forces from which members are drawn;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t36/s140402/6","parentIdentifier":"/us/usc/t36/s140402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs140402%2F6","sourceRelease":"119-100","text":"to further the education of children of members of the Armed Forces;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t36/s140402/7","parentIdentifier":"/us/usc/t36/s140402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs140402%2F7","sourceRelease":"119-100","text":"to aid members of the Armed Forces and their family members and survivors in every proper and legitimate manner;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t36/s140402/8","parentIdentifier":"/us/usc/t36/s140402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs140402%2F8","sourceRelease":"119-100","text":"to present and support legislative proposals that provide for the fair and equitable treatment of members of the Armed Forces, including the National Guard and Reserves, military retirees, family members, survivors, and veterans; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t36/s140402/9","parentIdentifier":"/us/usc/t36/s140402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs140402%2F9","sourceRelease":"119-100","text":"to encourage recruitment and appointment in the Armed Forces.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
