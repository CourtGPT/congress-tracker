{"type":"section","nativeType":"section","number":"4442","heading":"Administrative provisions","label":"4442 Administrative provisions","identifier":"/us/usc/t20/s4442","parentIdentifier":"/us/usc/t20/ch56/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Payments","label":"a Payments","identifier":"/us/usc/t20/s4442/a","parentIdentifier":"/us/usc/t20/s4442","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442%2Fa","sourceRelease":"119-100","text":"The Secretary may award grants under this subchapter in installments, in advance, or by way of reimbursement and may make necessary adjustments in payments of grants on account of overpayments or underpayments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Recovery of overpayments","label":"b Recovery of overpayments","identifier":"/us/usc/t20/s4442/b","parentIdentifier":"/us/usc/t20/s4442","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s4442/b/1","parentIdentifier":"/us/usc/t20/s4442/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s4442/b/1/A","parentIdentifier":"/us/usc/t20/s4442/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s4442/b/1/A/i","parentIdentifier":"/us/usc/t20/s4442/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t20/s4442/b/1/A/i/I","parentIdentifier":"/us/usc/t20/s4442/b/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442%2Fb%2F1%2FA%2Fi%2FI","sourceRelease":"119-100","text":"made, or has caused to be made by another, a false statement or representation of a material fact knowing it to be false, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t20/s4442/b/1/A/i/II","parentIdentifier":"/us/usc/t20/s4442/b/1/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442%2Fb%2F1%2FA%2Fi%2FII","sourceRelease":"119-100","text":"knowingly failed, or caused another to fail, to disclose a material fact; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s4442/b/1/A/ii","parentIdentifier":"/us/usc/t20/s4442/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"as a result of such action, has received any funds under this subchapter which such person would not have otherwise received, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s4442/b/1/B","parentIdentifier":"/us/usc/t20/s4442/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442%2Fb%2F1%2FB","sourceRelease":"119-100","text":"any person misappropriates any funds paid by the Secretary under this subchapter,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s4442/b/2","parentIdentifier":"/us/usc/t20/s4442/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442%2Fb%2F2","sourceRelease":"119-100","text":"Any amount repaid under this subsection shall be returned to the general fund of the Treasury of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Penalties","label":"c Penalties","identifier":"/us/usc/t20/s4442/c","parentIdentifier":"/us/usc/t20/s4442","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s4442/c/1","parentIdentifier":"/us/usc/t20/s4442/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442%2Fc%2F1","sourceRelease":"119-100","text":"makes a false statement of a material fact knowing it to be false, or knowingly fails to disclose a material fact, for the purpose of obtaining or increasing for such person or for any other person any payment of funds provided under this subchapter, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s4442/c/2","parentIdentifier":"/us/usc/t20/s4442/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs4442%2Fc%2F2","sourceRelease":"119-100","text":"misappropriates any funds provided under this subchapter,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
