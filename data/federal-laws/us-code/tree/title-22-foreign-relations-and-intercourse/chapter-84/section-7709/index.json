{"type":"section","nativeType":"section","number":"7709","heading":"Congressional and public notification","label":"7709 Congressional and public notification","identifier":"/us/usc/t22/s7709","parentIdentifier":"/us/usc/t22/ch84","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2018— amended section generally. Prior to amendment, section related to Congressional and public notification of Compact.Pub. L. 115–167"],"amendments":["Amendments2018— amended section generally. Prior to amendment, section related to Congressional and public notification of Compact.Pub. L. 115–167"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Congressional consultations and notifications","label":"a Congressional consultations and notifications","identifier":"/us/usc/t22/s7709/a","parentIdentifier":"/us/usc/t22/s7709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s7709/a/1","parentIdentifier":"/us/usc/t22/s7709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F1","sourceRelease":"119-100","text":"The Board, acting through the Chief Executive Officer, shall consult with and notify the appropriate congressional committees not later than 15 days before taking any of the actions described in paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Actions described","label":"2 Actions described","identifier":"/us/usc/t22/s7709/a/2","parentIdentifier":"/us/usc/t22/s7709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s7709/a/2/A","parentIdentifier":"/us/usc/t22/s7709/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F2%2FA","sourceRelease":"119-100","text":"providing assistance for an eligible country under ;section 7708(g) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s7709/a/2/B","parentIdentifier":"/us/usc/t22/s7709/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s7709/a/2/B/i","parentIdentifier":"/us/usc/t22/s7709/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"a Compact under ; orsection 7704 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s7709/a/2/B/ii","parentIdentifier":"/us/usc/t22/s7709/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"an agreement under ;section 7715 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s7709/a/2/C","parentIdentifier":"/us/usc/t22/s7709/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F2%2FC","sourceRelease":"119-100","text":"signing such a Compact or agreement; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s7709/a/2/D","parentIdentifier":"/us/usc/t22/s7709/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F2%2FD","sourceRelease":"119-100","text":"terminating assistance under such a Compact or agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Economic justification","label":"3 Economic justification","identifier":"/us/usc/t22/s7709/a/3","parentIdentifier":"/us/usc/t22/s7709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s7709/a/3/A","parentIdentifier":"/us/usc/t22/s7709/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F3%2FA","sourceRelease":"119-100","text":"the expected economic rate of return of the Compact;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s7709/a/3/B","parentIdentifier":"/us/usc/t22/s7709/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F3%2FB","sourceRelease":"119-100","text":"a cost-benefit analysis of the Compact;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s7709/a/3/C","parentIdentifier":"/us/usc/t22/s7709/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F3%2FC","sourceRelease":"119-100","text":"a description of the impact on beneficiary populations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s7709/a/3/D","parentIdentifier":"/us/usc/t22/s7709/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F3%2FD","sourceRelease":"119-100","text":"the likelihood that the investment will catalyze private sector investments; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t22/s7709/a/3/E","parentIdentifier":"/us/usc/t22/s7709/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F3%2FE","sourceRelease":"119-100","text":"any other applicable economic factors that justify each project to be funded under such a Compact to the extent practicable and appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Risk management plan","label":"4 Risk management plan","identifier":"/us/usc/t22/s7709/a/4","parentIdentifier":"/us/usc/t22/s7709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s7709/a/4/A","parentIdentifier":"/us/usc/t22/s7709/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s7709/a/4/A/i","parentIdentifier":"/us/usc/t22/s7709/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F4%2FA%2Fi","sourceRelease":"119-100","text":"the countries’ commitment to regional integration and cross-border cooperation and capacity to carry out commitments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s7709/a/4/A/ii","parentIdentifier":"/us/usc/t22/s7709/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F4%2FA%2Fii","sourceRelease":"119-100","text":"political and policy risks, including risks that could affect country eligibility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t22/s7709/a/4/A/iii","parentIdentifier":"/us/usc/t22/s7709/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F4%2FA%2Fiii","sourceRelease":"119-100","text":"risks associated with realizing economic returns;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t22/s7709/a/4/A/iv","parentIdentifier":"/us/usc/t22/s7709/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F4%2FA%2Fiv","sourceRelease":"119-100","text":"time and completion risks; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t22/s7709/a/4/A/v","parentIdentifier":"/us/usc/t22/s7709/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F4%2FA%2Fv","sourceRelease":"119-100","text":"cost and financial risks; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s7709/a/4/B","parentIdentifier":"/us/usc/t22/s7709/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s7709/a/4/B/i","parentIdentifier":"/us/usc/t22/s7709/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F4%2FB%2Fi","sourceRelease":"119-100","text":"securing other potential donors to finance projects or parts of projects as needed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s7709/a/4/B/ii","parentIdentifier":"/us/usc/t22/s7709/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fa%2F4%2FB%2Fii","sourceRelease":"119-100","text":"partnering with regional organizations to support and oversee effective cross-border cooperation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Congressional and public notification after entering into a Compact","label":"b Congressional and public notification after entering into a Compact","identifier":"/us/usc/t22/s7709/b","parentIdentifier":"/us/usc/t22/s7709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s7709/b/1","parentIdentifier":"/us/usc/t22/s7709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fb%2F1","sourceRelease":"119-100","text":"publish the text of the Compact on the website of the Corporation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s7709/b/2","parentIdentifier":"/us/usc/t22/s7709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fb%2F2","sourceRelease":"119-100","text":"provide the appropriate congressional committees with a detailed summary of the Compact and, upon request, the text of the Compact; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s7709/b/3","parentIdentifier":"/us/usc/t22/s7709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs7709%2Fb%2F3","sourceRelease":"119-100","text":"publish in the Federal Register a detailed summary of the Compact and a notice of availability of the text of the Compact on the website of the Corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
