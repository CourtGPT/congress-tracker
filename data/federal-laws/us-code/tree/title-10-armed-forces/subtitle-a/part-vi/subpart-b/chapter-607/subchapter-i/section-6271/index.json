{"type":"section","nativeType":"section","number":"6271","heading":"Definitions","label":"6271 Definitions","identifier":"/us/usc/t10/s6271","parentIdentifier":"/us/usc/t10/stA/ptVI/sptB/ch607/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6271","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsProvisions similar to those in this section were contained in , War and National Defense, prior to repeal by .section 2741 of Title 50Pub. L. 119–60, § 3111(b)(1)"],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6271/1","parentIdentifier":"/us/usc/t10/s6271","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6271%2F1","sourceRelease":"119-100","text":"The term “DOE national security authorization” means an authorization of appropriations for activities of the Department of Energy in carrying out programs necessary for national security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6271/2","parentIdentifier":"/us/usc/t10/s6271","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6271%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s6271/2/A","parentIdentifier":"/us/usc/t10/s6271/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6271%2F2%2FA","sourceRelease":"119-100","text":"Except as provided by subparagraph (B), the term “minor construction threshold” means $30,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s6271/2/B","parentIdentifier":"/us/usc/t10/s6271/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6271%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s6271/2/B/i","parentIdentifier":"/us/usc/t10/s6271/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6271%2F2%2FB%2Fi","sourceRelease":"119-100","text":"submits to the congressional defense committees a report on the method used by the Administrator to calculate the adjustment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s6271/2/B/ii","parentIdentifier":"/us/usc/t10/s6271/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6271%2F2%2FB%2Fii","sourceRelease":"119-100","text":"a period of 30 days elapses following the date of such submission; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t10/s6271/2/B/iii","parentIdentifier":"/us/usc/t10/s6271/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6271%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"publishes the adjusted amount in the Federal Register.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
