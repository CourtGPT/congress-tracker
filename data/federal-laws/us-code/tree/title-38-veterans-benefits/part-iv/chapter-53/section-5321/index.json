{"type":"section","nativeType":"section","number":"5321","heading":"Benefits helpline","label":"5321 Benefits helpline","identifier":"/us/usc/t38/s5321","parentIdentifier":"/us/usc/t38/ptIV/ch53","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5321","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t38/s5321/a","parentIdentifier":"/us/usc/t38/s5321","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5321%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s5321/a/1","parentIdentifier":"/us/usc/t38/s5321/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5321%2Fa%2F1","sourceRelease":"119-100","text":"obtain information about any service or benefit provided under the laws administered by the Secretary; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s5321/a/2","parentIdentifier":"/us/usc/t38/s5321/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5321%2Fa%2F2","sourceRelease":"119-100","text":"be directed to an appropriate office of the Department regarding such a service or benefit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Contract for Direction of Calls Authorized","label":"b .—Contract for Direction of Calls Authorized","identifier":"/us/usc/t38/s5321/b","parentIdentifier":"/us/usc/t38/s5321","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5321%2Fb","sourceRelease":"119-100","text":"The Secretary may enter into a contract with a third party to direct calls made to the helpline to an appropriate office under subsection (a)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Live Individual Required","label":"c .—Live Individual Required","identifier":"/us/usc/t38/s5321/c","parentIdentifier":"/us/usc/t38/s5321","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5321%2Fc","sourceRelease":"119-100","text":"The Secretary shall ensure that a covered individual who calls the helpline has the option to speak with a live individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Definitions","label":"d .—Definitions","identifier":"/us/usc/t38/s5321/d","parentIdentifier":"/us/usc/t38/s5321","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5321%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s5321/d/1","parentIdentifier":"/us/usc/t38/s5321/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5321%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s5321/d/1/A","parentIdentifier":"/us/usc/t38/s5321/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5321%2Fd%2F1%2FA","sourceRelease":"119-100","text":"a veteran;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s5321/d/1/B","parentIdentifier":"/us/usc/t38/s5321/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5321%2Fd%2F1%2FB","sourceRelease":"119-100","text":"an individual acting on behalf of a veteran; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s5321/d/1/C","parentIdentifier":"/us/usc/t38/s5321/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5321%2Fd%2F1%2FC","sourceRelease":"119-100","text":"an individual other than a veteran who is eligible to receive a benefit or service under a law administered by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s5321/d/2","parentIdentifier":"/us/usc/t38/s5321/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs5321%2Fd%2F2","sourceRelease":"119-100","text":"The term “veteran” has the meaning given such term in .section 2002(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
