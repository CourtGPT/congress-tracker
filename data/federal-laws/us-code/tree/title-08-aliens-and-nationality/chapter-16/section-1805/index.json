{"type":"section","nativeType":"section","number":"1805","heading":"Special immigrant juvenile fee","label":"1805 Special immigrant juvenile fee","identifier":"/us/usc/t8/s1805","parentIdentifier":"/us/usc/t8/ch16","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1805","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t8/s1805/a","parentIdentifier":"/us/usc/t8/s1805","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1805%2Fa","sourceRelease":"119-100","text":"In addition to any other fee authorized by law, the Secretary of Homeland Security shall require the payment of a fee, equal to the amount specified in this section, by any alien, parent, or legal guardian of an alien applying for special immigrant juvenile status under .section 1101(a)(27)(J) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Initial amount","label":"b Initial amount","identifier":"/us/usc/t8/s1805/b","parentIdentifier":"/us/usc/t8/s1805","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1805%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t8/s1805/b/1","parentIdentifier":"/us/usc/t8/s1805/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1805%2Fb%2F1","sourceRelease":"119-100","text":"$250; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t8/s1805/b/2","parentIdentifier":"/us/usc/t8/s1805/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1805%2Fb%2F2","sourceRelease":"119-100","text":"such amount as the Secretary of Homeland Security may establish, by rule.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Annual adjustments for inflation","label":"c Annual adjustments for inflation","identifier":"/us/usc/t8/s1805/c","parentIdentifier":"/us/usc/t8/s1805","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1805%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t8/s1805/c/1","parentIdentifier":"/us/usc/t8/s1805/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1805%2Fc%2F1","sourceRelease":"119-100","text":"the amount of the fee required under this subsection for the most recently concluded fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t8/s1805/c/2","parentIdentifier":"/us/usc/t8/s1805/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1805%2Fc%2F2","sourceRelease":"119-100","text":"the product resulting from the multiplication of the amount referred to in paragraph (1) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded to the next lowest multiple of $10.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Disposition of special immigrant juvenile fees","label":"d Disposition of special immigrant juvenile fees","identifier":"/us/usc/t8/s1805/d","parentIdentifier":"/us/usc/t8/s1805","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1805%2Fd","sourceRelease":"119-100","text":"All of the fees collected pursuant to this section shall be deposited into the general fund of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
