{"type":"section","nativeType":"section","number":"1635f","heading":"Mandatory packer reporting of boxed beef sales","label":"1635f Mandatory packer reporting of boxed beef sales","identifier":"/us/usc/t7/s1635f","parentIdentifier":"/us/usc/t7/ch38/schII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635f","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Daily reporting","label":"a Daily reporting","identifier":"/us/usc/t7/s1635f/a","parentIdentifier":"/us/usc/t7/s1635f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635f%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s1635f/a/1","parentIdentifier":"/us/usc/t7/s1635f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635f%2Fa%2F1","sourceRelease":"119-100","text":"the price for each lot of each negotiated boxed beef sale (determined by seller-buyer interaction and agreement), quoted in dollars per hundredweight (on a F.O.B. plant basis);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s1635f/a/2","parentIdentifier":"/us/usc/t7/s1635f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635f%2Fa%2F2","sourceRelease":"119-100","text":"the quantity for each lot of each sale, quoted by number of boxes sold; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s1635f/a/3","parentIdentifier":"/us/usc/t7/s1635f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635f%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1635f/a/3/A","parentIdentifier":"/us/usc/t7/s1635f/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635f%2Fa%2F3%2FA","sourceRelease":"119-100","text":"the grade of beef (USDA Choice or better, USDA Select, or ungraded no-roll product);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1635f/a/3/B","parentIdentifier":"/us/usc/t7/s1635f/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635f%2Fa%2F3%2FB","sourceRelease":"119-100","text":"the cut of beef; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s1635f/a/3/C","parentIdentifier":"/us/usc/t7/s1635f/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635f%2Fa%2F3%2FC","sourceRelease":"119-100","text":"the trim specification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Publication","label":"b Publication","identifier":"/us/usc/t7/s1635f/b","parentIdentifier":"/us/usc/t7/s1635f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1635f%2Fb","sourceRelease":"119-100","text":"The Secretary shall make available to the public the information required to be reported under subsection (a) not less frequently than twice each reporting day.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
