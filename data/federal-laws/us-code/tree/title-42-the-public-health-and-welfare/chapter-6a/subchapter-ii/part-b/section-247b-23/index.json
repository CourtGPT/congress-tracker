{"type":"section","nativeType":"section","number":"247b–23","heading":"National strategy and regional centers of excellence in vector-borne diseases","label":"247b–23 National strategy and regional centers of excellence in vector-borne diseases","identifier":"/us/usc/t42/s247b–23","parentIdentifier":"/us/usc/t42/ch6A/schII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s247b–23/a","parentIdentifier":"/us/usc/t42/s247b–23","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s247b–23/a/1","parentIdentifier":"/us/usc/t42/s247b–23/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s247b–23/a/1/A","parentIdentifier":"/us/usc/t42/s247b–23/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s247b–23/a/1/A/i","parentIdentifier":"/us/usc/t42/s247b–23/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"identifies and assesses gaps and any unnecessary duplication in federally-funded programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s247b–23/a/1/A/ii","parentIdentifier":"/us/usc/t42/s247b–23/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"identifies strategic goals to address such diseases and appropriate benchmarks to measure progress toward achieving such goals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s247b–23/a/1/B","parentIdentifier":"/us/usc/t42/s247b–23/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fa%2F1%2FB","sourceRelease":"119-100","text":"update such strategy, as appropriate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s247b–23/a/2","parentIdentifier":"/us/usc/t42/s247b–23/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fa%2F2","sourceRelease":"119-100","text":"coordinate programs and activities, including related to data collection, research, and the development of diagnostics, treatments, vaccines, and other related activities, to address vector-borne diseases, including tick-borne diseases, across the Department of Health and Human Services and with other Federal agencies or departments, as appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Consultation","label":"b Consultation","identifier":"/us/usc/t42/s247b–23/b","parentIdentifier":"/us/usc/t42/s247b–23","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s247b–23/b/1","parentIdentifier":"/us/usc/t42/s247b–23/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fb%2F1","sourceRelease":"119-100","text":"epidemiologists with experience in vector-borne diseases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s247b–23/b/2","parentIdentifier":"/us/usc/t42/s247b–23/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fb%2F2","sourceRelease":"119-100","text":"representatives of patient advocacy and research organizations that focus on vector-borne diseases, including such organizations that have demonstrated experience in related research, public health, data collection, or patient access to care;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s247b–23/b/3","parentIdentifier":"/us/usc/t42/s247b–23/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fb%2F3","sourceRelease":"119-100","text":"health information technology experts or other information management specialists;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s247b–23/b/4","parentIdentifier":"/us/usc/t42/s247b–23/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fb%2F4","sourceRelease":"119-100","text":"clinicians, entomologists, vector management professionals, public health professionals, and others with expertise in vector-borne diseases; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s247b–23/b/5","parentIdentifier":"/us/usc/t42/s247b–23/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fb%2F5","sourceRelease":"119-100","text":"researchers, including researchers with experience conducting translational research.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Centers of excellence","label":"c Centers of excellence","identifier":"/us/usc/t42/s247b–23/c","parentIdentifier":"/us/usc/t42/s247b–23","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s247b–23/c/1","parentIdentifier":"/us/usc/t42/s247b–23/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fc%2F1","sourceRelease":"119-100","text":"facilitating collaboration between academia and public health organizations for public health surveillance, prevention, and response activities related to vector-borne diseases, including tick-borne diseases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s247b–23/c/2","parentIdentifier":"/us/usc/t42/s247b–23/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fc%2F2","sourceRelease":"119-100","text":"providing training for public health entomologists and other health care professionals, as appropriate, to address vector-borne diseases, including tick-borne diseases;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s247b–23/c/3","parentIdentifier":"/us/usc/t42/s247b–23/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fc%2F3","sourceRelease":"119-100","text":"conducting research to develop and validate prevention and control tools and methods, including evidence-based and innovative, evidence-informed tools and methods to anticipate and respond to disease outbreaks; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s247b–23/c/4","parentIdentifier":"/us/usc/t42/s247b–23/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fc%2F4","sourceRelease":"119-100","text":"preparing for and responding to outbreaks of vector-borne diseases, including tick-borne diseases.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Eligibility","label":"d Eligibility","identifier":"/us/usc/t42/s247b–23/d","parentIdentifier":"/us/usc/t42/s247b–23","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fd","sourceRelease":"119-100","text":"To be eligible to receive a grant, contract, or cooperative agreement under subsection (c), an entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including a description of how the entity will conduct the activities described in such subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Reports","label":"e Reports","identifier":"/us/usc/t42/s247b–23/e","parentIdentifier":"/us/usc/t42/s247b–23","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Program summary","label":"1 Program summary","identifier":"/us/usc/t42/s247b–23/e/1","parentIdentifier":"/us/usc/t42/s247b–23/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fe%2F1","sourceRelease":"119-100","text":"An entity receiving an award under subsection (c) shall, not later than one year after receiving such award, and annually thereafter, submit to the Secretary a summary of programs and activities funded under the award.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Progress report","label":"2 Progress report","identifier":"/us/usc/t42/s247b–23/e/2","parentIdentifier":"/us/usc/t42/s247b–23/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Fe%2F2","sourceRelease":"119-100","text":"Not later than 4 years after , the Secretary shall submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives, a report on the progress made in addressing vector-borne diseases, including tick-borne diseases, through activities carried out under this section.December 20, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorization of appropriations","label":"f Authorization of appropriations","identifier":"/us/usc/t42/s247b–23/f","parentIdentifier":"/us/usc/t42/s247b–23","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs247b%E2%80%9323%2Ff","sourceRelease":"119-100","text":"For the purpose of carrying out this section, there are authorized to be appropriated $10,000,000 for each of fiscal years 2021 through 2025.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
