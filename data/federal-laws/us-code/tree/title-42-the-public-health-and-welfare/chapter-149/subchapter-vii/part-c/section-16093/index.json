entIdentifier":"/us/usc/t42/s16093/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16093%2Fc%2F2","sourceRelease":"119-100","text":"assesses the results of the development and demonstration program under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s16093/d","parentIdentifier":"/us/usc/t42/s16093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16093%2Fd","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Secretary to carry out this section $25,000,000 for the period of fiscal years 2006 through 2009.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
