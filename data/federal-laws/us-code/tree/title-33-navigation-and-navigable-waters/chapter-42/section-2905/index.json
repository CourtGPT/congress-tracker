{"type":"section","nativeType":"section","number":"2905","heading":"Estuary habitat restoration strategy","label":"2905 Estuary habitat restoration strategy","identifier":"/us/usc/t33/s2905","parentIdentifier":"/us/usc/t33/ch42","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t33/s2905/a","parentIdentifier":"/us/usc/t33/s2905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fa","sourceRelease":"119-100","text":"Not later than 1 year after , the Council, shall develop an estuary habitat restoration strategy designed to ensure a comprehensive approach to maximize benefits derived from estuary habitat restoration projects and to foster the coordination of Federal and non-Federal activities related to restoration of estuary habitat.November 7, 20001So in original. The comma probably should not appear.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Goal","label":"b Goal","identifier":"/us/usc/t33/s2905/b","parentIdentifier":"/us/usc/t33/s2905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fb","sourceRelease":"119-100","text":"The goal of the strategy shall be the restoration of 1,000,000 acres of estuary habitat by the year 2010.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Integration of estuary habitat restoration plans, programs, and partnerships","label":"c Integration of estuary habitat restoration plans, programs, and partnerships","identifier":"/us/usc/t33/s2905/c","parentIdentifier":"/us/usc/t33/s2905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s2905/c/1","parentIdentifier":"/us/usc/t33/s2905/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fc%2F1","sourceRelease":"119-100","text":"conduct a review of estuary management or habitat restoration plans and Federal programs established under other laws that authorize funding for estuary habitat restoration activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s2905/c/2","parentIdentifier":"/us/usc/t33/s2905/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fc%2F2","sourceRelease":"119-100","text":"ensure that the estuary habitat restoration strategy is developed in a manner that is consistent with the estuary management or habitat restoration plans.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Elements of the strategy","label":"d Elements of the strategy","identifier":"/us/usc/t33/s2905/d","parentIdentifier":"/us/usc/t33/s2905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s2905/d/1","parentIdentifier":"/us/usc/t33/s2905/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd%2F1","sourceRelease":"119-100","text":"maximizing the incentives for the creation of new public-private partnerships to carry out estuary habitat restoration projects and the use of Federal resources to encourage increased private sector involvement in estuary habitat restoration activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s2905/d/2","parentIdentifier":"/us/usc/t33/s2905/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd%2F2","sourceRelease":"119-100","text":"ensuring that the estuary habitat restoration strategy will be implemented in a manner that is consistent with the estuary management or habitat restoration plans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s2905/d/3","parentIdentifier":"/us/usc/t33/s2905/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s2905/d/3/A","parentIdentifier":"/us/usc/t33/s2905/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s2905/d/3/A/i","parentIdentifier":"/us/usc/t33/s2905/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd%2F3%2FA%2Fi","sourceRelease":"119-100","text":"wildlife, including endangered and threatened species, migratory birds, and resident species of an estuary watershed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s2905/d/3/A/ii","parentIdentifier":"/us/usc/t33/s2905/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd%2F3%2FA%2Fii","sourceRelease":"119-100","text":"fish and shellfish, including commercial and recreational fisheries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s2905/d/3/B","parentIdentifier":"/us/usc/t33/s2905/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd%2F3%2FB","sourceRelease":"119-100","text":"improve surface and ground water quality and quantity, and flood control;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s2905/d/3/C","parentIdentifier":"/us/usc/t33/s2905/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd%2F3%2FC","sourceRelease":"119-100","text":"provide outdoor recreation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t33/s2905/d/3/D","parentIdentifier":"/us/usc/t33/s2905/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd%2F3%2FD","sourceRelease":"119-100","text":"address other areas of concern that the Council determines to be appropriate for consideration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s2905/d/4","parentIdentifier":"/us/usc/t33/s2905/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd%2F4","sourceRelease":"119-100","text":"addressing the estimated historic losses, estimated current rate of loss, and extent of the threat of future loss or degradation of each type of estuary habitat;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t33/s2905/d/5","parentIdentifier":"/us/usc/t33/s2905/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd%2F5","sourceRelease":"119-100","text":"measuring the rate of change for each type of estuary habitat;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t33/s2905/d/6","parentIdentifier":"/us/usc/t33/s2905/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd%2F6","sourceRelease":"119-100","text":"selecting a balance of smaller and larger estuary habitat restoration projects; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t33/s2905/d/7","parentIdentifier":"/us/usc/t33/s2905/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fd%2F7","sourceRelease":"119-100","text":"ensuring equitable geographic distribution of projects funded under this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Public review and comment","label":"e Public review and comment","identifier":"/us/usc/t33/s2905/e","parentIdentifier":"/us/usc/t33/s2905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Fe","sourceRelease":"119-100","text":"Before the Council adopts a final or revised estuary habitat restoration strategy, the Secretary shall publish in the Federal Register a draft of the estuary habitat restoration strategy and provide an opportunity for public review and comment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Periodic revision","label":"f Periodic revision","identifier":"/us/usc/t33/s2905/f","parentIdentifier":"/us/usc/t33/s2905","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs2905%2Ff","sourceRelease":"119-100","text":"Using data and information developed through project monitoring and management, and other relevant information, the Council may periodically review and update, as necessary, the estuary habitat restoration strategy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
