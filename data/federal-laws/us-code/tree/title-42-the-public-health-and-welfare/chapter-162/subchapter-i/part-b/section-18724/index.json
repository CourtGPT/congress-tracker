18724/b/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fb%2F1%2FA%2Fii%2FV","sourceRelease":"119-100","text":"application of in-line edge security solutions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18724/b/1/B","parentIdentifier":"/us/usc/t42/s18724/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fb%2F1%2FB","sourceRelease":"119-100","text":"to leverage electric grid architecture as a means to assess risks to the energy sector, including by implementing an all-hazards approach to communications infrastructure, control systems architecture, and power systems architecture;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18724/b/1/C","parentIdentifier":"/us/usc/t42/s18724/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fb%2F1%2FC","sourceRelease":"119-100","text":"to perform pilot demonstration projects with the energy sector to gain experience with new technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s18724/b/1/D","parentIdentifier":"/us/usc/t42/s18724/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fb%2F1%2FD","sourceRelease":"119-100","text":"to develop workforce development curricula for energy sector-related cybersecurity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s18724/b/1/E","parentIdentifier":"/us/usc/t42/s18724/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fb%2F1%2FE","sourceRelease":"119-100","text":"to develop improved supply chain concepts for secure design of emerging digital components and power electronics.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Authorization of appropriations","label":"2 Authorization of appropriations","identifier":"/us/usc/t42/s18724/b/2","parentIdentifier":"/us/usc/t42/s18724/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fb%2F2","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary to carry out this subsection $250,000,000 for the period of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Energy sector operational support for cyberresilience program","label":"c Energy sector operational support for cyberresilience program","identifier":"/us/usc/t42/s18724/c","parentIdentifier":"/us/usc/t42/s18724","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18724/c/1","parentIdentifier":"/us/usc/t42/s18724/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18724/c/1/A","parentIdentifier":"/us/usc/t42/s18724/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s18724/c/1/A/i","parentIdentifier":"/us/usc/t42/s18724/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the emergency response capabilities of the Department; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s18724/c/1/A/ii","parentIdentifier":"/us/usc/t42/s18724/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the coordination of the Department with other agencies, the National Laboratories, and private industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18724/c/1/B","parentIdentifier":"/us/usc/t42/s18724/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fc%2F1%2FB","sourceRelease":"119-100","text":"to expand cooperation of the Department with the intelligence community for energy sector-related threat collection and analysis;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18724/c/1/C","parentIdentifier":"/us/usc/t42/s18724/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fc%2F1%2FC","sourceRelease":"119-100","text":"to enhance the tools of the Department and E-ISAC for monitoring the status of the energy sector;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s18724/c/1/D","parentIdentifier":"/us/usc/t42/s18724/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fc%2F1%2FD","sourceRelease":"119-100","text":"to expand industry participation in E-ISAC; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s18724/c/1/E","parentIdentifier":"/us/usc/t42/s18724/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fc%2F1%2FE","sourceRelease":"119-100","text":"to provide technical assistance to small electric utilities for purposes of assessing and improving cybermaturity levels and addressing gaps identified in the assessment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Authorization of appropriations","label":"2 Authorization of appropriations","identifier":"/us/usc/t42/s18724/c/2","parentIdentifier":"/us/usc/t42/s18724/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fc%2F2","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary to carry out this subsection $50,000,000 for the period of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Modeling and assessing energy infrastructure risk","label":"d Modeling and assessing energy infrastructure risk","identifier":"/us/usc/t42/s18724/d","parentIdentifier":"/us/usc/t42/s18724","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18724/d/1","parentIdentifier":"/us/usc/t42/s18724/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18724/d/1/A","parentIdentifier":"/us/usc/t42/s18724/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F1%2FA","sourceRelease":"119-100","text":"electric networks;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18724/d/1/B","parentIdentifier":"/us/usc/t42/s18724/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F1%2FB","sourceRelease":"119-100","text":"natural gas networks; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18724/d/1/C","parentIdentifier":"/us/usc/t42/s18724/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F1%2FC","sourceRelease":"119-100","text":"oil exploration, transmission, and delivery networks.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Security and resiliency objective","label":"2 Security and resiliency objective","identifier":"/us/usc/t42/s18724/d/2","parentIdentifier":"/us/usc/t42/s18724/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F2","sourceRelease":"119-100","text":"The objective of the program developed under paragraph (1) is to increase the functional preservation of electric grid operations or natural gas and oil operations in the face of natural and human-made threats and hazards, including electric magnetic pulse and geomagnetic disturbances.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Eligible activities","label":"3 Eligible activities","identifier":"/us/usc/t42/s18724/d/3","parentIdentifier":"/us/usc/t42/s18724/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18724/d/3/A","parentIdentifier":"/us/usc/t42/s18724/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F3%2FA","sourceRelease":"119-100","text":"develop capabilities to identify vulnerabilities and critical components that pose major risks to grid security if destroyed or impaired;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18724/d/3/B","parentIdentifier":"/us/usc/t42/s18724/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F3%2FB","sourceRelease":"119-100","text":"provide modeling at the national level to predict impacts from natural or human-made events;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18724/d/3/C","parentIdentifier":"/us/usc/t42/s18724/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F3%2FC","sourceRelease":"119-100","text":"add physical security to the cybersecurity maturity model;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s18724/d/3/D","parentIdentifier":"/us/usc/t42/s18724/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F3%2FD","sourceRelease":"119-100","text":"conduct exercises and assessments to identify and mitigate vulnerabilities to the electric grid, including providing mitigation recommendations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s18724/d/3/E","parentIdentifier":"/us/usc/t42/s18724/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F3%2FE","sourceRelease":"119-100","text":"conduct research on hardening solutions for critical components of the electric grid;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s18724/d/3/F","parentIdentifier":"/us/usc/t42/s18724/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F3%2FF","sourceRelease":"119-100","text":"conduct research on mitigation and recovery solutions for critical components of the electric grid; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s18724/d/3/G","parentIdentifier":"/us/usc/t42/s18724/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F3%2FG","sourceRelease":"119-100","text":"provide technical assistance to States and other entities for standards and risk analysis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Savings provision","label":"4 Savings provision","identifier":"/us/usc/t42/s18724/d/4","parentIdentifier":"/us/usc/t42/s18724/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F4","sourceRelease":"119-100","text":"Nothing in this section authorizes new regulatory requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Authorization of appropriations","label":"5 Authorization of appropriations","identifier":"/us/usc/t42/s18724/d/5","parentIdentifier":"/us/usc/t42/s18724/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18724%2Fd%2F5","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary to carry out this subsection $50,000,000 for the period of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
