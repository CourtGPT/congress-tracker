{"type":"section","nativeType":"section","number":"3058ff","heading":"Rule of construction","label":"3058ff Rule of construction","identifier":"/us/usc/t42/s3058ff","parentIdentifier":"/us/usc/t42/ch35/schXI/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3058ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s3058ff/1","parentIdentifier":"/us/usc/t42/s3058ff","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3058ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s3058ff/1/A","parentIdentifier":"/us/usc/t42/s3058ff/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3058ff%2F1%2FA","sourceRelease":"119-100","text":"either orally or in writing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s3058ff/1/B","parentIdentifier":"/us/usc/t42/s3058ff/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3058ff%2F1%2FB","sourceRelease":"119-100","text":"with respect to a specific illness or injury that the older individual has at the time of the decision; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s3058ff/1/C","parentIdentifier":"/us/usc/t42/s3058ff/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3058ff%2F1%2FC","sourceRelease":"119-100","text":"when the older individual is competent to make the decision;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s3058ff/2","parentIdentifier":"/us/usc/t42/s3058ff","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3058ff%2F2","sourceRelease":"119-100","text":"is set forth prior to the occurrence of the illness or injury in a living will, health care proxy, or other advance directive document that is validly executed and applied under State law; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s3058ff/3","parentIdentifier":"/us/usc/t42/s3058ff","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs3058ff%2F3","sourceRelease":"119-100","text":"may be unambiguously deduced from the older individual’s life history.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
