{"type":"section","nativeType":"section","number":"3104","heading":"Garnishment","label":"3104 Garnishment","identifier":"/us/usc/t28/s3104","parentIdentifier":"/us/usc/t28/ptVI/ch176/schB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs3104","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective 180 days after , and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see , set out as a note under .Nov. 29, 1990section 3631 of Pub. L. 101–647section 3001 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t28/s3104/a","parentIdentifier":"/us/usc/t28/s3104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs3104%2Fa","sourceRelease":"119-100","text":"If the requirements of section 3101 are satisfied, a court may issue a writ of garnishment against property (excluding earnings) in which the debtor has a substantial nonexempt interest and which is in the possession, custody, or control of a person other than the debtor in order to satisfy a claim for a debt. Co-owned property shall be subject to garnishment to the same extent as co-owned property is subject to garnishment under the law of the State in which such property is located. A court may issue simultaneous separate writs of garnishment to several garnishees. A writ of garnishment issued under this subsection shall be continuing and shall terminate only as provided in section 3205(c)(10).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Writ","label":"b .—Writ","identifier":"/us/usc/t28/s3104/b","parentIdentifier":"/us/usc/t28/s3104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs3104%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t28/s3104/b/1","parentIdentifier":"/us/usc/t28/s3104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs3104%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t28/s3104/b/1/A","parentIdentifier":"/us/usc/t28/s3104/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs3104%2Fb%2F1%2FA","sourceRelease":"119-100","text":"earnings of the debtor shall not be subject to garnishment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t28/s3104/b/1/B","parentIdentifier":"/us/usc/t28/s3104/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs3104%2Fb%2F1%2FB","sourceRelease":"119-100","text":"a reference in such subsections to a judgment debtor shall be deemed to be a reference to a debtor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t28/s3104/b/2","parentIdentifier":"/us/usc/t28/s3104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs3104%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t28/s3104/b/2/A","parentIdentifier":"/us/usc/t28/s3104/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs3104%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the amount of the claim asserted by the United States for a debt; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t28/s3104/b/2/B","parentIdentifier":"/us/usc/t28/s3104/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs3104%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the date the writ is issued.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Limitation","label":"c .—Limitation","identifier":"/us/usc/t28/s3104/c","parentIdentifier":"/us/usc/t28/s3104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs3104%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t28/s3104/c/1","parentIdentifier":"/us/usc/t28/s3104/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs3104%2Fc%2F1","sourceRelease":"119-100","text":"property securing the debt; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t28/s3104/c/2","parentIdentifier":"/us/usc/t28/s3104/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs3104%2Fc%2F2","sourceRelease":"119-100","text":"property attached or in receivership, or income sequestered, under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
