{"type":"section","nativeType":"section","number":"8813","heading":"Subcommittee on Quantum Information Science","label":"8813 Subcommittee on Quantum Information Science","identifier":"/us/usc/t15/s8813","parentIdentifier":"/us/usc/t15/ch114/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813","sourceRelease":"119-100","text":null,"notes":["Termination of SectionFor termination of section, see .section 8815 of this title","Editorial Notes","Amendments2022—Subsec. (h). added subsec. (h).Pub. L. 117–167"],"amendments":["Amendments2022—Subsec. (h). added subsec. (h).Pub. L. 117–167"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t15/s8813/a","parentIdentifier":"/us/usc/t15/s8813","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fa","sourceRelease":"119-100","text":"The President shall establish, through the National Science and Technology Council, the Subcommittee on Quantum Information Science.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Membership","label":"b Membership","identifier":"/us/usc/t15/s8813/b","parentIdentifier":"/us/usc/t15/s8813","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8813/b/1","parentIdentifier":"/us/usc/t15/s8813/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fb%2F1","sourceRelease":"119-100","text":"the National Institute of Standards and Technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8813/b/2","parentIdentifier":"/us/usc/t15/s8813/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fb%2F2","sourceRelease":"119-100","text":"the National Science Foundation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8813/b/3","parentIdentifier":"/us/usc/t15/s8813/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fb%2F3","sourceRelease":"119-100","text":"the Department of Energy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s8813/b/4","parentIdentifier":"/us/usc/t15/s8813/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fb%2F4","sourceRelease":"119-100","text":"the National Aeronautics and Space Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s8813/b/5","parentIdentifier":"/us/usc/t15/s8813/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fb%2F5","sourceRelease":"119-100","text":"the Department of Defense;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s8813/b/6","parentIdentifier":"/us/usc/t15/s8813/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fb%2F6","sourceRelease":"119-100","text":"the Office of the Director of National Intelligence;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t15/s8813/b/7","parentIdentifier":"/us/usc/t15/s8813/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fb%2F7","sourceRelease":"119-100","text":"the Office of Management and Budget;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t15/s8813/b/8","parentIdentifier":"/us/usc/t15/s8813/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fb%2F8","sourceRelease":"119-100","text":"the Office of Science and Technology Policy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t15/s8813/b/9","parentIdentifier":"/us/usc/t15/s8813/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fb%2F9","sourceRelease":"119-100","text":"such other Federal department or agency as the President considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Chairpersons","label":"c Chairpersons","identifier":"/us/usc/t15/s8813/c","parentIdentifier":"/us/usc/t15/s8813","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fc","sourceRelease":"119-100","text":"The Subcommittee shall be jointly chaired by the Director of the National Institute of Standards and Technology, the Director of the National Science Foundation, and the Secretary of Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Responsibilities","label":"d Responsibilities","identifier":"/us/usc/t15/s8813/d","parentIdentifier":"/us/usc/t15/s8813","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8813/d/1","parentIdentifier":"/us/usc/t15/s8813/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fd%2F1","sourceRelease":"119-100","text":"coordinate the quantum information science and technology research, information sharing about international standards development and use, and education activities and programs of the Federal agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8813/d/2","parentIdentifier":"/us/usc/t15/s8813/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fd%2F2","sourceRelease":"119-100","text":"establish goals and priorities of the Program, based on identified knowledge and workforce gaps and other national needs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8813/d/3","parentIdentifier":"/us/usc/t15/s8813/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fd%2F3","sourceRelease":"119-100","text":"assess and recommend Federal infrastructure needs to support the Program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s8813/d/4","parentIdentifier":"/us/usc/t15/s8813/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fd%2F4","sourceRelease":"119-100","text":"assess the status, development, and diversity of the United States quantum information science workforce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s8813/d/5","parentIdentifier":"/us/usc/t15/s8813/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fd%2F5","sourceRelease":"119-100","text":"assess the global outlook for quantum information science research and development efforts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s8813/d/6","parentIdentifier":"/us/usc/t15/s8813/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fd%2F6","sourceRelease":"119-100","text":"evaluate opportunities for international cooperation with strategic allies on research and development in quantum information science and technology; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t15/s8813/d/7","parentIdentifier":"/us/usc/t15/s8813/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fd%2F7","sourceRelease":"119-100","text":"propose a coordinated interagency budget for the Program to the Office of Management and Budget to ensure the maintenance of a balanced quantum information science research portfolio and an appropriate level of research effort.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Strategic plans","label":"e Strategic plans","identifier":"/us/usc/t15/s8813/e","parentIdentifier":"/us/usc/t15/s8813","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8813/e/1","parentIdentifier":"/us/usc/t15/s8813/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fe%2F1","sourceRelease":"119-100","text":"not later than 1 year after , develop a 5-year strategic plan;December 21, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8813/e/2","parentIdentifier":"/us/usc/t15/s8813/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fe%2F2","sourceRelease":"119-100","text":"not later than 6 years after , develop a subsequent 5-year strategic plan; andDecember 21, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8813/e/3","parentIdentifier":"/us/usc/t15/s8813/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fe%2F3","sourceRelease":"119-100","text":"periodically update each plan, as necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Submittal to Congress","label":"f Submittal to Congress","identifier":"/us/usc/t15/s8813/f","parentIdentifier":"/us/usc/t15/s8813","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Ff","sourceRelease":"119-100","text":"The chairpersons of the Subcommittee shall submit to the President, the Advisory Committee, and the appropriate committees of Congress each strategic plan developed under subsection (e) and any updates thereto.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Annual program budget report","label":"g Annual program budget report","identifier":"/us/usc/t15/s8813/g","parentIdentifier":"/us/usc/t15/s8813","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s8813/g/1","parentIdentifier":"/us/usc/t15/s8813/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fg%2F1","sourceRelease":"119-100","text":"Each year, concurrent with the annual budget request submitted by the President to Congress under , the chairpersons of the Subcommittee shall submit to the appropriate committees of Congress and such other committees of Congress as the chairpersons deem appropriate a report on the budget for the Program.section 1105 of title 31","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t15/s8813/g/2","parentIdentifier":"/us/usc/t15/s8813/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fg%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8813/g/2/A","parentIdentifier":"/us/usc/t15/s8813/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fg%2F2%2FA","sourceRelease":"119-100","text":"The budget of the Program for the current fiscal year, for each Federal department and agency described in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8813/g/2/B","parentIdentifier":"/us/usc/t15/s8813/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fg%2F2%2FB","sourceRelease":"119-100","text":"The budget proposed for the Program for the next fiscal year, for each Federal department and agency described in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s8813/g/2/C","parentIdentifier":"/us/usc/t15/s8813/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fg%2F2%2FC","sourceRelease":"119-100","text":"An analysis of the progress made toward achieving the goals and priorities established under subsection (d)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Report on quantum networking and communications","label":"h Report on quantum networking and communications","identifier":"/us/usc/t15/s8813/h","parentIdentifier":"/us/usc/t15/s8813","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s8813/h/1","parentIdentifier":"/us/usc/t15/s8813/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fh%2F1","sourceRelease":"119-100","text":"Not later than , the Quantum Networking Working Group within the Subcommittee on Quantum Information Science of the National Science and Technology Council, in coordination with the Subcommittee on the Economic and Security Implications of Quantum Information Science, shall submit to the appropriate committees of Congress a report detailing a plan for the advancement of quantum networking and communications technology in the United States, building on the report entitled .January 1, 2026A Strategic Vision for America’s Quantum Networks and A Coordinated Approach for Quantum Networking Research","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t15/s8813/h/2","parentIdentifier":"/us/usc/t15/s8813/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fh%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8813/h/2/A","parentIdentifier":"/us/usc/t15/s8813/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fh%2F2%2FA","sourceRelease":"119-100","text":"An update to the report entitled focusing on a framework for interagency collaboration regarding the advancement of quantum networking and communications research.Coordinated Approach to Quantum Networking Research Report","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8813/h/2/B","parentIdentifier":"/us/usc/t15/s8813/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fh%2F2%2FB","sourceRelease":"119-100","text":"A plan for Federal Government partnership with the private sector and interagency collaboration regarding engagement in international standards for quantum networking and communications technology, including a list of Federal priorities for standards relating to such networking and technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s8813/h/2/C","parentIdentifier":"/us/usc/t15/s8813/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fh%2F2%2FC","sourceRelease":"119-100","text":"A proposal for the protection of national security interests relating to the advancement of quantum networking and communications technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s8813/h/2/D","parentIdentifier":"/us/usc/t15/s8813/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fh%2F2%2FD","sourceRelease":"119-100","text":"An assessment of the relative position of the United States with respect to other countries in the global race to develop, demonstrate, and utilize quantum networking and communications technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s8813/h/2/E","parentIdentifier":"/us/usc/t15/s8813/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fh%2F2%2FE","sourceRelease":"119-100","text":"Recommendations to Congress for legislative action relating to the matters considered under subparagraphs (A), (B), (C), and (D).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t15/s8813/h/2/F","parentIdentifier":"/us/usc/t15/s8813/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8813%2Fh%2F2%2FF","sourceRelease":"119-100","text":"Such other matters as the Quantum Network Working Group considers necessary to advance the security of communications and network infrastructure, remain at the forefront of scientific discovery in the quantum information science domain, and transition quantum information science research into the emerging quantum technology economy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
