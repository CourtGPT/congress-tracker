{"type":"section","nativeType":"section","number":"20148","heading":"Railroad car visibility","label":"20148 Railroad car visibility","identifier":"/us/usc/t49/s20148","parentIdentifier":"/us/usc/t49/stV/ptA/ch201/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs20148","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Review of Rules","label":"a .—Review of Rules","identifier":"/us/usc/t49/s20148/a","parentIdentifier":"/us/usc/t49/s20148","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs20148%2Fa","sourceRelease":"119-100","text":"The Secretary of Transportation shall conduct a review of the Department of Transportation’s rules with respect to railroad car visibility. As part of this review, the Secretary shall collect relevant data from operational experience by railroads having enhanced visibility measures in service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Regulations","label":"b .—Regulations","identifier":"/us/usc/t49/s20148/b","parentIdentifier":"/us/usc/t49/s20148","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs20148%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s20148/b/1","parentIdentifier":"/us/usc/t49/s20148/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs20148%2Fb%2F1","sourceRelease":"119-100","text":"visibility of railroad cars from the perspective of nonrailroad traffic;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s20148/b/2","parentIdentifier":"/us/usc/t49/s20148/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs20148%2Fb%2F2","sourceRelease":"119-100","text":"whether certain railroad car paint colors should be prohibited or required;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s20148/b/3","parentIdentifier":"/us/usc/t49/s20148/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs20148%2Fb%2F3","sourceRelease":"119-100","text":"the use of reflective materials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s20148/b/4","parentIdentifier":"/us/usc/t49/s20148/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs20148%2Fb%2F4","sourceRelease":"119-100","text":"the visibility of lettering on railroad cars;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t49/s20148/b/5","parentIdentifier":"/us/usc/t49/s20148/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs20148%2Fb%2F5","sourceRelease":"119-100","text":"the effect of any enhanced visibility measures on the health and safety of train crew members; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t49/s20148/b/6","parentIdentifier":"/us/usc/t49/s20148/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs20148%2Fb%2F6","sourceRelease":"119-100","text":"the cost/benefit ratio of any new regulations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Exclusions","label":"c .—Exclusions","identifier":"/us/usc/t49/s20148/c","parentIdentifier":"/us/usc/t49/s20148","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs20148%2Fc","sourceRelease":"119-100","text":"In prescribing regulations under subsection (b), the Secretary may exclude from any specific visibility requirement any category of trains or railroad operations if the Secretary determines that such an exclusion is in the public interest and is consistent with railroad safety.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
