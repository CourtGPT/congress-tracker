{"type":"section","nativeType":"section","number":"124c","heading":"Coordination with information sharing environment","label":"124c Coordination with information sharing environment","identifier":"/us/usc/t6/s124c","parentIdentifier":"/us/usc/t6/ch1/schII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Guidance","label":"a Guidance","identifier":"/us/usc/t6/s124c/a","parentIdentifier":"/us/usc/t6/s124c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s124c/a/1","parentIdentifier":"/us/usc/t6/s124c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124c%2Fa%2F1","sourceRelease":"119-100","text":"consistent with any policies, guidelines, procedures, instructions, or standards established under ;section 485 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s124c/a/2","parentIdentifier":"/us/usc/t6/s124c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124c%2Fa%2F2","sourceRelease":"119-100","text":"implemented in coordination with, as appropriate, the program manager for the information sharing environment established under that section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s124c/a/3","parentIdentifier":"/us/usc/t6/s124c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124c%2Fa%2F3","sourceRelease":"119-100","text":"consistent with any applicable guidance issued by the Director of National Intelligence; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s124c/a/4","parentIdentifier":"/us/usc/t6/s124c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124c%2Fa%2F4","sourceRelease":"119-100","text":"consistent with any applicable guidance issued by the Secretary relating to the protection of law enforcement information or proprietary information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Consultation","label":"b Consultation","identifier":"/us/usc/t6/s124c/b","parentIdentifier":"/us/usc/t6/s124c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124c%2Fb","sourceRelease":"119-100","text":"In carrying out the duties and responsibilities under this part, the Under Secretary for Intelligence and Analysis shall take into account the views of the heads of the intelligence components of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
