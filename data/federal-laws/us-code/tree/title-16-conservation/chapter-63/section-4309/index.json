{"type":"section","nativeType":"section","number":"4309","heading":"Savings provision","label":"4309 Savings provision","identifier":"/us/usc/t16/s4309","parentIdentifier":"/us/usc/t16/ch63","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4309","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Water","label":"a Water","identifier":"/us/usc/t16/s4309/a","parentIdentifier":"/us/usc/t16/s4309","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4309%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s4309/a/1","parentIdentifier":"/us/usc/t16/s4309/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4309%2Fa%2F1","sourceRelease":"119-100","text":"affect the rights or jurisdiction of the United States, the States, Indian tribes, or other entities over waters of any river or stream or over any ground water resource;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s4309/a/2","parentIdentifier":"/us/usc/t16/s4309/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4309%2Fa%2F2","sourceRelease":"119-100","text":"alter, amend, repeal, interpret, modify, or be in conflict with any interstate compact made by the States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s4309/a/3","parentIdentifier":"/us/usc/t16/s4309/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4309%2Fa%2F3","sourceRelease":"119-100","text":"alter or establish the respective rights of States, the United States, Indian tribes, or any person with respect to any water or water-related right.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Fish and wildlife","label":"b Fish and wildlife","identifier":"/us/usc/t16/s4309/b","parentIdentifier":"/us/usc/t16/s4309","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4309%2Fb","sourceRelease":"119-100","text":"Nothing in this chapter shall be construed as affecting the jurisdiction or responsibilities of the States with respect to fish and wildlife.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
