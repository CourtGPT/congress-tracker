ices to accomplish the goals described in section ___101(1);1So in original. See References in Text note below.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9524/a/1/B","parentIdentifier":"/us/usc/t15/s9524/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fa%2F1%2FB","sourceRelease":"119-100","text":"develop, cultivate, and maintain a network of strategic partnerships with organizations that foster access by minority business enterprises to economic markets, capital, or contracts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9524/a/1/C","parentIdentifier":"/us/usc/t15/s9524/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fa%2F1%2FC","sourceRelease":"119-100","text":"continue to upgrade and modify the services provided by the Center, as necessary, in order to meet the changing and evolving needs of the business community;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s9524/a/1/D","parentIdentifier":"/us/usc/t15/s9524/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fa%2F1%2FD","sourceRelease":"119-100","text":"establish or continue a referral relationship with not less than 1 community-based organization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s9524/a/1/E","parentIdentifier":"/us/usc/t15/s9524/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fa%2F1%2FE","sourceRelease":"119-100","text":"collaborate with other Centers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9524/a/2","parentIdentifier":"/us/usc/t15/s9524/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9524/a/2/A","parentIdentifier":"/us/usc/t15/s9524/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fa%2F2%2FA","sourceRelease":"119-100","text":"operate on a fee-for-service basis; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9524/a/2/B","parentIdentifier":"/us/usc/t15/s9524/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9524/a/2/B/i","parentIdentifier":"/us/usc/t15/s9524/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"client fees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9524/a/2/B/ii","parentIdentifier":"/us/usc/t15/s9524/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"membership fees; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s9524/a/2/B/iii","parentIdentifier":"/us/usc/t15/s9524/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fa%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"any other appropriate fees proposed by the Center in the application submitted by the Center under subsection (e).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Term","label":"b Term","identifier":"/us/usc/t15/s9524/b","parentIdentifier":"/us/usc/t15/s9524","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fb","sourceRelease":"119-100","text":"Subject to subsection (g)(3), the term of an MBDA Business Center agreement shall be not less than 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Financial assistance","label":"c Financial assistance","identifier":"/us/usc/t15/s9524/c","parentIdentifier":"/us/usc/t15/s9524","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t15/s9524/c/1","parentIdentifier":"/us/usc/t15/s9524/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fc%2F1","sourceRelease":"119-100","text":"The amount of financial assistance provided by the Under Secretary under an MBDA Business Center agreement shall be not less than $250,000 for the term of the agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Matching requirement","label":"2 Matching requirement","identifier":"/us/usc/t15/s9524/c/2","parentIdentifier":"/us/usc/t15/s9524/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s9524/c/2/A","parentIdentifier":"/us/usc/t15/s9524/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fc%2F2%2FA","sourceRelease":"119-100","text":"A Center shall match not less than ⅓ of the amount of the financial assistance awarded to the Center under the terms of the applicable MBDA Business Center agreement, unless the Under Secretary determines that a waiver of that requirement is necessary after a demonstration by the Center of a substantial need for that waiver.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Form of funds","label":"B Form of funds","identifier":"/us/usc/t15/s9524/c/2/B","parentIdentifier":"/us/usc/t15/s9524/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9524/c/2/B/i","parentIdentifier":"/us/usc/t15/s9524/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"cash or in-kind contributions, without regard to whether the contribution is made by a third party; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9524/c/2/B/ii","parentIdentifier":"/us/usc/t15/s9524/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"Federal funds received from other Federal programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Use of financial assistance and program income","label":"3 Use of financial assistance and program income","identifier":"/us/usc/t15/s9524/c/3","parentIdentifier":"/us/usc/t15/s9524/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9524/c/3/A","parentIdentifier":"/us/usc/t15/s9524/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fc%2F3%2FA","sourceRelease":"119-100","text":"all financial assistance awarded to the Center under the applicable MBDA Business Center agreement to carry out subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9524/c/3/B","parentIdentifier":"/us/usc/t15/s9524/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9524/c/3/B/i","parentIdentifier":"/us/usc/t15/s9524/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":"to meet the matching requirement under paragraph (2) of this subsection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9524/c/3/B/ii","parentIdentifier":"/us/usc/t15/s9524/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":"if the Center meets the matching requirement under paragraph (2) of this subsection, to carry out subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Criteria for selection","label":"d Criteria for selection","identifier":"/us/usc/t15/s9524/d","parentIdentifier":"/us/usc/t15/s9524","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9524/d/1","parentIdentifier":"/us/usc/t15/s9524/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9524/d/1/A","parentIdentifier":"/us/usc/t15/s9524/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the Under Secretary shall use in determining whether to enter into an MBDA Business Center agreement with an eligible entity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9524/d/1/B","parentIdentifier":"/us/usc/t15/s9524/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fd%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9524/d/1/B/i","parentIdentifier":"/us/usc/t15/s9524/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fd%2F1%2FB%2Fi","sourceRelease":"119-100","text":"an area, the population of which is composed of not less than 51 percent socially or economically disadvantaged individuals, as determined in accordance with data collected by the Bureau of the Census;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9524/d/1/B/ii","parentIdentifier":"/us/usc/t15/s9524/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fd%2F1%2FB%2Fii","sourceRelease":"119-100","text":"a federally recognized area of economic distress; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s9524/d/1/B/iii","parentIdentifier":"/us/usc/t15/s9524/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fd%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"a State that is underserved with respect to the MBDA Business Center Program, as defined by the Under Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9524/d/2","parentIdentifier":"/us/usc/t15/s9524/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9524/d/2/A","parentIdentifier":"/us/usc/t15/s9