{"type":"section","nativeType":"section","number":"287d–2","heading":"Biennial report","label":"287d–2 Biennial report","identifier":"/us/usc/t42/s287d–2","parentIdentifier":"/us/usc/t42/ch6A/schIII/ptF","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs287d%E2%80%932","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s287d–2/a","parentIdentifier":"/us/usc/t42/s287d–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs287d%E2%80%932%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s287d–2/a/1","parentIdentifier":"/us/usc/t42/s287d–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs287d%E2%80%932%2Fa%2F1","sourceRelease":"119-100","text":"describing and evaluating the progress made during the preceding 2 fiscal years in research and treatment conducted or supported by the National Institutes of Health;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s287d–2/a/2","parentIdentifier":"/us/usc/t42/s287d–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs287d%E2%80%932%2Fa%2F2","sourceRelease":"119-100","text":"describing and analyzing the professional status of women physicians and scientists of such Institutes, including the identification of problems and barriers regarding advancements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s287d–2/a/3","parentIdentifier":"/us/usc/t42/s287d–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs287d%E2%80%932%2Fa%2F3","sourceRelease":"119-100","text":"summarizing and analyzing expenditures made by the agencies of such Institutes (and by such Office) during the preceding 2 fiscal years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s287d–2/a/4","parentIdentifier":"/us/usc/t42/s287d–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs287d%E2%80%932%2Fa%2F4","sourceRelease":"119-100","text":"making such recommendations for legislative and administrative initiatives as the Director of the Office determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Inclusion in biennial report of Director of NIH","label":"b Inclusion in biennial report of Director of NIH","identifier":"/us/usc/t42/s287d–2/b","parentIdentifier":"/us/usc/t42/s287d–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs287d%E2%80%932%2Fb","sourceRelease":"119-100","text":"The Director of the Office shall submit each report prepared under subsection (a) to the Director of NIH for inclusion in the report submitted to the President and the Congress under .section 283 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
