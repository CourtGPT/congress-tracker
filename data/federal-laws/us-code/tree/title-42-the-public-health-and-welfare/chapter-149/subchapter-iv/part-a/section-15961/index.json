{"type":"section","nativeType":"section","number":"15961","heading":"Authorization of appropriations","label":"15961 Authorization of appropriations","identifier":"/us/usc/t42/s15961","parentIdentifier":"/us/usc/t42/ch149/schIV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15961","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Clean coal power initiative","label":"a Clean coal power initiative","identifier":"/us/usc/t42/s15961/a","parentIdentifier":"/us/usc/t42/s15961","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15961%2Fa","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Secretary to carry out the activities authorized by this part $200,000,000 for each of fiscal years 2006 through 2014, to remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report","label":"b Report","identifier":"/us/usc/t42/s15961/b","parentIdentifier":"/us/usc/t42/s15961","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15961%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15961/b/1","parentIdentifier":"/us/usc/t42/s15961/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15961%2Fb%2F1","sourceRelease":"119-100","text":"a detailed assessment of whether the aggregate funding levels provided under subsection (a) are the appropriate funding levels for that program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15961/b/2","parentIdentifier":"/us/usc/t42/s15961/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15961%2Fb%2F2","sourceRelease":"119-100","text":"a detailed description of how proposals will be solicited and evaluated, including a list of all activities expected to be undertaken;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s15961/b/3","parentIdentifier":"/us/usc/t42/s15961/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15961%2Fb%2F3","sourceRelease":"119-100","text":"a detailed list of technical milestones for each coal and related technology that will be pursued; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s15961/b/4","parentIdentifier":"/us/usc/t42/s15961/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15961%2Fb%2F4","sourceRelease":"119-100","text":"a detailed description of how the program will avoid problems enumerated in Government Accountability Office reports on the Clean Coal Technology Program, including problems that have resulted in unspent funds and projects that failed either financially or scientifically.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
