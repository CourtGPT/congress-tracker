{"type":"section","nativeType":"section","number":"3994","heading":"Eligible programs","label":"3994 Eligible programs","identifier":"/us/usc/t20/s3994","parentIdentifier":"/us/usc/t20/ch52/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3994","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t20/s3994/a","parentIdentifier":"/us/usc/t20/s3994","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3994%2Fa","sourceRelease":"119-100","text":"A State may use funds from grants received in any fiscal year under this part for elementary and secondary programs described in this section. The State educational agency shall administer such funds, which shall be awarded to such programs on a competitive basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Use of funds","label":"b Use of funds","identifier":"/us/usc/t20/s3994/b","parentIdentifier":"/us/usc/t20/s3994","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3994%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Improvement of elementary and secondary resources","label":"1 Improvement of elementary and secondary resources","identifier":"/us/usc/t20/s3994/b/1","parentIdentifier":"/us/usc/t20/s3994/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3994%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s3994/b/1/A","parentIdentifier":"/us/usc/t20/s3994/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3994%2Fb%2F1%2FA","sourceRelease":"119-100","text":"improve instruction in mathematics and science education at the elementary and secondary level;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s3994/b/1/B","parentIdentifier":"/us/usc/t20/s3994/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3994%2Fb%2F1%2FB","sourceRelease":"119-100","text":"improve laboratory facilities, classroom and library resources in elementary and secondary mathematics and science education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s3994/b/1/C","parentIdentifier":"/us/usc/t20/s3994/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3994%2Fb%2F1%2FC","sourceRelease":"119-100","text":"attract matching dollars and in kind contributions of equipment, learning resources or shared time from business concerns, libraries, museums, nonprofit private organizations, professional mathematics and scientific associations, and appropriate State agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Advanced placement programs","label":"2 Advanced placement programs","identifier":"/us/usc/t20/s3994/b/2","parentIdentifier":"/us/usc/t20/s3994/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3994%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s3994/b/2/A","parentIdentifier":"/us/usc/t20/s3994/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3994%2Fb%2F2%2FA","sourceRelease":"119-100","text":"Such funds may be used for advanced placement programs operated by local educational agencies that are designed to allow qualified secondary students to attend college preparatory schools, colleges, or universities on a part-time or full-time basis with respect to science and mathematics instruction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s3994/b/2/B","parentIdentifier":"/us/usc/t20/s3994/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3994%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s3994/b/2/B/i","parentIdentifier":"/us/usc/t20/s3994/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3994%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the number of students participating in the program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s3994/b/2/B/ii","parentIdentifier":"/us/usc/t20/s3994/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3994%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the instruction time such students receive under the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
