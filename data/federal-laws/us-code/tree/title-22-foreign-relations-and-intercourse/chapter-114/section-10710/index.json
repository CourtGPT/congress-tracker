2%2Fs10710%2Fb%2F1%2FC","sourceRelease":"119-100","text":"to manipulate the information environment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10710/b/2","parentIdentifier":"/us/usc/t22/s10710/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10710%2Fb%2F2","sourceRelease":"119-100","text":"the activities and roles of the Department of State and other relevant Federal agencies in countering Russian and Chinese malign influence operations and campaigns;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s10710/b/3","parentIdentifier":"/us/usc/t22/s10710/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10710%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10710/b/3/A","parentIdentifier":"/us/usc/t22/s10710/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10710%2Fb%2F3%2FA","sourceRelease":"119-100","text":"each network, entity and individual, to the extent such information is available, of Russia, China, or any other country with which Russia or China may cooperate, that is supporting such Russian or Chinese malign influence operations or campaigns, including the provision of financial or operational support to activities in a Western Balkans country that may limit freedom of speech or create barriers of access to democratic processes, including exercising the right to vote in a free and fair election; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10710/b/3/B","parentIdentifier":"/us/usc/t22/s10710/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10710%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Form","label":"c Form","identifier":"/us/usc/t22/s10710/c","parentIdentifier":"/us/usc/t22/s10710","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10710%2Fc","sourceRelease":"119-100","text":"Each report required under subsection (a) shall be submitted in unclassified form, but may include a classified annex.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
