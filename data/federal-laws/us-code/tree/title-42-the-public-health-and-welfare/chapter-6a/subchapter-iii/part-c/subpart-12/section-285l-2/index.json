{"type":"section","nativeType":"section","number":"285l–2","heading":"Definitions","label":"285l–2 Definitions","identifier":"/us/usc/t42/s285l–2","parentIdentifier":"/us/usc/t42/ch6A/schIII/ptC/spt12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%932","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the ICCVAM Authorization Act of 2000, and not as part of the Public Health Service Act which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Alternative test method","label":"1 Alternative test method","identifier":"/us/usc/t42/s285l–2/1","parentIdentifier":"/us/usc/t42/s285l–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%932%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s285l–2/1/A","parentIdentifier":"/us/usc/t42/s285l–2/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%932%2F1%2FA","sourceRelease":"119-100","text":"includes any new or revised test method; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s285l–2/1/B","parentIdentifier":"/us/usc/t42/s285l–2/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%932%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s285l–2/1/B/i","parentIdentifier":"/us/usc/t42/s285l–2/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%932%2F1%2FB%2Fi","sourceRelease":"119-100","text":"reduces the number of animals required;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s285l–2/1/B/ii","parentIdentifier":"/us/usc/t42/s285l–2/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%932%2F1%2FB%2Fii","sourceRelease":"119-100","text":"refines procedures to lessen or eliminate pain or distress to animals, or enhances animal well-being; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s285l–2/1/B/iii","parentIdentifier":"/us/usc/t42/s285l–2/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%932%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"replaces animals with non-animal systems or one animal species with a phylogenetically lower animal species, such as replacing a mammal with an invertebrate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"ICCVAM test recommendation","label":"2 ICCVAM test recommendation","identifier":"/us/usc/t42/s285l–2/2","parentIdentifier":"/us/usc/t42/s285l–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285l%E2%80%932%2F2","sourceRelease":"119-100","text":"The term “ICCVAM test recommendation” means a summary report prepared by the ICCVAM characterizing the results of a scientific expert peer review of a test method.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
