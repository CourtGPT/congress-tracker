{"type":"section","nativeType":"section","number":"1093","heading":"Definitions","label":"1093 Definitions","identifier":"/us/usc/t18/s1093","parentIdentifier":"/us/usc/t18/ptI/ch50A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1093","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s1093/1","parentIdentifier":"/us/usc/t18/s1093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1093%2F1","sourceRelease":"119-100","text":"the term “children” means the plural and means individuals who have not attained the age of eighteen years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s1093/2","parentIdentifier":"/us/usc/t18/s1093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1093%2F2","sourceRelease":"119-100","text":"the term “ethnic group” means a set of individuals whose identity as such is distinctive in terms of common cultural traditions or heritage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t18/s1093/3","parentIdentifier":"/us/usc/t18/s1093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1093%2F3","sourceRelease":"119-100","text":"the term “incites” means urges another to engage imminently in conduct in circumstances under which there is a substantial likelihood of imminently causing such conduct;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t18/s1093/4","parentIdentifier":"/us/usc/t18/s1093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1093%2F4","sourceRelease":"119-100","text":"the term “members” means the plural;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t18/s1093/5","parentIdentifier":"/us/usc/t18/s1093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1093%2F5","sourceRelease":"119-100","text":"the term “national group” means a set of individuals whose identity as such is distinctive in terms of nationality or national origins;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t18/s1093/6","parentIdentifier":"/us/usc/t18/s1093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1093%2F6","sourceRelease":"119-100","text":"the term “racial group” means a set of individuals whose identity as such is distinctive in terms of physical characteristics or biological descent;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t18/s1093/7","parentIdentifier":"/us/usc/t18/s1093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1093%2F7","sourceRelease":"119-100","text":"the term “religious group” means a set of individuals whose identity as such is distinctive in terms of common religious creed, beliefs, doctrines, practices, or rituals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t18/s1093/8","parentIdentifier":"/us/usc/t18/s1093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs1093%2F8","sourceRelease":"119-100","text":"the term “substantial part” means a part of a group of such numerical significance that the destruction or loss of that part would cause the destruction of the group as a viable entity within the nation of which such group is a part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
