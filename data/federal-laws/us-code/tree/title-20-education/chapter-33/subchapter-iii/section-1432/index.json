ists;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xi","heading":null,"label":"xi","identifier":"/us/usc/t20/s1432/4/F/xi","parentIdentifier":"/us/usc/t20/s1432/4/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FF%2Fxi","sourceRelease":"119-100","text":"orientation and mobility specialists; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xii","heading":null,"label":"xii","identifier":"/us/usc/t20/s1432/4/F/xii","parentIdentifier":"/us/usc/t20/s1432/4/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FF%2Fxii","sourceRelease":"119-100","text":"pediatricians and other physicians;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t20/s1432/4/G","parentIdentifier":"/us/usc/t20/s1432/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FG","sourceRelease":"119-100","text":"to the maximum extent appropriate, are provided in natural environments, including the home, and community settings in which children without disabilities participate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t20/s1432/4/H","parentIdentifier":"/us/usc/t20/s1432/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1432%2F4%2FH","sourceRelease":"119-100","text":"are provided in conformity with an individualized family service plan adopted in accordance with .section 1436 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Infant or toddler with a disability","label":"5 Infant or 