{"type":"section","nativeType":"section","number":"3117","heading":"Notice of counterintelligence assessments and investigations of Federal candidates or officeholders","label":"3117 Notice of counterintelligence assessments and investigations of Federal candidates or officeholders","identifier":"/us/usc/t50/s3117","parentIdentifier":"/us/usc/t50/ch44/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Notice","label":"a Notice","identifier":"/us/usc/t50/s3117/a","parentIdentifier":"/us/usc/t50/s3117","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Notice required","label":"1 Notice required","identifier":"/us/usc/t50/s3117/a/1","parentIdentifier":"/us/usc/t50/s3117/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3117/a/1/A","parentIdentifier":"/us/usc/t50/s3117/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fa%2F1%2FA","sourceRelease":"119-100","text":"a candidate for Federal office; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3117/a/1/B","parentIdentifier":"/us/usc/t50/s3117/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fa%2F1%2FB","sourceRelease":"119-100","text":"a holder of Federal office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t50/s3117/a/2","parentIdentifier":"/us/usc/t50/s3117/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3117/a/2/A","parentIdentifier":"/us/usc/t50/s3117/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fa%2F2%2FA","sourceRelease":"119-100","text":"a summary of the relevant facts associated with the counterintelligence assessment or investigation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3117/a/2/B","parentIdentifier":"/us/usc/t50/s3117/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the identity of such individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Exception","label":"3 Exception","identifier":"/us/usc/t50/s3117/a/3","parentIdentifier":"/us/usc/t50/s3117/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fa%2F3","sourceRelease":"119-100","text":"The Director may refrain from providing a notice under paragraph (1) to an individual who is otherwise a recipient of notices under such paragraph if that individual is a target of the counterintelligence assessment or investigation covered by the notice.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Timing","label":"b Timing","identifier":"/us/usc/t50/s3117/b","parentIdentifier":"/us/usc/t50/s3117","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fb","sourceRelease":"119-100","text":"The Director shall provide each notice under subsection (a) not later than 15 days after the date of the commencement of the counterintelligence assessment or investigation that is the subject of such notice. With respect to counterintelligence assessments or investigations that commenced before and are ongoing as of , the Director shall provide each notice under subsection (a) not later than 15 days after .December 18, 2025December 18, 2025December 18, 2025","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Definitions","label":"c Definitions","identifier":"/us/usc/t50/s3117/c","parentIdentifier":"/us/usc/t50/s3117","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3117/c/1","parentIdentifier":"/us/usc/t50/s3117/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3117/c/1/A","parentIdentifier":"/us/usc/t50/s3117/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the congressional intelligence committees; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3117/c/1/B","parentIdentifier":"/us/usc/t50/s3117/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fc%2F1%2FB","sourceRelease":"119-100","text":"the Committees on the Judiciary of the House of Representatives and the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3117/c/2","parentIdentifier":"/us/usc/t50/s3117/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3117%2Fc%2F2","sourceRelease":"119-100","text":"The terms “candidate” and “Federal office” have the meanings given those terms in .section 30101 of title 52","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
