"/us/usc/t10/s8695/c/2/G","parentIdentifier":"/us/usc/t10/s8695/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fc%2F2%2FG","sourceRelease":"119-100","text":"Combat logistics force.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t10/s8695/c/2/H","parentIdentifier":"/us/usc/t10/s8695/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fc%2F2%2FH","sourceRelease":"119-100","text":"Expeditionary fast transport.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t10/s8695/c/2/I","parentIdentifier":"/us/usc/t10/s8695/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fc%2F2%2FI","sourceRelease":"119-100","text":"Expeditionary support base.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t10/s8695/c/2/J","parentIdentifier":"/us/usc/t10/s8695/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fc%2F2%2FJ","sourceRelease":"119-100","text":"Command and support.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"K","heading":null,"label":"K","identifier":"/us/usc/t10/s8695/c/2/K","parentIdentifier":"/us/usc/t10/s8695/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fc%2F2%2FK","sourceRelease":"119-100","text":"Other.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Definitions","label":"d .—Definitions","identifier":"/us/usc/t10/s8695/d","parentIdentifier":"/us/usc/t10/s8695","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s8695/d/1","parentIdentifier":"/us/usc/t10/s8695/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8695/d/1/A","parentIdentifier":"/us/usc/t10/s8695/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fd%2F1%2FA","sourceRelease":"119-100","text":"A commissioned United States Ship warship capable of contributing to combat operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8695/d/1/B","parentIdentifier":"/us/usc/t10/s8695/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fd%2F1%2FB","sourceRelease":"119-100","text":"A United States Naval Ship that contributes directly to Navy warfighting or support missions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s8695/d/2","parentIdentifier":"/us/usc/t10/s8695/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8695/d/2/A","parentIdentifier":"/us/usc/t10/s8695/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fd%2F2%2FA","sourceRelease":"119-100","text":"Strategic guidance that results in changes to theater campaign plans or warfighting scenarios.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8695/d/2/B","parentIdentifier":"/us/usc/t10/s8695/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fd%2F2%2FB","sourceRelease":"119-100","text":"Strategic laydown of vessels or aircraft that affects sustainable peacetime presence or warfighting response timelines.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s8695/d/2/C","parentIdentifier":"/us/usc/t10/s8695/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fd%2F2%2FC","sourceRelease":"119-100","text":"Operating concepts, including employment cycles, crewing constructs, or operational tempo limits, that affect peacetime presence or warfighting response timelines.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s8695/d/2/D","parentIdentifier":"/us/usc/t10/s8695/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fd%2F2%2FD","sourceRelease":"119-100","text":"Assigned missions that affect the type or quantity of force elements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Responsibilities of Commandant of Marine Corps","label":"e .—Responsibilities of Commandant of Marine Corps","identifier":"/us/usc/t10/s8695/e","parentIdentifier":"/us/usc/t10/s8695","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8695%2Fe","sourceRelease":"119-100","text":"In preparing each assessment and requirement under subsection (a), the Commandant of the Marine Corps shall be specifically responsible for developing the requirements relating to amphibious warfare ships and for naval vessels with the primary mission of transporting Marines.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
