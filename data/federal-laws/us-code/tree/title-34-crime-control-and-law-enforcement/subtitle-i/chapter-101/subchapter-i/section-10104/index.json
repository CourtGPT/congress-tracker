{"type":"section","nativeType":"section","number":"10104","heading":"Weed and Seed strategies","label":"10104 Weed and Seed strategies","identifier":"/us/usc/t34/s10104","parentIdentifier":"/us/usc/t34/stI/ch101/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to , The Public Health and Welfare, prior to editorial reclassification and renumbering as this section.section 3712b of Title 42","Statutory Notes and Related Subsidiaries","Effective DateSection effective with respect to appropriations for fiscal year 2007 and for each fiscal year thereafter, see , set out as a note under .section 1121(c) of Pub. L. 109–162section 10103 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t34/s10104/a","parentIdentifier":"/us/usc/t34/s10104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Weeding","label":"1 Weeding","identifier":"/us/usc/t34/s10104/a/1","parentIdentifier":"/us/usc/t34/s10104/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fa%2F1","sourceRelease":"119-100","text":"Activities, to be known as Weeding activities, which shall include promoting and coordinating a broad spectrum of community efforts (especially those of law enforcement agencies and prosecutors) to arrest, and to sanction or incarcerate, persons in that community who participate or engage in violent crime, criminal drug-related activity, and other crimes that threaten the quality of life in that community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Seeding","label":"2 Seeding","identifier":"/us/usc/t34/s10104/a/2","parentIdentifier":"/us/usc/t34/s10104/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s10104/a/2/A","parentIdentifier":"/us/usc/t34/s10104/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fa%2F2%2FA","sourceRelease":"119-100","text":"human services, relating to prevention, intervention, or treatment, for at-risk individuals and families; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s10104/a/2/B","parentIdentifier":"/us/usc/t34/s10104/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fa%2F2%2FB","sourceRelease":"119-100","text":"community revitalization efforts, including enforcement of building codes and development of the economy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Guidelines","label":"b Guidelines","identifier":"/us/usc/t34/s10104/b","parentIdentifier":"/us/usc/t34/s10104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s10104/b/1","parentIdentifier":"/us/usc/t34/s10104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s10104/b/1/A","parentIdentifier":"/us/usc/t34/s10104/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s10104/b/1/A/i","parentIdentifier":"/us/usc/t34/s10104/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"appropriate law enforcement agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s10104/b/1/A/ii","parentIdentifier":"/us/usc/t34/s10104/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"other public and private agencies, and neighborhood and community-based organizations, interested in criminal justice and community-based development and revitalization in the community; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s10104/b/1/B","parentIdentifier":"/us/usc/t34/s10104/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s10104/b/1/B/i","parentIdentifier":"/us/usc/t34/s10104/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the Drug Enforcement Administration’s special agent in charge for the jurisdiction encompassing the community; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s10104/b/1/B/ii","parentIdentifier":"/us/usc/t34/s10104/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the United States Attorney for the District encompassing the community;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s10104/b/2","parentIdentifier":"/us/usc/t34/s10104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fb%2F2","sourceRelease":"119-100","text":"describe how law enforcement agencies, other public and private agencies, neighborhood and community-based organizations, and interested citizens are to cooperate in implementing the strategy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s10104/b/3","parentIdentifier":"/us/usc/t34/s10104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fb%2F3","sourceRelease":"119-100","text":"incorporate a community-policing component that shall serve as a bridge between the Weeding activities under subsection (a)(1) and the Seeding activities under subsection (a)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Designation","label":"c Designation","identifier":"/us/usc/t34/s10104/c","parentIdentifier":"/us/usc/t34/s10104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s10104/c/1","parentIdentifier":"/us/usc/t34/s10104/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s10104/c/1/A","parentIdentifier":"/us/usc/t34/s10104/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the community suffers from consistently high levels of crime or otherwise is appropriate for such designation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s10104/c/1/B","parentIdentifier":"/us/usc/t34/s10104/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fc%2F1%2FB","sourceRelease":"119-100","text":"the Weed and Seed strategy proposed, adopted, or implemented by the steering committee has a high probability of improving the criminal justice system within the community and contains all the elements required by the Director; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s10104/c/1/C","parentIdentifier":"/us/usc/t34/s10104/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fc%2F1%2FC","sourceRelease":"119-100","text":"the steering committee is capable of implementing the strategy appropriately; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s10104/c/2","parentIdentifier":"/us/usc/t34/s10104/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fc%2F2","sourceRelease":"119-100","text":"the community must agree to formulate a timely and effective plan to independently sustain the strategy (or, at a minimum, a majority of the best practices of the strategy) when assistance under this section is no longer available.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Application","label":"d Application","identifier":"/us/usc/t34/s10104/d","parentIdentifier":"/us/usc/t34/s10104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s10104/d/1","parentIdentifier":"/us/usc/t34/s10104/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s10104/d/1/A","parentIdentifier":"/us/usc/t34/s10104/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fd%2F1%2FA","sourceRelease":"119-100","text":"the active involvement of the United States Attorney for the District encompassing the community, the Drug Enforcement Administration’s special agent in charge for the jurisdiction encompassing the community, and other Federal law enforcement agencies operating in the vicinity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s10104/d/1/B","parentIdentifier":"/us/usc/t34/s10104/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fd%2F1%2FB","sourceRelease":"119-100","text":"a significant community-oriented policing component; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s10104/d/1/C","parentIdentifier":"/us/usc/t34/s10104/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fd%2F1%2FC","sourceRelease":"119-100","text":"demonstrated coordination with complementary neighborhood and community-based programs and initiatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s10104/d/2","parentIdentifier":"/us/usc/t34/s10104/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fd%2F2","sourceRelease":"119-100","text":"a methodology with outcome measures and specific objective indicia of performance to be used to evaluate the effectiveness of the strategy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Grants","label":"e Grants","identifier":"/us/usc/t34/s10104/e","parentIdentifier":"/us/usc/t34/s10104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t34/s10104/e/1","parentIdentifier":"/us/usc/t34/s10104/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F1","sourceRelease":"119-100","text":"In implementing a strategy for a community under subsection (a), the Director may make grants to that community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Uses","label":"2 Uses","identifier":"/us/usc/t34/s10104/e/2","parentIdentifier":"/us/usc/t34/s10104/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F2","sourceRelease":"119-100","text":"For each grant under this subsection, the community receiving that grant may not use any of the grant amounts for construction, except that the Assistant Attorney General may authorize use of grant amounts for incidental or minor construction, renovation, or remodeling.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Limitations","label":"3 Limitations","identifier":"/us/usc/t34/s10104/e/3","parentIdentifier":"/us/usc/t34/s10104/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s10104/e/3/A","parentIdentifier":"/us/usc/t34/s10104/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F3%2FA","sourceRelease":"119-100","text":"for a period of more than 10 fiscal years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s10104/e/3/B","parentIdentifier":"/us/usc/t34/s10104/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F3%2FB","sourceRelease":"119-100","text":"for more than 5 separate fiscal years, except that the Assistant Attorney General may, in single increments and only upon a showing of extraordinary circumstances, authorize grants for not more than 3 additional separate fiscal years; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s10104/e/3/C","parentIdentifier":"/us/usc/t34/s10104/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F3%2FC","sourceRelease":"119-100","text":"in an aggregate amount of more than $1,000,000, except that the Assistant Attorney General may, upon a showing of extraordinary circumstances, authorize grants for not more than an additional $500,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Distribution","label":"4 Distribution","identifier":"/us/usc/t34/s10104/e/4","parentIdentifier":"/us/usc/t34/s10104/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s10104/e/4/A","parentIdentifier":"/us/usc/t34/s10104/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F4%2FA","sourceRelease":"119-100","text":"to the extent practicable, the distribution of such grants is geographically equitable and includes both urban and rural areas of varying population and area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s10104/e/4/B","parentIdentifier":"/us/usc/t34/s10104/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F4%2FB","sourceRelease":"119-100","text":"priority is given to communities that clearly and effectively coordinate crime prevention programs with other Federal programs in a manner that addresses the overall needs of such communities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Federal share","label":"5 Federal share","identifier":"/us/usc/t34/s10104/e/5","parentIdentifier":"/us/usc/t34/s10104/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s10104/e/5/A","parentIdentifier":"/us/usc/t34/s10104/e/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F5%2FA","sourceRelease":"119-100","text":"Subject to subparagraph (B), the Federal share of a grant under this subsection may not exceed 75 percent of the total costs of the projects described in the application for which the grant was made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s10104/e/5/B","parentIdentifier":"/us/usc/t34/s10104/e/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F5%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s10104/e/5/B/i","parentIdentifier":"/us/usc/t34/s10104/e/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F5%2FB%2Fi","sourceRelease":"119-100","text":"may be satisfied in cash or in kind; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s10104/e/5/B/ii","parentIdentifier":"/us/usc/t34/s10104/e/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F5%2FB%2Fii","sourceRelease":"119-100","text":"may be waived by the Assistant Attorney General upon a determination that the financial circumstances affecting the applicant warrant a finding that such a waiver is equitable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Supplement, not supplant","label":"6 Supplement, not supplant","identifier":"/us/usc/t34/s10104/e/6","parentIdentifier":"/us/usc/t34/s10104/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs10104%2Fe%2F6","sourceRelease":"119-100","text":"To receive a grant under this subsection, the applicant must provide assurances that the amounts received under the grant shall be used to supplement, not supplant, non-Federal funds that would otherwise be available for programs or services provided in the community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
