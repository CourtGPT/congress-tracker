{"type":"section","nativeType":"section","number":"300j–19d","heading":"Review of technologies","label":"300j–19d Review of technologies","identifier":"/us/usc/t42/s300j–19d","parentIdentifier":"/us/usc/t42/ch6A/schXII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Review","label":"a Review","identifier":"/us/usc/t42/s300j–19d/a","parentIdentifier":"/us/usc/t42/s300j–19d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300j–19d/a/1","parentIdentifier":"/us/usc/t42/s300j–19d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d%2Fa%2F1","sourceRelease":"119-100","text":"ensure the physical integrity of community water systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300j–19d/a/2","parentIdentifier":"/us/usc/t42/s300j–19d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d%2Fa%2F2","sourceRelease":"119-100","text":"prevent, detect, and respond to any contaminant for which a national primary drinking water regulation has been promulgated in community water systems and source water for community water systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300j–19d/a/3","parentIdentifier":"/us/usc/t42/s300j–19d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d%2Fa%2F3","sourceRelease":"119-100","text":"allow for use of alternate drinking water supplies from nontraditional sources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s300j–19d/a/4","parentIdentifier":"/us/usc/t42/s300j–19d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d%2Fa%2F4","sourceRelease":"119-100","text":"facilitate source water assessment and protection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Inclusions","label":"b Inclusions","identifier":"/us/usc/t42/s300j–19d/b","parentIdentifier":"/us/usc/t42/s300j–19d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300j–19d/b/1","parentIdentifier":"/us/usc/t42/s300j–19d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d%2Fb%2F1","sourceRelease":"119-100","text":"that are used for corrosion protection, metering, leak detection, or protection against water loss;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300j–19d/b/2","parentIdentifier":"/us/usc/t42/s300j–19d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d%2Fb%2F2","sourceRelease":"119-100","text":"that are intelligent systems, including hardware, software, or other technology, used to assist in protection and detection described in paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300j–19d/b/3","parentIdentifier":"/us/usc/t42/s300j–19d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d%2Fb%2F3","sourceRelease":"119-100","text":"that are point-of-use devices or point-of-entry devices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s300j–19d/b/4","parentIdentifier":"/us/usc/t42/s300j–19d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d%2Fb%2F4","sourceRelease":"119-100","text":"that are physical or electronic systems that monitor, or assist in monitoring, contaminants in drinking water in real-time; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s300j–19d/b/5","parentIdentifier":"/us/usc/t42/s300j–19d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d%2Fb%2F5","sourceRelease":"119-100","text":"that allow for the use of nontraditional sources for drinking water, including physical separation and chemical and biological transformation technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Availability","label":"c Availability","identifier":"/us/usc/t42/s300j–19d/c","parentIdentifier":"/us/usc/t42/s300j–19d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d%2Fc","sourceRelease":"119-100","text":"The Administrator shall make the results of the review under subsection (a) available to the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s300j–19d/d","parentIdentifier":"/us/usc/t42/s300j–19d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319d%2Fd","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Administrator to carry out this section $10,000,000 for fiscal year 2019, which shall remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
