{"type":"section","nativeType":"section","number":"3122","heading":"Longitudinal study of vocational rehabilitation programs","label":"3122 Longitudinal study of vocational rehabilitation programs","identifier":"/us/usc/t38/s3122","parentIdentifier":"/us/usc/t38/ptIII/ch31","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Study Required","label":"a .—Study Required","identifier":"/us/usc/t38/s3122/a","parentIdentifier":"/us/usc/t38/s3122","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s3122/a/1","parentIdentifier":"/us/usc/t38/s3122/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fa%2F1","sourceRelease":"119-100","text":"Subject to the availability of appropriated funds, the Secretary shall conduct a longitudinal study of a statistically valid sample of each of the groups of individuals described in paragraph (2). The Secretary shall study each such group over a period of at least 20 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s3122/a/2","parentIdentifier":"/us/usc/t38/s3122/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s3122/a/2/A","parentIdentifier":"/us/usc/t38/s3122/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fa%2F2%2FA","sourceRelease":"119-100","text":"Individuals who begin participating in a vocational rehabilitation program under this chapter during fiscal year 2010.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s3122/a/2/B","parentIdentifier":"/us/usc/t38/s3122/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fa%2F2%2FB","sourceRelease":"119-100","text":"Individuals who begin participating in such a program during fiscal year 2012.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s3122/a/2/C","parentIdentifier":"/us/usc/t38/s3122/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fa%2F2%2FC","sourceRelease":"119-100","text":"Individuals who begin participating in such a program during fiscal year 2014.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Annual Reports","label":"b .—Annual Reports","identifier":"/us/usc/t38/s3122/b","parentIdentifier":"/us/usc/t38/s3122","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fb","sourceRelease":"119-100","text":"By not later than July 1 of each year covered by the study required under subsection (a), the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a report on the study during the preceding year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Contents of Report","label":"c .—Contents of Report","identifier":"/us/usc/t38/s3122/c","parentIdentifier":"/us/usc/t38/s3122","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s3122/c/1","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F1","sourceRelease":"119-100","text":"The number of individuals participating in vocational rehabilitation programs under this chapter who suspended participation in such a program during the year covered by the report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s3122/c/2","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F2","sourceRelease":"119-100","text":"The average number of months such individuals served on active duty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s3122/c/3","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F3","sourceRelease":"119-100","text":"The distribution of disability ratings of such individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s3122/c/4","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F4","sourceRelease":"119-100","text":"The types of other benefits administered by the Secretary received by such individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t38/s3122/c/5","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F5","sourceRelease":"119-100","text":"The types of social security benefits received by such individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t38/s3122/c/6","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F6","sourceRelease":"119-100","text":"Any unemployment benefits received by such individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t38/s3122/c/7","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F7","sourceRelease":"119-100","text":"The average number of months such individuals were employed during the year covered by the report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t38/s3122/c/8","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F8","sourceRelease":"119-100","text":"The average annual starting and ending salaries of such individuals who were employed during the year covered by the report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t38/s3122/c/9","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F9","sourceRelease":"119-100","text":"The number of such individuals enrolled in an institution of higher learning, as that term is defined in .section 3452(f) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t38/s3122/c/10","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F10","sourceRelease":"119-100","text":"The average number of academic credit hours, degrees, and certificates obtained by such individuals during the year covered by the report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t38/s3122/c/11","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F11","sourceRelease":"119-100","text":"The average number of visits such individuals made to Department medical facilities during the year covered by the report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t38/s3122/c/12","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F12","sourceRelease":"119-100","text":"The average number of visits such individuals made to non-Department medical facilities during the year covered by the report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"13","heading":null,"label":"13","identifier":"/us/usc/t38/s3122/c/13","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F13","sourceRelease":"119-100","text":"The average annual income of such individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"14","heading":null,"label":"14","identifier":"/us/usc/t38/s3122/c/14","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F14","sourceRelease":"119-100","text":"The average total household income of such individuals for the year covered by the report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"15","heading":null,"label":"15","identifier":"/us/usc/t38/s3122/c/15","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F15","sourceRelease":"119-100","text":"The percentage of such individuals who own their principal residences.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"16","heading":null,"label":"16","identifier":"/us/usc/t38/s3122/c/16","parentIdentifier":"/us/usc/t38/s3122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs3122%2Fc%2F16","sourceRelease":"119-100","text":"The average number of dependents of each such veteran.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
