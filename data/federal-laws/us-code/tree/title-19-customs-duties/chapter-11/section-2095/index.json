{"type":"section","nativeType":"section","number":"2095","heading":"Definitions","label":"2095 Definitions","identifier":"/us/usc/t19/s2095","parentIdentifier":"/us/usc/t19/ch11","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2095","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s2095/1","parentIdentifier":"/us/usc/t19/s2095","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2095%2F1","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s2095/2","parentIdentifier":"/us/usc/t19/s2095","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2095%2F2","sourceRelease":"119-100","text":"The term “United States” includes the several States, the District of Columbia, and the Commonwealth of Puerto Rico.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s2095/3","parentIdentifier":"/us/usc/t19/s2095","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2095%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s2095/3/A","parentIdentifier":"/us/usc/t19/s2095/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2095%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s2095/3/A/i","parentIdentifier":"/us/usc/t19/s2095/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2095%2F3%2FA%2Fi","sourceRelease":"119-100","text":"is the product of a pre-Columbian Indian culture of Mexico, Central America, South America, or the Caribbean Islands;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s2095/3/A/ii","parentIdentifier":"/us/usc/t19/s2095/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2095%2F3%2FA%2Fii","sourceRelease":"119-100","text":"was an immobile monument or architectural structure or was a part of, or affixed to, any such monument or structure; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t19/s2095/3/A/iii","parentIdentifier":"/us/usc/t19/s2095/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2095%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"is subject to export control by the country of origin; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s2095/3/B","parentIdentifier":"/us/usc/t19/s2095/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2095%2F3%2FB","sourceRelease":"119-100","text":"any fragment or part of any stone carving or wall art described in subparagraph (A) of this paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t19/s2095/4","parentIdentifier":"/us/usc/t19/s2095","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs2095%2F4","sourceRelease":"119-100","text":"The term “country of origin”, as applied to any pre-Columbian monumental or architectural sculpture or mural, means the country where such sculpture or mural was first discovered.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
