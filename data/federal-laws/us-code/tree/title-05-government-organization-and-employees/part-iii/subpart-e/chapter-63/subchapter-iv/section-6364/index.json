{"type":"section","nativeType":"section","number":"6364","heading":"Establishment of Leave Bank Boards","label":"6364 Establishment of Leave Bank Boards","identifier":"/us/usc/t5/s6364","parentIdentifier":"/us/usc/t5/ptIII/sptE/ch63/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6364","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s6364/a","parentIdentifier":"/us/usc/t5/s6364","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6364%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6364/a/1","parentIdentifier":"/us/usc/t5/s6364/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6364%2Fa%2F1","sourceRelease":"119-100","text":"Each agency that establishes a leave bank shall establish a Leave Bank Board consisting of 3 members, at least one of whom shall represent a labor organization or employee group, to administer the leave bank under the provisions of this subchapter, in consultation with the Office of Personnel Management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6364/a/2","parentIdentifier":"/us/usc/t5/s6364/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6364%2Fa%2F2","sourceRelease":"119-100","text":"An agency may establish more than 1 Leave Bank Board based upon the administrative units within the agency. No more than 1 board may be established for each leave bank.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s6364/b","parentIdentifier":"/us/usc/t5/s6364","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6364%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6364/b/1","parentIdentifier":"/us/usc/t5/s6364/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6364%2Fb%2F1","sourceRelease":"119-100","text":"review and approve applications to the leave bank under section 6367;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6364/b/2","parentIdentifier":"/us/usc/t5/s6364/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6364%2Fb%2F2","sourceRelease":"119-100","text":"monitor each case of a leave recipient;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s6364/b/3","parentIdentifier":"/us/usc/t5/s6364/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6364%2Fb%2F3","sourceRelease":"119-100","text":"monitor the amount of leave in the leave bank and the number of applications for use of leave from the bank; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t5/s6364/b/4","parentIdentifier":"/us/usc/t5/s6364/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6364%2Fb%2F4","sourceRelease":"119-100","text":"maintain an adequate amount of leave in the leave bank to the greatest extent practicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
