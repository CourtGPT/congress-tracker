{"type":"section","nativeType":"section","number":"22703","heading":"Purposes","label":"22703 Purposes","identifier":"/us/usc/t49/s22703","parentIdentifier":"/us/usc/t49/stV/ptB/ch227","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs22703","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Purposes","label":"a .—Purposes","identifier":"/us/usc/t49/s22703/a","parentIdentifier":"/us/usc/t49/s22703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs22703%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s22703/a/1","parentIdentifier":"/us/usc/t49/s22703/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs22703%2Fa%2F1","sourceRelease":"119-100","text":"To set forth State policy involving freight and passenger rail transportation, including commuter rail operations, in the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s22703/a/2","parentIdentifier":"/us/usc/t49/s22703/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs22703%2Fa%2F2","sourceRelease":"119-100","text":"To establish the period covered by the State rail plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s22703/a/3","parentIdentifier":"/us/usc/t49/s22703/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs22703%2Fa%2F3","sourceRelease":"119-100","text":"To present priorities and strategies to enhance rail service in the State that benefits the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s22703/a/4","parentIdentifier":"/us/usc/t49/s22703/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs22703%2Fa%2F4","sourceRelease":"119-100","text":"To serve as the basis for Federal and State rail investments within the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Coordination","label":"b .—Coordination","identifier":"/us/usc/t49/s22703/b","parentIdentifier":"/us/usc/t49/s22703","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs22703%2Fb","sourceRelease":"119-100","text":"A State rail plan shall be coordinated with other State transportation planning goals and programs, including the plan required under , and set forth rail transportation’s role within the State transportation system.section 135 of title 23","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
