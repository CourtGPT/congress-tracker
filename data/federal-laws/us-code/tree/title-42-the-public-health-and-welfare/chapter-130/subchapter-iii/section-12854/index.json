arentIdentifier":"/us/usc/t42/s12854/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12854%2F2%2FB","sourceRelease":"119-100","text":"has not worked full-time full-year in the labor force for a number of years, but has during such years, worked primarily without remuneration to care for the home and family; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s12854/2/C","parentIdentifier":"/us/usc/t42/s12854/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12854%2F2%2FC","sourceRelease":"119-100","text":"is unemployed or underemployed and is experiencing difficulty in obtaining or upgrading employment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Fund","label":"3 Fund","identifier":"/us/usc/t42/s12854/3","parentIdentifier":"/us/usc/t42/s12854","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12854%2F3","sourceRelease":"119-100","text":"The term “Fund” means the National Homeownership Trust Fund established in .section 12853 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Single parent","label":"4 Single parent","identifier":"/us/usc/t42/s12854/4","parentIdentifier":"/us/usc/t42/s12854","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12854%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s12854/4/A","parentIdentifier":"/us/usc/t42/s12854/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12854%2F4%2FA","sourceRelease":"119-100","text":"is unmarried or 