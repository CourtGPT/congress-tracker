{"type":"section","nativeType":"section","number":"721","heading":"Responses to safety recommendations","label":"721 Responses to safety recommendations","identifier":"/us/usc/t14/s721","parentIdentifier":"/us/usc/t14/stI/ch7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs721","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t14/s721/a","parentIdentifier":"/us/usc/t14/s721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs721%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s721/a/1","parentIdentifier":"/us/usc/t14/s721/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs721%2Fa%2F1","sourceRelease":"119-100","text":"concurs with the recommendation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s721/a/2","parentIdentifier":"/us/usc/t14/s721/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs721%2Fa%2F2","sourceRelease":"119-100","text":"partially concurs with the recommendation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t14/s721/a/3","parentIdentifier":"/us/usc/t14/s721/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs721%2Fa%2F3","sourceRelease":"119-100","text":"does not concur with the recommendation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Explanation of Concurrence","label":"b .—Explanation of Concurrence","identifier":"/us/usc/t14/s721/b","parentIdentifier":"/us/usc/t14/s721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs721%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s721/b/1","parentIdentifier":"/us/usc/t14/s721/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs721%2Fb%2F1","sourceRelease":"119-100","text":"with respect to a recommendation with which the Commandant concurs or partially concurs, an explanation of the actions the Commandant intends to take to implement such recommendation or part of such recommendation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s721/b/2","parentIdentifier":"/us/usc/t14/s721/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs721%2Fb%2F2","sourceRelease":"119-100","text":"with respect to a recommendation with which the Commandant does not concur, the reasons the Commandant does not concur.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Failure To Respond","label":"c .—Failure To Respond","identifier":"/us/usc/t14/s721/c","parentIdentifier":"/us/usc/t14/s721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs721%2Fc","sourceRelease":"119-100","text":"If the National Transportation Safety Board has not received the written response required under subsection (a) by the end of the time period described in such subsection, the National Transportation Safety Board shall notify the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives that such response has not been received.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
