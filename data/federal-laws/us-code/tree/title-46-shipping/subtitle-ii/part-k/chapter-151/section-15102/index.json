{"type":"section","nativeType":"section","number":"15102","heading":"National Commercial Fishing Safety Advisory Committee","label":"15102 National Commercial Fishing Safety Advisory Committee","identifier":"/us/usc/t46/s15102","parentIdentifier":"/us/usc/t46/stII/ptK/ch151","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2021—Subsec. (b)(1). , inserted “and provide recommendations in writing to” after “advise” in introductory provisions.Pub. L. 116–283, § 8335(a)(1)(A)(i)(I)Subsec. (b)(3). , (ii), added par. (3).Pub. L. 116–283, § 8335(a)(1)(A)(i)(II)Subsecs. (d), (e). , added subsecs. (d) and (e).Pub. L. 116–283, § 8335(a)(1)(B)"],"amendments":["Amendments2021—Subsec. (b)(1). , inserted “and provide recommendations in writing to” after “advise” in introductory provisions.Pub. L. 116–283, § 8335(a)(1)(A)(i)(I)Subsec. (b)(3). , (ii), added par. (3).Pub. L. 116–283, § 8335(a)(1)(A)(i)(II)Subsecs. (d), (e). , added subsecs. (d) and (e).Pub. L. 116–283, § 8335(a)(1)(B)"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t46/s15102/a","parentIdentifier":"/us/usc/t46/s15102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fa","sourceRelease":"119-100","text":"There is established a National Commercial Fishing Safety Advisory Committee (in this section referred to as the “Committee”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Function","label":"b .—Function","identifier":"/us/usc/t46/s15102/b","parentIdentifier":"/us/usc/t46/s15102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t46/s15102/b/1","parentIdentifier":"/us/usc/t46/s15102/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s15102/b/1/A","parentIdentifier":"/us/usc/t46/s15102/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fb%2F1%2FA","sourceRelease":"119-100","text":"navigation safety;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s15102/b/1/B","parentIdentifier":"/us/usc/t46/s15102/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fb%2F1%2FB","sourceRelease":"119-100","text":"safety equipment and procedures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t46/s15102/b/1/C","parentIdentifier":"/us/usc/t46/s15102/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fb%2F1%2FC","sourceRelease":"119-100","text":"marine insurance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t46/s15102/b/1/D","parentIdentifier":"/us/usc/t46/s15102/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fb%2F1%2FD","sourceRelease":"119-100","text":"vessel design, construction, maintenance, and operation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t46/s15102/b/1/E","parentIdentifier":"/us/usc/t46/s15102/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fb%2F1%2FE","sourceRelease":"119-100","text":"personnel qualifications and training;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t46/s15102/b/2","parentIdentifier":"/us/usc/t46/s15102/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fb%2F2","sourceRelease":"119-100","text":"review regulations proposed under chapter 45 of this title (during preparation of the regulations); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t46/s15102/b/3","parentIdentifier":"/us/usc/t46/s15102/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fb%2F3","sourceRelease":"119-100","text":"review marine casualties and investigations of vessels covered by chapter 45 of this title and make recommendations to the Secretary to improve safety and reduce vessel casualties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Membership.—","label":"c Membership.—","identifier":"/us/usc/t46/s15102/c","parentIdentifier":"/us/usc/t46/s15102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t46/s15102/c/1","parentIdentifier":"/us/usc/t46/s15102/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F1","sourceRelease":"119-100","text":"The Committee shall consist of 18 members appointed by the Secretary in accordance with this section and section 15109 of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Expertise","label":"2 .—Expertise","identifier":"/us/usc/t46/s15102/c/2","parentIdentifier":"/us/usc/t46/s15102/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F2","sourceRelease":"119-100","text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Representation","label":"3 .—Representation","identifier":"/us/usc/t46/s15102/c/3","parentIdentifier":"/us/usc/t46/s15102/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s15102/c/3/A","parentIdentifier":"/us/usc/t46/s15102/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t46/s15102/c/3/A/i","parentIdentifier":"/us/usc/t46/s15102/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FA%2Fi","sourceRelease":"119-100","text":"as a group, shall together reflect a regional and representational balance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t46/s15102/c/3/A/ii","parentIdentifier":"/us/usc/t46/s15102/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t46/s15102/c/3/A/ii/I","parentIdentifier":"/us/usc/t46/s15102/c/3/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FA%2Fii%2FI","sourceRelease":"119-100","text":"in the operation of vessels to which chapter 45 of this title applies; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t46/s15102/c/3/A/ii/II","parentIdentifier":"/us/usc/t46/s15102/c/3/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FA%2Fii%2FII","sourceRelease":"119-100","text":"as a crew member or processing line worker on a fish processing vessel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s15102/c/3/B","parentIdentifier":"/us/usc/t46/s15102/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FB","sourceRelease":"119-100","text":"1 member shall represent naval architects and marine engineers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t46/s15102/c/3/C","parentIdentifier":"/us/usc/t46/s15102/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FC","sourceRelease":"119-100","text":"1 member shall represent manufacturers of equipment for vessels to which chapter 45 of this title applies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t46/s15102/c/3/D","parentIdentifier":"/us/usc/t46/s15102/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FD","sourceRelease":"119-100","text":"1 member shall represent education and training professionals related to fishing vessel, fish processing vessel, and fish tender vessel safety and personnel qualifications.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t46/s15102/c/3/E","parentIdentifier":"/us/usc/t46/s15102/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FE","sourceRelease":"119-100","text":"1 member shall represent underwriters that insure vessels to which chapter 45 of this title applies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t46/s15102/c/3/F","parentIdentifier":"/us/usc/t46/s15102/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FF","sourceRelease":"119-100","text":"1 member shall represent owners of vessels to which chapter 45 of this title applies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t46/s15102/c/3/G","parentIdentifier":"/us/usc/t46/s15102/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FG","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t46/s15102/c/3/G/i","parentIdentifier":"/us/usc/t46/s15102/c/3/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FG%2Fi","sourceRelease":"119-100","text":"an independent expert or consultant in maritime safety;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t46/s15102/c/3/G/ii","parentIdentifier":"/us/usc/t46/s15102/c/3/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FG%2Fii","sourceRelease":"119-100","text":"a marine surveyor who provides services to vessels to which chapter 45 of this title applies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t46/s15102/c/3/G/iii","parentIdentifier":"/us/usc/t46/s15102/c/3/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fc%2F3%2FG%2Fiii","sourceRelease":"119-100","text":"a person familiar with issues affecting fishing communities and the families of fishermen.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Quorum","label":"d .—Quorum","identifier":"/us/usc/t46/s15102/d","parentIdentifier":"/us/usc/t46/s15102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fd","sourceRelease":"119-100","text":"A quorum of 10 members is required to send any written recommendations from the Committee to the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Savings Clause","label":"e .—Savings Clause","identifier":"/us/usc/t46/s15102/e","parentIdentifier":"/us/usc/t46/s15102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15102%2Fe","sourceRelease":"119-100","text":"Nothing in this section shall preclude the Secretary from taking emergency action to ensure safety and preservation of life at sea.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
