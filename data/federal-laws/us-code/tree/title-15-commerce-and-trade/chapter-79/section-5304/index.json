{"type":"section","nativeType":"section","number":"5304","heading":"Operation of program","label":"5304 Operation of program","identifier":"/us/usc/t15/s5304","parentIdentifier":"/us/usc/t15/ch79","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Solicitation of proposals","label":"a Solicitation of proposals","identifier":"/us/usc/t15/s5304/a","parentIdentifier":"/us/usc/t15/s5304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s5304/a/1","parentIdentifier":"/us/usc/t15/s5304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fa%2F1","sourceRelease":"119-100","text":"the technical capability to enable it to make use of existing research support and facilities in carrying out its research objectives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s5304/a/2","parentIdentifier":"/us/usc/t15/s5304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fa%2F2","sourceRelease":"119-100","text":"a multidisciplinary research staff experienced in metal casting or other directly related technologies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s5304/a/3","parentIdentifier":"/us/usc/t15/s5304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fa%2F3","sourceRelease":"119-100","text":"the facilities and equipment capable of conducting at least laboratory scale testing or demonstration of metal casting or related processes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Proposal criteria","label":"b Proposal criteria","identifier":"/us/usc/t15/s5304/b","parentIdentifier":"/us/usc/t15/s5304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s5304/b/1","parentIdentifier":"/us/usc/t15/s5304/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s5304/b/1/A","parentIdentifier":"/us/usc/t15/s5304/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fb%2F1%2FA","sourceRelease":"119-100","text":"how industry has participated in deciding what research activities will be undertaken;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s5304/b/1/B","parentIdentifier":"/us/usc/t15/s5304/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fb%2F1%2FB","sourceRelease":"119-100","text":"how industry will participate in the evaluation of the applicant’s progress in research and development activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s5304/b/1/C","parentIdentifier":"/us/usc/t15/s5304/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the extent to which industry funds are committed to the applicant’s proposal;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s5304/b/2","parentIdentifier":"/us/usc/t15/s5304/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s5304/b/2/A","parentIdentifier":"/us/usc/t15/s5304/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fb%2F2%2FA","sourceRelease":"119-100","text":"cash, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s5304/b/2/B","parentIdentifier":"/us/usc/t15/s5304/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fb%2F2%2FB","sourceRelease":"119-100","text":"as determined by the Secretary, the fair market value of equipment, services, materials, appropriate technology transfer activities, and other assets directly related to the proposal’s cost;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s5304/b/3","parentIdentifier":"/us/usc/t15/s5304/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fb%2F3","sourceRelease":"119-100","text":"include a single or multiyear management plan that outlines how the research and development activities will be administered and carried out;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s5304/b/4","parentIdentifier":"/us/usc/t15/s5304/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fb%2F4","sourceRelease":"119-100","text":"state the annual cost of the proposal and a breakdown of those costs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s5304/b/5","parentIdentifier":"/us/usc/t15/s5304/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fb%2F5","sourceRelease":"119-100","text":"describe the technology transfer mechanisms the applicant will use to make available research results to industry and to other researchers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Content of management plan","label":"c Content of management plan","identifier":"/us/usc/t15/s5304/c","parentIdentifier":"/us/usc/t15/s5304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s5304/c/1","parentIdentifier":"/us/usc/t15/s5304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fc%2F1","sourceRelease":"119-100","text":"outline the basic research and development activities expected to be performed;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s5304/c/2","parentIdentifier":"/us/usc/t15/s5304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fc%2F2","sourceRelease":"119-100","text":"outline who will conduct those research activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s5304/c/3","parentIdentifier":"/us/usc/t15/s5304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fc%2F3","sourceRelease":"119-100","text":"establish the time frame over which the research activities will take place; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s5304/c/4","parentIdentifier":"/us/usc/t15/s5304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s5304/c/4/A","parentIdentifier":"/us/usc/t15/s5304/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fc%2F4%2FA","sourceRelease":"119-100","text":"identifying managerial, organizational and administrative procedures and responsibilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s5304/c/4/B","parentIdentifier":"/us/usc/t15/s5304/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fc%2F4%2FB","sourceRelease":"119-100","text":"outlining how the coordination of research and development between the individuals and organizations involved will be achieved;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s5304/c/4/C","parentIdentifier":"/us/usc/t15/s5304/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fc%2F4%2FC","sourceRelease":"119-100","text":"demonstrating how implementation and monitoring of the progress of research projects after receipt of funding from the Secretary will be achieved;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s5304/c/4/D","parentIdentifier":"/us/usc/t15/s5304/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fc%2F4%2FD","sourceRelease":"119-100","text":"demonstrating how recommendations and implementations on modifications to the plan will be achieved; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s5304/c/4/E","parentIdentifier":"/us/usc/t15/s5304/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fc%2F4%2FE","sourceRelease":"119-100","text":"providing sufficient rationale to support the plan’s costs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Selection of proposals","label":"d Selection of proposals","identifier":"/us/usc/t15/s5304/d","parentIdentifier":"/us/usc/t15/s5304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s5304/d/1","parentIdentifier":"/us/usc/t15/s5304/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s5304/d/1/A","parentIdentifier":"/us/usc/t15/s5304/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fd%2F1%2FA","sourceRelease":"119-100","text":"solidification and casting technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s5304/d/1/B","parentIdentifier":"/us/usc/t15/s5304/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fd%2F1%2FB","sourceRelease":"119-100","text":"computational modeling and design;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s5304/d/1/C","parentIdentifier":"/us/usc/t15/s5304/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fd%2F1%2FC","sourceRelease":"119-100","text":"processing technologies and design for energy efficiency, material conservation, environmental protection, or industrial productivity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s5304/d/1/D","parentIdentifier":"/us/usc/t15/s5304/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fd%2F1%2FD","sourceRelease":"119-100","text":"other areas of research, which in the judgment of the Secretary, after consulting with the Board established in , further the purposes of this chapter;section 5306 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s5304/d/2","parentIdentifier":"/us/usc/t15/s5304/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fd%2F2","sourceRelease":"119-100","text":"represent research and development in specific areas identified in the “Metal Casting Research Priorities” developed annually by the Board pursuant to ;section 5306(b)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s5304/d/3","parentIdentifier":"/us/usc/t15/s5304/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fd%2F3","sourceRelease":"119-100","text":"to the greatest extent possible and subject to available appropriations, ensure that at least one applicant is selected from each of the four census regions of the country where the metal casting industry is concentrated;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s5304/d/4","parentIdentifier":"/us/usc/t15/s5304/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fd%2F4","sourceRelease":"119-100","text":"demonstrate strong industry support;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s5304/d/5","parentIdentifier":"/us/usc/t15/s5304/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fd%2F5","sourceRelease":"119-100","text":"ensure the timely transfer of technology to industry; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s5304/d/6","parentIdentifier":"/us/usc/t15/s5304/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fd%2F6","sourceRelease":"119-100","text":"otherwise best carry out the purposes of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Funding of program","label":"e Funding of program","identifier":"/us/usc/t15/s5304/e","parentIdentifier":"/us/usc/t15/s5304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Fe","sourceRelease":"119-100","text":"From amounts made available in separate appropriation Acts, the Secretary shall provide to each applicant selected the financial and technical assistance and other incentives that are necessary and appropriate to carry out the purposes of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"National Metal Casting Research Institute","label":"f National Metal Casting Research Institute","identifier":"/us/usc/t15/s5304/f","parentIdentifier":"/us/usc/t15/s5304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs5304%2Ff","sourceRelease":"119-100","text":"Each recipient of financial assistance under subsection (d) shall be known as a “National Metal Casting Research Institute”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
