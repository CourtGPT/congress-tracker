119-100","text":"41 percent for coal of 7,000 to 9,000 Btu; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"cc","heading":null,"label":"cc","identifier":"/us/usc/t42/s15962/b/2/B/ii/IV/cc","parentIdentifier":"/us/usc/t42/s15962/b/2/B/ii/IV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F2%2FB%2Fii%2FIV%2Fcc","sourceRelease":"119-100","text":"39 percent for coal of less than 7,000 Btu.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Consultation","label":"3 Consultation","identifier":"/us/usc/t42/s15962/b/3","parentIdentifier":"/us/usc/t42/s15962/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15962/b/3/A","parentIdentifier":"/us/usc/t42/s15962/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the Administrator of the Environmental Protection Agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15962/b/3/B","parentIdentifier":"/us/usc/t42/s15962/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s15962/b/3/B/i","parentIdentifier":"/us/usc/t42/s15962/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"coal producers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s15962/b/3/B/ii","parentIdentifier":"/us/usc/t42/s15962/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"industries using coal;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s15962/b/3/B/iii","parentIdentifier":"/us/usc/t42/s15962/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"organizations that promote coal or advanced coal technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s15962/b/3/B/iv","parentIdentifier":"/us/usc/t42/s15962/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F3%2FB%2Fiv","sourceRelease":"119-100","text":"environmental organizations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s15962/b/3/B/v","parentIdentifier":"/us/usc/t42/s15962/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F3%2FB%2Fv","sourceRelease":"119-100","text":"organizations representing workers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s15962/b/3/B/vi","parentIdentifier":"/us/usc/t42/s15962/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F3%2FB%2Fvi","sourceRelease":"119-100","text":"organizations representing consumers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Existing units","label":"4 Existing units","identifier":"/us/usc/t42/s15962/b/4","parentIdentifier":"/us/usc/t42/s15962/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15962/b/4/A","parentIdentifier":"/us/usc/t42/s15962/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F4%2FA","sourceRelease":"119-100","text":"7 percent for coal of more than 9,000 Btu;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15962/b/4/B","parentIdentifier":"/us/usc/t42/s15962/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F4%2FB","sourceRelease":"119-100","text":"6 percent for coal of 7,000 to 9,000 Btu; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s15962/b/4/C","parentIdentifier":"/us/usc/t42/s15962/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F4%2FC","sourceRelease":"119-100","text":"4 percent for coal of less than 7,000 Btu.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Administration","label":"5 Administration","identifier":"/us/usc/t42/s15962/b/5","parentIdentifier":"/us/usc/t42/s15962/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Elevation of site","label":"A Elevation of site","identifier":"/us/usc/t42/s15962/b/5/A","parentIdentifier":"/us/usc/t42/s15962/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F5%2FA","sourceRelease":"119-100","text":"In evaluating project proposals to achieve thermal efficiency levels established under paragraphs (1)(B)(i) and (2)(B)(i) and in determining progress towards thermal efficiency milestones under paragraphs (1)(B)(ii)(IV), (2)(B)(ii)(IV), and (4), the Secretary shall take into account and make adjustments for the elevation of the site at which a project is proposed to be constructed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Applicability of milestones","label":"B Applicability of milestones","identifier":"/us/usc/t42/s15962/b/5/B","parentIdentifier":"/us/usc/t42/s15962/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F5%2FB","sourceRelease":"119-100","text":"In applying the thermal efficiency milestones under paragraphs (1)(B)(ii)(IV), (2)(B)(ii)(IV), and (4) to projects that separate and capture at least 50 percent of the potential emissions of carbon dioxide by a facility, the energy used for separation and capture of carbon dioxide shall not be counted in calculating the thermal efficiency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Permitted uses","label":"C Permitted uses","identifier":"/us/usc/t42/s15962/b/5/C","parentIdentifier":"/us/usc/t42/s15962/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F5%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s15962/b/5/C/i","parentIdentifier":"/us/usc/t42/s15962/b/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F5%2FC%2Fi","sourceRelease":"119-100","text":"the separation or capture of carbon dioxide; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s15962/b/5/C/ii","parentIdentifier":"/us/usc/t42/s15962/b/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fb%2F5%2FC%2Fii","sourceRelease":"119-100","text":"the reduction of the demand for natural gas if deployed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Financial criteria","label":"c Financial criteria","identifier":"/us/usc/t42/s15962/c","parentIdentifier":"/us/usc/t42/s15962","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15962/c/1","parentIdentifier":"/us/usc/t42/s15962/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fc%2F1","sourceRelease":"119-100","text":"the recipient is financially responsible;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15962/c/2","parentIdentifier":"/us/usc/t42/s15962/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fc%2F2","sourceRelease":"119-100","text":"the recipient will provide sufficient information to the Secretary to enable the Secretary to ensure that the funds are spent efficiently and effectively; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s15962/c/3","parentIdentifier":"/us/usc/t42/s15962/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fc%2F3","sourceRelease":"119-100","text":"a market exists for the technology being demonstrated or applied, as evidenced by statements of interest in writing from potential purchasers of the technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Financial assistance","label":"d Financial assistance","identifier":"/us/usc/t42/s15962/d","parentIdentifier":"/us/usc/t42/s15962","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15962/d/1","parentIdentifier":"/us/usc/t42/s15962/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fd%2F1","sourceRelease":"119-100","text":"meet the requirements of subsections (a), (b), and (c); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15962/d/2","parentIdentifier":"/us/usc/t42/s15962/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15962/d/2/A","parentIdentifier":"/us/usc/t42/s15962/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fd%2F2%2FA","sourceRelease":"119-100","text":"to achieve overall cost reductions in the use of coal to generate useful forms of energy or chemical feedstocks;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15962/d/2/B","parentIdentifier":"/us/usc/t42/s15962/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fd%2F2%2FB","sourceRelease":"119-100","text":"to improve the competitiveness of coal among various forms of energy in order to maintain a diversity of fuel choices in the United States to meet electricity generation requirements; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s15962/d/2/C","parentIdentifier":"/us/usc/t42/s15962/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fd%2F2%2FC","sourceRelease":"119-100","text":"to demonstrate methods and equipment that are applicable to 25 percent of the electricity generating facilities, using various types of coal, that use coal as the primary feedstock as of .August 8, 2005","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Cost-sharing","label":"e Cost-sharing","identifier":"/us/usc/t42/s15962/e","parentIdentifier":"/us/usc/t42/s15962","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fe","sourceRelease":"119-100","text":"In carrying out this part, the Secretary shall require cost sharing in accordance with .section 16352 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Scheduled completion of selected projects","label":"f Scheduled completion of selected projects","identifier":"/us/usc/t42/s15962/f","parentIdentifier":"/us/usc/t42/s15962","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s15962/f/1","parentIdentifier":"/us/usc/t42/s15962/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Ff%2F1","sourceRelease":"119-100","text":"In selecting a project for financial assistance under this section, the Secretary shall establish a reasonable period of time during which the owner or operator of the project shall complete the construction or demonstration phase of the project, as the Secretary determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Condition of financial assistance","label":"2 Condition of financial assistance","identifier":"/us/usc/t42/s15962/f/2","parentIdentifier":"/us/usc/t42/s15962/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Ff%2F2","sourceRelease":"119-100","text":"The Secretary shall require as a condition of receipt of any financial assistance under this part that the recipient of the assistance enter into an agreement with the Secretary not to request an extension of the time period established for the project by the Secretary under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Extension of time period","label":"3 Extension of time period","identifier":"/us/usc/t42/s15962/f/3","parentIdentifier":"/us/usc/t42/s15962/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Ff%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s15962/f/3/A","parentIdentifier":"/us/usc/t42/s15962/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Ff%2F3%2FA","sourceRelease":"119-100","text":"Subject to subparagraph (B), the Secretary may extend the time period established under paragraph (1) if the Secretary determines, in the sole discretion of the Secretary, that the owner or operator of the project cannot complete the construction or demonstration phase of the project within the time period due to circumstances beyond the control of the owner or operator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Limitation","label":"B Limitation","identifier":"/us/usc/t42/s15962/f/3/B","parentIdentifier":"/us/usc/t42/s15962/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Ff%2F3%2FB","sourceRelease":"119-100","text":"The Secretary shall not extend a time period under subparagraph (A) by more than 4 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Fee title","label":"g Fee title","identifier":"/us/usc/t42/s15962/g","parentIdentifier":"/us/usc/t42/s15962","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fg","sourceRelease":"119-100","text":"The Secretary may vest fee title or other property interests acquired under cost-share clean coal power initiative agreements under this part in any entity, including the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Data protection","label":"h Data protection","identifier":"/us/usc/t42/s15962/h","parentIdentifier":"/us/usc/t42/s15962","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15962/h/1","parentIdentifier":"/us/usc/t42/s15962/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fh%2F1","sourceRelease":"119-100","text":"results from demonstration activities carried out under the clean coal power initiative program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15962/h/2","parentIdentifier":"/us/usc/t42/s15962/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fh%2F2","sourceRelease":"119-100","text":"would be a trade secret or commercial or financial information that is privileged or confidential if the information had been obtained from and first produced by a non-Federal party participating in a clean coal power initiative project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Applicability","label":"i Applicability","identifier":"/us/usc/t42/s15962/i","parentIdentifier":"/us/usc/t42/s15962","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15962/i/1","parentIdentifier":"/us/usc/t42/s15962/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fi%2F1","sourceRelease":"119-100","text":"adequately demonstrated for purposes of ;section 7411 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15962/i/2","parentIdentifier":"/us/usc/t42/s15962/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fi%2F2","sourceRelease":"119-100","text":"achievable for purposes of ; orsection 7479 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s15962/i/3","parentIdentifier":"/us/usc/t42/s15962/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15962%2Fi%2F3","sourceRelease":"119-100","text":"achievable in practice for purposes of .section 7501 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
