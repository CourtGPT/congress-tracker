agraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s1725/c/1","parentIdentifier":"/us/usc/t47/s1725/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1725%2Fc%2F1","sourceRelease":"119-100","text":"the Secretary of Agriculture;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s1725/c/2","parentIdentifier":"/us/usc/t47/s1725/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1725%2Fc%2F2","sourceRelease":"119-100","text":"the Secretary of Housing and Urban Development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t47/s1725/c/3","parentIdentifier":"/us/usc/t47/s1725/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1725%2Fc%2F3","sourceRelease":"119-100","text":"the Secretary of Education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t47/s1725/c/4","parentIdentifier":"/us/usc/t47/s1725/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1725%2Fc%2F4","sourceRelease":"119-100","text":"the Secretary of Labor;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t47/s1725/c/5","parentIdentifier":"/us/usc/t47/s1725/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1725%2Fc%2F5","sourceRelease":"119-100","text":"the Secretary of Health and Human Services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t47/s1725/c