{"type":"section","nativeType":"section","number":"460ss–1","heading":"Establishment","label":"460ss–1 Establishment","identifier":"/us/usc/t16/s460ss–1","parentIdentifier":"/us/usc/t16/ch1/schCIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s460ss–1/a","parentIdentifier":"/us/usc/t16/s460ss–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fa","sourceRelease":"119-100","text":"The Secretary shall designate the anadromous fish habitats and resources of the Klamath River basin as the Klamath River Basin Conservation Area (hereafter in this subchapter referred to as the “Area”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Restoration program","label":"b Restoration program","identifier":"/us/usc/t16/s460ss–1/b","parentIdentifier":"/us/usc/t16/s460ss–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t16/s460ss–1/b/1","parentIdentifier":"/us/usc/t16/s460ss–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall, in consultation with the task force established under , formulate, establish, and implement a 20-year program to restore the anadromous fish populations of the Area to optimum levels and to maintain such levels. The program shall be based on the Klamath River Basin Fisheries Resource Plan referred to in and shall be known as the Klamath River Basin Conservation Area Restoration Program.section 460ss–3 of this titlesection 460ss(6) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Program activities","label":"2 Program activities","identifier":"/us/usc/t16/s460ss–1/b/2","parentIdentifier":"/us/usc/t16/s460ss–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460ss–1/b/2/A","parentIdentifier":"/us/usc/t16/s460ss–1/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F2%2FA","sourceRelease":"119-100","text":"monitor and coordinate research evaluating the Area anadromous fish populations and administer and evaluate the success of activities described in subparagraph (B); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460ss–1/b/2/B","parentIdentifier":"/us/usc/t16/s460ss–1/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460ss–1/b/2/B/i","parentIdentifier":"/us/usc/t16/s460ss–1/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"improve and restore Area habitats, and to promote access to blocked Area habitats, to support increased run sizes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460ss–1/b/2/B/ii","parentIdentifier":"/us/usc/t16/s460ss–1/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"rehabilitate problem watersheds in the Area to reduce negative impacts on fish and fish habitats;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s460ss–1/b/2/B/iii","parentIdentifier":"/us/usc/t16/s460ss–1/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"improve existing Area hatcheries and rearing ponds to assist in rebuilding the natural populations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s460ss–1/b/2/B/iv","parentIdentifier":"/us/usc/t16/s460ss–1/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"implement an intensive, short-term stocking program to rebuild run sizes while maintaining the genetic integrity and diversity of Area subbasin stocks; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t16/s460ss–1/b/2/B/v","parentIdentifier":"/us/usc/t16/s460ss–1/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F2%2FB%2Fv","sourceRelease":"119-100","text":"improve upstream and downstream migration by removal of obstacles to fish passage and the provision of facilities for avoiding obstacles.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Restoration work","label":"3 Restoration work","identifier":"/us/usc/t16/s460ss–1/b/3","parentIdentifier":"/us/usc/t16/s460ss–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460ss–1/b/3/A","parentIdentifier":"/us/usc/t16/s460ss–1/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F3%2FA","sourceRelease":"119-100","text":"commercial fishermen;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460ss–1/b/3/B","parentIdentifier":"/us/usc/t16/s460ss–1/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F3%2FB","sourceRelease":"119-100","text":"Indians; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s460ss–1/b/3/C","parentIdentifier":"/us/usc/t16/s460ss–1/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F3%2FC","sourceRelease":"119-100","text":"other persons whose livelihood depends upon Area fishery resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Memorandum of agreement","label":"4 Memorandum of agreement","identifier":"/us/usc/t16/s460ss–1/b/4","parentIdentifier":"/us/usc/t16/s460ss–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460ss%E2%80%931%2Fb%2F4","sourceRelease":"119-100","text":"In order to facilitate the implementation of any activity described in paragraph (2) over which the Secretary does not have jurisdiction, the Secretary shall enter into a memorandum of agreement with the Federal, State, and local agencies having jurisdiction over such activities, and the Area Indian tribes. The memorandum of agreement shall specify the program activities for which the respective signatories to the agreement are responsible and shall contain such provisions as are necessary to ensure the coordinated implementation of the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
