{"type":"section","nativeType":"section","number":"13456","heading":"Improving efficiency in energy-intensive industries","label":"13456 Improving efficiency in energy-intensive industries","identifier":"/us/usc/t42/s13456","parentIdentifier":"/us/usc/t42/ch134/schIX/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13456","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Secretarial action","label":"a Secretarial action","identifier":"/us/usc/t42/s13456/a","parentIdentifier":"/us/usc/t42/s13456","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13456%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13456/a/1","parentIdentifier":"/us/usc/t42/s13456/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13456%2Fa%2F1","sourceRelease":"119-100","text":"pursue a research, development, demonstration and commercial application program intended to improve energy efficiency and productivity in energy-intensive industries and industrial processes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13456/a/2","parentIdentifier":"/us/usc/t42/s13456/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13456%2Fa%2F2","sourceRelease":"119-100","text":"undertake joint ventures to encourage the commercialization of technologies developed under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Joint ventures","label":"b Joint ventures","identifier":"/us/usc/t42/s13456/b","parentIdentifier":"/us/usc/t42/s13456","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13456%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13456/b/1","parentIdentifier":"/us/usc/t42/s13456/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13456%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13456/b/1/A","parentIdentifier":"/us/usc/t42/s13456/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13456%2Fb%2F1%2FA","sourceRelease":"119-100","text":"conduct a competitive solicitation for proposals from private firms and investors for such joint ventures under subsection (a)(2); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13456/b/1/B","parentIdentifier":"/us/usc/t42/s13456/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13456%2Fb%2F1%2FB","sourceRelease":"119-100","text":"provide financial assistance to at least five such joint ventures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13456/b/2","parentIdentifier":"/us/usc/t42/s13456/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13456%2Fb%2F2","sourceRelease":"119-100","text":"The purpose of the joint ventures shall be to design, test, and demonstrate changes to industrial processes that will result in improved energy efficiency and productivity. The joint ventures may also demonstrate other improvements of benefit to such industries so long as demonstration of energy efficiency improvements is the principal objective of the joint venture.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13456/b/3","parentIdentifier":"/us/usc/t42/s13456/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13456%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s13456/b/3/A","parentIdentifier":"/us/usc/t42/s13456/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13456%2Fb%2F3%2FA","sourceRelease":"119-100","text":"whether the activities conducted under this section improve the quality and energy efficiency of industries or industrial processes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s13456/b/3/B","parentIdentifier":"/us/usc/t42/s13456/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13456%2Fb%2F3%2FB","sourceRelease":"119-100","text":"the regional distribution of the energy-intensive industries and industrial processes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s13456/b/3/C","parentIdentifier":"/us/usc/t42/s13456/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13456%2Fb%2F3%2FC","sourceRelease":"119-100","text":"whether the proposed joint venture project would be located in the region which has the energy-intensive industry and industrial processes that would benefit from the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
