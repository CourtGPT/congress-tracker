{"type":"section","nativeType":"section","number":"199","heading":"Joint Interagency Task Force 401","label":"199 Joint Interagency Task Force 401","identifier":"/us/usc/t10/s199","parentIdentifier":"/us/usc/t10/stA/ptI/ch8/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t10/s199/a","parentIdentifier":"/us/usc/t10/s199","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fa","sourceRelease":"119-100","text":"There is established in the Department of Defense a joint activity to be known as the “Joint Interagency Task Force 401” (referred to in this section as the “Task Force”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Director.—","label":"b Director.—","identifier":"/us/usc/t10/s199/b","parentIdentifier":"/us/usc/t10/s199","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s199/b/1","parentIdentifier":"/us/usc/t10/s199/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s199/b/1/A","parentIdentifier":"/us/usc/t10/s199/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fb%2F1%2FA","sourceRelease":"119-100","text":"general or flag officers of the covered armed forces; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s199/b/1/B","parentIdentifier":"/us/usc/t10/s199/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fb%2F1%2FB","sourceRelease":"119-100","text":"members of the Senior Executive Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s199/b/2","parentIdentifier":"/us/usc/t10/s199/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fb%2F2","sourceRelease":"119-100","text":"The Director shall report directly to the Deputy Secretary of Defense and shall serve as the principal advisor to the Deputy Secretary and the Chairman of the Joint Chiefs of Staff on counter-small unmanned aircraft system matters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Organization","label":"c .—Organization","identifier":"/us/usc/t10/s199/c","parentIdentifier":"/us/usc/t10/s199","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s199/c/1","parentIdentifier":"/us/usc/t10/s199/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fc%2F1","sourceRelease":"119-100","text":"be designated as a jointly manned activity with full joint manning support from the covered armed forces as determined by the Director; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s199/c/2","parentIdentifier":"/us/usc/t10/s199/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fc%2F2","sourceRelease":"119-100","text":"shall consist of such other subordinate organizational elements as the Director determines appropriate, subject to the authority, direction, and control of the Secretary of Defense with support from designated organizational elements within the Office of the Secretary of Defense as determined by the Director in coordination with the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Responsibilities","label":"d .—Responsibilities","identifier":"/us/usc/t10/s199/d","parentIdentifier":"/us/usc/t10/s199","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s199/d/1","parentIdentifier":"/us/usc/t10/s199/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fd%2F1","sourceRelease":"119-100","text":"Lead, advocate, coordinate, and focus all Department of Defense actions in support of efforts of the combatant commands and the covered armed forces to defeat small unmanned aircraft systems (referred to in this section as “sUAS”) as weapons of strategic influence.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s199/d/2","parentIdentifier":"/us/usc/t10/s199/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fd%2F2","sourceRelease":"119-100","text":"Integrate all counter-sUAS solutions throughout the Department of Defense, seeking interagency participation and assistance as necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s199/d/3","parentIdentifier":"/us/usc/t10/s199/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fd%2F3","sourceRelease":"119-100","text":"Develop and share counter-sUAS training tools, expertise, and tactics, techniques, and procedures for components of the Department of Defense that address needs of the joint force.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s199/d/4","parentIdentifier":"/us/usc/t10/s199/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fd%2F4","sourceRelease":"119-100","text":"Coordinate efforts across the Department of Defense to develop, test, evaluate, and procure counter-sUAS kinetic and non-kinetic defeat capabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s199/d/5","parentIdentifier":"/us/usc/t10/s199/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fd%2F5","sourceRelease":"119-100","text":"Carry out the counter-sUAS validation and acquisition responsibilities described in subsections (e) and (f).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t10/s199/d/6","parentIdentifier":"/us/usc/t10/s199/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fd%2F6","sourceRelease":"119-100","text":"Develop and regularly update a counter-sUAS strategic plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t10/s199/d/7","parentIdentifier":"/us/usc/t10/s199/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fd%2F7","sourceRelease":"119-100","text":"Carry out such other activities relating to counter-sUAS as the Secretary of Defense determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Approval and Validation of Counter-suas Systems.—","label":"e Approval and Validation of Counter-suas Systems.—","identifier":"/us/usc/t10/s199/e","parentIdentifier":"/us/usc/t10/s199","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s199/e/1","parentIdentifier":"/us/usc/t10/s199/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fe%2F1","sourceRelease":"119-100","text":"The Task Force shall serve as the entity within the Department of Defense with primary responsibility for the validation and approval of counter-sUAS systems for procurement and use by the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s199/e/2","parentIdentifier":"/us/usc/t10/s199/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fe%2F2","sourceRelease":"119-100","text":"In coordination with other components of the Department of Defense, the Director shall develop, maintain, and regularly update a list of counter-sUAS systems that are validated and approved for procurement and use by the Department as described in paragraph (1). The Director shall ensure that each counter-sUAS system on the list has been vetted by the Task Force and has proven to be effective for use by the Department in countering sUAS.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s199/e/3","parentIdentifier":"/us/usc/t10/s199/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fe%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s199/e/3/A","parentIdentifier":"/us/usc/t10/s199/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fe%2F3%2FA","sourceRelease":"119-100","text":"has been validated and approved by the Task Force under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s199/e/3/B","parentIdentifier":"/us/usc/t10/s199/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fe%2F3%2FB","sourceRelease":"119-100","text":"is included on the list maintained under paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s199/e/4","parentIdentifier":"/us/usc/t10/s199/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fe%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s199/e/4/A","parentIdentifier":"/us/usc/t10/s199/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fe%2F4%2FA","sourceRelease":"119-100","text":"notice of the intent to issue such a waiver; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s199/e/4/B","parentIdentifier":"/us/usc/t10/s199/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fe%2F4%2FB","sourceRelease":"119-100","text":"an explanation of the reasons for issuing the waiver.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Acquisition Division","label":"f .—Acquisition Division","identifier":"/us/usc/t10/s199/f","parentIdentifier":"/us/usc/t10/s199","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s199/f/1","parentIdentifier":"/us/usc/t10/s199/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Ff%2F1","sourceRelease":"119-100","text":"include acquisition professionals from relevant portfolio acquisition executives (as described in ) within each covered armed force;section 1732 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s199/f/2","parentIdentifier":"/us/usc/t10/s199/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s199/f/2/A","parentIdentifier":"/us/usc/t10/s199/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Ff%2F2%2FA","sourceRelease":"119-100","text":"to budget and plan for the integration and sustainment of counter-sUAS capabilities that are approved and validated by the Task Force under subsection (e); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s199/f/2/B","parentIdentifier":"/us/usc/t10/s199/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Ff%2F2%2FB","sourceRelease":"119-100","text":"to efficiently and effectively transition such capabilities into operational use; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s199/f/3","parentIdentifier":"/us/usc/t10/s199/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Ff%2F3","sourceRelease":"119-100","text":"have such other duties and responsibilities as the Director determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":".—Annual Reports","label":"g .—Annual Reports","identifier":"/us/usc/t10/s199/g","parentIdentifier":"/us/usc/t10/s199","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s199/g/1","parentIdentifier":"/us/usc/t10/s199/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fg%2F1","sourceRelease":"119-100","text":"the progress of the Task Force in carrying out the requirements of this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s199/g/2","parentIdentifier":"/us/usc/t10/s199/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fg%2F2","sourceRelease":"119-100","text":"the metrics used to measure such progress; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s199/g/3","parentIdentifier":"/us/usc/t10/s199/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fg%2F3","sourceRelease":"119-100","text":"recommendations for congressional consideration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":".—Definitions","label":"h .—Definitions","identifier":"/us/usc/t10/s199/h","parentIdentifier":"/us/usc/t10/s199","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s199/h/1","parentIdentifier":"/us/usc/t10/s199/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fh%2F1","sourceRelease":"119-100","text":"The term “counter-sUAS system” means a system or device capable of lawfully and safely disabling, disrupting, or seizing control of a small unmanned aircraft or small unmanned aircraft system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s199/h/2","parentIdentifier":"/us/usc/t10/s199/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fh%2F2","sourceRelease":"119-100","text":"The term “covered armed forces” means the Army, Navy, Air Force, Marine Corps, and Space Force.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s199/h/3","parentIdentifier":"/us/usc/t10/s199/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs199%2Fh%2F3","sourceRelease":"119-100","text":"The terms “small unmanned aircraft”, “unmanned aircraft”, and “unmanned aircraft system” have the meanings given those terms in .section 44801 of title 49","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
