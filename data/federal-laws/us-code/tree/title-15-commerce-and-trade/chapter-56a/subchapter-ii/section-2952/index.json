{"type":"section","nativeType":"section","number":"2952","heading":"International discussions","label":"2952 International discussions","identifier":"/us/usc/t15/s2952","parentIdentifier":"/us/usc/t15/ch56A/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Global change research","label":"a Global change research","identifier":"/us/usc/t15/s2952/a","parentIdentifier":"/us/usc/t15/s2952","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2952/a/1","parentIdentifier":"/us/usc/t15/s2952/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fa%2F1","sourceRelease":"119-100","text":"Allocation of costs in global change research programs, especially with respect to major capital projects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2952/a/2","parentIdentifier":"/us/usc/t15/s2952/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fa%2F2","sourceRelease":"119-100","text":"Coordination of global change research plans with those developed by international organizations such as the International Council on Scientific Unions, the World Meteorological Organization, and the United Nations Environment Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s2952/a/3","parentIdentifier":"/us/usc/t15/s2952/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fa%2F3","sourceRelease":"119-100","text":"Establishment of global change research centers and training programs for scientists, especially those from developing nations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s2952/a/4","parentIdentifier":"/us/usc/t15/s2952/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s2952/a/4/A","parentIdentifier":"/us/usc/t15/s2952/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fa%2F4%2FA","sourceRelease":"119-100","text":"use of new or existing intergovernmental organizations for the coordination or funding of global change research; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s2952/a/4/B","parentIdentifier":"/us/usc/t15/s2952/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fa%2F4%2FB","sourceRelease":"119-100","text":"creation of a limited foundation for global change research.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s2952/a/5","parentIdentifier":"/us/usc/t15/s2952/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s2952/a/5/A","parentIdentifier":"/us/usc/t15/s2952/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fa%2F5%2FA","sourceRelease":"119-100","text":"create globally accessible formats for data collected by various international sources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s2952/a/5/B","parentIdentifier":"/us/usc/t15/s2952/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fa%2F5%2FB","sourceRelease":"119-100","text":"combine and interpret data from various sources to produce information readily usable by policymakers attempting to formulate effective strategies for preventing, mitigating, and adapting to possible adverse effects of global change.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s2952/a/6","parentIdentifier":"/us/usc/t15/s2952/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fa%2F6","sourceRelease":"119-100","text":"Establishment of international offices to disseminate information useful in identifying, preventing, mitigating, or adapting to the possible effects of global change.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Energy research","label":"b Energy research","identifier":"/us/usc/t15/s2952/b","parentIdentifier":"/us/usc/t15/s2952","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2952/b/1","parentIdentifier":"/us/usc/t15/s2952/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fb%2F1","sourceRelease":"119-100","text":"Creation of an international cooperative program to fund research related to energy efficiency, solar and other renewable energy sources, and passively safe and diversion-resistant nuclear reactors.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2952/b/2","parentIdentifier":"/us/usc/t15/s2952/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fb%2F2","sourceRelease":"119-100","text":"Creation of an international cooperative program to develop low cost energy technologies which are appropriate to the environmental, economic, and social needs of developing nations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s2952/b/3","parentIdentifier":"/us/usc/t15/s2952/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2952%2Fb%2F3","sourceRelease":"119-100","text":"Exchange of information concerning environmentally safe energy technologies and practices, including those described in paragraphs (1) and (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
