{"type":"section","nativeType":"section","number":"1638g","heading":"Mobile health stations demonstration program","label":"1638g Mobile health stations demonstration program","identifier":"/us/usc/t25/s1638g","parentIdentifier":"/us/usc/t25/ch18/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Codificationis based on section 147 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by .Section 313 of Pub. L. 94–437section 10221(a) of Pub. L. 111–148"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t25/s1638g/a","parentIdentifier":"/us/usc/t25/s1638g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible tribal consortium","label":"1 Eligible tribal consortium","identifier":"/us/usc/t25/s1638g/a/1","parentIdentifier":"/us/usc/t25/s1638g/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa%2F1","sourceRelease":"119-100","text":"The term “eligible tribal consortium” means a consortium composed of 2 or more Service units between which a mobile health station can be transported by road in up to 8 hours. A Service unit operated by the Service or by an Indian tribe or tribal organization shall be equally eligible for participation in such consortium.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Mobile health station","label":"2 Mobile health station","identifier":"/us/usc/t25/s1638g/a/2","parentIdentifier":"/us/usc/t25/s1638g/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1638g/a/2/A","parentIdentifier":"/us/usc/t25/s1638g/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa%2F2%2FA","sourceRelease":"119-100","text":"is constructed, maintained, and capable of being transported within a semi-trailer truck or similar vehicle;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1638g/a/2/B","parentIdentifier":"/us/usc/t25/s1638g/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa%2F2%2FB","sourceRelease":"119-100","text":"is equipped for the provision of 1 or more specialty health care services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1638g/a/2/C","parentIdentifier":"/us/usc/t25/s1638g/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa%2F2%2FC","sourceRelease":"119-100","text":"can be equipped to be docked to a stationary health care facility when appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Specialty health care service","label":"3 Specialty health care service","identifier":"/us/usc/t25/s1638g/a/3","parentIdentifier":"/us/usc/t25/s1638g/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t25/s1638g/a/3/A","parentIdentifier":"/us/usc/t25/s1638g/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa%2F3%2FA","sourceRelease":"119-100","text":"The term “specialty health care service” means a health care service which requires the services of a health care professional with specialized knowledge or experience.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Inclusions","label":"B Inclusions","identifier":"/us/usc/t25/s1638g/a/3/B","parentIdentifier":"/us/usc/t25/s1638g/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s1638g/a/3/B/i","parentIdentifier":"/us/usc/t25/s1638g/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa%2F3%2FB%2Fi","sourceRelease":"119-100","text":"dialysis;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s1638g/a/3/B/ii","parentIdentifier":"/us/usc/t25/s1638g/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa%2F3%2FB%2Fii","sourceRelease":"119-100","text":"surgery;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t25/s1638g/a/3/B/iii","parentIdentifier":"/us/usc/t25/s1638g/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"mammography;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t25/s1638g/a/3/B/iv","parentIdentifier":"/us/usc/t25/s1638g/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa%2F3%2FB%2Fiv","sourceRelease":"119-100","text":"dentistry; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t25/s1638g/a/3/B/v","parentIdentifier":"/us/usc/t25/s1638g/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fa%2F3%2FB%2Fv","sourceRelease":"119-100","text":"any other specialty health care service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t25/s1638g/b","parentIdentifier":"/us/usc/t25/s1638g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fb","sourceRelease":"119-100","text":"The Secretary, acting through the Service, shall establish a demonstration program under which the Secretary shall provide at least 3 mobile health station projects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Petition","label":"c Petition","identifier":"/us/usc/t25/s1638g/c","parentIdentifier":"/us/usc/t25/s1638g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s1638g/c/1","parentIdentifier":"/us/usc/t25/s1638g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fc%2F1","sourceRelease":"119-100","text":"a description of the Indian population to be served;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s1638g/c/2","parentIdentifier":"/us/usc/t25/s1638g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fc%2F2","sourceRelease":"119-100","text":"a description of the specialty service or services for which the mobile health station is requested and the extent to which such service or services are currently available to the Indian population to be served; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s1638g/c/3","parentIdentifier":"/us/usc/t25/s1638g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fc%2F3","sourceRelease":"119-100","text":"such other information as the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Use of funds","label":"d Use of funds","identifier":"/us/usc/t25/s1638g/d","parentIdentifier":"/us/usc/t25/s1638g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s1638g/d/1","parentIdentifier":"/us/usc/t25/s1638g/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1638g/d/1/A","parentIdentifier":"/us/usc/t25/s1638g/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fd%2F1%2FA","sourceRelease":"119-100","text":"to establish, purchase, lease, or maintain mobile health stations for the eligible tribal consortia selected for projects; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1638g/d/1/B","parentIdentifier":"/us/usc/t25/s1638g/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fd%2F1%2FB","sourceRelease":"119-100","text":"to provide, through the mobile health station, such specialty health care services as the affected eligible tribal consortium determines to be necessary for the Indian population served;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s1638g/d/2","parentIdentifier":"/us/usc/t25/s1638g/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fd%2F2","sourceRelease":"119-100","text":"to employ an existing mobile health station (regardless of whether the mobile health station is owned or rented and operated by the Service) to provide specialty health care services to an eligible tribal consortium; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s1638g/d/3","parentIdentifier":"/us/usc/t25/s1638g/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fd%2F3","sourceRelease":"119-100","text":"to establish, purchase, or maintain docking equipment for a mobile health station, including the establishment or maintenance of such equipment at a modular component health care facility (as defined in ), if applicable.section 1638f(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Reports","label":"e Reports","identifier":"/us/usc/t25/s1638g/e","parentIdentifier":"/us/usc/t25/s1638g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s1638g/e/1","parentIdentifier":"/us/usc/t25/s1638g/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fe%2F1","sourceRelease":"119-100","text":"each activity carried out under the demonstration program including an evaluation of the success of the activity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s1638g/e/2","parentIdentifier":"/us/usc/t25/s1638g/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Fe%2F2","sourceRelease":"119-100","text":"the potential benefits of increased use of mobile health stations to provide specialty health care services for Indian communities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorization of appropriations","label":"f Authorization of appropriations","identifier":"/us/usc/t25/s1638g/f","parentIdentifier":"/us/usc/t25/s1638g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1638g%2Ff","sourceRelease":"119-100","text":"There are authorized to be appropriated $5,000,000 per year to carry out the demonstration program under this section for the first 5 fiscal years, and such sums as may be needed to carry out the program in subsequent fiscal years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
