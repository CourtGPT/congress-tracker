{"type":"section","nativeType":"section","number":"15093","heading":"Grants to States","label":"15093 Grants to States","identifier":"/us/usc/t42/s15093","parentIdentifier":"/us/usc/t42/ch144/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s15093/a","parentIdentifier":"/us/usc/t42/s15093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fa","sourceRelease":"119-100","text":"The Secretary shall make grants to States on a competitive basis, in accordance with the provisions of this subchapter, to support systems change activities designed to assist States to develop and implement, or expand and enhance, a statewide system of family support services for families of children with disabilities that accomplishes the purposes of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Award period and grant limitation","label":"b Award period and grant limitation","identifier":"/us/usc/t42/s15093/b","parentIdentifier":"/us/usc/t42/s15093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fb","sourceRelease":"119-100","text":"No grant shall be awarded under this section for a period of more than 3 years. No State shall be eligible for more than 1 grant under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Amount of grants","label":"c Amount of grants","identifier":"/us/usc/t42/s15093/c","parentIdentifier":"/us/usc/t42/s15093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Grants to States","label":"1 Grants to States","identifier":"/us/usc/t42/s15093/c/1","parentIdentifier":"/us/usc/t42/s15093/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Federal matching share","label":"A Federal matching share","identifier":"/us/usc/t42/s15093/c/1/A","parentIdentifier":"/us/usc/t42/s15093/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s15093/c/1/A/i","parentIdentifier":"/us/usc/t42/s15093/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"equal to not more than 75 percent of the cost of the systems change activities to be carried out by the State; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s15093/c/1/A/ii","parentIdentifier":"/us/usc/t42/s15093/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"not less than $100,000 and not more than $500,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Non-Federal share","label":"B Non-Federal share","identifier":"/us/usc/t42/s15093/c/1/B","parentIdentifier":"/us/usc/t42/s15093/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fc%2F1%2FB","sourceRelease":"119-100","text":"The non-Federal share of the cost of the systems change activities may be in cash or in kind, fairly evaluated, including plant, equipment, or services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Calculation of amounts","label":"2 Calculation of amounts","identifier":"/us/usc/t42/s15093/c/2","parentIdentifier":"/us/usc/t42/s15093/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15093/c/2/A","parentIdentifier":"/us/usc/t42/s15093/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the amounts available for making grants under this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15093/c/2/B","parentIdentifier":"/us/usc/t42/s15093/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the child population of the State concerned.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Priority for previously participating States","label":"d Priority for previously participating States","identifier":"/us/usc/t42/s15093/d","parentIdentifier":"/us/usc/t42/s15093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fd","sourceRelease":"119-100","text":"For the second and third fiscal years for which amounts are appropriated to carry out this section, the Secretary, in providing payments under this section, shall give priority to States that received payments under this section during the preceding fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Priorities for distribution","label":"e Priorities for distribution","identifier":"/us/usc/t42/s15093/e","parentIdentifier":"/us/usc/t42/s15093","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15093/e/1","parentIdentifier":"/us/usc/t42/s15093/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fe%2F1","sourceRelease":"119-100","text":"is geographically equitable;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15093/e/2","parentIdentifier":"/us/usc/t42/s15093/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fe%2F2","sourceRelease":"119-100","text":"distributes the grants among States that have differing levels of development of statewide systems of family support services for families of children with disabilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s15093/e/3","parentIdentifier":"/us/usc/t42/s15093/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15093%2Fe%2F3","sourceRelease":"119-100","text":"distributes the grants among States that attempt to meet the needs of unserved and underserved populations, such as individuals from racial and ethnic minority backgrounds, disadvantaged individuals, individuals with limited English proficiency, and individuals from underserved geographic areas (rural or urban).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
