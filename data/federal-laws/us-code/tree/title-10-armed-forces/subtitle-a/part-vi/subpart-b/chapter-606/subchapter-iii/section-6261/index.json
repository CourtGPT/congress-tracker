{"type":"section","nativeType":"section","number":"6261","heading":"Worker protection at nuclear weapons facilities","label":"6261 Worker protection at nuclear weapons facilities","identifier":"/us/usc/t10/s6261","parentIdentifier":"/us/usc/t10/stA/ptVI/sptB/ch606/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsProvisions similar to those in this section were contained in , War and National Defense, prior to repeal by .section 2731 of Title 50Pub. L. 119–60, § 3111(b)(1)","Amendments2025—, realigned margins.Pub. L. 119–60, § 3111(d)(2)(B)"],"amendments":["Amendments2025—, realigned margins.Pub. L. 119–60, § 3111(d)(2)(B)"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Training Grant Program","label":"a .—Training Grant Program","identifier":"/us/usc/t10/s6261/a","parentIdentifier":"/us/usc/t10/s6261","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6261/a/1","parentIdentifier":"/us/usc/t10/s6261/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s6261/a/1/A","parentIdentifier":"/us/usc/t10/s6261/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fa%2F1%2FA","sourceRelease":"119-100","text":"to provide training and education to persons who are or may be engaged in hazardous substance response or emergency response at Department of Energy nuclear weapons facilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s6261/a/1/B","parentIdentifier":"/us/usc/t10/s6261/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fa%2F1%2FB","sourceRelease":"119-100","text":"to develop curricula for such training and education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6261/a/2","parentIdentifier":"/us/usc/t10/s6261/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s6261/a/2/A","parentIdentifier":"/us/usc/t10/s6261/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s6261/a/2/A/i","parentIdentifier":"/us/usc/t10/s6261/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"implementing and conducting effective training and education programs relating to the general health and safety of workers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s6261/a/2/A/ii","parentIdentifier":"/us/usc/t10/s6261/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"identifying, and involving in training, groups of workers whose duties include hazardous substance response or emergency response.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s6261/a/2/B","parentIdentifier":"/us/usc/t10/s6261/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fa%2F2%2FB","sourceRelease":"119-100","text":"The Secretary shall give preference in the award of grants under this section to employee organizations and joint labor-management training programs that are grant recipients under section 126(g) of the Superfund Amendments and Reauthorization Act of 1986 ().42 U.S.C. 9660a","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s6261/a/3","parentIdentifier":"/us/usc/t10/s6261/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fa%2F3","sourceRelease":"119-100","text":"An organization awarded a grant under paragraph (1) shall carry out training, education, or curricula development pursuant to Department of Energy orders relating to employee safety training, including orders numbered 5480.4 and 5480.11.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Enforcement of Employee Safety Standards","label":"b .—Enforcement of Employee Safety Standards","identifier":"/us/usc/t10/s6261/b","parentIdentifier":"/us/usc/t10/s6261","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6261/b/1","parentIdentifier":"/us/usc/t10/s6261/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s6261/b/1/A","parentIdentifier":"/us/usc/t10/s6261/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fb%2F1%2FA","sourceRelease":"119-100","text":"employs individuals who are engaged in hazardous substance response or emergency response at Department of Energy nuclear weapons facilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s6261/b/1/B","parentIdentifier":"/us/usc/t10/s6261/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fb%2F1%2FB","sourceRelease":"119-100","text":"fails (i) to provide for the training of such individuals to carry out such hazardous substance response or emergency response, or (ii) to certify to the Department of Energy that such employees are adequately trained for such response pursuant to orders issued by the Department of Energy relating to employee safety training (including orders numbered 5480.4 and 5480.11).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6261/b/2","parentIdentifier":"/us/usc/t10/s6261/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fb%2F2","sourceRelease":"119-100","text":"Civil penalties assessed under this subsection may not exceed $5,000 for each day in which a failure referred to in paragraph (1)(B) occurs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Regulations","label":"c .—Regulations","identifier":"/us/usc/t10/s6261/c","parentIdentifier":"/us/usc/t10/s6261","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fc","sourceRelease":"119-100","text":"The Secretary shall prescribe regulations to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Definitions","label":"d .—Definitions","identifier":"/us/usc/t10/s6261/d","parentIdentifier":"/us/usc/t10/s6261","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6261%2Fd","sourceRelease":"119-100","text":"For the purposes of this section, the term “hazardous substance” includes radioactive waste and mixed radioactive and hazardous waste.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
