{"type":"section","nativeType":"section","number":"13293","heading":"Protection of proprietary information","label":"13293 Protection of proprietary information","identifier":"/us/usc/t42/s13293","parentIdentifier":"/us/usc/t42/ch134/schIV/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13293","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s13293/a","parentIdentifier":"/us/usc/t42/s13293","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13293%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13293/a/1","parentIdentifier":"/us/usc/t42/s13293/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13293%2Fa%2F1","sourceRelease":"119-100","text":"results from research and development activities conducted under this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13293/a/2","parentIdentifier":"/us/usc/t42/s13293/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13293%2Fa%2F2","sourceRelease":"119-100","text":"would be a trade secret or commercial or financial information that is privileged or confidential if the information had been obtained from a participant,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"“Domestic companies” defined","label":"b “Domestic companies” defined","identifier":"/us/usc/t42/s13293/b","parentIdentifier":"/us/usc/t42/s13293","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13293%2Fb","sourceRelease":"119-100","text":"For purposes of subsection (a), the term “domestic companies” means entities which are substantially involved in the United States in the domestic production of motor vehicles for sale in the United States and have a substantial percentage of their production facilities in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
