{"type":"section","nativeType":"section","number":"8698","heading":"Roles and responsibilities relating to sustainment and readiness of certain naval surface vessels","label":"8698 Roles and responsibilities relating to sustainment and readiness of certain naval surface vessels","identifier":"/us/usc/t10/s8698","parentIdentifier":"/us/usc/t10/stC/ptIV/ch863","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe date of the enactment of this section, referred to in text, means the date of enactment of the National Defense Authorization Act for Fiscal Year 2026, which was approved on .December 18, 2025"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Type Commander Leadership","label":"a .—Type Commander Leadership","identifier":"/us/usc/t10/s8698/a","parentIdentifier":"/us/usc/t10/s8698","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s8698/a/1","parentIdentifier":"/us/usc/t10/s8698/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8698/a/1/A","parentIdentifier":"/us/usc/t10/s8698/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fa%2F1%2FA","sourceRelease":"119-100","text":"designate type commanders as the primary authorities responsible for the maintenance, repair, sustainment, and readiness of covered vessels; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8698/a/1/B","parentIdentifier":"/us/usc/t10/s8698/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fa%2F1%2FB","sourceRelease":"119-100","text":"ensure that regional maintenance centers act under the direction of, and in support of, type commanders with respect to such maintenance, repair, and sustainment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s8698/a/2","parentIdentifier":"/us/usc/t10/s8698/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8698/a/2/A","parentIdentifier":"/us/usc/t10/s8698/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fa%2F2%2FA","sourceRelease":"119-100","text":"overseeing all maintenance and repair activities at private shipyards for covered vessels in the naval force of that type commander; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8698/a/2/B","parentIdentifier":"/us/usc/t10/s8698/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fa%2F2%2FB","sourceRelease":"119-100","text":"setting priorities and approving contracts for the maintenance and repair of such vessels.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Maintenance and Repair at Private Shipyards","label":"b .—Maintenance and Repair at Private Shipyards","identifier":"/us/usc/t10/s8698/b","parentIdentifier":"/us/usc/t10/s8698","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s8698/b/1","parentIdentifier":"/us/usc/t10/s8698/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8698/b/1/A","parentIdentifier":"/us/usc/t10/s8698/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fb%2F1%2FA","sourceRelease":"119-100","text":"may jointly determine the work to be performed during the overhaul period for the covered vessel, including by jointly adjusting priorities for such work consistent with the applicable budget and schedule for such maintenance or repair; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8698/b/1/B","parentIdentifier":"/us/usc/t10/s8698/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fb%2F1%2FB","sourceRelease":"119-100","text":"shall report directly to the type commander of the naval force to which the covered vessel belongs with respect to such maintenance or repair.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s8698/b/2","parentIdentifier":"/us/usc/t10/s8698/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fb%2F2","sourceRelease":"119-100","text":"Contracting officers of the Department of Defense shall manage contracts as necessary to ensure consistency with any determination or adjustment made pursuant to paragraph (1)(A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Definitions","label":"c .—Definitions","identifier":"/us/usc/t10/s8698/c","parentIdentifier":"/us/usc/t10/s8698","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s8698/c/1","parentIdentifier":"/us/usc/t10/s8698/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fc%2F1","sourceRelease":"119-100","text":"The term “covered vessel” means a naval surface vessel that is not propelled or powered by a nuclear reactor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s8698/c/2","parentIdentifier":"/us/usc/t10/s8698/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fc%2F2","sourceRelease":"119-100","text":"The term “port engineer concerned” means, with respect to a naval vessel, the technical expert on the condition of such vessel responsible for advising on repairs and related standards for such vessel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s8698/c/3","parentIdentifier":"/us/usc/t10/s8698/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fc%2F3","sourceRelease":"119-100","text":"The term “project manager concerned” means, with respect to a naval vessel undergoing maintenance or repair, the individual responsible for overseeing the overhaul period with respect to such maintenance or repair.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s8698/c/4","parentIdentifier":"/us/usc/t10/s8698/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8698/c/4/A","parentIdentifier":"/us/usc/t10/s8698/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fc%2F4%2FA","sourceRelease":"119-100","text":"means an organization of the Navy that supports ship maintenance in a designated geographic region; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8698/c/4/B","parentIdentifier":"/us/usc/t10/s8698/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fc%2F4%2FB","sourceRelease":"119-100","text":"includes the Mid-Atlantic Regional Maintenance Center in Nofolk, Virginia, the Southwest Regional Maintenance Center in San Diego, California, the Southeast Regional Maintenance Center in Mayport, Florida, and the Hawaii Regional Maintenance Center in Pearl Harbor, Hawaii.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s8698/c/5","parentIdentifier":"/us/usc/t10/s8698/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s8698/c/5/A","parentIdentifier":"/us/usc/t10/s8698/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fc%2F5%2FA","sourceRelease":"119-100","text":"Commander, Naval Surface Force, Atlantic.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s8698/c/5/B","parentIdentifier":"/us/usc/t10/s8698/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs8698%2Fc%2F5%2FB","sourceRelease":"119-100","text":"Commander, Naval Surface Force, Pacific Fleet.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
