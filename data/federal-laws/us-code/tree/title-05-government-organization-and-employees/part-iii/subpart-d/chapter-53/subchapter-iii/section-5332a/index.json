of Title 16October 1, 2024Mar. 15, 2025"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Definitions","label":"a .—Definitions","identifier":"/us/usc/t5/s5332a/a","parentIdentifier":"/us/usc/t5/s5332a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s5332a/a/1","parentIdentifier":"/us/usc/t5/s5332a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s5332a/a/1/A","parentIdentifier":"/us/usc/t5/s5332a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fa%2F1%2FA","sourceRelease":"119-100","text":"is a firefighter within the meaning of section 8331(21) or section 8401(14);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s5332a/a/1/B","parentIdentifier":"/us/usc/t5/s5332a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fa%2F1%2FB","sourceRelease":"119-100","text":"in the case of an employee who holds a supervisory or administrative position and is subject to subchapter III of chapter 83, but who does not qualify to be considered a firefighter within the meaning of section 8331(21), would otherwise qualify if the employee had transferred directly to that position after serving as a firefighter within the meaning of that section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s5332a/a/1/C","parentIdentifier":"/us/usc/t5/s5332a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fa%2F1%2FC","sourceRelease":"119-100","text":"in the case of an employee who holds a supervisory or administrative position and is subject to chapter 84, but who does not qualify to be considered a firefighter within the meaning of section 8401(14), would otherwise qualify if the employee had transferred directly to that position after performing duties described in section 8401(14)(A) for at least 3 years; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t5/s5332a/a/1/D","parentIdentifier":"/us/usc/t5/s5332a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fa%2F1%2FD","sourceRelease":"119-100","text":"in the case of an employee who is not subject to subchapter III of chapter 83 or chapter 84, holds a position that the Office of Personnel Management determines would satisfy subparagraph (A), (B), or (C) if the employee were subject to subchapter III of chapter 83 or chapter 84;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s5332a/a/2","parentIdentifier":"/us/usc/t5/s5332a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fa%2F2","sourceRelease":"119-100","text":"the term “General Schedule base rate” means an annual rate of basic pay established under section 5332 before any additions, such as a locality-based comparability payment under section 5304 or 5304a or a special rate supplement under section 5305;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s5332a/a/3","parentIdentifier":"/us/usc/t5/s5332a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fa%2F3","sourceRelease":"119-100","text":"the term “special base rate” means an annual rate of basic pay payable to a wildland firefighter, before any additions or reductions, that replaces the General Schedule base rate otherwise applicable to the wildland firefighter and that is administered in the same manner as a General Schedule base rate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t5/s5332a/a/4","parentIdentifier":"/us/usc/t5/s5332a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s5332a/a/4/A","parentIdentifier":"/us/usc/t5/s5332a/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fa%2F4%2FA","sourceRelease":"119-100","text":"who is employed by the Forest Service or the Department of the Interior; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s5332a/a/4/B","parentIdentifier":"/us/usc/t5/s5332a/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fa%2F4%2FB","sourceRelease":"119-100","text":"the duties of the position of whom primarily relate to fires occurring in forests, range lands, or other wildlands, as opposed to structural fires.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Special Base Rates of Pay.—","label":"b Special Base Rates of Pay.—","identifier":"/us/usc/t5/s5332a/b","parentIdentifier":"/us/usc/t5/s5332a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Entitlement to special rate","label":"1 .—Entitlement to special rate","identifier":"/us/usc/t5/s5332a/b/1","parentIdentifier":"/us/usc/t5/s5332a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s5332a/b/1/A","parentIdentifier":"/us/usc/t5/s5332a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"replace the otherwise applicable General Schedule base rate for the wildland firefighter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s5332a/b/1/B","parentIdentifier":"/us/usc/t5/s5332a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F1%2FB","sourceRelease":"119-100","text":"be basic pay for all purposes, including the purpose of computing a locality-based comparability payment under section 5304 or 5304a; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s5332a/b/1/C","parentIdentifier":"/us/usc/t5/s5332a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F1%2FC","sourceRelease":"119-100","text":"be computed as described in paragraph (2) and adjusted at the time of adjustments in the General Schedule.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Computation","label":"2 .—Computation","identifier":"/us/usc/t5/s5332a/b/2","parentIdentifier":"/us/usc/t5/s5332a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t5/s5332a/b/2/A","parentIdentifier":"/us/usc/t5/s5332a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t5/s5332a/b/2/A/i","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"For GS–1, 42 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t5/s5332a/b/2/A/ii","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"For GS–2, 39 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t5/s5332a/b/2/A/iii","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"For GS–3, 36 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t5/s5332a/b/2/A/iv","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"For GS–4, 33 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t5/s5332a/b/2/A/v","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fv","sourceRelease":"119-100","text":"For GS–5, 30 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t5/s5332a/b/2/A/vi","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fvi","sourceRelease":"119-100","text":"For GS–6, 27 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t5/s5332a/b/2/A/vii","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fvii","sourceRelease":"119-100","text":"For GS–7, 24 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t5/s5332a/b/2/A/viii","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fviii","sourceRelease":"119-100","text":"For GS–8, 21 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ix","heading":null,"label":"ix","identifier":"/us/usc/t5/s5332a/b/2/A/ix","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fix","sourceRelease":"119-100","text":"For GS–9, 18 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"x","heading":null,"label":"x","identifier":"/us/usc/t5/s5332a/b/2/A/x","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fx","sourceRelease":"119-100","text":"For GS–10, 15 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xi","heading":null,"label":"xi","identifier":"/us/usc/t5/s5332a/b/2/A/xi","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fxi","sourceRelease":"119-100","text":"For GS–11, 12 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xii","heading":null,"label":"xii","identifier":"/us/usc/t5/s5332a/b/2/A/xii","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fxii","sourceRelease":"119-100","text":"For GS–12, 9 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xiii","heading":null,"label":"xiii","identifier":"/us/usc/t5/s5332a/b/2/A/xiii","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fxiii","sourceRelease":"119-100","text":"For GS–13, 6 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xiv","heading":null,"label":"xiv","identifier":"/us/usc/t5/s5332a/b/2/A/xiv","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fxiv","sourceRelease":"119-100","text":"For GS–14, 3 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xv","heading":null,"label":"xv","identifier":"/us/usc/t5/s5332a/b/2/A/xv","parentIdentifier":"/us/usc/t5/s5332a/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FA%2Fxv","sourceRelease":"119-100","text":"For GS–15, 1.5 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Hourly, daily, weekly, or biweekly rates","label":"B .—Hourly, daily, weekly, or biweekly rates","identifier":"/us/usc/t5/s5332a/b/2/B","parentIdentifier":"/us/usc/t5/s5332a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs5332a%2Fb%2F2%2FB","sourceRelease":"119-100","text":"When the special base rate with respect to a wildland firefighter is expressed as an hourly, daily, weekly, or biweekly rate, the special base rate shall be computed from the appropriate annual rate of basic pay derived under subparagraph (A) in accordance with the rules under section 5504(b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
