{"type":"section","nativeType":"section","number":"7470","heading":"Referenda","label":"7470 Referenda","identifier":"/us/usc/t7/s7470","parentIdentifier":"/us/usc/t7/ch101/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Initial referendum","label":"a Initial referendum","identifier":"/us/usc/t7/s7470/a","parentIdentifier":"/us/usc/t7/s7470","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Referendum required","label":"1 Referendum required","identifier":"/us/usc/t7/s7470/a/1","parentIdentifier":"/us/usc/t7/s7470/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fa%2F1","sourceRelease":"119-100","text":"During the 60-day period immediately preceding the proposed effective date of an order issued under , the Secretary shall conduct a referendum among kiwifruit producers and importers who will be subject to assessments under the order, to ascertain whether producers and importers approve the implementation of the order.section 7463 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Approval of order","label":"2 Approval of order","identifier":"/us/usc/t7/s7470/a/2","parentIdentifier":"/us/usc/t7/s7470/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7470/a/2/A","parentIdentifier":"/us/usc/t7/s7470/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the order has been approved by a majority of the producers and importers voting in the referendum; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7470/a/2/B","parentIdentifier":"/us/usc/t7/s7470/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the producers and importers favoring approval produce and import more than 50 percent of the total volume of kiwifruit produced and imported by persons voting in the referendum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Subsequent referenda","label":"b Subsequent referenda","identifier":"/us/usc/t7/s7470/b","parentIdentifier":"/us/usc/t7/s7470","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fb","sourceRelease":"119-100","text":"The Secretary may periodically conduct a referendum to determine if kiwifruit producers and importers favor the continuation, termination, or suspension of any order issued under that is in effect at the time of the referendum.section 7463 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Required referenda","label":"c Required referenda","identifier":"/us/usc/t7/s7470/c","parentIdentifier":"/us/usc/t7/s7470","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7470/c/1","parentIdentifier":"/us/usc/t7/s7470/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fc%2F1","sourceRelease":"119-100","text":"at the end of the 6-year period beginning on the effective date of the order and at the end of each subsequent 6-year period;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7470/c/2","parentIdentifier":"/us/usc/t7/s7470/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fc%2F2","sourceRelease":"119-100","text":"at the request of the Board; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7470/c/3","parentIdentifier":"/us/usc/t7/s7470/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fc%2F3","sourceRelease":"119-100","text":"if not less than 30 percent of the kiwifruit producers and importers subject to assessments under the order submit a petition requesting the referendum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Vote","label":"d Vote","identifier":"/us/usc/t7/s7470/d","parentIdentifier":"/us/usc/t7/s7470","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7470/d/1","parentIdentifier":"/us/usc/t7/s7470/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fd%2F1","sourceRelease":"119-100","text":"the suspension or termination of the order is favored by not less than a majority of the producers and importers voting in the referendum; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7470/d/2","parentIdentifier":"/us/usc/t7/s7470/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fd%2F2","sourceRelease":"119-100","text":"the producers and importers produce and import more than 50 percent of the total volume of kiwifruit produced and imported by persons voting in the referendum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Confidentiality","label":"e Confidentiality","identifier":"/us/usc/t7/s7470/e","parentIdentifier":"/us/usc/t7/s7470","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7470%2Fe","sourceRelease":"119-100","text":"The ballots and other information or reports that reveal, or tend to reveal, the vote of any person under this subchapter and the voting list shall be held strictly confidential and shall not be disclosed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
