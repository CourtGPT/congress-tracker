t22/s2736c/a/1/C/iv","parentIdentifier":"/us/usc/t22/s2736c/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2736c%2Fa%2F1%2FC%2Fiv","sourceRelease":"119-100","text":"professional schools of international affairs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Training for senior positions","label":"2 Training for senior positions","identifier":"/us/usc/t22/s2736c/a/2","parentIdentifier":"/us/usc/t22/s2736c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2736c%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t22/s2736c/a/2/A","parentIdentifier":"/us/usc/t22/s2736c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2736c%2Fa%2F2%2FA","sourceRelease":"119-100","text":"The Secretary shall offer, or sponsor members of the workforce to participate in, a Senior Executive Service candidate development program or other program that trains members on the skills required for appointment to senior positions in the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Requirements","label":"B Requirements","identifier":"/us/usc/t22/s2736c/a/2/B","parentIdentifier":"/us/usc/t22/s2736c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2736c%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s2736c/a/2/B/i","parentIdentifier":"/us/usc/t22/s2736c/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2736c%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"ensure any program offered or sponsored by the Department under such subparagraph comports with the requirements of subpart C of part 412 of title 5, Code of Federal Regulations, or any successor thereto, including merit staffing and assessment requirements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s2736c/a/2/B/ii","parentIdentifier":"/us/usc/t22/s2736c/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2736c%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"consider the number of expected vacancies in senior positions as a factor in determining the number of candidates to select for such programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t22/s2736c/a/2/B/iii","parentIdentifier":"/us/usc/t22/s2736c/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2736c%2Fa%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"understand how participation in any program offered or sponsored by the Department under such subparagraph differs by gender, race, national origin, disability status, or other demographic categories; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t22/s2736c/a/2/B/iv","parentIdentifier":"/us/usc/t22/s2736c/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs2736c%2Fa%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"actively encourage participation from a range of demographic categories, especially from categories with consistently low participation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
