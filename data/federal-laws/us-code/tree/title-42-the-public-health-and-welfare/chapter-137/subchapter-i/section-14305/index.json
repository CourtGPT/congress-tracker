{"type":"section","nativeType":"section","number":"14305","heading":"Information gathering and access","label":"14305 Information gathering and access","identifier":"/us/usc/t42/s14305","parentIdentifier":"/us/usc/t42/ch137/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14305","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Records and reports","label":"a Records and reports","identifier":"/us/usc/t42/s14305/a","parentIdentifier":"/us/usc/t42/s14305","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14305%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s14305/a/1","parentIdentifier":"/us/usc/t42/s14305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14305%2Fa%2F1","sourceRelease":"119-100","text":"a regulated battery manufacturer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s14305/a/2","parentIdentifier":"/us/usc/t42/s14305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14305%2Fa%2F2","sourceRelease":"119-100","text":"a rechargeable consumer product manufacturer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s14305/a/3","parentIdentifier":"/us/usc/t42/s14305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14305%2Fa%2F3","sourceRelease":"119-100","text":"a mercury-containing battery manufacturer; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s14305/a/4","parentIdentifier":"/us/usc/t42/s14305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14305%2Fa%2F4","sourceRelease":"119-100","text":"an authorized agent of a person described in paragraph (1), (2), or (3),","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Access and copying","label":"b Access and copying","identifier":"/us/usc/t42/s14305/b","parentIdentifier":"/us/usc/t42/s14305","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14305%2Fb","sourceRelease":"119-100","text":"The Administrator or the Administrator’s authorized representative, on presentation of credentials of the Administrator, may at reasonable times have access to and copy any records required to be maintained under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Confidentiality","label":"c Confidentiality","identifier":"/us/usc/t42/s14305/c","parentIdentifier":"/us/usc/t42/s14305","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs14305%2Fc","sourceRelease":"119-100","text":"The Administrator shall maintain the confidentiality of documents and records that contain proprietary information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
