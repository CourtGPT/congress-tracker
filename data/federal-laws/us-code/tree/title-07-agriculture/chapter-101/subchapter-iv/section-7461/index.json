{"type":"section","nativeType":"section","number":"7461","heading":"Findings and purposes","label":"7461 Findings and purposes","identifier":"/us/usc/t7/s7461","parentIdentifier":"/us/usc/t7/ch101/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7461","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Findings","label":"a Findings","identifier":"/us/usc/t7/s7461/a","parentIdentifier":"/us/usc/t7/s7461","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7461%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7461/a/1","parentIdentifier":"/us/usc/t7/s7461/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7461%2Fa%2F1","sourceRelease":"119-100","text":"domestically produced kiwifruit are grown by many individual producers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7461/a/2","parentIdentifier":"/us/usc/t7/s7461/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7461%2Fa%2F2","sourceRelease":"119-100","text":"virtually all domestically produced kiwifruit are grown in the State of California, although there is potential for production in many other areas of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7461/a/3","parentIdentifier":"/us/usc/t7/s7461/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7461%2Fa%2F3","sourceRelease":"119-100","text":"kiwifruit move in interstate and foreign commerce, and kiwifruit that do not move in channels of commerce directly burden or affect interstate commerce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s7461/a/4","parentIdentifier":"/us/usc/t7/s7461/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7461%2Fa%2F4","sourceRelease":"119-100","text":"in recent years, large quantities of kiwifruit have been imported into the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s7461/a/5","parentIdentifier":"/us/usc/t7/s7461/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7461%2Fa%2F5","sourceRelease":"119-100","text":"the maintenance and expansion of existing domestic and foreign markets for kiwifruit, and the development of additional and improved markets for kiwifruit, are vital to the welfare of kiwifruit producers and other persons concerned with producing, marketing, and processing kiwifruit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s7461/a/6","parentIdentifier":"/us/usc/t7/s7461/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7461%2Fa%2F6","sourceRelease":"119-100","text":"a coordinated program of research, promotion, and consumer information regarding kiwifruit is necessary for the maintenance and development of the markets; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t7/s7461/a/7","parentIdentifier":"/us/usc/t7/s7461/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7461%2Fa%2F7","sourceRelease":"119-100","text":"kiwifruit producers, handlers, and importers are unable to implement and finance such a program without cooperative action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purposes","label":"b Purposes","identifier":"/us/usc/t7/s7461/b","parentIdentifier":"/us/usc/t7/s7461","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7461%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7461/b/1","parentIdentifier":"/us/usc/t7/s7461/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7461%2Fb%2F1","sourceRelease":"119-100","text":"to authorize the establishment of an orderly procedure for the development and financing (through an assessment) of an effective and coordinated program of research, promotion, and consumer information regarding kiwifruit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7461/b/2","parentIdentifier":"/us/usc/t7/s7461/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7461%2Fb%2F2","sourceRelease":"119-100","text":"to use the program to strengthen the position of the kiwifruit industry in domestic and foreign markets and maintain, develop, and expand markets for kiwifruit; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7461/b/3","parentIdentifier":"/us/usc/t7/s7461/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7461%2Fb%2F3","sourceRelease":"119-100","text":"to treat domestically produced kiwifruit and imported kiwifruit equitably.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
