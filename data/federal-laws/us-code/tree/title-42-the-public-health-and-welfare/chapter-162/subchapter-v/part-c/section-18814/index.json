{"type":"section","nativeType":"section","number":"18814","heading":"State manufacturing leadership","label":"18814 State manufacturing leadership","identifier":"/us/usc/t42/s18814","parentIdentifier":"/us/usc/t42/ch162/schV/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Wage Rate RequirementsFor provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of , including authority of Secretary of Labor, see .Pub. L. 117–58section 18851 of this title"],"amendments":["Wage Rate RequirementsFor provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of , including authority of Secretary of Labor, see .Pub. L. 117–58section 18851 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Financial assistance authorized","label":"a Financial assistance authorized","identifier":"/us/usc/t42/s18814/a","parentIdentifier":"/us/usc/t42/s18814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fa","sourceRelease":"119-100","text":"The Secretary may provide financial assistance on a competitive basis to States for the establishment of programs to be used as models for supporting the implementation of smart manufacturing technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Applications","label":"b Applications","identifier":"/us/usc/t42/s18814/b","parentIdentifier":"/us/usc/t42/s18814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18814/b/1","parentIdentifier":"/us/usc/t42/s18814/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fb%2F1","sourceRelease":"119-100","text":"To be eligible to receive financial assistance under this section, a State shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Criteria","label":"2 Criteria","identifier":"/us/usc/t42/s18814/b/2","parentIdentifier":"/us/usc/t42/s18814/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18814/b/2/A","parentIdentifier":"/us/usc/t42/s18814/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fb%2F2%2FA","sourceRelease":"119-100","text":"technical merit, innovation, and impact;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18814/b/2/B","parentIdentifier":"/us/usc/t42/s18814/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fb%2F2%2FB","sourceRelease":"119-100","text":"research approach, workplan, and deliverables;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18814/b/2/C","parentIdentifier":"/us/usc/t42/s18814/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fb%2F2%2FC","sourceRelease":"119-100","text":"academic and private sector partners; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s18814/b/2/D","parentIdentifier":"/us/usc/t42/s18814/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fb%2F2%2FD","sourceRelease":"119-100","text":"alternate sources of funding.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Requirements","label":"c Requirements","identifier":"/us/usc/t42/s18814/c","parentIdentifier":"/us/usc/t42/s18814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Term","label":"1 Term","identifier":"/us/usc/t42/s18814/c/1","parentIdentifier":"/us/usc/t42/s18814/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fc%2F1","sourceRelease":"119-100","text":"The term of an award of financial assistance under this section shall not exceed 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Maximum amount","label":"2 Maximum amount","identifier":"/us/usc/t42/s18814/c/2","parentIdentifier":"/us/usc/t42/s18814/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fc%2F2","sourceRelease":"119-100","text":"The amount of an award of financial assistance under this section shall be not more than $2,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Matching requirement","label":"3 Matching requirement","identifier":"/us/usc/t42/s18814/c/3","parentIdentifier":"/us/usc/t42/s18814/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fc%2F3","sourceRelease":"119-100","text":"Each State that receives financial assistance under this section shall contribute matching funds in an amount equal to not less than 30 percent of the amount of the financial assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Use of funds","label":"d Use of funds","identifier":"/us/usc/t42/s18814/d","parentIdentifier":"/us/usc/t42/s18814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18814/d/1","parentIdentifier":"/us/usc/t42/s18814/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fd%2F1","sourceRelease":"119-100","text":"to facilitate access to high-performance computing resources for small and medium manufacturers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18814/d/2","parentIdentifier":"/us/usc/t42/s18814/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fd%2F2","sourceRelease":"119-100","text":"to provide assistance to small and medium manufacturers to implement smart manufacturing technologies and practices.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Evaluation","label":"e Evaluation","identifier":"/us/usc/t42/s18814/e","parentIdentifier":"/us/usc/t42/s18814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18814/e/1","parentIdentifier":"/us/usc/t42/s18814/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fe%2F1","sourceRelease":"119-100","text":"to determine the impact and effectiveness of programs funded with the financial assistance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18814/e/2","parentIdentifier":"/us/usc/t42/s18814/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Fe%2F2","sourceRelease":"119-100","text":"to provide guidance to States on ways to better execute the program of the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorization of appropriations","label":"f Authorization of appropriations","identifier":"/us/usc/t42/s18814/f","parentIdentifier":"/us/usc/t42/s18814","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18814%2Ff","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary to carry out this section $50,000,000 for the period of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
