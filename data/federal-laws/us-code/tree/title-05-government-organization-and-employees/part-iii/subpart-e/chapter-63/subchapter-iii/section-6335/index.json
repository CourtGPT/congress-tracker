{"type":"section","nativeType":"section","number":"6335","heading":"Termination of medical emergency","label":"6335 Termination of medical emergency","identifier":"/us/usc/t5/s6335","parentIdentifier":"/us/usc/t5/ptIII/sptE/ch63/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6335","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s6335/a","parentIdentifier":"/us/usc/t5/s6335","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6335%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6335/a/1","parentIdentifier":"/us/usc/t5/s6335/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6335%2Fa%2F1","sourceRelease":"119-100","text":"the leave recipient notifies the employing agency of such leave recipient, in writing, that the medical emergency no longer exists;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6335/a/2","parentIdentifier":"/us/usc/t5/s6335/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6335%2Fa%2F2","sourceRelease":"119-100","text":"the employing agency of such leave recipient determines, after written notice and opportunity for the leave recipient (or, if appropriate, another person acting on behalf of the leave recipient) to answer orally or in writing, that the medical emergency no longer exists; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s6335/a/3","parentIdentifier":"/us/usc/t5/s6335/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6335%2Fa%2F3","sourceRelease":"119-100","text":"the leave recipient is separated from service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s6335/b","parentIdentifier":"/us/usc/t5/s6335","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6335%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6335/b/1","parentIdentifier":"/us/usc/t5/s6335/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6335%2Fb%2F1","sourceRelease":"119-100","text":"The employing agency of a leave recipient shall, consistent with guidelines prescribed by the Office of Personnel Management, establish procedures to ensure that a leave recipient is not permitted to use or receive any transferred leave under this subchapter after the medical emergency terminates.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6335/b/2","parentIdentifier":"/us/usc/t5/s6335/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6335%2Fb%2F2","sourceRelease":"119-100","text":"Nothing in section 5551, 5552, or 6306 shall apply with respect to any annual leave transferred to a leave recipient under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
