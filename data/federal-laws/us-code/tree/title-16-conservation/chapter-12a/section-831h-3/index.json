{"type":"section","nativeType":"section","number":"831h–3","heading":"Recreational access","label":"831h–3 Recreational access","identifier":"/us/usc/t16/s831h–3","parentIdentifier":"/us/usc/t16/ch12A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definition of floating cabin","label":"a Definition of floating cabin","identifier":"/us/usc/t16/s831h–3/a","parentIdentifier":"/us/usc/t16/s831h–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s831h–3/a/1","parentIdentifier":"/us/usc/t16/s831h–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fa%2F1","sourceRelease":"119-100","text":"primarily designed and used for human habitation or occupation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s831h–3/a/2","parentIdentifier":"/us/usc/t16/s831h–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fa%2F2","sourceRelease":"119-100","text":"not primarily designed or used for navigation or transportation on water.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Recreational access","label":"b Recreational access","identifier":"/us/usc/t16/s831h–3/b","parentIdentifier":"/us/usc/t16/s831h–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s831h–3/b/1","parentIdentifier":"/us/usc/t16/s831h–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fb%2F1","sourceRelease":"119-100","text":"the floating cabin is maintained by the owner to reasonable health, safety, and environmental standards, as required by the Board;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s831h–3/b/2","parentIdentifier":"/us/usc/t16/s831h–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fb%2F2","sourceRelease":"119-100","text":"the Corporation has authorized the use of recreational vessels on the waters; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s831h–3/b/3","parentIdentifier":"/us/usc/t16/s831h–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fb%2F3","sourceRelease":"119-100","text":"the floating cabin was located on waters under the jurisdiction of the Corporation as of .December 16, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Fees","label":"c Fees","identifier":"/us/usc/t16/s831h–3/c","parentIdentifier":"/us/usc/t16/s831h–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fc","sourceRelease":"119-100","text":"The Board may levy fees on the owner of a floating cabin on waters under the jurisdiction of the Corporation for the purpose of ensuring compliance with subsection (b) if the fees are necessary and reasonable for such purpose.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Continued recreational use","label":"d Continued recreational use","identifier":"/us/usc/t16/s831h–3/d","parentIdentifier":"/us/usc/t16/s831h–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s831h–3/d/1","parentIdentifier":"/us/usc/t16/s831h–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s831h–3/d/1/A","parentIdentifier":"/us/usc/t16/s831h–3/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fd%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s831h–3/d/1/A/i","parentIdentifier":"/us/usc/t16/s831h–3/d/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fd%2F1%2FA%2Fi","sourceRelease":"119-100","text":"in the case of a floating cabin that was granted a permit by the Corporation before , for a period of 15 years beginning on such date; andDecember 16, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s831h–3/d/1/A/ii","parentIdentifier":"/us/usc/t16/s831h–3/d/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fd%2F1%2FA%2Fii","sourceRelease":"119-100","text":"in the case of a floating cabin not granted a permit by the Corporation before , for a period of 5 years beginning on such date; andDecember 16, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s831h–3/d/1/B","parentIdentifier":"/us/usc/t16/s831h–3/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fd%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s831h–3/d/1/B/i","parentIdentifier":"/us/usc/t16/s831h–3/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fd%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the floating cabin meets the requirements of subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s831h–3/d/1/B/ii","parentIdentifier":"/us/usc/t16/s831h–3/d/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fd%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the owner of the floating cabin has paid any fee assessed pursuant to subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Savings provisions","label":"2 Savings provisions","identifier":"/us/usc/t16/s831h–3/d/2","parentIdentifier":"/us/usc/t16/s831h–3/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s831h–3/d/2/A","parentIdentifier":"/us/usc/t16/s831h–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fd%2F2%2FA","sourceRelease":"119-100","text":"Nothing in this subsection restricts the ability of the Corporation to enforce reasonable health, safety, or environmental standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s831h–3/d/2/B","parentIdentifier":"/us/usc/t16/s831h–3/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fd%2F2%2FB","sourceRelease":"119-100","text":"This section applies only to floating cabins located on waters under the jurisdiction of the Corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"New construction","label":"e New construction","identifier":"/us/usc/t16/s831h–3/e","parentIdentifier":"/us/usc/t16/s831h–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs831h%E2%80%933%2Fe","sourceRelease":"119-100","text":"The Corporation may establish regulations to prevent the construction of new floating cabins.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
