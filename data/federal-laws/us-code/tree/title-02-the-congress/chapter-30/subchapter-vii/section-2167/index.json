{"type":"section","nativeType":"section","number":"2167","heading":"Congressional Award Youth Park","label":"2167 Congressional Award Youth Park","identifier":"/us/usc/t2/s2167","parentIdentifier":"/us/usc/t2/ch30/schVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThis Act, referred to in subsec. (d), is , , , known as the Legislative Branch Appropriations Act, 2002. For complete classification of this Act to the Code, see Tables.Pub. L. 107–68115 Stat. 560Nov. 12, 2001","CodificationSection was classified to section 217c of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by , , .Pub. L. 107–217, § 1116 Stat. 1062Aug. 21, 2002"],"amendments":["References in TextThis Act, referred to in subsec. (d), is , , , known as the Legislative Branch Appropriations Act, 2002. For complete classification of this Act to the Code, see Tables.Pub. L. 107–68115 Stat. 560Nov. 12, 2001","CodificationSection was classified to section 217c of former Title 40, prior to the enactment of Title 40, Public Buildings, Property, and Works, by , , .Pub. L. 107–217, § 1116 Stat. 1062Aug. 21, 2002"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Designation","label":"a Designation","identifier":"/us/usc/t2/s2167/a","parentIdentifier":"/us/usc/t2/s2167","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fa","sourceRelease":"119-100","text":"The parcel of approximately 5 acres of land located on the Capitol Grounds and described in subsection (b) shall be known and designated as the “Congressional Award Youth Park”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Area included","label":"b Area included","identifier":"/us/usc/t2/s2167/b","parentIdentifier":"/us/usc/t2/s2167","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t2/s2167/b/1","parentIdentifier":"/us/usc/t2/s2167/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t2/s2167/b/1/A","parentIdentifier":"/us/usc/t2/s2167/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fb%2F1%2FA","sourceRelease":"119-100","text":"bounded on the north by Constitution Avenue, N.W.;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t2/s2167/b/1/B","parentIdentifier":"/us/usc/t2/s2167/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fb%2F1%2FB","sourceRelease":"119-100","text":"bounded on the east by First Street, N.W.;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t2/s2167/b/1/C","parentIdentifier":"/us/usc/t2/s2167/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fb%2F1%2FC","sourceRelease":"119-100","text":"bounded on the south by Pennsylvania Avenue, N.W.; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t2/s2167/b/1/D","parentIdentifier":"/us/usc/t2/s2167/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fb%2F1%2FD","sourceRelease":"119-100","text":"bounded on the west by Third Street N.W.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Extension","label":"2 Extension","identifier":"/us/usc/t2/s2167/b/2","parentIdentifier":"/us/usc/t2/s2167/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fb%2F2","sourceRelease":"119-100","text":"The park shall extend to the curbs of the streets described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Design","label":"c Design","identifier":"/us/usc/t2/s2167/c","parentIdentifier":"/us/usc/t2/s2167","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Competition","label":"1 Competition","identifier":"/us/usc/t2/s2167/c/1","parentIdentifier":"/us/usc/t2/s2167/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc%2F1","sourceRelease":"119-100","text":"The Architect of the Capitol shall sponsor a competition for the design of the park, based on specifications developed by the Architect.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Specifications","label":"2 Specifications","identifier":"/us/usc/t2/s2167/c/2","parentIdentifier":"/us/usc/t2/s2167/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t2/s2167/c/2/A","parentIdentifier":"/us/usc/t2/s2167/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc%2F2%2FA","sourceRelease":"119-100","text":"Not later than , the Architect, in consultation with the majority leader and the minority leader of the Senate, and the Speaker and the minority leader of the House of Representatives, shall develop the specifications for the park.June 30, 2002","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Requirements","label":"B Requirements","identifier":"/us/usc/t2/s2167/c/2/B","parentIdentifier":"/us/usc/t2/s2167/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t2/s2167/c/2/B/i","parentIdentifier":"/us/usc/t2/s2167/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"The specifications shall require an outdoor design that is accessible to the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Inclusions","label":"ii Inclusions","identifier":"/us/usc/t2/s2167/c/2/B/ii","parentIdentifier":"/us/usc/t2/s2167/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t2/s2167/c/2/B/ii/I","parentIdentifier":"/us/usc/t2/s2167/c/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc%2F2%2FB%2Fii%2FI","sourceRelease":"119-100","text":"a fountain;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t2/s2167/c/2/B/ii/II","parentIdentifier":"/us/usc/t2/s2167/c/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc%2F2%2FB%2Fii%2FII","sourceRelease":"119-100","text":"extensive use of trees and flowering plants from each of the 50 States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t2/s2167/c/2/B/ii/III","parentIdentifier":"/us/usc/t2/s2167/c/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc%2F2%2FB%2Fii%2FIII","sourceRelease":"119-100","text":"large-scale replicas of the medals awarded under the Congressional Award Program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t2/s2167/c/2/B/ii/IV","parentIdentifier":"/us/usc/t2/s2167/c/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc%2F2%2FB%2Fii%2FIV","sourceRelease":"119-100","text":"the inscription of the names of all Congressional Award recipients.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Selection","label":"3 Selection","identifier":"/us/usc/t2/s2167/c/3","parentIdentifier":"/us/usc/t2/s2167/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t2/s2167/c/3/A","parentIdentifier":"/us/usc/t2/s2167/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc%2F3%2FA","sourceRelease":"119-100","text":"As soon as practicable after the competition is completed, the Architect shall forward at least 3 designs, with recommendations, to the United States Capitol Preservation Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Final selection","label":"B Final selection","identifier":"/us/usc/t2/s2167/c/3/B","parentIdentifier":"/us/usc/t2/s2167/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fc%2F3%2FB","sourceRelease":"119-100","text":"The United States Capitol Preservation Commission shall select and approve the final design from among the 3 designs submitted under subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Funding","label":"d Funding","identifier":"/us/usc/t2/s2167/d","parentIdentifier":"/us/usc/t2/s2167","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs2167%2Fd","sourceRelease":"119-100","text":"Funds otherwise made available to the Architect of the Capitol under this Act shall be available to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
