%2Fd%2F5","sourceRelease":"119-100","text":"cost-sharing arrangements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t10/s1743/d/6","parentIdentifier":"/us/usc/t10/s1743/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1743%2Fd%2F6","sourceRelease":"119-100","text":"innovative contractor incentive practices; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t10/s1743/d/7","parentIdentifier":"/us/usc/t10/s1743/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1743%2Fd%2F7","sourceRelease":"119-100","text":"other innovative implementations of acquisition flexibilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Funding","label":"e .—Funding","identifier":"/us/usc/t10/s1743/e","parentIdentifier":"/us/usc/t10/s1743","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1743%2Fe","sourceRelease":"119-100","text":"The Secretary of Defense shall use funds from the Defense Acquisition Workforce Development Account to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
