2Fa%2F2%2FB%2Fi%2FII","sourceRelease":"119-100","text":"other capabilities that the Administrator determines necessary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s6135/a/2/B/ii","parentIdentifier":"/us/usc/t10/s6135/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6135%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"informs the entire development life cycle of the W93 nuclear weapon.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"3.—Certifications and Reports at Phase","label":"b 3.—Certifications and Reports at Phase","identifier":"/us/usc/t10/s6135/b","parentIdentifier":"/us/usc/t10/s6135","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6135%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6135/b/1","parentIdentifier":"/us/usc/t10/s6135/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6135%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s6135/b/1/A","parentIdentifier":"/us/usc/t10/s6135/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6135%2Fb%2F1%2FA","sourceRelease":"119-100","text":"phases 1 through 5 of the joint nuclear weapons life cycle for the weapon will employ, at a minimum, the same best practices and will provide Congress with the same level of programmatic insight as exists under the phase 6.X process for life extension programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s6135/b/1/B","parentIdentifier":"/us/usc/t10/s6135/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6135%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the proposed design for the weapon can be carried out within estimated schedule and cost objectives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6135/b/2","parentIdentifier":"/us/usc/t10/s6135/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6135%2Fb%2F2","sourceRelease":"119-100","text":"the Commander of the United States Strategic Command shall submit to the congressional defense committees a report containing, or provide to such committees a briefing on, the requirements for weapon quantity and composition by type for the sub-surface ballistic nuclear (SSBN) force, including such requirements planned for the 15-year period following the date of the report or briefing, as the case may be, including any planned life extensions, retirements, or alterations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Waivers","label":"c .—Waivers","identifier":"/us/usc/t10/s6135/c","parentIdentifier":"/us/usc/t10/s6135","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6135%2Fc","sourceRelease":"119-100","text":"Subsections (a) and (b) may be waived during a period of war declared by Congress after .January 1, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Joint Nuclear Weapons Life Cycle Defined","label":"d .—Joint Nuclear Weapons Life Cycle Defined","identifier":"/us/usc/t10/s6135/d","parentIdentifier":"/us/usc/t10/s6135","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6135%2Fd","sourceRelease":"119-100","text":"In this section, the term “joint nuclear weapons life cycle” has the meaning given that term in section 6131.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
