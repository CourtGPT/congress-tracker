{"type":"section","nativeType":"section","number":"3385","heading":"Reports and audits","label":"3385 Reports and audits","identifier":"/us/usc/t22/s3385","parentIdentifier":"/us/usc/t22/ch48A/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Annual report","label":"a Annual report","identifier":"/us/usc/t22/s3385/a","parentIdentifier":"/us/usc/t22/s3385","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s3385/a/1","parentIdentifier":"/us/usc/t22/s3385/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fa%2F1","sourceRelease":"119-100","text":"An assessment of the performance of the implementing partner in fulfilling the purposes of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s3385/a/2","parentIdentifier":"/us/usc/t22/s3385/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fa%2F2","sourceRelease":"119-100","text":"The names and sponsoring agencies of the fellows selected by the implementing partner and the extent to which such fellows represent the diversity of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s3385/a/3","parentIdentifier":"/us/usc/t22/s3385/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fa%2F3","sourceRelease":"119-100","text":"The names of the parliamentary offices, ministries, other agencies of Taiwan, and nongovernmental institutions to which each fellow was assigned during the second year of the fellowship.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s3385/a/4","parentIdentifier":"/us/usc/t22/s3385/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fa%2F4","sourceRelease":"119-100","text":"Any recommendations, as appropriate, to improve the implementation of the Taiwan Fellowship Program, including added flexibilities in the administration of the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s3385/a/5","parentIdentifier":"/us/usc/t22/s3385/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fa%2F5","sourceRelease":"119-100","text":"An assessment of the Taiwan Fellowship Program’s value upon the relationship between the United States and Taiwan or the United States and Asian countries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Annual financial audit","label":"b Annual financial audit","identifier":"/us/usc/t22/s3385/b","parentIdentifier":"/us/usc/t22/s3385","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s3385/b/1","parentIdentifier":"/us/usc/t22/s3385/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F1","sourceRelease":"119-100","text":"The financial records of any implementing partner shall be audited annually in accordance with generally accepted government auditing standards by independent certified public accountants or independent licensed public accountants who are certified or licensed by a regulatory authority of a State or another political subdivision of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Location","label":"2 Location","identifier":"/us/usc/t22/s3385/b/2","parentIdentifier":"/us/usc/t22/s3385/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F2","sourceRelease":"119-100","text":"Each audit under paragraph (1) shall be conducted at the place or places where the financial records of the implementing partner are normally kept.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Access to documents","label":"3 Access to documents","identifier":"/us/usc/t22/s3385/b/3","parentIdentifier":"/us/usc/t22/s3385/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s3385/b/3/A","parentIdentifier":"/us/usc/t22/s3385/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F3%2FA","sourceRelease":"119-100","text":"all books, financial records, files, other papers, things, and property belonging to, or in use by, the implementing partner that are necessary to facilitate the audit; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s3385/b/3/B","parentIdentifier":"/us/usc/t22/s3385/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F3%2FB","sourceRelease":"119-100","text":"full facilities for verifying transactions with the balances or securities held by depositories, fiscal agents, and custodians.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Report","label":"4 Report","identifier":"/us/usc/t22/s3385/b/4","parentIdentifier":"/us/usc/t22/s3385/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t22/s3385/b/4/A","parentIdentifier":"/us/usc/t22/s3385/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F4%2FA","sourceRelease":"119-100","text":"Not later than 270 days after the end of each fiscal year, the implementing partner shall provide a report of the audit conducted for such fiscal year under paragraph (1) to the Department of State and the American Institute in Taiwan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Contents","label":"B Contents","identifier":"/us/usc/t22/s3385/b/4/B","parentIdentifier":"/us/usc/t22/s3385/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s3385/b/4/B/i","parentIdentifier":"/us/usc/t22/s3385/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F4%2FB%2Fi","sourceRelease":"119-100","text":"set forth the scope of the audit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s3385/b/4/B/ii","parentIdentifier":"/us/usc/t22/s3385/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F4%2FB%2Fii","sourceRelease":"119-100","text":"include such statements, along with the auditor’s opinion of those statements, as may be necessary to present fairly the implementing partner’s assets and liabilities, surplus or deficit, with reasonable detail;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t22/s3385/b/4/B/iii","parentIdentifier":"/us/usc/t22/s3385/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F4%2FB%2Fiii","sourceRelease":"119-100","text":"include a statement of the implementing partner’s income and expenses during the year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t22/s3385/b/4/B/iv","parentIdentifier":"/us/usc/t22/s3385/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F4%2FB%2Fiv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t22/s3385/b/4/B/iv/I","parentIdentifier":"/us/usc/t22/s3385/b/4/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F4%2FB%2Fiv%2FI","sourceRelease":"119-100","text":"all contracts and cooperative agreements requiring payments greater than $5,000; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t22/s3385/b/4/B/iv/II","parentIdentifier":"/us/usc/t22/s3385/b/4/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F4%2FB%2Fiv%2FII","sourceRelease":"119-100","text":"any payments of compensation, salaries, or fees at a rate greater than $5,000 per year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Copies","label":"C Copies","identifier":"/us/usc/t22/s3385/b/4/C","parentIdentifier":"/us/usc/t22/s3385/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs3385%2Fb%2F4%2FC","sourceRelease":"119-100","text":"Each audit report shall be produced in sufficient copies for distribution to the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
