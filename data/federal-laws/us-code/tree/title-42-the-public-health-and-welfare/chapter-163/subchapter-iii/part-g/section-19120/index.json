{"type":"section","nativeType":"section","number":"19120","heading":"Evaluation","label":"19120 Evaluation","identifier":"/us/usc/t42/s19120","parentIdentifier":"/us/usc/t42/ch163/schIII/ptG","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19120","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s19120/a","parentIdentifier":"/us/usc/t42/s19120","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19120%2Fa","sourceRelease":"119-100","text":"After the Directorate has been in operation for 6 years, the Director shall enter into an agreement with the National Academies to provide an evaluation of how well the Directorate is achieving the purposes identified in .section 19102 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Inclusions","label":"b Inclusions","identifier":"/us/usc/t42/s19120/b","parentIdentifier":"/us/usc/t42/s19120","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19120%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19120/b/1","parentIdentifier":"/us/usc/t42/s19120/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19120%2Fb%2F1","sourceRelease":"119-100","text":"an assessment of the impact of Directorate activities on the Foundation’s primary science mission;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19120/b/2","parentIdentifier":"/us/usc/t42/s19120/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19120%2Fb%2F2","sourceRelease":"119-100","text":"an assessment of the Directorate’s impact on the challenges and key technology focus areas under ;section 19107 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19120/b/3","parentIdentifier":"/us/usc/t42/s19120/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19120%2Fb%2F3","sourceRelease":"119-100","text":"an assessment of efforts to ensure coordination between the Directorate and other Federal agencies, and with external entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s19120/b/4","parentIdentifier":"/us/usc/t42/s19120/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19120%2Fb%2F4","sourceRelease":"119-100","text":"a description of lessons learned from operation of the Directorate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s19120/b/5","parentIdentifier":"/us/usc/t42/s19120/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19120%2Fb%2F5","sourceRelease":"119-100","text":"recommended funding levels for the Directorate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Availability","label":"c Availability","identifier":"/us/usc/t42/s19120/c","parentIdentifier":"/us/usc/t42/s19120","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19120%2Fc","sourceRelease":"119-100","text":"On completion of the evaluation, the evaluation shall be made available to Congress and the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
