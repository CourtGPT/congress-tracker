{"type":"section","nativeType":"section","number":"300g–10","heading":"Cybersecurity support for public water systems","label":"300g–10 Cybersecurity support for public water systems","identifier":"/us/usc/t42/s300g–10","parentIdentifier":"/us/usc/t42/ch6A/schXII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s300g–10/a","parentIdentifier":"/us/usc/t42/s300g–10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Appropriate Congressional committees","label":"1 Appropriate Congressional committees","identifier":"/us/usc/t42/s300g–10/a/1","parentIdentifier":"/us/usc/t42/s300g–10/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300g–10/a/1/A","parentIdentifier":"/us/usc/t42/s300g–10/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the Committee on Environment and Public Works of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300g–10/a/1/B","parentIdentifier":"/us/usc/t42/s300g–10/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the Committee on Homeland Security and Governmental Affairs of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300g–10/a/1/C","parentIdentifier":"/us/usc/t42/s300g–10/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fa%2F1%2FC","sourceRelease":"119-100","text":"the Committee on Energy and Commerce of the House of Representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s300g–10/a/1/D","parentIdentifier":"/us/usc/t42/s300g–10/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fa%2F1%2FD","sourceRelease":"119-100","text":"the Committee on Homeland Security of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Director","label":"2 Director","identifier":"/us/usc/t42/s300g–10/a/2","parentIdentifier":"/us/usc/t42/s300g–10/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fa%2F2","sourceRelease":"119-100","text":"The term “Director” means the Director of the Cybersecurity and Infrastructure Security Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Incident","label":"3 Incident","identifier":"/us/usc/t42/s300g–10/a/3","parentIdentifier":"/us/usc/t42/s300g–10/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fa%2F3","sourceRelease":"119-100","text":"The term “incident” has the meaning given the term in .section 3552 of title 44","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Prioritization Framework","label":"4 Prioritization Framework","identifier":"/us/usc/t42/s300g–10/a/4","parentIdentifier":"/us/usc/t42/s300g–10/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fa%2F4","sourceRelease":"119-100","text":"The term “Prioritization Framework” means the prioritization framework developed by the Administrator under subsection (b)(1)(A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Support Plan","label":"5 Support Plan","identifier":"/us/usc/t42/s300g–10/a/5","parentIdentifier":"/us/usc/t42/s300g–10/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fa%2F5","sourceRelease":"119-100","text":"The term “Support Plan” means the Technical Cybersecurity Support Plan developed by the Administrator under subsection (b)(2)(A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Identification of and support for public water systems","label":"b Identification of and support for public water systems","identifier":"/us/usc/t42/s300g–10/b","parentIdentifier":"/us/usc/t42/s300g–10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Prioritization Framework","label":"1 Prioritization Framework","identifier":"/us/usc/t42/s300g–10/b/1","parentIdentifier":"/us/usc/t42/s300g–10/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s300g–10/b/1/A","parentIdentifier":"/us/usc/t42/s300g–10/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F1%2FA","sourceRelease":"119-100","text":"Not later than 180 days after , the Administrator, in coordination with the Director, shall develop a prioritization framework to identify public water systems (including sources of water for those public water systems) that, if degraded or rendered inoperable due to an incident, would lead to significant impacts on the health and safety of the public.November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Considerations","label":"B Considerations","identifier":"/us/usc/t42/s300g–10/b/1/B","parentIdentifier":"/us/usc/t42/s300g–10/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300g–10/b/1/B/i","parentIdentifier":"/us/usc/t42/s300g–10/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"whether cybersecurity vulnerabilities for a public water system have been identified under ;section 300i–2 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300g–10/b/1/B/ii","parentIdentifier":"/us/usc/t42/s300g–10/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the capacity of a public water system to remediate a cybersecurity vulnerability without additional Federal support;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s300g–10/b/1/B/iii","parentIdentifier":"/us/usc/t42/s300g–10/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"whether a public water system serves a defense installation or critical national security asset; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s300g–10/b/1/B/iv","parentIdentifier":"/us/usc/t42/s300g–10/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"whether a public water system, if degraded or rendered inoperable due to an incident, would cause a cascading failure of other critical infrastructure.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Technical Cybersecurity Support Plan","label":"2 Technical Cybersecurity Support Plan","identifier":"/us/usc/t42/s300g–10/b/2","parentIdentifier":"/us/usc/t42/s300g–10/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s300g–10/b/2/A","parentIdentifier":"/us/usc/t42/s300g–10/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F2%2FA","sourceRelease":"119-100","text":"Not later than 270 days after , the Administrator, in coordination with the Director and using existing authorities of the Administrator and the Director for providing voluntary support to public water systems and the Prioritization Framework, shall develop a Technical Cybersecurity Support Plan for public water systems.November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Requirements","label":"B Requirements","identifier":"/us/usc/t42/s300g–10/b/2/B","parentIdentifier":"/us/usc/t42/s300g–10/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300g–10/b/2/B/i","parentIdentifier":"/us/usc/t42/s300g–10/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"shall establish a methodology for identifying specific public water systems for which cybersecurity support should be prioritized;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300g–10/b/2/B/ii","parentIdentifier":"/us/usc/t42/s300g–10/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"shall establish timelines for making voluntary technical support for cybersecurity available to specific public water systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s300g–10/b/2/B/iii","parentIdentifier":"/us/usc/t42/s300g–10/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"may include public water systems identified by the Administrator, in coordination with the Director, as needing technical support for cybersecurity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s300g–10/b/2/B/iv","parentIdentifier":"/us/usc/t42/s300g–10/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F2%2FB%2Fiv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s300g–10/b/2/B/iv/I","parentIdentifier":"/us/usc/t42/s300g–10/b/2/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F2%2FB%2Fiv%2FI","sourceRelease":"119-100","text":"site vulnerability and risk assessments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s300g–10/b/2/B/iv/II","parentIdentifier":"/us/usc/t42/s300g–10/b/2/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F2%2FB%2Fiv%2FII","sourceRelease":"119-100","text":"penetration tests; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t42/s300g–10/b/2/B/iv/III","parentIdentifier":"/us/usc/t42/s300g–10/b/2/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F2%2FB%2Fiv%2FIII","sourceRelease":"119-100","text":"any additional support determined to be appropriate by the Administrator; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s300g–10/b/2/B/v","parentIdentifier":"/us/usc/t42/s300g–10/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F2%2FB%2Fv","sourceRelease":"119-100","text":"shall only include plans for providing voluntary support to public water systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Consultation required","label":"3 Consultation required","identifier":"/us/usc/t42/s300g–10/b/3","parentIdentifier":"/us/usc/t42/s300g–10/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F3","sourceRelease":"119-100","text":"In developing the Prioritization Framework pursuant to paragraph (1) and the Support Plan pursuant to paragraph (2), the Administrator shall consult with such Federal or non-Federal entities as determined to be appropriate by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Reports required","label":"4 Reports required","identifier":"/us/usc/t42/s300g–10/b/4","parentIdentifier":"/us/usc/t42/s300g–10/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Prioritization Framework","label":"A Prioritization Framework","identifier":"/us/usc/t42/s300g–10/b/4/A","parentIdentifier":"/us/usc/t42/s300g–10/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F4%2FA","sourceRelease":"119-100","text":"Not later than 190 days after , the Administrator shall submit to the appropriate Congressional committees a report describing the Prioritization Framework.November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Technical Cybersecurity Support Plan","label":"B Technical Cybersecurity Support Plan","identifier":"/us/usc/t42/s300g–10/b/4/B","parentIdentifier":"/us/usc/t42/s300g–10/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300g–10/b/4/B/i","parentIdentifier":"/us/usc/t42/s300g–10/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F4%2FB%2Fi","sourceRelease":"119-100","text":"the Support Plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300g–10/b/4/B/ii","parentIdentifier":"/us/usc/t42/s300g–10/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fb%2F4%2FB%2Fii","sourceRelease":"119-100","text":"a list describing any public water systems identified by the Administrator, in coordination with the Director, as needing technical support for cybersecurity during the development of the Support Plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Rules of construction","label":"c Rules of construction","identifier":"/us/usc/t42/s300g–10/c","parentIdentifier":"/us/usc/t42/s300g–10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300g–10/c/1","parentIdentifier":"/us/usc/t42/s300g–10/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fc%2F1","sourceRelease":"119-100","text":"alters the existing authorities of the Administrator; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300g–10/c/2","parentIdentifier":"/us/usc/t42/s300g–10/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300g%E2%80%9310%2Fc%2F2","sourceRelease":"119-100","text":"compels a public water system to accept technical support offered by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
