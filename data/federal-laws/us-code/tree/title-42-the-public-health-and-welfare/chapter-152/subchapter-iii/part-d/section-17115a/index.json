{"type":"section","nativeType":"section","number":"17115a","heading":"Development of national smart manufacturing plan","label":"17115a Development of national smart manufacturing plan","identifier":"/us/usc/t42/s17115a","parentIdentifier":"/us/usc/t42/ch152/schIII/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Energy Act of 2020, and not as part of the Energy Independence and Security Act of 2007 which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s17115a/a","parentIdentifier":"/us/usc/t42/s17115a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fa","sourceRelease":"119-100","text":"Not later than 3 years after , the Secretary of Energy (in this section referred to as the “Secretary”), in consultation with the National Academies, shall develop and complete a national plan for smart manufacturing technology development and deployment to improve the productivity and energy efficiency of the manufacturing sector of the United States.December 27, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Content","label":"b Content","identifier":"/us/usc/t42/s17115a/b","parentIdentifier":"/us/usc/t42/s17115a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17115a/b/1","parentIdentifier":"/us/usc/t42/s17115a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17115a/b/1/A","parentIdentifier":"/us/usc/t42/s17115a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"facilitate quicker development, deployment, and adoption of smart manufacturing technologies and processes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17115a/b/1/B","parentIdentifier":"/us/usc/t42/s17115a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fb%2F1%2FB","sourceRelease":"119-100","text":"result in greater energy efficiency and lower environmental impacts for all American manufacturers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17115a/b/1/C","parentIdentifier":"/us/usc/t42/s17115a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fb%2F1%2FC","sourceRelease":"119-100","text":"enhance competitiveness and strengthen the manufacturing sectors of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Inclusions","label":"2 Inclusions","identifier":"/us/usc/t42/s17115a/b/2","parentIdentifier":"/us/usc/t42/s17115a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17115a/b/2/A","parentIdentifier":"/us/usc/t42/s17115a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fb%2F2%2FA","sourceRelease":"119-100","text":"an assessment of previous and current actions of the Department relating to smart manufacturing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17115a/b/2/B","parentIdentifier":"/us/usc/t42/s17115a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the establishment of voluntary interconnection protocols and performance standards;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17115a/b/2/C","parentIdentifier":"/us/usc/t42/s17115a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fb%2F2%2FC","sourceRelease":"119-100","text":"the use of smart manufacturing to improve energy efficiency and reduce emissions in supply chains across multiple companies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17115a/b/2/D","parentIdentifier":"/us/usc/t42/s17115a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fb%2F2%2FD","sourceRelease":"119-100","text":"actions to increase cybersecurity in smart manufacturing infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17115a/b/2/E","parentIdentifier":"/us/usc/t42/s17115a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fb%2F2%2FE","sourceRelease":"119-100","text":"deployment of existing research results;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17115a/b/2/F","parentIdentifier":"/us/usc/t42/s17115a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fb%2F2%2FF","sourceRelease":"119-100","text":"the leveraging of existing high-performance computing infrastructure; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s17115a/b/2/G","parentIdentifier":"/us/usc/t42/s17115a/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fb%2F2%2FG","sourceRelease":"119-100","text":"consideration of the impact of smart manufacturing on existing manufacturing jobs and future manufacturing jobs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Biennial revisions","label":"c Biennial revisions","identifier":"/us/usc/t42/s17115a/c","parentIdentifier":"/us/usc/t42/s17115a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fc","sourceRelease":"119-100","text":"Not later than 2 years after the date on which the Secretary completes the plan under subsection (a), and not less frequently than once every 2 years thereafter, the Secretary shall revise the plan to account for advancements in information and communication technology and manufacturing needs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Report","label":"d Report","identifier":"/us/usc/t42/s17115a/d","parentIdentifier":"/us/usc/t42/s17115a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fd","sourceRelease":"119-100","text":"Annually until the completion of the plan under subsection (a), the Secretary shall submit to Congress a report on the progress made in developing the plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Definition","label":"e Definition","identifier":"/us/usc/t42/s17115a/e","parentIdentifier":"/us/usc/t42/s17115a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17115a/e/1","parentIdentifier":"/us/usc/t42/s17115a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17115a/e/1/A","parentIdentifier":"/us/usc/t42/s17115a/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fe%2F1%2FA","sourceRelease":"119-100","text":"simulate manufacturing production lines;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17115a/e/1/B","parentIdentifier":"/us/usc/t42/s17115a/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fe%2F1%2FB","sourceRelease":"119-100","text":"operate computer-controlled manufacturing equipment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17115a/e/1/C","parentIdentifier":"/us/usc/t42/s17115a/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fe%2F1%2FC","sourceRelease":"119-100","text":"monitor and communicate production line status; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17115a/e/1/D","parentIdentifier":"/us/usc/t42/s17115a/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fe%2F1%2FD","sourceRelease":"119-100","text":"manage and optimize energy productivity and cost throughout production;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17115a/e/2","parentIdentifier":"/us/usc/t42/s17115a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fe%2F2","sourceRelease":"119-100","text":"model, simulate, and optimize the energy efficiency of a factory building;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17115a/e/3","parentIdentifier":"/us/usc/t42/s17115a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fe%2F3","sourceRelease":"119-100","text":"monitor and optimize building energy performance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17115a/e/4","parentIdentifier":"/us/usc/t42/s17115a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fe%2F4","sourceRelease":"119-100","text":"model, simulate, and optimize the design of energy efficient and sustainable products, including the use of digital prototyping and additive manufacturing to enhance product design;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s17115a/e/5","parentIdentifier":"/us/usc/t42/s17115a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fe%2F5","sourceRelease":"119-100","text":"connect manufactured products in networks to monitor and optimize the performance of the networks, including automated network operations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s17115a/e/6","parentIdentifier":"/us/usc/t42/s17115a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17115a%2Fe%2F6","sourceRelease":"119-100","text":"digitally connect the supply chain network.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
