{"type":"section","nativeType":"section","number":"8954","heading":"Benefits","label":"8954 Benefits","identifier":"/us/usc/t5/s8954","parentIdentifier":"/us/usc/t5/ptIII/sptG/ch89A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8954","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , and applicable to contracts that take effect with respect to the calendar year 2006, see , set out as a note under .Dec. 23, 2004section 7 of Pub. L. 108–496section 8951 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s8954/a","parentIdentifier":"/us/usc/t5/s8954","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8954%2Fa","sourceRelease":"119-100","text":"The Office may prescribe reasonable minimum standards for enhanced dental benefits plans offered under this chapter and for qualified companies offering the plans.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s8954/b","parentIdentifier":"/us/usc/t5/s8954","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8954%2Fb","sourceRelease":"119-100","text":"Each contract may include more than 1 level of benefits that shall be made available to all eligible individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t5/s8954/c","parentIdentifier":"/us/usc/t5/s8954","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8954%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label"