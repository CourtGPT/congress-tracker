{"type":"section","nativeType":"section","number":"225","heading":"Continuing financial crimes enterprise","label":"225 Continuing financial crimes enterprise","identifier":"/us/usc/t18/s225","parentIdentifier":"/us/usc/t18/ptI/ch11","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs225","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t18/s225/a","parentIdentifier":"/us/usc/t18/s225","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs225%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s225/a/1","parentIdentifier":"/us/usc/t18/s225/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs225%2Fa%2F1","sourceRelease":"119-100","text":"organizes, manages, or supervises a continuing financial crimes enterprise; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s225/a/2","parentIdentifier":"/us/usc/t18/s225/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs225%2Fa%2F2","sourceRelease":"119-100","text":"receives $5,000,000 or more in gross receipts from such enterprise during any 24-month period,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t18/s225/b","parentIdentifier":"/us/usc/t18/s225","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs225%2Fb","sourceRelease":"119-100","text":"For purposes of subsection (a), the term “continuing financial crimes enterprise” means a series of violations under section 215, 656, 657, 1005, 1006, 1007, 1014, 1032, or 1344 of this title, or section 1341 or 1343 affecting a financial institution, committed by at least 4 persons acting in concert.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
