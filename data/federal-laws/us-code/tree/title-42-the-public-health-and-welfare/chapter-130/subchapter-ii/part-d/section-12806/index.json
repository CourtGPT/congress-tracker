{"type":"section","nativeType":"section","number":"12806","heading":"Home repair services grants for older and disabled homeowners","label":"12806 Home repair services grants for older and disabled homeowners","identifier":"/us/usc/t42/s12806","parentIdentifier":"/us/usc/t42/ch130/schII/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12806","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s12806/a","parentIdentifier":"/us/usc/t42/s12806","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12806%2Fa","sourceRelease":"119-100","text":"The Secretary shall make available a model program to provide home repair services for older homeowners and disabled homeowners, including such services as the examination of homes, repair services, and follow-up to ensure the continued effectiveness of the repairs provided.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Eligible recipients","label":"b Eligible recipients","identifier":"/us/usc/t42/s12806/b","parentIdentifier":"/us/usc/t42/s12806","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12806%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s12806/b/1","parentIdentifier":"/us/usc/t42/s12806/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12806%2Fb%2F1","sourceRelease":"119-100","text":"own and reside in the dwellings for which services are provided;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s12806/b/2","parentIdentifier":"/us/usc/t42/s12806/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12806%2Fb%2F2","sourceRelease":"119-100","text":"are older or disabled; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s12806/b/3","parentIdentifier":"/us/usc/t42/s12806/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12806%2Fb%2F3","sourceRelease":"119-100","text":"are members of low-income families.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Permitted restrictions","label":"c Permitted restrictions","identifier":"/us/usc/t42/s12806/c","parentIdentifier":"/us/usc/t42/s12806","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12806%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s12806/c/1","parentIdentifier":"/us/usc/t42/s12806/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12806%2Fc%2F1","sourceRelease":"119-100","text":"assisted dwelling units be the primary residence of the homeowner for whom services are provided;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s12806/c/2","parentIdentifier":"/us/usc/t42/s12806/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12806%2Fc%2F2","sourceRelease":"119-100","text":"preferences be provided for (A) very low-income families, and (B) individuals with intense need characterized by noneconomic factors such as physical and mental disabilities, language barriers, and cultural, social, or geographical isolation caused by racial or ethnic status that restricts the ability of an individual to perform normal daily tasks or that threatens the capacity of the individual to live independently;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s12806/c/3","parentIdentifier":"/us/usc/t42/s12806/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12806%2Fc%2F3","sourceRelease":"119-100","text":"any fees charged be based on the income of the individual receiving the home repair services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
