{"type":"section","nativeType":"section","number":"60143","heading":"Idled pipelines","label":"60143 Idled pipelines","identifier":"/us/usc/t49/s60143","parentIdentifier":"/us/usc/t49/stVIII/ch601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143","sourceRelease":"119-100","text":null,"notes":["References in TextThe date of enactment of the PIPES Act of 2020, referred to in subsec. (b)(1), is the date of enactment of div. R of , which was approved .Pub. L. 116–260Dec. 27, 2020"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Definition of Idled","label":"a .—Definition of Idled","identifier":"/us/usc/t49/s60143/a","parentIdentifier":"/us/usc/t49/s60143","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s60143/a/1","parentIdentifier":"/us/usc/t49/s60143/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s60143/a/1/A","parentIdentifier":"/us/usc/t49/s60143/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fa%2F1%2FA","sourceRelease":"119-100","text":"has ceased normal operations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s60143/a/1/B","parentIdentifier":"/us/usc/t49/s60143/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fa%2F1%2FB","sourceRelease":"119-100","text":"will not resume service for a period of not less than 180 days;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s60143/a/2","parentIdentifier":"/us/usc/t49/s60143/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fa%2F2","sourceRelease":"119-100","text":"has been isolated from all sources of hazardous liquid, natural gas, or other gas; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s60143/a/3","parentIdentifier":"/us/usc/t49/s60143/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s60143/a/3/A","parentIdentifier":"/us/usc/t49/s60143/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fa%2F3%2FA","sourceRelease":"119-100","text":"has been purged of combustibles and hazardous materials and maintains a blanket of inert, nonflammable gas at low pressure; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s60143/a/3/B","parentIdentifier":"/us/usc/t49/s60143/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fa%2F3%2FB","sourceRelease":"119-100","text":"has not been purged as described in subparagraph (A), but the volume of gas is so small that there is no potential hazard, as determined by the Secretary pursuant to a rule.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Rulemaking.—","label":"b Rulemaking.—","identifier":"/us/usc/t49/s60143/b","parentIdentifier":"/us/usc/t49/s60143","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s60143/b/1","parentIdentifier":"/us/usc/t49/s60143/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fb%2F1","sourceRelease":"119-100","text":"Not later than 2 years after the date of enactment of the PIPES Act of 2020, the Secretary shall promulgate regulations prescribing the applicability of the pipeline safety requirements to idled natural or other gas transmission and hazardous liquid pipelines.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements.—","label":"2 Requirements.—","identifier":"/us/usc/t49/s60143/b/2","parentIdentifier":"/us/usc/t49/s60143/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t49/s60143/b/2/A","parentIdentifier":"/us/usc/t49/s60143/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The applicability of the regulations under paragraph (1) shall be based on the risk that idled natural or other gas transmission and hazardous liquid pipelines pose to the public, property, and the environment, and shall include requirements to resume operation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Inspection","label":"B .—Inspection","identifier":"/us/usc/t49/s60143/b/2/B","parentIdentifier":"/us/usc/t49/s60143/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fb%2F2%2FB","sourceRelease":"119-100","text":"The Secretary or an appropriate State agency shall inspect each idled pipeline and verify that the pipeline has been purged of combustibles and hazardous materials, if required under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":".—Requirements for reinspection","label":"C .—Requirements for reinspection","identifier":"/us/usc/t49/s60143/b/2/C","parentIdentifier":"/us/usc/t49/s60143/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fb%2F2%2FC","sourceRelease":"119-100","text":"The Secretary shall determine the requirements for periodic reinspection of idled natural or other gas transmission and hazardous liquid pipelines.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":".—Resumption of operations","label":"D .—Resumption of operations","identifier":"/us/usc/t49/s60143/b/2/D","parentIdentifier":"/us/usc/t49/s60143/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fb%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t49/s60143/b/2/D/i","parentIdentifier":"/us/usc/t49/s60143/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fb%2F2%2FD%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t49/s60143/b/2/D/i/I","parentIdentifier":"/us/usc/t49/s60143/b/2/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fb%2F2%2FD%2Fi%2FI","sourceRelease":"119-100","text":"hydrostatic pressure testing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t49/s60143/b/2/D/i/II","parentIdentifier":"/us/usc/t49/s60143/b/2/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fb%2F2%2FD%2Fi%2FII","sourceRelease":"119-100","text":"an internal inspection device; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t49/s60143/b/2/D/i/III","parentIdentifier":"/us/usc/t49/s60143/b/2/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fb%2F2%2FD%2Fi%2FIII","sourceRelease":"119-100","text":"if the use of hydrostatic pressure testing or an internal inspection device is not technologically feasible, another comparable technology or practice; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t49/s60143/b/2/D/ii","parentIdentifier":"/us/usc/t49/s60143/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs60143%2Fb%2F2%2FD%2Fii","sourceRelease":"119-100","text":"in compliance with regulations promulgated under this chapter, including any regulations that became effective while the pipeline was idled.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}
