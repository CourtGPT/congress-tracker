{"type":"section","nativeType":"section","number":"4805","heading":"Call report simplification","label":"4805 Call report simplification","identifier":"/us/usc/t12/s4805","parentIdentifier":"/us/usc/t12/ch48","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4805","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationProvisions similar to this section are contained in .section 4805a of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Modernization of call report filing and disclosure system","label":"a Modernization of call report filing and disclosure system","identifier":"/us/usc/t12/s4805/a","parentIdentifier":"/us/usc/t12/s4805","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4805%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4805/a/1","parentIdentifier":"/us/usc/t12/s4805/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4805%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s4805/a/1/A","parentIdentifier":"/us/usc/t12/s4805/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4805%2Fa%2F1%2FA","sourceRelease":"119-100","text":"insured depository institutions and their affiliates may file such reports and statements electronically; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s4805/a/1/B","parentIdentifier":"/us/usc/t12/s4805/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4805%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the Federal banking agencies may make such reports and statements available to the public electronically; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4805/a/2","parentIdentifier":"/us/usc/t12/s4805/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4805%2Fa%2F2","sourceRelease":"119-100","text":"not later than 1 year after , report to the Congress and make recommendations for legislation that would enhance efficiency for filers and users of such reports and statements.September 23, 1994","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Uniform reports and simplification of instructions","label":"b Uniform reports and simplification of instructions","identifier":"/us/usc/t12/s4805/b","parentIdentifier":"/us/usc/t12/s4805","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4805%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4805/b/1","parentIdentifier":"/us/usc/t12/s4805/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4805%2Fb%2F1","sourceRelease":"119-100","text":"to adopt a single form for the filing of core information required to be submitted under Federal law to all such agencies in the reports and statements referred to in subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4805/b/2","parentIdentifier":"/us/usc/t12/s4805/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4805%2Fb%2F2","sourceRelease":"119-100","text":"to simplify instructions accompanying such reports and statements and to provide an index to the instructions that is adequate to meet the needs of both filers and users.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Review of call report schedule","label":"c Review of call report schedule","identifier":"/us/usc/t12/s4805/c","parentIdentifier":"/us/usc/t12/s4805","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4805%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4805/c/1","parentIdentifier":"/us/usc/t12/s4805/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4805%2Fc%2F1","sourceRelease":"119-100","text":"review the information required by schedules supplementing the core information referred to in subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4805/c/2","parentIdentifier":"/us/usc/t12/s4805/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4805%2Fc%2F2","sourceRelease":"119-100","text":"eliminate requirements that are not warranted for reasons of safety and soundness or other public purposes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
