{"type":"section","nativeType":"section","number":"4505","heading":"Applications; payments to eligible institutions","label":"4505 Applications; payments to eligible institutions","identifier":"/us/usc/t22/s4505","parentIdentifier":"/us/usc/t22/ch55","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4505","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t22/s4505/a","parentIdentifier":"/us/usc/t22/s4505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4505%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4505/a/1","parentIdentifier":"/us/usc/t22/s4505/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4505%2Fa%2F1","sourceRelease":"119-100","text":"provide a description of the purposes for which the payments will be used in accordance with ; andsection 4504 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4505/a/2","parentIdentifier":"/us/usc/t22/s4505/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4505%2Fa%2F2","sourceRelease":"119-100","text":"provide such fiscal control and such accounting procedures as may be necessary (A) to ensure a proper accounting of Federal funds paid under this chapter, and (B) to ensure the verification of the costs of the continuing education and research programs conducted under this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t22/s4505/b","parentIdentifier":"/us/usc/t22/s4505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4505%2Fb","sourceRelease":"119-100","text":"Payments under this chapter may be made in installments, in advance, or by way of reimbursement, with necessary adjustments on account of overpayments and underpayments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
