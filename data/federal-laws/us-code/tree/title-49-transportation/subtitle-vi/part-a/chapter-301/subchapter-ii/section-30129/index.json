{"type":"section","nativeType":"section","number":"30129","heading":"Crash avoidance technology","label":"30129 Crash avoidance technology","identifier":"/us/usc/t49/s30129","parentIdentifier":"/us/usc/t49/stVI/ptA/ch301/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs30129","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t49/s30129/a","parentIdentifier":"/us/usc/t49/s30129","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs30129%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s30129/a/1","parentIdentifier":"/us/usc/t49/s30129/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs30129%2Fa%2F1","sourceRelease":"119-100","text":"to establish minimum performance standards with respect to crash avoidance technology; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s30129/a/2","parentIdentifier":"/us/usc/t49/s30129/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs30129%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s30129/a/2/A","parentIdentifier":"/us/usc/t49/s30129/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs30129%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":n