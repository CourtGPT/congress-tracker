{"type":"section","nativeType":"section","number":"3222","heading":"Program on recruitment and training","label":"3222 Program on recruitment and training","identifier":"/us/usc/t50/s3222","parentIdentifier":"/us/usc/t50/ch44/schVIII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to prior to editorial reclassification and renumbering as this section.section 441n of this title","Amendments2022— amended section generally. Prior to amendment, section related to a program on recruitment and training for areas of specialization in which current or future capabilities of the intelligence community are deficient or likely to be deficient.Pub. L. 117–263"],"amendments":["Amendments2022— amended section generally. Prior to amendment, section related to a program on recruitment and training for areas of specialization in which current or future capabilities of the intelligence community are deficient or likely to be deficient.Pub. L. 117–263"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Program","label":"a Program","identifier":"/us/usc/t50/s3222/a","parentIdentifier":"/us/usc/t50/s3222","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Requirement","label":"1 Requirement","identifier":"/us/usc/t50/s3222/a/1","parentIdentifier":"/us/usc/t50/s3222/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3222/a/1/A","parentIdentifier":"/us/usc/t50/s3222/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa%2F1%2FA","sourceRelease":"119-100","text":"in capabilities, missions, or skillsets, especially in the fields of science, technology, math, and engineering, to address workforce requirements in which the intelligence community is deficient or likely to be deficient in the future; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3222/a/1/B","parentIdentifier":"/us/usc/t50/s3222/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t50/s3222/a/1/B/i","parentIdentifier":"/us/usc/t50/s3222/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"contributing to capabilities, missions, or skillsets in which the intelligence community is deficient or likely to be deficient in future; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t50/s3222/a/1/B/ii","parentIdentifier":"/us/usc/t50/s3222/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"being underrepresented in the intelligence community or likely to be underrepresented in the future.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Commitment","label":"2 Commitment","identifier":"/us/usc/t50/s3222/a/2","parentIdentifier":"/us/usc/t50/s3222/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa%2F2","sourceRelease":"119-100","text":"An individual selected for participation in the program shall commit to employment with an element of the intelligence community for a period that the Director determines is commensurate with the amount of funding provided to the individual under the program and under such terms and conditions as the Director considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Designation","label":"3 Designation","identifier":"/us/usc/t50/s3222/a/3","parentIdentifier":"/us/usc/t50/s3222/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa%2F3","sourceRelease":"119-100","text":"The program shall be known as the Pat Roberts Intelligence Scholars Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Outreach","label":"4 Outreach","identifier":"/us/usc/t50/s3222/a/4","parentIdentifier":"/us/usc/t50/s3222/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3222/a/4/A","parentIdentifier":"/us/usc/t50/s3222/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa%2F4%2FA","sourceRelease":"119-100","text":"the intent of the program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3222/a/4/B","parentIdentifier":"/us/usc/t50/s3222/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa%2F4%2FB","sourceRelease":"119-100","text":"the conditions and requirements for selection and participation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t50/s3222/a/4/C","parentIdentifier":"/us/usc/t50/s3222/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa%2F4%2FC","sourceRelease":"119-100","text":"application instructions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t50/s3222/a/4/D","parentIdentifier":"/us/usc/t50/s3222/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa%2F4%2FD","sourceRelease":"119-100","text":"the areas covered by the program pursuant to the review conducted under subsection (b)(2); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t50/s3222/a/4/E","parentIdentifier":"/us/usc/t50/s3222/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fa%2F4%2FE","sourceRelease":"119-100","text":"any other details the Director determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Elements","label":"b Elements","identifier":"/us/usc/t50/s3222/b","parentIdentifier":"/us/usc/t50/s3222","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3222/b/1","parentIdentifier":"/us/usc/t50/s3222/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fb%2F1","sourceRelease":"119-100","text":"establish such requirements relating to the academic training of participants as the Director considers appropriate to ensure that participants are prepared for employment as intelligence professionals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3222/b/2","parentIdentifier":"/us/usc/t50/s3222/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fb%2F2","sourceRelease":"119-100","text":"on an annual basis, review the areas that will contribute to the capabilities, missions, and skillsets in which the intelligence community is deficient or is likely to be deficient in the future.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Use of funds","label":"c Use of funds","identifier":"/us/usc/t50/s3222/c","parentIdentifier":"/us/usc/t50/s3222","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3222/c/1","parentIdentifier":"/us/usc/t50/s3222/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fc%2F1","sourceRelease":"119-100","text":"to provide a monthly stipend for each month that a participant is pursuing a course of study;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3222/c/2","parentIdentifier":"/us/usc/t50/s3222/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fc%2F2","sourceRelease":"119-100","text":"to pay the partial or full tuition of a participant for the completion of such course of study;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s3222/c/3","parentIdentifier":"/us/usc/t50/s3222/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fc%2F3","sourceRelease":"119-100","text":"to reimburse a participant for tuition paid by the participant before becoming an employee of an element of the intelligence community, including with respect to providing payments for student loans used for such tuition;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t50/s3222/c/4","parentIdentifier":"/us/usc/t50/s3222/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fc%2F4","sourceRelease":"119-100","text":"to pay for books and materials that the participant requires or required to complete such course of study;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t50/s3222/c/5","parentIdentifier":"/us/usc/t50/s3222/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fc%2F5","sourceRelease":"119-100","text":"to pay the expenses of the participant for travel requested by an element of the intelligence community in relation to such program; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t50/s3222/c/6","parentIdentifier":"/us/usc/t50/s3222/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3222%2Fc%2F6","sourceRelease":"119-100","text":"for such other purposes the Director considers reasonably appropriate to carry out such program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
