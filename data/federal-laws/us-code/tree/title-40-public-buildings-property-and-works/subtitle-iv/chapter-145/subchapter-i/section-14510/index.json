{"type":"section","nativeType":"section","number":"14510","heading":"Drug abuse mitigation initiative","label":"14510 Drug abuse mitigation initiative","identifier":"/us/usc/t40/s14510","parentIdentifier":"/us/usc/t40/stIV/ch145/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t40/s14510/a","parentIdentifier":"/us/usc/t40/s14510","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t40/s14510/a/1","parentIdentifier":"/us/usc/t40/s14510/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fa%2F1","sourceRelease":"119-100","text":"to facilitate the sharing of best practices among States, counties, and other experts in the region with respect to reducing such abuse;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t40/s14510/a/2","parentIdentifier":"/us/usc/t40/s14510/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fa%2F2","sourceRelease":"119-100","text":"to initiate or expand programs designed to eliminate or reduce the harm to the workforce and economic growth of the region that results from such abuse;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t40/s14510/a/3","parentIdentifier":"/us/usc/t40/s14510/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fa%2F3","sourceRelease":"119-100","text":"to attract and retain relevant health care services, businesses, and workers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t40/s14510/a/4","parentIdentifier":"/us/usc/t40/s14510/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fa%2F4","sourceRelease":"119-100","text":"to develop relevant infrastructure, including broadband infrastructure that supports the use of telemedicine.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Limitation on Available Amounts","label":"b .—Limitation on Available Amounts","identifier":"/us/usc/t40/s14510/b","parentIdentifier":"/us/usc/t40/s14510","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t40/s14510/b/1","parentIdentifier":"/us/usc/t40/s14510/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fb%2F1","sourceRelease":"119-100","text":"not more than 50 percent may be provided from amounts appropriated to carry out this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t40/s14510/b/2","parentIdentifier":"/us/usc/t40/s14510/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t40/s14510/b/2/A","parentIdentifier":"/us/usc/t40/s14510/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fb%2F2%2FA","sourceRelease":"119-100","text":"in the case of a project to be carried out in a county for which a distressed county designation is in effect under section 14526, not more than 80 percent may be provided from amounts appropriated to carry out this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t40/s14510/b/2/B","parentIdentifier":"/us/usc/t40/s14510/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fb%2F2%2FB","sourceRelease":"119-100","text":"in the case of a project to be carried out in a county for which an at-risk designation is in effect under section 14526, not more than 70 percent may be provided from amounts appropriated to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Sources of Assistance","label":"c .—Sources of Assistance","identifier":"/us/usc/t40/s14510/c","parentIdentifier":"/us/usc/t40/s14510","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t40/s14510/c/1","parentIdentifier":"/us/usc/t40/s14510/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fc%2F1","sourceRelease":"119-100","text":"under any other Federal program (subject to the availability of subsequent appropriations); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t40/s14510/c/2","parentIdentifier":"/us/usc/t40/s14510/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fc%2F2","sourceRelease":"119-100","text":"from any other source.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Federal Share","label":"d .—Federal Share","identifier":"/us/usc/t40/s14510/d","parentIdentifier":"/us/usc/t40/s14510","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs14510%2Fd","sourceRelease":"119-100","text":"Notwithstanding any provision of law limiting the Federal share under any other Federal program, amounts made available to carry out this section may be used to increase that Federal share, as the Appalachian Regional Commission determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
