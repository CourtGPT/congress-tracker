{"type":"section","nativeType":"section","number":"4024","heading":"Technical assistance","label":"4024 Technical assistance","identifier":"/us/usc/t25/s4024","parentIdentifier":"/us/usc/t25/ch42/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4024","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4024/1","parentIdentifier":"/us/usc/t25/s4024","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4024%2F1","sourceRelease":"119-100","text":"directly or by contract, provide Indian tribes with technical assistance in developing, implementing, and managing Indian trust fund investment plans; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4024/2","parentIdentifier":"/us/usc/t25/s4024","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4024%2F2","sourceRelease":"119-100","text":"among other things, ensure that legal, financial, and other expertise of the Department of the Interior has been made fully available in an advisory capacity to the Indian tribes to assist in the development, implementation, and management of investment plans.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
