{"type":"section","nativeType":"section","number":"7330B","heading":"Annual report on Veterans Health Administration and furnishing of hospital care, medical services, and nursing home care","label":"7330B Annual report on Veterans Health Administration and furnishing of hospital care, medical services, and nursing home care","identifier":"/us/usc/t38/s7330B","parentIdentifier":"/us/usc/t38/ptV/ch73/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Report Required","label":"a .—Report Required","identifier":"/us/usc/t38/s7330B/a","parentIdentifier":"/us/usc/t38/s7330B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s7330B/a/1","parentIdentifier":"/us/usc/t38/s7330B/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fa%2F1","sourceRelease":"119-100","text":"the furnishing of hospital care, medical services, and nursing home care under the laws administered by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s7330B/a/2","parentIdentifier":"/us/usc/t38/s7330B/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fa%2F2","sourceRelease":"119-100","text":"the administration of the furnishing of such care and services by the Veterans Health Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Elements","label":"b .—Elements","identifier":"/us/usc/t38/s7330B/b","parentIdentifier":"/us/usc/t38/s7330B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s7330B/b/1","parentIdentifier":"/us/usc/t38/s7330B/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fb%2F1","sourceRelease":"119-100","text":"An evaluation of the effectiveness of the Veterans Health Administration in increasing the access of veterans to hospital care, medical services, and nursing home care furnished by the Secretary for which such veterans are eligible.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s7330B/b/2","parentIdentifier":"/us/usc/t38/s7330B/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fb%2F2","sourceRelease":"119-100","text":"An evaluation of the effectiveness of the Veterans Health Administration in improving the quality of health care provided to veterans, without increasing the costs incurred for such health care by the Federal Government or veterans, including relevant information for each medical center and Veterans Integrated Service Network of the Department set forth separately.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s7330B/b/3","parentIdentifier":"/us/usc/t38/s7330B/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s7330B/b/3/A","parentIdentifier":"/us/usc/t38/s7330B/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the workload of physicians and other employees of the Veterans Health Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s7330B/b/3/B","parentIdentifier":"/us/usc/t38/s7330B/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fb%2F3%2FB","sourceRelease":"119-100","text":"patient demographics and utilization rates;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s7330B/b/3/C","parentIdentifier":"/us/usc/t38/s7330B/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fb%2F3%2FC","sourceRelease":"119-100","text":"physician compensation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t38/s7330B/b/3/D","parentIdentifier":"/us/usc/t38/s7330B/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fb%2F3%2FD","sourceRelease":"119-100","text":"the productivity of physicians and other employees of the Veterans Health Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t38/s7330B/b/3/E","parentIdentifier":"/us/usc/t38/s7330B/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fb%2F3%2FE","sourceRelease":"119-100","text":"the percentage of hospital care, medical services, and nursing home care provided to veterans in facilities of the Department and in non-Department facilities and any changes in such percentages compared to the year preceding the year covered by the report;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t38/s7330B/b/3/F","parentIdentifier":"/us/usc/t38/s7330B/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fb%2F3%2FF","sourceRelease":"119-100","text":"pharmaceutical prices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t38/s7330B/b/3/G","parentIdentifier":"/us/usc/t38/s7330B/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fb%2F3%2FG","sourceRelease":"119-100","text":"third-party health billings owed to the Department, including the total amount of such billings and the total amount collected by the Department, set forth separately for claims greater than $1,000 and for claims equal to or less than $1,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Definitions","label":"c .—Definitions","identifier":"/us/usc/t38/s7330B/c","parentIdentifier":"/us/usc/t38/s7330B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs7330B%2Fc","sourceRelease":"119-100","text":"In this section, the terms “hospital care”, “medical services”, “nursing home care”, “facilities of the Department”, and “non-Department facilities” have the meanings given those terms in .section 1701 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
