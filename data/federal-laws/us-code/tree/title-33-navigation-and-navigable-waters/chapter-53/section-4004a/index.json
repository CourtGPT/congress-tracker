/t33/s4004a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fb%2F3%2FE","sourceRelease":"119-100","text":"private industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t33/s4004a/b/3/F","parentIdentifier":"/us/usc/t33/s4004a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fb%2F3%2FF","sourceRelease":"119-100","text":"nongovernmental organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t33/s4004a/b/3/G","parentIdentifier":"/us/usc/t33/s4004a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fb%2F3%2FG","sourceRelease":"119-100","text":"Indian tribes (as defined in ).section 5304 of title 25","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Action plan","label":"c Action plan","identifier":"/us/usc/t33/s4004a/c","parentIdentifier":"/us/usc/t33/s4004a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s4004a/c/1","parentIdentifier":"/us/usc/t33/s4004a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F1","sourceRelease":"119-100","text":"Not later than 3 years and 180 days after , the Task Force shall develop and submit to Congress a plan, based on the integrated assessment under subsection (b), for reducing, mitigating, and controlling harmful algal blooms and hypoxia in South Florida.June 16, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t33/s4004a/c/2","parentIdentifier":"/us/usc/t33/s4004a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s4004a/c/2/A","parentIdentifier":"/us/usc/t33/s4004a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F2%2FA","sourceRelease":"119-100","text":"address the monitoring needs identified in the integrated assessment under subsection (b);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s4004a/c/2/B","parentIdentifier":"/us/usc/t33/s4004a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F2%2FB","sourceRelease":"119-100","text":"develop a timeline and budgetary requirements for deployment of future assets;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s4004a/c/2/C","parentIdentifier":"/us/usc/t33/s4004a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s4004a/c/2/C/i","parentIdentifier":"/us/usc/t33/s4004a/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F2%2FC%2Fi","sourceRelease":"119-100","text":"all assumptions built into the models; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s4004a/c/2/C/ii","parentIdentifier":"/us/usc/t33/s4004a/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F2%2FC%2Fii","sourceRelease":"119-100","text":"data quality methods used to ensure the best available data are utilized; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t33/s4004a/c/2/D","parentIdentifier":"/us/usc/t33/s4004a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F2%2FD","sourceRelease":"119-100","text":"propose a plan to implement a remote monitoring network and early warning system for alerting local communities in the region to harmful algal bloom risks that may impact human health.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Requirements","label":"3 Requirements","identifier":"/us/usc/t33/s4004a/c/3","parentIdentifier":"/us/usc/t33/s4004a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s4004a/c/3/A","parentIdentifier":"/us/usc/t33/s4004a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4004a%2Fc%2F3%2FA","sourceRelease":"119-100","text":"consult with the State of Florida, and affected local and tribal governments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"labe