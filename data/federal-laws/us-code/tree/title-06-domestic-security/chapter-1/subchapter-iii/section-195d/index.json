{"type":"section","nativeType":"section","number":"195d","heading":"Social media working group","label":"195d Social media working group","identifier":"/us/usc/t6/s195d","parentIdentifier":"/us/usc/t6/ch1/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t6/s195d/a","parentIdentifier":"/us/usc/t6/s195d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish within the Department a social media working group (in this section referred to as the “Group”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purpose","label":"b Purpose","identifier":"/us/usc/t6/s195d/b","parentIdentifier":"/us/usc/t6/s195d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fb","sourceRelease":"119-100","text":"In order to enhance the dissemination of information through social media technologies between the Department and appropriate stakeholders and to improve use of social media technologies in support of preparedness, response, and recovery, the Group shall identify, and provide guidance and best practices to the emergency preparedness and response community on, the use of social media technologies before, during, and after a natural disaster or an act of terrorism or other man-made disaster.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Membership","label":"c Membership","identifier":"/us/usc/t6/s195d/c","parentIdentifier":"/us/usc/t6/s195d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s195d/c/1","parentIdentifier":"/us/usc/t6/s195d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s195d/c/1/A","parentIdentifier":"/us/usc/t6/s195d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F1%2FA","sourceRelease":"119-100","text":"The Office of Public Affairs of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s195d/c/1/B","parentIdentifier":"/us/usc/t6/s195d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F1%2FB","sourceRelease":"119-100","text":"The Office of the Chief Information Officer of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s195d/c/1/C","parentIdentifier":"/us/usc/t6/s195d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F1%2FC","sourceRelease":"119-100","text":"The Privacy Office of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s195d/c/1/D","parentIdentifier":"/us/usc/t6/s195d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F1%2FD","sourceRelease":"119-100","text":"The Federal Emergency Management Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t6/s195d/c/1/E","parentIdentifier":"/us/usc/t6/s195d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F1%2FE","sourceRelease":"119-100","text":"The Office of Disability Integration and Coordination of the Federal Emergency Management Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t6/s195d/c/1/F","parentIdentifier":"/us/usc/t6/s195d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F1%2FF","sourceRelease":"119-100","text":"The American Red Cross.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t6/s195d/c/1/G","parentIdentifier":"/us/usc/t6/s195d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F1%2FG","sourceRelease":"119-100","text":"The Forest Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t6/s195d/c/1/H","parentIdentifier":"/us/usc/t6/s195d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F1%2FH","sourceRelease":"119-100","text":"The Centers for Disease Control and Prevention.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t6/s195d/c/1/I","parentIdentifier":"/us/usc/t6/s195d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F1%2FI","sourceRelease":"119-100","text":"The United States Geological Survey.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t6/s195d/c/1/J","parentIdentifier":"/us/usc/t6/s195d/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F1%2FJ","sourceRelease":"119-100","text":"The National Oceanic and Atmospheric Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Chairperson; co-chairperson","label":"2 Chairperson; co-chairperson","identifier":"/us/usc/t6/s195d/c/2","parentIdentifier":"/us/usc/t6/s195d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Chairperson","label":"A Chairperson","identifier":"/us/usc/t6/s195d/c/2/A","parentIdentifier":"/us/usc/t6/s195d/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F2%2FA","sourceRelease":"119-100","text":"The Secretary, or a designee of the Secretary, shall serve as the chairperson of the Group.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Co-chairperson","label":"B Co-chairperson","identifier":"/us/usc/t6/s195d/c/2/B","parentIdentifier":"/us/usc/t6/s195d/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F2%2FB","sourceRelease":"119-100","text":"The chairperson shall designate, on a rotating basis, a representative from a State or local government who is a member of the Group to serve as the co-chairperson of the Group.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Additional members","label":"3 Additional members","identifier":"/us/usc/t6/s195d/c/3","parentIdentifier":"/us/usc/t6/s195d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s195d/c/3/A","parentIdentifier":"/us/usc/t6/s195d/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F3%2FA","sourceRelease":"119-100","text":"be equal to or greater than the total number of regular members under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s195d/c/3/B","parentIdentifier":"/us/usc/t6/s195d/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s195d/c/3/B/i","parentIdentifier":"/us/usc/t6/s195d/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":"not fewer than 3 representatives from the private sector; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s195d/c/3/B/ii","parentIdentifier":"/us/usc/t6/s195d/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t6/s195d/c/3/B/ii/I","parentIdentifier":"/us/usc/t6/s195d/c/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F3%2FB%2Fii%2FI","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t6/s195d/c/3/B/ii/I/aa","parentIdentifier":"/us/usc/t6/s195d/c/3/B/ii/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F3%2FB%2Fii%2FI%2Faa","sourceRelease":"119-100","text":"law enforcement;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t6/s195d/c/3/B/ii/I/bb","parentIdentifier":"/us/usc/t6/s195d/c/3/B/ii/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F3%2FB%2Fii%2FI%2Fbb","sourceRelease":"119-100","text":"fire services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"cc","heading":null,"label":"cc","identifier":"/us/usc/t6/s195d/c/3/B/ii/I/cc","parentIdentifier":"/us/usc/t6/s195d/c/3/B/ii/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F3%2FB%2Fii%2FI%2Fcc","sourceRelease":"119-100","text":"emergency management; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"dd","heading":null,"label":"dd","identifier":"/us/usc/t6/s195d/c/3/B/ii/I/dd","parentIdentifier":"/us/usc/t6/s195d/c/3/B/ii/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F3%2FB%2Fii%2FI%2Fdd","sourceRelease":"119-100","text":"public health entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t6/s195d/c/3/B/ii/II","parentIdentifier":"/us/usc/t6/s195d/c/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F3%2FB%2Fii%2FII","sourceRelease":"119-100","text":"universities and academia; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t6/s195d/c/3/B/ii/III","parentIdentifier":"/us/usc/t6/s195d/c/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F3%2FB%2Fii%2FIII","sourceRelease":"119-100","text":"nonprofit disaster relief organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Term limits","label":"4 Term limits","identifier":"/us/usc/t6/s195d/c/4","parentIdentifier":"/us/usc/t6/s195d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fc%2F4","sourceRelease":"119-100","text":"The chairperson shall establish term limits for individuals appointed to the Group under paragraph (3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Consultation with non-members","label":"d Consultation with non-members","identifier":"/us/usc/t6/s195d/d","parentIdentifier":"/us/usc/t6/s195d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fd","sourceRelease":"119-100","text":"To the extent practicable, the Group shall work with entities in the public and private sectors to carry out subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Meetings","label":"e Meetings","identifier":"/us/usc/t6/s195d/e","parentIdentifier":"/us/usc/t6/s195d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Initial meeting","label":"1 Initial meeting","identifier":"/us/usc/t6/s195d/e/1","parentIdentifier":"/us/usc/t6/s195d/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fe%2F1","sourceRelease":"119-100","text":"Not later than 90 days after , the Group shall hold its initial meeting.November 5, 2015","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Subsequent meetings","label":"2 Subsequent meetings","identifier":"/us/usc/t6/s195d/e/2","parentIdentifier":"/us/usc/t6/s195d/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s195d/e/2/A","parentIdentifier":"/us/usc/t6/s195d/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fe%2F2%2FA","sourceRelease":"119-100","text":"at the call of the chairperson; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s195d/e/2/B","parentIdentifier":"/us/usc/t6/s195d/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fe%2F2%2FB","sourceRelease":"119-100","text":"not less frequently than twice each year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Virtual meetings","label":"3 Virtual meetings","identifier":"/us/usc/t6/s195d/e/3","parentIdentifier":"/us/usc/t6/s195d/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fe%2F3","sourceRelease":"119-100","text":"Each meeting of the Group may be held virtually.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Reports","label":"f Reports","identifier":"/us/usc/t6/s195d/f","parentIdentifier":"/us/usc/t6/s195d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s195d/f/1","parentIdentifier":"/us/usc/t6/s195d/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Ff%2F1","sourceRelease":"119-100","text":"A review and analysis of current and emerging social media technologies being used to support preparedness and response activities related to natural disasters and acts of terrorism and other man-made disasters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s195d/f/2","parentIdentifier":"/us/usc/t6/s195d/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Ff%2F2","sourceRelease":"119-100","text":"A review of best practices and lessons learned on the use of social media technologies during the response to natural disasters and acts of terrorism and other man-made disasters that occurred during the period covered by the report at issue.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s195d/f/3","parentIdentifier":"/us/usc/t6/s195d/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Ff%2F3","sourceRelease":"119-100","text":"Recommendations to improve the Department’s use of social media technologies for emergency management purposes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s195d/f/4","parentIdentifier":"/us/usc/t6/s195d/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Ff%2F4","sourceRelease":"119-100","text":"Recommendations to improve public awareness of the type of information disseminated through social media technologies, and how to access such information, during a natural disaster or an act of terrorism or other man-made disaster.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s195d/f/5","parentIdentifier":"/us/usc/t6/s195d/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Ff%2F5","sourceRelease":"119-100","text":"A review of available training for Federal, State, local, tribal, and territorial officials on the use of social media technologies in response to a natural disaster or an act of terrorism or other man-made disaster.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t6/s195d/f/6","parentIdentifier":"/us/usc/t6/s195d/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Ff%2F6","sourceRelease":"119-100","text":"A review of coordination efforts with the private sector to discuss and resolve legal, operational, technical, privacy, and security concerns.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Duration of group","label":"g Duration of group","identifier":"/us/usc/t6/s195d/g","parentIdentifier":"/us/usc/t6/s195d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s195d/g/1","parentIdentifier":"/us/usc/t6/s195d/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fg%2F1","sourceRelease":"119-100","text":"The Group shall terminate on the date that is 5 years after , unless the chairperson renews the Group for a successive 5-year period, prior to the date on which the Group would otherwise terminate, by submitting to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Homeland Security of the House of Representatives a certification that the continued existence of the Group is necessary to fulfill the purpose described in subsection (b).November 5, 2015","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Continued renewal","label":"2 Continued renewal","identifier":"/us/usc/t6/s195d/g/2","parentIdentifier":"/us/usc/t6/s195d/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs195d%2Fg%2F2","sourceRelease":"119-100","text":"The chairperson may continue to renew the Group for successive 5-year periods by submitting a certification in accordance with paragraph (1) prior to the date on which the Group would otherwise terminate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
