{"type":"section","nativeType":"section","number":"12753","heading":"Penalties for misuse of funds","label":"12753 Penalties for misuse of funds","identifier":"/us/usc/t42/s12753","parentIdentifier":"/us/usc/t42/ch130/schII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12753","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s12753/1","parentIdentifier":"/us/usc/t42/s12753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12753%2F1","sourceRelease":"119-100","text":"prevent withdrawals from the participating jurisdiction’s HOME Investment Trust Fund for activities affected by such failure to comply;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s12753/2","parentIdentifier":"/us/usc/t42/s12753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12753%2F2","sourceRelease":"119-100","text":"restrict the participating jurisdiction’s activities under this subchapter to activities that conform to one or more model programs made available under ; orsection 12743 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s12753/3","parentIdentifier":"/us/usc/t42/s12753","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12753%2F3","sourceRelease":"119-100","text":"remove the participating jurisdiction from participation in allocations or reallocations of funds made available under this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
