{"type":"section","nativeType":"section","number":"2182","heading":"Educational assistance: dependents of captives","label":"2182 Educational assistance: dependents of captives","identifier":"/us/usc/t10/s2182","parentIdentifier":"/us/usc/t10/stA/ptIII/ch110","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection applicable with respect to persons whose captive status begins after , see , set out as a note under 2181 of this title.Jan. 21, 1981section 806(d)(3) of Pub. L. 99–399","Executive Documents","Delegation of FunctionsFunctions of the President under this section delegated to the Secretary of Defense, see section 3 of Ex. Ord. No. 12598, , 52 F.R. 23421, set out as a note under , Government Organization and Employees.June 17, 1987section 5569 of Title 5"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t10/s2182/a","parentIdentifier":"/us/usc/t10/s2182","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2182/a/1","parentIdentifier":"/us/usc/t10/s2182/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fa%2F1","sourceRelease":"119-100","text":"subsistence;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2182/a/2","parentIdentifier":"/us/usc/t10/s2182/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fa%2F2","sourceRelease":"119-100","text":"tuition;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2182/a/3","parentIdentifier":"/us/usc/t10/s2182/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fa%2F3","sourceRelease":"119-100","text":"fees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s2182/a/4","parentIdentifier":"/us/usc/t10/s2182/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fa%2F4","sourceRelease":"119-100","text":"supplies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s2182/a/5","parentIdentifier":"/us/usc/t10/s2182/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fa%2F5","sourceRelease":"119-100","text":"books;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t10/s2182/a/6","parentIdentifier":"/us/usc/t10/s2182/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fa%2F6","sourceRelease":"119-100","text":"equipment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t10/s2182/a/7","parentIdentifier":"/us/usc/t10/s2182/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fa%2F7","sourceRelease":"119-100","text":"other educational expenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t10/s2182/b","parentIdentifier":"/us/usc/t10/s2182","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2182/b/1","parentIdentifier":"/us/usc/t10/s2182/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fb%2F1","sourceRelease":"119-100","text":"after that person is in a captive status for not less than 90 days; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2182/b/2","parentIdentifier":"/us/usc/t10/s2182/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2182/b/2/A","parentIdentifier":"/us/usc/t10/s2182/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the end of any semester or quarter (as appropriate) that begins before the date on which the captive status of that person terminates;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2182/b/2/B","parentIdentifier":"/us/usc/t10/s2182/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the earlier of the end of any course that began before such date or the end of the 16-week period following that date if the educational or training institution is not operated on a semester or quarter system; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s2182/b/2/C","parentIdentifier":"/us/usc/t10/s2182/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fb%2F2%2FC","sourceRelease":"119-100","text":"a date specified by the Secretary concerned in order to respond to special circumstances.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t10/s2182/c","parentIdentifier":"/us/usc/t10/s2182","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fc","sourceRelease":"119-100","text":"If a person in a captive status or a former captive dies and the death is incident to the captivity, payments shall be available under this section for a dependent of that person for education or training that occurs after the date of the death of that person.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t10/s2182/d","parentIdentifier":"/us/usc/t10/s2182","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2182%2Fd","sourceRelease":"119-100","text":"The provisions of this section shall not apply to any dependent who is eligible for assistance under chapter 35 of title 38 or similar assistance under any other provision of law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
