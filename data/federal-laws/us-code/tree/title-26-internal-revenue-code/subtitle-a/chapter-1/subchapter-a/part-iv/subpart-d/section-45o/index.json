mber":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t26/s45O/a","parentIdentifier":"/us/usc/t26/s45O","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fa","sourceRelease":"119-100","text":"For purposes of section 38, in the case of an eligible agricultural business, the agricultural chemicals security credit determined under this section for the taxable year is 30 percent of the qualified security expenditures for the taxable year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Facility limitation","label":"b Facility limitation","identifier":"/us/usc/t26/s45O/b","parentIdentifier":"/us/usc/t26/s45O","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s45O/b/1","parentIdentifier":"/us/usc/t26/s45O/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fb%2F1","sourceRelease":"119-100","text":"$100,000, reduced by","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s45O/b/2","parentIdentifier":"/us/usc/t26/s45O/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fb%2F2","sourceRelease":"119-100","text":"the aggregate amount of credits determined under subsection (a) with respect to such facility for the 5 prior taxable years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Annual limitation","label":"c Annual limitation","identifier":"/us/usc/t26/s45O/c","parentIdentifier":"/us/usc/t26/s45O","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fc","sourceRelease":"119-100","text":"The amount of the credit determined under subsection (a) with respect to any taxpayer for any taxable year shall not exceed $2,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Qualified chemical security expenditure","label":"d Qualified chemical security expenditure","identifier":"/us/usc/t26/s45O/d","parentIdentifier":"/us/usc/t26/s45O","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s45O/d/1","parentIdentifier":"/us/usc/t26/s45O/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fd%2F1","sourceRelease":"119-100","text":"employee security training and background checks,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s45O/d/2","parentIdentifier":"/us/usc/t26/s45O/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fd%2F2","sourceRelease":"119-100","text":"limitation and prevention of access to controls of specified agricultural chemicals stored at the facility,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t26/s45O/d/3","parentIdentifier":"/us/usc/t26/s45O/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fd%2F3","sourceRelease":"119-100","text":"tagging, locking tank valves, and chemical additives to prevent the theft of specified agricultural chemicals or to render such chemicals unfit for illegal use,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t26/s45O/d/4","parentIdentifier":"/us/usc/t26/s45O/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fd%2F4","sourceRelease":"119-100","text":"protection of the perimeter of specified agricultural chemicals,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t26/s45O/d/5","parentIdentifier":"/us/usc/t26/s45O/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fd%2F5","sourceRelease":"119-100","text":"installation of security lighting, cameras, recording equipment, and intrusion detection sensors,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t26/s45O/d/6","parentIdentifier":"/us/usc/t26/s45O/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fd%2F6","sourceRelease":"119-100","text":"implementation of measures to increase computer or computer network security,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t26/s45O/d/7","parentIdentifier":"/us/usc/t26/s45O/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fd%2F7","sourceRelease":"119-100","text":"conducting a security vulnerability assessment,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t26/s45O/d/8","parentIdentifier":"/us/usc/t26/s45O/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs45O%2Fd%2F8","sourceRelease":"119-10