","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2558/c/1","parentIdentifier":"/us/usc/t10/s2558/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2558%2Fc%2F1","sourceRelease":"119-100","text":"limited air and ground transportation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2558/c/2","parentIdentifier":"/us/usc/t10/s2558/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2558%2Fc%2F2","sourceRelease":"119-100","text":"communications;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2558/c/3","parentIdentifier":"/us/usc/t10/s2558/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2558%2Fc%2F3","sourceRelease":"119-100","text":"medical assistance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s2558/c/4","parentIdentifier":"/us/usc/t10/s2558/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2558%2Fc%2F4","sourceRelease":"119-100","text":"administrative support; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s2558/c/5","parentIdentifier":"/us/usc/t10/s2558/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2558%2Fc%2F5","sourceRelease":"119-100","text":"security support.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—National Military Associations","label":"d .—National Military Associations","identifier":"/us/usc/t10/s2558/d","parentIdentifier":"/us/usc/t10/s2558","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2558%2Fd","sourceRelease":"119-100","text":"The Secretary of Defense shall designate those organizations which are national military associations for purposes of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Regulations","label":"e .—Regulations","identifier":"/us/usc/t10/s2558/e","parentIdentifier":"/us/usc/t10/s2558","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2558%2Fe","sourceRelease":"119-100","text":"The Secretary of Defense shall prescribe regulations to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
