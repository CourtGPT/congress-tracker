{"type":"section","nativeType":"section","number":"3043a","heading":"National intelligence strategy","label":"3043a National intelligence strategy","identifier":"/us/usc/t50/s3043a","parentIdentifier":"/us/usc/t50/ch44/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t50/s3043a/a","parentIdentifier":"/us/usc/t50/s3043a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fa","sourceRelease":"119-100","text":"Beginning in 2017, and once every 4 years thereafter, the Director of National Intelligence shall develop a comprehensive national intelligence strategy to meet national security objectives for the following 4-year period, or a longer period, if appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirements","label":"b Requirements","identifier":"/us/usc/t50/s3043a/b","parentIdentifier":"/us/usc/t50/s3043a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3043a/b/1","parentIdentifier":"/us/usc/t50/s3043a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t50/s3043a/b/1/A","parentIdentifier":"/us/usc/t50/s3043a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the most recent national security strategy report submitted pursuant to ;section 3043 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t50/s3043a/b/1/B","parentIdentifier":"/us/usc/t50/s3043a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the strategic plans of other relevant departments and agencies of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t50/s3043a/b/1/C","parentIdentifier":"/us/usc/t50/s3043a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fb%2F1%2FC","sourceRelease":"119-100","text":"other relevant national-level plans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3043a/b/2","parentIdentifier":"/us/usc/t50/s3043a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fb%2F2","sourceRelease":"119-100","text":"address matters related to national and military intelligence, including counterintelligence;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s3043a/b/3","parentIdentifier":"/us/usc/t50/s3043a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fb%2F3","sourceRelease":"119-100","text":"identify the major national security missions that the intelligence community is currently pursuing and will pursue in the future to meet the anticipated security environment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t50/s3043a/b/4","parentIdentifier":"/us/usc/t50/s3043a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fb%2F4","sourceRelease":"119-100","text":"describe how the intelligence community will utilize personnel, technology, partnerships, and other capabilities to pursue the major national security missions identified in paragraph (3);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t50/s3043a/b/5","parentIdentifier":"/us/usc/t50/s3043a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fb%2F5","sourceRelease":"119-100","text":"assess current, emerging, and future threats to the intelligence community, including threats from foreign intelligence and security services and insider threats;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t50/s3043a/b/6","parentIdentifier":"/us/usc/t50/s3043a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fb%2F6","sourceRelease":"119-100","text":"outline the organizational roles and missions of the elements of the intelligence community as part of an integrated enterprise to meet customer demands for intelligence products, services, and support;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t50/s3043a/b/7","parentIdentifier":"/us/usc/t50/s3043a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fb%2F7","sourceRelease":"119-100","text":"identify sources of strategic, institutional, programmatic, fiscal, and technological risk; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t50/s3043a/b/8","parentIdentifier":"/us/usc/t50/s3043a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fb%2F8","sourceRelease":"119-100","text":"analyze factors that may affect the intelligence community’s performance in pursuing the major national security missions identified in paragraph (3) during the following 10-year period.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Submission to Congress","label":"c Submission to Congress","identifier":"/us/usc/t50/s3043a/c","parentIdentifier":"/us/usc/t50/s3043a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3043a%2Fc","sourceRelease":"119-100","text":"The Director of National Intelligence shall submit to the congressional intelligence committees a report on each national intelligence strategy required by subsection (a) not later than 45 days after the date of the completion of such strategy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
