{"type":"section","nativeType":"section","number":"563c","heading":"Inventory utilization","label":"563c Inventory utilization","identifier":"/us/usc/t6/s563c","parentIdentifier":"/us/usc/t6/ch1/schXII–A/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t6/s563c/a","parentIdentifier":"/us/usc/t6/s563c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563c%2Fa","sourceRelease":"119-100","text":"Before the procurement of additional quantities of equipment to fulfill a mission need, the Administrator, to the extent practicable, shall utilize any existing units in the Administration’s inventory to meet that need.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Tracking of inventory","label":"b Tracking of inventory","identifier":"/us/usc/t6/s563c/b","parentIdentifier":"/us/usc/t6/s563c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s563c/b/1","parentIdentifier":"/us/usc/t6/s563c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563c%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s563c/b/1/A","parentIdentifier":"/us/usc/t6/s563c/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563c%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the location of security-related equipment in the inventory under subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s563c/b/1/B","parentIdentifier":"/us/usc/t6/s563c/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563c%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the utilization status of security-related technology in the inventory under subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s563c/b/1/C","parentIdentifier":"/us/usc/t6/s563c/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563c%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the quantity of security-related equipment in the inventory under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Internal controls","label":"2 Internal controls","identifier":"/us/usc/t6/s563c/b/2","parentIdentifier":"/us/usc/t6/s563c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563c%2Fb%2F2","sourceRelease":"119-100","text":"The Administrator shall implement internal controls to ensure up-to-date accurate data on security-related technology owned, deployed, and in use.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Logistics management","label":"c Logistics management","identifier":"/us/usc/t6/s563c/c","parentIdentifier":"/us/usc/t6/s563c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563c%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s563c/c/1","parentIdentifier":"/us/usc/t6/s563c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563c%2Fc%2F1","sourceRelease":"119-100","text":"The Administrator shall establish logistics principles for managing inventory in an effective and efficient manner.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitation on just-in-time logistics","label":"2 Limitation on just-in-time logistics","identifier":"/us/usc/t6/s563c/c/2","parentIdentifier":"/us/usc/t6/s563c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563c%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s563c/c/2/A","parentIdentifier":"/us/usc/t6/s563c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563c%2Fc%2F2%2FA","sourceRelease":"119-100","text":"would inhibit necessary planning for large-scale delivery of equipment to airports or other facilities; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s563c/c/2/B","parentIdentifier":"/us/usc/t6/s563c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs563c%2Fc%2F2%2FB","sourceRelease":"119-100","text":"would unduly diminish surge capacity for response to a terrorist threat.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
