{"type":"section","nativeType":"section","number":"4730","heading":"Great Lakes and Lake Champlain Invasive Species Program","label":"4730 Great Lakes and Lake Champlain Invasive Species Program","identifier":"/us/usc/t16/s4730","parentIdentifier":"/us/usc/t16/ch67/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Vessel Incidental Discharge Act of 2018 and also as part of the Frank LoBiondo Coast Guard Authorization Act of 2018, and not as part of the Nonindigenous Aquatic Nuisance Prevention and Control Act of 1990 which comprises this chapter.Section is comprised of subsec. (g) of . For classification to the Code of other provisions of section 903, see Tables.section 903 of Pub. L. 115–282"],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Definitions","label":"1 Definitions","identifier":"/us/usc/t16/s4730/1","parentIdentifier":"/us/usc/t16/s4730","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Administrator","label":"A Administrator","identifier":"/us/usc/t16/s4730/1/A","parentIdentifier":"/us/usc/t16/s4730/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F1%2FA","sourceRelease":"119-100","text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Aquatic nuisance species","label":"B Aquatic nuisance species","identifier":"/us/usc/t16/s4730/1/B","parentIdentifier":"/us/usc/t16/s4730/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F1%2FB","sourceRelease":"119-100","text":"The term “aquatic nuisance species” has the meaning given that term in subsection (p)(1) of .section 1322 of title 33","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Director","label":"C Director","identifier":"/us/usc/t16/s4730/1/C","parentIdentifier":"/us/usc/t16/s4730/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F1%2FC","sourceRelease":"119-100","text":"The term “Director” means the Director of the Great Lakes National Program Office established by .section 1268(b) of title 33","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Great Lakes and Lake Champlain Systems","label":"D Great Lakes and Lake Champlain Systems","identifier":"/us/usc/t16/s4730/1/D","parentIdentifier":"/us/usc/t16/s4730/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F1%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s4730/1/D/i","parentIdentifier":"/us/usc/t16/s4730/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F1%2FD%2Fi","sourceRelease":"119-100","text":"Lake Champlain; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s4730/1/D/ii","parentIdentifier":"/us/usc/t16/s4730/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F1%2FD%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s4730/1/D/ii/I","parentIdentifier":"/us/usc/t16/s4730/1/D/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F1%2FD%2Fii%2FI","sourceRelease":"119-100","text":"the Great Lakes System (as defined in ); orsection 1268(a)(3) of title 33","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s4730/1/D/ii/II","parentIdentifier":"/us/usc/t16/s4730/1/D/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F1%2FD%2Fii%2FII","sourceRelease":"119-100","text":"the Lake Champlain drainage basin (as defined in ).section 1270(g) of title 33","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":"Program","label":"E Program","identifier":"/us/usc/t16/s4730/1/E","parentIdentifier":"/us/usc/t16/s4730/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F1%2FE","sourceRelease":"119-100","text":"The term “Program” means the Great Lakes and Lake Champlain Invasive Species Program established under paragraph (2)(A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Establishment of program","label":"2 Establishment of program","identifier":"/us/usc/t16/s4730/2","parentIdentifier":"/us/usc/t16/s4730","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s4730/2/A","parentIdentifier":"/us/usc/t16/s4730/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s4730/2/A/i","parentIdentifier":"/us/usc/t16/s4730/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s4730/2/A/i/I","parentIdentifier":"/us/usc/t16/s4730/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FA%2Fi%2FI","sourceRelease":"119-100","text":"the Director of the United States Fish and Wildlife Service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s4730/2/A/i/II","parentIdentifier":"/us/usc/t16/s4730/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FA%2Fi%2FII","sourceRelease":"119-100","text":"the Administrator of the National Oceanic and Atmospheric Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s4730/2/A/i/III","parentIdentifier":"/us/usc/t16/s4730/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FA%2Fi%2FIII","sourceRelease":"119-100","text":"the Director of the United States Geological Survey; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t16/s4730/2/A/i/IV","parentIdentifier":"/us/usc/t16/s4730/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FA%2Fi%2FIV","sourceRelease":"119-100","text":"the Secretary of the department in which the Coast Guard is operating; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s4730/2/A/ii","parentIdentifier":"/us/usc/t16/s4730/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s4730/2/A/ii/I","parentIdentifier":"/us/usc/t16/s4730/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FA%2Fii%2FI","sourceRelease":"119-100","text":"the head of Great Lakes Aquatic Nonindigenous Species Information System of the National Oceanic and Atmospheric Administration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s4730/2/A/ii/II","parentIdentifier":"/us/usc/t16/s4730/2/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FA%2Fii%2FII","sourceRelease":"119-100","text":"the head of Great Lakes Environmental Research Laboratory of the National Oceanic and Atmospheric Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Purposes","label":"B Purposes","identifier":"/us/usc/t16/s4730/2/B","parentIdentifier":"/us/usc/t16/s4730/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s4730/2/B/i","parentIdentifier":"/us/usc/t16/s4730/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FB%2Fi","sourceRelease":"119-100","text":"to monitor for the introduction and spread of aquatic nuisance species into or within the Great Lakes and Lake Champlain Systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s4730/2/B/ii","parentIdentifier":"/us/usc/t16/s4730/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FB%2Fii","sourceRelease":"119-100","text":"to detect newly introduced aquatic nuisance species prior to the establishment of the aquatic nuisance species in the Great Lakes and Lake Champlain Systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s4730/2/B/iii","parentIdentifier":"/us/usc/t16/s4730/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"to inform, and assist with, management and response actions to prevent or stop the establishment or spread of an aquatic nuisance species;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s4730/2/B/iv","parentIdentifier":"/us/usc/t16/s4730/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"to establish a watch list of candidate aquatic nuisance species that may be introduced or spread, and that may survive and establish, within the Great Lakes and Lake Champlain Systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t16/s4730/2/B/v","parentIdentifier":"/us/usc/t16/s4730/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FB%2Fv","sourceRelease":"119-100","text":"to monitor vectors likely to be contributing to the introduction or spread of aquatic nuisance species, including ballast water operations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t16/s4730/2/B/vi","parentIdentifier":"/us/usc/t16/s4730/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FB%2Fvi","sourceRelease":"119-100","text":"to work collaboratively with the Federal, State, local, and Tribal agencies to develop criteria for prioritizing and distributing monitoring efforts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t16/s4730/2/B/vii","parentIdentifier":"/us/usc/t16/s4730/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FB%2Fvii","sourceRelease":"119-100","text":"to develop, achieve type approval for, and pilot shipboard or land-based ballast water management systems installed on, or available for use by, commercial vessels operating solely within the Great Lakes and Lake Champlain Systems to prevent the spread of aquatic nuisance species populations within the Great Lakes and Lake Champlain Systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t16/s4730/2/B/viii","parentIdentifier":"/us/usc/t16/s4730/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F2%2FB%2Fviii","sourceRelease":"119-100","text":"to facilitate meaningful Federal and State implementation of the regulatory framework in this section, including monitoring, shipboard education, inspection, and compliance conducted by States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Methodology","label":"3 Methodology","identifier":"/us/usc/t16/s4730/3","parentIdentifier":"/us/usc/t16/s4730","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s4730/3/A","parentIdentifier":"/us/usc/t16/s4730/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s4730/3/A/i","parentIdentifier":"/us/usc/t16/s4730/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3%2FA%2Fi","sourceRelease":"119-100","text":"existing aquatic nuisance species monitoring efforts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s4730/3/A/ii","parentIdentifier":"/us/usc/t16/s4730/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3%2FA%2Fii","sourceRelease":"119-100","text":"efforts to develop criteria for prioritizing and distributing monitoring efforts, geographically and among taxa, in the Great Lakes and Lake Champlain Systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s4730/3/B","parentIdentifier":"/us/usc/t16/s4730/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3%2FB","sourceRelease":"119-100","text":"to advance early detection and monitoring, and capacity to control the establishment and spread, of aquatic nuisance species within the Great Lakes and Lake Champlain Systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s4730/3/C","parentIdentifier":"/us/usc/t16/s4730/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3%2FC","sourceRelease":"119-100","text":"to identify opportunities to interdict the introduction and spread of aquatic nuisance species through sound science and technological advancements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s4730/3/D","parentIdentifier":"/us/usc/t16/s4730/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3%2FD","sourceRelease":"119-100","text":"to assess the risk of aquatic nuisance species introduction and spread via the range of vectors active within the Great Lakes and Lake Champlain Systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s4730/3/E","parentIdentifier":"/us/usc/t16/s4730/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3%2FE","sourceRelease":"119-100","text":"to advance the development of type-approved ballast water management system (as defined in subsection (p)(1) of equipment for commercial, non-seagoing vessels that operate solely within the Great Lakes System (as defined in );section 1322 of title 331section 1268(a)(3) of title 33So in original. Probably should be followed by a closing parenthesis.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t16/s4730/3/F","parentIdentifier":"/us/usc/t16/s4730/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3%2FF","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s4730/3/F/i","parentIdentifier":"/us/usc/t16/s4730/3/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3%2FF%2Fi","sourceRelease":"119-100","text":"the detection of new aquatic nuisance species within the Great Lakes and Lake Champlain Systems; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s4730/3/F/ii","parentIdentifier":"/us/usc/t16/s4730/3/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3%2FF%2Fii","sourceRelease":"119-100","text":"the spread of aquatic nuisance species within the Great Lakes and Lake Champlain Systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t16/s4730/3/G","parentIdentifier":"/us/usc/t16/s4730/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3%2FG","sourceRelease":"119-100","text":"to annually submit to appropriate individuals and entities in each affected region a report describing the findings and activities of the Program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t16/s4730/3/H","parentIdentifier":"/us/usc/t16/s4730/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3%2FH","sourceRelease":"119-100","text":"to identify roles and responsibilities of Federal agencies in aquatic nuisance species monitoring and response; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s4730/3/I","parentIdentifier":"/us/usc/t16/s4730/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F3%2FI","sourceRelease":"119-100","text":"to provide resource assistance to States implementing State-level programs to enter into partnerships with Federal agencies in enforcing the requirements under subsection (p) of .section 1322 of title 33","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Collaboration","label":"4 Collaboration","identifier":"/us/usc/t16/s4730/4","parentIdentifier":"/us/usc/t16/s4730","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s4730/4/A","parentIdentifier":"/us/usc/t16/s4730/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F4%2FA","sourceRelease":"119-100","text":"applicable Federal, State, local, and Tribal agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s4730/4/B","parentIdentifier":"/us/usc/t16/s4730/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F4%2FB","sourceRelease":"119-100","text":"such other research entities or stakeholders as the Director determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Data availability","label":"5 Data availability","identifier":"/us/usc/t16/s4730/5","parentIdentifier":"/us/usc/t16/s4730","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s4730/5/A","parentIdentifier":"/us/usc/t16/s4730/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F5%2FA","sourceRelease":"119-100","text":"make the data collected under the Program available on a publicly accessible internet website, including in an annual summary report; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s4730/5/B","parentIdentifier":"/us/usc/t16/s4730/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F5%2FB","sourceRelease":"119-100","text":"in coordination with the entities identified under paragraph (4), develop communication and notification protocols for the purpose of communicating the range of aquatic nuisance species and any identification of a new aquatic nuisance species introduced to the Great Lakes and Lake Champlain Systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Report to Congress","label":"6 Report to Congress","identifier":"/us/usc/t16/s4730/6","parentIdentifier":"/us/usc/t16/s4730","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s4730/6/A","parentIdentifier":"/us/usc/t16/s4730/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F6%2FA","sourceRelease":"119-100","text":"Not later than , the Director shall submit to Congress a report summarizing the outcomes of activities carried out under the Program.December 31, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Contents","label":"B Contents","identifier":"/us/usc/t16/s4730/6/B","parentIdentifier":"/us/usc/t16/s4730/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F6%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s4730/6/B/i","parentIdentifier":"/us/usc/t16/s4730/6/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F6%2FB%2Fi","sourceRelease":"119-100","text":"a description of activities carried out under the Program, including an explanation of how those activities help to achieve the purposes described in paragraph (2)(B);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s4730/6/B/ii","parentIdentifier":"/us/usc/t16/s4730/6/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F6%2FB%2Fii","sourceRelease":"119-100","text":"an analysis of Federal, State, and local efforts to enhance multidisciplinary approaches to achieve the purposes described in paragraph (2)(B);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s4730/6/B/iii","parentIdentifier":"/us/usc/t16/s4730/6/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F6%2FB%2Fiii","sourceRelease":"119-100","text":"recommendations relating to activities that would contribute to achievement of the purposes described in paragraph (2)(B); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s4730/6/B/iv","parentIdentifier":"/us/usc/t16/s4730/6/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F6%2FB%2Fiv","sourceRelease":"119-100","text":"recommendations to improve the efficiency and effectiveness of the Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Authorization of appropriations","label":"7 Authorization of appropriations","identifier":"/us/usc/t16/s4730/7","parentIdentifier":"/us/usc/t16/s4730","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs4730%2F7","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out the Program $50,000,000 for each of fiscal years 2019 through 2023.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
