{"type":"section","nativeType":"section","number":"7603","heading":"Prescriber verification","label":"7603 Prescriber verification","identifier":"/us/usc/t15/s7603","parentIdentifier":"/us/usc/t15/ch102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective 60 days after , see , set out as a note under .Dec. 6, 2003section 12 of Pub. L. 108–164section 7601 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Prescription requirement","label":"a Prescription requirement","identifier":"/us/usc/t15/s7603/a","parentIdentifier":"/us/usc/t15/s7603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7603/a/1","parentIdentifier":"/us/usc/t15/s7603/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fa%2F1","sourceRelease":"119-100","text":"presented to the seller by the patient or prescriber directly or by facsimile; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7603/a/2","parentIdentifier":"/us/usc/t15/s7603/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fa%2F2","sourceRelease":"119-100","text":"verified by direct communication.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Record requirement","label":"b Record requirement","identifier":"/us/usc/t15/s7603/b","parentIdentifier":"/us/usc/t15/s7603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fb","sourceRelease":"119-100","text":"A seller shall maintain a record of all direct communications referred to in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Information","label":"c Information","identifier":"/us/usc/t15/s7603/c","parentIdentifier":"/us/usc/t15/s7603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7603/c/1","parentIdentifier":"/us/usc/t15/s7603/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fc%2F1","sourceRelease":"119-100","text":"Patient’s full name and address.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7603/c/2","parentIdentifier":"/us/usc/t15/s7603/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fc%2F2","sourceRelease":"119-100","text":"Contact lens power, manufacturer, base curve or appropriate designation, and diameter when appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s7603/c/3","parentIdentifier":"/us/usc/t15/s7603/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fc%2F3","sourceRelease":"119-100","text":"Quantity of lenses ordered.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s7603/c/4","parentIdentifier":"/us/usc/t15/s7603/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fc%2F4","sourceRelease":"119-100","text":"Date of patient request.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s7603/c/5","parentIdentifier":"/us/usc/t15/s7603/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fc%2F5","sourceRelease":"119-100","text":"Date and time of verification request.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s7603/c/6","parentIdentifier":"/us/usc/t15/s7603/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fc%2F6","sourceRelease":"119-100","text":"Name of contact person at seller’s company, including facsimile and telephone number.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Verification events","label":"d Verification events","identifier":"/us/usc/t15/s7603/d","parentIdentifier":"/us/usc/t15/s7603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7603/d/1","parentIdentifier":"/us/usc/t15/s7603/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fd%2F1","sourceRelease":"119-100","text":"The prescriber confirms the prescription is accurate by direct communication with the seller.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7603/d/2","parentIdentifier":"/us/usc/t15/s7603/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fd%2F2","sourceRelease":"119-100","text":"The prescriber informs the seller that the prescription is inaccurate and provides the accurate prescription.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s7603/d/3","parentIdentifier":"/us/usc/t15/s7603/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fd%2F3","sourceRelease":"119-100","text":"The prescriber fails to communicate with the seller within 8 business hours, or a similar time as defined by the Federal Trade Commission, after receiving from the seller the information described in subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Invalid prescription","label":"e Invalid prescription","identifier":"/us/usc/t15/s7603/e","parentIdentifier":"/us/usc/t15/s7603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fe","sourceRelease":"119-100","text":"If a prescriber informs a seller before the deadline under subsection (d)(3) that the contact lens prescription is inaccurate, expired, or otherwise invalid, the seller shall not fill the prescription. The prescriber shall specify the basis for the inaccuracy or invalidity of the prescription. If the prescription communicated by the seller to the prescriber is inaccurate, the prescriber shall correct it.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"No alteration","label":"f No alteration","identifier":"/us/usc/t15/s7603/f","parentIdentifier":"/us/usc/t15/s7603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Ff","sourceRelease":"119-100","text":"A seller may not alter a contact lens prescription. Notwithstanding the preceding sentence, if the same contact lens is manufactured by the same company and sold under multiple labels to individual providers, the seller may fill the prescription with a contact lens manufactured by that company under another label.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Direct communication","label":"g Direct communication","identifier":"/us/usc/t15/s7603/g","parentIdentifier":"/us/usc/t15/s7603","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7603%2Fg","sourceRelease":"119-100","text":"As used in this section, the term “direct communication” includes communication by telephone, facsimile, or electronic mail.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
