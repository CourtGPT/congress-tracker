 99–198, title XIII, § 1313(a)99 Stat. 1525Pub. L. 100–233, title VI, § 608101 Stat. 1667Pub. L. 101–624, title XVIII, § 1812104 Stat. 3821Pub. L. 103–354, title II, § 281(c)108 Stat. 3233Dec. 23, 1985Jan. 6, 1988Nov. 28, 1990Oct. 13, 1994","Amendments2018—Subsec. (h). substituted “2023” for “2018”.Pub. L. 115–3342014—Subsec. (h). substituted “2018” for “2012”.Pub. L. 113–79"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t7/s1983b/a","parentIdentifier":"/us/usc/t7/s1983b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Demonstration program","label":"1 Demonstration program","identifier":"/us/usc/t7/s1983b/a/1","parentIdentifier":"/us/usc/t7/s1983b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F1","sourceRelease":"119-100","text":"The term “demonstration program” means a demonstration program carried out by a qualified entity under the pilot program established in subsection (b)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible participant","label":"2 Eligible participant","identifier":"/us/usc/t7/s1983b/a/2","parentIdentifier":"/us/usc/t7/s1983b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1983b/a/2/A","parentIdentifier":"/us/usc/t7/s1983b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F2%2FA","sourceRelease":"119-100","text":"lacks significant financial resources or assets; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1983b/a/2/B","parentIdentifier":"/us/usc/t7/s1983b/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1983b/a/2/B/i","parentIdentifier":"/us/usc/t7/s1983b/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"80 percent of the median income of the State in which the farmer or rancher resides; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1983b/a/2/B/ii","parentIdentifier":"/us/usc/t7/s1983b/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"200 percent of the most recent annual Federal Poverty Income Guidelines published by the Department of Health and Human Services for the State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Individual development account","label":"3 Individual development account","identifier":"/us/usc/t7/s1983b/a/3","parentIdentifier":"/us/usc/t7/s1983b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F3","sourceRelease":"119-100","text":"The term “individual development account” means a savings account described in subsection (b)(4)(A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Qualified entity","label":"4 Qualified entity","identifier":"/us/usc/t7/s1983b/a/4","parentIdentifier":"/us/usc/t7/s1983b/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s1983b/a/4/A","parentIdentifier":"/us/usc/t7/s1983b/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1983b/a/4/A/i","parentIdentifier":"/us/usc/t7/s1983b/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F4%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s1983b/a/4/A/i/I","parentIdentifier":"/us/usc/t7/s1983b/a/4/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F4%2FA%2Fi%2FI","sourceRelease":"119-100","text":"described in ; andsection 501(c)(3) of title 26","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s1983b/a/4/A/i/II","parentIdentifier":"/us/usc/t7/s1983b/a/4/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F4%2FA%2Fi%2FII","sourceRelease":"119-100","text":"exempt from taxation under section 501(a) of such title; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1983b/a/4/A/ii","parentIdentifier":"/us/usc/t7/s1983b/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F4%2FA%2Fii","sourceRelease":"119-100","text":"a State, local, or tribal government submitting an application jointly with an organization described in clause (i).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"No prohibition on collaboration","label":"B No prohibition on collaboration","identifier":"/us/usc/t7/s1983b/a/4/B","parentIdentifier":"/us/usc/t7/s1983b/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fa%2F4%2FB","sourceRelease":"119-100","text":"An organization described in subparagraph (A)(i) may collaborate with a financial institution or for-profit community development corporation to carry out the purposes of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Pilot program","label":"b Pilot program","identifier":"/us/usc/t7/s1983b/b","parentIdentifier":"/us/usc/t7/s1983b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1983b/b/1","parentIdentifier":"/us/usc/t7/s1983b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1983b/b/1/A","parentIdentifier":"/us/usc/t7/s1983b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F1%2FA","sourceRelease":"119-100","text":"of at least 5 years in duration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1983b/b/1/B","parentIdentifier":"/us/usc/t7/s1983b/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F1%2FB","sourceRelease":"119-100","text":"in at least 15 States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Coordination","label":"2 Coordination","identifier":"/us/usc/t7/s1983b/b/2","parentIdentifier":"/us/usc/t7/s1983b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary shall operate the pilot program through, and in coordination with the farm loan programs of, the Farm Service Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Reserve funds","label":"3 Reserve funds","identifier":"/us/usc/t7/s1983b/b/3","parentIdentifier":"/us/usc/t7/s1983b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s1983b/b/3/A","parentIdentifier":"/us/usc/t7/s1983b/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F3%2FA","sourceRelease":"119-100","text":"A qualified entity carrying out a demonstration program under this section shall establish a reserve fund consisting of a non-Federal match of 50 percent of the total amount of the grant awarded to the demonstration program under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Federal funds","label":"B Federal funds","identifier":"/us/usc/t7/s1983b/b/3/B","parentIdentifier":"/us/usc/t7/s1983b/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F3%2FB","sourceRelease":"119-100","text":"After the qualified entity has deposited the non-Federal matching funds described in subparagraph (A) in the reserve fund, the Secretary shall provide the total amount of the grant awarded under this section to the demonstration program for deposit in the reserve fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Use of funds","label":"C Use of funds","identifier":"/us/usc/t7/s1983b/b/3/C","parentIdentifier":"/us/usc/t7/s1983b/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1983b/b/3/C/i","parentIdentifier":"/us/usc/t7/s1983b/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F3%2FC%2Fi","sourceRelease":"119-100","text":"may use up to 10 percent for administrative expenses; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1983b/b/3/C/ii","parentIdentifier":"/us/usc/t7/s1983b/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F3%2FC%2Fii","sourceRelease":"119-100","text":"shall use the remainder in making matching awards described in paragraph (4)(B)(ii)(I).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Interest","label":"D Interest","identifier":"/us/usc/t7/s1983b/b/3/D","parentIdentifier":"/us/usc/t7/s1983b/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F3%2FD","sourceRelease":"119-100","text":"Any interest earned on amounts in a reserve fund established under subparagraph (A) may be used by the qualified entity as additional matching funds for, or to administer, the demonstration program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":"Guidance","label":"E Guidance","identifier":"/us/usc/t7/s1983b/b/3/E","parentIdentifier":"/us/usc/t7/s1983b/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F3%2FE","sourceRelease":"119-100","text":"The Secretary shall issue guidance regarding the investment requirements of reserve funds established under this paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":"Reversion","label":"F Reversion","identifier":"/us/usc/t7/s1983b/b/3/F","parentIdentifier":"/us/usc/t7/s1983b/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F3%2FF","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1983b/b/3/F/i","parentIdentifier":"/us/usc/t7/s1983b/b/3/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F3%2FF%2Fi","sourceRelease":"119-100","text":"the amount of Federal funds deposited in the reserve fund under subparagraph (B) that were not used for administrative expenses; divided by","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1983b/b/3/F/ii","parentIdentifier":"/us/usc/t7/s1983b/b/3/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F3%2FF%2Fii","sourceRelease":"119-100","text":"the total amount of funds deposited in the reserve fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Individual development accounts","label":"4 Individual development accounts","identifier":"/us/usc/t7/s1983b/b/4","parentIdentifier":"/us/usc/t7/s1983b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s1983b/b/4/A","parentIdentifier":"/us/usc/t7/s1983b/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F4%2FA","sourceRelease":"119-100","text":"A qualified entity receiving a grant under this section shall establish and administer individual development accounts for eligible participants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Contract requirements","label":"B Contract requirements","identifier":"/us/usc/t7/s1983b/b/4/B","parentIdentifier":"/us/usc/t7/s1983b/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1983b/b/4/B/i","parentIdentifier":"/us/usc/t7/s1983b/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F4%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s1983b/b/4/B/i/I","parentIdentifier":"/us/usc/t7/s1983b/b/4/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F4%2FB%2Fi%2FI","sourceRelease":"119-100","text":"to deposit a certain amount of funds of the eligible participant in a personal savings account, as prescribed by the contractual agreement between the eligible participant and the qualified entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s1983b/b/4/B/i/II","parentIdentifier":"/us/usc/t7/s1983b/b/4/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F4%2FB%2Fi%2FII","sourceRelease":"119-100","text":"to use the funds described in subclause (I) only for 1 or more eligible expenditures described in paragraph (5)(A); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t7/s1983b/b/4/B/i/III","parentIdentifier":"/us/usc/t7/s1983b/b/4/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F4%2FB%2Fi%2FIII","sourceRelease":"119-100","text":"to complete financial training; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1983b/b/4/B/ii","parentIdentifier":"/us/usc/t7/s1983b/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F4%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s1983b/b/4/B/ii/I","parentIdentifier":"/us/usc/t7/s1983b/b/4/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F4%2FB%2Fii%2FI","sourceRelease":"119-100","text":"to deposit, not later than 1 month after an amount is deposited pursuant to clause (i)(I), at least a 100-percent, and up to a 200-percent, match of that amount into the individual development account established for the eligible participant; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s1983b/b/4/B/ii/II","parentIdentifier":"/us/usc/t7/s1983b/b/4/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F4%2FB%2Fii%2FII","sourceRelease":"119-100","text":"with uses of funds proposed by the eligible participant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Limitation","label":"C Limitation","identifier":"/us/usc/t7/s1983b/b/4/C","parentIdentifier":"/us/usc/t7/s1983b/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F4%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t7/s1983b/b/4/C/i","parentIdentifier":"/us/usc/t7/s1983b/b/4/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F4%2FC%2Fi","sourceRelease":"119-100","text":"A qualified entity administering a demonstration program under this section may provide not more than $6,000 for each fiscal year in matching funds to the individual development account established by the qualified entity for an eligible participant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Treatment of amount","label":"ii Treatment of amount","identifier":"/us/usc/t7/s1983b/b/4/C/ii","parentIdentifier":"/us/usc/t7/s1983b/b/4/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F4%2FC%2Fii","sourceRelease":"119-100","text":"An amount provided under clause (i) shall not be considered to be a gift or loan for mortgage purposes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Eligible expenditures","label":"5 Eligible expenditures","identifier":"/us/usc/t7/s1983b/b/5","parentIdentifier":"/us/usc/t7/s1983b/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s1983b/b/5/A","parentIdentifier":"/us/usc/t7/s1983b/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F5%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1983b/b/5/A/i","parentIdentifier":"/us/usc/t7/s1983b/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F5%2FA%2Fi","sourceRelease":"119-100","text":"to purchase farmland or make a down payment on an accepted purchase offer for farmland;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1983b/b/5/A/ii","parentIdentifier":"/us/usc/t7/s1983b/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F5%2FA%2Fii","sourceRelease":"119-100","text":"to make mortgage payments on farmland purchased pursuant to clause (i), for up to 180 days after the date of the purchase;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s1983b/b/5/A/iii","parentIdentifier":"/us/usc/t7/s1983b/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F5%2FA%2Fiii","sourceRelease":"119-100","text":"to purchase breeding stock, fruit or nut trees, or trees to harvest for timber; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s1983b/b/5/A/iv","parentIdentifier":"/us/usc/t7/s1983b/b/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F5%2FA%2Fiv","sourceRelease":"119-100","text":"for other similar expenditures, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Timing","label":"B Timing","identifier":"/us/usc/t7/s1983b/b/5/B","parentIdentifier":"/us/usc/t7/s1983b/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F5%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t7/s1983b/b/5/B/i","parentIdentifier":"/us/usc/t7/s1983b/b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F5%2FB%2Fi","sourceRelease":"119-100","text":"An eligible participant may make an eligible expenditure at any time during the 2-year period beginning on the date on which the last matching funds are provided under paragraph (4)(B)(ii)(I) to the individual development account established for the eligible participant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Unexpended funds","label":"ii Unexpended funds","identifier":"/us/usc/t7/s1983b/b/5/B/ii","parentIdentifier":"/us/usc/t7/s1983b/b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fb%2F5%2FB%2Fii","sourceRelease":"119-100","text":"At the end of the period described in clause (i), any funds remaining in an individual development account established for an eligible participant shall revert to the reserve fund of the demonstration program under which the account was established.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Applications","label":"c Applications","identifier":"/us/usc/t7/s1983b/c","parentIdentifier":"/us/usc/t7/s1983b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1983b/c/1","parentIdentifier":"/us/usc/t7/s1983b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc%2F1","sourceRelease":"119-100","text":"A qualified entity that seeks to carry out a demonstration program under this section may submit to the Secretary an application at such time, in such form, and containing such information as the Secretary may prescribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Criteria","label":"2 Criteria","identifier":"/us/usc/t7/s1983b/c/2","parentIdentifier":"/us/usc/t7/s1983b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1983b/c/2/A","parentIdentifier":"/us/usc/t7/s1983b/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the degree to which the demonstration program described in the application is likely to aid eligible participants in successfully pursuing new farming opportunities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1983b/c/2/B","parentIdentifier":"/us/usc/t7/s1983b/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the experience and ability of the qualified entity to responsibly administer the demonstration program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s1983b/c/2/C","parentIdentifier":"/us/usc/t7/s1983b/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc%2F2%2FC","sourceRelease":"119-100","text":"the experience and ability of the qualified entity in recruiting, educating, and assisting eligible participants to increase economic independence and pursue or advance farming opportunities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s1983b/c/2/D","parentIdentifier":"/us/usc/t7/s1983b/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc%2F2%2FD","sourceRelease":"119-100","text":"the aggregate amount of direct funds from non-Federal public sector and private sources that are formally committed to the demonstration program as matching contributions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s1983b/c/2/E","parentIdentifier":"/us/usc/t7/s1983b/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc%2F2%2FE","sourceRelease":"119-100","text":"the adequacy of the plan of the qualified entity to provide information relevant to an evaluation of the demonstration program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t7/s1983b/c/2/F","parentIdentifier":"/us/usc/t7/s1983b/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc%2F2%2FF","sourceRelease":"119-100","text":"such other factors as the Secretary considers to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Preferences","label":"3 Preferences","identifier":"/us/usc/t7/s1983b/c/3","parentIdentifier":"/us/usc/t7/s1983b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1983b/c/3/A","parentIdentifier":"/us/usc/t7/s1983b/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc%2F3%2FA","sourceRelease":"119-100","text":"a track record of serving clients targeted by the program, including, as appropriate, socially disadvantaged farmers or ranchers (as defined in ); andsection 2003(e)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1983b/c/3/B","parentIdentifier":"/us/usc/t7/s1983b/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc%2F3%2FB","sourceRelease":"119-100","text":"expertise in dealing with financial management aspects of farming.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Approval","label":"4 Approval","identifier":"/us/usc/t7/s1983b/c/4","parentIdentifier":"/us/usc/t7/s1983b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc%2F4","sourceRelease":"119-100","text":"Not later than 1 year after the date of enactment of this section, in accordance with this section, the Secretary shall, on a competitive basis, approve such applications to conduct demonstration programs as the Secretary considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Term of authority","label":"5 Term of authority","identifier":"/us/usc/t7/s1983b/c/5","parentIdentifier":"/us/usc/t7/s1983b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fc%2F5","sourceRelease":"119-100","text":"If the Secretary approves an application to carry out a demonstration program, the Secretary shall authorize the applicant to carry out the project for a period of 5 years, plus an additional 2 years to make eligible expenditures in accordance with subsection (b)(5)(B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Grant authority","label":"d Grant authority","identifier":"/us/usc/t7/s1983b/d","parentIdentifier":"/us/usc/t7/s1983b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1983b/d/1","parentIdentifier":"/us/usc/t7/s1983b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary shall make a grant to a qualified entity authorized to carry out a demonstration program under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Maximum amount of grants","label":"2 Maximum amount of grants","identifier":"/us/usc/t7/s1983b/d/2","parentIdentifier":"/us/usc/t7/s1983b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fd%2F2","sourceRelease":"119-100","text":"The aggregate amount of grant funds provided to a demonstration program carried out under this section shall not exceed $250,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Timing of grant payments","label":"3 Timing of grant payments","identifier":"/us/usc/t7/s1983b/d/3","parentIdentifier":"/us/usc/t7/s1983b/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1983b/d/3/A","parentIdentifier":"/us/usc/t7/s1983b/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fd%2F3%2FA","sourceRelease":"119-100","text":"on the awarding of the grant; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1983b/d/3/B","parentIdentifier":"/us/usc/t7/s1983b/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fd%2F3%2FB","sourceRelease":"119-100","text":"pursuant to such payment plan as the qualified entity may specify.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Reports","label":"e Reports","identifier":"/us/usc/t7/s1983b/e","parentIdentifier":"/us/usc/t7/s1983b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Annual progress reports","label":"1 Annual progress reports","identifier":"/us/usc/t7/s1983b/e/1","parentIdentifier":"/us/usc/t7/s1983b/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s1983b/e/1/A","parentIdentifier":"/us/usc/t7/s1983b/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fe%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s1983b/e/1/A/i","parentIdentifier":"/us/usc/t7/s1983b/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fe%2F1%2FA%2Fi","sourceRelease":"119-100","text":"an evaluation of the progress of the demonstration program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s1983b/e/1/A/ii","parentIdentifier":"/us/usc/t7/s1983b/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fe%2F1%2FA%2Fii","sourceRelease":"119-100","text":"information about the demonstration program, including the eligible participants and the individual development accounts that have been established; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s1983b/e/1/A/iii","parentIdentifier":"/us/usc/t7/s1983b/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fe%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"such other information as the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Submission of reports","label":"B Submission of reports","identifier":"/us/usc/t7/s1983b/e/1/B","parentIdentifier":"/us/usc/t7/s1983b/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fe%2F1%2FB","sourceRelease":"119-100","text":"A qualified entity shall submit each report required under subparagraph (A) to the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Reports by the Secretary","label":"2 Reports by the Secretary","identifier":"/us/usc/t7/s1983b/e/2","parentIdentifier":"/us/usc/t7/s1983b/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fe%2F2","sourceRelease":"119-100","text":"Not later than 1 year after the date on which all demonstration programs under this section are concluded, the Secretary shall submit to Congress a final report that describes the results and findings of all reports and evaluations carried out under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Annual review","label":"f Annual review","identifier":"/us/usc/t7/s1983b/f","parentIdentifier":"/us/usc/t7/s1983b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s1983b/f/1","parentIdentifier":"/us/usc/t7/s1983b/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Ff%2F1","sourceRelease":"119-100","text":"to assess the financial soundness of the qualified entity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s1983b/f/2","parentIdentifier":"/us/usc/t7/s1983b/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Ff%2F2","sourceRelease":"119-100","text":"to determine the use of grant funds made available to the qualified entity under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Regulations","label":"g Regulations","identifier":"/us/usc/t7/s1983b/g","parentIdentifier":"/us/usc/t7/s1983b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s1983b/g/1","parentIdentifier":"/us/usc/t7/s1983b/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fg%2F1","sourceRelease":"119-100","text":"the termination of demonstration programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s1983b/g/2","parentIdentifier":"/us/usc/t7/s1983b/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fg%2F2","sourceRelease":"119-100","text":"control of the reserve funds in the case of such a termination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s1983b/g/3","parentIdentifier":"/us/usc/t7/s1983b/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fg%2F3","sourceRelease":"119-100","text":"transfer of demonstration programs to other qualified entities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s1983b/g/4","parentIdentifier":"/us/usc/t7/s1983b/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fg%2F4","sourceRelease":"119-100","text":"remissions from a reserve fund to the Secretary in a case in which a demonstration program is terminated without transfer to a new qualified entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Authorization of appropriations","label":"h Authorization of appropriations","identifier":"/us/usc/t7/s1983b/h","parentIdentifier":"/us/usc/t7/s1983b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1983b%2Fh","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2008 through 2023.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
