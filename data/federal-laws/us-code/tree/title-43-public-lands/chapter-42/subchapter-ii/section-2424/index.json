{"type":"section","nativeType":"section","number":"2424","heading":"Defaults","label":"2424 Defaults","identifier":"/us/usc/t43/s2424","parentIdentifier":"/us/usc/t43/ch42/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Payments by Secretary","label":"a Payments by Secretary","identifier":"/us/usc/t43/s2424/a","parentIdentifier":"/us/usc/t43/s2424","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s2424/a/1","parentIdentifier":"/us/usc/t43/s2424/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fa%2F1","sourceRelease":"119-100","text":"If a borrower defaults on the obligation, the holder of the loan guarantee shall have the right to demand payment of the unpaid amount from the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Payment required","label":"2 Payment required","identifier":"/us/usc/t43/s2424/a/2","parentIdentifier":"/us/usc/t43/s2424/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fa%2F2","sourceRelease":"119-100","text":"By such date as may be specified in the loan guarantee or related agreements, the Secretary shall pay to the holder of the loan guarantee the unpaid interest on, and unpaid principal of, the obligation with respect to which the borrower has defaulted, unless the Secretary finds that there was not default by the borrower in the payment of interest or principal or that the default has been remedied.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Forbearance","label":"3 Forbearance","identifier":"/us/usc/t43/s2424/a/3","parentIdentifier":"/us/usc/t43/s2424/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fa%2F3","sourceRelease":"119-100","text":"Nothing in this subsection precludes any forbearance by the holder of the obligation for the benefit of the non-Federal borrower that may be agreed on by the parties to the obligation and approved by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Subrogation","label":"b Subrogation","identifier":"/us/usc/t43/s2424/b","parentIdentifier":"/us/usc/t43/s2424","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s2424/b/1","parentIdentifier":"/us/usc/t43/s2424/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2424/b/1/A","parentIdentifier":"/us/usc/t43/s2424/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fb%2F1%2FA","sourceRelease":"119-100","text":"complete, maintain, operate, lease, or otherwise dispose of any property acquired pursuant to the loan guarantee or related agreements; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2424/b/1/B","parentIdentifier":"/us/usc/t43/s2424/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fb%2F1%2FB","sourceRelease":"119-100","text":"permit the non-Federal borrower, pursuant to an agreement with the Secretary, to continue to pursue the purposes of the project if the Secretary determines the purposes to be in the public interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Superiority of rights","label":"2 Superiority of rights","identifier":"/us/usc/t43/s2424/b/2","parentIdentifier":"/us/usc/t43/s2424/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fb%2F2","sourceRelease":"119-100","text":"The rights of the Secretary, with respect to any property acquired pursuant to a loan guarantee or related agreement, shall be superior to the rights of any other person with respect to the property.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Payment of principal and interest by Secretary","label":"c Payment of principal and interest by Secretary","identifier":"/us/usc/t43/s2424/c","parentIdentifier":"/us/usc/t43/s2424","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2424/c/1","parentIdentifier":"/us/usc/t43/s2424/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2424/c/1/A","parentIdentifier":"/us/usc/t43/s2424/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the non-Federal borrower is unable to meet the payments and is not in default;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2424/c/1/B","parentIdentifier":"/us/usc/t43/s2424/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fc%2F1%2FB","sourceRelease":"119-100","text":"it is in the public interest to permit the non-Federal borrower to continue to pursue the purposes of the project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t43/s2424/c/1/C","parentIdentifier":"/us/usc/t43/s2424/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fc%2F1%2FC","sourceRelease":"119-100","text":"the probable net benefit to the Federal Government in paying the principal and interest will be greater than that which would result in the event of a default;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2424/c/2","parentIdentifier":"/us/usc/t43/s2424/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fc%2F2","sourceRelease":"119-100","text":"the amount of the payment that the Secretary is authorized to pay shall be no greater than the amount of principal and interest that the non-Federal borrower is obligated to pay under the agreement being guaranteed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s2424/c/3","parentIdentifier":"/us/usc/t43/s2424/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fc%2F3","sourceRelease":"119-100","text":"the borrower agrees to reimburse the Secretary for the payment (including interest) on terms and conditions that are satisfactory to the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Action by Attorney General","label":"d Action by Attorney General","identifier":"/us/usc/t43/s2424/d","parentIdentifier":"/us/usc/t43/s2424","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Notification","label":"1 Notification","identifier":"/us/usc/t43/s2424/d/1","parentIdentifier":"/us/usc/t43/s2424/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fd%2F1","sourceRelease":"119-100","text":"If the non-Federal borrower defaults on an obligation, the Secretary shall notify the Attorney General of the default.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Recovery","label":"2 Recovery","identifier":"/us/usc/t43/s2424/d/2","parentIdentifier":"/us/usc/t43/s2424/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2424/d/2/A","parentIdentifier":"/us/usc/t43/s2424/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fd%2F2%2FA","sourceRelease":"119-100","text":"such assets of the defaulting non-Federal borrower as are associated with the obligation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2424/d/2/B","parentIdentifier":"/us/usc/t43/s2424/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2424%2Fd%2F2%2FB","sourceRelease":"119-100","text":"any other security pledged to secure the obligation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
