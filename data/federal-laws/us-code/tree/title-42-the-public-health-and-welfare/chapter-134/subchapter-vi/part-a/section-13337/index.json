{"type":"section","nativeType":"section","number":"13337","heading":"Metallurgical coal development","label":"13337 Metallurgical coal development","identifier":"/us/usc/t42/s13337","parentIdentifier":"/us/usc/t42/ch134/schVI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13337","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t42/s13337/a","parentIdentifier":"/us/usc/t42/s13337","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13337%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish a research, development, demonstration, and commercial application program on metallurgical coal utilization for the purpose of developing techniques that will lead to the greater and more efficient utilization of the Nation’s metallurgical coal resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t42/s13337/b","parentIdentifier":"/us/usc/t42/s13337","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13337%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s13337/b/1","parentIdentifier":"/us/usc/t42/s13337/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13337%2Fb%2F1","sourceRelease":"119-100","text":"as a boiler fuel for the purpose of generating steam to produce electricity, including blending metallurgical coal with other coals in order to enhance its efficient application as a boiler fuel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s13337/b/2","parentIdentifier":"/us/usc/t42/s13337/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13337%2Fb%2F2","sourceRelease":"119-100","text":"as an ingredient in the manufacturing of steel; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s13337/b/3","parentIdentifier":"/us/usc/t42/s13337/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs13337%2Fb%2F3","sourceRelease":"119-100","text":"as a source of pipeline quality coalbed methane.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
