{"type":"section","nativeType":"section","number":"7417","heading":"Referenda","label":"7417 Referenda","identifier":"/us/usc/t7/s7417","parentIdentifier":"/us/usc/t7/ch101/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Initial referendum","label":"a Initial referendum","identifier":"/us/usc/t7/s7417/a","parentIdentifier":"/us/usc/t7/s7417","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Optional referendum","label":"1 Optional referendum","identifier":"/us/usc/t7/s7417/a/1","parentIdentifier":"/us/usc/t7/s7417/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7417/a/1/A","parentIdentifier":"/us/usc/t7/s7417/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the production or handling of the agricultural commodity covered by the order; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7417/a/1/B","parentIdentifier":"/us/usc/t7/s7417/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the importation of the agricultural commodity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Procedure","label":"2 Procedure","identifier":"/us/usc/t7/s7417/a/2","parentIdentifier":"/us/usc/t7/s7417/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fa%2F2","sourceRelease":"119-100","text":"The results of the referendum shall be determined in accordance with subsection (e). The Secretary may require that the agricultural commodity industry involved post a bond or other collateral to cover the cost of the referendum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Required referenda","label":"b Required referenda","identifier":"/us/usc/t7/s7417/b","parentIdentifier":"/us/usc/t7/s7417","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s7417/b/1","parentIdentifier":"/us/usc/t7/s7417/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7417/b/1/A","parentIdentifier":"/us/usc/t7/s7417/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the production or handling of the agricultural commodity covered by the order; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7417/b/1/B","parentIdentifier":"/us/usc/t7/s7417/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the importation of the agricultural commodity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Time for referendum","label":"2 Time for referendum","identifier":"/us/usc/t7/s7417/b/2","parentIdentifier":"/us/usc/t7/s7417/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fb%2F2","sourceRelease":"119-100","text":"The referendum shall be conducted not later than 3 years after assessments first begin under the order.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Exception","label":"3 Exception","identifier":"/us/usc/t7/s7417/b/3","parentIdentifier":"/us/usc/t7/s7417/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fb%2F3","sourceRelease":"119-100","text":"This subsection shall not apply if an initial referendum was conducted under subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Subsequent referenda","label":"c Subsequent referenda","identifier":"/us/usc/t7/s7417/c","parentIdentifier":"/us/usc/t7/s7417","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7417/c/1","parentIdentifier":"/us/usc/t7/s7417/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fc%2F1","sourceRelease":"119-100","text":"not later than 7 years after assessments first begin under the order;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7417/c/2","parentIdentifier":"/us/usc/t7/s7417/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fc%2F2","sourceRelease":"119-100","text":"at the request of the board established under the order; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7417/c/3","parentIdentifier":"/us/usc/t7/s7417/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fc%2F3","sourceRelease":"119-100","text":"at the request of 10 percent or more of the number of persons eligible to vote under subsection (b)(1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Other referenda","label":"d Other referenda","identifier":"/us/usc/t7/s7417/d","parentIdentifier":"/us/usc/t7/s7417","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fd","sourceRelease":"119-100","text":"The Secretary may conduct a referendum at any time to determine whether the continuation, suspension, or termination of the order or a provision of the order is favored by persons eligible to vote under subsection (b)(1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Approval of order","label":"e Approval of order","identifier":"/us/usc/t7/s7417/e","parentIdentifier":"/us/usc/t7/s7417","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s7417/e/1","parentIdentifier":"/us/usc/t7/s7417/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fe%2F1","sourceRelease":"119-100","text":"by a majority of those persons voting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s7417/e/2","parentIdentifier":"/us/usc/t7/s7417/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fe%2F2","sourceRelease":"119-100","text":"by persons voting for approval who represent a majority of the volume of the agricultural commodity; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s7417/e/3","parentIdentifier":"/us/usc/t7/s7417/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fe%2F3","sourceRelease":"119-100","text":"by a majority of those persons voting for approval who also represent a majority of the volume of the agricultural commodity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Costs of referenda","label":"f Costs of referenda","identifier":"/us/usc/t7/s7417/f","parentIdentifier":"/us/usc/t7/s7417","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Ff","sourceRelease":"119-100","text":"The board established under an order with respect to which a referendum is conducted under this section shall reimburse the Secretary for any expenses incurred by the Secretary to conduct the referendum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Manner of conducting referenda","label":"g Manner of conducting referenda","identifier":"/us/usc/t7/s7417/g","parentIdentifier":"/us/usc/t7/s7417","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s7417/g/1","parentIdentifier":"/us/usc/t7/s7417/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fg%2F1","sourceRelease":"119-100","text":"A referendum conducted under this section shall be conducted in the manner determined by the Secretary to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Advance registration","label":"2 Advance registration","identifier":"/us/usc/t7/s7417/g/2","parentIdentifier":"/us/usc/t7/s7417/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fg%2F2","sourceRelease":"119-100","text":"If the Secretary determines that an advance registration of eligible voters in a referendum is necessary before the voting period in order to facilitate the conduct of the referendum, the Secretary may institute the advance registration procedures by mail, or in person through the use of national and local offices of the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Voting","label":"3 Voting","identifier":"/us/usc/t7/s7417/g/3","parentIdentifier":"/us/usc/t7/s7417/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fg%2F3","sourceRelease":"119-100","text":"Eligible voters may vote by mail ballot in the referendum or in person if so prescribed by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Notice","label":"4 Notice","identifier":"/us/usc/t7/s7417/g/4","parentIdentifier":"/us/usc/t7/s7417/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7417%2Fg%2F4","sourceRelease":"119-100","text":"Not later than 30 days before a referendum is conducted under this section with respect to an order, the Secretary shall notify the agricultural commodity industry involved, in such manner as determined by the Secretary, of the period during which voting in the referendum will occur. The notice shall explain any registration and voting procedures established under this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
