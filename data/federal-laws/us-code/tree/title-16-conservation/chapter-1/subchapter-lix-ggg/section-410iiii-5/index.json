{"type":"section","nativeType":"section","number":"410iiii–5","heading":"Establishment of the Brown v. Board of Education affiliated areas","label":"410iiii–5 Establishment of the Brown v. Board of Education affiliated areas","identifier":"/us/usc/t16/s410iiii–5","parentIdentifier":"/us/usc/t16/ch1/schLIX–GGG","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsA prior was renumbered section 107 and is classified to .section 106 of Pub. L. 102–525section 410iiii–6 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s410iiii–5/a","parentIdentifier":"/us/usc/t16/s410iiii–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410iiii–5/a/1","parentIdentifier":"/us/usc/t16/s410iiii–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fa%2F1","sourceRelease":"119-100","text":"The Robert Russa Moton Museum in Farmville, Virginia.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410iiii–5/a/2","parentIdentifier":"/us/usc/t16/s410iiii–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410iiii–5/a/2/A","parentIdentifier":"/us/usc/t16/s410iiii–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the former Howard High School in Wilmington, Delaware;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410iiii–5/a/2/B","parentIdentifier":"/us/usc/t16/s410iiii–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fa%2F2%2FB","sourceRelease":"119-100","text":"Claymont High School in Claymont, Delaware; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s410iiii–5/a/2/C","parentIdentifier":"/us/usc/t16/s410iiii–5/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fa%2F2%2FC","sourceRelease":"119-100","text":"Hockessin Colored School #107 in Hockessin, Delaware.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s410iiii–5/a/3","parentIdentifier":"/us/usc/t16/s410iiii–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fa%2F3","sourceRelease":"119-100","text":"The John Philip Sousa Middle School in the District of Columbia.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Administration","label":"b Administration","identifier":"/us/usc/t16/s410iiii–5/b","parentIdentifier":"/us/usc/t16/s410iiii–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410iiii–5/b/1","parentIdentifier":"/us/usc/t16/s410iiii–5/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fb%2F1","sourceRelease":"119-100","text":"this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410iiii–5/b/2","parentIdentifier":"/us/usc/t16/s410iiii–5/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fb%2F2","sourceRelease":"119-100","text":"the laws generally applicable to units of the National Park System.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Management plans","label":"c Management plans","identifier":"/us/usc/t16/s410iiii–5/c","parentIdentifier":"/us/usc/t16/s410iiii–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s410iiii–5/c/1","parentIdentifier":"/us/usc/t16/s410iiii–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary, in consultation with the management entity for the applicable affiliated area, shall develop a management plan for each affiliated area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t16/s410iiii–5/c/2","parentIdentifier":"/us/usc/t16/s410iiii–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410iiii–5/c/2/A","parentIdentifier":"/us/usc/t16/s410iiii–5/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fc%2F2%2FA","sourceRelease":"119-100","text":"be prepared in consultation and coordination with interested State, county, and local governments, management entities, organizations, and interested members of the public associated with the affiliated area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410iiii–5/c/2/B","parentIdentifier":"/us/usc/t16/s410iiii–5/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fc%2F2%2FB","sourceRelease":"119-100","text":"identify, as appropriate, the roles and responsibilities of the National Park Service and the management entity in administering and interpreting the affiliated area in a manner that does not interfere with existing operations and continued use of existing facilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s410iiii–5/c/2/C","parentIdentifier":"/us/usc/t16/s410iiii–5/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fc%2F2%2FC","sourceRelease":"119-100","text":"require the Secretary to coordinate the preparation and implementation of the management plan and interpretation of the affiliated area with the historical park.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Public comment","label":"3 Public comment","identifier":"/us/usc/t16/s410iiii–5/c/3","parentIdentifier":"/us/usc/t16/s410iiii–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410iiii–5/c/3/A","parentIdentifier":"/us/usc/t16/s410iiii–5/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fc%2F3%2FA","sourceRelease":"119-100","text":"hold not less than 1 public meeting in the general proximity of each affiliated area on the proposed management plan, which shall include opportunities for public comment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410iiii–5/c/3/B","parentIdentifier":"/us/usc/t16/s410iiii–5/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s410iiii–5/c/3/B/i","parentIdentifier":"/us/usc/t16/s410iiii–5/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":"publish the draft management plan on the internet; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s410iiii–5/c/3/B/ii","parentIdentifier":"/us/usc/t16/s410iiii–5/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":"provide an opportunity for public comment on the draft management plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Submission","label":"4 Submission","identifier":"/us/usc/t16/s410iiii–5/c/4","parentIdentifier":"/us/usc/t16/s410iiii–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fc%2F4","sourceRelease":"119-100","text":"Not later than 3 years after the date on which funds are made available to carry out this section, the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives the management plan for each affiliated area developed under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Cooperative agreements","label":"d Cooperative agreements","identifier":"/us/usc/t16/s410iiii–5/d","parentIdentifier":"/us/usc/t16/s410iiii–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fd","sourceRelease":"119-100","text":"The Secretary may provide technical and financial assistance to, and enter into cooperative agreements with, the management entity for each affiliated area to provide financial assistance for the marketing, marking, interpretation, and preservation of the applicable affiliated area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Land use","label":"e Land use","identifier":"/us/usc/t16/s410iiii–5/e","parentIdentifier":"/us/usc/t16/s410iiii–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410iiii–5/e/1","parentIdentifier":"/us/usc/t16/s410iiii–5/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fe%2F1","sourceRelease":"119-100","text":"land use rights of private property owners within or adjacent to an affiliated area, including activities or uses on private land that can be seen or heard within an affiliated area; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410iiii–5/e/2","parentIdentifier":"/us/usc/t16/s410iiii–5/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Fe%2F2","sourceRelease":"119-100","text":"the authority of management entities to operate and administer the affiliated areas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Limited role of the Secretary","label":"f Limited role of the Secretary","identifier":"/us/usc/t16/s410iiii–5/f","parentIdentifier":"/us/usc/t16/s410iiii–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s410iiii–5/f/1","parentIdentifier":"/us/usc/t16/s410iiii–5/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s410iiii–5/f/1/A","parentIdentifier":"/us/usc/t16/s410iiii–5/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Ff%2F1%2FA","sourceRelease":"119-100","text":"to acquire land in an affiliated area; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s410iiii–5/f/1/B","parentIdentifier":"/us/usc/t16/s410iiii–5/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Ff%2F1%2FB","sourceRelease":"119-100","text":"to assume financial responsibility for the operation, maintenance, or management of an affiliated area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Ownership","label":"2 Ownership","identifier":"/us/usc/t16/s410iiii–5/f/2","parentIdentifier":"/us/usc/t16/s410iiii–5/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410iiii%E2%80%935%2Ff%2F2","sourceRelease":"119-100","text":"Each affiliated area shall continue to be owned, operated, and managed by the applicable public or private owner of the land in the affiliated area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
