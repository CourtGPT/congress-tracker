{"type":"section","nativeType":"section","number":"4508","heading":"Limitation of awards during a Presidential election year","label":"4508 Limitation of awards during a Presidential election year","identifier":"/us/usc/t5/s4508","parentIdentifier":"/us/usc/t5/ptIII/sptC/ch45/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs4508","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s4508/a","parentIdentifier":"/us/usc/t5/s4508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs4508%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s4508/a/1","parentIdentifier":"/us/usc/t5/s4508/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs4508%2Fa%2F1","sourceRelease":"119-100","text":"“Presidential election period” means any period beginning on June 1 in a calendar year in which the popular election of the President occurs, and ending on January 20 following the date of such election; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s4508/a/2","parentIdentifier":"/us/usc/t5/s4508/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs4508%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s4508/a/2/A","parentIdentifier":"/us/usc/t5/s4508/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs4508%2Fa%2F2%2FA","sourceRelease":"119-100","text":"in a Senior Executive Service position and is not a career appointee as defined under section 3132(a)(4); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s4508/a/2/B","parentIdentifier":"/us/usc/t5/s4508/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs4508%2Fa%2F2%2FB","sourceRelease":"119-100","text":"in a position of a confidential or policy-determining character under schedule C of subpart C of part 213 of title 5 of the Code of Federal Regulations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s4508/b","parentIdentifier":"/us/usc/t5/s4508","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs4508%2Fb","sourceRelease":"119-100","text":"No senior politically appointed officer may receive an award under the provisions of this subchapter during a Presidential election period.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
