{"type":"section","nativeType":"section","number":"8308","heading":"Memorandum","label":"8308 Memorandum","identifier":"/us/usc/t15/s8308","parentIdentifier":"/us/usc/t15/ch109/schI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8308","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t15/s8308/a","parentIdentifier":"/us/usc/t15/s8308","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8308%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8308/a/1","parentIdentifier":"/us/usc/t15/s8308/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8308%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8308/a/1/A","parentIdentifier":"/us/usc/t15/s8308/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8308%2Fa%2F1%2FA","sourceRelease":"119-100","text":"applying their respective authorities in a manner so as to ensure effective and efficient regulation in the public interest;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8308/a/1/B","parentIdentifier":"/us/usc/t15/s8308/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8308%2Fa%2F1%2FB","sourceRelease":"119-100","text":"resolving conflicts concerning overlapping jurisdiction between the 2 agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s8308/a/1/C","parentIdentifier":"/us/usc/t15/s8308/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8308%2Fa%2F1%2FC","sourceRelease":"119-100","text":"avoiding, to the extent possible, conflicting or duplicative regulation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8308/a/2","parentIdentifier":"/us/usc/t15/s8308/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8308%2Fa%2F2","sourceRelease":"119-100","text":"Such memorandum and any subsequent amendments to the memorandum shall be promptly submitted to the appropriate committees of Congress.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t15/s8308/b","parentIdentifier":"/us/usc/t15/s8308","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8308%2Fb","sourceRelease":"119-100","text":"The Commodity Futures Trading Commission and the Federal Energy Regulatory Commission shall, not later than 180 days after , negotiate a memorandum of understanding to share information that may be requested where either Commission is conducting an investigation into potential manipulation, fraud, or market power abuse in markets subject to such Commission’s regulation or oversight. Shared information shall remain subject to the same restrictions on disclosure applicable to the Commission initially holding the information.July 21, 2010","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
