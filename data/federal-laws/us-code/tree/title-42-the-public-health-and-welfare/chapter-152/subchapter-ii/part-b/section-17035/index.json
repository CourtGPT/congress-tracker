{"type":"section","nativeType":"section","number":"17035","heading":"University based research and development grant program","label":"17035 University based research and development grant program","identifier":"/us/usc/t42/s17035","parentIdentifier":"/us/usc/t42/ch152/schII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17035","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t42/s17035/a","parentIdentifier":"/us/usc/t42/s17035","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17035%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish a competitive grant program, in a geographically diverse manner, for projects submitted for consideration by institutions of higher education to conduct research and development of renewable energy technologies. Each grant made shall not exceed $2,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Eligibility","label":"b Eligibility","identifier":"/us/usc/t42/s17035/b","parentIdentifier":"/us/usc/t42/s17035","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17035%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17035/b/1","parentIdentifier":"/us/usc/t42/s17035/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17035%2Fb%2F1","sourceRelease":"119-100","text":"established programs of research in renewable energy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17035/b/2","parentIdentifier":"/us/usc/t42/s17035/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17035%2Fb%2F2","sourceRelease":"119-100","text":"locations that are low income or outside of an urbanized area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17035/b/3","parentIdentifier":"/us/usc/t42/s17035/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17035%2Fb%2F3","sourceRelease":"119-100","text":"a joint venture with an Indian tribe; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17035/b/4","parentIdentifier":"/us/usc/t42/s17035/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17035%2Fb%2F4","sourceRelease":"119-100","text":"proximity to trees dying of disease or insect infestation as a source of woody biomass.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t42/s17035/c","parentIdentifier":"/us/usc/t42/s17035","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17035%2Fc","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Secretary $25,000,000 for carrying out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definitions","label":"d Definitions","identifier":"/us/usc/t42/s17035/d","parentIdentifier":"/us/usc/t42/s17035","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17035%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Indian tribe","label":"1 Indian tribe","identifier":"/us/usc/t42/s17035/d/1","parentIdentifier":"/us/usc/t42/s17035/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17035%2Fd%2F1","sourceRelease":"119-100","text":"The term “Indian tribe” has the meaning as defined in .section 15823(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Renewable energy","label":"2 Renewable energy","identifier":"/us/usc/t42/s17035/d/2","parentIdentifier":"/us/usc/t42/s17035/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17035%2Fd%2F2","sourceRelease":"119-100","text":"The term “renewable energy” has the meaning as defined in .section 16181 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Urbanized area","label":"3 Urbanized area","identifier":"/us/usc/t42/s17035/d/3","parentIdentifier":"/us/usc/t42/s17035/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17035%2Fd%2F3","sourceRelease":"119-100","text":"The term “urbanized area” has the meaning as defined by the U.S. Bureau of the Census.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
