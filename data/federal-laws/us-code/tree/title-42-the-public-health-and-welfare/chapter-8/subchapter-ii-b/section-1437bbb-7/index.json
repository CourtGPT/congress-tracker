{"type":"section","nativeType":"section","number":"1437bbb–7","heading":"Accountability","label":"1437bbb–7 Accountability","identifier":"/us/usc/t42/s1437bbb–7","parentIdentifier":"/us/usc/t42/ch8/schII–B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437bbb%E2%80%937","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Maintenance of records","label":"a Maintenance of records","identifier":"/us/usc/t42/s1437bbb–7/a","parentIdentifier":"/us/usc/t42/s1437bbb–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437bbb%E2%80%937%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s1437bbb–7/a/1","parentIdentifier":"/us/usc/t42/s1437bbb–7/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437bbb%E2%80%937%2Fa%2F1","sourceRelease":"119-100","text":"document the amounts received by the jurisdiction under this chapter and the disposition of such amounts under the demonstration program under this subchapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s1437bbb–7/a/2","parentIdentifier":"/us/usc/t42/s1437bbb–7/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437bbb%E2%80%937%2Fa%2F2","sourceRelease":"119-100","text":"ensure compliance by the jurisdiction with this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s1437bbb–7/a/3","parentIdentifier":"/us/usc/t42/s1437bbb–7/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437bbb%E2%80%937%2Fa%2F3","sourceRelease":"119-100","text":"evaluate the performance of the jurisdiction under the demonstration program under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Reports","label":"b Reports","identifier":"/us/usc/t42/s1437bbb–7/b","parentIdentifier":"/us/usc/t42/s1437bbb–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437bbb%E2%80%937%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s1437bbb–7/b/1","parentIdentifier":"/us/usc/t42/s1437bbb–7/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437bbb%E2%80%937%2Fb%2F1","sourceRelease":"119-100","text":"documentation of the use of amounts made available to the jurisdiction under this subchapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s1437bbb–7/b/2","parentIdentifier":"/us/usc/t42/s1437bbb–7/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437bbb%E2%80%937%2Fb%2F2","sourceRelease":"119-100","text":"any information as the Secretary may request to assist the Secretary in evaluating the demonstration program under this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s1437bbb–7/b/3","parentIdentifier":"/us/usc/t42/s1437bbb–7/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437bbb%E2%80%937%2Fb%2F3","sourceRelease":"119-100","text":"a description and analysis of the effect of assisted activities in addressing the objectives of the demonstration program under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Access to documents by Secretary and Comptroller General","label":"c Access to documents by Secretary and Comptroller General","identifier":"/us/usc/t42/s1437bbb–7/c","parentIdentifier":"/us/usc/t42/s1437bbb–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437bbb%E2%80%937%2Fc","sourceRelease":"119-100","text":"The Secretary and the Comptroller General of the United States, or any duly authorized representative of the Secretary or the Comptroller General, shall have access for the purpose of audit and examination to any books, documents, papers, and records maintained by a participating jurisdiction that relate to the demonstration program under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Performance review and evaluation","label":"d Performance review and evaluation","identifier":"/us/usc/t42/s1437bbb–7/d","parentIdentifier":"/us/usc/t42/s1437bbb–7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437bbb%E2%80%937%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Performance review","label":"1 Performance review","identifier":"/us/usc/t42/s1437bbb–7/d/1","parentIdentifier":"/us/usc/t42/s1437bbb–7/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437bbb%E2%80%937%2Fd%2F1","sourceRelease":"119-100","text":"Based on the performance standards established under , the Secretary shall monitor the performance of participating jurisdictions in providing assistance under this subchapter.section 1437bbb–5(b)(4) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Status report","label":"2 Status report","identifier":"/us/usc/t42/s1437bbb–7/d/2","parentIdentifier":"/us/usc/t42/s1437bbb–7/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1437bbb%E2%80%937%2Fd%2F2","sourceRelease":"119-100","text":"Not later than 60 days after the conclusion of the second year of the demonstration program under this subchapter, the Secretary shall submit to Congress an interim report on the status of the demonstration program and the progress each participating jurisdiction in achieving the purposes of the demonstration program under .section 1437bbb of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
