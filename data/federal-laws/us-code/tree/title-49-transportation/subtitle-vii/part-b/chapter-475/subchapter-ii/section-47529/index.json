{"type":"section","nativeType":"section","number":"47529","heading":"Nonaddition rule","label":"47529 Nonaddition rule","identifier":"/us/usc/t49/s47529","parentIdentifier":"/us/usc/t49/stVII/ptB/ch475/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs47529","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevisedSectionSource (U.S. Code)Source (Statutes at Large)4752949 App.:2158., , ; , , .Nov. 5, 1990Oct. 31, 1992Pub. L. 101–508, § 9309104 Stat. 1388–384Pub. L. 102–581, § 136(b)106 Stat. 4889"],"amendments":["Historical and Revision NotesRevisedSectionSource (U.S. Code)Source (Statutes at Large)4752949 App.:2158., , ; , , .Nov. 5, 1990Oct. 31, 1992Pub. L. 101–508, § 9309104 Stat. 1388–384Pub. L. 102–581, § 136(b)106 Stat. 4889"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—General Limitations","label":"a .—General Limitations","identifier":"/us/usc/t49/s47529/a","parentIdentifier":"/us/usc/t49/s47529","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs47529%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s47529/a/1","parentIdentifier":"/us/usc/t49/s47529/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs47529%2Fa%2F1","sourceRelease":"119-100","text":"complies with the stage 3 noise levels; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s47529/a/2","parentIdentifier":"/us/usc/t49/s47529/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs47529%2Fa%2F2","sourceRelease":"119-100","text":"was purchased by the person importing the aircraft into the United States under a legally binding contract made before .November 5, 1990","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Exemptions","label":"b .—Exemptions","identifier":"/us/usc/t49/s47529/b","parentIdentifier":"/us/usc/t49/s47529","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs47529%2Fb","sourceRelease":"119-100","text":"The Secretary of Transportation may provide an exemption from subsection (a) of this section to permit a person to obtain modifications to an aircraft to meet the stage 3 noise levels.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Aircraft Deemed Not Imported","label":"c .—Aircraft Deemed Not Imported","identifier":"/us/usc/t49/s47529/c","parentIdentifier":"/us/usc/t49/s47529","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs47529%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s47529/c/1","parentIdentifier":"/us/usc/t49/s47529/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs47529%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s47529/c/1/A","parentIdentifier":"/us/usc/t49/s47529/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs47529%2Fc%2F1%2FA","sourceRelease":"119-100","text":"a corporation, trust, or partnership organized under the laws of the United States or a State (including the District of Columbia);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s47529/c/1/B","parentIdentifier":"/us/usc/t49/s47529/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs47529%2Fc%2F1%2FB","sourceRelease":"119-100","text":"an individual who is a citizen of the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s47529/c/1/C","parentIdentifier":"/us/usc/t49/s47529/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs47529%2Fc%2F1%2FC","sourceRelease":"119-100","text":"an entity that is owned or controlled by a corporation, trust, partnership, or individual described in subclause (A) or (B) of this clause; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s47529/c/2","parentIdentifier":"/us/usc/t49/s47529/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs47529%2Fc%2F2","sourceRelease":"119-100","text":"enters the United States not later than 6 months after the expiration of a lease agreement (including any extension) between an owner described in clause (1) of this subsection and a foreign carrier.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
