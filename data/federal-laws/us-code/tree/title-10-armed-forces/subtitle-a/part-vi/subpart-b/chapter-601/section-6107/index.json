{"type":"section","nativeType":"section","number":"6107","heading":"Establishment of Center for Security Technology, Analysis, Response, and Testing","label":"6107 Establishment of Center for Security Technology, Analysis, Response, and Testing","identifier":"/us/usc/t10/s6107","parentIdentifier":"/us/usc/t10/stA/ptVI/sptB/ch601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6107","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsProvisions similar to those in this section were contained in , War and National Defense, prior to repeal by .section 2515 of Title 50Pub. L. 119–60, § 3111(b)(2)"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t10/s6107/a","parentIdentifier":"/us/usc/t10/s6107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6107%2Fa","sourceRelease":"119-100","text":"The Administrator for Nuclear Security shall establish within the nuclear security enterprise a Center for Security Technology, Analysis, Response, and Testing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Duties","label":"b .—Duties","identifier":"/us/usc/t10/s6107/b","parentIdentifier":"/us/usc/t10/s6107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6107%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6107/b/1","parentIdentifier":"/us/usc/t10/s6107/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6107%2Fb%2F1","sourceRelease":"119-100","text":"Provide to the Administrator, the Chief of Defense Nuclear Security, and the management and operating contractors of the nuclear security enterprise a wide range of objective expertise on security technologies, systems, analysis, testing, and response forces.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6107/b/2","parentIdentifier":"/us/usc/t10/s6107/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6107%2Fb%2F2","sourceRelease":"119-100","text":"Assist the Administrator in developing standards, requirements, analysis methods, and testing criteria with respect to security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s6107/b/3","parentIdentifier":"/us/usc/t10/s6107/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6107%2Fb%2F3","sourceRelease":"119-100","text":"Collect, analyze, and distribute lessons learned with respect to security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s6107/b/4","parentIdentifier":"/us/usc/t10/s6107/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6107%2Fb%2F4","sourceRelease":"119-100","text":"Support inspections and oversight activities with respect to security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s6107/b/5","parentIdentifier":"/us/usc/t10/s6107/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6107%2Fb%2F5","sourceRelease":"119-100","text":"Promote professional development and training for security professionals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t10/s6107/b/6","parentIdentifier":"/us/usc/t10/s6107/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6107%2Fb%2F6","sourceRelease":"119-100","text":"Provide for advance and bulk procurement for security-related acquisitions that affect multiple facilities of the nuclear security enterprise.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t10/s6107/b/7","parentIdentifier":"/us/usc/t10/s6107/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6107%2Fb%2F7","sourceRelease":"119-100","text":"Advocate for continual improvement and security excellence throughout the nuclear security enterprise.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t10/s6107/b/8","parentIdentifier":"/us/usc/t10/s6107/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6107%2Fb%2F8","sourceRelease":"119-100","text":"Such other duties as the Administrator may assign.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
