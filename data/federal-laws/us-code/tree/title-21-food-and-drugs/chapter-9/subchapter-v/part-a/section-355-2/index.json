{"type":"section","nativeType":"section","number":"355–2","heading":"Actions for delays of generic drugs and biosimilar biological products","label":"355–2 Actions for delays of generic drugs and biosimilar biological products","identifier":"/us/usc/t21/s355–2","parentIdentifier":"/us/usc/t21/ch9/schV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Further Consolidated Appropriations Act, 2020, and not as part of the Federal Food, Drug, and Cosmetic Act which comprises this chapter.Section is comprised of . Subsecs. (d) and (f) of amended .section 610 of Pub. L. 116–94section 610 of Pub. L. 116–94section 355–1 of this title"],"amendments":["CodificationSection was enacted as part of the Further Consolidated Appropriations Act, 2020, and not as part of the Federal Food, Drug, and Cosmetic Act which comprises this chapter.Section is comprised of . Subsecs. (d) and (f) of amended .section 610 of Pub. L. 116–94section 610 of Pub. L. 116–94section 355–1 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t21/s355–2/a","parentIdentifier":"/us/usc/t21/s355–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s355–2/a/1","parentIdentifier":"/us/usc/t21/s355–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s355–2/a/1/A","parentIdentifier":"/us/usc/t21/s355–2/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F1%2FA","sourceRelease":"119-100","text":"a nondiscriminatory price for the sale of the covered product at or below, but not greater than, the most recent wholesale acquisition cost for the drug, as defined in ;section 1395w–3a(c)(6)(B) of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s355–2/a/1/B","parentIdentifier":"/us/usc/t21/s355–2/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F1%2FB","sourceRelease":"119-100","text":"a schedule for delivery that results in the transfer of the covered product to the eligible product developer consistent with the timing under subsection (b)(2)(A)(iv); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t21/s355–2/a/1/C","parentIdentifier":"/us/usc/t21/s355–2/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F1%2FC","sourceRelease":"119-100","text":"no additional conditions are imposed on the sale of the covered product;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s355–2/a/2","parentIdentifier":"/us/usc/t21/s355–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s355–2/a/2/A","parentIdentifier":"/us/usc/t21/s355–2/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s355–2/a/2/A/i","parentIdentifier":"/us/usc/t21/s355–2/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"any drug approved under subsection (c) or (j) of or biological product licensed under subsection (a) or (k) of ;section 355 of this titlesection 262 of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s355–2/a/2/A/ii","parentIdentifier":"/us/usc/t21/s355–2/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"any combination of a drug or biological product described in clause (i); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t21/s355–2/a/2/A/iii","parentIdentifier":"/us/usc/t21/s355–2/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"when reasonably necessary to support approval of an application under , or , as applicable, or otherwise meet the requirements for approval under either such section, any product, including any device, that is marketed or intended for use with such a drug or biological product; andsection 355 of this titlesection 262 of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s355–2/a/2/B","parentIdentifier":"/us/usc/t21/s355–2/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s355–2/a/2/B/i","parentIdentifier":"/us/usc/t21/s355–2/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the drug or biological product has been on the drug shortage list in effect under such continuously for more than 6 months; orsection 356e of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s355–2/a/2/B/ii","parentIdentifier":"/us/usc/t21/s355–2/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the Secretary determines that inclusion of the drug or biological product as a covered product is likely to contribute to alleviating or preventing a shortage.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t21/s355–2/a/3","parentIdentifier":"/us/usc/t21/s355–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F3","sourceRelease":"119-100","text":"the term “device” has the meaning given the term in ;section 321 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t21/s355–2/a/4","parentIdentifier":"/us/usc/t21/s355–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F4","sourceRelease":"119-100","text":"the term “eligible product developer” means a person that seeks to develop a product for approval pursuant to an application for approval under subsection (b)(2) or (j) of or for licensing pursuant to an application under ;section 355 of this titlesection 262(k) of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t21/s355–2/a/5","parentIdentifier":"/us/usc/t21/s355–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F5","sourceRelease":"119-100","text":"the term “license holder” means the holder of an application approved under subsection (c) or (j) of or the holder of a license under subsection (a) or (k) of for a covered product;section 355 of this titlesection 262 of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t21/s355–2/a/6","parentIdentifier":"/us/usc/t21/s355–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F6","sourceRelease":"119-100","text":"the term “REMS” means a risk evaluation and mitigation strategy under ;section 355–1 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t21/s355–2/a/7","parentIdentifier":"/us/usc/t21/s355–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F7","sourceRelease":"119-100","text":"the term “REMS with ETASU” means a REMS that contains elements to assure safe use under ;section 355–1(f) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t21/s355–2/a/8","parentIdentifier":"/us/usc/t21/s355–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F8","sourceRelease":"119-100","text":"the term “Secretary” means the Secretary of Health and Human Services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t21/s355–2/a/9","parentIdentifier":"/us/usc/t21/s355–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F9","sourceRelease":"119-100","text":"the term “single, shared system of elements to assure safe use” means a single, shared system of elements to assure safe use under ; andsection 355–1(f) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t21/s355–2/a/10","parentIdentifier":"/us/usc/t21/s355–2/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F10","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s355–2/a/10/A","parentIdentifier":"/us/usc/t21/s355–2/a/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F10%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s355–2/a/10/A/i","parentIdentifier":"/us/usc/t21/s355–2/a/10/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F10%2FA%2Fi","sourceRelease":"119-100","text":"subsection (b)(2) or (j) of ; orsection 355 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s355–2/a/10/A/ii","parentIdentifier":"/us/usc/t21/s355–2/a/10/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F10%2FA%2Fii","sourceRelease":"119-100","text":"; andsection 262(k) of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s355–2/a/10/B","parentIdentifier":"/us/usc/t21/s355–2/a/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fa%2F10%2FB","sourceRelease":"119-100","text":"fulfill any regulatory requirements relating to approval of such an application.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Civil action for failure to provide sufficient quantities of a covered product","label":"b Civil action for failure to provide sufficient quantities of a covered product","identifier":"/us/usc/t21/s355–2/b","parentIdentifier":"/us/usc/t21/s355–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t21/s355–2/b/1","parentIdentifier":"/us/usc/t21/s355–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F1","sourceRelease":"119-100","text":"An eligible product developer may bring a civil action against the license holder for a covered product seeking relief under this subsection in an appropriate district court of the United States alleging that the license holder has declined to provide sufficient quantities of the covered product to the eligible product developer on commercially reasonable, market-based terms.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Elements","label":"2 Elements","identifier":"/us/usc/t21/s355–2/b/2","parentIdentifier":"/us/usc/t21/s355–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t21/s355–2/b/2/A","parentIdentifier":"/us/usc/t21/s355–2/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s355–2/b/2/A/i","parentIdentifier":"/us/usc/t21/s355–2/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t21/s355–2/b/2/A/i/I","parentIdentifier":"/us/usc/t21/s355–2/b/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fi%2FI","sourceRelease":"119-100","text":"the covered product is not subject to a REMS with ETASU; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t21/s355–2/b/2/A/i/II","parentIdentifier":"/us/usc/t21/s355–2/b/2/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fi%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t21/s355–2/b/2/A/i/II/aa","parentIdentifier":"/us/usc/t21/s355–2/b/2/A/i/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fi%2FII%2Faa","sourceRelease":"119-100","text":"the eligible product developer has obtained a covered product authorization from the Secretary in accordance with subparagraph (B); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t21/s355–2/b/2/A/i/II/bb","parentIdentifier":"/us/usc/t21/s355–2/b/2/A/i/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fi%2FII%2Fbb","sourceRelease":"119-100","text":"the eligible product developer has provided a copy of the covered product authorization to the license holder;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s355–2/b/2/A/ii","parentIdentifier":"/us/usc/t21/s355–2/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"that, as of the date on which the civil action is filed, the eligible product developer has not obtained sufficient quantities of the covered product on commercially reasonable, market-based terms;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t21/s355–2/b/2/A/iii","parentIdentifier":"/us/usc/t21/s355–2/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t21/s355–2/b/2/A/iii/I","parentIdentifier":"/us/usc/t21/s355–2/b/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"was sent to a named corporate officer of the license holder;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t21/s355–2/b/2/A/iii/II","parentIdentifier":"/us/usc/t21/s355–2/b/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"was made by certified or registered mail with return receipt requested;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t21/s355–2/b/2/A/iii/III","parentIdentifier":"/us/usc/t21/s355–2/b/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fiii%2FIII","sourceRelease":"119-100","text":"specified an individual as the point of contact for the license holder to direct communications related to the sale of the covered product to the eligible product developer and a means for electronic and written communications with that individual; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t21/s355–2/b/2/A/iii/IV","parentIdentifier":"/us/usc/t21/s355–2/b/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fiii%2FIV","sourceRelease":"119-100","text":"specified an address to which the covered product was to be shipped upon reaching an agreement to transfer the covered product; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t21/s355–2/b/2/A/iv","parentIdentifier":"/us/usc/t21/s355–2/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fiv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t21/s355–2/b/2/A/iv/I","parentIdentifier":"/us/usc/t21/s355–2/b/2/A/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fiv%2FI","sourceRelease":"119-100","text":"for a covered product that is not subject to a REMS with ETASU, by the date that is 31 days after the date on which the license holder received the request for the covered product; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t21/s355–2/b/2/A/iv/II","parentIdentifier":"/us/usc/t21/s355–2/b/2/A/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fiv%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t21/s355–2/b/2/A/iv/II/aa","parentIdentifier":"/us/usc/t21/s355–2/b/2/A/iv/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fiv%2FII%2Faa","sourceRelease":"119-100","text":"the date on which the license holder received the request for the covered product; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t21/s355–2/b/2/A/iv/II/bb","parentIdentifier":"/us/usc/t21/s355–2/b/2/A/iv/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FA%2Fiv%2FII%2Fbb","sourceRelease":"119-100","text":"the date on which the license holder received a copy of the covered product authorization issued by the Secretary in accordance with subparagraph (B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Authorization for covered product subject to a REMS with ETASU","label":"B Authorization for covered product subject to a REMS with ETASU","identifier":"/us/usc/t21/s355–2/b/2/B","parentIdentifier":"/us/usc/t21/s355–2/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"Request","label":"i Request","identifier":"/us/usc/t21/s355–2/b/2/B/i","parentIdentifier":"/us/usc/t21/s355–2/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"An eligible product developer may submit to the Secretary a written request for the eligible product developer to be authorized to obtain sufficient quantities of an individual covered product subject to a REMS with ETASU.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Authorization","label":"ii Authorization","identifier":"/us/usc/t21/s355–2/b/2/B/ii","parentIdentifier":"/us/usc/t21/s355–2/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t21/s355–2/b/2/B/ii/I","parentIdentifier":"/us/usc/t21/s355–2/b/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FB%2Fii%2FI","sourceRelease":"119-100","text":"development and testing that does not involve human clinical trials, if the eligible product developer has agreed to comply with any conditions the Secretary determines necessary; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t21/s355–2/b/2/B/ii/II","parentIdentifier":"/us/usc/t21/s355–2/b/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FB%2Fii%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t21/s355–2/b/2/B/ii/II/aa","parentIdentifier":"/us/usc/t21/s355–2/b/2/B/ii/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FB%2Fii%2FII%2Faa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subitem","nativeType":"subitem","number":"AA","heading":null,"label":"AA","identifier":"/us/usc/t21/s355–2/b/2/B/ii/II/aa/AA","parentIdentifier":"/us/usc/t21/s355–2/b/2/B/ii/II/aa","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FB%2Fii%2FII%2Faa%2FAA","sourceRelease":"119-100","text":"submitted protocols, informed consent documents, and informational materials for testing that include protections that provide safety protections comparable to those provided by the REMS for the covered product; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subitem","nativeType":"subitem","number":"BB","heading":null,"label":"BB","identifier":"/us/usc/t21/s355–2/b/2/B/ii/II/aa/BB","parentIdentifier":"/us/usc/t21/s355–2/b/2/B/ii/II/aa","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FB%2Fii%2FII%2Faa%2FBB","sourceRelease":"119-100","text":"otherwise satisfied the Secretary that such protections will be provided; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t21/s355–2/b/2/B/ii/II/bb","parentIdentifier":"/us/usc/t21/s355–2/b/2/B/ii/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FB%2Fii%2FII%2Fbb","sourceRelease":"119-100","text":"met any other requirements the Secretary may establish.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":"Notice","label":"iii Notice","identifier":"/us/usc/t21/s355–2/b/2/B/iii","parentIdentifier":"/us/usc/t21/s355–2/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"A covered product authorization issued under this subparagraph shall state that the provision of the covered product by the license holder under the terms of the authorization will not be a violation of the REMS for the covered product.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Affirmative defense","label":"3 Affirmative defense","identifier":"/us/usc/t21/s355–2/b/3","parentIdentifier":"/us/usc/t21/s355–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s355–2/b/3/A","parentIdentifier":"/us/usc/t21/s355–2/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s355–2/b/3/A/i","parentIdentifier":"/us/usc/t21/s355–2/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F3%2FA%2Fi","sourceRelease":"119-100","text":"neither the license holder nor any of its agents, wholesalers, or distributors was engaged in the manufacturing or commercial marketing of the covered product; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s355–2/b/3/A/ii","parentIdentifier":"/us/usc/t21/s355–2/b/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F3%2FA%2Fii","sourceRelease":"119-100","text":"neither the license holder nor any of its agents, wholesalers, or distributors otherwise had access to inventory of the covered product to supply to the eligible product developer on commercially reasonable, market-based terms;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s355–2/b/3/B","parentIdentifier":"/us/usc/t21/s355–2/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s355–2/b/3/B/i","parentIdentifier":"/us/usc/t21/s355–2/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"the license holder sells the covered product through agents, distributors, or wholesalers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s355–2/b/3/B/ii","parentIdentifier":"/us/usc/t21/s355–2/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"the license holder has placed no restrictions, explicit or implicit, on its agents, distributors, or wholesalers to sell covered products to eligible product developers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t21/s355–2/b/3/B/iii","parentIdentifier":"/us/usc/t21/s355–2/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"the covered product can be purchased by the eligible product developer in sufficient quantities on commercially reasonable, market-based terms from the agents, distributors, or wholesalers of the license holder; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t21/s355–2/b/3/C","parentIdentifier":"/us/usc/t21/s355–2/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s355–2/b/3/C/i","parentIdentifier":"/us/usc/t21/s355–2/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F3%2FC%2Fi","sourceRelease":"119-100","text":"for a covered product that is not subject to a REMS with ETASU, by the date that is 14 days after the date on which the license holder received the request for the covered product, and the eligible product developer did not accept such offer by the date that is 7 days after the date on which the eligible product developer received such offer from the license holder; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s355–2/b/3/C/ii","parentIdentifier":"/us/usc/t21/s355–2/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F3%2FC%2Fii","sourceRelease":"119-100","text":"for a covered product that is subject to a REMS with ETASU, by the date that is 20 days after the date on which the license holder received the request for the covered product, and the eligible product developer did not accept such offer by the date that is 10 days after the date on which the eligible product developer received such offer from the license holder.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Remedies","label":"4 Remedies","identifier":"/us/usc/t21/s355–2/b/4","parentIdentifier":"/us/usc/t21/s355–2/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t21/s355–2/b/4/A","parentIdentifier":"/us/usc/t21/s355–2/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s355–2/b/4/A/i","parentIdentifier":"/us/usc/t21/s355–2/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FA%2Fi","sourceRelease":"119-100","text":"order the license holder to provide to the eligible product developer without delay sufficient quantities of the covered product on commercially reasonable, market-based terms;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s355–2/b/4/A/ii","parentIdentifier":"/us/usc/t21/s355–2/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FA%2Fii","sourceRelease":"119-100","text":"award to the eligible product developer reasonable attorney’s fees and costs of the civil action; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t21/s355–2/b/4/A/iii","parentIdentifier":"/us/usc/t21/s355–2/b/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t21/s355–2/b/4/A/iii/I","parentIdentifier":"/us/usc/t21/s355–2/b/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"that the license holder delayed providing sufficient quantities of the covered product to the eligible product developer without a legitimate business justification; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t21/s355–2/b/4/A/iii/II","parentIdentifier":"/us/usc/t21/s355–2/b/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"that the license holder failed to comply with an order issued under clause (i).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Maximum monetary amount","label":"B Maximum monetary amount","identifier":"/us/usc/t21/s355–2/b/4/B","parentIdentifier":"/us/usc/t21/s355–2/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s355–2/b/4/B/i","parentIdentifier":"/us/usc/t21/s355–2/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t21/s355–2/b/4/B/i/I","parentIdentifier":"/us/usc/t21/s355–2/b/4/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FB%2Fi%2FI","sourceRelease":"119-100","text":"for a covered product that is not subject to a REMS with ETASU, the date that is 31 days after the date on which the license holder received the request; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t21/s355–2/b/4/B/i/II","parentIdentifier":"/us/usc/t21/s355–2/b/4/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FB%2Fi%2FII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t21/s355–2/b/4/B/i/II/aa","parentIdentifier":"/us/usc/t21/s355–2/b/4/B/i/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FB%2Fi%2FII%2Faa","sourceRelease":"119-100","text":"the date on which the license holder received the request; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t21/s355–2/b/4/B/i/II/bb","parentIdentifier":"/us/usc/t21/s355–2/b/4/B/i/II","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FB%2Fi%2FII%2Fbb","sourceRelease":"119-100","text":"the date on which the license holder received a copy of the covered product authorization issued by the Secretary in accordance with paragraph (2)(B); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s355–2/b/4/B/ii","parentIdentifier":"/us/usc/t21/s355–2/b/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FB%2Fii","sourceRelease":"119-100","text":"ending on the date on which the eligible product developer received sufficient quantities of the covered product.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Avoidance of delay","label":"C Avoidance of delay","identifier":"/us/usc/t21/s355–2/b/4/C","parentIdentifier":"/us/usc/t21/s355–2/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fb%2F4%2FC","sourceRelease":"119-100","text":"The court may issue an order under subparagraph (A)(i) before conducting further proceedings that may be necessary to determine whether the eligible product developer is entitled to an award under clause (ii) or (iii) of subparagraph (A), or the amount of any such award.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Limitation of liability","label":"c Limitation of liability","identifier":"/us/usc/t21/s355–2/c","parentIdentifier":"/us/usc/t21/s355–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fc","sourceRelease":"119-100","text":"A license holder for a covered product shall not be liable for any claim under Federal, State, or local law arising out of the failure of an eligible product developer to follow adequate safeguards to assure safe use of the covered product during development or testing activities described in this section, including transportation, handling, use, or disposal of the covered product by the eligible product developer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Omitted","label":"d Omitted","identifier":"/us/usc/t21/s355–2/d","parentIdentifier":"/us/usc/t21/s355–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Rule of construction","label":"e Rule of construction","identifier":"/us/usc/t21/s355–2/e","parentIdentifier":"/us/usc/t21/s355–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Definition","label":"1 Definition","identifier":"/us/usc/t21/s355–2/e/1","parentIdentifier":"/us/usc/t21/s355–2/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s355–2/e/1/A","parentIdentifier":"/us/usc/t21/s355–2/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fe%2F1%2FA","sourceRelease":"119-100","text":"has the meaning given the term in subsection (a) of ; andsection 12 of title 15","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s355–2/e/1/B","parentIdentifier":"/us/usc/t21/s355–2/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fe%2F1%2FB","sourceRelease":"119-100","text":"includes to the extent that such section applies to unfair methods of competition.section 45 of title 15","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Antitrust laws","label":"2 Antitrust laws","identifier":"/us/usc/t21/s355–2/e/2","parentIdentifier":"/us/usc/t21/s355–2/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fe%2F2","sourceRelease":"119-100","text":"Nothing in this section shall be construed to limit the operation of any provision of the antitrust laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Omitted","label":"f Omitted","identifier":"/us/usc/t21/s355–2/f","parentIdentifier":"/us/usc/t21/s355–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Rule of construction","label":"g Rule of construction","identifier":"/us/usc/t21/s355–2/g","parentIdentifier":"/us/usc/t21/s355–2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s355–2/g/1","parentIdentifier":"/us/usc/t21/s355–2/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fg%2F1","sourceRelease":"119-100","text":"prohibiting a license holder from providing an eligible product developer access to a covered product in the absence of an authorization under this section; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s355–2/g/2","parentIdentifier":"/us/usc/t21/s355–2/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs355%E2%80%932%2Fg%2F2","sourceRelease":"119-100","text":"in any way negating the applicability of a REMS with ETASU, as otherwise required under such , with respect to such covered product.section 355–1 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
