{"type":"section","nativeType":"section","number":"3502","heading":"Civil penalty","label":"3502 Civil penalty","identifier":"/us/usc/t7/s3502","parentIdentifier":"/us/usc/t7/ch66","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3502","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t7/s3502/a","parentIdentifier":"/us/usc/t7/s3502","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3502%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s3502/a/1","parentIdentifier":"/us/usc/t7/s3502/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3502%2Fa%2F1","sourceRelease":"119-100","text":"has failed to submit a report in accordance with the provisions of , orsection 3501 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s3502/a/2","parentIdentifier":"/us/usc/t7/s3502/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3502%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s3502/a/2/A","parentIdentifier":"/us/usc/t7/s3502/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3502%2Fa%2F2%2FA","sourceRelease":"119-100","text":"which does not contain all the information required to be in such report, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s3502/a/2/B","parentIdentifier":"/us/usc/t7/s3502/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3502%2Fa%2F2%2FB","sourceRelease":"119-100","text":"which contains information that is misleading or false,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t7/s3502/b","parentIdentifier":"/us/usc/t7/s3502","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs3502%2Fb","sourceRelease":"119-100","text":"The amount of any civil penalty imposed by the Secretary under subsection (a) of this section shall be such amount as the Secretary determines to be appropriate to carry out the purposes of this chapter, except that such amount shall not exceed 25 percent of the fair market value, on the date of the assessment of such penalty, of the interest in agricultural land with respect to which such violation occurred.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
