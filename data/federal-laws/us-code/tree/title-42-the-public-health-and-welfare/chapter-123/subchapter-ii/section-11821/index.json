{"type":"section","nativeType":"section","number":"11821","heading":"Establishment of program","label":"11821 Establishment of program","identifier":"/us/usc/t42/s11821","parentIdentifier":"/us/usc/t42/ch123/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11821","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Program aims","label":"a Program aims","identifier":"/us/usc/t42/s11821/a","parentIdentifier":"/us/usc/t42/s11821","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11821%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s11821/a/1","parentIdentifier":"/us/usc/t42/s11821/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11821%2Fa%2F1","sourceRelease":"119-100","text":"to provide individual, family, and group counseling to runaway youth and their families and to homeless youth for the purpose of preventing or reducing the illicit use of drugs by such youth,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s11821/a/2","parentIdentifier":"/us/usc/t42/s11821/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11821%2Fa%2F2","sourceRelease":"119-100","text":"to develop and support peer counseling programs for runaway and homeless youth related to the illicit use of drugs,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s11821/a/3","parentIdentifier":"/us/usc/t42/s11821/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11821%2Fa%2F3","sourceRelease":"119-100","text":"to develop and support community education activities related to illicit use of drugs by runaway and homeless youth, including outreach to youth individually,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s11821/a/4","parentIdentifier":"/us/usc/t42/s11821/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11821%2Fa%2F4","sourceRelease":"119-100","text":"to provide to runaway and homeless youth in rural areas assistance (including the development of community support groups) related to the illicit use of drugs,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s11821/a/5","parentIdentifier":"/us/usc/t42/s11821/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11821%2Fa%2F5","sourceRelease":"119-100","text":"to provide to individuals involved in providing services to runaway and homeless youth, information and training regarding issues related to the illicit use of drugs by runaway and homeless youth,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s11821/a/6","parentIdentifier":"/us/usc/t42/s11821/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11821%2Fa%2F6","sourceRelease":"119-100","text":"to support research on the illicit drug use by runaway and homeless youth, and the effects on such youth of drug abuse by family members, and any correlation between such use and attempts at suicide, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s11821/a/7","parentIdentifier":"/us/usc/t42/s11821/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11821%2Fa%2F7","sourceRelease":"119-100","text":"to improve the availability and coordination of local services related to drug abuse, for runaway and homeless youth.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Priority","label":"b Priority","identifier":"/us/usc/t42/s11821/b","parentIdentifier":"/us/usc/t42/s11821","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11821%2Fb","sourceRelease":"119-100","text":"In selecting among applicants for grants under subsection (a), the Secretary shall give priority to agencies and organizations that have experience in providing services to runaway and homeless youth.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Limitation","label":"c Limitation","identifier":"/us/usc/t42/s11821/c","parentIdentifier":"/us/usc/t42/s11821","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs11821%2Fc","sourceRelease":"119-100","text":"Grants under this section may be made for a period not to exceed 3 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
