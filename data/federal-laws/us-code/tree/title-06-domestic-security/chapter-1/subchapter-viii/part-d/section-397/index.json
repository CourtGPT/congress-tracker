%2Ft6%2Fs397%2Fa%2F1%2FE","sourceRelease":"119-100","text":"Chemical, biological, radiological, and nuclear protective gear.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t6/s397/a/1/F","parentIdentifier":"/us/usc/t6/s397/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F1%2FF","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s397/a/1/F/i","parentIdentifier":"/us/usc/t6/s397/a/1/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F1%2FF%2Fi","sourceRelease":"119-100","text":"Soft ballistic panels.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s397/a/1/F/ii","parentIdentifier":"/us/usc/t6/s397/a/1/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F1%2FF%2Fii","sourceRelease":"119-100","text":"Hard ballistic plates.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t6/s397/a/1/F/iii","parentIdentifier":"/us/usc/t6/s397/a/1/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F1%2FF%2Fiii","sourceRelease":"119-100","text":"Concealed armor carriers worn under a uniform.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t6/s397/a/1/F/iv","parentIdentifier":"/us/usc/t6/s397/a/1/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F1%2FF%2Fiv","sourceRelease":"119-100","text":"External armor carriers worn over a uniform.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t6/s397/a/1/G","parentIdentifier":"/us/usc/t6/s397/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F1%2FG","sourceRelease":"119-100","text":"Any other item of clothing or protective equipment as determined appropriate by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Frontline operational component","label":"2 Frontline operational component","identifier":"/us/usc/t6/s397/a/2","parentIdentifier":"/us/usc/t6/s397/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s397/a/2/A","parentIdentifier":"/us/usc/t6/s397/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F2%2FA","sourceRelease":"119-100","text":"U.S. Customs and Border Protection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s397/a/2/B","parentIdentifier":"/us/usc/t6/s397/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F2%2FB","sourceRelease":"119-100","text":"U.S. Immigration and Customs Enforcement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s397/a/2/C","parentIdentifier":"/us/usc/t6/s397/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F2%2FC","sourceRelease":"119-100","text":"The United States Secret Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s397/a/2/D","parentIdentifier":"/us/usc/t6/s397/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F2%2FD","sourceRelease":"119-100","text":"The Transportation Security Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t6/s397/a/2/E","parentIdentifier":"/us/usc/t6/s397/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F2%2FE","sourceRelease":"119-100","text":"The Federal Protective Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t6/s397/a/2/F","parentIdentifier":"/us/usc/t6/s397/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F2%2FF","sourceRelease":"119-100","text":"The Federal Emergency Management Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t6/s397/a/2/G","parentIdentifier":"/us/usc/t6/s397/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F2%2FG","sourceRelease":"119-100","text":"The Federal Law Enforcement Training Centers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t6/s397/a/2/H","parentIdentifier":"/us/usc/t6/s397/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fa%2F2%2FH","sourceRelease":"119-100","text":"The Cybersecurity and Infrastructure Security Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirements","label":"b Requirements","identifier":"/us/usc/t6/s397/b","parentIdentifier":"/us/usc/t6/s397","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s397/b/1","parentIdentifier":"/us/usc/t6/s397/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s397/b/1/A","parentIdentifier":"/us/usc/t6/s397/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s397/b/1/A/i","parentIdentifier":"/us/usc/t6/s397/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"To the maximum extent possible, not less than one-third of funds obligated in a specific fiscal year for the procurement of such covered items shall be covered items that are manufactured or supplied in the United States by entities that qualify as small business concerns, as such term is described under .section 632 of title 15","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s397/b/1/A/ii","parentIdentifier":"/us/usc/t6/s397/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t6/s397/b/1/A/ii/I","parentIdentifier":"/us/usc/t6/s397/b/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F1%2FA%2Fii%2FI","sourceRelease":"119-100","text":"are unable to manufacture covered items in the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t6/s397/b/1/A/ii/II","parentIdentifier":"/us/usc/t6/s397/b/1/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F1%2FA%2Fii%2FII","sourceRelease":"119-100","text":"meet the criteria identified in subparagraph (B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s397/b/1/B","parentIdentifier":"/us/usc/t6/s397/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s397/b/1/B/i","parentIdentifier":"/us/usc/t6/s397/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"is an entity registered with the System for Award Management (or successor system) administered by the General Services Administration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s397/b/1/B/ii","parentIdentifier":"/us/usc/t6/s397/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"is in compliance with ISO 9001:2015 of the International Organization for Standardization (or successor standard) or a standard determined appropriate by the Secretary to ensure the quality of products and adherence to applicable statutory and regulatory requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s397/b/1/C","parentIdentifier":"/us/usc/t6/s397/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s397/b/1/C/i","parentIdentifier":"/us/usc/t6/s397/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F1%2FC%2Fi","sourceRelease":"119-100","text":"store such covered item with such insignia or such insignia in a locked area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s397/b/1/C/ii","parentIdentifier":"/us/usc/t6/s397/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F1%2FC%2Fii","sourceRelease":"119-100","text":"report any pilferage or theft of such covered item with such insignia or such insignia occurring at any stage before delivery of such covered item with such insignia or such insignia; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t6/s397/b/1/C/iii","parentIdentifier":"/us/usc/t6/s397/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"destroy any such defective or unusable covered item with insignia or insignia in a manner established by the Secretary, and maintain records, for three years after the creation of such records, of such destruction that include the date of such destruction, a description of the covered item with insignia or insignia destroyed, the quantity of the covered item with insignia or insignia destroyed, and the method of destruction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Waiver","label":"2 Waiver","identifier":"/us/usc/t6/s397/b/2","parentIdentifier":"/us/usc/t6/s397/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t6/s397/b/2/A","parentIdentifier":"/us/usc/t6/s397/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F2%2FA","sourceRelease":"119-100","text":"In the case of a national emergency declared by the President under the National Emergencies Act ( et seq.) or a major disaster declared by the President under , the Secretary may waive a requirement in subparagraph (A), (B) or (C) of paragraph (1) if the Secretary determines there is an insufficient supply of a covered item that meets such requirement.50 U.S.C. 1601section 5170 of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Notice","label":"B Notice","identifier":"/us/usc/t6/s397/b/2/B","parentIdentifier":"/us/usc/t6/s397/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s397/b/2/B/i","parentIdentifier":"/us/usc/t6/s397/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"Identification of the national emergency or major disaster declared by the President.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s397/b/2/B/ii","parentIdentifier":"/us/usc/t6/s397/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"Identification of the covered item for which the Secretary intends to issue the waiver.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t6/s397/b/2/B/iii","parentIdentifier":"/us/usc/t6/s397/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"A description of the demand for the covered item and corresponding lack of supply from contractors able to meet the criteria described in subparagraph (B) or (C) of paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Pricing","label":"c Pricing","identifier":"/us/usc/t6/s397/c","parentIdentifier":"/us/usc/t6/s397","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fc","sourceRelease":"119-100","text":"The Secretary shall ensure that covered items are purchased at a fair and reasonable price, consistent with the procedures and guidelines specified in the Federal Acquisition Regulation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Report","label":"d Report","identifier":"/us/usc/t6/s397/d","parentIdentifier":"/us/usc/t6/s397","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fd","sourceRelease":"119-100","text":"Not later than one year after , and annually thereafter, the Secretary shall provide to the Committee on Homeland Security, the Committee on Oversight and Reform, the Committee on Small Business, and the Committee on Appropriations of the House of Representatives, and the Committee on Homeland Security and Governmental Affairs, the Committee on Small Business and Entrepreneurship, and the Committee on Appropriations of the Senate a briefing on instances in which vendors have failed to meet deadlines for delivery of covered items and corrective actions taken by the Department in response to such instances.December 23, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Effective date","label":"e Effective date","identifier":"/us/usc/t6/s397/e","parentIdentifier":"/us/usc/t6/s397","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs397%2Fe","sourceRelease":"119-100","text":"This section applies with respect to a contract entered into by the Department or any frontline operational component on or after the date that is 180 days after .December 23, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
