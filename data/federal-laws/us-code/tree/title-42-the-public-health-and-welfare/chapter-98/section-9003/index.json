{"type":"section","nativeType":"section","number":"9003","heading":"Research and development","label":"9003 Research and development","identifier":"/us/usc/t42/s9003","parentIdentifier":"/us/usc/t42/ch98","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9003","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Initiation of research","label":"a Initiation of research","identifier":"/us/usc/t42/s9003/a","parentIdentifier":"/us/usc/t42/s9003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9003%2Fa","sourceRelease":"119-100","text":"The Secretary shall initiate research or accelerate existing research in areas in which the lack of knowledge limits development of ocean thermal energy conversion systems in order to achieve the purposes of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Evaluations, tests, and dissemination of information, data, and materials","label":"b Evaluations, tests, and dissemination of information, data, and materials","identifier":"/us/usc/t42/s9003/b","parentIdentifier":"/us/usc/t42/s9003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9003%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s9003/b/1","parentIdentifier":"/us/usc/t42/s9003/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9003%2Fb%2F1","sourceRelease":"119-100","text":"interface requirements between the platform and cold water pipe;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s9003/b/2","parentIdentifier":"/us/usc/t42/s9003/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9003%2Fb%2F2","sourceRelease":"119-100","text":"cold water pipe deployment techniques;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s9003/b/3","parentIdentifier":"/us/usc/t42/s9003/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9003%2Fb%2F3","sourceRelease":"119-100","text":"heat exchangers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s9003/b/4","parentIdentifier":"/us/usc/t42/s9003/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9003%2Fb%2F4","sourceRelease":"119-100","text":"control system simulation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s9003/b/5","parentIdentifier":"/us/usc/t42/s9003/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9003%2Fb%2F5","sourceRelease":"119-100","text":"stationkeeping requirements; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s9003/b/6","parentIdentifier":"/us/usc/t42/s9003/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9003%2Fb%2F6","sourceRelease":"119-100","text":"energy delivery systems, such as electric cable or energy product transport.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Consideration of new or improved technologies","label":"c Consideration of new or improved technologies","identifier":"/us/usc/t42/s9003/c","parentIdentifier":"/us/usc/t42/s9003","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9003%2Fc","sourceRelease":"119-100","text":"The Secretary shall, for the purpose of performing his responsibilities pursuant to this chapter, solicit proposals and evaluate any reasonable new or improved technology, a description of which is submitted to the Secretary in writing, which could lead or contribute to the development of ocean thermal energy conversion system technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
