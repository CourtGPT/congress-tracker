{"type":"section","nativeType":"section","number":"727","heading":"Reassignment of senior executives","label":"727 Reassignment of senior executives","identifier":"/us/usc/t38/s727","parentIdentifier":"/us/usc/t38/ptI/ch7/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs727","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Approval of Reassignments","label":"a .—Approval of Reassignments","identifier":"/us/usc/t38/s727/a","parentIdentifier":"/us/usc/t38/s727","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs727%2Fa","sourceRelease":"119-100","text":"No individual employed in a senior executive position at the Department may be reassigned to another such position at the Department unless such reassignment is approved in writing and signed by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Semiannual Reports Required","label":"b .—Semiannual Reports Required","identifier":"/us/usc/t38/s727/b","parentIdentifier":"/us/usc/t38/s727","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs727%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s727/b/1","parentIdentifier":"/us/usc/t38/s727/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs727%2Fb%2F1","sourceRelease":"119-100","text":"Not later than June 30 and December 31 of each year, the Secretary shall submit to Congress a report on the reassignment of individuals employed in senior executive positions at the Department to other such positions at the Department during the period covered by the report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s727/b/2","parentIdentifier":"/us/usc/t38/s727/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs727%2Fb%2F2","sourceRelease":"119-100","text":"Each report submitted under paragraph (1) shall describe the purpose of each reassignment and the costs associated with such reassignment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s727/b/3","parentIdentifier":"/us/usc/t38/s727/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs727%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s727/b/3/A","parentIdentifier":"/us/usc/t38/s727/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs727%2Fb%2F3%2FA","sourceRelease":"119-100","text":"A salary increase.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s727/b/3/B","parentIdentifier":"/us/usc/t38/s727/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs727%2Fb%2F3%2FB","sourceRelease":"119-100","text":"Temporary travel expenses for the individual or the family of the individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s727/b/3/C","parentIdentifier":"/us/usc/t38/s727/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs727%2Fb%2F3%2FC","sourceRelease":"119-100","text":"Moving expenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t38/s727/b/3/D","parentIdentifier":"/us/usc/t38/s727/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs727%2Fb%2F3%2FD","sourceRelease":"119-100","text":"A paid incentive.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Senior Executive Position Defined","label":"c .—Senior Executive Position Defined","identifier":"/us/usc/t38/s727/c","parentIdentifier":"/us/usc/t38/s727","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs727%2Fc","sourceRelease":"119-100","text":"In this section, the term “senior executive position” has the meaning given such term in .section 713(d) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
