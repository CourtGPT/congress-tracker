s15911/b/4","parentIdentifier":"/us/usc/t42/s15911/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fb%2F4","sourceRelease":"119-100","text":"the construction of fuel transportation networks and related facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s15911/b/5","parentIdentifier":"/us/usc/t42/s15911/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fb%2F5","sourceRelease":"119-100","text":"power cost equalization programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s15911/b/6","parentIdentifier":"/us/usc/t42/s15911/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fb%2F6","sourceRelease":"119-100","text":"projects using coal as a fuel, including coal gasification projects.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Open meetings","label":"c Open meetings","identifier":"/us/usc/t42/s15911/c","parentIdentifier":"/us/usc/t42/s15911","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s15911/c/1","parentIdentifier":"/us/usc/t42/s15911/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15911/c/1/A","parentIdentifier":"/us/usc/t42/s15911/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the Commission members take action on behalf of the Commission; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15911/c/1/B","parentIdentifier":"/us/usc/t42/s15911/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fc%2F1%2FB","sourceRelease":"119-100","text":"the deliberations of the Commission determine, or result in the joint conduct or disposition of, official Commission business.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Exceptions","label":"2 Exceptions","identifier":"/us/usc/t42/s15911/c/2","parentIdentifier":"/us/usc/t42/s15911/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fc%2F2","sourceRelease":"119-100","text":"Paragraph (1) shall not apply to any portion of a Commission meeting for which the Commission, in public session, votes to close the meeting for the reasons described in paragraph (2), (4), (5), or (6) of subsection (c) of .section 552b of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Public notice","label":"3 Public notice","identifier":"/us/usc/t42/s15911/c/3","parentIdentifier":"/us/usc/t42/s15911/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s15911/c/3/A","parentIdentifier":"/us/usc/t42/s15911/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fc%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s15911/c/3/A/i","parentIdentifier":"/us/usc/t42/s15911/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fc%2F3%2FA%2Fi","sourceRelease":"119-100","text":"the time, place, and subject matter of the meeting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s15911/c/3/A/ii","parentIdentifier":"/us/usc/t42/s15911/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fc%2F3%2FA%2Fii","sourceRelease":"119-100","text":"whether the meeting is to be open or closed to the public; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s15911/c/3/A/iii","parentIdentifier":"/us/usc/t42/s15911/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fc%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"the name and telephone number of an appropriate person to respond to requests for information about the meeting.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Additional notice","label":"B Additional notice","identifier":"/us/usc/t42/s15911/c/3/B","parentIdentifier":"/us/usc/t42/s15911/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fc%2F3%2FB","sourceRelease":"119-100","text":"The Commission shall make a public announcement of any change to the information made available under subparagraph (A) at the earliest practicable time.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Minutes","label":"4 Minutes","identifier":"/us/usc/t42/s15911/c/4","parentIdentifier":"/us/usc/t42/s15911/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fc%2F4","sourceRelease":"119-100","text":"The Commission shall keep, and make available to the public, a transcript, electronic recording, or minutes from each Commission meeting, except for portions of the meeting closed under paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s15911/d","parentIdentifier":"/us/usc/t42/s15911","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15911%2Fd","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Commission not more than $55,000,000 for each of fiscal years 2006 through 2015 to carry out subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
