{"type":"section","nativeType":"section","number":"1722","heading":"Injunction and specific enforcement authority","label":"1722 Injunction and specific enforcement authority","identifier":"/us/usc/t30/s1722","parentIdentifier":"/us/usc/t30/ch29/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1722","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Civil action by Attorney General","label":"a Civil action by Attorney General","identifier":"/us/usc/t30/s1722/a","parentIdentifier":"/us/usc/t30/s1722","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1722%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t30/s1722/a/1","parentIdentifier":"/us/usc/t30/s1722/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1722%2Fa%2F1","sourceRelease":"119-100","text":"to restrain any violation of this chapter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t30/s1722/a/2","parentIdentifier":"/us/usc/t30/s1722/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1722%2Fa%2F2","sourceRelease":"119-100","text":"to compel the taking of any action required by or under this chapter or any mineral leasing law of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Venue","label":"b Venue","identifier":"/us/usc/t30/s1722/b","parentIdentifier":"/us/usc/t30/s1722","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft30%2Fs1722%2Fb","sourceRelease":"119-100","text":"A civil acti