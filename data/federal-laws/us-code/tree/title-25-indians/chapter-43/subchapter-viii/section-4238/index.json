{"type":"section","nativeType":"section","number":"4238","heading":"Monitoring of compliance","label":"4238 Monitoring of compliance","identifier":"/us/usc/t25/s4238","parentIdentifier":"/us/usc/t25/ch43/schVIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4238","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Codification, and , enacted identical sections 819 of . This section is based on the text of , as added by .Pub. L. 106–568, § 203Pub. L. 106–569, § 513Pub. L. 104–330section 819 of Pub. L. 104–330Pub. L. 106–569, § 513"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Enforceable agreements","label":"a Enforceable agreements","identifier":"/us/usc/t25/s4238/a","parentIdentifier":"/us/usc/t25/s4238","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4238%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s4238/a/1","parentIdentifier":"/us/usc/t25/s4238/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4238%2Fa%2F1","sourceRelease":"119-100","text":"The Director, through binding contractual agreements with owners or other authorized entities, shall ensure long-term compliance with the provisions of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Measures","label":"2 Measures","identifier":"/us/usc/t25/s4238/a/2","parentIdentifier":"/us/usc/t25/s4238/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4238%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s4238/a/2/A","parentIdentifier":"/us/usc/t25/s4238/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4238%2Fa%2F2%2FA","sourceRelease":"119-100","text":"to the extent allowable by Federal and State law, the enforcement of the provisions of this subchapter by the Department and the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s4238/a/2/B","parentIdentifier":"/us/usc/t25/s4238/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4238%2Fa%2F2%2FB","sourceRelease":"119-100","text":"remedies for breach of the provisions referred to in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Periodic monitoring","label":"b Periodic monitoring","identifier":"/us/usc/t25/s4238/b","parentIdentifier":"/us/usc/t25/s4238","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4238%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s4238/b/1","parentIdentifier":"/us/usc/t25/s4238/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4238%2Fb%2F1","sourceRelease":"119-100","text":"Not less frequently than annually, the Director shall review the activities conducted and housing assisted under this subchapter to assess compliance with the requirements of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Review","label":"2 Review","identifier":"/us/usc/t25/s4238/b/2","parentIdentifier":"/us/usc/t25/s4238/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4238%2Fb%2F2","sourceRelease":"119-100","text":"Each review under paragraph (1) shall include onsite inspection of housing to determine compliance with applicable requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Results","label":"3 Results","identifier":"/us/usc/t25/s4238/b/3","parentIdentifier":"/us/usc/t25/s4238/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4238%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s4238/b/3/A","parentIdentifier":"/us/usc/t25/s4238/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4238%2Fb%2F3%2FA","sourceRelease":"119-100","text":"included in a performance report of the Director submitted to the Secretary under ; andsection 4239 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s4238/b/3/B","parentIdentifier":"/us/usc/t25/s4238/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4238%2Fb%2F3%2FB","sourceRelease":"119-100","text":"made available to the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Performance measures","label":"c Performance measures","identifier":"/us/usc/t25/s4238/c","parentIdentifier":"/us/usc/t25/s4238","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4238%2Fc","sourceRelease":"119-100","text":"The Secretary shall establish such performance measures as may be necessary to assess compliance with the requirements of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
