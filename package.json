{
  "name": "congress-tracker",
  "version": "1.0.0",
  "description": "Track US congressional activity - bills, votes, members, committees",
  "main": "index.js",
  "scripts": {
    "fetch:bills": "node scripts/fetch-bills.js",
    "fetch:members": "node scripts/fetch-members.js",
    "fetch:votes": "node scripts/fetch-votes.js",
    "backfill": "node scripts/backfill.js",
    "update": "npm run fetch:bills && npm run fetch:members && npm run fetch:votes",
