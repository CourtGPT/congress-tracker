{"type":"section","nativeType":"section","number":"2104a","heading":"Pest and Disease Revolving Loan Fund","label":"2104a Pest and Disease Revolving Loan Fund","identifier":"/us/usc/t16/s2104a","parentIdentifier":"/us/usc/t16/ch41","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Codificationand enacted identical sections. was repealed by .Pub. L. 110–234Pub. L. 110–246Pub. L. 110–234section 4(a) of Pub. L. 110–246Section was enacted as part of the Food, Conservation, and Energy Act of 2008, and not as part of the Cooperative Forestry Assistance Act of 1978 which comprises this chapter.","Statutory Notes and Related Subsidiaries","Effective DateEnactment of this section and repeal of by effective , the date of enactment of , see , set out as a note under , Agriculture.Pub. L. 110–234Pub. L. 110–246Pub. L. 110–234section 4 of Pub. L. 110–246section 8701 of Title 7May 22, 2008"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t16/s2104a/a","parentIdentifier":"/us/usc/t16/s2104a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Authorized equipment","label":"1 Authorized equipment","identifier":"/us/usc/t16/s2104a/a/1","parentIdentifier":"/us/usc/t16/s2104a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s2104a/a/1/A","parentIdentifier":"/us/usc/t16/s2104a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa%2F1%2FA","sourceRelease":"119-100","text":"The term “authorized equipment” means any equipment necessary for the management of forest land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Inclusions","label":"B Inclusions","identifier":"/us/usc/t16/s2104a/a/1/B","parentIdentifier":"/us/usc/t16/s2104a/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s2104a/a/1/B/i","parentIdentifier":"/us/usc/t16/s2104a/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"cherry pickers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s2104a/a/1/B/ii","parentIdentifier":"/us/usc/t16/s2104a/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s2104a/a/1/B/ii/I","parentIdentifier":"/us/usc/t16/s2104a/a/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa%2F1%2FB%2Fii%2FI","sourceRelease":"119-100","text":"the construction of staging and marshalling areas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s2104a/a/1/B/ii/II","parentIdentifier":"/us/usc/t16/s2104a/a/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa%2F1%2FB%2Fii%2FII","sourceRelease":"119-100","text":"the planting of trees; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s2104a/a/1/B/ii/III","parentIdentifier":"/us/usc/t16/s2104a/a/1/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa%2F1%2FB%2Fii%2FIII","sourceRelease":"119-100","text":"the surveying of forest land;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s2104a/a/1/B/iii","parentIdentifier":"/us/usc/t16/s2104a/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"vehicles capable of transporting harvested trees;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s2104a/a/1/B/iv","parentIdentifier":"/us/usc/t16/s2104a/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"wood chippers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t16/s2104a/a/1/B/v","parentIdentifier":"/us/usc/t16/s2104a/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa%2F1%2FB%2Fv","sourceRelease":"119-100","text":"any other appropriate equipment, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Fund","label":"2 Fund","identifier":"/us/usc/t16/s2104a/a/2","parentIdentifier":"/us/usc/t16/s2104a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa%2F2","sourceRelease":"119-100","text":"The term “Fund” means the Pest and Disease Revolving Loan Fund established by subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Secretary","label":"3 Secretary","identifier":"/us/usc/t16/s2104a/a/3","parentIdentifier":"/us/usc/t16/s2104a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fa%2F3","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Agriculture, acting through the Deputy Chief of the State and Private Forestry organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment of Fund","label":"b Establishment of Fund","identifier":"/us/usc/t16/s2104a/b","parentIdentifier":"/us/usc/t16/s2104a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fb","sourceRelease":"119-100","text":"There is established in the Treasury of the United States a revolving fund, to be known as the “Pest and Disease Revolving Loan Fund”, consisting of such amounts as are appropriated to the Fund under subsection (f).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Expenditures from Fund","label":"c Expenditures from Fund","identifier":"/us/usc/t16/s2104a/c","parentIdentifier":"/us/usc/t16/s2104a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s2104a/c/1","parentIdentifier":"/us/usc/t16/s2104a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fc%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2), on request by the Secretary, the Secretary of the Treasury shall transfer from the Fund to the Secretary such amounts as the Secretary determines are necessary to provide loans under subsection (e).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Administrative expenses","label":"2 Administrative expenses","identifier":"/us/usc/t16/s2104a/c/2","parentIdentifier":"/us/usc/t16/s2104a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fc%2F2","sourceRelease":"119-100","text":"An amount not exceeding 10 percent of the amounts in the Fund shall be available for each fiscal year to pay the administrative expenses necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Transfers of amounts","label":"d Transfers of amounts","identifier":"/us/usc/t16/s2104a/d","parentIdentifier":"/us/usc/t16/s2104a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s2104a/d/1","parentIdentifier":"/us/usc/t16/s2104a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fd%2F1","sourceRelease":"119-100","text":"The amounts required to be transferred to the Fund under this section shall be transferred at least monthly from the general fund of the Treasury to the Fund on the basis of estimates made by the Secretary of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Adjustments","label":"2 Adjustments","identifier":"/us/usc/t16/s2104a/d/2","parentIdentifier":"/us/usc/t16/s2104a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fd%2F2","sourceRelease":"119-100","text":"Proper adjustment shall be made in amounts subsequently transferred to the extent prior estimates were in excess of or less than the amounts required to be transferred.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Uses of Fund","label":"e Uses of Fund","identifier":"/us/usc/t16/s2104a/e","parentIdentifier":"/us/usc/t16/s2104a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Loans","label":"1 Loans","identifier":"/us/usc/t16/s2104a/e/1","parentIdentifier":"/us/usc/t16/s2104a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s2104a/e/1/A","parentIdentifier":"/us/usc/t16/s2104a/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s2104a/e/1/A/i","parentIdentifier":"/us/usc/t16/s2104a/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F1%2FA%2Fi","sourceRelease":"119-100","text":"on land under the jurisdiction of the eligible units of local government; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s2104a/e/1/A/ii","parentIdentifier":"/us/usc/t16/s2104a/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F1%2FA%2Fii","sourceRelease":"119-100","text":"within the borders of quarantine areas infested by plant pests.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Maximum amount","label":"B Maximum amount","identifier":"/us/usc/t16/s2104a/e/1/B","parentIdentifier":"/us/usc/t16/s2104a/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s2104a/e/1/B/i","parentIdentifier":"/us/usc/t16/s2104a/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the amount that the eligible unit of local government has appropriated to finance purchases of authorized equipment in accordance with subparagraph (A); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s2104a/e/1/B/ii","parentIdentifier":"/us/usc/t16/s2104a/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F1%2FB%2Fii","sourceRelease":"119-100","text":"$5,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Interest rate","label":"C Interest rate","identifier":"/us/usc/t16/s2104a/e/1/C","parentIdentifier":"/us/usc/t16/s2104a/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F1%2FC","sourceRelease":"119-100","text":"The interest rate on any loan made by the Secretary under this paragraph shall be a rate equal to 2 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Report","label":"D Report","identifier":"/us/usc/t16/s2104a/e/1/D","parentIdentifier":"/us/usc/t16/s2104a/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F1%2FD","sourceRelease":"119-100","text":"Not later than 180 days after the date on which an eligible unit of local government receives a loan provided by the Secretary under subparagraph (A), the eligible unit of local government shall submit to the Secretary a report that describes each purchase made by the eligible unit of local government using assistance provided through the loan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Loan repayment schedule","label":"2 Loan repayment schedule","identifier":"/us/usc/t16/s2104a/e/2","parentIdentifier":"/us/usc/t16/s2104a/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s2104a/e/2/A","parentIdentifier":"/us/usc/t16/s2104a/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F2%2FA","sourceRelease":"119-100","text":"To be eligible to receive a loan from the Secretary under paragraph (1), in accordance with each requirement described in subparagraph (B), an eligible unit of local government shall enter into an agreement with the Secretary to establish a loan repayment schedule relating to the repayment of the loan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Requirements relating to loan repayment schedule","label":"B Requirements relating to loan repayment schedule","identifier":"/us/usc/t16/s2104a/e/2/B","parentIdentifier":"/us/usc/t16/s2104a/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s2104a/e/2/B/i","parentIdentifier":"/us/usc/t16/s2104a/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F2%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s2104a/e/2/B/i/I","parentIdentifier":"/us/usc/t16/s2104a/e/2/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F2%2FB%2Fi%2FI","sourceRelease":"119-100","text":"the principal amount of the loan (including interest); by","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s2104a/e/2/B/i/II","parentIdentifier":"/us/usc/t16/s2104a/e/2/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F2%2FB%2Fi%2FII","sourceRelease":"119-100","text":"the total quantity of payments that the eligible unit of local government is required to make during the repayment period of the loan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s2104a/e/2/B/ii","parentIdentifier":"/us/usc/t16/s2104a/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Fe%2F2%2FB%2Fii","sourceRelease":"119-100","text":"not later than 20 years after the date on which the eligible unit of local government receives a loan under paragraph (1), to complete repayment to the Secretary of the Treasury of the loan made under this section (including interest).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorization of appropriations","label":"f Authorization of appropriations","identifier":"/us/usc/t16/s2104a/f","parentIdentifier":"/us/usc/t16/s2104a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs2104a%2Ff","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Fund such sums as are necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
