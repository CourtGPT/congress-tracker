{"type":"section","nativeType":"section","number":"7382c","heading":"Fellowship Program","label":"7382c Fellowship Program","identifier":"/us/usc/t42/s7382c","parentIdentifier":"/us/usc/t42/ch84/schXIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s7382c/a","parentIdentifier":"/us/usc/t42/s7382c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t42/s7382c/a/1","parentIdentifier":"/us/usc/t42/s7382c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary shall establish the Albert Einstein Distinguished Educator Fellowship Program (hereafter in this subchapter referred to as the “Program”) to provide 12 elementary or secondary school mathematics or science teachers with fellowships in each fiscal year in accordance with this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Order of priority","label":"2 Order of priority","identifier":"/us/usc/t42/s7382c/a/2","parentIdentifier":"/us/usc/t42/s7382c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7382c/a/2/A","parentIdentifier":"/us/usc/t42/s7382c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F2%2FA","sourceRelease":"119-100","text":"Three fellowships in the Department of Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7382c/a/2/B","parentIdentifier":"/us/usc/t42/s7382c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F2%2FB","sourceRelease":"119-100","text":"Two fellowships in the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s7382c/a/2/C","parentIdentifier":"/us/usc/t42/s7382c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F2%2FC","sourceRelease":"119-100","text":"Two fellowships in the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s7382c/a/2/D","parentIdentifier":"/us/usc/t42/s7382c/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s7382c/a/2/D/i","parentIdentifier":"/us/usc/t42/s7382c/a/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F2%2FD%2Fi","sourceRelease":"119-100","text":"The Department of Education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s7382c/a/2/D/ii","parentIdentifier":"/us/usc/t42/s7382c/a/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F2%2FD%2Fii","sourceRelease":"119-100","text":"The National Institutes of Health.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s7382c/a/2/D/iii","parentIdentifier":"/us/usc/t42/s7382c/a/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F2%2FD%2Fiii","sourceRelease":"119-100","text":"The National Science Foundation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s7382c/a/2/D/iv","parentIdentifier":"/us/usc/t42/s7382c/a/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F2%2FD%2Fiv","sourceRelease":"119-100","text":"The National Aeronautics and Space Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s7382c/a/2/D/v","parentIdentifier":"/us/usc/t42/s7382c/a/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F2%2FD%2Fv","sourceRelease":"119-100","text":"The Office of Science and Technology Policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Terms of fellowships","label":"3 Terms of fellowships","identifier":"/us/usc/t42/s7382c/a/3","parentIdentifier":"/us/usc/t42/s7382c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F3","sourceRelease":"119-100","text":"Each fellowship awarded under this subchapter shall be awarded for a period of ten months that, to the extent practicable, coincide with the academic year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Eligibility","label":"4 Eligibility","identifier":"/us/usc/t42/s7382c/a/4","parentIdentifier":"/us/usc/t42/s7382c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7382c/a/4/A","parentIdentifier":"/us/usc/t42/s7382c/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F4%2FA","sourceRelease":"119-100","text":"that such teacher would bring unique and valuable contributions to the Program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7382c/a/4/B","parentIdentifier":"/us/usc/t42/s7382c/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F4%2FB","sourceRelease":"119-100","text":"that such teacher is recognized for excellence in mathematics or science education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s7382c/a/4/C","parentIdentifier":"/us/usc/t42/s7382c/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F4%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s7382c/a/4/C/i","parentIdentifier":"/us/usc/t42/s7382c/a/4/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F4%2FC%2Fi","sourceRelease":"119-100","text":"a sabbatical leave from teaching will be granted in order to participate in the Program; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s7382c/a/4/C/ii","parentIdentifier":"/us/usc/t42/s7382c/a/4/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fa%2F4%2FC%2Fii","sourceRelease":"119-100","text":"the teacher will return to a teaching position comparable to the position held prior to participating in the Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Administration","label":"b Administration","identifier":"/us/usc/t42/s7382c/b","parentIdentifier":"/us/usc/t42/s7382c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s7382c/b/1","parentIdentifier":"/us/usc/t42/s7382c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fb%2F1","sourceRelease":"119-100","text":"provide for the development and administration of an application and selection process for fellowships under the Program, including a process whereby final selections of fellowship recipients are made in accordance with subsection (c);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s7382c/b/2","parentIdentifier":"/us/usc/t42/s7382c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fb%2F2","sourceRelease":"119-100","text":"provide for the publication of information on the Program in appropriate professional publications, including an invitation for applications from teachers listed in the directories of national and State recognition programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s7382c/b/3","parentIdentifier":"/us/usc/t42/s7382c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fb%2F3","sourceRelease":"119-100","text":"select from the pool of applicants 12 elementary and secondary school mathematics teachers and 12 elementary and secondary school science teachers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s7382c/b/4","parentIdentifier":"/us/usc/t42/s7382c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fb%2F4","sourceRelease":"119-100","text":"develop a program of orientation for fellowship recipients under this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s7382c/b/5","parentIdentifier":"/us/usc/t42/s7382c/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fb%2F5","sourceRelease":"119-100","text":"not later than August 31 of each year in which fellowships are awarded, prepare and submit an annual report and evaluation of the Program to the appropriate Committees of the Senate and the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Selection","label":"c Selection","identifier":"/us/usc/t42/s7382c/c","parentIdentifier":"/us/usc/t42/s7382c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s7382c/c/1","parentIdentifier":"/us/usc/t42/s7382c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary shall arrange for the 24 semifinalists to travel to Washington, D.C., to participate in interviews in accordance with the selection process described in paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Final selection","label":"2 Final selection","identifier":"/us/usc/t42/s7382c/c/2","parentIdentifier":"/us/usc/t42/s7382c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7382c/c/2/A","parentIdentifier":"/us/usc/t42/s7382c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc%2F2%2FA","sourceRelease":"119-100","text":"Not later than May 1 of each year preceding each year in which fellowships are to be awarded, the Secretary shall select and announce the names of the fellowship recipients.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7382c/c/2/B","parentIdentifier":"/us/usc/t42/s7382c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s7382c/c/2/B/i","parentIdentifier":"/us/usc/t42/s7382c/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"The Secretary shall select three fellowship recipients who shall be assigned to the Department of Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s7382c/c/2/B/ii","parentIdentifier":"/us/usc/t42/s7382c/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"The Majority Leader of the Senate and the Minority Leader of the Senate, or their designees, shall each select a fellowship recipient who shall be assigned to the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s7382c/c/2/B/iii","parentIdentifier":"/us/usc/t42/s7382c/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"The Speaker of the House of Representatives and the Minority Leader of the House of Representatives, or their designees, shall each select a fellowship recipient who shall be assigned to the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s7382c/c/2/B/iv","parentIdentifier":"/us/usc/t42/s7382c/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc%2F2%2FB%2Fiv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s7382c/c/2/B/iv/I","parentIdentifier":"/us/usc/t42/s7382c/c/2/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc%2F2%2FB%2Fiv%2FI","sourceRelease":"119-100","text":"The Secretary of Education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s7382c/c/2/B/iv/II","parentIdentifier":"/us/usc/t42/s7382c/c/2/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc%2F2%2FB%2Fiv%2FII","sourceRelease":"119-100","text":"The Director of the National Institutes of Health.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t42/s7382c/c/2/B/iv/III","parentIdentifier":"/us/usc/t42/s7382c/c/2/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc%2F2%2FB%2Fiv%2FIII","sourceRelease":"119-100","text":"The Director of the National Science Foundation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t42/s7382c/c/2/B/iv/IV","parentIdentifier":"/us/usc/t42/s7382c/c/2/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc%2F2%2FB%2Fiv%2FIV","sourceRelease":"119-100","text":"The Administrator of the National Aeronautics and Space Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t42/s7382c/c/2/B/iv/V","parentIdentifier":"/us/usc/t42/s7382c/c/2/B/iv","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7382c%2Fc%2F2%2FB%2Fiv%2FV","sourceRelease":"119-100","text":"The Director of the Office of Science and Technology Policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}]}
