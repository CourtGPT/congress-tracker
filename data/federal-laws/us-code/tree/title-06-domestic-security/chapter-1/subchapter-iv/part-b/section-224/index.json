{"type":"section","nativeType":"section","number":"224","heading":"Other reporting requirements","label":"224 Other reporting requirements","identifier":"/us/usc/t6/s224","parentIdentifier":"/us/usc/t6/ch1/schIV/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of Missing Persons and Unidentified Remains Act of 2019, and not as part of the Homeland Security Act of 2002 which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Unidentified remains","label":"a Unidentified remains","identifier":"/us/usc/t6/s224/a","parentIdentifier":"/us/usc/t6/s224","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Reporting requirement","label":"1 Reporting requirement","identifier":"/us/usc/t6/s224/a/1","parentIdentifier":"/us/usc/t6/s224/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s224/a/1/A","parentIdentifier":"/us/usc/t6/s224/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s224/a/1/A/i","parentIdentifier":"/us/usc/t6/s224/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the cause and manner of death, if known;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s224/a/1/A/ii","parentIdentifier":"/us/usc/t6/s224/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the sex, age (at time of death), and country of origin (if such information is determinable); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t6/s224/a/1/A/iii","parentIdentifier":"/us/usc/t6/s224/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fa%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"the location of each unidentified remain;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s224/a/1/B","parentIdentifier":"/us/usc/t6/s224/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the total number of deceased people whose unidentified remains were discovered by U.S. Customs and Border Protection during the reporting period;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s224/a/1/C","parentIdentifier":"/us/usc/t6/s224/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fa%2F1%2FC","sourceRelease":"119-100","text":"to the extent such information is available to U.S. Customs and Border Protection, the total number of deceased people whose unidentified remains were discovered by Federal, State, local or Tribal law enforcement officers, military personnel, or medical examiners offices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s224/a/1/D","parentIdentifier":"/us/usc/t6/s224/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fa%2F1%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s224/a/1/D/i","parentIdentifier":"/us/usc/t6/s224/a/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fa%2F1%2FD%2Fi","sourceRelease":"119-100","text":"to identify and map the locations at which migrant deaths occur; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s224/a/1/D/ii","parentIdentifier":"/us/usc/t6/s224/a/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fa%2F1%2FD%2Fii","sourceRelease":"119-100","text":"to count the number of deaths that occur at such locations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t6/s224/a/1/E","parentIdentifier":"/us/usc/t6/s224/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fa%2F1%2FE","sourceRelease":"119-100","text":"a detailed description of U.S. Customs and Border Protection’s Missing Migrant Program, including how the program helps mitigate migrant deaths while maintaining border security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Public disclosure","label":"2 Public disclosure","identifier":"/us/usc/t6/s224/a/2","parentIdentifier":"/us/usc/t6/s224/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fa%2F2","sourceRelease":"119-100","text":"Not later than 30 days after each report required under paragraph (1) is submitted, the Commissioner of U.S. Customs and Border Protection shall publish on the website of the agency the information described in subparagraphs (A), (B), and (C) of paragraph (1) during each reporting period.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Rescue beacons","label":"b Rescue beacons","identifier":"/us/usc/t6/s224/b","parentIdentifier":"/us/usc/t6/s224","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s224/b/1","parentIdentifier":"/us/usc/t6/s224/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fb%2F1","sourceRelease":"119-100","text":"the number of rescue beacons in each border patrol sector;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s224/b/2","parentIdentifier":"/us/usc/t6/s224/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fb%2F2","sourceRelease":"119-100","text":"the specific location of each rescue beacon;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s224/b/3","parentIdentifier":"/us/usc/t6/s224/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fb%2F3","sourceRelease":"119-100","text":"the frequency with which each rescue beacon was activated by a person in distress;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s224/b/4","parentIdentifier":"/us/usc/t6/s224/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fb%2F4","sourceRelease":"119-100","text":"a description of the nature of the distress that resulted in each rescue beacon activation (if such information is determinable); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s224/b/5","parentIdentifier":"/us/usc/t6/s224/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fb%2F5","sourceRelease":"119-100","text":"an assessment, in consultation with local stakeholders, including elected officials, nongovernmental organizations, and landowners, of necessary additional rescue beacons and recommendations for locations for deployment to reduce migrant deaths.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"GAO report","label":"c GAO report","identifier":"/us/usc/t6/s224/c","parentIdentifier":"/us/usc/t6/s224","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s224/c/1","parentIdentifier":"/us/usc/t6/s224/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fc%2F1","sourceRelease":"119-100","text":"how U.S. Customs and Border Protection collects and records border-crossing death data;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s224/c/2","parentIdentifier":"/us/usc/t6/s224/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fc%2F2","sourceRelease":"119-100","text":"the differences (if any) in U.S. Customs and Border Protection border-crossing death data collection methodology across its sectors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s224/c/3","parentIdentifier":"/us/usc/t6/s224/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fc%2F3","sourceRelease":"119-100","text":"how U.S. Customs and Border Protection’s data and statistical analysis on trends in the numbers, locations, causes, and characteristics of border-crossing deaths compare to other sources of data on these deaths, including border county medical examiners and coroners and the Centers for Disease Control and Prevention;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s224/c/4","parentIdentifier":"/us/usc/t6/s224/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fc%2F4","sourceRelease":"119-100","text":"how U.S. Customs and Border Protection measures the effectiveness of its programs to mitigate migrant deaths; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s224/c/5","parentIdentifier":"/us/usc/t6/s224/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s224/c/5/A","parentIdentifier":"/us/usc/t6/s224/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fc%2F5%2FA","sourceRelease":"119-100","text":"to accurately identify deceased individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s224/c/5/B","parentIdentifier":"/us/usc/t6/s224/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fc%2F5%2FB","sourceRelease":"119-100","text":"to resolve cases involving unidentified remains;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s224/c/5/C","parentIdentifier":"/us/usc/t6/s224/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fc%2F5%2FC","sourceRelease":"119-100","text":"to resolve cases involving unidentified persons; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s224/c/5/D","parentIdentifier":"/us/usc/t6/s224/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs224%2Fc%2F5%2FD","sourceRelease":"119-100","text":"to share information on missing persons and unidentified remains, specifically with the National Missing and Unidentified Persons System (NamUs).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
