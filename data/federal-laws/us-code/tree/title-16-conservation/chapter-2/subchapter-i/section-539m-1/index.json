s an existing use that, at any time after , is modified or reconfigured but not significantly expanded.February 20, 2003","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Inclusions","label":"B Inclusions","identifier":"/us/usc/t16/s539m–1/7/B","parentIdentifier":"/us/usc/t16/s539m–1/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%931%2F7%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s539m–1/7/B/i","parentIdentifier":"/us/usc/t16/s539m–1/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%931%2F7%2FB%2Fi","sourceRelease":"119-100","text":"a trail or trailhead being modified, such as to accommodate handicapped access;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s539m–1/7/B/ii","parentIdentifier":"/us/usc/t16/s539m–1/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%931%2F7%2FB%2Fii","sourceRelease":"119-100","text":"a parking area being reconfigured (but not expanded); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s539m–1/7/B/iii","parentIdentifier":"/us/usc/t16/s539m–1/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs539m%E2%80%931%2F7%2FB%2Fiii","sourceRelease":"119-100","text":"a special use authorization for a group recreation use being authorized for a different use area or time period.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","headin