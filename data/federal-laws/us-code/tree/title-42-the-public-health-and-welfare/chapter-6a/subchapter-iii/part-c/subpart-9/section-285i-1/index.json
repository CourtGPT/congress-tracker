{"type":"section","nativeType":"section","number":"285i–1","heading":"Clinical research on eye care and diabetes","label":"285i–1 Clinical research on eye care and diabetes","identifier":"/us/usc/t42/s285i–1","parentIdentifier":"/us/usc/t42/ch6A/schIII/ptC/spt9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Program of grants","label":"a Program of grants","identifier":"/us/usc/t42/s285i–1/a","parentIdentifier":"/us/usc/t42/s285i–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s285i–1/a/1","parentIdentifier":"/us/usc/t42/s285i–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fa%2F1","sourceRelease":"119-100","text":"providing comprehensive eye care services for people with diabetes, including a full complement of preventive, diagnostic and treatment procedures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s285i–1/a/2","parentIdentifier":"/us/usc/t42/s285i–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fa%2F2","sourceRelease":"119-100","text":"developing new and improved techniques of patient care through basic and clinical research;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s285i–1/a/3","parentIdentifier":"/us/usc/t42/s285i–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fa%2F3","sourceRelease":"119-100","text":"assisting in translation of the latest research advances into clinical practice; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s285i–1/a/4","parentIdentifier":"/us/usc/t42/s285i–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fa%2F4","sourceRelease":"119-100","text":"expanding the knowledge of the eye and diabetes through further research.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Use of funds","label":"b Use of funds","identifier":"/us/usc/t42/s285i–1/b","parentIdentifier":"/us/usc/t42/s285i–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s285i–1/b/1","parentIdentifier":"/us/usc/t42/s285i–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fb%2F1","sourceRelease":"119-100","text":"Establishing the biochemical, cellular, and genetic mechanisms associated with diabetic eye disease and the earlier detection of pending eye abnormalities. The focus of work under this paragraph shall require that ophthalmologists have training in the most up-to-date molecular and cell biological methods.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s285i–1/b/2","parentIdentifier":"/us/usc/t42/s285i–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s285i–1/b/2/A","parentIdentifier":"/us/usc/t42/s285i–1/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fb%2F2%2FA","sourceRelease":"119-100","text":"provide improved patient care;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s285i–1/b/2/B","parentIdentifier":"/us/usc/t42/s285i–1/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fb%2F2%2FB","sourceRelease":"119-100","text":"provide for the evaluation of retinal physiology and its affect on diabetes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s285i–1/b/2/C","parentIdentifier":"/us/usc/t42/s285i–1/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fb%2F2%2FC","sourceRelease":"119-100","text":"provide for the assessment of risks for the development and progression of diabetic eye disease and a more immediate evaluation of various therapies aimed at preventing diabetic eye disease.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s285i–1/b/3","parentIdentifier":"/us/usc/t42/s285i–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fb%2F3","sourceRelease":"119-100","text":"The translation of the results of vision research into the improved care of patients with diabetic eye disease. Such translation shall require the application of institutional resources that encompass patient care, clinical research and basic laboratory research.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s285i–1/b/4","parentIdentifier":"/us/usc/t42/s285i–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fb%2F4","sourceRelease":"119-100","text":"The conduct of research concerning the outcomes of eye care treatments and eye health education programs as they relate to patients with diabetic eye disease, including the evaluation of regional approaches to such research.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorized expenditures","label":"c Authorized expenditures","identifier":"/us/usc/t42/s285i–1/c","parentIdentifier":"/us/usc/t42/s285i–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs285i%E2%80%931%2Fc","sourceRelease":"119-100","text":"The purposes for which a grant under subsection (a) may be expended include equipment for the research described in such subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
