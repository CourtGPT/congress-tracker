119-100","text":"Endodontics.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t5/s8954/c/7","parentIdentifier":"/us/usc/t5/s8954/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8954%2Fc%2F7","sourceRelease":"119-100","text":"Periodontics.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t5/s8954/c/8","parentIdentifier":"/us/usc/t5/s8954/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8954%2Fc%2F8","sourceRelease":"119-100","text":"Prosthodontics.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t5/s8954/c/9","parentIdentifier":"/us/usc/t5/s8954/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8954%2Fc%2F9","sourceRelease":"119-100","text":"Orthodontics.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t5/s8954/d","parentIdentifier":"/us/usc/t5/s8954","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8954%2Fd","sourceRelease":"119-100","text":"A contract approved under this chapter shall require the qualified company to cover the geographic service delivery area specified by the Office. The Office shall require qualified companies to include dentally underserved areas in their service delivery areas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":null,"label":"e","identifier":"/us/usc/t5/s8954/e","parentIdentifier":"/us/usc/t5/s8954","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs8954%2Fe","sourceRelease":"119-100","text":"If an individual has dental coverage under a health benefits plan under chapter 89 and also has coverage under a plan under this chapter, the health benefits plan under chapter 89 shall be the first payor of any benefit payments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
