{"type":"section","nativeType":"section","number":"2149","heading":"Termination of Oversight Board","label":"2149 Termination of Oversight Board","identifier":"/us/usc/t48/s2149","parentIdentifier":"/us/usc/t48/ch20/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs2149","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t48/s2149/1","parentIdentifier":"/us/usc/t48/s2149","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs2149%2F1","sourceRelease":"119-100","text":"the applicable territorial government has adequate access to short-term and long-term credit markets at reasonable interest rates to meet the borrowing needs of the territorial government; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t48/s2149/2","parentIdentifier":"/us/usc/t48/s2149","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs2149%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t48/s2149/2/A","parentIdentifier":"/us/usc/t48/s2149/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs2149%2F2%2FA","sourceRelease":"119-100","text":"the territorial government has developed its Budgets in accordance with modified accrual accounting standards; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t48/s2149/2/B","parentIdentifier":"/us/usc/t48/s2149/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft48%2Fs2149%2F2%2FB","sourceRelease":"119-100","text":"the expenditures made by the territorial government during each fiscal year did not exceed the revenues of the territorial government during that year, as determined in accordance with modified accrual accounting standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
