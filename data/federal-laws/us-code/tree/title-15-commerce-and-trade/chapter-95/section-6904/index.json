{"type":"section","nativeType":"section","number":"6904","heading":"Qualified organizations","label":"6904 Qualified organizations","identifier":"/us/usc/t15/s6904","parentIdentifier":"/us/usc/t15/ch95","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6904","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s6904/1","parentIdentifier":"/us/usc/t15/s6904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6904%2F1","sourceRelease":"119-100","text":"a nonprofit microenterprise development organization or program (or a group or collaborative thereof) that has a demonstrated record of delivering microenterprise services to disadvantaged entrepreneurs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s6904/2","parentIdentifier":"/us/usc/t15/s6904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6904%2F2","sourceRelease":"119-100","text":"an intermediary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s6904/3","parentIdentifier":"/us/usc/t15/s6904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6904%2F3","sourceRelease":"119-100","text":"a microenterprise development organization or program that is accountable to a local community, working in conjunction with a State or local government or Indian tribe; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s6904/4","parentIdentifier":"/us/usc/t15/s6904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs6904%2F4","sourceRelease":"119-100","text":"an Indian tribe acting on its own, if the Indian tribe can certify that no private organization or program referred to in this paragraph exists within its jurisdiction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
