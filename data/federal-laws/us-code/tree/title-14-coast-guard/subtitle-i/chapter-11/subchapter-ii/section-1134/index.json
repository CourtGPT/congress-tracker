{"type":"section","nativeType":"section","number":"1134","heading":"Acquisition, production, deployment, and support","label":"1134 Acquisition, production, deployment, and support","identifier":"/us/usc/t14/s1134","parentIdentifier":"/us/usc/t14/stI/ch11/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1134","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2018— renumbered as this section.Pub. L. 115–282section 574 of this title"],"amendments":["Amendments2018— renumbered as this section.Pub. L. 115–282section 574 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t14/s1134/a","parentIdentifier":"/us/usc/t14/s1134","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1134%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s1134/a/1","parentIdentifier":"/us/usc/t14/s1134/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1134%2Fa%2F1","sourceRelease":"119-100","text":"ensure there is a stable and efficient production and support capability to develop an asset or capability for the Coast Guard;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s1134/a/2","parentIdentifier":"/us/usc/t14/s1134/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs1134%2Fa%2F2","sourceRelease":"119-100","text":"conduct follow-on testing to confirm and monitor performance and correct deficiencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","id