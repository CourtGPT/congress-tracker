{"type":"section","nativeType":"section","number":"6336","heading":"Restoration of transferred leave","label":"6336 Restoration of transferred leave","identifier":"/us/usc/t5/s6336","parentIdentifier":"/us/usc/t5/ptIII/sptE/ch63/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6336","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s6336/a","parentIdentifier":"/us/usc/t5/s6336","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6336%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6336/a/1","parentIdentifier":"/us/usc/t5/s6336/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6336%2Fa%2F1","sourceRelease":"119-100","text":"The Office of Personnel Management shall establish procedures under which, except as provided in paragraph (2), any transferred leave remaining to the credit of a leave recipient when the medical emergency affecting the leave recipient terminates shall be restored on a prorated basis by transfer to the appropriate accounts of the respective leave donors.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6336/a/2","parentIdentifier":"/us/usc/t5/s6336/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6336%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s6336/a/2/A","parentIdentifier":"/us/usc/t5/s6336/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6336%2Fa%2F2%2FA","sourceRelease":"119-100","text":"if the amount of leave which would be restored to such donor would be less than 1 hour or any other shorter period of time which the Office may by regulation prescribe;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s6336/a/2/B","parentIdentifier":"/us/usc/t5/s6336/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6336%2Fa%2F2%2FB","sourceRelease":"119-100","text":"if such donor retires, dies, or is otherwise separated from service, before the date on which such restoration would otherwise be made; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s6336/a/2/C","parentIdentifier":"/us/usc/t5/s6336/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6336%2Fa%2F2%2FC","sourceRelease":"119-100","text":"if such restoration is not administratively feasible, as determined under regulations prescribed by the Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s6336/b","parentIdentifier":"/us/usc/t5/s6336","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6336%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6336/b/1","parentIdentifier":"/us/usc/t5/s6336/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6336%2Fb%2F1","sourceRelease":"119-100","text":"crediting such leave to the leave donor’s annual leave account in the then current leave year;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6336/b/2","parentIdentifier":"/us/usc/t5/s6336/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6336%2Fb%2F2","sourceRelease":"119-100","text":"crediting such leave to the leave donor’s annual leave account, effective as of the first day of the first leave year beginning after the date of the election; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s6336/b/3","parentIdentifier":"/us/usc/t5/s6336/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6336%2Fb%2F3","sourceRelease":"119-100","text":"donating such leave in whole or part to another leave recipient; if a leave donor elects to donate only part of restored leave to another recipient, the donor may elect to have the remaining leave credited to the donor’s annual leave account in accordance with paragraph (1) or (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t5/s6336/c","parentIdentifier":"/us/usc/t5/s6336","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6336%2Fc","sourceRelease":"119-100","text":"The Office shall prescribe regulations under which this section shall be applied in the case of an employee who is paid other than on the basis of biweekly pay periods.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t5/s6336/d","parentIdentifier":"/us/usc/t5/s6336","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6336%2Fd","sourceRelease":"119-100","text":"Restorations of leave under this section shall be carried out in a manner consistent with regulations prescribed to carry out section 6334(c), if applicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
