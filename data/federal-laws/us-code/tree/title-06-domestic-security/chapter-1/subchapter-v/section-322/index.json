{"type":"section","nativeType":"section","number":"322","heading":"Continuity of the economy plan","label":"322 Continuity of the economy plan","identifier":"/us/usc/t6/s322","parentIdentifier":"/us/usc/t6/ch1/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021, and not as part of the Homeland Security Act of 2002 which comprises this chapter.","Statutory Notes and Related Subsidiaries","Change of NameCommittee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, .Jan. 9, 2023"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Requirement","label":"a Requirement","identifier":"/us/usc/t6/s322/a","parentIdentifier":"/us/usc/t6/s322","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s322/a/1","parentIdentifier":"/us/usc/t6/s322/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F1","sourceRelease":"119-100","text":"The President shall develop and maintain a plan to maintain and restore the economy of the United States in response to a significant event.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Principles","label":"2 Principles","identifier":"/us/usc/t6/s322/a/2","parentIdentifier":"/us/usc/t6/s322/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s322/a/2/A","parentIdentifier":"/us/usc/t6/s322/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s322/a/2/A/i","parentIdentifier":"/us/usc/t6/s322/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"a free market economy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s322/a/2/A/ii","parentIdentifier":"/us/usc/t6/s322/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the rule of law; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s322/a/2/B","parentIdentifier":"/us/usc/t6/s322/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F2%2FB","sourceRelease":"119-100","text":"respect private property rights.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Contents","label":"3 Contents","identifier":"/us/usc/t6/s322/a/3","parentIdentifier":"/us/usc/t6/s322/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s322/a/3/A","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FA","sourceRelease":"119-100","text":"examine the distribution of goods and services across the United States necessary for the reliable functioning of the United States during a significant event;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s322/a/3/B","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s322/a/3/B/i","parentIdentifier":"/us/usc/t6/s322/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FB%2Fi","sourceRelease":"119-100","text":"security;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s322/a/3/B/ii","parentIdentifier":"/us/usc/t6/s322/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FB%2Fii","sourceRelease":"119-100","text":"economic security;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t6/s322/a/3/B/iii","parentIdentifier":"/us/usc/t6/s322/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"defense readiness; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t6/s322/a/3/B/iv","parentIdentifier":"/us/usc/t6/s322/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FB%2Fiv","sourceRelease":"119-100","text":"public health or safety;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s322/a/3/C","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s322/a/3/C/i","parentIdentifier":"/us/usc/t6/s322/a/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FC%2Fi","sourceRelease":"119-100","text":"bulk power and electric transmission systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s322/a/3/C/ii","parentIdentifier":"/us/usc/t6/s322/a/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FC%2Fii","sourceRelease":"119-100","text":"national and international financial systems, including wholesale payments, stocks, and currency exchanges;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t6/s322/a/3/C/iii","parentIdentifier":"/us/usc/t6/s322/a/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FC%2Fiii","sourceRelease":"119-100","text":"national and international communications networks, data-hosting services, and cloud services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t6/s322/a/3/C/iv","parentIdentifier":"/us/usc/t6/s322/a/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FC%2Fiv","sourceRelease":"119-100","text":"interstate oil and natural gas pipelines; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t6/s322/a/3/C/v","parentIdentifier":"/us/usc/t6/s322/a/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FC%2Fv","sourceRelease":"119-100","text":"mechanisms for the interstate and international trade and distribution of materials, food, and medical supplies, including road, rail, air, and maritime shipping;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s322/a/3/D","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s322/a/3/D/i","parentIdentifier":"/us/usc/t6/s322/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FD%2Fi","sourceRelease":"119-100","text":"catastrophic economic loss;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s322/a/3/D/ii","parentIdentifier":"/us/usc/t6/s322/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FD%2Fii","sourceRelease":"119-100","text":"the loss of public confidence; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t6/s322/a/3/D/iii","parentIdentifier":"/us/usc/t6/s322/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FD%2Fiii","sourceRelease":"119-100","text":"the widespread imperilment of human life;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t6/s322/a/3/E","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FE","sourceRelease":"119-100","text":"identify the economic functions of relevant actors that are so vital to the economy of the United States that the disruption, corruption, or dysfunction of those economic functions would undermine response, recovery, or mobilization efforts during a significant event;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t6/s322/a/3/F","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FF","sourceRelease":"119-100","text":"incorporate, to the greatest extent practicable, the principles and practices contained within Federal plans for the continuity of Government and continuity of operations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t6/s322/a/3/G","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FG","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s322/a/3/G/i","parentIdentifier":"/us/usc/t6/s322/a/3/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FG%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t6/s322/a/3/G/i/I","parentIdentifier":"/us/usc/t6/s322/a/3/G/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FG%2Fi%2FI","sourceRelease":"119-100","text":"security;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t6/s322/a/3/G/i/II","parentIdentifier":"/us/usc/t6/s322/a/3/G/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FG%2Fi%2FII","sourceRelease":"119-100","text":"economic security;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t6/s322/a/3/G/i/III","parentIdentifier":"/us/usc/t6/s322/a/3/G/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FG%2Fi%2FIII","sourceRelease":"119-100","text":"defense readiness; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t6/s322/a/3/G/i/IV","parentIdentifier":"/us/usc/t6/s322/a/3/G/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FG%2Fi%2FIV","sourceRelease":"119-100","text":"public health or safety; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s322/a/3/G/ii","parentIdentifier":"/us/usc/t6/s322/a/3/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FG%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t6/s322/a/3/G/ii/I","parentIdentifier":"/us/usc/t6/s322/a/3/G/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FG%2Fii%2FI","sourceRelease":"119-100","text":"the installation of parallel services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t6/s322/a/3/G/ii/II","parentIdentifier":"/us/usc/t6/s322/a/3/G/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FG%2Fii%2FII","sourceRelease":"119-100","text":"the use of stand-alone analog services; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t6/s322/a/3/G/ii/III","parentIdentifier":"/us/usc/t6/s322/a/3/G/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FG%2Fii%2FIII","sourceRelease":"119-100","text":"the significant hardening of the industrial control network against failure, disruption, corruption, or dysfunction;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t6/s322/a/3/H","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FH","sourceRelease":"119-100","text":"identify critical economic sectors for which the preservation of data in a protected, verified, and uncorrupted status would be required for the quick recovery of the economy of the United States in the face of a significant disruption following a significant event;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t6/s322/a/3/I","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FI","sourceRelease":"119-100","text":"include a list of raw materials, industrial goods, and other items, the absence of which would significantly undermine the ability of the United States to sustain the functions described in subparagraphs (B), (D), and (E);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t6/s322/a/3/J","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FJ","sourceRelease":"119-100","text":"provide an analysis of supply chain diversification for the items described in subparagraph (I) in the event of a disruption caused by a significant event;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"K","heading":null,"label":"K","identifier":"/us/usc/t6/s322/a/3/K","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FK","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s322/a/3/K/i","parentIdentifier":"/us/usc/t6/s322/a/3/K","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FK%2Fi","sourceRelease":"119-100","text":"a recommendation as to whether the United States should maintain a strategic reserve of 1 or more of the items described in subparagraph (I); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s322/a/3/K/ii","parentIdentifier":"/us/usc/t6/s322/a/3/K","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FK%2Fii","sourceRelease":"119-100","text":"for each item described in subparagraph (I) for which the President recommends maintaining a strategic reserve under clause (i), an identification of mechanisms for tracking inventory and availability of the item in the strategic reserve;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"L","heading":null,"label":"L","identifier":"/us/usc/t6/s322/a/3/L","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FL","sourceRelease":"119-100","text":"identify mechanisms in existence on and mechanisms that can be developed to ensure that the swift transport and delivery of the items described in subparagraph (I) is feasible in the event of a distribution network disturbance or degradation, including a distribution network disturbance or degradation caused by a significant event;January 1, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"M","heading":null,"label":"M","identifier":"/us/usc/t6/s322/a/3/M","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FM","sourceRelease":"119-100","text":"include guidance for determining the prioritization for the distribution of the items described in subparagraph (I), including distribution to States and Indian Tribes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"N","heading":null,"label":"N","identifier":"/us/usc/t6/s322/a/3/N","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FN","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s322/a/3/N/i","parentIdentifier":"/us/usc/t6/s322/a/3/N","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FN%2Fi","sourceRelease":"119-100","text":"is necessary to avoid severe economic degradation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s322/a/3/N/ii","parentIdentifier":"/us/usc/t6/s322/a/3/N","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FN%2Fii","sourceRelease":"119-100","text":"allows for the recovery from a significant event;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"O","heading":null,"label":"O","identifier":"/us/usc/t6/s322/a/3/O","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FO","sourceRelease":"119-100","text":"include guidance for determining categories of employees that should be prioritized to continue to work in order to sustain the functions described in subparagraphs (B), (D), and (E) in the event that there are limitations on the ability of individuals to travel to workplaces or to work remotely, including considerations for defense readiness;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"P","heading":null,"label":"P","identifier":"/us/usc/t6/s322/a/3/P","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FP","sourceRelease":"119-100","text":"identify critical economic sectors necessary to provide material and operational support to the defense of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"Q","heading":null,"label":"Q","identifier":"/us/usc/t6/s322/a/3/Q","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FQ","sourceRelease":"119-100","text":"determine whether the Secretary of Homeland Security, the National Guard, and the Secretary of Defense have adequate authority to assist the United States in a recovery from a severe economic degradation caused by a significant event;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"R","heading":null,"label":"R","identifier":"/us/usc/t6/s322/a/3/R","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FR","sourceRelease":"119-100","text":"review and assess the authority and capability of heads of other agencies that the President determines necessary to assist the United States in a recovery from a severe economic degradation caused by a significant event; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"S","heading":null,"label":"S","identifier":"/us/usc/t6/s322/a/3/S","parentIdentifier":"/us/usc/t6/s322/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fa%2F3%2FS","sourceRelease":"119-100","text":"consider any other matter that would aid in protecting and increasing the resilience of the economy of the United States from a significant event.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Coordination","label":"b Coordination","identifier":"/us/usc/t6/s322/b","parentIdentifier":"/us/usc/t6/s322","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s322/b/1","parentIdentifier":"/us/usc/t6/s322/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s322/b/1/A","parentIdentifier":"/us/usc/t6/s322/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the Secretary of Homeland Security;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s322/b/1/B","parentIdentifier":"/us/usc/t6/s322/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the Secretary of Defense;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s322/b/1/C","parentIdentifier":"/us/usc/t6/s322/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs322%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the Secretary of the Treasury;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","headin