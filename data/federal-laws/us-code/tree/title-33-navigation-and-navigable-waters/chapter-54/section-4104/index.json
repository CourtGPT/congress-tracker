{"type":"section","nativeType":"section","number":"4104","heading":"Acquisition of unmanned maritime systems","label":"4104 Acquisition of unmanned maritime systems","identifier":"/us/usc/t33/s4104","parentIdentifier":"/us/usc/t33/ch54","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4104","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t33/s4104/a","parentIdentifier":"/us/usc/t33/s4104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4104%2Fa","sourceRelease":"119-100","text":"The Administrator shall coordinate and centralize the acquisition by the Administration of unmanned maritime systems to meet the prioritized list of data requirements identified by OAR and OMAO in carrying out this chapter in their regular assessments and approved by the USEOB.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Memoranda of understanding","label":"b Memoranda of understanding","identifier":"/us/usc/t33/s4104/b","parentIdentifier":"/us/usc/t33/s4104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4104%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s4104/b/1","parentIdentifier":"/us/usc/t33/s4104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4104%2Fb%2F1","sourceRelease":"119-100","text":"participate in procurements conducted by the signatories to the memorandum of understanding;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s4104/b/2","parentIdentifier":"/us/usc/t33/s4104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4104%2Fb%2F2","sourceRelease":"119-100","text":"accept decommissioned unmanned maritime systems from the Navy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s4104/b/3","parentIdentifier":"/us/usc/t33/s4104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4104%2Fb%2F3","sourceRelease":"119-100","text":"develop policies and procedures to share unmanned maritime systems; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s4104/b/4","parentIdentifier":"/us/usc/t33/s4104/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4104%2Fb%2F4","sourceRelease":"119-100","text":"provide for other means of creating efficiency and savings in Federal acquisition of unmanned maritime systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Rule of construction","label":"c Rule of construction","identifier":"/us/usc/t33/s4104/c","parentIdentifier":"/us/usc/t33/s4104","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4104%2Fc","sourceRelease":"119-100","text":"Nothing in this chapter shall be construed to modify Federal procurement law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
