{"type":"section","nativeType":"section","number":"1922B","heading":"Service-disabled veterans insurance","label":"1922B Service-disabled veterans insurance","identifier":"/us/usc/t38/s1922B","parentIdentifier":"/us/usc/t38/ptII/ch19/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Insurance","label":"a .—Insurance","identifier":"/us/usc/t38/s1922B/a","parentIdentifier":"/us/usc/t38/s1922B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1922B/a/1","parentIdentifier":"/us/usc/t38/s1922B/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F1","sourceRelease":"119-100","text":"Beginning , the Secretary shall carry out a service-disabled veterans insurance program under which a veteran is granted insurance by the United States against the death of such individual occurring while such insurance is in force.January 1, 2023","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1922B/a/2","parentIdentifier":"/us/usc/t38/s1922B/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F2","sourceRelease":"119-100","text":"The Secretary may only issue whole-life policies under the insurance program under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1922B/a/3","parentIdentifier":"/us/usc/t38/s1922B/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1922B/a/3/A","parentIdentifier":"/us/usc/t38/s1922B/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F3%2FA","sourceRelease":"119-100","text":"the veteran submits the application for such insurance before the veteran attains 81 years of age; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1922B/a/3/B","parentIdentifier":"/us/usc/t38/s1922B/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t38/s1922B/a/3/B/i","parentIdentifier":"/us/usc/t38/s1922B/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F3%2FB%2Fi","sourceRelease":"119-100","text":"the veteran filed a claim for compensation under chapter 11 of this title before attaining such age;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t38/s1922B/a/3/B/ii","parentIdentifier":"/us/usc/t38/s1922B/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F3%2FB%2Fii","sourceRelease":"119-100","text":"based on such claim, and after the veteran attained such age, the Secretary first determines that the veteran has a service-connected disability; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t38/s1922B/a/3/B/iii","parentIdentifier":"/us/usc/t38/s1922B/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"the veteran submits the application for such insurance during the two-year period following the date of such determination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s1922B/a/4","parentIdentifier":"/us/usc/t38/s1922B/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1922B/a/4/A","parentIdentifier":"/us/usc/t38/s1922B/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t38/s1922B/a/4/A/i","parentIdentifier":"/us/usc/t38/s1922B/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F4%2FA%2Fi","sourceRelease":"119-100","text":"$10,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t38/s1922B/a/4/A/ii","parentIdentifier":"/us/usc/t38/s1922B/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F4%2FA%2Fii","sourceRelease":"119-100","text":"$20,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t38/s1922B/a/4/A/iii","parentIdentifier":"/us/usc/t38/s1922B/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F4%2FA%2Fiii","sourceRelease":"119-100","text":"$30,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t38/s1922B/a/4/A/iv","parentIdentifier":"/us/usc/t38/s1922B/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F4%2FA%2Fiv","sourceRelease":"119-100","text":"$40,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t38/s1922B/a/4/A/v","parentIdentifier":"/us/usc/t38/s1922B/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F4%2FA%2Fv","sourceRelease":"119-100","text":"In accordance with subparagraph (B), a maximum amount greater than $40,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1922B/a/4/B","parentIdentifier":"/us/usc/t38/s1922B/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t38/s1922B/a/4/B/i","parentIdentifier":"/us/usc/t38/s1922B/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F4%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t38/s1922B/a/4/B/i/I","parentIdentifier":"/us/usc/t38/s1922B/a/4/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F4%2FB%2Fi%2FI","sourceRelease":"119-100","text":"are administratively and actuarially sound for the insurance program under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t38/s1922B/a/4/B/i/II","parentIdentifier":"/us/usc/t38/s1922B/a/4/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F4%2FB%2Fi%2FII","sourceRelease":"119-100","text":"will not result in such program operating at a loss; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t38/s1922B/a/4/B/ii","parentIdentifier":"/us/usc/t38/s1922B/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F4%2FB%2Fii","sourceRelease":"119-100","text":"publishes in the Federal Register, and submits to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives, such maximum amount and determination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t38/s1922B/a/5","parentIdentifier":"/us/usc/t38/s1922B/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1922B/a/5/A","parentIdentifier":"/us/usc/t38/s1922B/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F5%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t38/s1922B/a/5/A/i","parentIdentifier":"/us/usc/t38/s1922B/a/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F5%2FA%2Fi","sourceRelease":"119-100","text":"Insurance granted under this section shall be on a nonparticipating basis and all premiums and other collections therefor shall be credited directly to a revolving fund in the Treasury of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t38/s1922B/a/5/A/ii","parentIdentifier":"/us/usc/t38/s1922B/a/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F5%2FA%2Fii","sourceRelease":"119-100","text":"Any payments on such insurance shall be made directly from such fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1922B/a/5/B","parentIdentifier":"/us/usc/t38/s1922B/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F5%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t38/s1922B/a/5/B/i","parentIdentifier":"/us/usc/t38/s1922B/a/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F5%2FB%2Fi","sourceRelease":"119-100","text":"The Secretary of the Treasury may invest in and sell and retire special interest-bearing obligations of the United States for the account of the revolving fund under subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t38/s1922B/a/5/B/ii","parentIdentifier":"/us/usc/t38/s1922B/a/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F5%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t38/s1922B/a/5/B/ii/I","parentIdentifier":"/us/usc/t38/s1922B/a/5/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F5%2FB%2Fii%2FI","sourceRelease":"119-100","text":"have maturities fixed with due regard for the needs of the fund; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t38/s1922B/a/5/B/ii/II","parentIdentifier":"/us/usc/t38/s1922B/a/5/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F5%2FB%2Fii%2FII","sourceRelease":"119-100","text":"bear interest at a rate equal to the average market yield (computed by the Secretary of the Treasury on the basis of market quotations as of the end of the calendar month preceding the date of issue) on all marketable interest-bearing obligations of the United States then forming a part of the public debt which are not due or callable until after the expiration of four years from the end of such calendar month; except that where such average market yield is not a multiple of one-eighth of one per centum, the rate of interest of such obligation shall be the multiple of one-eighth of one per centum nearest such market yield.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t38/s1922B/a/6","parentIdentifier":"/us/usc/t38/s1922B/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1922B/a/6/A","parentIdentifier":"/us/usc/t38/s1922B/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F6%2FA","sourceRelease":"119-100","text":"Administrative support financed by the appropriations for “General Operating Expenses, Department of Veterans Affairs” and “Information Technology Systems, Department of Veterans Affairs” for the insurance program under paragraph (1) shall be paid from premiums credited to the fund under paragraph (5).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1922B/a/6/B","parentIdentifier":"/us/usc/t38/s1922B/a/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fa%2F6%2FB","sourceRelease":"119-100","text":"Such payment for administrative support shall be reimbursed for that fiscal year from funds that are available on such insurance after claims have been paid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Eligibility","label":"b .—Eligibility","identifier":"/us/usc/t38/s1922B/b","parentIdentifier":"/us/usc/t38/s1922B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1922B/b/1","parentIdentifier":"/us/usc/t38/s1922B/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fb%2F1","sourceRelease":"119-100","text":"whether such disability is compensable under chapter 11 of this title; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1922B/b/2","parentIdentifier":"/us/usc/t38/s1922B/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fb%2F2","sourceRelease":"119-100","text":"whether the veteran meets standards of good health required for other life insurance policies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Enrollment and Waiting Period","label":"c .—Enrollment and Waiting Period","identifier":"/us/usc/t38/s1922B/c","parentIdentifier":"/us/usc/t38/s1922B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1922B/c/1","parentIdentifier":"/us/usc/t38/s1922B/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fc%2F1","sourceRelease":"119-100","text":"An eligible veteran may enroll in the insurance program under subsection (a)(1) at any time.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1922B/c/2","parentIdentifier":"/us/usc/t38/s1922B/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1922B/c/2/A","parentIdentifier":"/us/usc/t38/s1922B/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fc%2F2%2FA","sourceRelease":"119-100","text":"a period of two years elapses following the date of such enrollment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1922B/c/2/B","parentIdentifier":"/us/usc/t38/s1922B/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the veteran pays the premiums required during such two-year period.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1922B/c/3","parentIdentifier":"/us/usc/t38/s1922B/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1922B/c/3/A","parentIdentifier":"/us/usc/t38/s1922B/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fc%2F3%2FA","sourceRelease":"119-100","text":"If a veteran dies during the two-year period described in paragraph (2), the Secretary shall pay to the beneficiary of the veteran the amount of premiums paid by the veteran under this section, plus interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1922B/c/3/B","parentIdentifier":"/us/usc/t38/s1922B/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t38/s1922B/c/3/B/i","parentIdentifier":"/us/usc/t38/s1922B/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t38/s1922B/c/3/B/i/I","parentIdentifier":"/us/usc/t38/s1922B/c/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fc%2F3%2FB%2Fi%2FI","sourceRelease":"119-100","text":"shall set such interest at a rate of one percent; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t38/s1922B/c/3/B/i/II","parentIdentifier":"/us/usc/t38/s1922B/c/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fc%2F3%2FB%2Fi%2FII","sourceRelease":"119-100","text":"may adjust such rate during such year based on program experience, except that the interest rate may not be less than zero percent;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t38/s1922B/c/3/B/ii","parentIdentifier":"/us/usc/t38/s1922B/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":"for the second and each subsequent year of the program, shall calculate such interest at an annual rate equal to the rate of return on the revolving fund under subsection (a)(5) for the calendar year preceding the year of the veteran’s death, except that the interest rate may not be less than zero percent; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t38/s1922B/c/3/B/iii","parentIdentifier":"/us/usc/t38/s1922B/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fc%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"on an annual basis, shall publish on the internet website of the Department the average interest rate calculated under clause (ii) for the preceding calendar year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Premiums","label":"d .—Premiums","identifier":"/us/usc/t38/s1922B/d","parentIdentifier":"/us/usc/t38/s1922B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1922B/d/1","parentIdentifier":"/us/usc/t38/s1922B/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary shall establish a schedule of basic premium rates by age per $10,000 of insurance under subsection (a)(1) consistent with basic premium rates generally charged for guaranteed acceptance life insurance policies by private life insurance companies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1922B/d/2","parentIdentifier":"/us/usc/t38/s1922B/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fd%2F2","sourceRelease":"119-100","text":"The Secretary may adjust such schedule after the first policy year in a manner consistent with the general practice of guaranteed acceptance life insurance policies issued by private life insurance companies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1922B/d/3","parentIdentifier":"/us/usc/t38/s1922B/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fd%2F3","sourceRelease":"119-100","text":"shall not apply to life insurance policies under subsection (a)(1), and the Secretary may not otherwise waive premiums for such insurance policies.Section 1912 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Beneficiaries","label":"e .—Beneficiaries","identifier":"/us/usc/t38/s1922B/e","parentIdentifier":"/us/usc/t38/s1922B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1922B/e/1","parentIdentifier":"/us/usc/t38/s1922B/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fe%2F1","sourceRelease":"119-100","text":"A veteran who enrolls in the insurance program under subsection (a)(1) may designate a beneficiary of the life insurance policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1922B/e/2","parentIdentifier":"/us/usc/t38/s1922B/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1922B/e/2/A","parentIdentifier":"/us/usc/t38/s1922B/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fe%2F2%2FA","sourceRelease":"119-100","text":"The surviving spouse of the veteran.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1922B/e/2/B","parentIdentifier":"/us/usc/t38/s1922B/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fe%2F2%2FB","sourceRelease":"119-100","text":"The children of the veteran and descendants of deceased children by representation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s1922B/e/2/C","parentIdentifier":"/us/usc/t38/s1922B/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fe%2F2%2FC","sourceRelease":"119-100","text":"The parents of the veteran or the survivors of the parents.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t38/s1922B/e/2/D","parentIdentifier":"/us/usc/t38/s1922B/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fe%2F2%2FD","sourceRelease":"119-100","text":"The duly appointed executor or administrator of the estate of the veteran.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t38/s1922B/e/2/E","parentIdentifier":"/us/usc/t38/s1922B/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fe%2F2%2FE","sourceRelease":"119-100","text":"Other next of kin of the veteran entitled under the laws of domicile of the veteran at the time of the death of the veteran.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":".—Claims","label":"f .—Claims","identifier":"/us/usc/t38/s1922B/f","parentIdentifier":"/us/usc/t38/s1922B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1922B/f/1","parentIdentifier":"/us/usc/t38/s1922B/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Ff%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1922B/f/1/A","parentIdentifier":"/us/usc/t38/s1922B/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Ff%2F1%2FA","sourceRelease":"119-100","text":"the designated beneficiary is the only person who may file a claim for payment under subsection (g) during the one-year period beginning on the date of the death of the veteran; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1922B/f/1/B","parentIdentifier":"/us/usc/t38/s1922B/f/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Ff%2F1%2FB","sourceRelease":"119-100","text":"if the designated beneficiary does not file a claim for the payment during the period described in paragraph (1), or if payment to the designated beneficiary within that period is prohibited by Federal statute or regulation, a beneficiary described in subsection (e)(2) may file a claim for such payment during the one-year period following the period described in subparagraph (A) as if the designated beneficiary had predeceased the veteran.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1922B/f/2","parentIdentifier":"/us/usc/t38/s1922B/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Ff%2F2","sourceRelease":"119-100","text":"If the deceased veteran did not designate a beneficiary under subsection (e)(1), or if the designated beneficiary predeceased the veteran, a beneficiary described in subsection (e)(2) may file a claim for payment under subsection (g) during the two-year period beginning on the date of the death of the veteran.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1922B/f/3","parentIdentifier":"/us/usc/t38/s1922B/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Ff%2F3","sourceRelease":"119-100","text":"If, on the date that is two years after the date of the death of the veteran, no claim for payment has been filed by any beneficiary pursuant to paragraph (1) or (2), and the Secretary has not received notice that any such claim will be so filed during the subsequent one-year period, the Secretary may make the payment to a claimant whom the Secretary determines to be equitably entitled to such payment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":".—Payments","label":"g .—Payments","identifier":"/us/usc/t38/s1922B/g","parentIdentifier":"/us/usc/t38/s1922B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t38/s1922B/g/1","parentIdentifier":"/us/usc/t38/s1922B/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fg%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t38/s1922B/g/1/A","parentIdentifier":"/us/usc/t38/s1922B/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fg%2F1%2FA","sourceRelease":"119-100","text":"in paragraph (1)(A), the Secretary shall pay the designated beneficiary not later than 90 days after the designated beneficiary files a complete and valid claim for payment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t38/s1922B/g/1/B","parentIdentifier":"/us/usc/t38/s1922B/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fg%2F1%2FB","sourceRelease":"119-100","text":"in paragraph (1)(B) or (2), the Secretary shall make any payment not later than one year after the end of the period described in the applicable such paragraph, if the Secretary receives a complete and valid claim for payment in accordance with the applicable such paragraph; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t38/s1922B/g/1/C","parentIdentifier":"/us/usc/t38/s1922B/g/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fg%2F1%2FC","sourceRelease":"119-100","text":"in paragraph (3), the Secretary shall make any payment not later than one year after the end of the period described in such paragraph, if the Secretary receives a complete and valid claim for payment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t38/s1922B/g/2","parentIdentifier":"/us/usc/t38/s1922B/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fg%2F2","sourceRelease":"119-100","text":"In a case where the Secretary has not made an insurance payment under this section during the applicable period specified in paragraph (1) by reason of a beneficiary not yet having filed a claim, or the Secretary not yet making a determination under subsection (f)(3), the Secretary may make the payment after such applicable period.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t38/s1922B/g/3","parentIdentifier":"/us/usc/t38/s1922B/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fg%2F3","sourceRelease":"119-100","text":"Notwithstanding , the Secretary shall make an insurance payment under this section in a lump sum.section 1917 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t38/s1922B/g/4","parentIdentifier":"/us/usc/t38/s1922B/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fg%2F4","sourceRelease":"119-100","text":"The Secretary may not make an insurance payment under this section if such payment will escheat to a State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t38/s1922B/g/5","parentIdentifier":"/us/usc/t38/s1922B/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft38%2Fs1922B%2Fg%2F5","sourceRelease":"119-100","text":"Any payment under this subsection shall be a bar to recovery by any other person.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
