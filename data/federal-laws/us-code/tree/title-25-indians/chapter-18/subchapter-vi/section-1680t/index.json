{"type":"section","nativeType":"section","number":"1680t","heading":"Other GAO reports","label":"1680t Other GAO reports","identifier":"/us/usc/t25/s1680t","parentIdentifier":"/us/usc/t25/ch18/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Codificationis based on section 199 of title I of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by .Section 830 of Pub. L. 94–437section 10221(a) of Pub. L. 111–148"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Coordination of services","label":"a Coordination of services","identifier":"/us/usc/t25/s1680t/a","parentIdentifier":"/us/usc/t25/s1680t","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Study and evaluation","label":"1 Study and evaluation","identifier":"/us/usc/t25/s1680t/a/1","parentIdentifier":"/us/usc/t25/s1680t/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1680t/a/1/A","parentIdentifier":"/us/usc/t25/s1680t/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fa%2F1%2FA","sourceRelease":"119-100","text":"through Medicare, Medicaid, or SCHIP;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1680t/a/1/B","parentIdentifier":"/us/usc/t25/s1680t/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fa%2F1%2FB","sourceRelease":"119-100","text":"by the Service; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1680t/a/1/C","parentIdentifier":"/us/usc/t25/s1680t/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fa%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s1680t/a/1/C/i","parentIdentifier":"/us/usc/t25/s1680t/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fa%2F1%2FC%2Fi","sourceRelease":"119-100","text":"State or local governments; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s1680t/a/1/C/ii","parentIdentifier":"/us/usc/t25/s1680t/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fa%2F1%2FC%2Fii","sourceRelease":"119-100","text":"Indian tribes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report","label":"2 Report","identifier":"/us/usc/t25/s1680t/a/2","parentIdentifier":"/us/usc/t25/s1680t/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1680t/a/2/A","parentIdentifier":"/us/usc/t25/s1680t/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fa%2F2%2FA","sourceRelease":"119-100","text":"describing the results of the evaluation under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1680t/a/2/B","parentIdentifier":"/us/usc/t25/s1680t/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fa%2F2%2FB","sourceRelease":"119-100","text":"containing recommendations of the Comptroller General regarding measures to support and increase coordination of the provision of health care services to Indians as described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Payments for contract health services","label":"b Payments for contract health services","identifier":"/us/usc/t25/s1680t/b","parentIdentifier":"/us/usc/t25/s1680t","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t25/s1680t/b/1","parentIdentifier":"/us/usc/t25/s1680t/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fb%2F1","sourceRelease":"119-100","text":"The Comptroller General shall conduct a study on the use of health care furnished by health care providers under the contract health services program funded by the Service and operated by the Service, an Indian tribe, or a tribal organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Analysis","label":"2 Analysis","identifier":"/us/usc/t25/s1680t/b/2","parentIdentifier":"/us/usc/t25/s1680t/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1680t/b/2/A","parentIdentifier":"/us/usc/t25/s1680t/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the amounts reimbursed under the contract health services program described in paragraph (1) for health care furnished by entities, individual providers, and suppliers, including a comparison of reimbursement for that health care through other public programs and in the private sector;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1680t/b/2/B","parentIdentifier":"/us/usc/t25/s1680t/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fb%2F2%2FB","sourceRelease":"119-100","text":"barriers to accessing care under such contract health services program, including barriers relating to travel distances, cultural differences, and public and private sector reluctance to furnish care to patients under the program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1680t/b/2/C","parentIdentifier":"/us/usc/t25/s1680t/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fb%2F2%2FC","sourceRelease":"119-100","text":"the adequacy of existing Federal funding for health care under the contract health services program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s1680t/b/2/D","parentIdentifier":"/us/usc/t25/s1680t/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fb%2F2%2FD","sourceRelease":"119-100","text":"the administration of the contract health service program, including the distribution of funds to Indian health programs pursuant to the program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t25/s1680t/b/2/E","parentIdentifier":"/us/usc/t25/s1680t/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fb%2F2%2FE","sourceRelease":"119-100","text":"any other items determined appropriate by the Comptroller General.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Report","label":"3 Report","identifier":"/us/usc/t25/s1680t/b/3","parentIdentifier":"/us/usc/t25/s1680t/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s1680t/b/3/A","parentIdentifier":"/us/usc/t25/s1680t/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the appropriate level of Federal funding that should be established for health care under the contract health services program described in paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s1680t/b/3/B","parentIdentifier":"/us/usc/t25/s1680t/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fb%2F3%2FB","sourceRelease":"119-100","text":"how to most efficiently use that funding; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s1680t/b/3/C","parentIdentifier":"/us/usc/t25/s1680t/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fb%2F3%2FC","sourceRelease":"119-100","text":"the identification of any inequities in the current distribution formula or inequitable results for any Indian tribe under the funding level, and any recommendations for addressing any inequities or inequitable results identified.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Consultation","label":"4 Consultation","identifier":"/us/usc/t25/s1680t/b/4","parentIdentifier":"/us/usc/t25/s1680t/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs1680t%2Fb%2F4","sourceRelease":"119-100","text":"In conducting the study under paragraph (1) and preparing the report under paragraph (3), the Comptroller General shall consult with the Service, Indian tribes, and tribal organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
