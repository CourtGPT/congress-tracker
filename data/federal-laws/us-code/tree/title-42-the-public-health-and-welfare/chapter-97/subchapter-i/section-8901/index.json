{"type":"section","nativeType":"section","number":"8901","heading":"Introductory provisions","label":"8901 Introductory provisions","identifier":"/us/usc/t42/s8901","parentIdentifier":"/us/usc/t42/ch97/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8901","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Short TitleSection 701 of title VII provided that:Pub. L. 96–294“This title [enacting this chapter] may be cited as the ‘Acid Precipitation Act of 1980’.”"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Congressional statement of findings and purpose","label":"a Congressional statement of findings and purpose","identifier":"/us/usc/t42/s8901/a","parentIdentifier":"/us/usc/t42/s8901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8901%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s8901/a/1","parentIdentifier":"/us/usc/t42/s8901/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8901%2Fa%2F1","sourceRelease":"119-100","text":"could contribute to the increasing pollution of natural and man-made water systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s8901/a/2","parentIdentifier":"/us/usc/t42/s8901/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8901%2Fa%2F2","sourceRelease":"119-100","text":"could adversely affect agricultural and forest crops;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s8901/a/3","parentIdentifier":"/us/usc/t42/s8901/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8901%2Fa%2F3","sourceRelease":"119-100","text":"could adversely affect fish and wildlife and natural ecosystems generally;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s8901/a/4","parentIdentifier":"/us/usc/t42/s8901/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8901%2Fa%2F4","sourceRelease":"119-100","text":"could contribute to corrosion of metals, wood, paint, and masonry used in construction and ornamentation of buildings and public monuments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s8901/a/5","parentIdentifier":"/us/usc/t42/s8901/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8901%2Fa%2F5","sourceRelease":"119-100","text":"could adversely affect public health and welfare; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s8901/a/6","parentIdentifier":"/us/usc/t42/s8901/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8901%2Fa%2F6","sourceRelease":"119-100","text":"could affect areas distant from sources and thus involve issues of national and international policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Congressional declaration of purpose","label":"b Congressional declaration of purpose","identifier":"/us/usc/t42/s8901/b","parentIdentifier":"/us/usc/t42/s8901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8901%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s8901/b/1","parentIdentifier":"/us/usc/t42/s8901/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8901%2Fb%2F1","sourceRelease":"119-100","text":"to identify the causes and sources of acid precipitation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s8901/b/2","parentIdentifier":"/us/usc/t42/s8901/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8901%2Fb%2F2","sourceRelease":"119-100","text":"to evaluate the environmental, social, and economic effects of acid precipitation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s8901/b/3","parentIdentifier":"/us/usc/t42/s8901/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8901%2Fb%2F3","sourceRelease":"119-100","text":"based on the results of the research program established by this subchapter and to the extent consistent with existing law, to take action to the extent necessary and practicable (A) to limit or eliminate the identified emissions which are sources of acid precipitation, and (B) to remedy or otherwise ameliorate the harmful effects which may result from acid precipitation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"“Acid precipitation” defined","label":"c “Acid precipitation” defined","identifier":"/us/usc/t42/s8901/c","parentIdentifier":"/us/usc/t42/s8901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs8901%2Fc","sourceRelease":"119-100","text":"For purposes of this subchapter the term “acid precipitation” means the wet or dry deposition from the atmosphere of acid chemical compounds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
