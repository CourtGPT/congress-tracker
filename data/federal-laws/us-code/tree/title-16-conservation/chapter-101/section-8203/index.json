":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s8203/a/2/C","parentIdentifier":"/us/usc/t16/s8203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FC","sourceRelease":"119-100","text":"1 shall be a representative of the Department of Commerce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s8203/a/2/D","parentIdentifier":"/us/usc/t16/s8203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FD","sourceRelease":"119-100","text":"1 shall be a representative of the Department of Agriculture;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s8203/a/2/E","parentIdentifier":"/us/usc/t16/s8203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FE","sourceRelease":"119-100","text":"1 shall be a representative of the Association of Fish and Wildlife Agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t16/s8203/a/2/F","parentIdentifier":"/us/usc/t16/s8203/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8203%2Fa%2F2%2FF","sourceRelease":"119-100","text":"4 shall be representatives of State agencies, 1 of whom shall be nominated by a regional association of fish and wildlife agencies from each of the Northeast, Southeast, Midwest, and Western regions of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","headin