c","sourceRelease":"119-100","text":"legal assistance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t15/s9524/e/1/B/i/II","parentIdentifier":"/us/usc/t15/s9524/e/1/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fe%2F1%2FB%2Fi%2FII","sourceRelease":"119-100","text":"access established supply chains; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t15/s9524/e/1/B/i/III","parentIdentifier":"/us/usc/t15/s9524/e/1/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fe%2F1%2FB%2Fi%2FIII","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t15/s9524/e/1/B/i/III/aa","parentIdentifier":"/us/usc/t15/s9524/e/1/B/i/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fe%2F1%2FB%2Fi%2FIII%2Faa","sourceRelease":"119-100","text":"joint ventures, teaming arrangements, and mergers and acquisitions; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t15/s9524/e/1/B/i/III/bb","parentIdentifier":"/us/usc/t15/s9524/e/1/B/i/III","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fe%2F1%2FB%2Fi%2FIII%2Fbb","sourceRelease":"119-100","text":"large-scale transactions in global markets;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9524/e/1/B/ii","parentIdentifier":"/us/usc/t15/s9524/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fe%2F1%2FB%2Fii","sourceRelease":"119-100","text":"supporting minority business enterprises in increasing the size of the workforces of those enterprises, including, with respect to a minority business enterprise that does not have employees, aiding the minority business enterprise in becoming an enterprise that has employees; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s9524/e/1/B/iii","parentIdentifier":"/us/usc/t15/s9524/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fe%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"advocating for minority business enterprises; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9524/e/2","parentIdentifier":"/us/usc/t15/s9524/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fe%2F2","sourceRelease":"119-100","text":"the budget and corresponding budget narrative that the eligible entity will use in carrying out subsection (a) during the term of the applicable MBDA Business Center agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Notification","label":"f Notification","identifier":"/us/usc/t15/s9524/f","parentIdentifier":"/us/usc/t15/s9524","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Ff","sourceRelease":"119-100","text":"If the Under Secretary grants an application of an eligible entity submitted under subsection (e), the Under Secretary shall notify the eligible entity that the application has been granted not later than 150 days after the last day on which an application may be submitted under that subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Program examination; accreditation; extensions","label":"g Program examination; accreditation; extensions","identifier":"/us/usc/t15/s9524/g","parentIdentifier":"/us/usc/t15/s9524","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Examination","label":"1 Examination","identifier":"/us/usc/t15/s9524/g/1","parentIdentifier":"/us/usc/t15/s9524/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fg%2F1","sourceRelease":"119-100","text":"Not later than 180 days after , and biennially thereafter, the Under Secretary shall conduct a programmatic financial examination of each Center.November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Accreditation","label":"2 Accreditation","identifier":"/us/usc/t15/s9524/g/2","parentIdentifier":"/us/usc/t15/s9524/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fg%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9524/g/2/A","parentIdentifier":"/us/usc/t15/s9524/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fg%2F2%2FA","sourceRelease":"119-100","text":"pursue matters of common concern with respect to Centers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9524/g/2/B","parentIdentifier":"/us/usc/t15/s9524/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fg%2F2%2FB","sourceRelease":"119-100","text":"develop an accreditation program with respect to Centers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Extensions","label":"3 Extensions","identifier":"/us/usc/t15/s9524/g/3","parentIdentifier":"/us/usc/t15/s9524/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fg%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s9524/g/3/A","parentIdentifier":"/us/usc/t15/s9524/g/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fg%2F3%2FA","sourceRelease":"119-100","text":"The Under Secretary may extend the term under subsection (b) of an MBDA Business Center agreement to which a Center is a party, if the Center consents to the extension.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Financial assistance","label":"B Financial assistance","identifier":"/us/usc/t15/s9524/g/3/B","parentIdentifier":"/us/usc/t15/s9524/g/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fg%2F3%2FB","sourceRelease":"119-100","text":"If the Under Secretary extends the term of an MBDA Business Center agreement under paragraph (1), the Under Secretary shall, in the same manner and amount in which financial assistance was provided during the initial term of the agreement, provide financial assistance under the agreement during the extended term of the agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"MBDA involvement","label":"h MBDA involvement","identifier":"/us/usc/t15/s9524/h","parentIdentifier":"/us/usc/t15/s9524","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9524/h/1","parentIdentifier":"/us/usc/t15/s9524/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh%2F1","sourceRelease":"119-100","text":"providing to each Center training relating to the MBDA Business Center Program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9524/h/2","parentIdentifier":"/us/usc/t15/s9524/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9524/h/2/A","parentIdentifier":"/us/usc/t15/s9524/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9524/h/2/A/i","parentIdentifier":"/us/usc/t15/s9524/h/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh%2F2%2FA%2Fi","sourceRelease":"119-100","text":"a conference with the Agency to establish the services and programs that the Center will provide in carrying out the requirements before the date on which the Center begins providing those services and programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9524/h/2/A/ii","parentIdentifier":"/us/usc/t15/s9524/h/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh%2F2%2FA%2Fii","sourceRelease":"119-100","text":"training provided under paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9524/h/2/B","parentIdentifier":"/us/usc/t15/s9524/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh%2F2%2FB","sourceRelease":"119-100","text":"receive necessary guidance relating to carrying out the requirements under subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s9524/h/2/C","parentIdentifier":"/us/usc/t15/s9524/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh%2F2%2FC","sourceRelease":"119-100","text":"work in coordination and collaboration with the Under Secretary to carry out the MBDA Business Center Program and other programs of the Agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s9524/h/3","parentIdentifier":"/us/usc/t15/s9524/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9524/h/3/A","parentIdentifier":"/us/usc/t15/s9524/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh%2F3%2FA","sourceRelease":"119-100","text":"Federal agencies other than the Agency, as appropriate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9524/h/3/B","parentIdentifier":"/us/usc/t15/s9524/h/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9524/h/3/B/i","parentIdentifier":"/us/usc/t15/s9524/h/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh%2F3%2FB%2Fi","sourceRelease":"119-100","text":"small business development centers, as that term is defined in ;section 632(t) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9524/h/3/B/ii","parentIdentifier":"/us/usc/t15/s9524/h/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh%2F3%2FB%2Fii","sourceRelease":"119-100","text":"women’s business centers described in ;section 656 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s9524/h/3/B/iii","parentIdentifier":"/us/usc/t15/s9524/h/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9524%2Fh%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"eligible entities, as that term is defined in section 2411 of title 10, that provide services under the program carried out under chapter 142 of that title; and22See References in Text note below.2","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","head