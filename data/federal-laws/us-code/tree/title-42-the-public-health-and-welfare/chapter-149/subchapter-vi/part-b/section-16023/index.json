{"type":"section","nativeType":"section","number":"16023","heading":"Project organization","label":"16023 Project organization","identifier":"/us/usc/t42/s16023","parentIdentifier":"/us/usc/t42/ch149/schVI/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Major project elements","label":"a Major project elements","identifier":"/us/usc/t42/s16023/a","parentIdentifier":"/us/usc/t42/s16023","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16023/a/1","parentIdentifier":"/us/usc/t42/s16023/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fa%2F1","sourceRelease":"119-100","text":"High-temperature hydrogen production technology development and validation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16023/a/2","parentIdentifier":"/us/usc/t42/s16023/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fa%2F2","sourceRelease":"119-100","text":"Energy conversion technology development and validation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16023/a/3","parentIdentifier":"/us/usc/t42/s16023/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fa%2F3","sourceRelease":"119-100","text":"Nuclear fuel development, characterization, and qualification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16023/a/4","parentIdentifier":"/us/usc/t42/s16023/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fa%2F4","sourceRelease":"119-100","text":"Materials selection, development, testing, and qualification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16023/a/5","parentIdentifier":"/us/usc/t42/s16023/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fa%2F5","sourceRelease":"119-100","text":"Reactor and balance-of-plant design, engineering, safety analysis, and qualification.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Project phases","label":"b Project phases","identifier":"/us/usc/t42/s16023/b","parentIdentifier":"/us/usc/t42/s16023","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"First project phase","label":"1 First project phase","identifier":"/us/usc/t42/s16023/b/1","parentIdentifier":"/us/usc/t42/s16023/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16023/b/1/A","parentIdentifier":"/us/usc/t42/s16023/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fb%2F1%2FA","sourceRelease":"119-100","text":"select and validate the appropriate technology under subsection (a)(1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16023/b/1/B","parentIdentifier":"/us/usc/t42/s16023/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fb%2F1%2FB","sourceRelease":"119-100","text":"carry out enabling research, development, and demonstration activities on technologies and components under paragraphs (2) through (4) of subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16023/b/1/C","parentIdentifier":"/us/usc/t42/s16023/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fb%2F1%2FC","sourceRelease":"119-100","text":"determine whether it is appropriate to combine electricity generation and hydrogen production in a single prototype nuclear reactor and plant; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16023/b/1/D","parentIdentifier":"/us/usc/t42/s16023/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fb%2F1%2FD","sourceRelease":"119-100","text":"carry out initial design activities for a prototype nuclear reactor and plant, including development of design methods and safety analytical methods and studies under subsection (a)(5).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Second project phase","label":"2 Second project phase","identifier":"/us/usc/t42/s16023/b/2","parentIdentifier":"/us/usc/t42/s16023/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16023/b/2/A","parentIdentifier":"/us/usc/t42/s16023/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fb%2F2%2FA","sourceRelease":"119-100","text":"continue appropriate activities under paragraphs (1) through (5) of subsection (a);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16023/b/2/B","parentIdentifier":"/us/usc/t42/s16023/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fb%2F2%2FB","sourceRelease":"119-100","text":"develop, through a competitive process, a final design for the prototype nuclear reactor and plant;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16023/b/2/C","parentIdentifier":"/us/usc/t42/s16023/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fb%2F2%2FC","sourceRelease":"119-100","text":"apply for licenses to construct and operate the prototype nuclear reactor from the Nuclear Regulatory Commission; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16023/b/2/D","parentIdentifier":"/us/usc/t42/s16023/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fb%2F2%2FD","sourceRelease":"119-100","text":"construct and start up operations of the prototype nuclear reactor and its associated hydrogen or electricity production facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Project requirements","label":"c Project requirements","identifier":"/us/usc/t42/s16023/c","parentIdentifier":"/us/usc/t42/s16023","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16023/c/1","parentIdentifier":"/us/usc/t42/s16023/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16023/c/1/A","parentIdentifier":"/us/usc/t42/s16023/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the nuclear power industry, including nuclear powerplant construction firms, particularly with respect to issues associated with plant design, construction, and operational and safety issues;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16023/c/1/B","parentIdentifier":"/us/usc/t42/s16023/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16023/c/1/B/i","parentIdentifier":"/us/usc/t42/s16023/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the use of process energy for production of hydrogen; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16023/c/1/B/ii","parentIdentifier":"/us/usc/t42/s16023/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the integration of technologies developed by the Project into chemical processing environments; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16023/c/1/C","parentIdentifier":"/us/usc/t42/s16023/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F1%2FC","sourceRelease":"119-100","text":"international efforts in areas related to the Project, particularly with respect to hydrogen production technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"International collaboration","label":"2 International collaboration","identifier":"/us/usc/t42/s16023/c/2","parentIdentifier":"/us/usc/t42/s16023/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16023/c/2/A","parentIdentifier":"/us/usc/t42/s16023/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F2%2FA","sourceRelease":"119-100","text":"The Secretary shall seek international cooperation, participation, and financial contributions for the Project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Assistance from international partners","label":"B Assistance from international partners","identifier":"/us/usc/t42/s16023/c/2/B","parentIdentifier":"/us/usc/t42/s16023/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F2%2FB","sourceRelease":"119-100","text":"The Secretary, through the Idaho National Laboratory, may contract for assistance from specialists or facilities from member countries of the Generation IV International Forum, the Russian Federation, or other international partners if the specialists or facilities provide access to cost-effective and relevant skills or test capabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Partner nations","label":"C Partner nations","identifier":"/us/usc/t42/s16023/c/2/C","parentIdentifier":"/us/usc/t42/s16023/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F2%2FC","sourceRelease":"119-100","text":"The Project may involve demonstration of selected project objectives in a partner country.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"Generation IV International Forum","label":"D Generation IV International Forum","identifier":"/us/usc/t42/s16023/c/2/D","parentIdentifier":"/us/usc/t42/s16023/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F2%2FD","sourceRelease":"119-100","text":"The Secretary shall ensure that international activities of the Project are coordinated with the Generation IV International Forum.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Review by Nuclear Energy Research Advisory Committee","label":"3 Review by Nuclear Energy Research Advisory Committee","identifier":"/us/usc/t42/s16023/c/3","parentIdentifier":"/us/usc/t42/s16023/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16023/c/3/A","parentIdentifier":"/us/usc/t42/s16023/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16023/c/3/A/i","parentIdentifier":"/us/usc/t42/s16023/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F3%2FA%2Fi","sourceRelease":"119-100","text":"review all program plans for the Project and all progress under the Project on an ongoing basis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16023/c/3/A/ii","parentIdentifier":"/us/usc/t42/s16023/c/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F3%2FA%2Fii","sourceRelease":"119-100","text":"ensure that important scientific, technical, safety, and program management issues receive attention in the Project and by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Additional expertise","label":"B Additional expertise","identifier":"/us/usc/t42/s16023/c/3/B","parentIdentifier":"/us/usc/t42/s16023/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F3%2FB","sourceRelease":"119-100","text":"The NERAC shall supplement the expertise of the NERAC or appoint subpanels to incorporate into the review by the NERAC the relevant sources of expertise described under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Initial review","label":"C Initial review","identifier":"/us/usc/t42/s16023/c/3/C","parentIdentifier":"/us/usc/t42/s16023/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16023/c/3/C/i","parentIdentifier":"/us/usc/t42/s16023/c/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F3%2FC%2Fi","sourceRelease":"119-100","text":"review existing program plans for the Project in light of the recommendations of the document entitled “Design Features and Technology Uncertainties for the Next Generation Nuclear Plant,” dated ; andJune 30, 2004","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16023/c/3/C/ii","parentIdentifier":"/us/usc/t42/s16023/c/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F3%2FC%2Fii","sourceRelease":"119-100","text":"address any recommendations of the document not incorporated in program plans for the Project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":"First project phase review","label":"D First project phase review","identifier":"/us/usc/t42/s16023/c/3/D","parentIdentifier":"/us/usc/t42/s16023/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F3%2FD","sourceRelease":"119-100","text":"On a determination by the Secretary that the appropriate activities under the first project phase under subsection (b)(1) are nearly complete, the Secretary shall request the NERAC to conduct a comprehensive review of the Project and to report to the Secretary the recommendation of the NERAC concerning whether the Project is ready to proceed to the second project phase under subsection (b)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":"Transmittal of reports to Congress","label":"E Transmittal of reports to Congress","identifier":"/us/usc/t42/s16023/c/3/E","parentIdentifier":"/us/usc/t42/s16023/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16023%2Fc%2F3%2FE","sourceRelease":"119-100","text":"Not later than 60 days after receiving any report from the NERAC related to the Project, the Secretary shall submit to the appropriate committees of the Senate and the House of Representatives a copy of the report, along with any additional views of the Secretary that the Secretary may consider appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
