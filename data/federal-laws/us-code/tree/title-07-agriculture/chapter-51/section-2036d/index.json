{"type":"section","nativeType":"section","number":"2036d","heading":"Pilot projects to encourage the use of public-private partnerships committed to addressing food insecurity","label":"2036d Pilot projects to encourage the use of public-private partnerships committed to addressing food insecurity","identifier":"/us/usc/t7/s2036d","parentIdentifier":"/us/usc/t7/ch51","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t7/s2036d/a","parentIdentifier":"/us/usc/t7/s2036d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fa","sourceRelease":"119-100","text":"The Secretary may, on application of eligible entities, approve not more than 10 pilot projects to support public-private partnerships that address food insecurity and poverty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Definitions","label":"b Definitions","identifier":"/us/usc/t7/s2036d/b","parentIdentifier":"/us/usc/t7/s2036d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2036d/b/1","parentIdentifier":"/us/usc/t7/s2036d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2036d/b/1/A","parentIdentifier":"/us/usc/t7/s2036d/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fb%2F1%2FA","sourceRelease":"119-100","text":"a nonprofit organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2036d/b/1/B","parentIdentifier":"/us/usc/t7/s2036d/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fb%2F1%2FB","sourceRelease":"119-100","text":"a community-based organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s2036d/b/1/C","parentIdentifier":"/us/usc/t7/s2036d/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fb%2F1%2FC","sourceRelease":"119-100","text":"an institution of higher education; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s2036d/b/1/D","parentIdentifier":"/us/usc/t7/s2036d/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fb%2F1%2FD","sourceRelease":"119-100","text":"a private entity, as determined by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2036d/b/2","parentIdentifier":"/us/usc/t7/s2036d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fb%2F2","sourceRelease":"119-100","text":"the term “public agency” means a department, agency, other unit, or instrumentality of Federal, State, or local government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Project requirements","label":"c Project requirements","identifier":"/us/usc/t7/s2036d/c","parentIdentifier":"/us/usc/t7/s2036d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2036d/c/1","parentIdentifier":"/us/usc/t7/s2036d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fc%2F1","sourceRelease":"119-100","text":"be limited to 2 years in length; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2036d/c/2","parentIdentifier":"/us/usc/t7/s2036d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s2036d/c/2/A","parentIdentifier":"/us/usc/t7/s2036d/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fc%2F2%2FA","sourceRelease":"119-100","text":"improves the effectiveness and impact of the supplemental nutrition assistance program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s2036d/c/2/B","parentIdentifier":"/us/usc/t7/s2036d/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fc%2F2%2FB","sourceRelease":"119-100","text":"develops food security solutions that are specific to the needs of a community or region; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s2036d/c/2/C","parentIdentifier":"/us/usc/t7/s2036d/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fc%2F2%2FC","sourceRelease":"119-100","text":"strengthens the capacity of communities to address food insecurity and poverty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Evaluation","label":"d Evaluation","identifier":"/us/usc/t7/s2036d/d","parentIdentifier":"/us/usc/t7/s2036d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2036d/d/1","parentIdentifier":"/us/usc/t7/s2036d/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fd%2F1","sourceRelease":"119-100","text":"a summary of the activities conducted under the pilot projects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2036d/d/2","parentIdentifier":"/us/usc/t7/s2036d/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fd%2F2","sourceRelease":"119-100","text":"an assessment of the effectiveness of the pilot projects; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s2036d/d/3","parentIdentifier":"/us/usc/t7/s2036d/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fd%2F3","sourceRelease":"119-100","text":"best practices regarding the use of public-private partnerships to improve the effectiveness of public benefit programs to address food insecurity and poverty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Funding","label":"e Funding","identifier":"/us/usc/t7/s2036d/e","parentIdentifier":"/us/usc/t7/s2036d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Authorization of appropriations","label":"1 Authorization of appropriations","identifier":"/us/usc/t7/s2036d/e/1","parentIdentifier":"/us/usc/t7/s2036d/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fe%2F1","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $5,000,000 to remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Appropriation in advance","label":"2 Appropriation in advance","identifier":"/us/usc/t7/s2036d/e/2","parentIdentifier":"/us/usc/t7/s2036d/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2036d%2Fe%2F2","sourceRelease":"119-100","text":"Only funds appropriated under paragraph (1) in advance specifically to carry out this section shall be available to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
