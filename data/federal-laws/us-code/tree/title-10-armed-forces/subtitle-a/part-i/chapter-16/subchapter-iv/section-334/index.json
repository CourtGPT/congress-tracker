{"type":"section","nativeType":"section","number":"334","heading":"Administrative support and payment of certain expenses for covered foreign defense personnel","label":"334 Administrative support and payment of certain expenses for covered foreign defense personnel","identifier":"/us/usc/t10/s334","parentIdentifier":"/us/usc/t10/stA/ptI/ch16/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsA prior section 334 was renumbered .section 254 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t10/s334/a","parentIdentifier":"/us/usc/t10/s334","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s334/a/1","parentIdentifier":"/us/usc/t10/s334/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fa%2F1","sourceRelease":"119-100","text":"provide administrative services and support to the United Nations Command for the performance of duties by covered foreign defense personnel during the period in which the covered foreign defense personnel are assigned to the United Nations Command or the Neutral Nations Supervisory Commission in accordance with the Korean War Armistice Agreement of 1953; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s334/a/2","parentIdentifier":"/us/usc/t10/s334/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s334/a/2/A","parentIdentifier":"/us/usc/t10/s334/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fa%2F2%2FA","sourceRelease":"119-100","text":"from a developing country; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s334/a/2/B","parentIdentifier":"/us/usc/t10/s334/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fa%2F2%2FB","sourceRelease":"119-100","text":"assigned to the headquarters of the United Nations Command.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Types of Expenses","label":"b .—Types of Expenses","identifier":"/us/usc/t10/s334/b","parentIdentifier":"/us/usc/t10/s334","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s334/b/1","parentIdentifier":"/us/usc/t10/s334/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fb%2F1","sourceRelease":"119-100","text":"Travel and subsistence expenses directly related to the duties of covered foreign defense personnel described in subsection (a)(2) in connection with the assignment of such covered foreign defense personnel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s334/b/2","parentIdentifier":"/us/usc/t10/s334/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fb%2F2","sourceRelease":"119-100","text":"Personal expenses directly related to carrying out such duties.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s334/b/3","parentIdentifier":"/us/usc/t10/s334/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fb%2F3","sourceRelease":"119-100","text":"Expenses for medical care at a military medical facility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s334/b/4","parentIdentifier":"/us/usc/t10/s334/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s334/b/4/A","parentIdentifier":"/us/usc/t10/s334/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fb%2F4%2FA","sourceRelease":"119-100","text":"adequate medical care is not available to such covered foreign defense personnel at a local military medical treatment facility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s334/b/4/B","parentIdentifier":"/us/usc/t10/s334/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fb%2F4%2FB","sourceRelease":"119-100","text":"the Secretary determines that payment of such medical expenses is necessary and in the best interests of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s334/b/4/C","parentIdentifier":"/us/usc/t10/s334/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fb%2F4%2FC","sourceRelease":"119-100","text":"medical care is not otherwise available to such covered foreign defense personnel pursuant to a treaty or any other international agreement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s334/b/5","parentIdentifier":"/us/usc/t10/s334/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s334/b/5/A","parentIdentifier":"/us/usc/t10/s334/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fb%2F5%2FA","sourceRelease":"119-100","text":"such travel is in direct support of the national interests of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s334/b/5/B","parentIdentifier":"/us/usc/t10/s334/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fb%2F5%2FB","sourceRelease":"119-100","text":"the Commander of the United Nations Command directs round-trip travel from the headquarters of the United Nations Command to one or more locations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Reimbursement","label":"c .—Reimbursement","identifier":"/us/usc/t10/s334/c","parentIdentifier":"/us/usc/t10/s334","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fc","sourceRelease":"119-100","text":"The Secretary may provide the administrative services and support and pay the expenses authorized by subsection (a) with or without reimbursement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Definitions","label":"d .—Definitions","identifier":"/us/usc/t10/s334/d","parentIdentifier":"/us/usc/t10/s334","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s334/d/1","parentIdentifier":"/us/usc/t10/s334/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fd%2F1","sourceRelease":"119-100","text":"The term “administrative services and support” means base or installation support services, facilities use, base operations support, office space, office supplies, utilities, copying services, computer support, communication services, fire and police protection, postal services, bank services, transportation services, housing and temporary billeting (including ancillary services), specialized clothing required to perform assigned duties, temporary loan of special equipment, storage services, training services, and repair and maintenance services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s334/d/2","parentIdentifier":"/us/usc/t10/s334/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s334/d/2/A","parentIdentifier":"/us/usc/t10/s334/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fd%2F2%2FA","sourceRelease":"119-100","text":"the United Nations Command; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s334/d/2/B","parentIdentifier":"/us/usc/t10/s334/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fd%2F2%2FB","sourceRelease":"119-100","text":"the Neutral Nations Supervisory Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s334/d/3","parentIdentifier":"/us/usc/t10/s334/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fd%2F3","sourceRelease":"119-100","text":"The term “developing country” has the meaning given the term in .section 301(4) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s334/d/4","parentIdentifier":"/us/usc/t10/s334/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fd%2F4","sourceRelease":"119-100","text":"The term “Neutral Nations Supervisory Commission” means the delegations from Sweden and Switzerland (or successor delegations) appointed in accordance with the Korean War Armistice Agreement of 1953 or its subsequent agreements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s334/d/5","parentIdentifier":"/us/usc/t10/s334/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs334%2Fd%2F5","sourceRelease":"119-100","text":"The term “United Nations Command” means the headquarters of the United Nations Command, the United Nations Command Military Armistice Commission, the United Nations Command-Rear, and the United Nations Command Honor Guard.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
