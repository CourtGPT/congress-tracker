{"type":"section","nativeType":"section","number":"5105","heading":"Standards for State license renewal","label":"5105 Standards for State license renewal","identifier":"/us/usc/t12/s5105","parentIdentifier":"/us/usc/t12/ch51","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t12/s5105/a","parentIdentifier":"/us/usc/t12/s5105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s5105/a/1","parentIdentifier":"/us/usc/t12/s5105/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fa%2F1","sourceRelease":"119-100","text":"The loan originator continues to meet the minimum standards for license issuance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s5105/a/2","parentIdentifier":"/us/usc/t12/s5105/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fa%2F2","sourceRelease":"119-100","text":"The loan originator has satisfied the annual continuing education requirements described in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Continuing education for State-licensed loan originators","label":"b Continuing education for State-licensed loan originators","identifier":"/us/usc/t12/s5105/b","parentIdentifier":"/us/usc/t12/s5105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t12/s5105/b/1","parentIdentifier":"/us/usc/t12/s5105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s5105/b/1/A","parentIdentifier":"/us/usc/t12/s5105/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fb%2F1%2FA","sourceRelease":"119-100","text":"3 hours of Federal law and regulations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s5105/b/1/B","parentIdentifier":"/us/usc/t12/s5105/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fb%2F1%2FB","sourceRelease":"119-100","text":"2 hours of ethics, which shall include instruction on fraud, consumer protection, and fair lending issues; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s5105/b/1/C","parentIdentifier":"/us/usc/t12/s5105/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fb%2F1%2FC","sourceRelease":"119-100","text":"2 hours of training related to lending standards for the nontraditional mortgage product marketplace.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Approved educational courses","label":"2 Approved educational courses","identifier":"/us/usc/t12/s5105/b/2","parentIdentifier":"/us/usc/t12/s5105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fb%2F2","sourceRelease":"119-100","text":"For purposes of paragraph (1), continuing education courses shall be reviewed, and approved by the Nationwide Mortgage Licensing System and Registry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Calculation of continuing education credits","label":"3 Calculation of continuing education credits","identifier":"/us/usc/t12/s5105/b/3","parentIdentifier":"/us/usc/t12/s5105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s5105/b/3/A","parentIdentifier":"/us/usc/t12/s5105/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fb%2F3%2FA","sourceRelease":"119-100","text":"may only receive credit for a continuing education course in the year in which the course is taken; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s5105/b/3/B","parentIdentifier":"/us/usc/t12/s5105/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fb%2F3%2FB","sourceRelease":"119-100","text":"may not take the same approved course in the same or successive years to meet the annual requirements for continuing education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Instructor credit","label":"4 Instructor credit","identifier":"/us/usc/t12/s5105/b/4","parentIdentifier":"/us/usc/t12/s5105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fb%2F4","sourceRelease":"119-100","text":"A State-licensed loan originator who is approved as an instructor of an approved continuing education course may receive credit for the originator’s own annual continuing education requirement at the rate of 2 hours credit for every 1 hour taught.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Limitation and standards","label":"5 Limitation and standards","identifier":"/us/usc/t12/s5105/b/5","parentIdentifier":"/us/usc/t12/s5105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Limitation","label":"A Limitation","identifier":"/us/usc/t12/s5105/b/5/A","parentIdentifier":"/us/usc/t12/s5105/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fb%2F5%2FA","sourceRelease":"119-100","text":"To maintain the independence of the approval process, the Nationwide Mortgage Licensing System and Registry shall not directly or indirectly offer any continuing education courses for loan originators.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Standards","label":"B Standards","identifier":"/us/usc/t12/s5105/b/5/B","parentIdentifier":"/us/usc/t12/s5105/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs5105%2Fb%2F5%2FB","sourceRelease":"119-100","text":"In approving courses under this section, the Nationwide Mortgage Licensing System and Registry shall apply reasonable standards in the review and approval of courses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
