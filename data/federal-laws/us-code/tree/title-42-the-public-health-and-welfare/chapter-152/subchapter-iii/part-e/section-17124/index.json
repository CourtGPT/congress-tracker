{"type":"section","nativeType":"section","number":"17124","heading":"Advisory Committee on Energy Efficiency Finance","label":"17124 Advisory Committee on Energy Efficiency Finance","identifier":"/us/usc/t42/s17124","parentIdentifier":"/us/usc/t42/ch152/schIII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17124","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t42/s17124/a","parentIdentifier":"/us/usc/t42/s17124","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17124%2Fa","sourceRelease":"119-100","text":"The Secretary, acting through the Assistant Secretary of Energy for Energy Efficiency and Renewable Energy, shall establish an Advisory Committee on Energy Efficiency Finance to provide advice and recommendations to the Department on energy efficiency finance and investment issues, options, ideas, and trends, and to assist the energy community in identifying practical ways of lowering costs and increasing investments in energy efficiency technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Membership","label":"b Membership","identifier":"/us/usc/t42/s17124/b","parentIdentifier":"/us/usc/t42/s17124","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17124%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17124/b/1","parentIdentifier