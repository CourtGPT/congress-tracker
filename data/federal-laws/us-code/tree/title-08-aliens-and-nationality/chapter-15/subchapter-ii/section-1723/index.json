{"type":"section","nativeType":"section","number":"1723","heading":"Commission on Interoperable Data Sharing","label":"1723 Commission on Interoperable Data Sharing","identifier":"/us/usc/t8/s1723","parentIdentifier":"/us/usc/t8/ch15/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t8/s1723/a","parentIdentifier":"/us/usc/t8/s1723","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t8/s1723/a/1","parentIdentifier":"/us/usc/t8/s1723/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723%2Fa%2F1","sourceRelease":"119-100","text":"monitor the protections described in ;section 1721(c)(3) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t8/s1723/a/2","parentIdentifier":"/us/usc/t8/s1723/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723%2Fa%2F2","sourceRelease":"119-100","text":"provide oversight of the interoperable electronic data system described in ; andsection 1722 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t8/s1723/a/3","parentIdentifier":"/us/usc/t8/s1723/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723%2Fa%2F3","sourceRelease":"119-100","text":"report to Congress annually on the Commission’s findings and recommendations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Composition","label":"b Composition","identifier":"/us/usc/t8/s1723/b","parentIdentifier":"/us/usc/t8/s1723","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t8/s1723/b/1","parentIdentifier":"/us/usc/t8/s1723/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723%2Fb%2F1","sourceRelease":"119-100","text":"One member, who shall serve as Chair of the Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t8/s1723/b/2","parentIdentifier":"/us/usc/t8/s1723/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723%2Fb%2F2","sourceRelease":"119-100","text":"Eight members, who shall be appointed from a list of nominees jointly provided by the Speaker of the House of Representatives, the Minority Leader of the House of Representatives, the Majority Leader of the Senate, and the Minority Leader of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Considerations","label":"c Considerations","identifier":"/us/usc/t8/s1723/c","parentIdentifier":"/us/usc/t8/s1723","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t8/s1723/c/1","parentIdentifier":"/us/usc/t8/s1723/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723%2Fc%2F1","sourceRelease":"119-100","text":"Adequate protection of privacy concerns inherent in the design, implementation, or operation of the interoperable electronic data system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t8/s1723/c/2","parentIdentifier":"/us/usc/t8/s1723/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723%2Fc%2F2","sourceRelease":"119-100","text":"Timely adoption of security innovations, consistent with generally accepted security standards, to protect the integrity and confidentiality of information to prevent the risks of accidental or unauthorized loss, access, destruction, use modification, or disclosure of information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t8/s1723/c/3","parentIdentifier":"/us/usc/t8/s1723/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723%2Fc%2F3","sourceRelease":"119-100","text":"The adequacy of mechanisms to permit the timely correction of errors in data maintained by the interoperable data system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t8/s1723/c/4","parentIdentifier":"/us/usc/t8/s1723/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723%2Fc%2F4","sourceRelease":"119-100","text":"Other protections against unauthorized use of data to guard against the misuse of the interoperable data system or the data maintained by the system, including recommendations for modifications to existing laws and regulations to sanction misuse of the system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t8/s1723/d","parentIdentifier":"/us/usc/t8/s1723","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1723%2Fd","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Commission such sums as may be necessary to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
