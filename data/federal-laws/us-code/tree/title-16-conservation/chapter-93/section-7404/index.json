{"type":"section","nativeType":"section","number":"7404","heading":"Authorization or denial of port entry","label":"7404 Authorization or denial of port entry","identifier":"/us/usc/t16/s7404","parentIdentifier":"/us/usc/t16/ch93","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Submission of information required under Agreement","label":"a Submission of information required under Agreement","identifier":"/us/usc/t16/s7404/a","parentIdentifier":"/us/usc/t16/s7404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s7404/a/1","parentIdentifier":"/us/usc/t16/s7404/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fa%2F1","sourceRelease":"119-100","text":"A vessel described in paragraph (2) seeking entry to a port that is subject to the jurisdiction of the United States must submit to the Secretary of the department in which the Coast Guard is operating information as required under the Agreement in advance of its arrival in port. The Secretary of the department in which the Coast Guard is operating shall provide that information to the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Covered vessels","label":"2 Covered vessels","identifier":"/us/usc/t16/s7404/a/2","parentIdentifier":"/us/usc/t16/s7404/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s7404/a/2/A","parentIdentifier":"/us/usc/t16/s7404/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fa%2F2%2FA","sourceRelease":"119-100","text":"is not documented under chapter 121 of title 46; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s7404/a/2/B","parentIdentifier":"/us/usc/t16/s7404/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fa%2F2%2FB","sourceRelease":"119-100","text":"is not numbered under chapter 123 of that title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Decision to authorize or deny port entry","label":"b Decision to authorize or deny port entry","identifier":"/us/usc/t16/s7404/b","parentIdentifier":"/us/usc/t16/s7404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Decision","label":"1 Decision","identifier":"/us/usc/t16/s7404/b/1","parentIdentifier":"/us/usc/t16/s7404/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s7404/b/1/A","parentIdentifier":"/us/usc/t16/s7404/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the Secretary of the department in which the Coast Guard is operating; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s7404/b/1/B","parentIdentifier":"/us/usc/t16/s7404/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the vessel or its representative.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Authorization or denial of entry","label":"2 Authorization or denial of entry","identifier":"/us/usc/t16/s7404/b/2","parentIdentifier":"/us/usc/t16/s7404/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary of the department in which the Coast Guard is operating shall authorize or deny entry to vessels to which such a decision applies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Vessels to which entry may be denied","label":"3 Vessels to which entry may be denied","identifier":"/us/usc/t16/s7404/b/3","parentIdentifier":"/us/usc/t16/s7404/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s7404/b/3/A","parentIdentifier":"/us/usc/t16/s7404/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fb%2F3%2FA","sourceRelease":"119-100","text":"that is described in subsection (a)(2); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s7404/b/3/B","parentIdentifier":"/us/usc/t16/s7404/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s7404/b/3/B/i","parentIdentifier":"/us/usc/t16/s7404/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"is a listed IUU vessel; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s7404/b/3/B/ii","parentIdentifier":"/us/usc/t16/s7404/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s7404/b/3/B/ii/I","parentIdentifier":"/us/usc/t16/s7404/b/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fb%2F3%2FB%2Fii%2FI","sourceRelease":"119-100","text":"has engaged in IUU fishing or fishing-related activities in support of such fishing; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s7404/b/3/B/ii/II","parentIdentifier":"/us/usc/t16/s7404/b/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fb%2F3%2FB%2Fii%2FII","sourceRelease":"119-100","text":"has violated this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Denial of use of port","label":"c Denial of use of port","identifier":"/us/usc/t16/s7404/c","parentIdentifier":"/us/usc/t16/s7404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s7404/c/1","parentIdentifier":"/us/usc/t16/s7404/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fc%2F1","sourceRelease":"119-100","text":"the vessel entered without authorization under subsection (b);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s7404/c/2","parentIdentifier":"/us/usc/t16/s7404/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fc%2F2","sourceRelease":"119-100","text":"the vessel is a listed IUU vessel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s7404/c/3","parentIdentifier":"/us/usc/t16/s7404/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fc%2F3","sourceRelease":"119-100","text":"the vessel is not documented under the laws of another nation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s7404/c/4","parentIdentifier":"/us/usc/t16/s7404/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fc%2F4","sourceRelease":"119-100","text":"the flag nation of the vessel has failed to provide confirmation requested by the Secretary that the fish on board were taken in accordance with applicable RFMO conservation and management measures; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s7404/c/5","parentIdentifier":"/us/usc/t16/s7404/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s7404/c/5/A","parentIdentifier":"/us/usc/t16/s7404/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fc%2F5%2FA","sourceRelease":"119-100","text":"the vessel lacks valid authorizations to engage in fishing or fishing-related activities as required by its flag nation or the relevant coastal nation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s7404/c/5/B","parentIdentifier":"/us/usc/t16/s7404/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fc%2F5%2FB","sourceRelease":"119-100","text":"the fish on board were taken in violation of foreign law or in contravention of any RFMO conservation and management measure; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s7404/c/5/C","parentIdentifier":"/us/usc/t16/s7404/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fc%2F5%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s7404/c/5/C/i","parentIdentifier":"/us/usc/t16/s7404/c/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fc%2F5%2FC%2Fi","sourceRelease":"119-100","text":"it was acting in a manner consistent with applicable RFMO conservation and management measures; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s7404/c/5/C/ii","parentIdentifier":"/us/usc/t16/s7404/c/5/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fc%2F5%2FC%2Fii","sourceRelease":"119-100","text":"in the case of the provision of personnel, fuel, gear, and other supplies at sea, the vessel provisioned was not, at the time of provisioning, a listed IUU vessel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Exceptions","label":"d Exceptions","identifier":"/us/usc/t16/s7404/d","parentIdentifier":"/us/usc/t16/s7404","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s7404/d/1","parentIdentifier":"/us/usc/t16/s7404/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fd%2F1","sourceRelease":"119-100","text":"if they are essential to the safety or health of the crew or safety of the vessel;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s7404/d/2","parentIdentifier":"/us/usc/t16/s7404/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fd%2F2","sourceRelease":"119-100","text":"to allow, where appropriate, for the scrapping of the vessel; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s7404/d/3","parentIdentifier":"/us/usc/t16/s7404/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs7404%2Fd%2F3","sourceRelease":"119-100","text":"pursuant to an inspection or other enforcement action.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
