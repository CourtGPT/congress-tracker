143/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fa%2F6","sourceRelease":"119-100","text":"direct marketing, supply chain, and traceability;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t33/s1143/a/7","parentIdentifier":"/us/usc/t33/s1143/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fa%2F7","sourceRelease":"119-100","text":"financial and risk management, including vessel, permit, and quota purchasing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t33/s1143/a/8","parentIdentifier":"/us/usc/t33/s1143/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fa%2F8","sourceRelease":"119-100","text":"State and Federal legal requirements for specific fisheries, including reporting, monitoring, licenses, and regulations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t33/s1143/a/9","parentIdentifier":"/us/usc/t33/s1143/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fa%2F9","sourceRelease":"119-100","text":"State and Federal fisheries policy and management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t33/s1143/a/10","parentIdentifier":"/us/usc/t33/s1143/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fa%2F10","sourceRelease":"119-100","text":"mentoring, apprenticeships, or internships; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t33/s1143/a/11","parentIdentifier":"/us/usc/t33/s1143/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fa%2F11","sourceRelease":"119-100","text":"any other activities, opportunities, or programs, as the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Eligibility","label":"b Eligibility","identifier":"/us/usc/t33/s1143/b","parentIdentifier":"/us/usc/t33/s1143","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Applicants","label":"1 Applicants","identifier":"/us/usc/t33/s1143/b/1","parentIdentifier":"/us/usc/t33/s1143/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1143/b/1/A","parentIdentifier":"/us/usc/t33/s1143/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fb%2F1%2FA","sourceRelease":"119-100","text":"a Sea Grant Institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1143/b/1/B","parentIdentifier":"/us/usc/t33/s1143/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fb%2F1%2FB","sourceRelease":"119-100","text":"a Federal or State agency or a Tribal organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s1143/b/1/C","parentIdentifier":"/us/usc/t33/s1143/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fb%2F1%2FC","sourceRelease":"119-100","text":"a community-based nongovernmental organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t33/s1143/b/1/D","parentIdentifier":"/us/usc/t33/s1143/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fb%2F1%2FD","sourceRelease":"119-100","text":"fishermen’s cooperatives or associations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t33/s1143/b/1/E","parentIdentifier":"/us/usc/t33/s1143/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fb%2F1%2FE","sourceRelease":"119-100","text":"an institution of higher education (including an institution awarding an associate’s degree), or a foundation maintained by an institution of higher education; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t33/s1143/b/1/F","parentIdentifier":"/us/usc/t33/s1143/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fb%2F1%2FF","sourceRelease":"119-100","text":"any other appropriate entity, as the Secretary determines appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Participants","label":"2 Participants","identifier":"/us/usc/t33/s1143/b/2","parentIdentifier":"/us/usc/t33/s1143/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fb%2F2","sourceRelease":"119-100","text":"All young fishermen seeking to participate in the commercial fisheries of the United States and the Great Lakes are eligible to participate in the activities funded through grants provided for in this section, except that participants in such activities shall be selected by each grant recipient.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Maximum term and amount of grant","label":"c Maximum term and amount of grant","identifier":"/us/usc/t33/s1143/c","parentIdentifier":"/us/usc/t33/s1143","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s1143/c/1","parentIdentifier":"/us/usc/t33/s1143/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1143/c/1/A","parentIdentifier":"/us/usc/t33/s1143/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fc%2F1%2FA","sourceRelease":"119-100","text":"have a term of no more than 3 fiscal years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1143/c/1/B","parentIdentifier":"/us/usc/t33/s1143/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fc%2F1%2FB","sourceRelease":"119-100","text":"be in an amount that is not more than $200,000 for each fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Consecutive grants","label":"2 Consecutive grants","identifier":"/us/usc/t33/s1143/c/2","parentIdentifier":"/us/usc/t33/s1143/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fc%2F2","sourceRelease":"119-100","text":"An eligible recipient may receive consecutive grants under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Matching requirement","label":"d Matching requirement","identifier":"/us/usc/t33/s1143/d","parentIdentifier":"/us/usc/t33/s1143","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fd","sourceRelease":"119-100","text":"To be eligible to receive a grant under this section, a recipient shall provide a match in the form of cash or in-kind contributions from the recipient in the amount equal to or greater than 25 percent of the funds provided by the grant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Regional balance","label":"e Regional balance","identifier":"/us/usc/t33/s1143/e","parentIdentifier":"/us/usc/t33/s1143","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fe","sourceRelease":"119-100","text":"In making grants under this section, the Secretary shall, to the maximum extent practicable, ensure geographic diversity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Cooperation and evaluation criteria","label":"f Cooperation and evaluation criteria","identifier":"/us/usc/t33/s1143/f","parentIdentifier":"/us/usc/t33/s1143","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1143/f/1","parentIdentifier":"/us/usc/t33/s1143/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Ff%2F1","sourceRelease":"119-100","text":"Sea Grant Institutions and extension agents of such institutions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1143/f/2","parentIdentifier":"/us/usc/t33/s1143/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Ff%2F2","sourceRelease":"119-100","text":"community-based nongovernmental fishing organizations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s1143/f/3","parentIdentifier":"/us/usc/t33/s1143/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Ff%2F3","sourceRelease":"119-100","text":"Federal and State agencies, including Regional Fishery Management Councils established under the Magnuson-Stevens Fishery Conservation and Management Act ( et seq.);16 U.S.C. 18511See References in Text note below.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s1143/f/4","parentIdentifier":"/us/usc/t33/s1143/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Ff%2F4","sourceRelease":"119-100","text":"institutions of higher education with fisheries expertise and programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t33/s1143/f/5","parentIdentifier":"/us/usc/t33/s1143/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Ff%2F5","sourceRelease":"119-100","text":"partners, as the Secretary determines.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Prohibition","label":"g Prohibition","identifier":"/us/usc/t33/s1143/g","parentIdentifier":"/us/usc/t33/s1143","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1143%2Fg","sourceRelease":"119-100","text":"A grant under this section may not be used to purchase any fishing license, permit, quota, or other harvesting right.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
