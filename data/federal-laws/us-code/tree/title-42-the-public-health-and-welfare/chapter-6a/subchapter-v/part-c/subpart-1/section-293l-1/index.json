{"type":"section","nativeType":"section","number":"293l–1","heading":"Teaching health centers development grants","label":"293l–1 Teaching health centers development grants","identifier":"/us/usc/t42/s293l–1","parentIdentifier":"/us/usc/t42/ch6A/schV/ptC/spt1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Program authorized","label":"a Program authorized","identifier":"/us/usc/t42/s293l–1/a","parentIdentifier":"/us/usc/t42/s293l–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Fa","sourceRelease":"119-100","text":"The Secretary may award grants under this section to teaching health centers for the purpose of establishing new accredited or expanded primary care residency programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Amount and duration","label":"b Amount and duration","identifier":"/us/usc/t42/s293l–1/b","parentIdentifier":"/us/usc/t42/s293l–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Fb","sourceRelease":"119-100","text":"Grants awarded under this section shall be for a term of not more than 3 years and the maximum award may not be more than $500,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Use of funds","label":"c Use of funds","identifier":"/us/usc/t42/s293l–1/c","parentIdentifier":"/us/usc/t42/s293l–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s293l–1/c/1","parentIdentifier":"/us/usc/t42/s293l–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s293l–1/c/1/A","parentIdentifier":"/us/usc/t42/s293l–1/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Fc%2F1%2FA","sourceRelease":"119-100","text":"curriculum development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s293l–1/c/1/B","parentIdentifier":"/us/usc/t42/s293l–1/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Fc%2F1%2FB","sourceRelease":"119-100","text":"recruitment, training and retention of residents and faculty:1So in original. The colon probably should be a semicolon.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s293l–1/c/1/C","parentIdentifier":"/us/usc/t42/s293l–1/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Fc%2F1%2FC","sourceRelease":"119-100","text":"accreditation by the Accreditation Council for Graduate Medical Education (ACGME), the American Dental Association (ADA), or the American Osteopathic Association (AOA); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s293l–1/c/1/D","parentIdentifier":"/us/usc/t42/s293l–1/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Fc%2F1%2FD","sourceRelease":"119-100","text":"faculty salaries during the development phase; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s293l–1/c/2","parentIdentifier":"/us/usc/t42/s293l–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Fc%2F2","sourceRelease":"119-100","text":"technical assistance provided by an eligible entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Application","label":"d Application","identifier":"/us/usc/t42/s293l–1/d","parentIdentifier":"/us/usc/t42/s293l–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Fd","sourceRelease":"119-100","text":"A teaching health center seeking a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Preference for certain applications","label":"e Preference for certain applications","identifier":"/us/usc/t42/s293l–1/e","parentIdentifier":"/us/usc/t42/s293l–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Fe","sourceRelease":"119-100","text":"In selecting recipients for grants under this section, the Secretary shall give preference to any such application that documents an existing affiliation agreement with an area health education center program as defined in sections 294a and 295p of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Definitions","label":"f Definitions","identifier":"/us/usc/t42/s293l–1/f","parentIdentifier":"/us/usc/t42/s293l–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible entity","label":"1 Eligible entity","identifier":"/us/usc/t42/s293l–1/f/1","parentIdentifier":"/us/usc/t42/s293l–1/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Ff%2F1","sourceRelease":"119-100","text":"The term “eligible entity” means an organization capable of providing technical assistance including an area health education center program as defined in sections 294a and 295p of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Primary care residency program","label":"2 Primary care residency program","identifier":"/us/usc/t42/s293l–1/f/2","parentIdentifier":"/us/usc/t42/s293l–1/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Ff%2F2","sourceRelease":"119-100","text":"The term “primary care residency program” means an approved graduate medical residency training program (as defined in ) in family medicine, internal medicine, pediatrics, internal medicine-pediatrics, obstetrics and gynecology, psychiatry, general dentistry, pediatric dentistry, and geriatrics.section 256h of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Teaching health center","label":"3 Teaching health center","identifier":"/us/usc/t42/s293l–1/f/3","parentIdentifier":"/us/usc/t42/s293l–1/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Ff%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s293l–1/f/3/A","parentIdentifier":"/us/usc/t42/s293l–1/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Ff%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s293l–1/f/3/A/i","parentIdentifier":"/us/usc/t42/s293l–1/f/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Ff%2F3%2FA%2Fi","sourceRelease":"119-100","text":"is a community based, ambulatory patient care center; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s293l–1/f/3/A/ii","parentIdentifier":"/us/usc/t42/s293l–1/f/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Ff%2F3%2FA%2Fii","sourceRelease":"119-100","text":"operates a primary care residency program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Inclusion of certain entities","label":"B Inclusion of certain entities","identifier":"/us/usc/t42/s293l–1/f/3/B","parentIdentifier":"/us/usc/t42/s293l–1/f/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Ff%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s293l–1/f/3/B/i","parentIdentifier":"/us/usc/t42/s293l–1/f/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Ff%2F3%2FB%2Fi","sourceRelease":"119-100","text":"A Federally qualified health center (as defined in section 1396d()(2)(B) of this title).l","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s293l–1/f/3/B/ii","parentIdentifier":"/us/usc/t42/s293l–1/f/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Ff%2F3%2FB%2Fii","sourceRelease":"119-100","text":"A community mental health center (as defined in ).section 1395x(ff)(3)(B) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s293l–1/f/3/B/iii","parentIdentifier":"/us/usc/t42/s293l–1/f/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Ff%2F3%2FB%2Fiii","sourceRelease":"119-100","text":"A rural health clinic, as defined in .section 1395x(aa) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s293l–1/f/3/B/iv","parentIdentifier":"/us/usc/t42/s293l–1/f/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Ff%2F3%2FB%2Fiv","sourceRelease":"119-100","text":"A health center operated by the Indian Health Service, an Indian tribe or tribal organization, or an urban Indian organization (as defined in ).section 1603 of title 25","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s293l–1/f/3/B/v","parentIdentifier":"/us/usc/t42/s293l–1/f/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Ff%2F3%2FB%2Fv","sourceRelease":"119-100","text":"An entity receiving funds under subchapter VIII.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Authorization of appropriations","label":"g Authorization of appropriations","identifier":"/us/usc/t42/s293l–1/g","parentIdentifier":"/us/usc/t42/s293l–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs293l%E2%80%931%2Fg","sourceRelease":"119-100","text":"There is authorized to be appropriated, $25,000,000 for fiscal year 2010, $50,000,000 for fiscal year 2011, $50,000,000 for fiscal year 2012, and such sums as may be necessary for each fiscal year thereafter to carry out this section. Not to exceed $5,000,000 annually may be used for technical assistance program grants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
