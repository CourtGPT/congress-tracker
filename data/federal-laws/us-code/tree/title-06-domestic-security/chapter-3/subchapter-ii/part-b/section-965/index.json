{"type":"section","nativeType":"section","number":"965","heading":"Tier 2 participants in C–TPAT","label":"965 Tier 2 participants in C–TPAT","identifier":"/us/usc/t6/s965","parentIdentifier":"/us/usc/t6/ch3/schII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs965","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Validation","label":"a Validation","identifier":"/us/usc/t6/s965/a","parentIdentifier":"/us/usc/t6/s965","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs965%2Fa","sourceRelease":"119-100","text":"The Secretary, acting through the Commissioner, shall validate the security measures and supply chain security practices of a Tier 1 participant in accordance with the guidelines referred to in subsection (c). Such validation shall include on-site assessments at appropriate foreign locations utilized by the Tier 1 participant in its supply chain and shall, to the extent practicable, be completed not later than 1 year after certification as a Tier 1 participant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Benefits","label":"b Benefits","identifier":"/us/usc/t6/s965/b","parentIdentifier":"/us/usc/t6/s965","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs965%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s965/b/1","parentIdentifier":"/us/usc/t6/s965/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs965%2Fb%2F1","sourceRelease":"119-100","text":"reduced scores in the Automated Targeting System;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s965/b/2","parentIdentifier":"/us/usc/t6/s965/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs965%2Fb%2F2","sourceRelease":"119-100","text":"reduced examinations of cargo; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s965/b/3","parentIdentifier":"/us/usc/t6/s965/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs965%2Fb%2F3","sourceRelease":"119-100","text":"priority searches of cargo.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Guidelines","label":"c Guidelines","identifier":"/us/usc/t6/s965/c","parentIdentifier":"/us/usc/t6/s965","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs965%2Fc","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary, acting through the Commissioner, shall develop a schedule and update the guidelines for validating a participant’s security measures and supply chain security practices under this section.October 13, 2006","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
