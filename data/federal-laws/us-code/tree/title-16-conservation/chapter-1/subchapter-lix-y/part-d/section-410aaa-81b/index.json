plants, insects, and animals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s410aaa–81b/b/2/B/ii","parentIdentifier":"/us/usc/t16/s410aaa–81b/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381b%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"soil;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s410aaa–81b/b/2/B/iii","parentIdentifier":"/us/usc/t16/s410aaa–81b/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381b%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"air quality;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s410aaa–81b/b/2/B/iv","parentIdentifier":"/us/usc/t16/s410aaa–81b/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381b%2Fb%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"water quality and quantity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t16/s410aaa–81b/b/2/B/v","parentIdentifier":"/us/usc/t16/s410aaa–81b/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa%E2%80%9381b%2Fb%2F2%2FB%2Fv","sourceRelease":"119-100","text":"species migration and survival;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s410aaa–81b/b/2/C","parentIdentifier":"/us/usc/t16/s410aaa–81b/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410aaa