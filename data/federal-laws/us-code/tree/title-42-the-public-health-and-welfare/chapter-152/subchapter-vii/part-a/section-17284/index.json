{"type":"section","nativeType":"section","number":"17284","heading":"Assessment of resources","label":"17284 Assessment of resources","identifier":"/us/usc/t42/s17284","parentIdentifier":"/us/usc/t42/ch152/schVII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"5-year plan","label":"a 5-year plan","identifier":"/us/usc/t42/s17284/a","parentIdentifier":"/us/usc/t42/s17284","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t42/s17284/a/1","parentIdentifier":"/us/usc/t42/s17284/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fa%2F1","sourceRelease":"119-100","text":"The Administrator of the Energy Information Administration (referred to in this section as the “Administrator”) shall establish a 5-year plan to enhance the quality and scope of the data collection necessary to ensure the scope, accuracy, and timeliness of the information needed for efficient functioning of energy markets and related financial operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirement","label":"2 Requirement","identifier":"/us/usc/t42/s17284/a/2","parentIdentifier":"/us/usc/t42/s17284/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17284/a/2/A","parentIdentifier":"/us/usc/t42/s17284/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fa%2F2%2FA","sourceRelease":"119-100","text":"data series terminated because of budget constraints;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17284/a/2/B","parentIdentifier":"/us/usc/t42/s17284/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fa%2F2%2FB","sourceRelease":"119-100","text":"data on demand response;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17284/a/2/C","parentIdentifier":"/us/usc/t42/s17284/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fa%2F2%2FC","sourceRelease":"119-100","text":"timely data series of State-level information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17284/a/2/D","parentIdentifier":"/us/usc/t42/s17284/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fa%2F2%2FD","sourceRelease":"119-100","text":"improvements in the area of oil and gas data;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17284/a/2/E","parentIdentifier":"/us/usc/t42/s17284/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fa%2F2%2FE","sourceRelease":"119-100","text":"improvements in data on solid byproducts from coal-based energy-producing facilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17284/a/2/F","parentIdentifier":"/us/usc/t42/s17284/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fa%2F2%2FF","sourceRelease":"119-100","text":"the ability to meet applicable deadlines under Federal law (including regulations) to provide data required by Congress.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Submission to Congress","label":"b Submission to Congress","identifier":"/us/usc/t42/s17284/b","parentIdentifier":"/us/usc/t42/s17284","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fb","sourceRelease":"119-100","text":"The Administrator shall submit to Congress the plan established under subsection (a), including a description of any improvements needed to enhance the ability of the Administrator to collect and process energy information in a manner consistent with the needs of energy markets.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Guidelines","label":"c Guidelines","identifier":"/us/usc/t42/s17284/c","parentIdentifier":"/us/usc/t42/s17284","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17284/c/1","parentIdentifier":"/us/usc/t42/s17284/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17284/c/1/A","parentIdentifier":"/us/usc/t42/s17284/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fc%2F1%2FA","sourceRelease":"119-100","text":"establish guidelines to ensure the quality, comparability, and scope of State energy data, including data on energy production and consumption by product and sector and renewable and alternative sources, required to provide a comprehensive, accurate energy profile at the State level;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17284/c/1/B","parentIdentifier":"/us/usc/t42/s17284/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fc%2F1%2FB","sourceRelease":"119-100","text":"share company-level data collected at the State level with each State involved, in a manner consistent with the legal authorities, confidentiality protections, and stated uses in effect at the time the data were collected, subject to the condition that the State shall agree to reasonable requirements for use of the data, as the Administrator may require;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17284/c/1/C","parentIdentifier":"/us/usc/t42/s17284/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fc%2F1%2FC","sourceRelease":"119-100","text":"assess any existing gaps in data obtained and compiled by the Energy Information Administration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17284/c/1/D","parentIdentifier":"/us/usc/t42/s17284/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fc%2F1%2FD","sourceRelease":"119-100","text":"evaluate the most cost-effective ways to address any data quality and quantity issues in conjunction with State officials.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Consultation","label":"2 Consultation","identifier":"/us/usc/t42/s17284/c/2","parentIdentifier":"/us/usc/t42/s17284/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17284/c/2/A","parentIdentifier":"/us/usc/t42/s17284/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fc%2F2%2FA","sourceRelease":"119-100","text":"establishing guidelines and determining the scope of State-level data under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17284/c/2/B","parentIdentifier":"/us/usc/t42/s17284/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fc%2F2%2FB","sourceRelease":"119-100","text":"exploring ways to address data needs and serve data uses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Assessment of State data needs","label":"d Assessment of State data needs","identifier":"/us/usc/t42/s17284/d","parentIdentifier":"/us/usc/t42/s17284","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fd","sourceRelease":"119-100","text":"Not later than 1 year after , the Administrator shall submit to Congress an assessment of State-level data needs, including a plan to address the needs.December 19, 2007","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s17284/e","parentIdentifier":"/us/usc/t42/s17284","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17284/e/1","parentIdentifier":"/us/usc/t42/s17284/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fe%2F1","sourceRelease":"119-100","text":"$10,000,000 for fiscal year 2008;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17284/e/2","parentIdentifier":"/us/usc/t42/s17284/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fe%2F2","sourceRelease":"119-100","text":"$10,000,000 for fiscal year 2009;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17284/e/3","parentIdentifier":"/us/usc/t42/s17284/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fe%2F3","sourceRelease":"119-100","text":"$10,000,000 for fiscal year 2010;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17284/e/4","parentIdentifier":"/us/usc/t42/s17284/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fe%2F4","sourceRelease":"119-100","text":"$15,000,000 for fiscal year 2011;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s17284/e/5","parentIdentifier":"/us/usc/t42/s17284/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fe%2F5","sourceRelease":"119-100","text":"$20,000,000 for fiscal year 2012; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s17284/e/6","parentIdentifier":"/us/usc/t42/s17284/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17284%2Fe%2F6","sourceRelease":"119-100","text":"such sums as are necessary for subsequent fiscal years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
