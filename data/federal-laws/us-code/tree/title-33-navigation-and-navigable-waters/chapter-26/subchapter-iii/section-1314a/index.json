ress","identifier":"/us/usc/t33/s1314a/b","parentIdentifier":"/us/usc/t33/s1314a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1314a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1314a/b/1","parentIdentifier":"/us/usc/t33/s1314a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1314a%2Fb%2F1","sourceRelease":"119-100","text":"the type and amount of information provided under subsection (a) to units of local government and nonprofit organizations regarding alternative wastewater treatment and recycling technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1314a/b/2","parentIdentifier":"/us/usc/t33/s1314a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1314a%2Fb%2F2","sourceRelease":"119-100","text":"the States and regions that have made greatest use of alternative wastewater treatment and recycling technologies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s1314a/b/3","parentIdentifier":"/us/usc/t33/s1314a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1314a%2Fb%2F3","sourceRelease":"119-100","text":"the actions taken by the Administrator to assist States in the deployment of alternative wastewater treatment and recycling technologies, including onsite and decentralized systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
