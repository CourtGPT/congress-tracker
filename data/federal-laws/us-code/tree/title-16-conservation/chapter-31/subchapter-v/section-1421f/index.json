{"type":"section","nativeType":"section","number":"1421f","heading":"National Marine Mammal Tissue Bank and tissue analysis","label":"1421f National Marine Mammal Tissue Bank and tissue analysis","identifier":"/us/usc/t16/s1421f","parentIdentifier":"/us/usc/t16/ch31/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2022—Subsec. (c)(2)(A). , substituted “marine mammal health and mortality and the health of” for “the health of marine mammals and”.Pub. L. 117–263, § 10405(1)Subsec. (d). , inserted “public” before “access” in introductory provisions.Pub. L. 117–263, § 10405(2)"],"amendments":["Amendments2022—Subsec. (c)(2)(A). , substituted “marine mammal health and mortality and the health of” for “the health of marine mammals and”.Pub. L. 117–263, § 10405(1)Subsec. (d). , inserted “public” before “access” in introductory provisions.Pub. L. 117–263, § 10405(2)"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Tissue Bank","label":"a Tissue Bank","identifier":"/us/usc/t16/s1421f/a","parentIdentifier":"/us/usc/t16/s1421f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s1421f/a/1","parentIdentifier":"/us/usc/t16/s1421f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary shall make provision for the storage, preparation, examination, and archiving of marine mammal tissues. Tissues archived pursuant to this subsection shall be known as the “National Marine Mammal Tissue Bank”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Guidance for marine mammal tissue collection, preparation, and archiving","label":"2 Guidance for marine mammal tissue collection, preparation, and archiving","identifier":"/us/usc/t16/s1421f/a/2","parentIdentifier":"/us/usc/t16/s1421f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1421f/a/2/A","parentIdentifier":"/us/usc/t16/s1421f/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%2Fa%2F2%2FA","sourceRelease":"119-100","text":"appropriate and uniform methods and standards for those activities to provide confidence in marine mammal tissue samples used for research; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1421f/a/2/B","parentIdentifier":"/us/usc/t16/s1421f/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%2Fa%2F2%2FB","sourceRelease":"119-100","text":"documentation of procedures used for collecting, preparing, and archiving those samples.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Source of tissue","label":"3 Source of tissue","identifier":"/us/usc/t16/s1421f/a/3","parentIdentifier":"/us/usc/t16/s1421f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1421f%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1421f/a/3/A","parentIdentifier":"/us/usc/t16/s1421f/a/3","