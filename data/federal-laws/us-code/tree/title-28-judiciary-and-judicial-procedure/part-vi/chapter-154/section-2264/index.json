{"type":"section","nativeType":"section","number":"2264","heading":"Scope of Federal review; district court adjudications","label":"2264 Scope of Federal review; district court adjudications","identifier":"/us/usc/t28/s2264","parentIdentifier":"/us/usc/t28/ptVI/ch154","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs2264","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection applicable to cases pending on or after , see , set out as a note under .Apr. 24, 1996section 107(c) of Pub. L. 104–132section 2261 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t28/s2264/a","parentIdentifier":"/us/usc/t28/s2264","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs2264%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t28/s2264/a/1","parentIdentifier":"/us/usc/t28/s2264/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs2264%2Fa%2F1","sourceRelease":"119-100","text":"the result of State action in violation of the Constitution or laws of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t28/s2264/a/2","parentIdentifier":"/us/usc/t28/s2264/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs2264%2Fa%2F2","sourceRelease":"119-100","text":"the result of the Supreme Court’s recognition of a new Federal right that is made retroactively applicable; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t28/s2264/a/3","parentIdentifier":"/us/usc/t28/s2264/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs2264%2Fa%2F3","sourceRelease":"119-100","text":"based on a factual predicate that could not have been discovered through the exercise of due diligence in time to present the claim for State or Federal post-conviction review.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t28/s2264/b","parentIdentifier":"/us/usc/t28/s2264","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft28%2Fs2264%2Fb","sourceRelease":"119-100","text":"Following review subject to subsections (a), (d), and (e) of section 2254, the court shall rule on the claims properly before it.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
