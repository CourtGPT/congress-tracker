{"type":"section","nativeType":"section","number":"16255","heading":"Preprocessing and harvesting demonstration grants","label":"16255 Preprocessing and harvesting demonstration grants","identifier":"/us/usc/t42/s16255","parentIdentifier":"/us/usc/t42/ch149/schIX/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16255","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s16255/a","parentIdentifier":"/us/usc/t42/s16255","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16255%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16255/a/1","parentIdentifier":"/us/usc/t42/s16255/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16255%2Fa%2F1","sourceRelease":"119-100","text":"preprocessing of feedstocks, including cleaning, separating and sorting, mixing or blending, and chemical or biochemical treatments, to add value and lower the cost of feedstock processing at a biorefinery; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16255/a/2","parentIdentifier":"/us/usc/t42/s16255/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16255%2Fa%2F2","sourceRelease":"119-100","text":"1-pass or other efficient, multiple crop harvesting techniques.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitations on grants","label":"b Limitations on grants","identifier":"/us/usc/t42/s16255/b","parentIdentifier":"/us/usc/t42/s16255","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16255%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Number of grants","label":"1 Number of grants","identifier":"/us/usc/t42/s16255/b/1","parentIdentifier":"/us/usc/t42/s16255/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16255%2Fb%2F1","sourceRelease":"119-100","text":"Not more than 5 demonstration projects per fiscal year shall be funded under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Non-Federal cost share","label":"2 Non-Federal cost share","identifier":"/us/usc/t42/s16255/b/2","parentIdentifier":"/us/usc/t42/s16255/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16255%2Fb%2F2","sourceRelease":"119-100","text":"The non-Federal cost share of a project under this section shall be not less than 20 percent, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Condition of grant","label":"c Condition of grant","identifier":"/us/usc/t42/s16255/c","parentIdentifier":"/us/usc/t42/s16255","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16255%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16255/c/1","parentIdentifier":"/us/usc/t42/s16255/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16255%2Fc%2F1","sourceRelease":"119-100","text":"to produce ethanol; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16255/c/2","parentIdentifier":"/us/usc/t42/s16255/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16255%2Fc%2F2","sourceRelease":"119-100","text":"for another energy purpose, such as the generation of heat or electricity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization for appropriations","label":"d Authorization for appropriations","identifier":"/us/usc/t42/s16255/d","parentIdentifier":"/us/usc/t42/s16255","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16255%2Fd","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2006 through 2010.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
