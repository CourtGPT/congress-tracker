{"type":"section","nativeType":"section","number":"1662","heading":"Advertising of downpayments and installments","label":"1662 Advertising of downpayments and installments","identifier":"/us/usc/t15/s1662","parentIdentifier":"/us/usc/t15/ch41/schI/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1662","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s1662/1","parentIdentifier":"/us/usc/t15/s1662","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1662%2F1","sourceRelease":"119-100","text":"that a specific periodic consumer credit amount or installment amount can be arranged, unless the creditor usually and customarily arranges credit payments or installments for that period and in that amount.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s1662/2","parentIdentifier":"/us/usc/t15/s1662","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs1662%2F2","sourceRelease":"119-100","text":"that a specified downpayment is required in connection with any extension of consumer credit, unless the creditor usually and customarily arranges downpayments in that amount.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
