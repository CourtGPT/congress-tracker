{"type":"section","nativeType":"section","number":"6924","heading":"Food Loss and Waste Reduction Liaison","label":"6924 Food Loss and Waste Reduction Liaison","identifier":"/us/usc/t7/s6924","parentIdentifier":"/us/usc/t7/ch98/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t7/s6924/a","parentIdentifier":"/us/usc/t7/s6924","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish a Food Loss and Waste Reduction Liaison to coordinate Federal, State, local, and nongovernmental programs, and other efforts, to measure and reduce the incidence of food loss and waste in accordance with this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"In general","label":"b In general","identifier":"/us/usc/t7/s6924/b","parentIdentifier":"/us/usc/t7/s6924","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s6924/b/1","parentIdentifier":"/us/usc/t7/s6924/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fb%2F1","sourceRelease":"119-100","text":"coordinate food loss and waste reduction efforts within the Department of Agriculture and with other Federal agencies, including the Environmental Protection Agency and the Food and Drug Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s6924/b/2","parentIdentifier":"/us/usc/t7/s6924/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fb%2F2","sourceRelease":"119-100","text":"support and promote Federal programs to measure and reduce the incidence of food loss and waste and increase food recovery;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s6924/b/3","parentIdentifier":"/us/usc/t7/s6924/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fb%2F3","sourceRelease":"119-100","text":"provide information to, and serve as a resource for, entities engaged in food loss and waste reduction and food recovery, including information about the availability of, and eligibility requirements for, participation in Federal, State, local, and nongovernmental programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s6924/b/4","parentIdentifier":"/us/usc/t7/s6924/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fb%2F4","sourceRelease":"119-100","text":"raise awareness of the liability protections afforded under the Bill Emerson Good Samaritan Food Donation Act () to persons engaged in food loss and waste reduction and food recovery; and42 U.S.C. 1791","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s6924/b/5","parentIdentifier":"/us/usc/t7/s6924/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fb%2F5","sourceRelease":"119-100","text":"make recommendations with respect to expanding innovative food recovery models and reducing the incidence of food loss and waste.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Cooperative agreements","label":"c Cooperative agreements","identifier":"/us/usc/t7/s6924/c","parentIdentifier":"/us/usc/t7/s6924","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s6924/c/1","parentIdentifier":"/us/usc/t7/s6924/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fc%2F1","sourceRelease":"119-100","text":"the development of educational materials;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s6924/c/2","parentIdentifier":"/us/usc/t7/s6924/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fc%2F2","sourceRelease":"119-100","text":"the conduct of workshops and courses; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s6924/c/3","parentIdentifier":"/us/usc/t7/s6924/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fc%2F3","sourceRelease":"119-100","text":"the conduct of research on best practices with respect to food loss and waste reduction and food recovery.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Study on food waste","label":"d Study on food waste","identifier":"/us/usc/t7/s6924/d","parentIdentifier":"/us/usc/t7/s6924","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s6924/d/1","parentIdentifier":"/us/usc/t7/s6924/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fd%2F1","sourceRelease":"119-100","text":"methods of measuring food waste;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s6924/d/2","parentIdentifier":"/us/usc/t7/s6924/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fd%2F2","sourceRelease":"119-100","text":"standards for the volume of food waste;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s6924/d/3","parentIdentifier":"/us/usc/t7/s6924/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fd%2F3","sourceRelease":"119-100","text":"factors that contribute to food waste;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s6924/d/4","parentIdentifier":"/us/usc/t7/s6924/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fd%2F4","sourceRelease":"119-100","text":"the cost and volume of food loss;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s6924/d/5","parentIdentifier":"/us/usc/t7/s6924/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fd%2F5","sourceRelease":"119-100","text":"the effectiveness of existing liability protections afforded under the Bill Emerson Good Samaritan Food Donation Act (); and42 U.S.C. 1791","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s6924/d/6","parentIdentifier":"/us/usc/t7/s6924/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fd%2F6","sourceRelease":"119-100","text":"measures to ensure that programs contemplated, undertaken, or funded by the Department of Agriculture do not disrupt existing food waste recovery and disposal efforts by commercial, marketing, or business relationships.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Reports","label":"e Reports","identifier":"/us/usc/t7/s6924/e","parentIdentifier":"/us/usc/t7/s6924","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Initial report","label":"1 Initial report","identifier":"/us/usc/t7/s6924/e/1","parentIdentifier":"/us/usc/t7/s6924/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fe%2F1","sourceRelease":"119-100","text":"Not later than 1 year after , the Food Loss and Waste Liaison shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that describes the results of the study conducted under subsection (d).December 20, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report","label":"2 Report","identifier":"/us/usc/t7/s6924/e/2","parentIdentifier":"/us/usc/t7/s6924/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6924/e/2/A","parentIdentifier":"/us/usc/t7/s6924/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fe%2F2%2FA","sourceRelease":"119-100","text":"an estimate of the quantity of food waste during such year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6924/e/2/B","parentIdentifier":"/us/usc/t7/s6924/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6924%2Fe%2F2%2FB","sourceRelease":"119-100","text":"the results of the food waste reduction and loss prevention activities carried out or led by the Department of Agriculture.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
