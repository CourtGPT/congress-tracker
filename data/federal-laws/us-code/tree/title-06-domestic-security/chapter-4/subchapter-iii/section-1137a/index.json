ier":"/us/usc/t6/s1137a/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1137a%2Fd%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s1137a/d/2/C/i","parentIdentifier":"/us/usc/t6/s1137a/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1137a%2Fd%2F2%2FC%2Fi","sourceRelease":"119-100","text":"an entity offering scheduled, fixed-route transportation services by over-the-road bus (as such term is defined in ); orsection 1151(4) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s1137a/d/2/C/ii","parentIdentifier":"/us/usc/t6/s1137a/d/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1137a%2Fd%2F2%2FC%2Fii","sourceRelease":"119-100","text":"a bus terminal; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s1137a/d/2/D","parentIdentifier":"/us/usc/t6/s1137a/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1137a%2Fd%2F2%2FD","sourceRelease":"119-100","text":"other transportation facilities, equipment, or systems, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s1137a/d/3","parentIdentifier":"/us/usc/t6/s1137a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1137a%2Fd%2F3","sourceRelease":"119-100","text":"The term “targeted violence” means an incident of violence in which an attacker selected a particular target in order to inflict mass injury or death with no discernable political or ideological motivation beyond mass injury or death.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s1137a/d/4","parentIdentifier":"/us/usc/t6/s1137a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1137a%2Fd%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s1137a/d/4/A","parentIdentifier":"/us/usc/t6/s1137a/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1137a%2Fd%2F4%2FA","sourceRelease":"119-100","text":"domestic terrorism (as such term is defined in ); andsection 2331(5) of title 18","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s1137a/d/4/B","parentIdentifier":"/us/usc/t6/s1137a/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1137a%2Fd%2F4%2FB","sourceRelease":"119-100","text":"international terrorism (as such term is defined in ).section 2331(1) of title 18","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
