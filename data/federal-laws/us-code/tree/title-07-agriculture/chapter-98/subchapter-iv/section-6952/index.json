{"type":"section","nativeType":"section","number":"6952","heading":"Multiagency task force","label":"6952 Multiagency task force","identifier":"/us/usc/t7/s6952","parentIdentifier":"/us/usc/t7/ch98/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2018—Subsec. (b)(3). substituted “Under Secretary of Agriculture for Farm Production and Conservation” for “Under Secretary for Farm and Foreign Agricultural Services”.Pub. L. 115–334"],"amendments":["Amendments2018—Subsec. (b)(3). substituted “Under Secretary of Agriculture for Farm Production and Conservation” for “Under Secretary for Farm and Foreign Agricultural Services”.Pub. L. 115–334"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t7/s6952/a","parentIdentifier":"/us/usc/t7/s6952","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish, in the office of the Under Secretary for Food, Nutrition, and Consumer Services, a multiagency task force for the purpose of providing coordination and direction for commodity programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Composition","label":"b Composition","identifier":"/us/usc/t7/s6952/b","parentIdentifier":"/us/usc/t7/s6952","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s6952/b/1","parentIdentifier":"/us/usc/t7/s6952/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6952/b/1/A","parentIdentifier":"/us/usc/t7/s6952/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fb%2F1%2FA","sourceRelease":"119-100","text":"be appointed by the Under Secretary for Food, Nutrition, and Consumer Services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6952/b/1/B","parentIdentifier":"/us/usc/t7/s6952/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fb%2F1%2FB","sourceRelease":"119-100","text":"serve as Chairperson of the Task Force;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s6952/b/2","parentIdentifier":"/us/usc/t7/s6952/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fb%2F2","sourceRelease":"119-100","text":"at least 1 representative from the Agricultural Marketing Service, who shall be appointed by the Under Secretary for Marketing and Regulatory Programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s6952/b/3","parentIdentifier":"/us/usc/t7/s6952/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fb%2F3","sourceRelease":"119-100","text":"at least 1 representative from the Farm Services Agency, who shall be appointed by the Under Secretary of Agriculture for Farm Production and Conservation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s6952/b/4","parentIdentifier":"/us/usc/t7/s6952/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fb%2F4","sourceRelease":"119-100","text":"at least 1 representative from the Food Safety and Inspection Service, who shall be appointed by the Under Secretary for Food Safety.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duties","label":"c Duties","identifier":"/us/usc/t7/s6952/c","parentIdentifier":"/us/usc/t7/s6952","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s6952/c/1","parentIdentifier":"/us/usc/t7/s6952/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6952/c/1/A","parentIdentifier":"/us/usc/t7/s6952/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fc%2F1%2FA","sourceRelease":"119-100","text":"to support the United States farm sector; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6952/c/1/B","parentIdentifier":"/us/usc/t7/s6952/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fc%2F1%2FB","sourceRelease":"119-100","text":"to contribute to the health and well-being of individuals in the United States through the distribution of domestic agricultural products through commodity programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Specific duties","label":"2 Specific duties","identifier":"/us/usc/t7/s6952/c/2","parentIdentifier":"/us/usc/t7/s6952/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s6952/c/2/A","parentIdentifier":"/us/usc/t7/s6952/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fc%2F2%2FA","sourceRelease":"119-100","text":"review and make recommendations regarding the specifications used for the procurement of food commodities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s6952/c/2/B","parentIdentifier":"/us/usc/t7/s6952/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fc%2F2%2FB","sourceRelease":"119-100","text":"review and make recommendations regarding the efficient and effective distribution of food commodities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s6952/c/2/C","parentIdentifier":"/us/usc/t7/s6952/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fc%2F2%2FC","sourceRelease":"119-100","text":"review and make recommendations regarding the degree to which the quantity, quality, and specifications of procured food commodities align the needs of producers and the preferences of recipient agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Reports","label":"d Reports","identifier":"/us/usc/t7/s6952/d","parentIdentifier":"/us/usc/t7/s6952","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s6952/d/1","parentIdentifier":"/us/usc/t7/s6952/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fd%2F1","sourceRelease":"119-100","text":"the findings and recommendations of the Task Force; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s6952/d/2","parentIdentifier":"/us/usc/t7/s6952/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs6952%2Fd%2F2","sourceRelease":"119-100","text":"policies implemented for the improvement of commodity procurement programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
