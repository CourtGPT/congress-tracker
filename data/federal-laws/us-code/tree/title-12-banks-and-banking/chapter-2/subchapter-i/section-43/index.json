{"type":"section","nativeType":"section","number":"43","heading":"Interpretations concerning preemption of certain State laws","label":"43 Interpretations concerning preemption of certain State laws","identifier":"/us/usc/t12/s43","parentIdentifier":"/us/usc/t12/ch2/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs43","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationAnother R.S. § 5244 is classified to , Navigation and Navigable Waters.section 8 of Title 33"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Notice and opportunity for comment required","label":"a Notice and opportunity for comment required","identifier":"/us/usc/t12/s43/a","parentIdentifier":"/us/usc/t12/s43","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs43%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s43/a/1","parentIdentifier":"/us/usc/t12/s43/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs43%2Fa%2F1","sourceRelease":"119-100","text":"publish in the Federal Register notice of the preemption or discrimination issue that the agency is considering (including a description of each State law at issue);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s43/a/2","parentIdentifier":"/us/usc/t12/s43/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs43%2Fa%2F2","sourceRelease":"119-100","text":"give interested parties not less than 30 days in which to submit written comments; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t12/s43/a/3","parentIdentifier":"/us/usc/t12/s43/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs43%2Fa%2F3","sourceRelease":"119-100","text":"in developing the final opinion letter or interpretive rule issued by the agency, or making any determination under , consider any comments received.section 36(f)(1)(A)(ii) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Publication required","label":"b Publication required","identifier":"/us/usc/t12/s43/b","parentIdentifier":"/us/usc/t12/s43","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs43%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s43/b/1","parentIdentifier":"/us/usc/t12/s43/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs43%2Fb%2F1","sourceRelease":"119-100","text":"any final opinion letter or interpretive rule concluding that Federal law preempts the application of any State law regarding community reinvestment, consumer protection, fair lending, or establishment of intrastate branches to a national bank; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s43/b/2","parentIdentifier":"/us/usc/t12/s43/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs43%2Fb%2F2","sourceRelease":"119-100","text":"any determination under .section 36(f)(1)(A)(ii) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Exceptions","label":"c Exceptions","identifier":"/us/usc/t12/s43/c","parentIdentifier":