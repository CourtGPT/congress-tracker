{"type":"section","nativeType":"section","number":"2311","heading":"Response to threats of terrorist use of weapons of mass destruction","label":"2311 Response to threats of terrorist use of weapons of mass destruction","identifier":"/us/usc/t50/s2311","parentIdentifier":"/us/usc/t50/ch40/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2311","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Enhanced response capability","label":"a Enhanced response capability","identifier":"/us/usc/t50/s2311/a","parentIdentifier":"/us/usc/t50/s2311","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2311%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2311/a/1","parentIdentifier":"/us/usc/t50/s2311/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2311%2Fa%2F1","sourceRelease":"119-100","text":"to enhance the capability of the Federal Government to prevent and respond to terrorist incidents involving weapons of mass destruction; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2311/a/2","parentIdentifier":"/us/usc/t50/s2311/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2311%2Fa%2F2","sourceRelease":"119-100","text":"to provide enhanced support to improve the capabilities of State and local emergency response agencies to prevent and respond to such incidents at both the national and the local level.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report required","label":"b Report required","identifier":"/us/usc/t50/s2311/b","parentIdentifier":"/us/usc/t50/s2311","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2311%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s2311/b/1","parentIdentifier":"/us/usc/t50/s2311/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2311%2Fb%2F1","sourceRelease":"119-100","text":"an assessment of the capabilities of the Federal Government to prevent and respond to terrorist incidents involving weapons of mass destruction and to support State and local prevention and response efforts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s2311/b/2","parentIdentifier":"/us/usc/t50/s2311/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2311%2Fb%2F2","sourceRelease":"119-100","text":"requirements for improvements in those capabilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s2311/b/3","parentIdentifier":"/us/usc/t50/s2311/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs2311%2Fb%2F3","sourceRelease":"119-100","text":"the measures that should be taken to achieve such improvements, including additional resources and legislative authorities that would be required.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
