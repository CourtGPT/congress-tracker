{"type":"section","nativeType":"section","number":"9046","heading":"Suspension of certain aviation excise taxes","label":"9046 Suspension of certain aviation excise taxes","identifier":"/us/usc/t15/s9046","parentIdentifier":"/us/usc/t15/ch116/schIII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9046","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Transportation by air","label":"a Transportation by air","identifier":"/us/usc/t15/s9046/a","parentIdentifier":"/us/usc/t15/s9046","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9046%2Fa","sourceRelease":"119-100","text":"In the case of any amount paid for transportation by air (including any amount treated as paid for transportation by air by reason of ) during the excise tax holiday period, no tax shall be imposed under section 4261 or 4271 of title 26. The preceding sentence shall not apply to amounts paid on or before .section 4261(e)(3) of title 26March 27, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Use of Kerosene in commercial aviation","label":"b Use of Kerosene in commercial aviation","identifier":"/us/usc/t15/s9046/b","parentIdentifier":"/us/usc/t15/s9046","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9046%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9046/b/1","parentIdentifier":"/us/usc/t15/s9046/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9046%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A",