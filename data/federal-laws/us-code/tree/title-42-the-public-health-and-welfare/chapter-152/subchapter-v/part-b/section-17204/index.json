":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17204/a/1/F","parentIdentifier":"/us/usc/t42/s17204/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17204%2Fa%2F1%2FF","sourceRelease":"119-100","text":"a Native corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"High-cost region","label":"2 High-cost region","identifier":"/us/usc/t42/s17204/a/2","parentIdentifier":"/us/usc/t42/s17204/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17204%2Fa%2F2","sourceRelease":"119-100","text":"The term “high-cost region” means a region in which the average cost of electrical power or heat exceeds 150 percent of the national average retail cost, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Program","label":"b Program","identifier":"/us/usc/t42/s17204/b","parentIdentifier":"/us/usc/t42/s17204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17204%2Fb","sourceRelease":"119-100","text":"The Secretary shall use amounts made available to carry out this section to make grants to eligible entities for activities described in subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Eligible activities","label":"c Eligible activities","identifier":"/us/usc/t42/s17204/c","parentIdentifier":"/us/usc/t42/s17204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17204%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17204/c/1","parentIdentifier":"/us/usc/t42/s17204/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17204%2Fc%2F1","sourceRelease":"119-100","text":"to conduct a feasibility study, including a study of exploration, geochemical testing, geomagnetic surveys, geologic information gathering, baseline environmental studies, well drilling, resource characterization, permitting, and economic analysis;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17204/c/2","parentIdentifier":"/us/usc/t42/s17204/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17204%2Fc%2F2","sourceRelease":"119-100","text":"for design and engineering costs, relating to the project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17204/c/3","parentIdentifier":"/us/usc/t42/s17204/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17204%2Fc%2F3","sourceRelease":"119-100","text":"to demonstrate and promote commercial application of technologies related to geothermal energy as part of the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Cost sharing","label":"d Cost sharing","identifier":"/us/usc/t42/s17204/d","parentIdentifier":"/us/usc/t42/s17204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17204%2Fd","sourceRelease":"119-100","text":"The cost-sharing requirements of shall apply to any project carried out under this section.section 16352 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s17204/e","parentIdentifier":"/us/usc/t42/s17204","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17204%2Fe","sourceRelease":"119-100","text":"Out of funds authorized under , there is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2021 through 2025.section 17202 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
