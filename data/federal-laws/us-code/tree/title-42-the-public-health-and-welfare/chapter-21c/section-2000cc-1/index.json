{"type":"section","nativeType":"section","number":"2000cc–1","heading":"Protection of religious exercise of institutionalized persons","label":"2000cc–1 Protection of religious exercise of institutionalized persons","identifier":"/us/usc/t42/s2000cc–1","parentIdentifier":"/us/usc/t42/ch21C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs2000cc%E2%80%931","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"General rule","label":"a General rule","identifier":"/us/usc/t42/s2000cc–1/a","parentIdentifier":"/us/usc/t42/s2000cc–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs2000cc%E2%80%931%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s2000cc–1/a/1","parentIdentifier":"/us/usc/t42/s2000cc–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs2000cc%E2%80%931%2Fa%2F1","sourceRelease":"119-100","text":"is in furtherance of a compelling governmental interest; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s2000cc–1/a/2","parentIdentifier":"/us/usc/t42/s2000cc–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs2000cc%E2%80%931%2Fa%2F2","sourceRelease":"119-100","text":"is the least restrictive means of furthering that compelling governmental interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Scope of application","label":"b Scope of application","identifier":"/us/usc/t42/s2000cc–1/b","parentIdentifier":"/us/usc/t42/s2000cc–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs2000cc%E2%80%931%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s2000cc–1/b/1","parentIdentifier":"/us/usc/t42/s2000cc–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs2000cc%E2%80%931%2Fb%2F1","sourceRelease":"119-100","text":"the substantial burden is imposed in a program or activity that receives Federal financial assistance; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s2000cc–1/b/2","parentIdentifier":"/us/usc/t42/s2000cc–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs2000cc%E2%80%931%2Fb%2F2","sourceRelease":"119-100","text":"the substantial burden affects, or removal of that substantial burden would affect, commerce with foreign nations, among the several States, or with Indian tribes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
