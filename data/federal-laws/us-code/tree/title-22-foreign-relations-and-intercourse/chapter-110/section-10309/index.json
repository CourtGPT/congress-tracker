{"type":"section","nativeType":"section","number":"10309","heading":"Post Data Pilot Program","label":"10309 Post Data Pilot Program","identifier":"/us/usc/t22/s10309","parentIdentifier":"/us/usc/t22/ch110","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","DefinitionsFor definitions of “Department” and “Secretary” as used in this section, see section 5002 of Pub. L. 119—60, set out as a note under .section 2651 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Post Data and AI Pilot Program","label":"a Post Data and AI Pilot Program","identifier":"/us/usc/t22/s10309/a","parentIdentifier":"/us/usc/t22/s10309","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Establishment","label":"1 Establishment","identifier":"/us/usc/t22/s10309/a/1","parentIdentifier":"/us/usc/t22/s10309/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fa%2F1","sourceRelease":"119-100","text":"The Secretary is authorized to establish a program, which shall be known as the “Post Data Program” (referred to in this section as the “Program”), that shall be overseen by the Department’s Chief Data and Artificial Intelligence Officer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Goals","label":"2 Goals","identifier":"/us/usc/t22/s10309/a/2","parentIdentifier":"/us/usc/t22/s10309/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10309/a/2/A","parentIdentifier":"/us/usc/t22/s10309/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fa%2F2%2FA","sourceRelease":"119-100","text":"Cultivating a data and artificial intelligence culture at diplomatic posts globally, including data fluency and data collaboration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10309/a/2/B","parentIdentifier":"/us/usc/t22/s10309/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fa%2F2%2FB","sourceRelease":"119-100","text":"Promoting data integration with Department of State Headquarters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10309/a/2/C","parentIdentifier":"/us/usc/t22/s10309/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fa%2F2%2FC","sourceRelease":"119-100","text":"Creating operational efficiencies, supporting innovation, and enhancing mission impact.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Implementation plan","label":"b Implementation plan","identifier":"/us/usc/t22/s10309/b","parentIdentifier":"/us/usc/t22/s10309","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s10309/b/1","parentIdentifier":"/us/usc/t22/s10309/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10309/b/1/A","parentIdentifier":"/us/usc/t22/s10309/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fb%2F1%2FA","sourceRelease":"119-100","text":"advancing the goals described in subsection (a)(2);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10309/b/1/B","parentIdentifier":"/us/usc/t22/s10309/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fb%2F1%2FB","sourceRelease":"119-100","text":"hiring data and artificial intelligence officers at United States diplomatic posts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10309/b/1/C","parentIdentifier":"/us/usc/t22/s10309/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fb%2F1%2FC","sourceRelease":"119-100","text":"allocation of necessary resources to sustain the Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Annual reporting requirement","label":"2 Annual reporting requirement","identifier":"/us/usc/t22/s10309/b/2","parentIdentifier":"/us/usc/t22/s10309/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fb%2F2","sourceRelease":"119-100","text":"Not later than 180 days after , and annually thereafter for the following three years, the Secretary shall submit a report to the appropriate congressional committees regarding the status of the implementation plan required under paragraph (1).December 18, 2025","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Appropriate congressional committees defined","label":"c Appropriate congressional committees defined","identifier":"/us/usc/t22/s10309/c","parentIdentifier":"/us/usc/t22/s10309","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10309/c/1","parentIdentifier":"/us/usc/t22/s10309/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fc%2F1","sourceRelease":"119-100","text":"the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10309/c/2","parentIdentifier":"/us/usc/t22/s10309/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10309%2Fc%2F2","sourceRelease":"119-100","text":"the Committee on Foreign Relations and the Committee on Appropriations of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
