{"type":"section","nativeType":"section","number":"40725","heading":"National Forensic Science Commission","label":"40725 National Forensic Science Commission","identifier":"/us/usc/t34/s40725","parentIdentifier":"/us/usc/t34/stIV/ch407/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to , The Public Health and Welfare, prior to editorial reclassification and renumbering as this section.section 14136c of Title 42"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Appointment","label":"a Appointment","identifier":"/us/usc/t34/s40725/a","parentIdentifier":"/us/usc/t34/s40725","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fa","sourceRelease":"119-100","text":"The Attorney General shall appoint a National Forensic Science Commission (in this section referred to as the “Commission”), composed of persons experienced in criminal justice issues, including persons from the forensic science and criminal justice communities, to carry out the responsibilities under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Responsibilities","label":"b Responsibilities","identifier":"/us/usc/t34/s40725/b","parentIdentifier":"/us/usc/t34/s40725","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s40725/b/1","parentIdentifier":"/us/usc/t34/s40725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb%2F1","sourceRelease":"119-100","text":"assess the present and future resource needs of the forensic science community;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s40725/b/2","parentIdentifier":"/us/usc/t34/s40725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb%2F2","sourceRelease":"119-100","text":"make recommendations to the Attorney General for maximizing the use of forensic technologies and techniques to solve crimes and protect the public;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s40725/b/3","parentIdentifier":"/us/usc/t34/s40725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb%2F3","sourceRelease":"119-100","text":"identify potential scientific advances that may assist law enforcement in using forensic technologies and techniques to protect the public;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t34/s40725/b/4","parentIdentifier":"/us/usc/t34/s40725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb%2F4","sourceRelease":"119-100","text":"make recommendations to the Attorney General for programs that will increase the number of qualified forensic scientists available to work in public crime laboratories;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t34/s40725/b/5","parentIdentifier":"/us/usc/t34/s40725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb%2F5","sourceRelease":"119-100","text":"disseminate, through the National Institute of Justice, best practices concerning the collection and analyses of forensic evidence to help ensure quality and consistency in the use of forensic technologies and techniques to solve crimes and protect the public;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t34/s40725/b/6","parentIdentifier":"/us/usc/t34/s40725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb%2F6","sourceRelease":"119-100","text":"examine additional issues pertaining to forensic science as requested by the Attorney General;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t34/s40725/b/7","parentIdentifier":"/us/usc/t34/s40725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb%2F7","sourceRelease":"119-100","text":"examine Federal, State, and local privacy protection statutes, regulations, and practices relating to access to, or use of, stored DNA samples or DNA analyses, to determine whether such protections are sufficient;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t34/s40725/b/8","parentIdentifier":"/us/usc/t34/s40725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s40725/b/8/A","parentIdentifier":"/us/usc/t34/s40725/b/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb%2F8%2FA","sourceRelease":"119-100","text":"the appropriate use and dissemination of DNA information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s40725/b/8/B","parentIdentifier":"/us/usc/t34/s40725/b/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb%2F8%2FB","sourceRelease":"119-100","text":"the accuracy, security, and confidentiality of DNA information;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s40725/b/8/C","parentIdentifier":"/us/usc/t34/s40725/b/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb%2F8%2FC","sourceRelease":"119-100","text":"the timely removal and destruction of obsolete, expunged, or inaccurate DNA information; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s40725/b/8/D","parentIdentifier":"/us/usc/t34/s40725/b/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb%2F8%2FD","sourceRelease":"119-100","text":"that any other necessary measures are taken to protect privacy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t34/s40725/b/9","parentIdentifier":"/us/usc/t34/s40725/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fb%2F9","sourceRelease":"119-100","text":"provide a forum for the exchange and dissemination of ideas and information in furtherance of the objectives described in paragraphs (1) through (8).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Personnel; procedures","label":"c Personnel; procedures","identifier":"/us/usc/t34/s40725/c","parentIdentifier":"/us/usc/t34/s40725","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s40725/c/1","parentIdentifier":"/us/usc/t34/s40725/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fc%2F1","sourceRelease":"119-100","text":"designate the Chair of the Commission from among its members;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s40725/c/2","parentIdentifier":"/us/usc/t34/s40725/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fc%2F2","sourceRelease":"119-100","text":"designate any necessary staff to assist in carrying out the functions of the Commission; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s40725/c/3","parentIdentifier":"/us/usc/t34/s40725/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fc%2F3","sourceRelease":"119-100","text":"establish procedures and guidelines for the operations of the Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t34/s40725/d","parentIdentifier":"/us/usc/t34/s40725","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs40725%2Fd","sourceRelease":"119-100","text":"There are authorized to be appropriated $500,000 for each of fiscal years 2005 through 2009 to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
