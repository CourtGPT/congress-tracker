{"type":"section","nativeType":"section","number":"4813","heading":"Refunds","label":"4813 Refunds","identifier":"/us/usc/t7/s4813","parentIdentifier":"/us/usc/t7/ch79","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4813","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , see , set out as a note under .Jan. 1, 1986section 1631 of Pub. L. 99–198section 4801 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Demand for refund; persons eligible","label":"a Demand for refund; persons eligible","identifier":"/us/usc/t7/s4813/a","parentIdentifier":"/us/usc/t7/s4813","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4813%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s4813/a/1","parentIdentifier":"/us/usc/t7/s4813/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4813%2Fa%2F1","sourceRelease":"119-100","text":"is responsible for paying such assessment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s4813/a/2","parentIdentifier":"/us/usc/t7/s4813/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4813%2Fa%2F2","sourceRelease":"119-100","text":"does not support the program established under this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Form and time within which demand to be made","label":"b Form and time within which demand to be made","identifier":"/us/usc/t7/s4813/b","parentIdentifier":"/us/usc/t7/s4813","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4813%2Fb","sourceRelease":"119-100","text":"Such demand shall be made in accordance with regulations, on a form, and within a time period prescribed by the Board and approved by the Secretary, but not later than 30 days after the end of the month in which the assessment was paid.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Payment of refund on submission of satisfactory proof","label":"c Payment of refund on submission of satisfactory proof","identifier":"/us/usc/t7/s4813/c","parentIdentifier":"/us/usc/t7/s4813","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4813%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s4813/c/1","parentIdentifier":"/us/usc/t7/s4813/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4813%2Fc%2F1","sourceRelease":"119-100","text":"paid the assessment for which refund is sought; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s4813/c/2","parentIdentifier":"/us/usc/t7/s4813/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4813%2Fc%2F2","sourceRelease":"119-100","text":"did not collect such assessment from another producer, person, or importer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
