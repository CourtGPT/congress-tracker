{"type":"section","nativeType":"section","number":"309","heading":"Land grants in the State of North Dakota","label":"309 Land grants in the State of North Dakota","identifier":"/us/usc/t7/s309","parentIdentifier":"/us/usc/t7/ch13/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs309","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Expenses","label":"a Expenses","identifier":"/us/usc/t7/s309/a","parentIdentifier":"/us/usc/t7/s309","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs309%2Fa","sourceRelease":"119-100","text":"Notwithstanding , the State of North Dakota shall manage the land granted to the State under , including any proceeds from the land, in accordance with this section.section 303 of this titlesection 301 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Disposition of proceeds","label":"b Disposition of proceeds","identifier":"/us/usc/t7/s309/b","parentIdentifier":"/us/usc/t7/s309","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs309%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s309/b/1","parentIdentifier":"/us/usc/t7/s309/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs309%2Fb%2F1","sourceRelease":"119-100","text":"deposit all revenues earned by a trust fund into the trust fund;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s309/b/2","parentIdentifier":"/us/usc/t7/s309/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%