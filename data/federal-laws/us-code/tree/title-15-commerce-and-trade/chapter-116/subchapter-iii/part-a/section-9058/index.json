bel":"ii","identifier":"/us/usc/t15/s9058/a/1/A/ii","parentIdentifier":"/us/usc/t15/s9058/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"without a lease or with a lease terminable under State law; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9058/a/1/B","parentIdentifier":"/us/usc/t15/s9058/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F1%2FB","sourceRelease":"119-100","text":"is on or in a covered property.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Covered property","label":"2 Covered property","identifier":"/us/usc/t15/s9058/a/2","parentIdentifier":"/us/usc/t15/s9058/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9058/a/2/A","parentIdentifier":"/us/usc/t15/s9058/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9058/a/2/A/i","parentIdentifier":"/us/usc/t15/s9058/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"a covered housing program (as defined in ); orsection 12491(a) of title 34","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9058/a/2/A/ii","parentIdentifier":"/us/usc/t15/s9058/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the rural housing voucher program under ; orsection 1490r of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9058/a/2/B","parentIdentifier":"/us/usc/t15/s9058/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s9058/a/2/B/i","parentIdentifier":"/us/usc/t15/s9058/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F2%2FB%2Fi","sourceRelease":"119-100","text":"Federally backed mortgage loan; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s9058/a/2/B/ii","parentIdentifier":"/us/usc/t15/s9058/a/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F2%2FB%2Fii","sourceRelease":"119-100","text":"Federally backed multifamily mortgage loan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Dwelling","label":"3 Dwelling","identifier":"/us/usc/t15/s9058/a/3","parentIdentifier":"/us/usc/t15/s9058/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9058/a/3/A","parentIdentifier":"/us/usc/t15/s9058/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F3%2FA","sourceRelease":"119-100","text":"has the meaning given the term in ; andsection 3602 of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9058/a/3/B","parentIdentifier":"/us/usc/t15/s9058/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F3%2FB","sourceRelease":"119-100","text":"includes houses and dwellings described in .section 3603(b) of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Federally backed mortgage loan","label":"4 Federally backed mortgage loan","identifier":"/us/usc/t15/s9058/a/4","parentIdentifier":"/us/usc/t15/s9058/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9058/a/4/A","parentIdentifier":"/us/usc/t15/s9058/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F4%2FA","sourceRelease":"119-100","text":"is secured by a first or subordinate lien on residential real property (including individual units of condominiums and cooperatives) designed principally for the occupancy of from 1 to 4 families, including any such secured loan, the proceeds of which are used to prepay or pay off an existing loan secured by the same property; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9058/a/4/B","parentIdentifier":"/us/usc/t15/s9058/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F4%2FB","sourceRelease":"119-100","text":"is made in whole or in part, or insured, guaranteed, supplemented, or assisted in any way, by any officer or agency of the Federal Government or under or in connection with a housing or urban development program administered by the Secretary of Housing and Urban Development or a housing or related program administered by any other such officer or agency, or is purchased or securitized by the Federal Home Loan Mortgage Corporation or the Federal National Mortgage Association.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Federally backed multifamily mortgage loan","label":"5 Federally backed multifamily mortgage loan","identifier":"/us/usc/t15/s9058/a/5","parentIdentifier":"/us/usc/t15/s9058/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9058/a/5/A","parentIdentifier":"/us/usc/t15/s9058/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F5%2FA","sourceRelease":"119-100","text":"is secured by a first or subordinate lien on residential multifamily real property designed principally for the occupancy of 5 or more families, including any such secured loan, the proceeds of which are used to prepay or pay off an existing loan secured by the same property; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9058/a/5/B","parentIdentifier":"/us/usc/t15/s9058/a/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fa%2F5%2FB","sourceRelease":"119-100","text":"is made in whole or in part, or insured, guaranteed, supplemented, or assisted in any way, by any officer or agency of the Federal Government or under or in connection with a housing or urban development program administered by the Secretary of Housing and Urban Development or a housing or related program administered by any other such officer or agency, or is purchased or securitized by the Federal Home Loan Mortgage Corporation or the Federal National Mortgage Association.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Moratorium","label":"b Moratorium","identifier":"/us/usc/t15/s9058/b","parentIdentifier":"/us/usc/t15/s9058","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9058/b/1","parentIdentifier":"/us/usc/t15/s9058/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fb%2F1","sourceRelease":"119-100","text":"make, or cause to be made, any filing with the court of jurisdiction to initiate a legal action to recover possession of the covered dwelling from the tenant for nonpayment of rent or other fees or charges; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9058/b/2","parentIdentifier":"/us/usc/t15/s9058/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fb%2F2","sourceRelease":"119-100","text":"charge fees, penalties, or other charges to the tenant related to such nonpayment of rent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Notice","label":"c Notice","identifier":"/us/usc/t15/s9058/c","parentIdentifier":"/us/usc/t15/s9058","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s9058/c/1","parentIdentifier":"/us/usc/t15/s9058/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fc%2F1","sourceRelease":"119-100","text":"may not require the tenant to vacate the covered dwelling unit before the date that is 30 days after the date on which the lessor provides the tenant with a notice to vacate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s9058/c/2","parentIdentifier":"/us/usc/t15/s9058/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9058%2Fc%2F2","sourceRelease":"119-100","text":"may not issue a notice to vacate under paragraph (1) until after the expiration of the period described in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
