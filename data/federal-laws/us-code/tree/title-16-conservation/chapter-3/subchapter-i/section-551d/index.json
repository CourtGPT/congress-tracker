{"type":"section","nativeType":"section","number":"551d","heading":"Wildland firefighter safety","label":"551d Wildland firefighter safety","identifier":"/us/usc/t16/s551d","parentIdentifier":"/us/usc/t16/ch3/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t16/s551d/a","parentIdentifier":"/us/usc/t16/s551d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Secretaries","label":"1 Secretaries","identifier":"/us/usc/t16/s551d/a/1","parentIdentifier":"/us/usc/t16/s551d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s551d/a/1/A","parentIdentifier":"/us/usc/t16/s551d/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the Secretary of the Interior, acting through the Directors of the Bureau of Land Management, the United States Fish and Wildlife Service, the National Park Service, and the Bureau of Indian Affairs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s551d/a/1/B","parentIdentifier":"/us/usc/t16/s551d/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the Secretary of Agriculture, acting through the Chief of the Forest Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Wildland firefighter","label":"2 Wildland firefighter","identifier":"/us/usc/t16/s551d/a/2","parentIdentifier":"/us/usc/t16/s551d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s551d/a/2/A","parentIdentifier":"/us/usc/t16/s551d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fa%2F2%2FA","sourceRelease":"119-100","text":"under the direction of either of the Secretaries; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s551d/a/2/B","parentIdentifier":"/us/usc/t16/s551d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fa%2F2%2FB","sourceRelease":"119-100","text":"under a contract or compact with a federally recognized Indian tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Annual report to Congress","label":"b Annual report to Congress","identifier":"/us/usc/t16/s551d/b","parentIdentifier":"/us/usc/t16/s551d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s551d/b/1","parentIdentifier":"/us/usc/t16/s551d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fb%2F1","sourceRelease":"119-100","text":"The Secretaries shall jointly submit to Congress an annual report on the wildland firefighter safety practices of the Secretaries, including training programs and activities for wildland fire suppression, prescribed burning, and wildland fire use, during the preceding calendar year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Timeline","label":"2 Timeline","identifier":"/us/usc/t16/s551d/b/2","parentIdentifier":"/us/usc/t16/s551d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s551d/b/2/A","parentIdentifier":"/us/usc/t16/s551d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fb%2F2%2FA","sourceRelease":"119-100","text":"be submitted by not later than March of the year following the calendar year covered by the report; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s551d/b/2/B","parentIdentifier":"/us/usc/t16/s551d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s551d/b/2/B/i","parentIdentifier":"/us/usc/t16/s551d/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"a description of, and any changes to, wildland firefighter safety practices, including training programs and activities for wildland fire suppression, prescribed burning, and wildland fire use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s551d/b/2/B/ii","parentIdentifier":"/us/usc/t16/s551d/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"statistics and trend analyses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s551d/b/2/B/iii","parentIdentifier":"/us/usc/t16/s551d/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fb%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"an estimate of the amount of Federal funds expended by the Secretaries on wildland firefighter safety practices, including training programs and activities for wildland fire suppression, prescribed burning, and wildland fire use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s551d/b/2/B/iv","parentIdentifier":"/us/usc/t16/s551d/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fb%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"progress made in implementing recommendations from the Inspector General, the Government Accountability Office, the Occupational Safety and Health Administration, or an agency report relating to a wildland firefighting fatality issued during the preceding 10 years; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t16/s551d/b/2/B/v","parentIdentifier":"/us/usc/t16/s551d/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fb%2F2%2FB%2Fv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s551d/b/2/B/v/I","parentIdentifier":"/us/usc/t16/s551d/b/2/B/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fb%2F2%2FB%2Fv%2FI","sourceRelease":"119-100","text":"the provisions relating to wildland firefighter safety practices in any Federal contract or other agreement governing the provision of wildland firefighters by a non-Federal entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s551d/b/2/B/v/II","parentIdentifier":"/us/usc/t16/s551d/b/2/B/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fb%2F2%2FB%2Fv%2FII","sourceRelease":"119-100","text":"a summary of any actions taken by the Secretaries to ensure that the provisions relating to safety practices, including training, are complied with by the non-Federal entity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s551d/b/2/B/v/III","parentIdentifier":"/us/usc/t16/s551d/b/2/B/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs551d%2Fb%2F2%2FB%2Fv%2FIII","sourceRelease":"119-100","text":"the results of those actions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}]}
