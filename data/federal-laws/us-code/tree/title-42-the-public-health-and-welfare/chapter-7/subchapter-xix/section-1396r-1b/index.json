1b%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s1396r–1b/c/1","parentIdentifier":"/us/usc/t42/s1396r–1b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s1396r–1b/c/1/A","parentIdentifier":"/us/usc/t42/s1396r–1b/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fc%2F1%2FA","sourceRelease":"119-100","text":"such forms as are necessary for an application to be made by an individual described in subsection (a) for medical assistance under the State plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s1396r–1b/c/1/B","parentIdentifier":"/us/usc/t42/s1396r–1b/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fc%2F1%2FB","sourceRelease":"119-100","text":"information on how to assist such individuals in completing and filing such forms.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Notification requirements","label":"2 Notification requirements","identifier":"/us/usc/t42/s1396r–1b/c/2","parentIdentifier":"/us/usc/t42/s1396r–1b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s1396r–1b/c/2/A","parentIdentifier":"/us/usc/t42/s1396r–1b/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fc%2F2%2FA","sourceRelease":"119-100","text":"notify the State agency of the determination within 5 working days after the date on which determination is made; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s1396r–1b/c/2/B","parentIdentifier":"/us/usc/t42/s1396r–1b/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fc%2F2%2FB","sourceRelease":"119-100","text":"inform such individual at the time the determination is made that an application for medical assistance under the State plan is required to be made by not later than the last day of the month following the month during which the determination is made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Application for medical assistance","label":"3 Application for medical assistance","identifier":"/us/usc/t42/s1396r–1b/c/3","parentIdentifier":"/us/usc/t42/s1396r–1b/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs1396r%E2%80%931b%2Fc%2F3","sourceRelease":"119-100","text":"In the case of an individual described in subsection (a) who is determined by a qualified entity to be presumptively eligible for medical assistance under a State plan, the individual shall apply for medical assistance under such plan by not later than the last day of the month following the month during which the determination is made.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Payment","label":"d Payment","identifier":"/us/usc/t42/s1396r–1b/d","parentIdentifier":"/us/usc/t42