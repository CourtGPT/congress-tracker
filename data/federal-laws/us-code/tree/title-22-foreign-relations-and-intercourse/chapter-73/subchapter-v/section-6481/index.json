{"type":"section","nativeType":"section","number":"6481","heading":"Business codes of conduct","label":"6481 Business codes of conduct","identifier":"/us/usc/t22/s6481","parentIdentifier":"/us/usc/t22/ch73/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6481","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Congressional finding","label":"a Congressional finding","identifier":"/us/usc/t22/s6481/a","parentIdentifier":"/us/usc/t22/s6481","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6481%2Fa","sourceRelease":"119-100","text":"Congress recognizes the increasing importance of transnational corporations as global actors, and their potential for providing positive leadership in their host countries in the area of human rights.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Sense of Congress","label":"b Sense of Congress","identifier":"/us/usc/t22/s6481/b","parentIdentifier":"/us/usc/t22/s6481","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6481%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s6481/b/1","parentIdentifier":"/us/usc/t22/s6481/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6481%2Fb%2F1","sourceRelease":"119-100","text":"upholding the right to freedom of religion of their employees; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s6481/b/2","parentIdentifier":"/us/usc/t22/s6481/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6481%2Fb%2F2","sourceRelease":"119-100","text":"ensuring that a worker’s religious views and peaceful practices of belief in no way affect, or be allowed to affect, the status or terms of his or her employment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
