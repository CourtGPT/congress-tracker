[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16535/d/2/B","parentIdentifier":"/us/usc/t42/s16535/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16535%2Fd%2F2%2FB","sourceRelease":"119-100","text":"made through an open, competitive selection process.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Term","label":"3 Term","identifier":"/us/usc/t42/s16535/d/3","parentIdentifier":"/us/usc/t42/s16535/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16535%2Fd%2F3","sourceRelease":"119-100","text":"An Institute shall receive a grant under this section for not more than 3 fiscal years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Review","label":"e Review","identifier":"/us/usc/t42/s16535/e","parentIdentifier":"/us/usc/t42/s16535","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16535%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16535/e/1","parentIdentifier":"/us/usc/t42/s16535/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16535%2Fe%2F1","sourceRelease":"119-100","text":"review the performance of the Institutes under this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16535/e/2","parentIdentifier":"/us/usc/t42/s16535/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16535%2Fe%2F2","sourceRelease":"119-100","text":"submit to Congress and the Secretary a report describing the results of the review.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorization of appropriations","label":"f Authorization of appropriations","identifier":"/us/usc/t42/s16535/f","parentIdentifier":"/us/usc/t42/s16535","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16535%2Ff","sourceRelease":"119-100","text":"There is authorized to be appropriated to provide grants to each Institute selected under this section $10,000,000 for each of fiscal years 2008 through 2010.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
