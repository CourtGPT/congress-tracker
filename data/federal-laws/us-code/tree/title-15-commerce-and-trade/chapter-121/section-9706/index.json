el":"4","identifier":"/us/usc/t15/s9706/a/4","parentIdentifier":"/us/usc/t15/s9706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9706%2Fa%2F4","sourceRelease":"119-100","text":"nutrient load;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s9706/a/5","parentIdentifier":"/us/usc/t15/s9706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9706%2Fa%2F5","sourceRelease":"119-100","text":"water temperature; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s9706/a/6","parentIdentifier":"/us/usc/t15/s9706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9706%2Fa%2F6","sourceRelease":"119-100","text":"sediment load.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Data needs assessment","label":"b Data needs assessment","identifier":"/us/usc/t15/s9706/b","parentIdentifier":"/us/usc/t15/s9706","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9706%2Fb","sourceRelease":"119-100","text":"The Administrator shall assess the need for additional data to assess and predict the effect of the flooding and freshwater discharge described in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Inventory of data needs","label":"c Inventory of data needs","identifier":"/us/usc/t15/s9706/c","parentIdentifier":"/us/usc/t15/s9706","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9706%2Fc","sourceRelease":"119-100","text":"Based on the assessments required by subsections (a) and (b), the Administrator shall create an inventory of data needs with respect to the flooding and freshwater discharge described in subsections (a) and (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Planning","label":"d Planning","identifier":"/us/usc/t15/s9706/d","parentIdentifier":"/us/usc/t15/s9706","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9706%2Fd","sourceRelease":"119-100","text":"In planning for the collection of additional data necessary for ecosystem-based modeling of the effect of the flooding and freshwater discharge described in subsections (a) and (b), the Administrator shall use the inventory created under subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
