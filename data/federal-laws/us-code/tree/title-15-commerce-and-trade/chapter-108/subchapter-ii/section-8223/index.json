{"type":"section","nativeType":"section","number":"8223","heading":"Definitions","label":"8223 Definitions","identifier":"/us/usc/t15/s8223","parentIdentifier":"/us/usc/t15/ch108/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8223","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Ceding insurer","label":"1 Ceding insurer","identifier":"/us/usc/t15/s8223/1","parentIdentifier":"/us/usc/t15/s8223","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8223%2F1","sourceRelease":"119-100","text":"The term “ceding insurer” means an insurer that purchases reinsurance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Domiciliary State","label":"2 Domiciliary State","identifier":"/us/usc/t15/s8223/2","parentIdentifier":"/us/usc/t15/s8223","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8223%2F2","sourceRelease":"119-100","text":"The terms “State of domicile” and “domiciliary State” mean, with respect to an insurer or reinsurer, the State in which the insurer or reinsurer is incorporated or entered through, and licensed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"NAIC","label":"3 NAIC","identifier":"/us/usc/t15/s8223/3","parentIdentifier":"/us/usc/t15/s8223","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8223%2F3","sourceRelease":"119-100","text":"The term “NAIC” means the National Association of Insurance Commissioners or any successor entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Reinsurance","label":"4 Reinsurance","identifier":"/us/usc/t15/s8223/4","parentIdentifier":"/us/usc/t15/s8223","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8223%2F4","sourceRelease":"119-100","text":"The term “reinsurance” means the assumption by an insurer of all or part of a risk undertaken originally by another insurer.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Reinsurer","label":"5 Reinsurer","identifier":"/us/usc/t15/s8223/5","parentIdentifier":"/us/usc/t15/s8223","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8223%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s8223/5/A","parentIdentifier":"/us/usc/t15/s8223/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8223%2F5%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s8223/5/A/i","parentIdentifier":"/us/usc/t15/s8223/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8223%2F5%2FA%2Fi","sourceRelease":"119-100","text":"is principally engaged in the business of reinsurance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s8223/5/A/ii","parentIdentifier":"/us/usc/t15/s8223/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8223%2F5%2FA%2Fii","sourceRelease":"119-100","text":"does not conduct significant amounts of direct insurance as a percentage of its net premiums; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s8223/5/A/iii","parentIdentifier":"/us/usc/t15/s8223/5/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8223%2F5%2FA%2Fiii","sourceRelease":"119-100","text":"is not engaged in an ongoing basis in the business of soliciting direct insurance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Determination","label":"B Determination","identifier":"/us/usc/t15/s8223/5/B","parentIdentifier":"/us/usc/t15/s8223/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8223%2F5%2FB","sourceRelease":"119-100","text":"A determination of whether an insurer is a reinsurer shall be made under the laws of the State of domicile in accordance with this paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"State","label":"6 State","identifier":"/us/usc/t15/s8223/6","parentIdentifier":"/us/usc/t15/s8223","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8223%2F6","sourceRelease":"119-100","text":"The term “State” includes any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Northern Mariana Islands, the Virgin Islands, and American Samoa.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
