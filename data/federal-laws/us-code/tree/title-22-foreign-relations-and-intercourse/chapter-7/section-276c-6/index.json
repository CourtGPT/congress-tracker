{"type":"section","nativeType":"section","number":"276c–6","heading":"Supporting the employment of United States citizens by international organizations","label":"276c–6 Supporting the employment of United States citizens by international organizations","identifier":"/us/usc/t22/s276c–6","parentIdentifier":"/us/usc/t22/ch7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","DefinitionsFor definitions of “Department”, “Secretary”, and “appropriate congressional committees” as used in this section, see , set out as a note under .section 9002 of Pub. L. 117–263section 2651 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Sense of Congress","label":"a Sense of Congress","identifier":"/us/usc/t22/s276c–6/a","parentIdentifier":"/us/usc/t22/s276c–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s276c–6/a/1","parentIdentifier":"/us/usc/t22/s276c–6/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fa%2F1","sourceRelease":"119-100","text":"the Department should continue to eliminate the unreasonable barriers United States nationals face to obtain employment in the United Nations Secretariat, funds, programs, and agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s276c–6/a/2","parentIdentifier":"/us/usc/t22/s276c–6/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fa%2F2","sourceRelease":"119-100","text":"the Department should bolster efforts to increase the number of qualified United States nationals who are candidates for leadership and oversight positions in the United Nations system, agencies, and commissions, and in other international organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"In general","label":"b In general","identifier":"/us/usc/t22/s276c–6/b","parentIdentifier":"/us/usc/t22/s276c–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s276c–6/b/1","parentIdentifier":"/us/usc/t22/s276c–6/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fb%2F1","sourceRelease":"119-100","text":"providing stipends, consultation, and analytical services to support United States citizen applicants; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s276c–6/b/2","parentIdentifier":"/us/usc/t22/s276c–6/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fb%2F2","sourceRelease":"119-100","text":"making grants for the purposes described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Using diplomatic programs funding to promote the employment of United States citizens by international organizations","label":"c Using diplomatic programs funding to promote the employment of United States citizens by international organizations","identifier":"/us/usc/t22/s276c–6/c","parentIdentifier":"/us/usc/t22/s276c–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fc","sourceRelease":"119-100","text":"Amounts appropriated under the heading “Diplomatic Programs” in Acts making appropriations for the Department of State, Foreign Operations, and Related Programs are authorized to be appropriated for grants, programs, and activities described in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Strategy to establish junior professional program","label":"d Strategy to establish junior professional program","identifier":"/us/usc/t22/s276c–6/d","parentIdentifier":"/us/usc/t22/s276c–6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s276c–6/d/1","parentIdentifier":"/us/usc/t22/s276c–6/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s276c–6/d/1/A","parentIdentifier":"/us/usc/t22/s276c–6/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fd%2F1%2FA","sourceRelease":"119-100","text":"set international scientific, technical, or commercial standards; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s276c–6/d/1/B","parentIdentifier":"/us/usc/t22/s276c–6/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fd%2F1%2FB","sourceRelease":"119-100","text":"are involved in international finance and development.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report to Congress","label":"2 Report to Congress","identifier":"/us/usc/t22/s276c–6/d/2","parentIdentifier":"/us/usc/t22/s276c–6/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s276c–6/d/2/A","parentIdentifier":"/us/usc/t22/s276c–6/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fd%2F2%2FA","sourceRelease":"119-100","text":"the number of United States citizens who are involved in relevant junior professional programs in an international organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s276c–6/d/2/B","parentIdentifier":"/us/usc/t22/s276c–6/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fd%2F2%2FB","sourceRelease":"119-100","text":"the distribution of individuals described in subparagraph (A) among various international organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s276c–6/d/2/C","parentIdentifier":"/us/usc/t22/s276c–6/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs276c%E2%80%936%2Fd%2F2%2FC","sourceRelease":"119-100","text":"the types of pre-deployment training that are available to United States citizens through a junior professional program at an international organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
