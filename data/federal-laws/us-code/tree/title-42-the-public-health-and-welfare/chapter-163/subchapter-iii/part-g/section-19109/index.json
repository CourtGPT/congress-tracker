{"type":"section","nativeType":"section","number":"19109","heading":"Translation Accelerator","label":"19109 Translation Accelerator","identifier":"/us/usc/t42/s19109","parentIdentifier":"/us/usc/t42/ch163/schIII/ptG","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19109","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s19109/a","parentIdentifier":"/us/usc/t42/s19109","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19109%2Fa","sourceRelease":"119-100","text":"The Director shall establish Translation Accelerators to further the research, development, and commercialization of innovation in the key technology focus areas.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Partnerships","label":"b Partnerships","identifier":"/us/usc/t42/s19109/b","parentIdentifier":"/us/usc/t42/s19109","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19109%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s19109/b/1","parentIdentifier":"/us/usc/t42/s19109/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19109%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19109/b/1/A","parentIdentifier":"/us/usc/t42/s19109/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19109%2Fb%2F1%2FA","sourceRelease":"119-100","text":"An institution of higher education.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19109/b/1/B","parentIdentifier":"/us/usc/t42/s19109/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19109%2Fb%2F1%2FB","sourceRelease":"119-100","text":"A for-profit company.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s19109/b/1/C","parentIdentifier":"/us/usc/t42/s19109/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19109%2Fb%2F1%2FC","sourceRelease":"119-100","text":"A nonprofit organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s19109/b/1/D","parentIdentifier":"/us/usc/t42/s19109/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19109%2Fb%2F1%2FD","sourceRelease":"119-100","text":"A Federal agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s19109/b/1/E","parentIdentifier":"/us/usc/t42/s19109/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19109%2Fb%2F1%2FE","sourceRelease":"119-100","text":"Another entity, if that entity is determined by the Director to be vital to the success of the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Institutional or organizational level","label":"2 Institutional or organizational level","identifier":"/us/usc/t42/s19109/b/2","parentIdentifier":"/us/usc/t42/s19109/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19109%2Fb%2F2","sourceRelease":"119-100","text":"The Director shall work to ensure that such partnerships exist at the institutional or organization level, rather than solely at the principal investigator level.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Cost share","label":"3 Cost share","identifier":"/us/usc/t42/s19109/b/3","parentIdentifier":"/us/usc/t42/s19109/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19109%2Fb%2F3","sourceRelease":"119-100","text":"Not less than 25 percent of the funding for an institute shall be provided by non-Federal entities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Number of centers and institutes established","label":"4 Number of centers and institutes established","identifier":"/us/usc/t42/s19109/b/4","parentIdentifier":"/us/usc/t42/s19109/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19109%2Fb%2F4","sourceRelease":"119-100","text":"The Director shall endeavor to establish a balance in the number of Regional Innovation Engines and Translation Accelerators.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Authorization of appropriations","label":"c Authorization of appropriations","identifier":"/us/usc/t42/s19109/c","parentIdentifier":"/us/usc/t42/s19109","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19109%2Fc","sourceRelease":"119-100","text":"From within funds authorized for the Directorate for Technology, Innovation, and Partnerships, there are authorized to carry out the activities under this section and $6,500,000,000 for fiscal years 2023 through 2027.section 19108 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
