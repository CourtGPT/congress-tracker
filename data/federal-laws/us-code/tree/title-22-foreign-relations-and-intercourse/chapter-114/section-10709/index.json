{"type":"section","nativeType":"section","number":"10709","heading":"Relations between Kosovo and Serbia","label":"10709 Relations between Kosovo and Serbia","identifier":"/us/usc/t22/s10709","parentIdentifier":"/us/usc/t22/ch114","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10709","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Sense of Congress","label":"a Sense of Congress","identifier":"/us/usc/t22/s10709/a","parentIdentifier":"/us/usc/t22/s10709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10709%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10709/a/1","parentIdentifier":"/us/usc/t22/s10709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10709%2Fa%2F1","sourceRelease":"119-100","text":"the Agreement on the Path to Normalization of Relations, which was agreed to by Kosovo and Serbia on , with the facilitation of the European Union, is a positive step forward in advancing normalization between the two countries;February 27, 2023","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10709/a/2","parentIdentifier":"/us/usc/t22/s10709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10709%2Fa%2F2","sourceRelease":"119-100","text":"Serbia and Kosovo should seek to make immediate progress on the Implementation Annex to the agreement referred to in paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s10709/a/3","parentIdentifier":"/us/usc/t22/s10709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10709%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10709/a/3/A","parentIdentifier":"/us/usc/t22/s10709/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10709%2Fa%2F3%2FA","sourceRelease":"119-100","text":"establishing bilateral strategic dialogues with Kosovo and Serbia; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10709/a/3/B","parentIdentifier":"/us/usc/t22/s10709/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10709%2Fa%2F3%2FB","sourceRelease":"119-100","text":"advancing concrete initiatives to deepen economic ties and investment with both countries; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s10709/a/4","parentIdentifier":"/us/usc/t22/s10709/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10709%2Fa%2F4","sourceRelease":"119-100","text":"the United States should continue to support a comprehensive final agreement between Kosovo and Serbia based on mutual recognition.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Statement of policy","label":"b Statement of policy","identifier":"/us/usc/t22/s10709/b","parentIdentifier":"/us/usc/t22/s10709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10709%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10709/b/1","parentIdentifier":"/us/usc/t22/s10709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10709%2Fb%2F1","sourceRelease":"119-100","text":"it shall not pursue any policy that advocates for land swaps, partition, or other forms of redrawing borders along ethnic lines in the Western Balkans as a means to settle disputes between nation states in the region; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10709/b/2","parentIdentifier":"/us/usc/t22/s10709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10709%2Fb%2F2","sourceRelease":"119-100","text":"it should support pluralistic democracies in countries in the Western Balkans as a means to prevent a return to the ethnic strife that once characterized the region.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
