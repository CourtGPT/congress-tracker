{"type":"section","nativeType":"section","number":"50503","heading":"Blue Alert Coordinator; guidelines","label":"50503 Blue Alert Coordinator; guidelines","identifier":"/us/usc/t34/s50503","parentIdentifier":"/us/usc/t34/stV/ch505","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was formerly classified to , The Public Health and Welfare, prior to editorial reclassification and renumbering as this section.section 14165b of Title 42"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Coordination within Department of Justice","label":"a Coordination within Department of Justice","identifier":"/us/usc/t34/s50503/a","parentIdentifier":"/us/usc/t34/s50503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fa","sourceRelease":"119-100","text":"The Attorney General shall assign an existing officer of the Department of Justice to act as the national coordinator of the Blue Alert communications network.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties of the Coordinator","label":"b Duties of the Coordinator","identifier":"/us/usc/t34/s50503/b","parentIdentifier":"/us/usc/t34/s50503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s50503/b/1","parentIdentifier":"/us/usc/t34/s50503/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F1","sourceRelease":"119-100","text":"provide assistance to States and units of local government that are using Blue Alert plans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s50503/b/2","parentIdentifier":"/us/usc/t34/s50503/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50503/b/2/A","parentIdentifier":"/us/usc/t34/s50503/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FA","sourceRelease":"119-100","text":"a list of the resources necessary to establish a Blue Alert plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50503/b/2/B","parentIdentifier":"/us/usc/t34/s50503/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FB","sourceRelease":"119-100","text":"criteria for evaluating whether a situation warrants issuing a Blue Alert;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s50503/b/2/C","parentIdentifier":"/us/usc/t34/s50503/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FC","sourceRelease":"119-100","text":"guidelines to protect the privacy, dignity, independence, and autonomy of any law enforcement officer who may be the subject of a Blue Alert and the family of the law enforcement officer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s50503/b/2/D","parentIdentifier":"/us/usc/t34/s50503/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s50503/b/2/D/i","parentIdentifier":"/us/usc/t34/s50503/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FD%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t34/s50503/b/2/D/i/I","parentIdentifier":"/us/usc/t34/s50503/b/2/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FD%2Fi%2FI","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"item","nativeType":"item","number":"aa","heading":null,"label":"aa","identifier":"/us/usc/t34/s50503/b/2/D/i/I/aa","parentIdentifier":"/us/usc/t34/s50503/b/2/D/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FD%2Fi%2FI%2Faa","sourceRelease":"119-100","text":"the death or serious injury of the law enforcement officer; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"item","nativeType":"item","number":"bb","heading":null,"label":"bb","identifier":"/us/usc/t34/s50503/b/2/D/i/I/bb","parentIdentifier":"/us/usc/t34/s50503/b/2/D/i/I","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FD%2Fi%2FI%2Fbb","sourceRelease":"119-100","text":"the attack on the law enforcement officer and that there is an indication of the death or serious injury of the officer; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t34/s50503/b/2/D/i/II","parentIdentifier":"/us/usc/t34/s50503/b/2/D/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FD%2Fi%2FII","sourceRelease":"119-100","text":"concludes that the law enforcement officer is missing in connection with the officer’s official duties;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s50503/b/2/D/ii","parentIdentifier":"/us/usc/t34/s50503/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FD%2Fii","sourceRelease":"119-100","text":"there is an indication of serious injury to or death of the law enforcement officer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s50503/b/2/D/iii","parentIdentifier":"/us/usc/t34/s50503/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FD%2Fiii","sourceRelease":"119-100","text":"the suspect involved has not been apprehended; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t34/s50503/b/2/D/iv","parentIdentifier":"/us/usc/t34/s50503/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FD%2Fiv","sourceRelease":"119-100","text":"there is sufficient descriptive information of the suspect involved and any relevant vehicle and tag numbers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t34/s50503/b/2/E","parentIdentifier":"/us/usc/t34/s50503/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s50503/b/2/E/i","parentIdentifier":"/us/usc/t34/s50503/b/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FE%2Fi","sourceRelease":"119-100","text":"a law enforcement agency involved confirms that the threat is imminent and credible;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s50503/b/2/E/ii","parentIdentifier":"/us/usc/t34/s50503/b/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FE%2Fii","sourceRelease":"119-100","text":"at the time of receipt of the threat, the suspect is wanted by a law enforcement agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s50503/b/2/E/iii","parentIdentifier":"/us/usc/t34/s50503/b/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FE%2Fiii","sourceRelease":"119-100","text":"the suspect involved has not been apprehended; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t34/s50503/b/2/E/iv","parentIdentifier":"/us/usc/t34/s50503/b/2/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FE%2Fiv","sourceRelease":"119-100","text":"there is sufficient descriptive information of the suspect involved and any relevant vehicle and tag numbers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t34/s50503/b/2/F","parentIdentifier":"/us/usc/t34/s50503/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FF","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s50503/b/2/F/i","parentIdentifier":"/us/usc/t34/s50503/b/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FF%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t34/s50503/b/2/F/i/I","parentIdentifier":"/us/usc/t34/s50503/b/2/F/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FF%2Fi%2FI","sourceRelease":"119-100","text":"a law enforcement officer who is seriously injured or killed in the line of duty; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t34/s50503/b/2/F/i/II","parentIdentifier":"/us/usc/t34/s50503/b/2/F/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FF%2Fi%2FII","sourceRelease":"119-100","text":"an imminent and credible threat to cause the serious injury or death of a law enforcement officer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s50503/b/2/F/ii","parentIdentifier":"/us/usc/t34/s50503/b/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FF%2Fii","sourceRelease":"119-100","text":"that a Blue Alert should, to the maximum extent practicable (as determined by the Coordinator in consultation with law enforcement agencies of States and units of local governments), be limited to the geographic areas most likely to facilitate the apprehension of the suspect involved or which the suspect could reasonably reach, which should not be limited to State lines;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s50503/b/2/F/iii","parentIdentifier":"/us/usc/t34/s50503/b/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FF%2Fiii","sourceRelease":"119-100","text":"for law enforcement agencies of States or units of local government to develop plans to communicate information to neighboring States to provide for seamless communication of a Blue Alert; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t34/s50503/b/2/F/iv","parentIdentifier":"/us/usc/t34/s50503/b/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FF%2Fiv","sourceRelease":"119-100","text":"providing that a Blue Alert should be suspended when the suspect involved is apprehended or when the law enforcement agency involved determines that the Blue Alert is no longer effective; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t34/s50503/b/2/G","parentIdentifier":"/us/usc/t34/s50503/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FG","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s50503/b/2/G/i","parentIdentifier":"/us/usc/t34/s50503/b/2/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FG%2Fi","sourceRelease":"119-100","text":"the issuance of Blue Alerts through the network; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s50503/b/2/G/ii","parentIdentifier":"/us/usc/t34/s50503/b/2/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F2%2FG%2Fii","sourceRelease":"119-100","text":"the extent of the dissemination of alerts issued through the network;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s50503/b/3","parentIdentifier":"/us/usc/t34/s50503/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50503/b/3/A","parentIdentifier":"/us/usc/t34/s50503/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the use of public safety communications;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50503/b/3/B","parentIdentifier":"/us/usc/t34/s50503/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F3%2FB","sourceRelease":"119-100","text":"command center operations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s50503/b/3/C","parentIdentifier":"/us/usc/t34/s50503/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F3%2FC","sourceRelease":"119-100","text":"incident review, evaluation, debriefing, and public information procedures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t34/s50503/b/4","parentIdentifier":"/us/usc/t34/s50503/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F4","sourceRelease":"119-100","text":"work with States to ensure appropriate regional coordination of various elements of the network;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t34/s50503/b/5","parentIdentifier":"/us/usc/t34/s50503/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50503/b/5/A","parentIdentifier":"/us/usc/t34/s50503/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F5%2FA","sourceRelease":"119-100","text":"to the maximum extent practicable, representation from the various geographic regions of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50503/b/5/B","parentIdentifier":"/us/usc/t34/s50503/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F5%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s50503/b/5/B/i","parentIdentifier":"/us/usc/t34/s50503/b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F5%2FB%2Fi","sourceRelease":"119-100","text":"representatives of a law enforcement organization representing rank-and-file officers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s50503/b/5/B/ii","parentIdentifier":"/us/usc/t34/s50503/b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F5%2FB%2Fii","sourceRelease":"119-100","text":"representatives of other law enforcement agencies and public safety communications;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s50503/b/5/B/iii","parentIdentifier":"/us/usc/t34/s50503/b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F5%2FB%2Fiii","sourceRelease":"119-100","text":"broadcasters, first responders, dispatchers, and radio station personnel; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t34/s50503/b/5/B/iv","parentIdentifier":"/us/usc/t34/s50503/b/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F5%2FB%2Fiv","sourceRelease":"119-100","text":"representatives of any other individuals or organizations that the Coordinator determines are necessary to the success of the network;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t34/s50503/b/6","parentIdentifier":"/us/usc/t34/s50503/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50503/b/6/A","parentIdentifier":"/us/usc/t34/s50503/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F6%2FA","sourceRelease":"119-100","text":"the development of the network; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50503/b/6/B","parentIdentifier":"/us/usc/t34/s50503/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F6%2FB","sourceRelease":"119-100","text":"regional coordination of Blue Alerts through the network; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t34/s50503/b/7","parentIdentifier":"/us/usc/t34/s50503/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50503/b/7/A","parentIdentifier":"/us/usc/t34/s50503/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F7%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s50503/b/7/A/i","parentIdentifier":"/us/usc/t34/s50503/b/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F7%2FA%2Fi","sourceRelease":"119-100","text":"a law enforcement officer is killed or seriously injured in the line of duty;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s50503/b/7/A/ii","parentIdentifier":"/us/usc/t34/s50503/b/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F7%2FA%2Fii","sourceRelease":"119-100","text":"a law enforcement officer is missing in connection with the officer’s official duties; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s50503/b/7/A/iii","parentIdentifier":"/us/usc/t34/s50503/b/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F7%2FA%2Fiii","sourceRelease":"119-100","text":"an imminent and credible threat to kill or seriously injure a law enforcement officer is received; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50503/b/7/B","parentIdentifier":"/us/usc/t34/s50503/b/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fb%2F7%2FB","sourceRelease":"119-100","text":"which of the procedures and practices are effective and that do not require the expenditure of additional resources to implement.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Limitations","label":"c Limitations","identifier":"/us/usc/t34/s50503/c","parentIdentifier":"/us/usc/t34/s50503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Voluntary participation","label":"1 Voluntary participation","identifier":"/us/usc/t34/s50503/c/1","parentIdentifier":"/us/usc/t34/s50503/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fc%2F1","sourceRelease":"119-100","text":"The guidelines established under subsection (b)(2), protocols developed under subsection (b)(3), and other programs established under subsection (b), shall not be mandatory.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Dissemination of information","label":"2 Dissemination of information","identifier":"/us/usc/t34/s50503/c/2","parentIdentifier":"/us/usc/t34/s50503/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fc%2F2","sourceRelease":"119-100","text":"The guidelines established under subsection (b)(2) shall, to the maximum extent practicable (as determined by the Coordinator in consultation with law enforcement agencies of States and units of local government), provide that appropriate information relating to a Blue Alert is disseminated to the appropriate officials of law enforcement agencies, public health agencies, and other agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Privacy and civil liberties protections","label":"3 Privacy and civil liberties protections","identifier":"/us/usc/t34/s50503/c/3","parentIdentifier":"/us/usc/t34/s50503/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s50503/c/3/A","parentIdentifier":"/us/usc/t34/s50503/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fc%2F3%2FA","sourceRelease":"119-100","text":"provide mechanisms that ensure that Blue Alerts comply with all applicable Federal, State, and local privacy laws and regulations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s50503/c/3/B","parentIdentifier":"/us/usc/t34/s50503/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fc%2F3%2FB","sourceRelease":"119-100","text":"include standards that specifically provide for the protection of the civil liberties, including the privacy, of law enforcement officers who are seriously injured or killed in the line of duty, is missing in connection with the officer’s official duties, or who are threatened with death or serious injury, and the families of the officers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Cooperation with other agencies","label":"d Cooperation with other agencies","identifier":"/us/usc/t34/s50503/d","parentIdentifier":"/us/usc/t34/s50503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fd","sourceRelease":"119-100","text":"The Coordinator shall cooperate with the Secretary of Homeland Security, the Secretary of Transportation, the Chairman of the Federal Communications Commission, and appropriate offices of the Department of Justice in carrying out activities under this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Restrictions on Coordinator","label":"e Restrictions on Coordinator","identifier":"/us/usc/t34/s50503/e","parentIdentifier":"/us/usc/t34/s50503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s50503/e/1","parentIdentifier":"/us/usc/t34/s50503/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fe%2F1","sourceRelease":"119-100","text":"perform any official travel for the sole purpose of carrying out the duties of the Coordinator;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s50503/e/2","parentIdentifier":"/us/usc/t34/s50503/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fe%2F2","sourceRelease":"119-100","text":"lobby any officer of a State regarding the funding or implementation of a Blue Alert plan; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s50503/e/3","parentIdentifier":"/us/usc/t34/s50503/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Fe%2F3","sourceRelease":"119-100","text":"host a conference focused solely on the Blue Alert program that requires the expenditure of Federal funds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Reports","label":"f Reports","identifier":"/us/usc/t34/s50503/f","parentIdentifier":"/us/usc/t34/s50503","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs50503%2Ff","sourceRelease":"119-100","text":"Not later than 1 year after , and annually thereafter, the Coordinator shall submit to Congress a report on the activities of the Coordinator and the effectiveness and status of the Blue Alert plans that are in effect or being developed.May 19, 2015","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
