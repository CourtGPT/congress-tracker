{"type":"section","nativeType":"section","number":"2504","heading":"Competitive grants","label":"2504 Competitive grants","identifier":"/us/usc/t29/s2504","parentIdentifier":"/us/usc/t29/ch27","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2504","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t29/s2504/a","parentIdentifier":"/us/usc/t29/s2504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2504%2Fa","sourceRelease":"119-100","text":"Each community-based organization that desires to receive a grant to provide technical assistance under to employers and labor unions shall submit an application to the Secretary at such time, in such manner, and accompanied by such information as the Secretary may reasonably require.section 2503(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Priority","label":"b Priority","identifier":"/us/usc/t29/s2504/b","parentIdentifier":"/us/usc/t29/s2504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2504%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s2504/b/1","parentIdentifier":"/us/usc/t29/s2504/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2504%2Fb%2F1","sourceRelease":"119-100","text":"demonstrate experience preparing women to gain employment in apprenticeable occupations or other nontraditional occupations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s2504/b/2","parentIdentifier":"/us/usc/t29/s2504/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2504%2Fb%2F2","sourceRelease":"119-100","text":"demonstrate experience working with the business community to prepare them to place women in apprenticeable occupations or other nontraditional occupations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t29/s2504/b/3","parentIdentifier":"/us/usc/t29/s2504/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2504%2Fb%2F3","sourceRelease":"119-100","text":"have tradeswomen or women in nontraditional occupations as active members of the organization, as either employed staff or board members; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t29/s2504/b/4","parentIdentifier":"/us/usc/t29/s2504/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2504%2Fb%2F4","sourceRelease":"119-100","text":"have experience delivering technical assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
