{"type":"section","nativeType":"section","number":"2350i","heading":"Foreign contributions for cooperative projects","label":"2350i Foreign contributions for cooperative projects","identifier":"/us/usc/t10/s2350i","parentIdentifier":"/us/usc/t10/stA/ptIV/ch138/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Crediting of Contributions","label":"a .—Crediting of Contributions","identifier":"/us/usc/t10/s2350i/a","parentIdentifier":"/us/usc/t10/s2350i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fa","sourceRelease":"119-100","text":"Whenever the United States participates in a cooperative project with a friendly foreign country or the North Atlantic Treaty Organization (NATO) on a cost-sharing basis, any contribution received by the United States from that foreign country or NATO to meet its share of the costs of the project may be credited to appropriations available to an appropriate military department or another appropriate organization within the Department of Defense, as determined by the Secretary of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Use of Amounts Credited","label":"b .—Use of Amounts Credited","identifier":"/us/usc/t10/s2350i/b","parentIdentifier":"/us/usc/t10/s2350i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2350i/b/1","parentIdentifier":"/us/usc/t10/s2350i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fb%2F1","sourceRelease":"119-100","text":"Payments to contractors and other suppliers (including the Department of Defense and other participants acting as suppliers) for necessary articles and services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2350i/b/2","parentIdentifier":"/us/usc/t10/s2350i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fb%2F2","sourceRelease":"119-100","text":"Payments for any damages and costs resulting from the performance or cancellation of any contract or other obligation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2350i/b/3","parentIdentifier":"/us/usc/t10/s2350i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fb%2F3","sourceRelease":"119-100","text":"Payments or reimbursements of other program expenses, including program office overhead and administrative costs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s2350i/b/4","parentIdentifier":"/us/usc/t10/s2350i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fb%2F4","sourceRelease":"119-100","text":"Refunds to other participants.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Definitions","label":"c .—Definitions","identifier":"/us/usc/t10/s2350i/c","parentIdentifier":"/us/usc/t10/s2350i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2350i/c/1","parentIdentifier":"/us/usc/t10/s2350i/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s2350i/c/1/A","parentIdentifier":"/us/usc/t10/s2350i/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fc%2F1%2FA","sourceRelease":"119-100","text":"is undertaken by the participants in order to improve the conventional defense capabilities of the participants; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s2350i/c/1/B","parentIdentifier":"/us/usc/t10/s2350i/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s2350i/c/1/B/i","parentIdentifier":"/us/usc/t10/s2350i/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"one or more participants (other than the United States) to share with the United States the cost of research and development, testing, evaluation, or joint production (including follow-on support) of defense articles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s2350i/c/1/B/ii","parentIdentifier":"/us/usc/t10/s2350i/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the United States and another participant concurrently to produce in the United States and the country of such other participant a defense article jointly developed in a cooperative project described in clause (i); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t10/s2350i/c/1/B/iii","parentIdentifier":"/us/usc/t10/s2350i/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fc%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"the United States to procure a defense article or a defense service from another participant in the cooperative project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2350i/c/2","parentIdentifier":"/us/usc/t10/s2350i/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fc%2F2","sourceRelease":"119-100","text":"The term “defense article” has the meaning given such term in section 47(3) of the Arms Export Control Act ().22 U.S.C. 2794(3)","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2350i/c/3","parentIdentifier":"/us/usc/t10/s2350i/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2350i%2Fc%2F3","sourceRelease":"119-100","text":"The term “defense service” has the meaning given such term in section 47(4) of the Arms Export Control Act ().22 U.S.C. 2794(4)","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
