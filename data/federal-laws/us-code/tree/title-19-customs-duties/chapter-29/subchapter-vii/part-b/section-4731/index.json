{"type":"section","nativeType":"section","number":"4731","heading":"Border water infrastructure improvement authority","label":"4731 Border water infrastructure improvement authority","identifier":"/us/usc/t19/s4731","parentIdentifier":"/us/usc/t19/ch29/schVII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t19/s4731/a","parentIdentifier":"/us/usc/t19/s4731","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fa","sourceRelease":"119-100","text":"The Administrator of the Environmental Protection Agency shall, in coordination with eligible public entities, carry out the planning, design, construction, and operation and maintenance of high priority treatment works in the covered area to treat wastewater (including stormwater), nonpoint sources of pollution, and related matters resulting from international transboundary water flows originating in Mexico.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report to Congress","label":"b Report to Congress","identifier":"/us/usc/t19/s4731/b","parentIdentifier":"/us/usc/t19/s4731","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fb","sourceRelease":"119-100","text":"Not later than 1 year after , and annually thereafter, the Administrator shall submit to Congress a report on activities carried out pursuant to this section.January 29, 2020","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Definitions","label":"c Definitions","identifier":"/us/usc/t19/s4731/c","parentIdentifier":"/us/usc/t19/s4731","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Covered area","label":"1 Covered area","identifier":"/us/usc/t19/s4731/c/1","parentIdentifier":"/us/usc/t19/s4731/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F1","sourceRelease":"119-100","text":"The term “covered area” means the portion of the Tijuana River watershed that is in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible public entities","label":"2 Eligible public entities","identifier":"/us/usc/t19/s4731/c/2","parentIdentifier":"/us/usc/t19/s4731/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s4731/c/2/A","parentIdentifier":"/us/usc/t19/s4731/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F2%2FA","sourceRelease":"119-100","text":"the United States Section of the International Boundary and Water Commission;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s4731/c/2/B","parentIdentifier":"/us/usc/t19/s4731/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the Corps of Engineers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t19/s4731/c/2/C","parentIdentifier":"/us/usc/t19/s4731/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F2%2FC","sourceRelease":"119-100","text":"the North American Development Bank;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t19/s4731/c/2/D","parentIdentifier":"/us/usc/t19/s4731/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F2%2FD","sourceRelease":"119-100","text":"the Department of State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t19/s4731/c/2/E","parentIdentifier":"/us/usc/t19/s4731/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F2%2FE","sourceRelease":"119-100","text":"any other appropriate Federal agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t19/s4731/c/2/F","parentIdentifier":"/us/usc/t19/s4731/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F2%2FF","sourceRelease":"119-100","text":"the State of California; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t19/s4731/c/2/G","parentIdentifier":"/us/usc/t19/s4731/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F2%2FG","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s4731/c/2/G/i","parentIdentifier":"/us/usc/t19/s4731/c/2/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F2%2FG%2Fi","sourceRelease":"119-100","text":"A local government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s4731/c/2/G/ii","parentIdentifier":"/us/usc/t19/s4731/c/2/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F2%2FG%2Fii","sourceRelease":"119-100","text":"An Indian Tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t19/s4731/c/2/G/iii","parentIdentifier":"/us/usc/t19/s4731/c/2/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F2%2FG%2Fiii","sourceRelease":"119-100","text":"A regional water board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t19/s4731/c/2/G/iv","parentIdentifier":"/us/usc/t19/s4731/c/2/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F2%2FG%2Fiv","sourceRelease":"119-100","text":"A public wastewater utility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Treatment works","label":"3 Treatment works","identifier":"/us/usc/t19/s4731/c/3","parentIdentifier":"/us/usc/t19/s4731/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4731%2Fc%2F3","sourceRelease":"119-100","text":"The term “treatment works” has the meaning given that term in .section 1292 of title 33","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
