{"type":"section","nativeType":"section","number":"1748b–1","heading":"Wildfire technology modernization","label":"1748b–1 Wildfire technology modernization","identifier":"/us/usc/t43/s1748b–1","parentIdentifier":"/us/usc/t43/ch35/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection is comprised of . Subsec. (g) of amended , Commerce and Trade.section 1114 of Pub. L. 116–9section 1114 of Pub. L. 116–9section 2208 of Title 15","Statutory Notes and Related Subsidiaries","Definition of “Secretary”“Secretary” means the Secretary of the Interior, see , set out as a note under , Conservation.section 2 of Pub. L. 116–9section 1 of Title 16"],"amendments":["CodificationSection is comprised of . Subsec. (g) of amended , Commerce and Trade.section 1114 of Pub. L. 116–9section 1114 of Pub. L. 116–9section 2208 of Title 15"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purpose","label":"a Purpose","identifier":"/us/usc/t43/s1748b–1/a","parentIdentifier":"/us/usc/t43/s1748b–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s1748b–1/a/1","parentIdentifier":"/us/usc/t43/s1748b–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fa%2F1","sourceRelease":"119-100","text":"to meet applicable protection objectives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s1748b–1/a/2","parentIdentifier":"/us/usc/t43/s1748b–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s1748b–1/a/2/A","parentIdentifier":"/us/usc/t43/s1748b–1/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fa%2F2%2FA","sourceRelease":"119-100","text":"firefighters; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s1748b–1/a/2/B","parentIdentifier":"/us/usc/t43/s1748b–1/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Definitions","label":"b Definitions","identifier":"/us/usc/t43/s1748b–1/b","parentIdentifier":"/us/usc/t43/s1748b–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Secretaries","label":"1 Secretaries","identifier":"/us/usc/t43/s1748b–1/b/1","parentIdentifier":"/us/usc/t43/s1748b–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s1748b–1/b/1/A","parentIdentifier":"/us/usc/t43/s1748b–1/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the Secretary of Agriculture; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s1748b–1/b/1/B","parentIdentifier":"/us/usc/t43/s1748b–1/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Secretary concerned","label":"2 Secretary concerned","identifier":"/us/usc/t43/s1748b–1/b/2","parentIdentifier":"/us/usc/t43/s1748b–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s1748b–1/b/2/A","parentIdentifier":"/us/usc/t43/s1748b–1/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the Secretary of Agriculture, with respect to activities under the Department of Agriculture; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s1748b–1/b/2/B","parentIdentifier":"/us/usc/t43/s1748b–1/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the Secretary, with respect to activities under the Department of the Interior.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Unmanned aircraft systems","label":"c Unmanned aircraft systems","identifier":"/us/usc/t43/s1748b–1/c","parentIdentifier":"/us/usc/t43/s1748b–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Definitions","label":"1 Definitions","identifier":"/us/usc/t43/s1748b–1/c/1","parentIdentifier":"/us/usc/t43/s1748b–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fc%2F1","sourceRelease":"119-100","text":"In this subsection, the terms “unmanned aircraft” and “unmanned aircraft system” have the meanings given those terms in .section 44801 of title 49","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Establishment of program","label":"2 Establishment of program","identifier":"/us/usc/t43/s1748b–1/c/2","parentIdentifier":"/us/usc/t43/s1748b–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fc%2F2","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary, in consultation with the Secretary of Agriculture, shall establish a research, development, and testing program, or expand an applicable existing program, to assess unmanned aircraft system technologies, including optionally piloted aircraft, across the full range of wildland fire management operations in order to accelerate the deployment and integration of those technologies into the operations of the Secretaries.March 12, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Expanding use of unmanned aircraft systems on wildfires","label":"3 Expanding use of unmanned aircraft systems on wildfires","identifier":"/us/usc/t43/s1748b–1/c/3","parentIdentifier":"/us/usc/t43/s1748b–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fc%2F3","sourceRelease":"119-100","text":"In carrying out the program established under paragraph (2), the Secretaries, in coordination with the Federal Aviation Administration, State wildland firefighting agencies, and other relevant Federal agencies, shall enter into an agreement under which the Secretaries shall develop consistent protocols and plans for the use on wildland fires of unmanned aircraft system technologies, including for the development of real-time maps of the location of wildland fires.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Location systems for wildland firefighters","label":"d Location systems for wildland firefighters","identifier":"/us/usc/t43/s1748b–1/d","parentIdentifier":"/us/usc/t43/s1748b–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s1748b–1/d/1","parentIdentifier":"/us/usc/t43/s1748b–1/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F1","sourceRelease":"119-100","text":"Not later than 2 years after , subject to the availability of appropriations, the Secretaries, in coordination with State wildland firefighting agencies, shall jointly develop and operate a tracking system (referred to in this subsection as the “system”) to remotely locate the positions of fire resources for use by wildland firefighters, including, at a minimum, any fire resources assigned to Federal type 1 wildland fire incident management teams.March 12, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirements","label":"2 Requirements","identifier":"/us/usc/t43/s1748b–1/d/2","parentIdentifier":"/us/usc/t43/s1748b–1/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s1748b–1/d/2/A","parentIdentifier":"/us/usc/t43/s1748b–1/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F2%2FA","sourceRelease":"119-100","text":"use the most practical and effective technology available to the Secretaries to remotely track the location of an active resource, such as a Global Positioning System;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s1748b–1/d/2/B","parentIdentifier":"/us/usc/t43/s1748b–1/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F2%2FB","sourceRelease":"119-100","text":"depict the location of each fire resource on the applicable maps developed under subsection (c)(3);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t43/s1748b–1/d/2/C","parentIdentifier":"/us/usc/t43/s1748b–1/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F2%2FC","sourceRelease":"119-100","text":"operate continuously during the period for which any firefighting personnel are assigned to the applicable Federal wildland fire; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t43/s1748b–1/d/2/D","parentIdentifier":"/us/usc/t43/s1748b–1/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F2%2FD","sourceRelease":"119-100","text":"be subject to such terms and conditions as the Secretary concerned determines necessary for the effective implementation of the system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Operation","label":"3 Operation","identifier":"/us/usc/t43/s1748b–1/d/3","parentIdentifier":"/us/usc/t43/s1748b–1/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s1748b–1/d/3/A","parentIdentifier":"/us/usc/t43/s1748b–1/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s1748b–1/d/3/A/i","parentIdentifier":"/us/usc/t43/s1748b–1/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F3%2FA%2Fi","sourceRelease":"119-100","text":"conduct not fewer than 2 pilot projects relating to the operation, management, and effectiveness of the system; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s1748b–1/d/3/A/ii","parentIdentifier":"/us/usc/t43/s1748b–1/d/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F3%2FA%2Fii","sourceRelease":"119-100","text":"review the results of those pilot projects;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s1748b–1/d/3/B","parentIdentifier":"/us/usc/t43/s1748b–1/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F3%2FB","sourceRelease":"119-100","text":"conduct training, and maintain a culture, such that an employee, officer, or contractor shall not rely on the system for safety; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t43/s1748b–1/d/3/C","parentIdentifier":"/us/usc/t43/s1748b–1/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s1748b–1/d/3/C/i","parentIdentifier":"/us/usc/t43/s1748b–1/d/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F3%2FC%2Fi","sourceRelease":"119-100","text":"data security; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s1748b–1/d/3/C/ii","parentIdentifier":"/us/usc/t43/s1748b–1/d/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fd%2F3%2FC%2Fii","sourceRelease":"119-100","text":"the privacy of wildland fire personnel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Wildland fire decision support","label":"e Wildland fire decision support","identifier":"/us/usc/t43/s1748b–1/e","parentIdentifier":"/us/usc/t43/s1748b–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Protocol","label":"1 Protocol","identifier":"/us/usc/t43/s1748b–1/e/1","parentIdentifier":"/us/usc/t43/s1748b–1/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s1748b–1/e/1/A","parentIdentifier":"/us/usc/t43/s1748b–1/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe%2F1%2FA","sourceRelease":"119-100","text":"minimizes firefighter exposure to the lowest level necessary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s1748b–1/e/1/B","parentIdentifier":"/us/usc/t43/s1748b–1/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe%2F1%2FB","sourceRelease":"119-100","text":"reduces overall costs of wildfire incidents.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Wildfire decision support system","label":"2 Wildfire decision support system","identifier":"/us/usc/t43/s1748b–1/e/2","parentIdentifier":"/us/usc/t43/s1748b–1/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t43/s1748b–1/e/2/A","parentIdentifier":"/us/usc/t43/s1748b–1/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe%2F2%2FA","sourceRelease":"119-100","text":"The Secretaries, in coordination with State wildland firefighting agencies, shall establish a system or expand an existing system to track and monitor decisions made by the Secretaries or State wildland firefighting agencies in managing wildfires.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Components","label":"B Components","identifier":"/us/usc/t43/s1748b–1/e/2/B","parentIdentifier":"/us/usc/t43/s1748b–1/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s1748b–1/e/2/B/i","parentIdentifier":"/us/usc/t43/s1748b–1/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe%2F2%2FB%2Fi","sourceRelease":"119-100","text":"unusual costs are incurred;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s1748b–1/e/2/B/ii","parentIdentifier":"/us/usc/t43/s1748b–1/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s1748b–1/e/2/B/ii/I","parentIdentifier":"/us/usc/t43/s1748b–1/e/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe%2F2%2FB%2Fii%2FI","sourceRelease":"119-100","text":"endanger the safety of a firefighter; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s1748b–1/e/2/B/ii/II","parentIdentifier":"/us/usc/t43/s1748b–1/e/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe%2F2%2FB%2Fii%2FII","sourceRelease":"119-100","text":"be ineffective in meeting an applicable suppression or protection goal; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t43/s1748b–1/e/2/B/iii","parentIdentifier":"/us/usc/t43/s1748b–1/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe%2F2%2FB%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t43/s1748b–1/e/2/B/iii/I","parentIdentifier":"/us/usc/t43/s1748b–1/e/2/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe%2F2%2FB%2Fiii%2FI","sourceRelease":"119-100","text":"an applicable protocol established by the Secretaries, including the requirement under paragraph (1); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s1748b–1/e/2/B/iii/II","parentIdentifier":"/us/usc/t43/s1748b–1/e/2/B/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fe%2F2%2FB%2Fiii%2FII","sourceRelease":"119-100","text":"an applicable spatial fire management plan or fire management plan of the Secretary concerned.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Smoke projections from active wildland fires","label":"f Smoke projections from active wildland fires","identifier":"/us/usc/t43/s1748b–1/f","parentIdentifier":"/us/usc/t43/s1748b–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s1748b–1/f/1","parentIdentifier":"/us/usc/t43/s1748b–1/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Ff%2F1","sourceRelease":"119-100","text":"to the maximum extent practicable, shall assign 1 or more air resource advisors to a type 1 incident management team managing a Federal wildland fire; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s1748b–1/f/2","parentIdentifier":"/us/usc/t43/s1748b–1/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Ff%2F2","sourceRelease":"119-100","text":"may assign 1 or more air resource advisors to a type 2 incident management team managing a wildland fire.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Omitted","label":"g Omitted","identifier":"/us/usc/t43/s1748b–1/g","parentIdentifier":"/us/usc/t43/s1748b–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Rapid Response Erosion Database","label":"h Rapid Response Erosion Database","identifier":"/us/usc/t43/s1748b–1/h","parentIdentifier":"/us/usc/t43/s1748b–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s1748b–1/h/1","parentIdentifier":"/us/usc/t43/s1748b–1/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fh%2F1","sourceRelease":"119-100","text":"The Secretaries, in consultation with the Administrator of the National Aeronautics and Space Administration and the Secretary of Commerce, shall establish and maintain a database, to be known as the “Rapid Response Erosion Database” (referred to in this subsection as the “Database”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Open-source Database","label":"2 Open-source Database","identifier":"/us/usc/t43/s1748b–1/h/2","parentIdentifier":"/us/usc/t43/s1748b–1/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fh%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Availability","label":"A Availability","identifier":"/us/usc/t43/s1748b–1/h/2/A","parentIdentifier":"/us/usc/t43/s1748b–1/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fh%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s1748b–1/h/2/A/i","parentIdentifier":"/us/usc/t43/s1748b–1/h/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fh%2F2%2FA%2Fi","sourceRelease":"119-100","text":"web-based; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s1748b–1/h/2/A/ii","parentIdentifier":"/us/usc/t43/s1748b–1/h/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fh%2F2%2FA%2Fii","sourceRelease":"119-100","text":"available without charge.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Components","label":"B Components","identifier":"/us/usc/t43/s1748b–1/h/2/B","parentIdentifier":"/us/usc/t43/s1748b–1/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fh%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s1748b–1/h/2/B/i","parentIdentifier":"/us/usc/t43/s1748b–1/h/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fh%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the automatic incorporation of spatial data relating to vegetation, soils, and elevation into an applicable map created by the Secretary concerned that depicts the changes in land-cover and soil properties caused by a wildland fire; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s1748b–1/h/2/B/ii","parentIdentifier":"/us/usc/t43/s1748b–1/h/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fh%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the generation of a composite map that can be used by the Secretary concerned to model the effectiveness of treatments in the burned area to prevent flooding, erosion, and landslides under a range of weather scenarios.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Use","label":"3 Use","identifier":"/us/usc/t43/s1748b–1/h/3","parentIdentifier":"/us/usc/t43/s1748b–1/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fh%2F3","sourceRelease":"119-100","text":"The Secretary concerned shall use the Database, as applicable, in developing recommendations for emergency stabilization treatments or modifications to drainage structures to protect values-at-risk following a wildland fire.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Coordination","label":"4 Coordination","identifier":"/us/usc/t43/s1748b–1/h/4","parentIdentifier":"/us/usc/t43/s1748b–1/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fh%2F4","sourceRelease":"119-100","text":"The Secretaries may share the Database, and any results generated in using the Database, with any State or unit of local government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Predicting where wildfires will start","label":"i Predicting where wildfires will start","identifier":"/us/usc/t43/s1748b–1/i","parentIdentifier":"/us/usc/t43/s1748b–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s1748b–1/i/1","parentIdentifier":"/us/usc/t43/s1748b–1/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fi%2F1","sourceRelease":"119-100","text":"The Secretaries, in consultation with the Administrator of the National Aeronautics and Space Administration, the Secretary of Energy, and the Secretary of Commerce, through the capabilities and assets located at the National Laboratories, shall establish and maintain a system to predict the locations of future wildfires for fire-prone areas of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Cooperation; components","label":"2 Cooperation; components","identifier":"/us/usc/t43/s1748b–1/i/2","parentIdentifier":"/us/usc/t43/s1748b–1/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fi%2F2","sourceRelease":"119-100","text":"The system established under paragraph (1) shall be based on, and seek to enhance, similar systems in existence on , including the Fire Danger Assessment System.March 12, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Use in forecasts","label":"3 Use in forecasts","identifier":"/us/usc/t43/s1748b–1/i/3","parentIdentifier":"/us/usc/t43/s1748b–1/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fi%2F3","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretaries shall use the system established under paragraph (1), to the maximum extent practicable, for purposes of developing any wildland fire potential forecasts.March 12, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Coordination","label":"4 Coordination","identifier":"/us/usc/t43/s1748b–1/i/4","parentIdentifier":"/us/usc/t43/s1748b–1/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fi%2F4","sourceRelease":"119-100","text":"The Secretaries may share the system established under paragraph (1), and any results generated in using the system, with any State or unit of local government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"j","heading":"Termination of authority","label":"j Termination of authority","identifier":"/us/usc/t43/s1748b–1/j","parentIdentifier":"/us/usc/t43/s1748b–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fj","sourceRelease":"119-100","text":"The authority provided by this section terminates on the date that is 10 years after .March 12, 2019","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"k","heading":"Savings clause","label":"k Savings clause","identifier":"/us/usc/t43/s1748b–1/k","parentIdentifier":"/us/usc/t43/s1748b–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fk","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s1748b–1/k/1","parentIdentifier":"/us/usc/t43/s1748b–1/k","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fk%2F1","sourceRelease":"119-100","text":"requires the Secretary concerned to establish a new program, system, or database to replace an existing program, system, or database that meets the objectives of this section; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s1748b–1/k/2","parentIdentifier":"/us/usc/t43/s1748b–1/k","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fk%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s1748b–1/k/2/A","parentIdentifier":"/us/usc/t43/s1748b–1/k/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fk%2F2%2FA","sourceRelease":"119-100","text":"is more efficient, safer, or better meets the needs of firefighters, other personnel, or the public; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s1748b–1/k/2/B","parentIdentifier":"/us/usc/t43/s1748b–1/k/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1748b%E2%80%931%2Fk%2F2%2FB","sourceRelease":"119-100","text":"meets the objectives of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
