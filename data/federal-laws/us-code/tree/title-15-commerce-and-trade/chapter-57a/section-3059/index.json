{"type":"section","nativeType":"section","number":"3059","heading":"Unfair or deceptive acts or practices","label":"3059 Unfair or deceptive acts or practices","identifier":"/us/usc/t15/s3059","parentIdentifier":"/us/usc/t15/ch57A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3059","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s3059/1","parentIdentifier":"/us/usc/t15/s3059","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3059%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s3059/1/A","parentIdentifier":"/us/usc/t15/s3059/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3059%2F1%2FA","sourceRelease":"119-100","text":"a bisphosphonate prior to the horse’s fourth birthday; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s3059/1/B","parentIdentifier":"/us/usc/t15/s3059/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3059%2F1%2FB","sourceRelease":"119-100","text":"any other substance or method the Authority determines has a long-term degrading effect on the soundness of the covered horse; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s3059/2","parentIdentifier":"/us/usc/t15/s3059","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs3059%2F2","sourceRelease":"119-100","text":"fails to disclose to the buyer the administration of the bisphosphonate