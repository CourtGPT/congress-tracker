e; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t20/s1161e/e/1/A/vi","parentIdentifier":"/us/usc/t20/s1161e/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fe%2F1%2FA%2Fvi","sourceRelease":"119-100","text":"teacher preparation initiatives that stress content mastery regarding traditional American history, free institutions, or Western civilization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161e/e/1/B","parentIdentifier":"/us/usc/t20/s1161e/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fe%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1161e/e/1/B/i","parentIdentifier":"/us/usc/t20/s1161e/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fe%2F1%2FB%2Fi","sourceRelease":"119-100","text":"to undergraduate students (including students enrolled in teacher education programs, if applicable);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t20/s1161e/e/1/B/ii","parentIdentifier":"/us/usc/t20/s1161e/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fe%2F1%2FB%2Fii","sourceRelease":"119-100","text":"to graduate students (including students enrolled in teacher education programs, if applicable);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t20/s1161e/e/1/B/iii","parentIdentifier":"/us/usc/t20/s1161e/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fe%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"to faculty;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t20/s1161e/e/1/B/iv","parentIdentifier":"/us/usc/t20/s1161e/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fe%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"to local educational agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t20/s1161e/e/1/B/v","parentIdentifier":"/us/usc/t20/s1161e/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fe%2F1%2FB%2Fv","sourceRelease":"119-100","text":"within the local community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Allowable uses of funds","label":"2 Allowable uses of funds","identifier":"/us/usc/t20/s1161e/e/2","parentIdentifier":"/us/usc/t20/s1161e/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161e/e/2/A","parentIdentifier":"/us/usc/t20/s1161e/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fe%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t20/s1161e/e/2/A/i","parentIdentifier":"/us/usc/t20/s1161e/e/2/A","sourceUrl":"h