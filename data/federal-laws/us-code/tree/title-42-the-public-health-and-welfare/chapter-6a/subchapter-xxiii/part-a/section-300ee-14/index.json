{"type":"section","nativeType":"section","number":"300ee–14","heading":"Restrictions on use of grant","label":"300ee–14 Restrictions on use of grant","identifier":"/us/usc/t42/s300ee–14","parentIdentifier":"/us/usc/t42/ch6A/schXXIII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300ee%E2%80%9314","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsA prior section 2504 of act , was successively renumbered by subsequent acts, see .July 1, 1944section 238c of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s300ee–14/a","parentIdentifier":"/us/usc/t42/s300ee–14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300ee%E2%80%9314%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300ee–14/a/1","parentIdentifier":"/us/usc/t42/s300ee–14/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300ee%E2%80%9314%2Fa%2F1","sourceRelease":"119-100","text":"to provide inpatient services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300ee–14/a/2","parentIdentifier":"/us/usc/t42/s300ee–14/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300ee%E2%80%9314%2Fa%2F2","sourceRelease":"119-100","text":"to make cash payments to intended recipients of services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300ee–14/a/3","parentIdentifier":"/us/usc/t42/s300ee–14/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300ee%E2%80%9314%2Fa%2F3","sourceRelease":"119-100","text":"to purchase or improve real property (other than minor remodeling of existing improvements to real property) or to purchase major medical equipment; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s300ee–14/a/4","parentIdentifier":"/us/usc/t42/s300ee–14/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300ee%E2%80%9314%2Fa%2F4","sourceRelease":"119-100","text":"to satisfy any requirement for the expenditure of non-Federal funds as a condition for the receipt of Federal funds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitation on administrative expenses","label":"b Limitation on administrative expenses","identifier":"/us/usc/t42/s300ee–14/b","parentIdentifier":"/us/usc/t42/s300ee–14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300ee%E2%80%9314%2Fb","sourceRelease":"119-100","text":"The Secretary may not make payments under for a fiscal year unless the State involved agrees that the State will not expend more than 5 percent of the payments for administrative expenses with respect to carrying out the purpose described in .section 300ee–11(a) of this titlesection 300ee–11(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
