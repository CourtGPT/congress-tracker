{"type":"section","nativeType":"section","number":"1599j","heading":"Restricted reports of incidents of adult sexual assault","label":"1599j Restricted reports of incidents of adult sexual assault","identifier":"/us/usc/t10/s1599j","parentIdentifier":"/us/usc/t10/stA/ptII/ch81","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Restricted Reports","label":"a .—Restricted Reports","identifier":"/us/usc/t10/s1599j/a","parentIdentifier":"/us/usc/t10/s1599j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fa","sourceRelease":"119-100","text":"The Secretary of Defense may provide a civilian employee of the Department of Defense an opportunity to submit to an individual described in subsection (d) a restricted report of an alleged incident of adult sexual assault for the purpose of assisting the employee in obtaining information and access to authorized victim support services provided by the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Restrictions on Disclosures and Initiating Investigations","label":"b .—Restrictions on Disclosures and Initiating Investigations","identifier":"/us/usc/t10/s1599j/b","parentIdentifier":"/us/usc/t10/s1599j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1599j/b/1","parentIdentifier":"/us/usc/t10/s1599j/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fb%2F1","sourceRelease":"119-100","text":"be disclosed to the supervisor of the employee or any other management official; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1599j/b/2","parentIdentifier":"/us/usc/t10/s1599j/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fb%2F2","sourceRelease":"119-100","text":"cause the initiation of a Federal civil or criminal investigation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Duties Under Other Laws","label":"c .—Duties Under Other Laws","identifier":"/us/usc/t10/s1599j/c","parentIdentifier":"/us/usc/t10/s1599j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fc","sourceRelease":"119-100","text":"The receipt of a restricted report submitted under subsection (a) shall not be construed as imputing actual or constructive knowledge of an alleged incident of sexual assault to the Department of Defense for any purpose.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Individuals Authorized to Receive Restricted Reports","label":"d .—Individuals Authorized to Receive Restricted Reports","identifier":"/us/usc/t10/s1599j/d","parentIdentifier":"/us/usc/t10/s1599j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s1599j/d/1","parentIdentifier":"/us/usc/t10/s1599j/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fd%2F1","sourceRelease":"119-100","text":"Sexual assault prevention and response.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s1599j/d/2","parentIdentifier":"/us/usc/t10/s1599j/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fd%2F2","sourceRelease":"119-100","text":"Victim advocacy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s1599j/d/3","parentIdentifier":"/us/usc/t10/s1599j/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fd%2F3","sourceRelease":"119-100","text":"Equal employment opportunity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s1599j/d/4","parentIdentifier":"/us/usc/t10/s1599j/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fd%2F4","sourceRelease":"119-100","text":"Workplace violence prevention and response.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t10/s1599j/d/5","parentIdentifier":"/us/usc/t10/s1599j/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fd%2F5","sourceRelease":"119-100","text":"Employee assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t10/s1599j/d/6","parentIdentifier":"/us/usc/t10/s1599j/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fd%2F6","sourceRelease":"119-100","text":"Family advocacy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Definitions","label":"e .—Definitions","identifier":"/us/usc/t10/s1599j/e","parentIdentifier":"/us/usc/t10/s1599j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Civilian employee","label":"1 .—Civilian employee","identifier":"/us/usc/t10/s1599j/e/1","parentIdentifier":"/us/usc/t10/s1599j/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fe%2F1","sourceRelease":"119-100","text":"The term “civilian employee” has the meaning given the term “employee” in .section 2105 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Sexual assault","label":"2 .—Sexual assault","identifier":"/us/usc/t10/s1599j/e/2","parentIdentifier":"/us/usc/t10/s1599j/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs1599j%2Fe%2F2","sourceRelease":"119-100","text":"The term “sexual assault” has the meaning given that term in (article 120 of the Uniform Code of Military Justice), and includes penetrative offenses and sexual contact offenses.section 920 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
