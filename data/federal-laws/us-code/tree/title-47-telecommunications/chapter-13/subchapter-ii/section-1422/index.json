{"type":"section","nativeType":"section","number":"1422","heading":"Public safety broadband network","label":"1422 Public safety broadband network","identifier":"/us/usc/t47/s1422","parentIdentifier":"/us/usc/t47/ch13/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1422","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t47/s1422/a","parentIdentifier":"/us/usc/t47/s1422","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1422%2Fa","sourceRelease":"119-100","text":"The First Responder Network Authority shall ensure the establishment of a nationwide, interoperable public safety broadband network.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Network components","label":"b Network components","identifier":"/us/usc/t47/s1422/b","parentIdentifier":"/us/usc/t47/s1422","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1422%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s1422/b/1","parentIdentifier":"/us/usc/t47/s1422/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1422%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1422/b/1/A","parentIdentifier":"/us/usc/t47/s1422/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1422%2Fb%2F1%2FA","sourceRelease":"119-100","text":"consists of national and regional data centers, and other elements and functions that may be distributed geographically, all of which shall be based on commercial standards; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1422/b/1/B","parentIdentifier":"/us/usc/t47/s1422/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1422%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1422/b/1/B/i","parentIdentifier":"/us/usc/t47/s1422/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1422%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the radio access network; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1422/b/1/B/ii","parentIdentifier":"/us/usc/t47/s1422/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1422%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the public Internet or the public switched network, or both; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s1422/b/2","parentIdentifier":"/us/usc/t47/s1422/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1422%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1422/b/2/A","parentIdentifier":"/us/usc/t47/s1422/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1422%2Fb%2F2%2FA","sourceRelease":"119-100","text":"consists of all cell site equipment, antennas, and backhaul equipment, based on commercial standards, that are required to enable wireless communications with devices using the public safety broadband spectrum; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1422/b/2/B","parentIdentifier":"/us/usc/t47/s1422/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1422%2Fb%2F2%2FB","sourceRelease":"119-100","text":"shall be developed, constructed, managed, maintained, and operated taking into account the plans developed in the State, local, and tribal planning and implementation grant program under .section 1442(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
