{"type":"section","nativeType":"section","number":"416a","heading":"Resident Advisory Committees","label":"416a Resident Advisory Committees","identifier":"/us/usc/t24/s416a","parentIdentifier":"/us/usc/t24/ch10/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs416a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment and purpose","label":"a Establishment and purpose","identifier":"/us/usc/t24/s416a/a","parentIdentifier":"/us/usc/t24/s416a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs416a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t24/s416a/a/1","parentIdentifier":"/us/usc/t24/s416a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs416a%2Fa%2F1","sourceRelease":"119-100","text":"A Resident Advisory Committee is an elected body of residents at each facility of the Retirement Home established to provide a forum for all residents to express their needs, ideas, and interests through elected representatives of their respective floor or area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t24/s416a/a/2","parentIdentifier":"/us/usc/t24/s416a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs416a%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t24/s416a/a/2/A","parentIdentifier":"/us/usc/t24/s416a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs416a%2Fa%2F2%2FA","sourceRelease":"119-100","text":"serves as a forum for ideas, recommendations, and representation to management of that facility of the Retirement Home to enhance the morale, safety, health, and well-being of residents; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t24/s416a/a/2/B","parentIdentifier":"/us/usc/t24/s416a/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs416a%2Fa%2F2%2FB","sourceRelease":"119-100","text":"provides a means to communicate policy and general information between residents and management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Election process","label":"b Election process","identifier":"/us/usc/t24/s416a/b","parentIdentifier":"/us/usc/t24/s416a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs416a%2Fb","sourceRelease":"119-100","text":"The election process for the Resident Advisory Committee at a facility of the Retirement Home shall be coordinated by the facility Ombudsman.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Chairperson","label":"c Chairperson","identifier":"/us/usc/t24/s416a/c","parentIdentifier":"/us/usc/t24/s416a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs416a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t24/s416a/c/1","parentIdentifier":"/us/usc/t24/s416a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs416a%2Fc%2F1","sourceRelease":"119-100","text":"The Chairperson of a Resident Advisory Committee shall be elected at large and serve a two-year term.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t24/s416a/c/2","parentIdentifier":"/us/usc/t24/s416a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs416a%2Fc%2F2","sourceRelease":"119-100","text":"Chairpersons serve as a liaison to the Administrator and are voting members of the Advisory Council. Chairpersons shall create meeting agendas, conduct the meetings, and provide a copy of the minutes to the Administrator, who will forward the copy to the Chief Operating Officer for approval.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Meetings","label":"d Meetings","identifier":"/us/usc/t24/s416a/d","parentIdentifier":"/us/usc/t24/s416a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft24%2Fs416a%2Fd","sourceRelease":"119-100","text":"At a minimum, meetings of a Resident Advisory Committee shall be conducted quarterly.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
