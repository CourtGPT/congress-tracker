{"type":"section","nativeType":"section","number":"460n–3","heading":"Purposes and uses of area","label":"460n–3 Purposes and uses of area","identifier":"/us/usc/t16/s460n–3","parentIdentifier":"/us/usc/t16/ch1/schLXXII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460n%E2%80%933","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Public recreation, benefit, and use","label":"a Public recreation, benefit, and use","identifier":"/us/usc/t16/s460n–3/a","parentIdentifier":"/us/usc/t16/s460n–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460n%E2%80%933%2Fa","sourceRelease":"119-100","text":"Lake Mead National Recreation Area shall be administered by the Secretary of the Interior for general purposes of public recreation, benefit, and use, and in a manner that will preserve, develop, and enhance, so far as practicable, the recreation potential, and in a manner that will preserve the scenic, historic, scientific, and other important features of the area, consistently with applicable reservations and limitations relating to such area and with other authorized uses of the lands and properties within such area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Specific activities","label":"b Specific activities","identifier":"/us/usc/t16/s460n–3/b","parentIdentifier":"/us/usc/t16/s460n–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460n%E2%80%933%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460n–3/b/1","parentIdentifier":"/us/usc/t16/s460n–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460n%E2%80%933%2Fb%2F1","sourceRelease":"119-100","text":"General recreation use, such as bathing, boating, camping, and picnicking;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460n–3/b/2","parentIdentifier":"/us/usc/t16/s460n–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460n%E2%80%933%2Fb%2F2","sourceRelease":"119-100","text":"Grazing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s460n–3/b/3","parentIdentifier":"/us/usc/t16/s460n–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460n%E2%80%933%2Fb%2F3","sourceRelease":"119-100","text":"Mineral leasing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s460n–3/b/4","parentIdentifier":"/us/usc/t16/s460n–3/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460n%E2%80%933%2Fb%2F4","sourceRelease":"119-100","text":"Vacation cabin site use, in accordance with existing policies of the Department of the Interior relating to such use, or as such policies may be revised hereafter by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
