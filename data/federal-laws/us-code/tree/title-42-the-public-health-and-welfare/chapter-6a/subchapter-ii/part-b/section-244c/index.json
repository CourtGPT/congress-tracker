{"type":"section","nativeType":"section","number":"244c","heading":"Cardiomyopathy research","label":"244c Cardiomyopathy research","identifier":"/us/usc/t42/s244c","parentIdentifier":"/us/usc/t42/ch6A/schII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244c","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s244c/a","parentIdentifier":"/us/usc/t42/s244c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244c%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s244c/a/1","parentIdentifier":"/us/usc/t42/s244c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244c%2Fa%2F1","sourceRelease":"119-100","text":"causation of cardiomyopathy, including genetic causes and molecular biomarkers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s244c/a/2","parentIdentifier":"/us/usc/t42/s244c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244c%2Fa%2F2","sourceRelease":"119-100","text":"long-term health outcomes in individuals with cardiomyopathy, including infants, children, teenagers, adults, and elderly individuals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s244c/a/3","parentIdentifier":"/us/usc/t42/s244c/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244c%2Fa%2F3","sourceRelease":"119-100","text":"studies using longitudinal data and retrospective analysis to identify effective treatments and outcomes for individuals with cardiomyopathy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Nonduplication","label":"b Nonduplication","identifier":"/us/usc/t42/s244c/b","parentIdentifier":"/us/usc/t42/s244c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244c%2Fb","sourceRelease":"119-100","text":"The Secretary shall ensure that any research and activities related to cardiomyopathy under this section do not unnecessarily duplicate activities, programs, or efforts of other agencies and offices within the Department of Health and Human Services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"NIH report","label":"c NIH report","identifier":"/us/usc/t42/s244c/c","parentIdentifier":"/us/usc/t42/s244c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244c%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s244c/c/1","parentIdentifier":"/us/usc/t42/s244c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244c%2Fc%2F1","sourceRelease":"119-100","text":"outlining the ongoing research efforts of the National Institutes of Health regarding cardiomyopathy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s244c/c/2","parentIdentifier":"/us/usc/t42/s244c/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244c%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s244c/c/2/A","parentIdentifier":"/us/usc/t42/s244c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244c%2Fc%2F2%2FA","sourceRelease":"119-100","text":"a research agenda regarding adult forms of cardiomyopathy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s244c/c/2/B","parentIdentifier":"/us/usc/t42/s244c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244c%2Fc%2F2%2FB","sourceRelease":"119-100","text":"plans for researching cardiomyopathy affecting the pediatric population; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s244c/c/2/C","parentIdentifier":"/us/usc/t42/s244c/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244c%2Fc%2F2%2FC","sourceRelease":"119-100","text":"the areas of greatest need for such research.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Cardiomyopathy defined","label":"d Cardiomyopathy defined","identifier":"/us/usc/t42/s244c/d","parentIdentifier":"/us/usc/t42/s244c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs244c%2Fd","sourceRelease":"119-100","text":"In this section, the term “cardiomyopathy” has the meaning given to such term in .section 244a of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
