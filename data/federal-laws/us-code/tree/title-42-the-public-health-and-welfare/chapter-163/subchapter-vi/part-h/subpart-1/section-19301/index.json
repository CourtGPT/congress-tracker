{"type":"section","nativeType":"section","number":"19301","heading":"National Clean Energy Incubator Program","label":"19301 National Clean Energy Incubator Program","identifier":"/us/usc/t42/s19301","parentIdentifier":"/us/usc/t42/ch163/schVI/ptH/spt1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Clean energy incubator defined","label":"a Clean energy incubator defined","identifier":"/us/usc/t42/s19301/a","parentIdentifier":"/us/usc/t42/s19301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19301/a/1","parentIdentifier":"/us/usc/t42/s19301/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19301/a/1/A","parentIdentifier":"/us/usc/t42/s19301/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fa%2F1%2FA","sourceRelease":"119-100","text":"physical workspace, labs, and prototyping facilities to support clean energy startups or established clean energy companies; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19301/a/1/B","parentIdentifier":"/us/usc/t42/s19301/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s19301/a/1/B/i","parentIdentifier":"/us/usc/t42/s19301/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"access to business education and counseling;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s19301/a/1/B/ii","parentIdentifier":"/us/usc/t42/s19301/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"mentorship opportunities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s19301/a/1/B/iii","parentIdentifier":"/us/usc/t42/s19301/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fa%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"other services rendered for the purpose of aiding the development and commercial application of a clean energy technology; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19301/a/2","parentIdentifier":"/us/usc/t42/s19301/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fa%2F2","sourceRelease":"119-100","text":"may include a program within or established by a National Laboratory, an institution of higher education or a State, territorial, local, or tribal government.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Program establishment","label":"b Program establishment","identifier":"/us/usc/t42/s19301/b","parentIdentifier":"/us/usc/t42/s19301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fb","sourceRelease":"119-100","text":"Not later than 180 days after the enactment of this Act, the Secretary, acting through the Chief Commercialization Officer established in , shall establish a Clean Energy Incubator Program (herein referred to as the “program”) to competitively award grants to clean energy incubators.section 16391(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Clean energy incubator selection","label":"c Clean energy incubator selection","identifier":"/us/usc/t42/s19301/c","parentIdentifier":"/us/usc/t42/s19301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19301/c/1","parentIdentifier":"/us/usc/t42/s19301/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fc%2F1","sourceRelease":"119-100","text":"partner with entities that carry out activities relevant to the activities of such incubator and that operate at the local, State, and regional levels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19301/c/2","parentIdentifier":"/us/usc/t42/s19301/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fc%2F2","sourceRelease":"119-100","text":"support the commercial application activities of startup companies focused on physical hardware, computational, or integrated hardware and software technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s19301/c/3","parentIdentifier":"/us/usc/t42/s19301/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fc%2F3","sourceRelease":"119-100","text":"are located in geographically diverse regions of the United States, such as the Great Lakes region;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s19301/c/4","parentIdentifier":"/us/usc/t42/s19301/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fc%2F4","sourceRelease":"119-100","text":"are located in, or partner with entities located in, economically-distressed areas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s19301/c/5","parentIdentifier":"/us/usc/t42/s19301/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fc%2F5","sourceRelease":"119-100","text":"support the development of entities focused on expanding clean energy tools and technologies to rural, Tribal, and low-income communities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s19301/c/6","parentIdentifier":"/us/usc/t42/s19301/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fc%2F6","sourceRelease":"119-100","text":"support the commercial application of technologies being developed by clean energy entrepreneurs from underrepresented backgrounds; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s19301/c/7","parentIdentifier":"/us/usc/t42/s19301/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fc%2F7","sourceRelease":"119-100","text":"have a plan for sustaining activities of the incubator after grant funds received under this program have been expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Award limits","label":"d Award limits","identifier":"/us/usc/t42/s19301/d","parentIdentifier":"/us/usc/t42/s19301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fd","sourceRelease":"119-100","text":"The Secretary shall not award more than $4,000,000 to one or more incubators in one given State, per fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Duration","label":"e Duration","identifier":"/us/usc/t42/s19301/e","parentIdentifier":"/us/usc/t42/s19301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fe","sourceRelease":"119-100","text":"Each grant under subsection (b) shall be for a period of no longer than 5 years, subject to the availability of appropriations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Use of funds","label":"f Use of funds","identifier":"/us/usc/t42/s19301/f","parentIdentifier":"/us/usc/t42/s19301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Ff","sourceRelease":"119-100","text":"An entity receiving a grant under this section may use grant amounts for operating expenses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Renewal","label":"g Renewal","identifier":"/us/usc/t42/s19301/g","parentIdentifier":"/us/usc/t42/s19301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fg","sourceRelease":"119-100","text":"An award made to a clean energy incubator under this section may be renewed for a period of not more than 3 years, subject to merit review.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Evaluation","label":"h Evaluation","identifier":"/us/usc/t42/s19301/h","parentIdentifier":"/us/usc/t42/s19301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fh","sourceRelease":"119-100","text":"In accordance with , the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate an evaluation of the program established under this section that includes analyses of the performance of the clean energy incubators.section 16391a of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Authorization of appropriations","label":"i Authorization of appropriations","identifier":"/us/usc/t42/s19301/i","parentIdentifier":"/us/usc/t42/s19301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19301%2Fi","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Secretary to carry out this section $15,000,000 for each of fiscal years 2023 through 2027.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
