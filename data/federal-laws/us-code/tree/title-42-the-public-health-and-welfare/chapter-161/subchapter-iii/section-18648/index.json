{"type":"section","nativeType":"section","number":"18648","heading":"Accelerator research and development","label":"18648 Accelerator research and development","identifier":"/us/usc/t42/s18648","parentIdentifier":"/us/usc/t42/ch161/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Program","label":"a Program","identifier":"/us/usc/t42/s18648/a","parentIdentifier":"/us/usc/t42/s18648","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18648/a/1","parentIdentifier":"/us/usc/t42/s18648/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fa%2F1","sourceRelease":"119-100","text":"to advance accelerator science and technology relevant to the Department, other Federal agencies, and United States industry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18648/a/2","parentIdentifier":"/us/usc/t42/s18648/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fa%2F2","sourceRelease":"119-100","text":"to foster partnerships to develop, demonstrate, and enable the commercial application of accelerator technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18648/a/3","parentIdentifier":"/us/usc/t42/s18648/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fa%2F3","sourceRelease":"119-100","text":"to support the development of a skilled, diverse, and inclusive accelerator workforce; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18648/a/4","parentIdentifier":"/us/usc/t42/s18648/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fa%2F4","sourceRelease":"119-100","text":"to provide access to accelerator design and engineering resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Accelerator research","label":"b Accelerator research","identifier":"/us/usc/t42/s18648/b","parentIdentifier":"/us/usc/t42/s18648","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18648/b/1","parentIdentifier":"/us/usc/t42/s18648/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fb%2F1","sourceRelease":"119-100","text":"research activities in cross-cutting accelerator technologies including superconducting magnets and accelerators, beam physics, data analytics-based accelerator controls, simulation software, new particle sources, advanced laser technology, and transformative research; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18648/b/2","parentIdentifier":"/us/usc/t42/s18648/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fb%2F2","sourceRelease":"119-100","text":"optimal operation of the Accelerator Test Facility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Accelerator development","label":"c Accelerator development","identifier":"/us/usc/t42/s18648/c","parentIdentifier":"/us/usc/t42/s18648","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fc","sourceRelease":"119-100","text":"In carrying out the program authorized under subsection (a), the Director shall support partnerships to foster the development, demonstration, and commercial application of accelerator technologies, including advanced superconducting wire and cable, superconducting RF cavities, and high efficiency radiofrequency power sources for accelerators.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Research collaborations","label":"d Research collaborations","identifier":"/us/usc/t42/s18648/d","parentIdentifier":"/us/usc/t42/s18648","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18648/d/1","parentIdentifier":"/us/usc/t42/s18648/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fd%2F1","sourceRelease":"119-100","text":"consider the requirements necessary to support translational research and development for medical, industrial, security, and defense applications; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18648/d/2","parentIdentifier":"/us/usc/t42/s18648/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fd%2F2","sourceRelease":"119-100","text":"leverage investments in accelerator technologies and fundamental research in particle physics by partnering with institutions of higher education, industry, and other Federal agencies to enable the commercial application of advanced accelerator technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s18648/e","parentIdentifier":"/us/usc/t42/s18648","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18648/e/1","parentIdentifier":"/us/usc/t42/s18648/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fe%2F1","sourceRelease":"119-100","text":"$19,080,000 for fiscal year 2023;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18648/e/2","parentIdentifier":"/us/usc/t42/s18648/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fe%2F2","sourceRelease":"119-100","text":"$20,224,800 for fiscal year 2024;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18648/e/3","parentIdentifier":"/us/usc/t42/s18648/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fe%2F3","sourceRelease":"119-100","text":"$21,438,288 for fiscal year 2025;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18648/e/4","parentIdentifier":"/us/usc/t42/s18648/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fe%2F4","sourceRelease":"119-100","text":"$22,724,585 for fiscal year 2026; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s18648/e/5","parentIdentifier":"/us/usc/t42/s18648/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18648%2Fe%2F5","sourceRelease":"119-100","text":"$24,088,060 for fiscal year 2027.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
