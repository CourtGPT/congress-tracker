{"type":"section","nativeType":"section","number":"6287","heading":"Matters relating to critical decisions","label":"6287 Matters relating to critical decisions","identifier":"/us/usc/t10/s6287","parentIdentifier":"/us/usc/t10/stA/ptVI/sptB/ch607/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6287","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsProvisions similar to those in this section were contained in , War and National Defense, prior to repeal by .section 2755 of Title 50Pub. L. 119–60, § 3111(b)(1)"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"2 .—Post-critical DecisionChanges","label":"a 2 .—Post-critical DecisionChanges","identifier":"/us/usc/t10/s6287/a","parentIdentifier":"/us/usc/t10/s6287","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6287%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s6287/a/1","parentIdentifier":"/us/usc/t10/s6287/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6287%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s6287/a/1/A","parentIdentifier":"/us/usc/t10/s6287/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6287%2Fa%2F1%2FA","sourceRelease":"119-100","text":"a certification that the Administrator, without delegation, authorizes such proposed change; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s6287/a/1/B","parentIdentifier":"/us/usc/t10/s6287/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6287%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t10/s6287/a/1/B/i","parentIdentifier":"/us/usc/t10/s6287/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6287%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the effects of such proposed change on the project cost and schedule; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t10/s6287/a/1/B/ii","parentIdentifier":"/us/usc/t10/s6287/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6287%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"any mission risks and operational risks from making such change or not making such change; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s6287/a/2","parentIdentifier":"/us/usc/t10/s6287/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6287%2Fa%2F2","sourceRelease":"119-100","text":"a period of 15 days elapses following the date of such submission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Review and Approval","label":"b .—Review and Approval","identifier":"/us/usc/t10/s6287/b","parentIdentifier":"/us/usc/t10/s6287","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs6287%2Fb","sourceRelease":"119-100","text":"The Administrator shall ensure that critical decision packages are timely reviewed and either approved or disapproved.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
