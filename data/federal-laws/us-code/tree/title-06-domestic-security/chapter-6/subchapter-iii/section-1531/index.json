{"type":"section","nativeType":"section","number":"1531","heading":"Apprehension and prosecution of international cyber criminals","label":"1531 Apprehension and prosecution of international cyber criminals","identifier":"/us/usc/t6/s1531","parentIdentifier":"/us/usc/t6/ch6/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"International cyber criminal defined","label":"a International cyber criminal defined","identifier":"/us/usc/t6/s1531/a","parentIdentifier":"/us/usc/t6/s1531","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s1531/a/1","parentIdentifier":"/us/usc/t6/s1531/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fa%2F1","sourceRelease":"119-100","text":"who is believed to have committed a cybercrime or intellectual property crime against the interests of the United States or the citizens of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s1531/a/2","parentIdentifier":"/us/usc/t6/s1531/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s1531/a/2/A","parentIdentifier":"/us/usc/t6/s1531/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fa%2F2%2FA","sourceRelease":"119-100","text":"an arrest warrant has been issued by a judge in the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s1531/a/2/B","parentIdentifier":"/us/usc/t6/s1531/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fa%2F2%2FB","sourceRelease":"119-100","text":"an international wanted notice (commonly referred to as a “Red Notice”) has been circulated by Interpol.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Consultations for noncooperation","label":"b Consultations for noncooperation","identifier":"/us/usc/t6/s1531/b","parentIdentifier":"/us/usc/t6/s1531","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s1531/b/1","parentIdentifier":"/us/usc/t6/s1531/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fb%2F1","sourceRelease":"119-100","text":"to apprehend and prosecute such criminals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s1531/b/2","parentIdentifier":"/us/usc/t6/s1531/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fb%2F2","sourceRelease":"119-100","text":"to prevent such criminals from carrying out cybercrimes or intellectual property crimes against the interests of the United States or its citizens.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Annual report","label":"c Annual report","identifier":"/us/usc/t6/s1531/c","parentIdentifier":"/us/usc/t6/s1531","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s1531/c/1","parentIdentifier":"/us/usc/t6/s1531/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s1531/c/1/A","parentIdentifier":"/us/usc/t6/s1531/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the number of international cyber criminals located in other countries, disaggregated by country, and indicating from which countries extradition is not likely due to the lack of an extradition treaty with the United States or other reasons;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s1531/c/1/B","parentIdentifier":"/us/usc/t6/s1531/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fc%2F1%2FB","sourceRelease":"119-100","text":"the nature and number of significant discussions by an official of the Department of State on ways to thwart or prosecute international cyber criminals with an official of another country, including the name of each such country; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s1531/c/1/C","parentIdentifier":"/us/usc/t6/s1531/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fc%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s1531/c/1/C/i","parentIdentifier":"/us/usc/t6/s1531/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fc%2F1%2FC%2Fi","sourceRelease":"119-100","text":"his or her name;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s1531/c/1/C/ii","parentIdentifier":"/us/usc/t6/s1531/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fc%2F1%2FC%2Fii","sourceRelease":"119-100","text":"the crimes for which he or she was charged;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t6/s1531/c/1/C/iii","parentIdentifier":"/us/usc/t6/s1531/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fc%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"his or her previous country of residence; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t6/s1531/c/1/C/iv","parentIdentifier":"/us/usc/t6/s1531/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fc%2F1%2FC%2Fiv","sourceRelease":"119-100","text":"the country from which he or she was extradited into the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Form","label":"2 Form","identifier":"/us/usc/t6/s1531/c/2","parentIdentifier":"/us/usc/t6/s1531/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fc%2F2","sourceRelease":"119-100","text":"The report required by this subsection shall be in unclassified form to the maximum extent possible, but may include a classified annex.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Appropriate congressional committees","label":"3 Appropriate congressional committees","identifier":"/us/usc/t6/s1531/c/3","parentIdentifier":"/us/usc/t6/s1531/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s1531/c/3/A","parentIdentifier":"/us/usc/t6/s1531/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fc%2F3%2FA","sourceRelease":"119-100","text":"the Committee on Foreign Relations, the Committee on Appropriations, the Committee on Homeland Security and Governmental Affairs, the Committee on Banking, Housing, and Urban Affairs, the Select Committee on Intelligence, and the Committee on the Judiciary of the Senate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s1531/c/3/B","parentIdentifier":"/us/usc/t6/s1531/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1531%2Fc%2F3%2FB","sourceRelease":"119-100","text":"the Committee on Foreign Affairs, the Committee on Appropriations, the Committee on Homeland Security, the Committee on Financial Services, the Permanent Select Committee on Intelligence, and the Committee on the Judiciary of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
