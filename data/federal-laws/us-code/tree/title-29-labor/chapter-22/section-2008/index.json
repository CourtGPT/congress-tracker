{"type":"section","nativeType":"section","number":"2008","heading":"Disclosure of information","label":"2008 Disclosure of information","identifier":"/us/usc/t29/s2008","parentIdentifier":"/us/usc/t29/ch22","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2008","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective 6 months after , except that rules and regulations shall be issued not later than 90 days after , see , set out as a note under .June 27, 1988June 27, 1988section 11 of Pub. L. 100–347section 2001 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t29/s2008/a","parentIdentifier":"/us/usc/t29/s2008","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2008%2Fa","sourceRelease":"119-100","text":"A person, other than the examinee, may not disclose information obtained during a polygraph test, except as provided in this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Permitted disclosures","label":"b Permitted disclosures","identifier":"/us/usc/t29/s2008/b","parentIdentifier":"/us/usc/t29/s2008","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2008%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s2008/b/1","parentIdentifier":"/us/usc/t29/s2008/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2008%2Fb%2F1","sourceRelease":"119-100","text":"the examinee or any other person specifically designated in writing by the examinee;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s2008/b/2","parentIdentifier":"/us/usc/t29/s2008/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2008%2Fb%2F2","sourceRelease":"119-100","text":"the employer that requested the test; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t29/s2008/b/3","parentIdentifier":"/us/usc/t29/s2008/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2008%2Fb%2F3","sourceRelease":"119-100","text":"any court, governmental agency, arbitrator, or mediator, in accordance with due process of law, pursuant to an order from a court of competent jurisdiction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Disclosure by employer","label":"c Disclosure by employer","identifier":"/us/usc/t29/s2008/c","parentIdentifier":"/us/usc/t29/s2008","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2008%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s2008/c/1","parentIdentifier":"/us/usc/t29/s2008/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2008%2Fc%2F1","sourceRelease":"119-100","text":"a person in accordance with subsection (b); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s2008/c/2","parentIdentifier":"/us/usc/t29/s2008/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2008%2Fc%2F2","sourceRelease":"119-100","text":"a governmental agency, but only insofar as the disclosed information is an admission of criminal conduct.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
