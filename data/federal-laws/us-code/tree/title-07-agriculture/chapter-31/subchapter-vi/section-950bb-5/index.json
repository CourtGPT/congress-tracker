{"type":"section","nativeType":"section","number":"950bb–5","heading":"Default and deobligation; deferral","label":"950bb–5 Default and deobligation; deferral","identifier":"/us/usc/t7/s950bb–5","parentIdentifier":"/us/usc/t7/ch31/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%935","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Default and deobligation","label":"a Default and deobligation","identifier":"/us/usc/t7/s950bb–5/a","parentIdentifier":"/us/usc/t7/s950bb–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%935%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s950bb–5/a/1","parentIdentifier":"/us/usc/t7/s950bb–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%935%2Fa%2F1","sourceRelease":"119-100","text":"recover funds from loan and grant defaults;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s950bb–5/a/2","parentIdentifier":"/us/usc/t7/s950bb–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%935%2Fa%2F2","sourceRelease":"119-100","text":"deobligate any awards, less allowable costs that demonstrate an insufficient level of performance (including metrics determined by the Secretary) or fraudulent spending, to the extent funds with respect to the award are available in the account relating to the program established by this subchapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s950bb–5/a/3","parentIdentifier":"/us/usc/t7/s950bb–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%935%2Fa%2F3","sourceRelease":"119-100","text":"award those funds, on a competitive basis, to new or existing applicants consistent with this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s950bb–5/a/4","parentIdentifier":"/us/usc/t7/s950bb–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%935%2Fa%2F4","sourceRelease":"119-100","text":"minimize overlap among the programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Deferral period","label":"b Deferral period","identifier":"/us/usc/t7/s950bb–5/b","parentIdentifier":"/us/usc/t7/s950bb–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950bb%E2%80%935%2Fb","sourceRelease":"119-100","text":"In determining the terms and conditions of assistance provided under this subchapter, the Secretary may establish a deferral period of not shorter than the buildout period established for the project involved in order to support the financial feasibility and long-term sustainability of the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
