{"type":"section","nativeType":"section","number":"45g","heading":"Addition to Sequoia National Park","label":"45g Addition to Sequoia National Park","identifier":"/us/usc/t16/s45g","parentIdentifier":"/us/usc/t16/ch1/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs45g","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s45g/a","parentIdentifier":"/us/usc/t16/s45g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs45g%2Fa","sourceRelease":"119-100","text":"As soon as practicable after , the Secretary of the Interior shall acquire by donation, purchase with donated or appropriated funds, or exchange, all interest in and to the land described in subsection (b) for addition to Sequoia National Park, California.December 28, 2000","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Land acquired","label":"b Land acquired","identifier":"/us/usc/t16/s45g/b","parentIdentifier":"/us/usc/t16/s45g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs45g%2Fb","sourceRelease":"119-100","text":"The land referred to in subsection (a) is the land depicted on the map entitled “Dillonwood”, numbered 102/80,044, and dated September 1999.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Addition to park","label":"c Addition to park","identifier":"/us/usc/t16/s45g/c","parentIdentifier":"/us/usc/t16/s45g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs45g%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s45g/c/1","parentIdentifier":"/us/usc/t16/s45g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs45g%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s45g/c/1/A","parentIdentifier":"/us/usc/t16/s45g/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs45g%2Fc%2F1%2FA","sourceRelease":"119-100","text":"modify the boundaries of Sequoia National Park to include the land within the park; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s45g/c/1/B","parentIdentifier":"/us/usc/t16/s45g/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs45g%2Fc%2F1%2FB","sourceRelease":"119-100","text":"administer the land as part of Sequoia National Park in accordance with all applicable laws; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s45g/c/2","parentIdentifier":"/us/usc/t16/s45g/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs45g%2Fc%2F2","sourceRelease":"119-100","text":"the Secretary of Agriculture shall modify the boundaries of the Sequoia National Forest to exclude the land from the forest boundaries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
