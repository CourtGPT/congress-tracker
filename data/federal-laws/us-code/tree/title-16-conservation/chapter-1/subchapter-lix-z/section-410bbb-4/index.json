{"type":"section","nativeType":"section","number":"410bbb–4","heading":"General management plan","label":"410bbb–4 General management plan","identifier":"/us/usc/t16/s410bbb–4","parentIdentifier":"/us/usc/t16/ch1/schLIX–Z","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410bbb%E2%80%934","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s410bbb–4/1","parentIdentifier":"/us/usc/t16/s410bbb–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410bbb%E2%80%934%2F1","sourceRelease":"119-100","text":"a visitor use plan indicating programs and facilities associated with park programs that will be made available to the public;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s410bbb–4/2","parentIdentifier":"/us/usc/t16/s410bbb–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410bbb%E2%80%934%2F2","sourceRelease":"119-100","text":"preservation and use plans for any structures and sites that are identified through the historic landmark study for inclusion within the historical park;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s410bbb–4/3","parentIdentifier":"/us/usc/t16/s410bbb–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410bbb%E2%80%934%2F3","sourceRelease":"119-100","text":"the location and associated cost of public facilities that are proposed for inclusion within the historical park, including a visitor center;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s410bbb–4/4","parentIdentifier":"/us/usc/t16/s410bbb–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410bbb%E2%80%934%2F4","sourceRelease":"119-100","text":"identification of programs that the Secretary will implement or be associated with through cooperative agreements with other groups and organizations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s410bbb–4/5","parentIdentifier":"/us/usc/t16/s410bbb–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410bbb%E2%80%934%2F5","sourceRelease":"119-100","text":"a transportation plan that addresses visitor use access needs to sites, facilities, and programs central to the purpose of the historical park;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s410bbb–4/6","parentIdentifier":"/us/usc/t16/s410bbb–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410bbb%E2%80%934%2F6","sourceRelease":"119-100","text":"plans for the implementation of an archival system for materials, objects, and items of importance relating to the history of jazz; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t16/s410bbb–4/7","parentIdentifier":"/us/usc/t16/s410bbb–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs410bbb%E2%80%934%2F7","sourceRelease":"119-100","text":"guidelines for the application of cooperative agreements that will be used to assist in the management of historical park facilities and programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
