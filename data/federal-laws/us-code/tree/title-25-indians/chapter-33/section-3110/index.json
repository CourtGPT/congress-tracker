{"type":"section","nativeType":"section","number":"3110","heading":"Tribal forestry programs","label":"3110 Tribal forestry programs","identifier":"/us/usc/t25/s3110","parentIdentifier":"/us/usc/t25/ch33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3110","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t25/s3110/a","parentIdentifier":"/us/usc/t25/s3110","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3110%2Fa","sourceRelease":"119-100","text":"The Secretary shall establish within the Bureau of Indian Affairs a program to provide financial support to forestry programs established by an Indian tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Support allocation formula; criteria","label":"b Support allocation formula; criteria","identifier":"/us/usc/t25/s3110/b","parentIdentifier":"/us/usc/t25/s3110","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3110%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s3110/b/1","parentIdentifier":"/us/usc/t25/s3110/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3110%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3110/b/1/A","parentIdentifier":"/us/usc/t25/s3110/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3110%2Fb%2F1%2FA","sourceRelease":"119-100","text":"for the determination of Indian tribes eligible for such support,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3110/b/1/B","parentIdentifier":"/us/usc/t25/s3110/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3110%2Fb%2F1%2FB","sourceRelease":"119-100","text":"for the provision of levels of assistance for the forestry programs of such tribes, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s3110/b/1/C","parentIdentifier":"/us/usc/t25/s3110/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3110%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the allocation of base support funds to such tribes under the program established pursuant to subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s3110/b/2","parentIdentifier":"/us/usc/t25/s3110/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3110%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3110/b/2/A","parentIdentifier":"/us/usc/t25/s3110/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3110%2Fb%2F2%2FA","sourceRelease":"119-100","text":"one professional forester, including fringe benefits and support costs, for each eligible tribe, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3110/b/2/B","parentIdentifier":"/us/usc/t25/s3110/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3110%2Fb%2F2%2FB","sourceRelease":"119-100","text":"one additional professional forester or forest technician, including fringe benefits and support costs, for each level of assistance for which an eligible Indian tribe qualifies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s3110/b/3","parentIdentifier":"/us/usc/t25/s3110/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3110%2Fb%2F3","sourceRelease":"119-100","text":"In any fiscal year that appropriations are not sufficient to fully fund tribal forestry programs at each level of assistance under the formula required to be established in this section, available funds for each level of assistance shall be evenly divided among the tribes qualifying for that level of assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
