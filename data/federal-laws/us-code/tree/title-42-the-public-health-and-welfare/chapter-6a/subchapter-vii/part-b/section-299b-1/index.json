type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s299b–1/a/2/A/ii","parentIdentifier":"/us/usc/t42/s299b–1/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"other populations, including those receiving long-term care services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s299b–1/a/2/B","parentIdentifier":"/us/usc/t42/s299b–1/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the ongoing development, testing, and dissemination of quality measures, including measures of health and functional outcomes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s299b–1/a/2/C","parentIdentifier":"/us/usc/t42/s299b–1/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fa%2F2%2FC","sourceRelease":"119-100","text":"the compilation and dissemination of health care quality measures developed in the private and public sector;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s299b–1/a/2/D","parentIdentifier":"/us/usc/t42/s299b–1/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fa%2F2%2FD","sourceRelease":"119-100","text":"assistance in the development of improved health care information systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s299b–1/a/2/E","parentIdentifier":"/us/usc/t42/s299b–1/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fa%2F2%2FE","sourceRelease":"119-100","text":"the development of survey tools for the purpose of measuring participant and beneficiary assessments of their health care; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s299b–1/a/2/F","parentIdentifier":"/us/usc/t42/s299b–1/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fa%2F2%2FF","sourceRelease":"119-100","text":"identifying and disseminating information on mechanisms for the integration of information on quality into purchaser and consumer decision-making processes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Centers for education and research on therapeutics","label":"b Centers for education and research on therapeutics","identifier":"/us/usc/t42/s299b–1/b","parentIdentifier":"/us/usc/t42/s299b–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s299b–1/b/1","parentIdentifier":"/us/usc/t42/s299b–1/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs299b%E2%80%931%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary, acting through the Director and in consultation with the Commissioner of Food and Drugs, shall establish a program for the purpose of making one or more grants for the establishment and operation of one or more centers to carry out the activities specified in paragraph (2).","no