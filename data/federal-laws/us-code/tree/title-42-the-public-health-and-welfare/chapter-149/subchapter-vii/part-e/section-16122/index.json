{"type":"section","nativeType":"section","number":"16122","heading":"Federal and State procurement of fuel cell vehicles and hydrogen energy systems","label":"16122 Federal and State procurement of fuel cell vehicles and hydrogen energy systems","identifier":"/us/usc/t42/s16122","parentIdentifier":"/us/usc/t42/ch149/schVII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purposes","label":"a Purposes","identifier":"/us/usc/t42/s16122/a","parentIdentifier":"/us/usc/t42/s16122","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16122/a/1","parentIdentifier":"/us/usc/t42/s16122/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fa%2F1","sourceRelease":"119-100","text":"to stimulate acceptance by the market of fuel cell vehicles and hydrogen energy systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16122/a/2","parentIdentifier":"/us/usc/t42/s16122/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fa%2F2","sourceRelease":"119-100","text":"to support development of technologies relating to fuel cell vehicles, public refueling stations, and hydrogen energy systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16122/a/3","parentIdentifier":"/us/usc/t42/s16122/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fa%2F3","sourceRelease":"119-100","text":"to require the Federal government, which is the largest single user of energy in the United States, to adopt those technologies as soon as practicable after the technologies are developed, in conjunction with private industry partners.1So in original. Probably should be capitalized.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Federal leases and purchases","label":"b Federal leases and purchases","identifier":"/us/usc/t42/s16122/b","parentIdentifier":"/us/usc/t42/s16122","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Requirement","label":"1 Requirement","identifier":"/us/usc/t42/s16122/b/1","parentIdentifier":"/us/usc/t42/s16122/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16122/b/1/A","parentIdentifier":"/us/usc/t42/s16122/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F1%2FA","sourceRelease":"119-100","text":"Not later than , the head of any Federal agency that uses a light-duty or heavy-duty vehicle fleet shall lease or purchase fuel cell vehicles and hydrogen energy systems to meet any applicable energy savings goal described in subsection (c).January 1, 2010","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Learning demonstration vehicles","label":"B Learning demonstration vehicles","identifier":"/us/usc/t42/s16122/b/1/B","parentIdentifier":"/us/usc/t42/s16122/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F1%2FB","sourceRelease":"119-100","text":"The Secretary may lease or purchase appropriate vehicles developed under subsections (a)(10) and (b)(1)(A) of to meet the requirement in subparagraph (A).section 16157 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Costs of leases and purchases","label":"2 Costs of leases and purchases","identifier":"/us/usc/t42/s16122/b/2","parentIdentifier":"/us/usc/t42/s16122/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16122/b/2/A","parentIdentifier":"/us/usc/t42/s16122/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16122/b/2/A/i","parentIdentifier":"/us/usc/t42/s16122/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the cost to the agencies of leasing or purchasing fuel cell vehicles and hydrogen energy systems under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16122/b/2/A/ii","parentIdentifier":"/us/usc/t42/s16122/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the cost to the agencies of a feasible alternative to leasing or purchasing fuel cell vehicles and hydrogen energy systems, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Competitive costs and management structures","label":"B Competitive costs and management structures","identifier":"/us/usc/t42/s16122/b/2/B","parentIdentifier":"/us/usc/t42/s16122/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16122/b/2/B/i","parentIdentifier":"/us/usc/t42/s16122/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"a cost-effective purchase of a fuel cell vehicle or hydrogen energy system; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16122/b/2/B/ii","parentIdentifier":"/us/usc/t42/s16122/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"a cost-effective management structure of the lease of a fuel cell vehicle or hydrogen energy system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Exception","label":"3 Exception","identifier":"/us/usc/t42/s16122/b/3","parentIdentifier":"/us/usc/t42/s16122/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s16122/b/3/A","parentIdentifier":"/us/usc/t42/s16122/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F3%2FA","sourceRelease":"119-100","text":"If the Secretary determines that the head of an agency described in paragraph (1) cannot find an appropriately efficient and reliable fuel cell vehicle or hydrogen energy system in accordance with paragraph (1), that agency shall be excepted from compliance with paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Consideration","label":"B Consideration","identifier":"/us/usc/t42/s16122/b/3/B","parentIdentifier":"/us/usc/t42/s16122/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16122/b/3/B/i","parentIdentifier":"/us/usc/t42/s16122/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"the needs of the agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16122/b/3/B/ii","parentIdentifier":"/us/usc/t42/s16122/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s16122/b/3/B/ii/I","parentIdentifier":"/us/usc/t42/s16122/b/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F3%2FB%2Fii%2FI","sourceRelease":"119-100","text":"the Task Force; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s16122/b/3/B/ii/II","parentIdentifier":"/us/usc/t42/s16122/b/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fb%2F3%2FB%2Fii%2FII","sourceRelease":"119-100","text":"the Technical Advisory Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Energy savings goals","label":"c Energy savings goals","identifier":"/us/usc/t42/s16122/c","parentIdentifier":"/us/usc/t42/s16122","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16122/c/1","parentIdentifier":"/us/usc/t42/s16122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Regulations","label":"A Regulations","identifier":"/us/usc/t42/s16122/c/1/A","parentIdentifier":"/us/usc/t42/s16122/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16122/c/1/A/i","parentIdentifier":"/us/usc/t42/s16122/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"in cooperation with the Task Force, promulgate regulations for the period of 2008 through 2010 that extend and augment energy savings goals for each Federal agency, in accordance with any Executive order issued after March 2000; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16122/c/1/A/ii","parentIdentifier":"/us/usc/t42/s16122/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"promulgate regulations to expand the minimum Federal fleet requirement and credit allowances for fuel cell vehicle systems under .section 13212 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Review, evaluation, and new regulations","label":"B Review, evaluation, and new regulations","identifier":"/us/usc/t42/s16122/c/1/B","parentIdentifier":"/us/usc/t42/s16122/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16122/c/1/B/i","parentIdentifier":"/us/usc/t42/s16122/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"review the regulations promulgated under subparagraph (A);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16122/c/1/B/ii","parentIdentifier":"/us/usc/t42/s16122/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"evaluate any progress made toward achieving energy savings by Federal agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16122/c/1/B/iii","parentIdentifier":"/us/usc/t42/s16122/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fc%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"promulgate new regulations for the period of 2011 through 2015 to achieve additional energy savings by Federal agencies relating to technical and cost-performance standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Offsetting energy savings goals","label":"2 Offsetting energy savings goals","identifier":"/us/usc/t42/s16122/c/2","parentIdentifier":"/us/usc/t42/s16122/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fc%2F2","sourceRelease":"119-100","text":"An agency that leases or purchases a fuel cell vehicle or hydrogen energy system in accordance with subsection (b)(1) may use that lease or purchase to count toward an energy savings goal of the agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Cooperative program with State agencies","label":"d Cooperative program with State agencies","identifier":"/us/usc/t42/s16122/d","parentIdentifier":"/us/usc/t42/s16122","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16122/d/1","parentIdentifier":"/us/usc/t42/s16122/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary may establish a cooperative program with State agencies managing motor vehicle fleets to encourage purchase of fuel cell vehicles by the agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Incentives","label":"2 Incentives","identifier":"/us/usc/t42/s16122/d/2","parentIdentifier":"/us/usc/t42/s16122/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fd%2F2","sourceRelease":"119-100","text":"In carrying out the cooperative program, the Secretary may offer incentive payments to a State agency to assist with the cost of planning, differential purchases, and administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s16122/e","parentIdentifier":"/us/usc/t42/s16122","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16122/e/1","parentIdentifier":"/us/usc/t42/s16122/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fe%2F1","sourceRelease":"119-100","text":"$15,000,000 for fiscal year 2008;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16122/e/2","parentIdentifier":"/us/usc/t42/s16122/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fe%2F2","sourceRelease":"119-100","text":"$25,000,000 for fiscal year 2009;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16122/e/3","parentIdentifier":"/us/usc/t42/s16122/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fe%2F3","sourceRelease":"119-100","text":"$65,000,000 for fiscal year 2010; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16122/e/4","parentIdentifier":"/us/usc/t42/s16122/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16122%2Fe%2F4","sourceRelease":"119-100","text":"such sums as are necessary for each of fiscal years 2011 through 2015.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
