{"type":"section","nativeType":"section","number":"6854","heading":"Data consolidation and publication of route and area data for public recreational use","label":"6854 Data consolidation and publication of route and area data for public recreational use","identifier":"/us/usc/t16/s6854","parentIdentifier":"/us/usc/t16/ch87A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2025—Subsec. (a)(4). substituted “regulated or closed” for “permanently restricted or prohibited”.Pub. L. 118–234"],"amendments":["Amendments2025—Subsec. (a)(4). substituted “regulated or closed” for “permanently restricted or prohibited”.Pub. L. 118–234"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s6854/a","parentIdentifier":"/us/usc/t16/s6854","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s6854/a/1","parentIdentifier":"/us/usc/t16/s6854/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fa%2F1","sourceRelease":"119-100","text":"Status information with respect to whether roads and trails on the Federal land are open or closed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6854/a/2","parentIdentifier":"/us/usc/t16/s6854/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fa%2F2","sourceRelease":"119-100","text":"The dates on which roads and trails on the Federal land are seasonally closed.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s6854/a/3","parentIdentifier":"/us/usc/t16/s6854/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6854/a/3/A","parentIdentifier":"/us/usc/t16/s6854/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fa%2F3%2FA","sourceRelease":"119-100","text":"off-highway vehicles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6854/a/3/B","parentIdentifier":"/us/usc/t16/s6854/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fa%2F3%2FB","sourceRelease":"119-100","text":"motorcycles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6854/a/3/C","parentIdentifier":"/us/usc/t16/s6854/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fa%2F3%2FC","sourceRelease":"119-100","text":"nonmotorized bicycles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s6854/a/3/D","parentIdentifier":"/us/usc/t16/s6854/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fa%2F3%2FD","sourceRelease":"119-100","text":"electric bicycles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s6854/a/3/E","parentIdentifier":"/us/usc/t16/s6854/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fa%2F3%2FE","sourceRelease":"119-100","text":"passenger vehicles;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t16/s6854/a/3/F","parentIdentifier":"/us/usc/t16/s6854/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fa%2F3%2FF","sourceRelease":"119-100","text":"nonmechanized transportation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t16/s6854/a/3/G","parentIdentifier":"/us/usc/t16/s6854/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fa%2F3%2FG","sourceRelease":"119-100","text":"over-snow vehicles.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s6854/a/4","parentIdentifier":"/us/usc/t16/s6854/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fa%2F4","sourceRelease":"119-100","text":"The boundaries of areas where hunting or recreational shooting (including archery, firearm discharge, and target shooting) is regulated or closed on the Federal land.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Updates","label":"b Updates","identifier":"/us/usc/t16/s6854/b","parentIdentifier":"/us/usc/t16/s6854","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s6854/b/1","parentIdentifier":"/us/usc/t16/s6854/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fb%2F1","sourceRelease":"119-100","text":"The Secretaries, to the maximum extent practicable, shall update the data described in subsection (a) not less frequently than twice per year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Public comment","label":"2 Public comment","identifier":"/us/usc/t16/s6854/b/2","parentIdentifier":"/us/usc/t16/s6854/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fb%2F2","sourceRelease":"119-100","text":"The Secretaries shall develop a process to allow members of the public to submit questions or comments regarding the information described in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Effect","label":"c Effect","identifier":"/us/usc/t16/s6854/c","parentIdentifier":"/us/usc/t16/s6854","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6854%2Fc","sourceRelease":"119-100","text":"Geographic information system data made publicly available under subsection (a) shall not disclose information regarding the nature, location, character, or ownership of historic, paleontological, or archaeological resources, consistent with applicable law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
