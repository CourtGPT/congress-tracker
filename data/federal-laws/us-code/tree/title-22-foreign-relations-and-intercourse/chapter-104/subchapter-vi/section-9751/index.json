{"type":"section","nativeType":"section","number":"9751","heading":"Developing and implementing a coordinated sanctions strategy with partners in the Western Hemisphere and the European Union","label":"9751 Developing and implementing a coordinated sanctions strategy with partners in the Western Hemisphere and the European Union","identifier":"/us/usc/t22/s9751","parentIdentifier":"/us/usc/t22/ch104/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Strengthening sanctions capacity in Latin America and the Caribbean","label":"a Strengthening sanctions capacity in Latin America and the Caribbean","identifier":"/us/usc/t22/s9751/a","parentIdentifier":"/us/usc/t22/s9751","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9751/a/1","parentIdentifier":"/us/usc/t22/s9751/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fa%2F1","sourceRelease":"119-100","text":"are responsible for human rights abuses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9751/a/2","parentIdentifier":"/us/usc/t22/s9751/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fa%2F2","sourceRelease":"119-100","text":"have engaged in public corruption; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s9751/a/3","parentIdentifier":"/us/usc/t22/s9751/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fa%2F3","sourceRelease":"119-100","text":"are undermining democratic institutions and processes in Venezuela.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Coordinating international sanctions","label":"b Coordinating international sanctions","identifier":"/us/usc/t22/s9751/b","parentIdentifier":"/us/usc/t22/s9751","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fb","sourceRelease":"119-100","text":"The Secretary of State, in consultation with the Secretary of the Treasury, shall engage in diplomatic efforts with partner governments, including the Government of Canada, governments in the European Union, and governments in Latin America and the Caribbean, to impose targeted sanctions on the Maduro regime officials described in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Strategy requirement","label":"c Strategy requirement","identifier":"/us/usc/t22/s9751/c","parentIdentifier":"/us/usc/t22/s9751","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9751/c/1","parentIdentifier":"/us/usc/t22/s9751/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fc%2F1","sourceRelease":"119-100","text":"the Committee on Foreign Relations of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9751/c/2","parentIdentifier":"/us/usc/t22/s9751/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fc%2F2","sourceRelease":"119-100","text":"the Committee on Appropriations of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s9751/c/3","parentIdentifier":"/us/usc/t22/s9751/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fc%2F3","sourceRelease":"119-100","text":"the Committee on Banking, Housing, and Urban Affairs of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s9751/c/4","parentIdentifier":"/us/usc/t22/s9751/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fc%2F4","sourceRelease":"119-100","text":"the Committee on Foreign Affairs of the House of Representatives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s9751/c/5","parentIdentifier":"/us/usc/t22/s9751/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fc%2F5","sourceRelease":"119-100","text":"the Committee on Appropriations of the House of Representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s9751/c/6","parentIdentifier":"/us/usc/t22/s9751/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fc%2F6","sourceRelease":"119-100","text":"the Committee on Financial Services of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t22/s9751/d","parentIdentifier":"/us/usc/t22/s9751","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s9751/d/1","parentIdentifier":"/us/usc/t22/s9751/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fd%2F1","sourceRelease":"119-100","text":"There is authorized to be appropriated to the Secretary of State for fiscal year 2020, $3,000,000 to carry out the activities set forth in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Notification requirements","label":"2 Notification requirements","identifier":"/us/usc/t22/s9751/d/2","parentIdentifier":"/us/usc/t22/s9751/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9751%2Fd%2F2","sourceRelease":"119-100","text":"Amounts appropriated pursuant to paragraph (1) are subject to the notification requirements applicable to expenditures from the Economic Support Fund under and the International Narcotics and Law Enforcement Fund under to the extent that such funds are expended.section 2346(c) of this titlesection 2291h of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
