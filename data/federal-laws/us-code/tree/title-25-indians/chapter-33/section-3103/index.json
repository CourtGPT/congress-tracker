{"type":"section","nativeType":"section","number":"3103","heading":"Definitions","label":"3103 Definitions","identifier":"/us/usc/t25/s3103","parentIdentifier":"/us/usc/t25/ch33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s3103/1","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F1","sourceRelease":"119-100","text":"“Alaska Native” means Native as defined in ;section 1602(b) of title 43","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s3103/2","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3103/2/A","parentIdentifier":"/us/usc/t25/s3103/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F2%2FA","sourceRelease":"119-100","text":"is characterized by a more or less dense and extensive tree cover,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3103/2/B","parentIdentifier":"/us/usc/t25/s3103/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F2%2FB","sourceRelease":"119-100","text":"contains, or once contained, at least ten percent tree crown cover, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s3103/2/C","parentIdentifier":"/us/usc/t25/s3103/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F2%2FC","sourceRelease":"119-100","text":"is not developed or planned for exclusive nonforest use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s3103/3","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F3","sourceRelease":"119-100","text":"“Indian forest land” means Indian lands, including commercial and non-commercial timberland and woodland, that are considered chiefly valuable for the production of forest products or to maintain watershed or other land values enhanced by a forest cover, regardless whether a formal inspection and land classification action has been taken;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s3103/4","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3103/4/A","parentIdentifier":"/us/usc/t25/s3103/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s3103/4/A/i","parentIdentifier":"/us/usc/t25/s3103/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FA%2Fi","sourceRelease":"119-100","text":"development and maintenance of policy and operational procedures, program oversight, and evaluation,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s3103/4/A/ii","parentIdentifier":"/us/usc/t25/s3103/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FA%2Fii","sourceRelease":"119-100","text":"securing of legal assistance and handling of legal matters,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t25/s3103/4/A/iii","parentIdentifier":"/us/usc/t25/s3103/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FA%2Fiii","sourceRelease":"119-100","text":"budget, finance, and personnel management, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t25/s3103/4/A/iv","parentIdentifier":"/us/usc/t25/s3103/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FA%2Fiv","sourceRelease":"119-100","text":"development and maintenance of necessary data bases and program reports;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3103/4/B","parentIdentifier":"/us/usc/t25/s3103/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FB","sourceRelease":"119-100","text":"all aspects of the development, preparation and revision of forest inventory and management plans, including aerial photography, mapping, field management inventories and re-inventories, inventory analysis, growth studies, allowable annual cut calculations, environmental assessment, and forest history, consistent with and reflective of tribal integrated resource management plans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s3103/4/C","parentIdentifier":"/us/usc/t25/s3103/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FC","sourceRelease":"119-100","text":"forest land development, including forestation, thinning, tree improvement activities, and the use of silvicultural treatments to restore or increase growth and yield to the full productive capacity of the forest environment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s3103/4/D","parentIdentifier":"/us/usc/t25/s3103/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FD","sourceRelease":"119-100","text":"protection against losses from wildfire, including acquisition and maintenance of fire fighting equipment and fire detection systems, construction of firebreaks, hazard reduction, prescribed burning, and the development of cooperative wildfire management agreements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t25/s3103/4/E","parentIdentifier":"/us/usc/t25/s3103/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s3103/4/E/i","parentIdentifier":"/us/usc/t25/s3103/4/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FE%2Fi","sourceRelease":"119-100","text":"all aspects of detection and evaluation,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s3103/4/E/ii","parentIdentifier":"/us/usc/t25/s3103/4/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FE%2Fii","sourceRelease":"119-100","text":"preparation of project proposals containing project description, environmental assessments and statements, and cost-benefit analyses necessary to secure funding,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t25/s3103/4/E/iii","parentIdentifier":"/us/usc/t25/s3103/4/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FE%2Fiii","sourceRelease":"119-100","text":"field suppression operations, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t25/s3103/4/E/iv","parentIdentifier":"/us/usc/t25/s3103/4/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FE%2Fiv","sourceRelease":"119-100","text":"reporting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t25/s3103/4/F","parentIdentifier":"/us/usc/t25/s3103/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FF","sourceRelease":"119-100","text":"assessment of damage caused by forest trespass, infestation or fire, including field examination and survey, damage appraisal, investigation assistance, and report, demand letter, and testimony preparation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t25/s3103/4/G","parentIdentifier":"/us/usc/t25/s3103/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FG","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s3103/4/G/i","parentIdentifier":"/us/usc/t25/s3103/4/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FG%2Fi","sourceRelease":"119-100","text":"cruising, product marking, silvicultural prescription, appraisal and harvest supervision,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s3103/4/G/ii","parentIdentifier":"/us/usc/t25/s3103/4/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FG%2Fii","sourceRelease":"119-100","text":"forest product marketing assistance, including evaluation of marketing and development opportunities related to Indian forest products and consultation and advice to tribes, tribal and Indian enterprises on maximization of return on forest products,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t25/s3103/4/G/iii","parentIdentifier":"/us/usc/t25/s3103/4/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FG%2Fiii","sourceRelease":"119-100","text":"archeological, historical, environmental and other land management reviews, clearances, and analyses,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t25/s3103/4/G/iv","parentIdentifier":"/us/usc/t25/s3103/4/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FG%2Fiv","sourceRelease":"119-100","text":"advertising, executing, and supervising contracts,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t25/s3103/4/G/v","parentIdentifier":"/us/usc/t25/s3103/4/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FG%2Fv","sourceRelease":"119-100","text":"marking and scaling of timber, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t25/s3103/4/G/vi","parentIdentifier":"/us/usc/t25/s3103/4/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FG%2Fvi","sourceRelease":"119-100","text":"collecting, recording and distributing receipts from sales;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t25/s3103/4/H","parentIdentifier":"/us/usc/t25/s3103/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FH","sourceRelease":"119-100","text":"provision of financial assistance for the education of Indians enrolled in accredited programs of postsecondary and postgraduate forestry and forestry-related fields of study, including the provision of scholarships, internships, relocation assistance, and other forms of assistance to cover educational expenses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t25/s3103/4/I","parentIdentifier":"/us/usc/t25/s3103/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FI","sourceRelease":"119-100","text":"participation in the development and implementation of tribal integrated resource management plans, including activities to coordinate current and future multiple uses of Indian forest lands;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t25/s3103/4/J","parentIdentifier":"/us/usc/t25/s3103/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FJ","sourceRelease":"119-100","text":"improvement and maintenance of extended season primary and secondary Indian forest land road systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"K","heading":null,"label":"K","identifier":"/us/usc/t25/s3103/4/K","parentIdentifier":"/us/usc/t25/s3103/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F4%2FK","sourceRelease":"119-100","text":"research activities to improve the basis for determining appropriate management measures to apply to Indian forest lands;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s3103/5","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3103/5/A","parentIdentifier":"/us/usc/t25/s3103/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F5%2FA","sourceRelease":"119-100","text":"standards setting forth the funding and staffing requirements necessary to carry out each management plan, with a report of current forestry funding and staffing levels; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3103/5/B","parentIdentifier":"/us/usc/t25/s3103/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F5%2FB","sourceRelease":"119-100","text":"standards providing quantitative criteria to evaluate performance against the objectives set forth in the plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t25/s3103/6","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3103/6/A","parentIdentifier":"/us/usc/t25/s3103/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F6%2FA","sourceRelease":"119-100","text":"timber,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3103/6/B","parentIdentifier":"/us/usc/t25/s3103/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F6%2FB","sourceRelease":"119-100","text":"a timber product, including lumber, lath, crating, ties, bolts, logs, pulpwood, fuelwood, posts, poles and split products,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s3103/6/C","parentIdentifier":"/us/usc/t25/s3103/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F6%2FC","sourceRelease":"119-100","text":"bark,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s3103/6/D","parentIdentifier":"/us/usc/t25/s3103/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F6%2FD","sourceRelease":"119-100","text":"Christmas trees, stays, branches, firewood, berries, mosses, pinyon nuts, roots, acorns, syrups, wild rice, and herbs,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t25/s3103/6/E","parentIdentifier":"/us/usc/t25/s3103/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F6%2FE","sourceRelease":"119-100","text":"other marketable material, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t25/s3103/6/F","parentIdentifier":"/us/usc/t25/s3103/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F6%2FF","sourceRelease":"119-100","text":"gravel which is extracted from, and utilized on, Indian forest lands;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t25/s3103/7","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F7","sourceRelease":"119-100","text":"“forest resources” means all the benefits derived from Indian forest lands, including forest products, soil productivity, water, fisheries, wildlife, recreation, and aesthetic or other traditional values of Indian forest lands;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t25/s3103/8","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F8","sourceRelease":"119-100","text":"“forest trespass” means the act of illegally removing forest products from, or illegally damaging forest products on, forest lands;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t25/s3103/9","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F9","sourceRelease":"119-100","text":"“Indian” means a member of an Indian tribe;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t25/s3103/10","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F10","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3103/10/A","parentIdentifier":"/us/usc/t25/s3103/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F10%2FA","sourceRelease":"119-100","text":"the United States in trust for an Indian, an individual of Indian or Alaska Native ancestry who is not a member of a federally-recognized Indian tribe, or an Indian tribe, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3103/10/B","parentIdentifier":"/us/usc/t25/s3103/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F10%2FB","sourceRelease":"119-100","text":"an Indian, an individual of Indian or Alaska Native ancestry who is not a member of a federally recognized tribe, or an Indian tribe subject to a restriction by the United States against alienation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t25/s3103/11","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F11","sourceRelease":"119-100","text":"“Indian tribe” or “tribe” means any Indian tribe, band, nation, Pueblo or other organized group or community which is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians and shall mean, where appropriate, the recognized tribal government of such tribe’s reservation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t25/s3103/12","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F12","sourceRelease":"119-100","text":"“reservation” includes Indian reservations established pursuant to treaties, Acts of Congress or Executive orders, public domain Indian allotments, and former Indian reservations in Oklahoma;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"13","heading":null,"label":"13","identifier":"/us/usc/t25/s3103/13","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F13","sourceRelease":"119-100","text":"“Secretary” means the Secretary of the Interior;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"14","heading":null,"label":"14","identifier":"/us/usc/t25/s3103/14","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F14","sourceRelease":"119-100","text":"“sustained yield” means the yield of forest products that a forest can produce continuously at a given intensity of management; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"15","heading":null,"label":"15","identifier":"/us/usc/t25/s3103/15","parentIdentifier":"/us/usc/t25/s3103","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3103%2F15","sourceRelease":"119-100","text":"“tribal integrated resource management plan” means a document, approved by an Indian tribe and the Secretary, which provides coordination for the comprehensive management of such tribe’s natural resources.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
