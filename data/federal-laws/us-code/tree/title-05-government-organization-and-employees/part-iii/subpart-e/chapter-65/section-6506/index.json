":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Contents","label":"2 .—Contents","identifier":"/us/usc/t5/s6506/b/2","parentIdentifier":"/us/usc/t5/s6506/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s6506/b/2/A","parentIdentifier":"/us/usc/t5/s6506/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t5/s6506/b/2/A/i","parentIdentifier":"/us/usc/t5/s6506/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the total number of employees in the agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t5/s6506/b/2/A/ii","parentIdentifier":"/us/usc/t5/s6506/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the number and percent of employees in the agency who are eligible to telework; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t5/s6506/b/2/A/iii","parentIdentifier":"/us/usc/t5/s6506/b/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t5/s6506/b/2/A/iii/I","parentIdentifier":"/us/usc/t5/s6506/b/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"3 or more days per pay period;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t5/s6506/b/2/A/iii/II","parentIdentifier":"/us/usc/t5/s6506/b/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"1 or 2 days per pay period;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t5/s6506/b/2/A/iii/III","parentIdentifier":"/us/usc/t5/s6506/b/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FA%2Fiii%2FIII","sourceRelease":"119-100","text":"once per month; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t5/s6506/b/2/A/iii/IV","parentIdentifier":"/us/usc/t5/s6506/b/2/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FA%2Fiii%2FIV","sourceRelease":"119-100","text":"on an occasional, episodic, or short-term basis;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s6506/b/2/B","parentIdentifier":"/us/usc/t5/s6506/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the method for gathering telework data in each agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s6506/b/2/C","parentIdentifier":"/us/usc/t5/s6506/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FC","sourceRelease":"119-100","text":"if the total number of employees teleworking is 10 percent higher or lower than the previous year in any agency, the reasons for the positive or negative variation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t5/s6506/b/2/D","parentIdentifier":"/us/usc/t5/s6506/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FD","sourceRelease":"119-100","text":"the agency goal for increasing participation to the extent practicable or necessary for the next reporting period, as indicated by the percent of eligible employees teleworking in each frequency category described under subparagraph (A)(iii);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t5/s6506/b/2/E","parentIdentifier":"/us/usc/t5/s6506/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FE","sourceRelease":"119-100","text":"an explanation of whether or not the agency met the goals for the last reporting period and, if not, what actions are being taken to identify and eliminate barriers to maximizing telework opportunities for the next reporting period;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t5/s6506/b/2/F","parentIdentifier":"/us/usc/t5/s6506/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FF","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t5/s6506/b/2/F/i","parentIdentifier":"/us/usc/t5/s6506/b/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FF%2Fi","sourceRelease":"119-100","text":"emergency readiness;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t5/s6506/b/2/F/ii","parentIdentifier":"/us/usc/t5/s6506/b/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FF%2Fii","sourceRelease":"119-100","text":"energy use;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t5/s6506/b/2/F/iii","parentIdentifier":"/us/usc/t5/s6506/b/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FF%2Fiii","sourceRelease":"119-100","text":"recruitment and retention;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t5/s6506/b/2/F/iv","parentIdentifier":"/us/usc/t5/s6506/b/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FF%2Fiv","sourceRelease":"119-100","text":"performance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t5/s6506/b/2/F/v","parentIdentifier":"/us/usc/t5/s6506/b/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FF%2Fv","sourceRelease":"119-100","text":"productivity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t5/s6506/b/2/F/vi","parentIdentifier":"/us/usc/t5/s6506/b/2/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FF%2Fvi","sourceRelease":"119-100","text":"employee attitudes and opinions regarding telework; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t5/s6506/b/2/G","parentIdentifier":"/us/usc/t5/s6506/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fb%2F2%2FG","sourceRelease":"119-100","text":"the best practices in agency telework programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Comptroller General Reports.—","label":"c Comptroller General Reports.—","identifier":"/us/usc/t5/s6506/c","parentIdentifier":"/us/usc/t5/s6506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Report on government accountability office telework program.—","label":"1 Report on government accountability office telework program.—","identifier":"/us/usc/t5/s6506/c/1","parentIdentifier":"/us/usc/t5/s6506/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t5/s6506/c/1/A","parentIdentifier":"/us/usc/t5/s6506/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t5/s6506/c/1/A/i","parentIdentifier":"/us/usc/t5/s6506/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the Committee on Homeland Security and Governmental Affairs of the Senate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t5/s6506/c/1/A/ii","parentIdentifier":"/us/usc/t5/s6506/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the Committee on Oversight and Government Reform of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Contents","label":"B .—Contents","identifier":"/us/usc/t5/s6506/c/1/B","parentIdentifier":"/us/usc/t5/s6506/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fc%2F1%2FB","sourceRelease":"119-100","text":"Each report submitted by the Comptroller General shall include the same information as required under subsection (b) applicable to the Government Accountability Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Report to congress on office of personnel management report","label":"2 .—Report to congress on office of personnel management report","identifier":"/us/usc/t5/s6506/c/2","parentIdentifier":"/us/usc/t5/s6506/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fc%2F2","sourceRelease":"119-100","text":"Not later than 6 months after the submission of the first report to Congress required under subsection (b), the Comptroller General shall review that report required under subsection (b) and submit a report to Congress on the progress each executive agency has made towards the goals established under section 6504(b)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Chief Human Capital Officer Reports.—","label":"d Chief Human Capital Officer Reports.—","identifier":"/us/usc/t5/s6506/d","parentIdentifier":"/us/usc/t5/s6506","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t5/s6506/d/1","parentIdentifier":"/us/usc/t5/s6506/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fd%2F1","sourceRelease":"119-100","text":"Each year the Chief Human Capital Officer of each executive agency, in consultation with the Telework Managing Officer of that agency, shall submit a report to the Chair and Vice Chair of the Chief Human Capital Officers Council on agency management efforts to promote telework.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Review and inclusion of relevant information","label":"2 .—Review and inclusion of relevant information","identifier":"/us/usc/t5/s6506/d/2","parentIdentifier":"/us/usc/t5/s6506/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s6506/d/2/A","parentIdentifier":"/us/usc/t5/s6506/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fd%2F2%2FA","sourceRelease":"119-100","text":"review the reports submitted under paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s6506/d/2/B","parentIdentifier":"/us/usc/t5/s6506/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fd%2F2%2FB","sourceRelease":"119-100","text":"include relevant information from the submitted reports in the annual report to Congress required under subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s6506/d/2/C","parentIdentifier":"/us/usc/t5/s6506/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6506%2Fd%2F2%2FC","sourceRelease":"119-100","text":"use that relevant information for other purposes related to the strategic management of human capital.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
