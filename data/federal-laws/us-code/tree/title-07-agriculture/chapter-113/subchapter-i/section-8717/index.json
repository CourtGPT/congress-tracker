{"type":"section","nativeType":"section","number":"8717","heading":"Planting flexibility","label":"8717 Planting flexibility","identifier":"/us/usc/t7/s8717","parentIdentifier":"/us/usc/t7/ch113/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Codificationand enacted identical sections. was repealed by .Pub. L. 110–234Pub. L. 110–246Pub. L. 110–234section 4(a) of Pub. L. 110–246","Statutory Notes and Related Subsidiaries","Effective DateEnactment of this section and repeal of by effective , the date of enactment of , see , set out as a note under .Pub. L. 110–234Pub. L. 110–246Pub. L. 110–234section 4 of Pub. L. 110–246section 8701 of this titleMay 22, 2008"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Permitted crops","label":"a Permitted crops","identifier":"/us/usc/t7/s8717/a","parentIdentifier":"/us/usc/t7/s8717","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fa","sourceRelease":"119-100","text":"Subject to subsection (b), any commodity or crop may be planted on base acres on a farm.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitations regarding certain commodities","label":"b Limitations regarding certain commodities","identifier":"/us/usc/t7/s8717/b","parentIdentifier":"/us/usc/t7/s8717","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"General limitation","label":"1 General limitation","identifier":"/us/usc/t7/s8717/b/1","parentIdentifier":"/us/usc/t7/s8717/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fb%2F1","sourceRelease":"119-100","text":"The planting of an agricultural commodity specified in paragraph (3) shall be prohibited on base acres unless the commodity, if planted, is destroyed before harvest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Treatment of trees and other perennials","label":"2 Treatment of trees and other perennials","identifier":"/us/usc/t7/s8717/b/2","parentIdentifier":"/us/usc/t7/s8717/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fb%2F2","sourceRelease":"119-100","text":"The planting of an agricultural commodity specified in paragraph (3) that is produced on a tree or other perennial plant shall be prohibited on base acres.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Covered agricultural commodities","label":"3 Covered agricultural commodities","identifier":"/us/usc/t7/s8717/b/3","parentIdentifier":"/us/usc/t7/s8717/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s8717/b/3/A","parentIdentifier":"/us/usc/t7/s8717/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fb%2F3%2FA","sourceRelease":"119-100","text":"Fruits.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s8717/b/3/B","parentIdentifier":"/us/usc/t7/s8717/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fb%2F3%2FB","sourceRelease":"119-100","text":"Vegetables (other than mung beans and pulse crops).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s8717/b/3/C","parentIdentifier":"/us/usc/t7/s8717/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fb%2F3%2FC","sourceRelease":"119-100","text":"Wild rice.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Exceptions","label":"c Exceptions","identifier":"/us/usc/t7/s8717/c","parentIdentifier":"/us/usc/t7/s8717","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s8717/c/1","parentIdentifier":"/us/usc/t7/s8717/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fc%2F1","sourceRelease":"119-100","text":"in any region in which there is a history of double-cropping of covered commodities with agricultural commodities specified in subsection (b)(3), as determined by the Secretary, in which case the double-cropping shall be permitted;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s8717/c/2","parentIdentifier":"/us/usc/t7/s8717/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fc%2F2","sourceRelease":"119-100","text":"on a farm that the Secretary determines has a history of planting agricultural commodities specified in subsection (b)(3) on base acres, except that direct payments and counter-cyclical payments shall be reduced by an acre for each acre planted to such an agricultural commodity; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s8717/c/3","parentIdentifier":"/us/usc/t7/s8717/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s8717/c/3/A","parentIdentifier":"/us/usc/t7/s8717/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fc%2F3%2FA","sourceRelease":"119-100","text":"the quantity planted may not exceed the average annual planting history of such agricultural commodity by the producers on the farm in the 1991 through 1995 or 1998 through 2001 crop years (excluding any crop year in which no plantings were made), as determined by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s8717/c/3/B","parentIdentifier":"/us/usc/t7/s8717/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fc%2F3%2FB","sourceRelease":"119-100","text":"direct payments and counter-cyclical payments shall be reduced by an acre for each acre planted to such agricultural commodity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Planting transferability pilot project","label":"d Planting transferability pilot project","identifier":"/us/usc/t7/s8717/d","parentIdentifier":"/us/usc/t7/s8717","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Pilot project authorized","label":"1 Pilot project authorized","identifier":"/us/usc/t7/s8717/d/1","parentIdentifier":"/us/usc/t7/s8717/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F1","sourceRelease":"119-100","text":"Notwithstanding paragraphs (1) and (2) of subsection (b) and in addition to the exceptions provided in subsection (c), the Secretary shall carry out a pilot project to permit the planting of cucumbers, green peas, lima beans, pumpkins, snap beans, sweet corn, and tomatoes grown for processing on base acres during each of the 2009 through 2012 crop years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Pilot project States and acres","label":"2 Pilot project States and acres","identifier":"/us/usc/t7/s8717/d/2","parentIdentifier":"/us/usc/t7/s8717/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s8717/d/2/A","parentIdentifier":"/us/usc/t7/s8717/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F2%2FA","sourceRelease":"119-100","text":"9,000 acres in the State of Illinois;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s8717/d/2/B","parentIdentifier":"/us/usc/t7/s8717/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F2%2FB","sourceRelease":"119-100","text":"9,000 acres in the State of Indiana;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s8717/d/2/C","parentIdentifier":"/us/usc/t7/s8717/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F2%2FC","sourceRelease":"119-100","text":"1,000 acres in the State of Iowa;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s8717/d/2/D","parentIdentifier":"/us/usc/t7/s8717/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F2%2FD","sourceRelease":"119-100","text":"9,000 acres in the State of Michigan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t7/s8717/d/2/E","parentIdentifier":"/us/usc/t7/s8717/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F2%2FE","sourceRelease":"119-100","text":"34,000 acres in the State of Minnesota;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t7/s8717/d/2/F","parentIdentifier":"/us/usc/t7/s8717/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F2%2FF","sourceRelease":"119-100","text":"4,000 acres in the State of Ohio; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t7/s8717/d/2/G","parentIdentifier":"/us/usc/t7/s8717/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F2%2FG","sourceRelease":"119-100","text":"9,000 acres in the State of Wisconsin.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Contract and management requirements","label":"3 Contract and management requirements","identifier":"/us/usc/t7/s8717/d/3","parentIdentifier":"/us/usc/t7/s8717/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s8717/d/3/A","parentIdentifier":"/us/usc/t7/s8717/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F3%2FA","sourceRelease":"119-100","text":"demonstrate to the Secretary that the producers on the farm have entered into a contract to produce a crop of a commodity specified in paragraph (1) for processing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s8717/d/3/B","parentIdentifier":"/us/usc/t7/s8717/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F3%2FB","sourceRelease":"119-100","text":"agree to produce the crop as part of a program of crop rotation on the farm to achieve agronomic and pest and disease management benefits; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s8717/d/3/C","parentIdentifier":"/us/usc/t7/s8717/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F3%2FC","sourceRelease":"119-100","text":"provide evidence of the disposition of the crop.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Temporary reduction in base acres","label":"4 Temporary reduction in base acres","identifier":"/us/usc/t7/s8717/d/4","parentIdentifier":"/us/usc/t7/s8717/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F4","sourceRelease":"119-100","text":"The base acres on a farm for a crop year shall be reduced by an acre for each acre planted under the pilot program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Duration of reductions","label":"5 Duration of reductions","identifier":"/us/usc/t7/s8717/d/5","parentIdentifier":"/us/usc/t7/s8717/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F5","sourceRelease":"119-100","text":"The reduction in the base acres of a farm for a crop year under paragraph (4) shall expire at the end of the crop year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Recalculation of base acres","label":"6 Recalculation of base acres","identifier":"/us/usc/t7/s8717/d/6","parentIdentifier":"/us/usc/t7/s8717/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s8717/d/6/A","parentIdentifier":"/us/usc/t7/s8717/d/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F6%2FA","sourceRelease":"119-100","text":"If the Secretary recalculates base acres for a farm while the farm is included in the pilot project, the planting and production of a crop of a commodity specified in paragraph (1) on base acres for which a temporary reduction was made under this section shall be considered to be the same as the planting and production of a covered commodity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Prohibition","label":"B Prohibition","identifier":"/us/usc/t7/s8717/d/6/B","parentIdentifier":"/us/usc/t7/s8717/d/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F6%2FB","sourceRelease":"119-100","text":"Nothing in this paragraph provides authority for the Secretary to recalculate base acres for a farm.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Pilot impact evaluation","label":"7 Pilot impact evaluation","identifier":"/us/usc/t7/s8717/d/7","parentIdentifier":"/us/usc/t7/s8717/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s8717/d/7/A","parentIdentifier":"/us/usc/t7/s8717/d/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F7%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s8717/d/7/A/i","parentIdentifier":"/us/usc/t7/s8717/d/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F7%2FA%2Fi","sourceRelease":"119-100","text":"fresh fruits and vegetables; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s8717/d/7/A/ii","parentIdentifier":"/us/usc/t7/s8717/d/7/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F7%2FA%2Fii","sourceRelease":"119-100","text":"fruits and vegetables for processing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Determination","label":"B Determination","identifier":"/us/usc/t7/s8717/d/7/B","parentIdentifier":"/us/usc/t7/s8717/d/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F7%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s8717/d/7/B/i","parentIdentifier":"/us/usc/t7/s8717/d/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F7%2FB%2Fi","sourceRelease":"119-100","text":"producers of fresh fruits and vegetables are being negatively impacted; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s8717/d/7/B/ii","parentIdentifier":"/us/usc/t7/s8717/d/7/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F7%2FB%2Fii","sourceRelease":"119-100","text":"existing production capacities are being supplanted.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Report","label":"C Report","identifier":"/us/usc/t7/s8717/d/7/C","parentIdentifier":"/us/usc/t7/s8717/d/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs8717%2Fd%2F7%2FC","sourceRelease":"119-100","text":"As soon as practicable after conducting an evaluation under subparagraph (A), the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that describes the results of the evaluation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
