{"type":"section","nativeType":"section","number":"981","heading":"Pilot integrated scanning system","label":"981 Pilot integrated scanning system","identifier":"/us/usc/t6/s981","parentIdentifier":"/us/usc/t6/ch3/schII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Designations","label":"a Designations","identifier":"/us/usc/t6/s981/a","parentIdentifier":"/us/usc/t6/s981","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fa","sourceRelease":"119-100","text":"Not later than 90 days after , the Secretary shall designate 3 foreign seaports through which containers pass or are transshipped to the United States for the establishment of pilot integrated scanning systems that couple nonintrusive imaging equipment and radiation detection equipment. In making the designations under this subsection, the Secretary shall consider 3 distinct ports with unique features and differing levels of trade volume.October 13, 2006","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Coordination","label":"b Coordination","identifier":"/us/usc/t6/s981/b","parentIdentifier":"/us/usc/t6/s981","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s981/b/1","parentIdentifier":"/us/usc/t6/s981/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fb%2F1","sourceRelease":"119-100","text":"coordinate with the Secretary of Energy, as necessary, to provide radiation detection equipment through the Department of Energy’s Second Line of Defense and Megaports programs; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s981/b/2","parentIdentifier":"/us/usc/t6/s981/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fb%2F2","sourceRelease":"119-100","text":"work with the private sector or, when possible, host governments to obtain radiation detection equipment that meets both the Department’s and the Department of Energy’s technical specifications for such equipment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Pilot system implementation","label":"c Pilot system implementation","identifier":"/us/usc/t6/s981/c","parentIdentifier":"/us/usc/t6/s981","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s981/c/1","parentIdentifier":"/us/usc/t6/s981/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fc%2F1","sourceRelease":"119-100","text":"shall scan all containers destined for the United States that are loaded in such ports;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s981/c/2","parentIdentifier":"/us/usc/t6/s981/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fc%2F2","sourceRelease":"119-100","text":"shall electronically transmit the images and information to appropriate United States Government personnel in the country in which the port is located or in the United States for evaluation and analysis;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s981/c/3","parentIdentifier":"/us/usc/t6/s981/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fc%2F3","sourceRelease":"119-100","text":"shall resolve every radiation alarm according to established Department procedures;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s981/c/4","parentIdentifier":"/us/usc/t6/s981/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fc%2F4","sourceRelease":"119-100","text":"shall utilize the information collected to enhance the Automated Targeting System or other relevant programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s981/c/5","parentIdentifier":"/us/usc/t6/s981/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fc%2F5","sourceRelease":"119-100","text":"shall store the information for later retrieval and analysis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t6/s981/c/6","parentIdentifier":"/us/usc/t6/s981/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fc%2F6","sourceRelease":"119-100","text":"may provide an automated notification of questionable or high-risk cargo as a trigger for further inspection by appropriately trained personnel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Report","label":"d Report","identifier":"/us/usc/t6/s981/d","parentIdentifier":"/us/usc/t6/s981","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s981/d/1","parentIdentifier":"/us/usc/t6/s981/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd%2F1","sourceRelease":"119-100","text":"an evaluation of the lessons derived from the pilot system implemented under this subsection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s981/d/2","parentIdentifier":"/us/usc/t6/s981/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd%2F2","sourceRelease":"119-100","text":"an analysis of the efficacy of the Automated Targeting System or other relevant programs in utilizing the images captured to examine high-risk containers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s981/d/3","parentIdentifier":"/us/usc/t6/s981/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd%2F3","sourceRelease":"119-100","text":"an evaluation of the effectiveness of the integrated scanning system in detecting shielded and unshielded nuclear and radiological material;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s981/d/4","parentIdentifier":"/us/usc/t6/s981/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd%2F4","sourceRelease":"119-100","text":"an evaluation of software and other technologies that are capable of automatically identifying potential anomalies in scanned containers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s981/d/5","parentIdentifier":"/us/usc/t6/s981/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s981/d/5/A","parentIdentifier":"/us/usc/t6/s981/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd%2F5%2FA","sourceRelease":"119-100","text":"an analysis of the infrastructure requirements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s981/d/5/B","parentIdentifier":"/us/usc/t6/s981/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd%2F5%2FB","sourceRelease":"119-100","text":"a projection of the effect on current average processing speed of containerized cargo;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s981/d/5/C","parentIdentifier":"/us/usc/t6/s981/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd%2F5%2FC","sourceRelease":"119-100","text":"an evaluation of the scalability of the system to meet both current and future forecasted trade flows;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s981/d/5/D","parentIdentifier":"/us/usc/t6/s981/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd%2F5%2FD","sourceRelease":"119-100","text":"the ability of the system to automatically maintain and catalog appropriate data for reference and analysis in the event of a transportation disruption;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t6/s981/d/5/E","parentIdentifier":"/us/usc/t6/s981/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd%2F5%2FE","sourceRelease":"119-100","text":"an analysis of requirements, including costs, to install and maintain an integrated scanning system;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t6/s981/d/5/F","parentIdentifier":"/us/usc/t6/s981/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd%2F5%2FF","sourceRelease":"119-100","text":"the ability of administering personnel to efficiently manage and utilize the data produced by a nonintrusive scanning system;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t6/s981/d/5/G","parentIdentifier":"/us/usc/t6/s981/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd%2F5%2FG","sourceRelease":"119-100","text":"the ability to safeguard commercial data generated by, or submitted to, a nonintrusive scanning system; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t6/s981/d/5/H","parentIdentifier":"/us/usc/t6/s981/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs981%2Fd%2F5%2FH","sourceRelease":"119-100","text":"an assessment of the reliability of currently available technology to implement an integrated scanning system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
