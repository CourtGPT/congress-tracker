{"type":"section","nativeType":"section","number":"2811","heading":"Native American Issues Coordinator","label":"2811 Native American Issues Coordinator","identifier":"/us/usc/t25/s2811","parentIdentifier":"/us/usc/t25/ch30","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2811","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t25/s2811/a","parentIdentifier":"/us/usc/t25/s2811","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2811%2Fa","sourceRelease":"119-100","text":"There is established in the Executive Office for United States Attorneys of the Department of Justice a position to be known as the “Native American Issues Coordinator”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties","label":"b Duties","identifier":"/us/usc/t25/s2811/b","parentIdentifier":"/us/usc/t25/s2811","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2811%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s2811/b/1","parentIdentifier":"/us/usc/t25/s2811/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2811%2Fb%2F1","sourceRelease":"119-100","text":"coordinate with the United States Attorneys that have authority to prosecute crimes in Indian country;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s2811/b/2","parentIdentifier":"/us/usc/t25/s2811/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2811%2Fb%2F2","sourceRelease":"119-100","text":"coordinate prosecutions of crimes of national significance in Indian country, as determined by the Attorney General;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s2811/b/3","parentIdentifier":"/us/usc/t25/s2811/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2811%2Fb%2F3","sourceRelease":"119-100","text":"coordinate as necessary with other components of the Department of Justice and any relevant advisory groups to the Attorney General or the Deputy Attorney General; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s2811/b/4","parentIdentifier":"/us/usc/t25/s2811/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs2811%2Fb%2F4","sourceRelease":"119-100","text":"carry out such other duties as the Attorney General may prescribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
