{"type":"section","nativeType":"section","number":"3318","heading":"Availability of Federal building project information","label":"3318 Availability of Federal building project information","identifier":"/us/usc/t40/s3318","parentIdentifier":"/us/usc/t40/stII/ptA/ch33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe date of enactment of this section, referred to in subsec. (a), is the date of enactment of , which was approved .Pub. L. 116–333Jan. 13, 2021"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t40/s3318/a","parentIdentifier":"/us/usc/t40/s3318","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t40/s3318/a/1","parentIdentifier":"/us/usc/t40/s3318/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fa%2F1","sourceRelease":"119-100","text":"The Administrator shall maintain such information in an easily accessible and readable, organized, downloadable, and searchable format.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t40/s3318/a/2","parentIdentifier":"/us/usc/t40/s3318/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fa%2F2","sourceRelease":"119-100","text":"The Administrator shall ensure the information is current and prospectuses and associated information updated on a regular basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t40/s3318/a/3","parentIdentifier":"/us/usc/t40/s3318/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fa%2F3","sourceRelease":"119-100","text":"The information required under this section shall be inclusive for a period of not less than 10 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t40/s3318/a/4","parentIdentifier":"/us/usc/t40/s3318/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t40/s3318/a/4/A","parentIdentifier":"/us/usc/t40/s3318/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fa%2F4%2FA","sourceRelease":"119-100","text":"the last date on which the relevant webpage was updated;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t40/s3318/a/4/B","parentIdentifier":"/us/usc/t40/s3318/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fa%2F4%2FB","sourceRelease":"119-100","text":"approval dates of respective authorizing resolutions by each committee of jurisdiction, if applicable;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t40/s3318/a/4/C","parentIdentifier":"/us/usc/t40/s3318/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fa%2F4%2FC","sourceRelease":"119-100","text":"copies of respective committee of jurisdiction resolutions authorizing such prospectuses, as appropriate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t40/s3318/a/4/D","parentIdentifier":"/us/usc/t40/s3318/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fa%2F4%2FD","sourceRelease":"119-100","text":"cross-references to any resubmitted or amended prospectuses and associated resolutions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t40/s3318/a/4/E","parentIdentifier":"/us/usc/t40/s3318/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fa%2F4%2FE","sourceRelease":"119-100","text":"such other information as determined by the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Definitions","label":"b .—Definitions","identifier":"/us/usc/t40/s3318/b","parentIdentifier":"/us/usc/t40/s3318","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Prospectus","label":"1 .—Prospectus","identifier":"/us/usc/t40/s3318/b/1","parentIdentifier":"/us/usc/t40/s3318/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fb%2F1","sourceRelease":"119-100","text":"The term “prospectus” means prospectuses, building surveys, and factsheets submitted to the committees of jurisdiction pursuant to sections 3307 and 3316.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Committees of jurisdiction","label":"2 .—Committees of jurisdiction","identifier":"/us/usc/t40/s3318/b/2","parentIdentifier":"/us/usc/t40/s3318/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fb%2F2","sourceRelease":"119-100","text":"The term “committees of jurisdiction” means the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Associated information","label":"3 .—Associated information","identifier":"/us/usc/t40/s3318/b/3","parentIdentifier":"/us/usc/t40/s3318/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft40%2Fs3318%2Fb%2F3","sourceRelease":"119-100","text":"The term “associated information” means resolutions approved by the committees of jurisdiction and other information as required pursuant to subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
