{"type":"section","nativeType":"section","number":"107","heading":"Automatic execution of conforming changes","label":"107 Automatic execution of conforming changes","identifier":"/us/usc/t14/s107","parentIdentifier":"/us/usc/t14/stI/ch1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs107","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t14/s107/a","parentIdentifier":"/us/usc/t14/s107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs107%2Fa","sourceRelease":"119-100","text":"When an amendment to a covered Coast Guard law adds a section or larger organizational unit to the covered Coast Guard law, repeals or transfers a section or larger organizational unit in the covered Coast Guard law, or amends the designation or heading of a section or larger organizational unit in the covered Coast Guard law, that amendment also shall have the effect of amending any analysis, table of contents, or similar tabular entries in the covered Coast Guard law to alter the table to conform to the changes made by the amendment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Exceptions","label":"b .—Exceptions","identifier":"/us/usc/t14/s107/b","parentIdentifier":"/us/usc/t14/s107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs107%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s107/b/1","parentIdentifier":"/us/usc/t14/s107/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs107%2Fb%2F1","sourceRelease":"119-100","text":"the amendment or a clerical amendment enacted at the same time expressly amends a table of sections, table of contents, or similar tabular entries in the covered maritime law to alter the table to conform to the changes made by the amendment; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s107/b/2","parentIdentifier":"/us/usc/t14/s107/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs107%2Fb%2F2","sourceRelease":"119-100","text":"the amendment otherwise expressly exempts itself from the operation of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Covered Coast Guard Law Defined","label":"c .—Covered Coast Guard Law Defined","identifier":"/us/usc/t14/s107/c","parentIdentifier":"/us/usc/t14/s107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs107%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t14/s107/c/1","parentIdentifier":"/us/usc/t14/s107/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs107%2Fc%2F1","sourceRelease":"119-100","text":"this title;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t14/s107/c/2","parentIdentifier":"/us/usc/t14/s107/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs107%2Fc%2F2","sourceRelease":"119-100","text":"any Coast Guard authorization Act that authorizes funds to be appropriated for a fiscal year to the Coast Guard; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t14/s107/c/3","parentIdentifier":"/us/usc/t14/s107/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft14%2Fs107%2Fc%2F3","sourceRelease":"119-100","text":"any other law designated in the text thereof as a covered Coast Guard law for purposes of application of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
