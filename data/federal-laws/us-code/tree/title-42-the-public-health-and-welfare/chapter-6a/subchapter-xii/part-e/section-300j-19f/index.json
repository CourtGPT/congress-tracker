{"type":"section","nativeType":"section","number":"300j–19f","heading":"Operational sustainability of small public water systems","label":"300j–19f Operational sustainability of small public water systems","identifier":"/us/usc/t42/s300j–19f","parentIdentifier":"/us/usc/t42/ch6A/schXII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s300j–19f/a","parentIdentifier":"/us/usc/t42/s300j–19f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible entity","label":"1 Eligible entity","identifier":"/us/usc/t42/s300j–19f/a/1","parentIdentifier":"/us/usc/t42/s300j–19f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–19f/a/1/A","parentIdentifier":"/us/usc/t42/s300j–19f/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F1%2FA","sourceRelease":"119-100","text":"a State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–19f/a/1/B","parentIdentifier":"/us/usc/t42/s300j–19f/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F1%2FB","sourceRelease":"119-100","text":"a unit of local government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300j–19f/a/1/C","parentIdentifier":"/us/usc/t42/s300j–19f/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F1%2FC","sourceRelease":"119-100","text":"a public corporation established by a unit of local government to provide water service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s300j–19f/a/1/D","parentIdentifier":"/us/usc/t42/s300j–19f/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F1%2FD","sourceRelease":"119-100","text":"a nonprofit corporation, public trust, or cooperative association that owns or operates a public water system;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s300j–19f/a/1/E","parentIdentifier":"/us/usc/t42/s300j–19f/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F1%2FE","sourceRelease":"119-100","text":"an Indian Tribe that owns or operates a public water system;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s300j–19f/a/1/F","parentIdentifier":"/us/usc/t42/s300j–19f/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F1%2FF","sourceRelease":"119-100","text":"a nonprofit organization that provides technical assistance to public water systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s300j–19f/a/1/G","parentIdentifier":"/us/usc/t42/s300j–19f/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F1%2FG","sourceRelease":"119-100","text":"a Tribal consortium.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Operational sustainability","label":"2 Operational sustainability","identifier":"/us/usc/t42/s300j–19f/a/2","parentIdentifier":"/us/usc/t42/s300j–19f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F2","sourceRelease":"119-100","text":"The term “operational sustainability” means the ability to improve the operation of a small system through the identification and prevention of potable water loss due to leaks, breaks, and other metering or infrastructure failures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Program","label":"3 Program","identifier":"/us/usc/t42/s300j–19f/a/3","parentIdentifier":"/us/usc/t42/s300j–19f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F3","sourceRelease":"119-100","text":"The term “program” means the grant program established under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Small system","label":"4 Small system","identifier":"/us/usc/t42/s300j–19f/a/4","parentIdentifier":"/us/usc/t42/s300j–19f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–19f/a/4/A","parentIdentifier":"/us/usc/t42/s300j–19f/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F4%2FA","sourceRelease":"119-100","text":"serves fewer than 10,000 people; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–19f/a/4/B","parentIdentifier":"/us/usc/t42/s300j–19f/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F4%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300j–19f/a/4/B/i","parentIdentifier":"/us/usc/t42/s300j–19f/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F4%2FB%2Fi","sourceRelease":"119-100","text":"a unit of local government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300j–19f/a/4/B/ii","parentIdentifier":"/us/usc/t42/s300j–19f/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F4%2FB%2Fii","sourceRelease":"119-100","text":"a public corporation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s300j–19f/a/4/B/iii","parentIdentifier":"/us/usc/t42/s300j–19f/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F4%2FB%2Fiii","sourceRelease":"119-100","text":"a nonprofit corporation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s300j–19f/a/4/B/iv","parentIdentifier":"/us/usc/t42/s300j–19f/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F4%2FB%2Fiv","sourceRelease":"119-100","text":"a public trust;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s300j–19f/a/4/B/v","parentIdentifier":"/us/usc/t42/s300j–19f/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F4%2FB%2Fv","sourceRelease":"119-100","text":"a cooperative association; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s300j–19f/a/4/B/vi","parentIdentifier":"/us/usc/t42/s300j–19f/a/4/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fa%2F4%2FB%2Fvi","sourceRelease":"119-100","text":"an Indian Tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t42/s300j–19f/b","parentIdentifier":"/us/usc/t42/s300j–19f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fb","sourceRelease":"119-100","text":"Subject to the availability of appropriations, the Administrator shall establish a program to award grants to eligible entities for the purpose of improving the operational sustainability of 1 or more small systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Applications","label":"c Applications","identifier":"/us/usc/t42/s300j–19f/c","parentIdentifier":"/us/usc/t42/s300j–19f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300j–19f/c/1","parentIdentifier":"/us/usc/t42/s300j–19f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fc%2F1","sourceRelease":"119-100","text":"a proposal of the project to be carried out using grant funds under the program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300j–19f/c/2","parentIdentifier":"/us/usc/t42/s300j–19f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fc%2F2","sourceRelease":"119-100","text":"documentation provided by the eligible entity describing the deficiencies or suspected deficiencies in operational sustainability of 1 or more small systems that are to be addressed through the proposed project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300j–19f/c/3","parentIdentifier":"/us/usc/t42/s300j–19f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fc%2F3","sourceRelease":"119-100","text":"a description of how the proposed project will improve the operational sustainability of 1 or more small systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s300j–19f/c/4","parentIdentifier":"/us/usc/t42/s300j–19f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fc%2F4","sourceRelease":"119-100","text":"a description of how the improvements described in paragraph (3) will be maintained beyond the life of the proposed project, including a plan to maintain and update any asset data collected as a result of the proposed project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s300j–19f/c/5","parentIdentifier":"/us/usc/t42/s300j–19f/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fc%2F5","sourceRelease":"119-100","text":"any additional information the Administrator may require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Additional required information","label":"d Additional required information","identifier":"/us/usc/t42/s300j–19f/d","parentIdentifier":"/us/usc/t42/s300j–19f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300j–19f/d/1","parentIdentifier":"/us/usc/t42/s300j–19f/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fd%2F1","sourceRelease":"119-100","text":"if the grant recipient is located in a State that has established a State drinking water treatment revolving loan fund under , a copy of a written agreement between the grant recipient and the State in which the grant recipient agrees to provide a copy of any data collected under the proposed project to the State agency administering the State drinking water treatment revolving loan fund (or a designee); orsection 300j–12 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300j–19f/d/2","parentIdentifier":"/us/usc/t42/s300j–19f/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fd%2F2","sourceRelease":"119-100","text":"if the grant recipient is located in an area other than a State that has established a State drinking water treatment revolving loan fund under , a copy of a written agreement between the grant recipient and the Administrator in which the eligible entity agrees to provide a copy of any data collected under the proposed project to the Administrator (or a designee).section 300j–12 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Use of funds","label":"e Use of funds","identifier":"/us/usc/t42/s300j–19f/e","parentIdentifier":"/us/usc/t42/s300j–19f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300j–19f/e/1","parentIdentifier":"/us/usc/t42/s300j–19f/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fe%2F1","sourceRelease":"119-100","text":"the development of a detailed asset inventory, which may include drinking water sources, wells, storage, valves, treatment systems, distribution lines, hydrants, pumps, controls, and other essential infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300j–19f/e/2","parentIdentifier":"/us/usc/t42/s300j–19f/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–19f/e/2/A","parentIdentifier":"/us/usc/t42/s300j–19f/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fe%2F2%2FA","sourceRelease":"119-100","text":"geographic information system software; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–19f/e/2/B","parentIdentifier":"/us/usc/t42/s300j–19f/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fe%2F2%2FB","sourceRelease":"119-100","text":"global positioning system software;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s300j–19f/e/3","parentIdentifier":"/us/usc/t42/s300j–19f/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fe%2F3","sourceRelease":"119-100","text":"the deployment of leak detection technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s300j–19f/e/4","parentIdentifier":"/us/usc/t42/s300j–19f/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fe%2F4","sourceRelease":"119-100","text":"the deployment of metering technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s300j–19f/e/5","parentIdentifier":"/us/usc/t42/s300j–19f/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fe%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–19f/e/5/A","parentIdentifier":"/us/usc/t42/s300j–19f/e/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fe%2F5%2FA","sourceRelease":"119-100","text":"the eligible entity; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–19f/e/5/B","parentIdentifier":"/us/usc/t42/s300j–19f/e/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fe%2F5%2FB","sourceRelease":"119-100","text":"the small systems for which the grant was received;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s300j–19f/e/6","parentIdentifier":"/us/usc/t42/s300j–19f/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fe%2F6","sourceRelease":"119-100","text":"the deployment of strategies, techniques, and technologies to enhance the operational sustainability and effective use of water resources through water reuse; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s300j–19f/e/7","parentIdentifier":"/us/usc/t42/s300j–19f/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fe%2F7","sourceRelease":"119-100","text":"the development or deployment of other strategies, techniques, or technologies that the Administrator may determine to be appropriate under the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Cost share","label":"f Cost share","identifier":"/us/usc/t42/s300j–19f/f","parentIdentifier":"/us/usc/t42/s300j–19f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s300j–19f/f/1","parentIdentifier":"/us/usc/t42/s300j–19f/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Ff%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2), the Federal share of the cost of a project carried out using a grant under the program shall be 90 percent of the total cost of the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Waiver","label":"2 Waiver","identifier":"/us/usc/t42/s300j–19f/f/2","parentIdentifier":"/us/usc/t42/s300j–19f/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Ff%2F2","sourceRelease":"119-100","text":"The Administrator may increase the Federal share under paragraph (1) to 100 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Report","label":"g Report","identifier":"/us/usc/t42/s300j–19f/g","parentIdentifier":"/us/usc/t42/s300j–19f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fg","sourceRelease":"119-100","text":"Not later than 2 years after , the Administrator shall submit to Congress a report that describes the implementation of the program, which shall include a description of the use and deployment of amounts made available under the program.November 15, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Authorization of appropriations","label":"h Authorization of appropriations","identifier":"/us/usc/t42/s300j–19f/h","parentIdentifier":"/us/usc/t42/s300j–19f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319f%2Fh","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out this section $50,000,000 for each of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
