{"type":"section","nativeType":"section","number":"4584","heading":"Multilateral engagement and coordination","label":"4584 Multilateral engagement and coordination","identifier":"/us/usc/t50/s4584","parentIdentifier":"/us/usc/t50/ch55/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authorities","label":"a Authorities","identifier":"/us/usc/t50/s4584/a","parentIdentifier":"/us/usc/t50/s4584","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s4584/a/1","parentIdentifier":"/us/usc/t50/s4584/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fa%2F1","sourceRelease":"119-100","text":"conduct bilateral and multilateral engagement with the governments of countries that are allies and partners of the United States to promote and increase coordination of protocols and procedures to facilitate the effective implementation of and appropriate compliance with the prohibitions and notification requirement pursuant to this subchapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s4584/a/2","parentIdentifier":"/us/usc/t50/s4584/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fa%2F2","sourceRelease":"119-100","text":"upon adoption of protocols and procedures described in paragraph (1), work with those governments to establish mechanisms for sharing information, including trends, with respect to such activities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s4584/a/3","parentIdentifier":"/us/usc/t50/s4584/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fa%2F3","sourceRelease":"119-100","text":"work with and encourage the governments of countries that are allies and partners of the United States to develop similar mechanisms of their own, for the exclusive purpose of preventing the development of prohibited technologies by a country of concern.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Strategy for multilateral engagement and coordination","label":"b Strategy for multilateral engagement and coordination","identifier":"/us/usc/t50/s4584/b","parentIdentifier":"/us/usc/t50/s4584","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s4584/b/1","parentIdentifier":"/us/usc/t50/s4584/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fb%2F1","sourceRelease":"119-100","text":"develop a strategy to work with the governments of countries that are allies and partners of the United States to develop mechanisms that are comparable to the prohibitions and notification requirements pursuant to this subchapter, for the exclusive purpose of preventing the development of prohibited technologies by a country of concern; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s4584/b/2","parentIdentifier":"/us/usc/t50/s4584/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fb%2F2","sourceRelease":"119-100","text":"assess opportunities to provide technical assistance to those countries with respect to the development of those mechanisms.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Report","label":"c Report","identifier":"/us/usc/t50/s4584/c","parentIdentifier":"/us/usc/t50/s4584","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s4584/c/1","parentIdentifier":"/us/usc/t50/s4584/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fc%2F1","sourceRelease":"119-100","text":"a discussion of any strategy developed pursuant to subsection (b)(1), including key tools and objectives for the development of comparable mechanisms by the governments of allies and partners of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s4584/c/2","parentIdentifier":"/us/usc/t50/s4584/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fc%2F2","sourceRelease":"119-100","text":"a list of partner and allied countries to target for cooperation in developing their own prohibitions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s4584/c/3","parentIdentifier":"/us/usc/t50/s4584/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fc%2F3","sourceRelease":"119-100","text":"the status of the strategy’s implementation and outcomes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t50/s4584/c/4","parentIdentifier":"/us/usc/t50/s4584/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fc%2F4","sourceRelease":"119-100","text":"a description of impediments to the establishment of comparable mechanisms by governments of allies and partners of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Appropriate congressional committees defined","label":"d Appropriate congressional committees defined","identifier":"/us/usc/t50/s4584/d","parentIdentifier":"/us/usc/t50/s4584","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s4584/d/1","parentIdentifier":"/us/usc/t50/s4584/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fd%2F1","sourceRelease":"119-100","text":"the Committee on Foreign Relations and the Committee on Banking, Housing, and Urban Affairs of the Senate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s4584/d/2","parentIdentifier":"/us/usc/t50/s4584/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs4584%2Fd%2F2","sourceRelease":"119-100","text":"the Committee on Foreign Affairs and the Committee on Financial Services of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
