{"type":"section","nativeType":"section","number":"2704","heading":"Treatment of certain lapsing rights and restrictions","label":"2704 Treatment of certain lapsing rights and restrictions","identifier":"/us/usc/t26/s2704","parentIdentifier":"/us/usc/t26/stB/ch14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments1996—Subsec. (c)(3). substituted “section 2701(e)(3)” for “section 2701(e)(3)(A)”.Pub. L. 104–188","Statutory Notes and Related Subsidiaries","Effective Date of 1996 AmendmentAmendment by effective, except as otherwise expressly provided, as if included in the provision of the Revenue Reconciliation Act of 1990, , to which such amendment relates, see , set out as a note under .Pub. L. 104–188Pub. L. 101–508, title XIsection 1702(i) of Pub. L. 104–188section 38 of this title"],"amendments":["Amendments1996—Subsec. (c)(3). substituted “section 2701(e)(3)” for “section 2701(e)(3)(A)”.Pub. L. 104–188","Effective Date of 1996 AmendmentAmendment by effective, except as otherwise expressly provided, as if included in the provision of the Revenue Reconciliation Act of 1990, , to which such amendment relates, see , set out as a note under .Pub. L. 104–188Pub. L. 101–508, title XIsection 1702(i) of Pub. L. 104–188section 38 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Treatment of lapsed voting or liquidation rights","label":"a Treatment of lapsed voting or liquidation rights","identifier":"/us/usc/t26/s2704/a","parentIdentifier":"/us/usc/t26/s2704","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t26/s2704/a/1","parentIdentifier":"/us/usc/t26/s2704/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s2704/a/1/A","parentIdentifier":"/us/usc/t26/s2704/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fa%2F1%2FA","sourceRelease":"119-100","text":"there is a lapse of any voting or liquidation right in a corporation or partnership, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s2704/a/1/B","parentIdentifier":"/us/usc/t26/s2704/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fa%2F1%2FB","sourceRelease":"119-100","text":"the individual holding such right immediately before the lapse and members of such individual’s family hold, both before and after the lapse, control of the entity,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Amount of transfer","label":"2 Amount of transfer","identifier":"/us/usc/t26/s2704/a/2","parentIdentifier":"/us/usc/t26/s2704/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s2704/a/2/A","parentIdentifier":"/us/usc/t26/s2704/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the value of all interests in the entity held by the individual described in paragraph (1) immediately before the lapse (determined as if the voting and liquidation rights were nonlapsing), over","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s2704/a/2/B","parentIdentifier":"/us/usc/t26/s2704/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the value of such interests immediately after the lapse.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Similar rights","label":"3 Similar rights","identifier":"/us/usc/t26/s2704/a/3","parentIdentifier":"/us/usc/t26/s2704/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fa%2F3","sourceRelease":"119-100","text":"The Secretary may by regulations apply this subsection to rights similar to voting and liquidation rights.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Certain restrictions on liquidation disregarded","label":"b Certain restrictions on liquidation disregarded","identifier":"/us/usc/t26/s2704/b","parentIdentifier":"/us/usc/t26/s2704","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t26/s2704/b/1","parentIdentifier":"/us/usc/t26/s2704/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s2704/b/1/A","parentIdentifier":"/us/usc/t26/s2704/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fb%2F1%2FA","sourceRelease":"119-100","text":"there is a transfer of an interest in a corporation or partnership to (or for the benefit of) a member of the transferor’s family, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s2704/b/1/B","parentIdentifier":"/us/usc/t26/s2704/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the transferor and members of the transferor’s family hold, immediately before the transfer, control of the entity,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Applicable restriction","label":"2 Applicable restriction","identifier":"/us/usc/t26/s2704/b/2","parentIdentifier":"/us/usc/t26/s2704/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s2704/b/2/A","parentIdentifier":"/us/usc/t26/s2704/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fb%2F2%2FA","sourceRelease":"119-100","text":"which effectively limits the ability of the corporation or partnership to liquidate, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s2704/b/2/B","parentIdentifier":"/us/usc/t26/s2704/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s2704/b/2/B/i","parentIdentifier":"/us/usc/t26/s2704/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"The restriction lapses, in whole or in part, after the transfer referred to in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s2704/b/2/B/ii","parentIdentifier":"/us/usc/t26/s2704/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"The transferor or any member of the transferor’s family, either alone or collectively, has the right after such transfer to remove, in whole or in part, the restriction.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Exceptions","label":"3 Exceptions","identifier":"/us/usc/t26/s2704/b/3","parentIdentifier":"/us/usc/t26/s2704/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s2704/b/3/A","parentIdentifier":"/us/usc/t26/s2704/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fb%2F3%2FA","sourceRelease":"119-100","text":"any commercially reasonable restriction which arises as part of any financing by the corporation or partnership with a person who is not related to the transferor or transferee, or a member of the family of either, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s2704/b/3/B","parentIdentifier":"/us/usc/t26/s2704/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fb%2F3%2FB","sourceRelease":"119-100","text":"any restriction imposed, or required to be imposed, by any Federal or State law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Other restrictions","label":"4 Other restrictions","identifier":"/us/usc/t26/s2704/b/4","parentIdentifier":"/us/usc/t26/s2704/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fb%2F4","sourceRelease":"119-100","text":"The Secretary may by regulations provide that other restrictions shall be disregarded in determining the value of the transfer of any interest in a corporation or partnership to a member of the transferor’s family if such restriction has the effect of reducing the value of the transferred interest for purposes of this subtitle but does not ultimately reduce the value of such interest to the transferee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Definitions and special rules","label":"c Definitions and special rules","identifier":"/us/usc/t26/s2704/c","parentIdentifier":"/us/usc/t26/s2704","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Control","label":"1 Control","identifier":"/us/usc/t26/s2704/c/1","parentIdentifier":"/us/usc/t26/s2704/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fc%2F1","sourceRelease":"119-100","text":"The term “control” has the meaning given such term by section 2701(b)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Member of the family","label":"2 Member of the family","identifier":"/us/usc/t26/s2704/c/2","parentIdentifier":"/us/usc/t26/s2704/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s2704/c/2/A","parentIdentifier":"/us/usc/t26/s2704/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fc%2F2%2FA","sourceRelease":"119-100","text":"such individual’s spouse,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s2704/c/2/B","parentIdentifier":"/us/usc/t26/s2704/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fc%2F2%2FB","sourceRelease":"119-100","text":"any ancestor or lineal descendant of such individual or such individual’s spouse,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t26/s2704/c/2/C","parentIdentifier":"/us/usc/t26/s2704/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fc%2F2%2FC","sourceRelease":"119-100","text":"any brother or sister of the individual, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t26/s2704/c/2/D","parentIdentifier":"/us/usc/t26/s2704/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fc%2F2%2FD","sourceRelease":"119-100","text":"any spouse of any individual described in subparagraph (B) or (C).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Attribution","label":"3 Attribution","identifier":"/us/usc/t26/s2704/c/3","parentIdentifier":"/us/usc/t26/s2704/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs2704%2Fc%2F3","sourceRelease":"119-100","text":"The rule of section 2701(e)(3) shall apply for purposes of determining the interests held by any individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
