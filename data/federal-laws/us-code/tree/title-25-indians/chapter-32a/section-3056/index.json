ildren":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3056/a/2/A","parentIdentifier":"/us/usc/t25/s3056/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3056%2Fa%2F2%2FA","sourceRelease":"119-100","text":"a site or resource used for traditional and cultural purposes by an Indian tribe; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3056/a/2/B","parentIdentifier":"/us/usc/t25/s3056/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3056%2Fa%2F2%2FB","sourceRelease":"119-100","text":"any cultural items not covered under .section 3053 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limited release of information","label":"b Limited release of information","identifier":"/us/usc/t25/s3056/b","parentIdentifier":"/us/usc/t25/s3056","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3056%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Reburial","label":"1 Reburial","identifier":"/us/usc/t25/s3056/b/1","parentIdentifier":"/us/usc/t25/s3056/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3056%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3056/b/1/A","parentIdentifier":"/us/usc/t25/s3056/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3056%2Fb%2F1%2FA","sourceRelease":"119-100","text":"consults with an affected Indian tribe or lineal descendent;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3056/b/1/B","parentIdentifier":"/us/usc/t25/s3056/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3056%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t25/s3056/b/1/B/i","parentIdentifier":"/us/usc/t25/s3056/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3056%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"would advance the purposes of this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t25/s3056/b/1/B/ii","parentIdentifier":"/us/usc/t25/s3056/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3056%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"is necessary to protect the human remains or cultural items from harm, theft, or destruction; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s3056/b/1/C","parentIdentifier":"/us/usc/t25/s3056/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3056%2Fb%2F1%2FC","sourceRelease":"119-100","text":"attempts to mitigate any adverse impacts identified by an Indian tribe or lineal descendant that reasonably could be expected to result from disclosure of the information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Other information","label":"2 Other information","identifier":"/us/usc/t25/s3056/b/2","parentIdentifier":"/us/usc/t25/s3056/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3056%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3056/b/2/A","parentIdentifier":"/us/usc/t25/s3056/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3056%2Fb%2F2%2FA","sourceRelease":"119-100","text":"would advance the purposes of this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3056/b/2/B","parentIdentifier":"/us/usc/t25/s3056/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3056%2Fb%2F2%2FB","sourceRelease":"119-100","text":"would not create an unreasonable risk of harm, theft, or destruction of the resource, site, or object, including individual organic or inorganic specimens; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s3056/b/2/C","parentIdentifier":"/us/usc/t25/s3056/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3056%2Fb%2F2%2FC","sourceRelease":"119-100","text":"would be consistent with other applicable laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
