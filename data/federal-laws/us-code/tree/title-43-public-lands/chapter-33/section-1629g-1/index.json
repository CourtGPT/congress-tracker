of-way of the TransAlaska Pipeline; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t43/s1629g–1/a/1/B/i/II","parentIdentifier":"/us/usc/t43/s1629g–1/a/1/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629g%E2%80%931%2Fa%2F1%2FB%2Fi%2FII","sourceRelease":"119-100","text":"an inner or outer corridor of such a right-of-way;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s1629g–1/a/1/B/ii","parentIdentifier":"/us/usc/t43/s1629g–1/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629g%E2%80%931%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"withdrawn or acquired for purposes of the Armed Forces;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t43/s1629g–1/a/1/B/iii","parentIdentifier":"/us/usc/t43/s1629g–1/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629g%E2%80%931%2Fa%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"under review for a pending right-of-way for a natural gas corridor;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t43/s1629g–1/a/1/B/iv","parentIdentifier":"/us/usc/t43/s1629g–1/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1629g%E2%80%931%2Fa%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"within the Arctic National Wildlife Refuge;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t43/s1629g–1/a/1/B/v","parentIdentifi