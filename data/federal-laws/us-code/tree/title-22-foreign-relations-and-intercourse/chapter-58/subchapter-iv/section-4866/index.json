{"type":"section","nativeType":"section","number":"4866","heading":"Security training for personnel assigned to a high risk, high threat post","label":"4866 Security training for personnel assigned to a high risk, high threat post","identifier":"/us/usc/t22/s4866","parentIdentifier":"/us/usc/t22/ch58/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s4866/a","parentIdentifier":"/us/usc/t22/s4866","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fa","sourceRelease":"119-100","text":"Individuals assigned permanently to or who are in long-term temporary duty status as designated by the Secretary of State at a high risk, high threat post shall receive security training described in subsection (b) on a mandatory basis in order to prepare such individuals for living and working at such posts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Security training described","label":"b Security training described","identifier":"/us/usc/t22/s4866/b","parentIdentifier":"/us/usc/t22/s4866","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4866/b/1","parentIdentifier":"/us/usc/t22/s4866/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fb%2F1","sourceRelease":"119-100","text":"is training to improve basic knowledge and skills; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4866/b/2","parentIdentifier":"/us/usc/t22/s4866/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s4866/b/2/A","parentIdentifier":"/us/usc/t22/s4866/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fb%2F2%2FA","sourceRelease":"119-100","text":"an ability to recognize, avoid, and respond to potential terrorist situations, including a complex attack;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s4866/b/2/B","parentIdentifier":"/us/usc/t22/s4866/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fb%2F2%2FB","sourceRelease":"119-100","text":"conducting surveillance detection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s4866/b/2/C","parentIdentifier":"/us/usc/t22/s4866/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fb%2F2%2FC","sourceRelease":"119-100","text":"providing emergency medical care;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s4866/b/2/D","parentIdentifier":"/us/usc/t22/s4866/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fb%2F2%2FD","sourceRelease":"119-100","text":"ability to detect the presence of improvised explosive devices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t22/s4866/b/2/E","parentIdentifier":"/us/usc/t22/s4866/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fb%2F2%2FE","sourceRelease":"119-100","text":"minimal firearms familiarization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t22/s4866/b/2/F","parentIdentifier":"/us/usc/t22/s4866/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fb%2F2%2FF","sourceRelease":"119-100","text":"defensive driving maneuvers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Effective date","label":"c Effective date","identifier":"/us/usc/t22/s4866/c","parentIdentifier":"/us/usc/t22/s4866","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fc","sourceRelease":"119-100","text":"The requirements of this section shall take effect upon .December 16, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definitions","label":"d Definitions","identifier":"/us/usc/t22/s4866/d","parentIdentifier":"/us/usc/t22/s4866","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Complex attack","label":"1 Complex attack","identifier":"/us/usc/t22/s4866/d/1","parentIdentifier":"/us/usc/t22/s4866/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fd%2F1","sourceRelease":"119-100","text":"The term “complex attack” has the meaning given such term by the North Atlantic Treaty Organization, as follows: “An attack conducted by multiple hostile elements which employ at least two distinct classes of weapon systems (i.e., indirect fire and direct fire, improvised explosive devices, and surface to air fire).”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"High risk, high threat post","label":"2 High risk, high threat post","identifier":"/us/usc/t22/s4866/d/2","parentIdentifier":"/us/usc/t22/s4866/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4866%2Fd%2F2","sourceRelease":"119-100","text":"The term “high risk, high threat post” has the meaning given such term in .section 4803 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
