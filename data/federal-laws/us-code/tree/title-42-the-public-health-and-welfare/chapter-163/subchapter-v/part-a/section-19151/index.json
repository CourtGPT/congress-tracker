{"type":"section","nativeType":"section","number":"19151","heading":"Federal research agency policies for caregivers","label":"19151 Federal research agency policies for caregivers","identifier":"/us/usc/t42/s19151","parentIdentifier":"/us/usc/t42/ch163/schV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"OSTP guidance","label":"a OSTP guidance","identifier":"/us/usc/t42/s19151/a","parentIdentifier":"/us/usc/t42/s19151","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19151/a/1","parentIdentifier":"/us/usc/t42/s19151/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19151/a/1/A","parentIdentifier":"/us/usc/t42/s19151/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fa%2F1%2FA","sourceRelease":"119-100","text":"research awards granted by such agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19151/a/1/B","parentIdentifier":"/us/usc/t42/s19151/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fa%2F1%2FB","sourceRelease":"119-100","text":"principal investigators of such research and their trainees, including postdoctoral researchers and graduate students, who have caregiving responsibilities, including care for a newborn or newly adopted child and care for an immediate family member who has a disability or a serious health condition; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19151/a/2","parentIdentifier":"/us/usc/t42/s19151/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s19151/a/2/A","parentIdentifier":"/us/usc/t42/s19151/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fa%2F2%2FA","sourceRelease":"119-100","text":"flexibility in timing for the initiation of approved research awards granted by such agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s19151/a/2/B","parentIdentifier":"/us/usc/t42/s19151/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fa%2F2%2FB","sourceRelease":"119-100","text":"no-cost extensions of such research awards;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s19151/a/2/C","parentIdentifier":"/us/usc/t42/s19151/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fa%2F2%2FC","sourceRelease":"119-100","text":"award supplements, as appropriate, to research awards to sustain research activities conducted under such awards; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s19151/a/2/D","parentIdentifier":"/us/usc/t42/s19151/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fa%2F2%2FD","sourceRelease":"119-100","text":"any other appropriate accommodations at the discretion of the director of each such agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Uniformity of guidance","label":"b Uniformity of guidance","identifier":"/us/usc/t42/s19151/b","parentIdentifier":"/us/usc/t42/s19151","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fb","sourceRelease":"119-100","text":"In providing guidance under subsection (a), the Director shall encourage uniformity, to the extent practicable, and consistency in the policies established pursuant to such guidance across all Federal research agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Establishment of policies","label":"c Establishment of policies","identifier":"/us/usc/t42/s19151/c","parentIdentifier":"/us/usc/t42/s19151","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19151/c/1","parentIdentifier":"/us/usc/t42/s19151/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fc%2F1","sourceRelease":"119-100","text":"maintain or develop and implement policies for individuals described in paragraph (1)(B) of such subsection; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19151/c/2","parentIdentifier":"/us/usc/t42/s19151/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fc%2F2","sourceRelease":"119-100","text":"broadly disseminate in easily accessible formats such policies to current and potential award recipients.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Data on usage","label":"d Data on usage","identifier":"/us/usc/t42/s19151/d","parentIdentifier":"/us/usc/t42/s19151","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s19151/d/1","parentIdentifier":"/us/usc/t42/s19151/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fd%2F1","sourceRelease":"119-100","text":"collecting data, including demographic data that can be disaggregated by sex, geographic location, and socioeconomic indicators, which may include employment status, occupation, educational attainment, parental education, and income, on the usage of the policies under subsection (c), at both institutions of higher education and Federal laboratories; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s19151/d/2","parentIdentifier":"/us/usc/t42/s19151/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs19151%2Fd%2F2","sourceRelease":"119-100","text":"reporting such data on an annual basis to the Director in such form as required by the Director.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
