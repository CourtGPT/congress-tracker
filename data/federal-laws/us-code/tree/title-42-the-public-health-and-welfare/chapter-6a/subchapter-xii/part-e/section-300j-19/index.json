{"type":"section","nativeType":"section","number":"300j–19","heading":"Algal toxin risk assessment and management","label":"300j–19 Algal toxin risk assessment and management","identifier":"/us/usc/t42/s300j–19","parentIdentifier":"/us/usc/t42/ch6A/schXII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Strategic plan","label":"a Strategic plan","identifier":"/us/usc/t42/s300j–19/a","parentIdentifier":"/us/usc/t42/s300j–19","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Development","label":"1 Development","identifier":"/us/usc/t42/s300j–19/a/1","parentIdentifier":"/us/usc/t42/s300j–19/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–19/a/1/A","parentIdentifier":"/us/usc/t42/s300j–19/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa%2F1%2FA","sourceRelease":"119-100","text":"evaluate the risk to human health from drinking water provided by public water systems contaminated with algal toxins;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–19/a/1/B","parentIdentifier":"/us/usc/t42/s300j–19/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa%2F1%2FB","sourceRelease":"119-100","text":"establish, publish, and update a comprehensive list of algal toxins which the Administrator determines may have an adverse effect on human health when present in drinking water provided by public water systems, taking into account likely exposure levels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s300j–19/a/1/C","parentIdentifier":"/us/usc/t42/s300j–19/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300j–19/a/1/C/i","parentIdentifier":"/us/usc/t42/s300j–19/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa%2F1%2FC%2Fi","sourceRelease":"119-100","text":"the known adverse human health effects of algal toxins included on the list published under subparagraph (B) when present in drinking water provided by public water systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300j–19/a/1/C/ii","parentIdentifier":"/us/usc/t42/s300j–19/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa%2F1%2FC%2Fii","sourceRelease":"119-100","text":"factors that cause toxin-producing cyanobacteria and algae to proliferate and express toxins;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s300j–19/a/1/D","parentIdentifier":"/us/usc/t42/s300j–19/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa%2F1%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s300j–19/a/1/D/i","parentIdentifier":"/us/usc/t42/s300j–19/a/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa%2F1%2FD%2Fi","sourceRelease":"119-100","text":"publish health advisories pursuant to for such algal toxins in drinking water provided by public water systems;section 300g–1(b)(1)(F) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s300j–19/a/1/D/ii","parentIdentifier":"/us/usc/t42/s300j–19/a/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa%2F1%2FD%2Fii","sourceRelease":"119-100","text":"establish guidance regarding feasible analytical methods to quantify the presence of algal toxins; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s300j–19/a/1/D/iii","parentIdentifier":"/us/usc/t42/s300j–19/a/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa%2F1%2FD%2Fiii","sourceRelease":"119-100","text":"establish guidance regarding the frequency of monitoring necessary to determine if such algal toxins are present in drinking water provided by public water systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s300j–19/a/1/E","parentIdentifier":"/us/usc/t42/s300j–19/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa%2F1%2FE","sourceRelease":"119-100","text":"recommend feasible treatment options, including procedures, equipment, and source water protection practices, to mitigate any adverse public health effects of algal toxins included on the list published under subparagraph (B); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s300j–19/a/1/F","parentIdentifier":"/us/usc/t42/s300j–19/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa%2F1%2FF","sourceRelease":"119-100","text":"enter into cooperative agreements with, and provide technical assistance to, affected States and public water systems, as identified by the Administrator, for the purpose of managing risks associated with algal toxins included on the list published under subparagraph (B).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Updates","label":"2 Updates","identifier":"/us/usc/t42/s300j–19/a/2","parentIdentifier":"/us/usc/t42/s300j–19/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fa%2F2","sourceRelease":"119-100","text":"The Administrator shall, as appropriate, update and submit to Congress the strategic plan developed under paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Information coordination","label":"b Information coordination","identifier":"/us/usc/t42/s300j–19/b","parentIdentifier":"/us/usc/t42/s300j–19","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s300j–19/b/1","parentIdentifier":"/us/usc/t42/s300j–19/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–19/b/1/A","parentIdentifier":"/us/usc/t42/s300j–19/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the human health effects of algal toxins included on the list published under subsection (a)(1)(B); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s300j–19/b/1/B","parentIdentifier":"/us/usc/t42/s300j–19/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fb%2F1%2FB","sourceRelease":"119-100","text":"methods and means of testing and monitoring for the presence of harmful algal toxins in source water of, or drinking water provided by, public water systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s300j–19/b/2","parentIdentifier":"/us/usc/t42/s300j–19/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s300j–19/b/2/A","parentIdentifier":"/us/usc/t42/s300j–19/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300j%E2%80%9319%2Fb%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate"