{"type":"section","nativeType":"section","number":"4569","heading":"Capital Magnet Fund","label":"4569 Capital Magnet Fund","identifier":"/us/usc/t12/s4569","parentIdentifier":"/us/usc/t12/ch46/schI/ptB/spt2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t12/s4569/a","parentIdentifier":"/us/usc/t12/s4569","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fa","sourceRelease":"119-100","text":"There is established in the Treasury of the United States a trust fund to be known as the Capital Magnet Fund, which shall be a special account within the Community Development Financial Institutions Fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Deposits to Trust Fund","label":"b Deposits to Trust Fund","identifier":"/us/usc/t12/s4569/b","parentIdentifier":"/us/usc/t12/s4569","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4569/b/1","parentIdentifier":"/us/usc/t12/s4569/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fb%2F1","sourceRelease":"119-100","text":"any amounts transferred to the Fund pursuant to ; andsection 4567 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4569/b/2","parentIdentifier":"/us/usc/t12/s4569/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fb%2F2","sourceRelease":"119-100","text":"any amounts as are or may be appropriated, transferred, or credited to such Fund under any other provisions of law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Expenditures from Trust Fund","label":"c Expenditures from Trust Fund","identifier":"/us/usc/t12/s4569/c","parentIdentifier":"/us/usc/t12/s4569","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4569/c/1","parentIdentifier":"/us/usc/t12/s4569/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fc%2F1","sourceRelease":"119-100","text":"the development, preservation, rehabilitation, or purchase of affordable housing for primarily extremely low-, very low-, and low-income families; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4569/c/2","parentIdentifier":"/us/usc/t12/s4569/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fc%2F2","sourceRelease":"119-100","text":"economic development activities or community service facilities, such as day care centers, workforce development centers, and health care clinics, which in conjunction with affordable housing activities implement a concerted strategy to stabilize or revitalize a low-income area or underserved rural area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Federal assistance","label":"d Federal assistance","identifier":"/us/usc/t12/s4569/d","parentIdentifier":"/us/usc/t12/s4569","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fd","sourceRelease":"119-100","text":"For purposes of the application of Federal civil rights laws, all assistance provided using amounts in the Capital Magnet Fund shall be considered Federal financial assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Eligible grantees","label":"e Eligible grantees","identifier":"/us/usc/t12/s4569/e","parentIdentifier":"/us/usc/t12/s4569","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4569/e/1","parentIdentifier":"/us/usc/t12/s4569/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fe%2F1","sourceRelease":"119-100","text":"a Treasury certified community development financial institution; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4569/e/2","parentIdentifier":"/us/usc/t12/s4569/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fe%2F2","sourceRelease":"119-100","text":"a nonprofit organization having as 1 of its principal purposes the development or management of affordable housing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Eligible uses","label":"f Eligible uses","identifier":"/us/usc/t12/s4569/f","parentIdentifier":"/us/usc/t12/s4569","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s4569/f/1","parentIdentifier":"/us/usc/t12/s4569/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Ff%2F1","sourceRelease":"119-100","text":"To provide loan loss reserves.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s4569/f/2","parentIdentifier":"/us/usc/t12/s4569/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Ff%2F2","sourceRelease":"119-100","text":"To capitalize a revolving loan fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t12/s4569/f/3","parentIdentifier":"/us/usc/t12/s4569/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Ff%2F3","sourceRelease":"119-100","text":"To capitalize an affordable housing fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t12/s4569/f/4","parentIdentifier":"/us/usc/t12/s4569/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Ff%2F4","sourceRelease":"119-100","text":"To capitalize a fund to support activities described in subsection (c)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t12/s4569/f/5","parentIdentifier":"/us/usc/t12/s4569/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Ff%2F5","sourceRelease":"119-100","text":"For risk-sharing loans.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Applications","label":"g Applications","identifier":"/us/usc/t12/s4569/g","parentIdentifier":"/us/usc/t12/s4569","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t12/s4569/g/1","parentIdentifier":"/us/usc/t12/s4569/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fg%2F1","sourceRelease":"119-100","text":"The Secretary of the Treasury shall provide, in a competitive application process established by regulation, for eligible grantees under subsection (e) to submit applications for Capital Magnet Fund grants to the Secretary at such time and in such manner as the Secretary shall determine.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Content of application","label":"2 Content of application","identifier":"/us/usc/t12/s4569/g/2","parentIdentifier":"/us/usc/t12/s4569/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fg%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s4569/g/2/A","parentIdentifier":"/us/usc/t12/s4569/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fg%2F2%2FA","sourceRelease":"119-100","text":"the types of affordable housing, economic, and community revitalization projects that support or sustain residents of an affordable housing project funded by a grant under this section for which such grant amounts would be used, including the proposed use of eligible grants as authorized under this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s4569/g/2/B","parentIdentifier":"/us/usc/t12/s4569/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fg%2F2%2FB","sourceRelease":"119-100","text":"the types, sources, and amounts of other funding for such projects; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s4569/g/2/C","parentIdentifier":"/us/usc/t12/s4569/g/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fg%2F2%2FC","sourceRelease":"119-100","text":"the expected time frame of any grant used for such project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Grant limitation","label":"h Grant limitation","identifier":"/us/usc/t12/s4569/h","parentIdentifier":"/us/usc/t12/s4569","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t12/s4569/h/1","parentIdentifier":"/us/usc/t12/s4569/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F1","sourceRelease":"119-100","text":"Any 1 eligible grantee and its subsidiaries and affiliates may not be awarded more than 15 percent of the aggregate funds available for grants during any year from the Capital Magnet Fund.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Geographic diversity","label":"2 Geographic diversity","identifier":"/us/usc/t12/s4569/h/2","parentIdentifier":"/us/usc/t12/s4569/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Goal","label":"A Goal","identifier":"/us/usc/t12/s4569/h/2/A","parentIdentifier":"/us/usc/t12/s4569/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F2%2FA","sourceRelease":"119-100","text":"The Secretary of the Treasury shall seek to fund activities in geographically diverse areas of economic distress, including metropolitan and underserved rural areas in every State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Diversity defined","label":"B Diversity defined","identifier":"/us/usc/t12/s4569/h/2/B","parentIdentifier":"/us/usc/t12/s4569/h/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t12/s4569/h/2/B/i","parentIdentifier":"/us/usc/t12/s4569/h/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the percentage of low-income families or the extent of poverty;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t12/s4569/h/2/B/ii","parentIdentifier":"/us/usc/t12/s4569/h/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the rate of unemployment or underemployment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t12/s4569/h/2/B/iii","parentIdentifier":"/us/usc/t12/s4569/h/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"extent of blight and disinvestment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t12/s4569/h/2/B/iv","parentIdentifier":"/us/usc/t12/s4569/h/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"projects that target extremely low-, very low-, and low-income families in or outside a designated economic distress area; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t12/s4569/h/2/B/v","parentIdentifier":"/us/usc/t12/s4569/h/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F2%2FB%2Fv","sourceRelease":"119-100","text":"any other criteria designated by the Secretary of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Leverage of funds","label":"3 Leverage of funds","identifier":"/us/usc/t12/s4569/h/3","parentIdentifier":"/us/usc/t12/s4569/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F3","sourceRelease":"119-100","text":"Each grant from the Capital Magnet Fund awarded under this section shall be reasonably expected to result in eligible housing, or economic and community development projects that support or sustain an affordable housing project funded by a grant under this section whose aggregate costs total at least 10 times the grant amount.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Commitment for use deadline","label":"4 Commitment for use deadline","identifier":"/us/usc/t12/s4569/h/4","parentIdentifier":"/us/usc/t12/s4569/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F4","sourceRelease":"119-100","text":"Amounts made available for grants under this section shall be committed for use within 2 years of the date of such allocation. The Secretary of the Treasury shall recapture into the Capital Magnet Fund any amounts not so used or committed for use and allocate such amounts in the first year after such recapture.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Prohibited uses","label":"5 Prohibited uses","identifier":"/us/usc/t12/s4569/h/5","parentIdentifier":"/us/usc/t12/s4569/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s4569/h/5/A","parentIdentifier":"/us/usc/t12/s4569/h/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F5%2FA","sourceRelease":"119-100","text":"political activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s4569/h/5/B","parentIdentifier":"/us/usc/t12/s4569/h/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F5%2FB","sourceRelease":"119-100","text":"advocacy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s4569/h/5/C","parentIdentifier":"/us/usc/t12/s4569/h/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F5%2FC","sourceRelease":"119-100","text":"lobbying, whether directly or through other parties;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t12/s4569/h/5/D","parentIdentifier":"/us/usc/t12/s4569/h/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F5%2FD","sourceRelease":"119-100","text":"counseling services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t12/s4569/h/5/E","parentIdentifier":"/us/usc/t12/s4569/h/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F5%2FE","sourceRelease":"119-100","text":"travel expenses; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t12/s4569/h/5/F","parentIdentifier":"/us/usc/t12/s4569/h/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F5%2FF","sourceRelease":"119-100","text":"preparing or providing advice on tax returns;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Additional lobbying restrictions","label":"6 Additional lobbying restrictions","identifier":"/us/usc/t12/s4569/h/6","parentIdentifier":"/us/usc/t12/s4569/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F6","sourceRelease":"119-100","text":"No assistance or amounts made available under this section may be expended by an eligible grantee to pay any person to influence or attempt to influence any agency, elected official, officer or employee of a State or local government in connection with the making, award, extension, continuation, renewal, amendment, or modification of any State or local government contract, grant, loan, or cooperative agreement as such terms are defined in .section 1352 of title 31","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Prohibition of consideration of use for meeting housing goals or duty to serve","label":"7 Prohibition of consideration of use for meeting housing goals or duty to serve","identifier":"/us/usc/t12/s4569/h/7","parentIdentifier":"/us/usc/t12/s4569/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F7","sourceRelease":"119-100","text":"In determining the compliance of the enterprises with the housing goals under this section and the duty to serve underserved markets under , the Director of the Federal Housing Finance Agency may not consider any Capital Magnet Fund amounts used under this section for eligible activities under subsection (f). The Director of the Federal Housing Finance Agency shall give credit toward the achievement of such housing goals and such duty to serve underserved markets to purchases by the enterprises of mortgages for housing that receives funding from Capital Magnet Fund grant amounts, but only to the extent that such purchases by the enterprises are funded other than with such grant amounts.section 4565 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Accountability of recipients and grantees","label":"8 Accountability of recipients and grantees","identifier":"/us/usc/t12/s4569/h/8","parentIdentifier":"/us/usc/t12/s4569/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Tracking of funds","label":"A Tracking of funds","identifier":"/us/usc/t12/s4569/h/8/A","parentIdentifier":"/us/usc/t12/s4569/h/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F8%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t12/s4569/h/8/A/i","parentIdentifier":"/us/usc/t12/s4569/h/8/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F8%2FA%2Fi","sourceRelease":"119-100","text":"require each grantee to develop and maintain a system to ensure that each recipient of assistance from the Capital Magnet Fund uses such amounts in accordance with this section, the regulations issued under this section, and any requirements or conditions under which such amounts were provided; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t12/s4569/h/8/A/ii","parentIdentifier":"/us/usc/t12/s4569/h/8/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F8%2FA%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t12/s4569/h/8/A/ii/I","parentIdentifier":"/us/usc/t12/s4569/h/8/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F8%2FA%2Fii%2FI","sourceRelease":"119-100","text":"appropriate periodic financial and project reporting, record retention, and audit requirements for the duration of the grant to the recipient to ensure compliance with the limitations and requirements of this section and the regulations under this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t12/s4569/h/8/A/ii/II","parentIdentifier":"/us/usc/t12/s4569/h/8/A/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F8%2FA%2Fii%2FII","sourceRelease":"119-100","text":"any other requirements that the Secretary determines are necessary to ensure appropriate grant administration and compliance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Misuse of funds","label":"B Misuse of funds","identifier":"/us/usc/t12/s4569/h/8/B","parentIdentifier":"/us/usc/t12/s4569/h/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F8%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t12/s4569/h/8/B/i","parentIdentifier":"/us/usc/t12/s4569/h/8/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F8%2FB%2Fi","sourceRelease":"119-100","text":"reduce the amount of assistance under this section to the grantee by an amount equal to the amount of Capital Magnet Fund grant amounts which were not used in accordance with this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t12/s4569/h/8/B/ii","parentIdentifier":"/us/usc/t12/s4569/h/8/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F8%2FB%2Fii","sourceRelease":"119-100","text":"require the grantee to repay the Secretary any amount of the Capital Magnet Fund grant amounts which were not used in accordance with this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t12/s4569/h/8/B/iii","parentIdentifier":"/us/usc/t12/s4569/h/8/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F8%2FB%2Fiii","sourceRelease":"119-100","text":"limit the availability of assistance under this section to the grantee to activities or recipients not affected by such failure to comply; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t12/s4569/h/8/B/iv","parentIdentifier":"/us/usc/t12/s4569/h/8/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fh%2F8%2FB%2Fiv","sourceRelease":"119-100","text":"terminate any assistance under this section to the grantee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Periodic reports","label":"i Periodic reports","identifier":"/us/usc/t12/s4569/i","parentIdentifier":"/us/usc/t12/s4569","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t12/s4569/i/1","parentIdentifier":"/us/usc/t12/s4569/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fi%2F1","sourceRelease":"119-100","text":"The Secretary of the Treasury shall submit a report, on a periodic basis, to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives describing the activities to be funded under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Reports available to public","label":"2 Reports available to public","identifier":"/us/usc/t12/s4569/i/2","parentIdentifier":"/us/usc/t12/s4569/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fi%2F2","sourceRelease":"119-100","text":"The Secretary of the Treasury shall make the reports required under paragraph (1) publicly available.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"j","heading":"Regulations","label":"j Regulations","identifier":"/us/usc/t12/s4569/j","parentIdentifier":"/us/usc/t12/s4569","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fj","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t12/s4569/j/1","parentIdentifier":"/us/usc/t12/s4569/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fj%2F1","sourceRelease":"119-100","text":"The Secretary of the Treasury shall issue regulations to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Required contents","label":"2 Required contents","identifier":"/us/usc/t12/s4569/j/2","parentIdentifier":"/us/usc/t12/s4569/j","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fj%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t12/s4569/j/2/A","parentIdentifier":"/us/usc/t12/s4569/j/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fj%2F2%2FA","sourceRelease":"119-100","text":"authority for the Secretary to audit, provide for an audit, or otherwise verify an enterprise’s activities, to ensure compliance with this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t12/s4569/j/2/B","parentIdentifier":"/us/usc/t12/s4569/j/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fj%2F2%2FB","sourceRelease":"119-100","text":"a requirement that the Secretary ensure that the allocation of each enterprise is audited not less than annually to ensure compliance with this section;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t12/s4569/j/2/C","parentIdentifier":"/us/usc/t12/s4569/j/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fj%2F2%2FC","sourceRelease":"119-100","text":"a requirement that, for the purposes of subparagraphs (A) and (B), any financial statement submitted by a grantee to the Secretary shall be reviewed by an independent certified public accountant in accordance with Statements on Standards for Accounting and Review Services, issued by the American Institute of Certified Public Accountants; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t12/s4569/j/2/D","parentIdentifier":"/us/usc/t12/s4569/j/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fj%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t12/s4569/j/2/D/i","parentIdentifier":"/us/usc/t12/s4569/j/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fj%2F2%2FD%2Fi","sourceRelease":"119-100","text":"funds be fairly distributed to urban, suburban, and rural areas; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t12/s4569/j/2/D/ii","parentIdentifier":"/us/usc/t12/s4569/j/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fj%2F2%2FD%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t12/s4569/j/2/D/ii/I","parentIdentifier":"/us/usc/t12/s4569/j/2/D/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fj%2F2%2FD%2Fii%2FI","sourceRelease":"119-100","text":"the ability to use such funds to generate additional investments;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t12/s4569/j/2/D/ii/II","parentIdentifier":"/us/usc/t12/s4569/j/2/D/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fj%2F2%2FD%2Fii%2FII","sourceRelease":"119-100","text":"affordable housing need (taking into account the distinct needs of different regions of the country); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t12/s4569/j/2/D/ii/III","parentIdentifier":"/us/usc/t12/s4569/j/2/D/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs4569%2Fj%2F2%2FD%2Fii%2FIII","sourceRelease":"119-100","text":"ability to obligate amounts and undertake activities so funded in a timely manner.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}]}]}
