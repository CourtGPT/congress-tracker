{"type":"section","nativeType":"section","number":"18652","heading":"Helium conservation program","label":"18652 Helium conservation program","identifier":"/us/usc/t42/s18652","parentIdentifier":"/us/usc/t42/ch161/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s18652/a","parentIdentifier":"/us/usc/t42/s18652","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18652/a/1","parentIdentifier":"/us/usc/t42/s18652/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652%2Fa%2F1","sourceRelease":"119-100","text":"the purchase of equipment to capture, reuse, and recycle helium;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18652/a/2","parentIdentifier":"/us/usc/t42/s18652/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652%2Fa%2F2","sourceRelease":"119-100","text":"the installation, maintenance, and repair of new and existing helium capture, reuse, and recycling equipment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18652/a/3","parentIdentifier":"/us/usc/t42/s18652/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652%2Fa%2F3","sourceRelease":"119-100","text":"helium alternatives research and development activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report","label":"b Report","identifier":"/us/usc/t42/s18652/b","parentIdentifier":"/us/usc/t42/s18652","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18652/b/1","parentIdentifier":"/us/usc/t42/s18652/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652%2Fb%2F1","sourceRelease":"119-100","text":"the quantity of helium purchased for projects and facilities supported by Department grants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18652/b/2","parentIdentifier":"/us/usc/t42/s18652/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652%2Fb%2F2","sourceRelease":"119-100","text":"a cost-analysis for such helium;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18652/b/3","parentIdentifier":"/us/usc/t42/s18652/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652%2Fb%2F3","sourceRelease":"119-100","text":"to the maximum extent practicable, information on whether such helium was imported from outside the United States, and if available, the country or region of the world from which the helium was imported;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18652/b/4","parentIdentifier":"/us/usc/t42/s18652/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652%2Fb%2F4","sourceRelease":"119-100","text":"expected or experienced impacts of helium supply shortages or prices on the research projects and facilities supported by the Department; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s18652/b/5","parentIdentifier":"/us/usc/t42/s18652/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652%2Fb%2F5","sourceRelease":"119-100","text":"recommendations for reducing Department grant recipients’ exposure to volatile helium prices and supply shortages.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Coordination","label":"c Coordination","identifier":"/us/usc/t42/s18652/c","parentIdentifier":"/us/usc/t42/s18652","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652%2Fc","sourceRelease":"119-100","text":"In carrying out the program under this section, the Director shall coordinate with the National Science Foundation and other relevant Federal agencies on helium conservation activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Duration","label":"d Duration","identifier":"/us/usc/t42/s18652/d","parentIdentifier":"/us/usc/t42/s18652","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652%2Fd","sourceRelease":"119-100","text":"The program established under this section shall receive support for a period of not more than 5 years, subject to the availability of appropriations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Renewal","label":"e Renewal","identifier":"/us/usc/t42/s18652/e","parentIdentifier":"/us/usc/t42/s18652","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18652%2Fe","sourceRelease":"119-100","text":"Upon expiration of any period of support of the program under this section, the Director may renew support for the program for a period of not more than 5 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
