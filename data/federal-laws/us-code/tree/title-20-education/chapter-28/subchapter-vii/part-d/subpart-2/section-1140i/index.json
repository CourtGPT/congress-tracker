{"type":"section","nativeType":"section","number":"1140i","heading":"Authorization of appropriations and reservation","label":"1140i Authorization of appropriations and reservation","identifier":"/us/usc/t20/s1140i","parentIdentifier":"/us/usc/t20/ch28/schVII/ptD/spt2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1140i","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authorization of appropriations","label":"a Authorization of appropriations","identifier":"/us/usc/t20/s1140i/a","parentIdentifier":"/us/usc/t20/s1140i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1140i%2Fa","sourceRelease":"119-100","text":"There are authorized to be appropriated to carry out this subpart such sums as may be necessary for fiscal year 2009 and each of the five succeeding fiscal years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Reservation of funds","label":"b Reservation of funds","identifier":"/us/usc/t20/s1140i/b","parentIdentifier":"/us/usc/t20/s1140i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1140i%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1140i/b/1","parentIdentifier":"/us/usc/t20/s1140i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1140i%2Fb%2F1","sourceRelease":"119-100","text":"not less than $240,000 for any year in which the amount appropriated to carry out this subpart is $8,000,000 or less; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1140i/b/2","parentIdentifier":"/us/usc/t20/s1140i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1140i%2Fb%2F2","sourceRelease":"119-100","text":"equal to 3 percent of the amount appropriated to carry out this subpart for any year in which such amount appropriated is greater than $8,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
