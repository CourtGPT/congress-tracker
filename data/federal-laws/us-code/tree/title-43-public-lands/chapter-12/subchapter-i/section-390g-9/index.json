 chapter 717; et seq.), or constructed by the United States pursuant to such law, or in connection with which there is a repayment or water service contract executed by the United States pursuant to such law, or any project constructed by the Secretary through the Bureau for the reclamation of land.August 11, 193953 Stat. 141816 U.S.C. 590y","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Flexibility to allow greater aquifer recharge in Western States","label":"c Flexibility to allow greater aquifer recharge in Western States","identifier":"/us/usc/t43/s390g–9/c","parentIdentifier":"/us/usc/t43/s390g–9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Use of Reclamation facilities","label":"1 Use of Reclamation facilities","identifier":"/us/usc/t43/s390g–9/c/1","parentIdentifier":"/us/usc/t43/s390g–9/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t43/s390g–9/c/1/A","parentIdentifier":"/us/usc/t43/s390g–9/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s390g–9/c/1/A/i","parentIdentifier":"/us/usc/t43/s390g–9/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs390g%E2%80%939%2Fc%2F1%2FA%2Fi","sourceRelease":"1