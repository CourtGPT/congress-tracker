{"type":"section","nativeType":"section","number":"9655","heading":"Engagement with investors","label":"9655 Engagement with investors","identifier":"/us/usc/t22/s9655","parentIdentifier":"/us/usc/t22/ch103/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s9655/a","parentIdentifier":"/us/usc/t22/s9655","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9655/a/1","parentIdentifier":"/us/usc/t22/s9655/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fa%2F1","sourceRelease":"119-100","text":"develop a strategic relationship with private sector entities focused at the nexus of business opportunities and development priorities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9655/a/2","parentIdentifier":"/us/usc/t22/s9655/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fa%2F2","sourceRelease":"119-100","text":"engage such entities and reduce business risks primarily through direct transaction support and facilitating investment partnerships;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s9655/a/3","parentIdentifier":"/us/usc/t22/s9655/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fa%2F3","sourceRelease":"119-100","text":"develop and support tools, approaches, and intermediaries that can mobilize private finance at scale in the developing world;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s9655/a/4","parentIdentifier":"/us/usc/t22/s9655/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fa%2F4","sourceRelease":"119-100","text":"pursue highly developmental projects of all sizes, especially those that are small but designed for work in the most underdeveloped areas, including countries with chronic suffering as a result of extreme poverty, fragile institutions, or a history of violence; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s9655/a/5","parentIdentifier":"/us/usc/t22/s9655/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fa%2F5","sourceRelease":"119-100","text":"pursue projects consistent with the policy of the United States described in and the Joint Strategic Plan and the Mission Country Development Cooperation Strategies of the United States Agency for International Development.section 9611 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Assistance","label":"b Assistance","identifier":"/us/usc/t22/s9655/b","parentIdentifier":"/us/usc/t22/s9655","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s9655/b/1","parentIdentifier":"/us/usc/t22/s9655/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fb%2F1","sourceRelease":"119-100","text":"develop risk mitigation tools;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s9655/b/2","parentIdentifier":"/us/usc/t22/s9655/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fb%2F2","sourceRelease":"119-100","text":"provide transaction structuring support for blended finance models;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s9655/b/3","parentIdentifier":"/us/usc/t22/s9655/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fb%2F3","sourceRelease":"119-100","text":"support intermediaries linking capital supply and demand;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s9655/b/4","parentIdentifier":"/us/usc/t22/s9655/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fb%2F4","sourceRelease":"119-100","text":"coordinate with other Federal agencies to support or accelerate transactions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s9655/b/5","parentIdentifier":"/us/usc/t22/s9655/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fb%2F5","sourceRelease":"119-100","text":"convene financial, donor, civil society, and public sector partners around opportunities for private finance within development priorities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s9655/b/6","parentIdentifier":"/us/usc/t22/s9655/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fb%2F6","sourceRelease":"119-100","text":"offer strategic planning and programming assistance to catalyze investment into priority sectors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t22/s9655/b/7","parentIdentifier":"/us/usc/t22/s9655/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fb%2F7","sourceRelease":"119-100","text":"provide transaction structuring support;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t22/s9655/b/8","parentIdentifier":"/us/usc/t22/s9655/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fb%2F8","sourceRelease":"119-100","text":"deliver training and knowledge management tools for engaging private investors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t22/s9655/b/9","parentIdentifier":"/us/usc/t22/s9655/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fb%2F9","sourceRelease":"119-100","text":"partner with private sector entities that provide access to capital and expertise; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t22/s9655/b/10","parentIdentifier":"/us/usc/t22/s9655/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fb%2F10","sourceRelease":"119-100","text":"identify and screen new investment partners.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Technical assistance","label":"c Technical assistance","identifier":"/us/usc/t22/s9655/c","parentIdentifier":"/us/usc/t22/s9655","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs9655%2Fc","sourceRelease":"119-100","text":"The Corporation shall coordinate with the United States Agency for International Development and other agencies and departments, as necessary, on projects and programs supported by the Corporation that include technical assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
