{"type":"section","nativeType":"section","number":"7385s","heading":"Definitions","label":"7385s Definitions","identifier":"/us/usc/t42/s7385s","parentIdentifier":"/us/usc/t42/ch84/schXVI/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7385s","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s7385s/1","parentIdentifier":"/us/usc/t42/s7385s","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7385s%2F1","sourceRelease":"119-100","text":"The term “covered DOE contractor employee” means any Department of Energy contractor employee determined under to have contracted a covered illness through exposure at a Department of Energy facility.section 7385s–4 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s7385s/2","parentIdentifier":"/us/usc/t42/s7385s","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7385s%2F2","sourceRelease":"119-100","text":"The term “covered illness” means an illness or death resulting from exposure to a toxic substance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s7385s/3","parentIdentifier":"/us/usc/t42/s7385s","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7385s%2F3","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Labor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
