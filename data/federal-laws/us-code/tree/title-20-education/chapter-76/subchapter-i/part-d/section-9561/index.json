{"type":"section","nativeType":"section","number":"9561","heading":"Establishment","label":"9561 Establishment","identifier":"/us/usc/t20/s9561","parentIdentifier":"/us/usc/t20/ch76/schI/ptD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9561","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t20/s9561/a","parentIdentifier":"/us/usc/t20/s9561","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9561%2Fa","sourceRelease":"119-100","text":"There is established in the Institute a National Center for Education Evaluation and Regional Assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Mission","label":"b Mission","identifier":"/us/usc/t20/s9561/b","parentIdentifier":"/us/usc/t20/s9561","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9561%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s9561/b/1","parentIdentifier":"/us/usc/t20/s9561/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9561%2Fb%2F1","sourceRelease":"119-100","text":"to provide technical assistance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s9561/b/2","parentIdentifier":"/us/usc/t20/s9561/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9561%2Fb%2F2","sourceRelease":"119-100","text":"to conduct evaluations of Federal education programs administered by the Secretary (and as time and resources allow, other education programs) to determine the impact of such programs (especially on student academic achievement in the core academic areas of reading, mathematics, and science);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s9561/b/3","parentIdentifier":"/us/usc/t20/s9561/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9561%2Fb%2F3","sourceRelease":"119-100","text":"to support synthesis and wide dissemination of results of evaluation, research, and products developed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s9561/b/4","parentIdentifier":"/us/usc/t20/s9561/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9561%2Fb%2F4","sourceRelease":"119-100","text":"to encourage the use of scientifically valid education research and evaluation throughout the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Grants, contracts, and cooperative agreements","label":"c Grants, contracts, and cooperative agreements","identifier":"/us/usc/t20/s9561/c","parentIdentifier":"/us/usc/t20/s9561","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9561%2Fc","sourceRelease":"119-100","text":"In carrying out the duties under this part, the Director may award grants, enter into contracts and cooperative agreements, and provide technical assistance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
