{"type":"section","nativeType":"section","number":"1302e","heading":"Connection to publicly owned treatment works","label":"1302e Connection to publicly owned treatment works","identifier":"/us/usc/t33/s1302e","parentIdentifier":"/us/usc/t33/ch26/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t33/s1302e/a","parentIdentifier":"/us/usc/t33/s1302e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible entity","label":"1 Eligible entity","identifier":"/us/usc/t33/s1302e/a/1","parentIdentifier":"/us/usc/t33/s1302e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1302e/a/1/A","parentIdentifier":"/us/usc/t33/s1302e/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fa%2F1%2FA","sourceRelease":"119-100","text":"an owner or operator of a publicly owned treatment works that assists or is seeking to assist low-income or moderate-income individuals with connecting the household of the individual to the publicly owned treatment works; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1302e/a/1/B","parentIdentifier":"/us/usc/t33/s1302e/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fa%2F1%2FB","sourceRelease":"119-100","text":"a nonprofit entity that assists low-income or moderate-income individuals with the costs associated with connecting the household of the individual to a publicly owned treatment works.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Program","label":"2 Program","identifier":"/us/usc/t33/s1302e/a/2","parentIdentifier":"/us/usc/t33/s1302e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fa%2F2","sourceRelease":"119-100","text":"The term “program” means the competitive grant program established under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Qualified individual","label":"3 Qualified individual","identifier":"/us/usc/t33/s1302e/a/3","parentIdentifier":"/us/usc/t33/s1302e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fa%2F3","sourceRelease":"119-100","text":"The term “qualified individual” has the meaning given the term “eligible individual” in .section 1383(j) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Establishment","label":"b Establishment","identifier":"/us/usc/t33/s1302e/b","parentIdentifier":"/us/usc/t33/s1302e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fb","sourceRelease":"119-100","text":"Subject to the availability of appropriations, the Administrator shall establish a competitive grant program with the purpose of improving general welfare, under which the Administrator awards grants to eligible entities to provide funds to assist qualified individuals in covering the costs incurred by the qualified individual in connecting the household of the qualified individual to a publicly owned treatment works.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Application","label":"c Application","identifier":"/us/usc/t33/s1302e/c","parentIdentifier":"/us/usc/t33/s1302e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s1302e/c/1","parentIdentifier":"/us/usc/t33/s1302e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fc%2F1","sourceRelease":"119-100","text":"An eligible entity seeking a grant under the program shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator may by regulation require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirement","label":"2 Requirement","identifier":"/us/usc/t33/s1302e/c/2","parentIdentifier":"/us/usc/t33/s1302e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fc%2F2","sourceRelease":"119-100","text":"Not later than 90 days after the date on which the Administrator receives an application from an eligible entity under paragraph (1), the Administrator shall notify the eligible entity of whether the Administrator will award a grant to the eligible entity under the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Selection criteria","label":"d Selection criteria","identifier":"/us/usc/t33/s1302e/d","parentIdentifier":"/us/usc/t33/s1302e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1302e/d/1","parentIdentifier":"/us/usc/t33/s1302e/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fd%2F1","sourceRelease":"119-100","text":"Whether the eligible entity seeking a grant provides services to, or works directly with, qualified individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s1302e/d/2","parentIdentifier":"/us/usc/t33/s1302e/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1302e/d/2/A","parentIdentifier":"/us/usc/t33/s1302e/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fd%2F2%2FA","sourceRelease":"119-100","text":"has an existing program to assist in covering the costs incurred in connecting a household to a publicly owned treatment works; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1302e/d/2/B","parentIdentifier":"/us/usc/t33/s1302e/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fd%2F2%2FB","sourceRelease":"119-100","text":"seeks to create a program described in subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Requirements","label":"e Requirements","identifier":"/us/usc/t33/s1302e/e","parentIdentifier":"/us/usc/t33/s1302e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Voluntary connection","label":"1 Voluntary connection","identifier":"/us/usc/t33/s1302e/e/1","parentIdentifier":"/us/usc/t33/s1302e/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1302e/e/1/A","parentIdentifier":"/us/usc/t33/s1302e/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fe%2F1%2FA","sourceRelease":"119-100","text":"the qualified individual has connected to the publicly owned treatment works voluntarily; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1302e/e/1/B","parentIdentifier":"/us/usc/t33/s1302e/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fe%2F1%2FB","sourceRelease":"119-100","text":"if the eligible entity is not the owner or operator of the publicly owned treatment works to which the qualified individual has connected, the publicly owned treatment works to which the qualified individual has connected has agreed to the connection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Reimbursements from publicly owned treatment works","label":"2 Reimbursements from publicly owned treatment works","identifier":"/us/usc/t33/s1302e/e/2","parentIdentifier":"/us/usc/t33/s1302e/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s1302e/e/2/A","parentIdentifier":"/us/usc/t33/s1302e/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fe%2F2%2FA","sourceRelease":"119-100","text":"reducing the amount otherwise owed by the qualified individual to the owner or operator for wastewater or other services provided by the owner or operator; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s1302e/e/2/B","parentIdentifier":"/us/usc/t33/s1302e/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Fe%2F2%2FB","sourceRelease":"119-100","text":"providing a direct payment to the qualified individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorization of appropriations","label":"f Authorization of appropriations","identifier":"/us/usc/t33/s1302e/f","parentIdentifier":"/us/usc/t33/s1302e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s1302e/f/1","parentIdentifier":"/us/usc/t33/s1302e/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Ff%2F1","sourceRelease":"119-100","text":"There is authorized to be appropriated to carry out the program $40,000,000 for each of fiscal years 2022 through 2026.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitations on use of funds","label":"2 Limitations on use of funds","identifier":"/us/usc/t33/s1302e/f/2","parentIdentifier":"/us/usc/t33/s1302e/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Small systems","label":"A Small systems","identifier":"/us/usc/t33/s1302e/f/2/A","parentIdentifier":"/us/usc/t33/s1302e/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Ff%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s1302e/f/2/A/i","parentIdentifier":"/us/usc/t33/s1302e/f/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Ff%2F2%2FA%2Fi","sourceRelease":"119-100","text":"eligible entities described in subsection (a)(1)(A) that are owners and operators of publicly owned treatment works that serve fewer than 3,300 people; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s1302e/f/2/A/ii","parentIdentifier":"/us/usc/t33/s1302e/f/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Ff%2F2%2FA%2Fii","sourceRelease":"119-100","text":"eligible entities described in subsection (a)(1)(B) that provide the assistance described in that subsection in areas that are served by publicly owned treatment works that serve fewer than 3,300 people.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Administrative costs","label":"B Administrative costs","identifier":"/us/usc/t33/s1302e/f/2/B","parentIdentifier":"/us/usc/t33/s1302e/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1302e%2Ff%2F2%2FB","sourceRelease":"119-100","text":"Of the amounts made available for grants under paragraph (1), not more than 2 percent may be used to pay the administrative costs of the Administrator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
