{"type":"section","nativeType":"section","number":"16025","heading":"Project timelines and authorization of appropriations","label":"16025 Project timelines and authorization of appropriations","identifier":"/us/usc/t42/s16025","parentIdentifier":"/us/usc/t42/ch149/schVI/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16025","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Target date to complete the first project phase","label":"a Target date to complete the first project phase","identifier":"/us/usc/t42/s16025/a","parentIdentifier":"/us/usc/t42/s16025","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16025%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16025/a/1","parentIdentifier":"/us/usc/t42/s16025/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16025%2Fa%2F1","sourceRelease":"119-100","text":"select the technology to be used by the Project for high-temperature hydrogen production and the initial design parameters for the prototype nuclear plant; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16025/a/2","parentIdentifier":"/us/usc/t42/s16025/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16025%2Fa%2F2","sourceRelease":"119-100","text":"submit to Congress a report establishing an alternative date for making the selection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Design competition for second project phase","label":"b Design competition for second project phase","identifier":"/us/usc/t42/s16025/b","parentIdentifier":"/us/usc/t42/s16025","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16025%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16025/b/1","parentIdentifier":"/us/usc/t42/s16025/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16025%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary, acting through the Idaho National Laboratory, shall fund not more than 4 teams for not more than 2 years to develop detailed proposals for competitive evaluation and selection of a single proposal for a final design of the prototype nuclear reactor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Systems integration","label":"2 Systems integration","identifier":"/us/usc/t42/s16025/b/2","parentIdentifier":"/us/usc/t42/s16025/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16025%2Fb%2F2","sourceRelease":"119-100","text":"The Secretary may structure Project activities in the second project phase to use the lead industrial partner of the competitively selected design under paragraph (1) in a systems integration role for final design and construction of the Project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Target date to complete project construction","label":"c Target date to complete project construction","identifier":"/us/usc/t42/s16025/c","parentIdentifier":"/us/usc/t42/s16025","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16025%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16025/c/1","parentIdentifier":"/us/usc/t42/s16025/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16025%2Fc%2F1","sourceRelease":"119-100","text":"complete construction and begin operations of the prototype nuclear reactor and associated energy or hydrogen facilities; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16025/c/2","parentIdentifier":"/us/usc/t42/s16025/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16025%2Fc%2F2","sourceRelease":"119-100","text":"submit to Congress a report establishing an alternative date for completion.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Authorization of appropriations","label":"d Authorization of appropriations","identifier":"/us/usc/t42/s16025/d","parentIdentifier":"/us/usc/t42/s16025","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16025%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16025/d/1","parentIdentifier":"/us/usc/t42/s16025/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16025%2Fd%2F1","sourceRelease":"119-100","text":"$1,250,000,000 for the period of fiscal years 2006 through 2015; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16025/d/2","parentIdentifier":"/us/usc/t42/s16025/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16025%2Fd%2F2","sourceRelease":"119-100","text":"such sums as are necessary for each of fiscal years 2016 through 2021.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
