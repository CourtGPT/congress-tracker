Release":"119-100","text":"such that the access qualifies as an advanced telecommunications capability;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1721/1/B","parentIdentifier":"/us/usc/t47/s1721/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F1%2FB","sourceRelease":"119-100","text":"with the digital skills that are necessary for the individual to participate online; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t47/s1721/1/C","parentIdentifier":"/us/usc/t47/s1721/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1721/1/C/i","parentIdentifier":"/us/usc/t47/s1721/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F1%2FC%2Fi","sourceRelease":"119-100","text":"personal device; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1721/1/C/ii","parentIdentifier":"/us/usc/t47/s1721/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F1%2FC%2Fii","sourceRelease":"119-100","text":"secure and convenient network.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Advanced telecommunications capability","label":"2 Advanced telecommunications capability","identifier":"/us/usc/t47/s1721/2","parentIdentifier":"/us/usc/t47/s1721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F2","sourceRelease":"119-100","text":"The term “advanced telecommunications capability” has the meaning given the term in .section 1302(d) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Aging individual","label":"3 Aging individual","identifier":"/us/usc/t47/s1721/3","parentIdentifier":"/us/usc/t47/s1721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F3","sourceRelease":"119-100","text":"The term “aging individual” has the meaning given the term “older individual” in .section 3002 of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Appropriate committees of Congress","label":"4 Appropriate committees of Congress","identifier":"/us/usc/t47/s1721/4","parentIdentifier":"/us/usc/t47/s1721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1721/4/A","parentIdentifier":"/us/usc/t47/s1721/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F4%2FA","sourceRelease":"119-100","text":"the Committee on Appropriations of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1721/4/B","parentIdentifier":"/us/usc/t47/s1721/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F4%2FB","sourceRelease":"119-100","text":"the Committee on Commerce, Science, and Transportation of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t47/s1721/4/C","parentIdentifier":"/us/usc/t47/s1721/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F4%2FC","sourceRelease":"119-100","text":"the Committee on Appropriations of the House of Representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t47/s1721/4/D","parentIdentifier":"/us/usc/t47/s1721/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F4%2FD","sourceRelease":"119-100","text":"the Committee on Energy and Commerce of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Assistant Secretary","label":"5 Assistant Secretary","identifier":"/us/usc/t47/s1721/5","parentIdentifier":"/us/usc/t47/s1721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F5","sourceRelease":"119-100","text":"The term “Assistant Secretary” means the Assistant Secretary of Commerce for Communications and Information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Community anchor institution","label":"6 Community anchor institution","identifier":"/us/usc/t47/s1721/6","parentIdentifier":"/us/usc/t47/s1721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F6","sourceRelease":"119-100","text":"The term “community anchor institution” means a public school, a public or multi-family housing authority, a library, a medical or healthcare provider, a community college or other institution of higher education, a State library agency, and any other nonprofit or governmental community support organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Covered household","label":"7 Covered household","identifier":"/us/usc/t47/s1721/7","parentIdentifier":"/us/usc/t47/s1721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F7","sourceRelease":"119-100","text":"The term “covered household” means a household, the income of which for the most recently completed year is not more than 150 percent of an amount equal to the poverty level, as determined by using criteria of poverty established by the Bureau of the Census.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Covered populations","label":"8 Covered populations","identifier":"/us/usc/t47/s1721/8","parentIdentifier":"/us/usc/t47/s1721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1721/8/A","parentIdentifier":"/us/usc/t47/s1721/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F8%2FA","sourceRelease":"119-100","text":"individuals who live in covered households;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1721/8/B","parentIdentifier":"/us/usc/t47/s1721/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F8%2FB","sourceRelease":"119-100","text":"aging individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t47/s1721/8/C","parentIdentifier":"/us/usc/t47/s1721/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F8%2FC","sourceRelease":"119-100","text":"incarcerated individuals, other than individuals who are incarcerated in a Federal correctional facility;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t47/s1721/8/D","parentIdentifier":"/us/usc/t47/s1721/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F8%2FD","sourceRelease":"119-100","text":"veterans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t47/s1721/8/E","parentIdentifier":"/us/usc/t47/s1721/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F8%2FE","sourceRelease":"119-100","text":"individuals with disabilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t47/s1721/8/F","parentIdentifier":"/us/usc/t47/s1721/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F8%2FF","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1721/8/F/i","parentIdentifier":"/us/usc/t47/s1721/8/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F8%2FF%2Fi","sourceRelease":"119-100","text":"are English learners; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1721/8/F/ii","parentIdentifier":"/us/usc/t47/s1721/8/F","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F8%2FF%2Fii","sourceRelease":"119-100","text":"have low levels of literacy;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t47/s1721/8/G","parentIdentifier":"/us/usc/t47/s1721/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F8%2FG","sourceRelease":"119-100","text":"individuals who are members of a racial or ethnic minority group; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t47/s1721/8/H","parentIdentifier":"/us/usc/t47/s1721/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F8%2FH","sourceRelease":"119-100","text":"individuals who primarily reside in a rural area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":"Covered programs","label":"9 Covered programs","identifier":"/us/usc/t47/s1721/9","parentIdentifier":"/us/usc/t47/s1721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F9","sourceRelease":"119-100","text":"The term “covered programs” means the State Digital Equity Capacity Grant Program established under and the Digital Equity Competitive Grant Program established under .section 1723 of this titlesection 1724 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":"Digital equity","label":"10 Digital equity","identifier":"/us/usc/t47/s1721/10","parentIdentifier":"/us/usc/t47/s1721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F10","sourceRelease":"119-100","text":"The term “digital equity” means the condition in which individuals and communities have the information technology capacity that is needed for full participation in the society and economy of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":"Digital inclusion","label":"11 Digital inclusion","identifier":"/us/usc/t47/s1721/11","parentIdentifier":"/us/usc/t47/s1721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F11","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1721/11/A","parentIdentifier":"/us/usc/t47/s1721/11","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F11%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1721/11/A/i","parentIdentifier":"/us/usc/t47/s1721/11/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F11%2FA%2Fi","sourceRelease":"119-100","text":"reliable fixed and wireless broadband internet service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1721/11/A/ii","parentIdentifier":"/us/usc/t47/s1721/11/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F11%2FA%2Fii","sourceRelease":"119-100","text":"internet-enabled devices that meet the needs of the user; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t47/s1721/11/A/iii","parentIdentifier":"/us/usc/t47/s1721/11/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F11%2FA%2Fiii","sourceRelease":"119-100","text":"applications and online content designed to enable and encourage self-sufficiency, participation, and collaboration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1721/11/B","parentIdentifier":"/us/usc/t47/s1721/11","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F11%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t47/s1721/11/B/i","parentIdentifier":"/us/usc/t47/s1721/11/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F11%2FB%2Fi","sourceRelease":"119-100","text":"obtaining access to digital literacy training;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t47/s1721/11/B/ii","parentIdentifier":"/us/usc/t47/s1721/11/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F11%2FB%2Fii","sourceRelease":"119-100","text":"the provision of quality technical support; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t47/s1721/11/B/iii","parentIdentifier":"/us/usc/t47/s1721/11/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F11%2FB%2Fiii","sourceRelease":"119-100","text":"obtaining basic awareness of measures to ensure online privacy and cybersecurity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":"Digital literacy","label":"12 Digital literacy","identifier":"/us/usc/t47/s1721/12","parentIdentifier":"/us/usc/t47/s1721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F12","sourceRelease":"119-100","text":"The term “digital literacy” means the skills associated with using technology to enable users to find, evaluate, organize, create, and communicate information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"13","heading":"Disability","label":"13 Disability","identifier":"/us/usc/t47/s1721/13","parentIdentifier":"/us/usc/t47/s1721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F13","sourceRelease":"119-100","text":"The term “disability” has the meaning given the term in .section 12102 of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"14","heading":"Eligible State","label":"14 Eligible State","identifier":"/us/usc/t47/s1721/14","parentIdentifier":"/us/usc/t47/s1721","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F14","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1721/14/A","parentIdentifier":"/us/usc/t47/s1721/14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1721%2F14%2FA","sourceRelease":"119-100","text":"with respect to planning grants made available under section 60304(c)(3), a State with respect to which the Assistant Secretary has approved an application submitted to the Assistant Secretary under ; andsection 1723(c)(3)(C) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1721/14/B","parentIdentifier":"/us/usc/t47/s1721/14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47