{"type":"section","nativeType":"section","number":"3552","heading":"Definitions","label":"3552 Definitions","identifier":"/us/usc/t44/s3552","parentIdentifier":"/us/usc/t44/ch35/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsProvisions similar to this section were contained in sections 3532 and 3542 of this title prior to repeal by .Pub. L. 113–283"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t44/s3552/a","parentIdentifier":"/us/usc/t44/s3552","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fa","sourceRelease":"119-100","text":"Except as provided under subsection (b), the definitions under section 3502 shall apply to this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Additional Definitions","label":"b .—Additional Definitions","identifier":"/us/usc/t44/s3552/b","parentIdentifier":"/us/usc/t44/s3552","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t44/s3552/b/1","parentIdentifier":"/us/usc/t44/s3552/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t44/s3552/b/1/A","parentIdentifier":"/us/usc/t44/s3552/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F1%2FA","sourceRelease":"119-100","text":"is for purposes of safeguarding Federal information and information systems from a known or reasonably suspected information security threat, vulnerability, or risk;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t44/s3552/b/1/B","parentIdentifier":"/us/usc/t44/s3552/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F1%2FB","sourceRelease":"119-100","text":"shall be in accordance with policies, principles, standards, and guidelines issued by the Director; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t44/s3552/b/1/C","parentIdentifier":"/us/usc/t44/s3552/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F1%2FC","sourceRelease":"119-100","text":"may be revised or repealed by the Director if the direction issued on behalf of the Director is not in accordance with policies and principles developed by the Director.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t44/s3552/b/2","parentIdentifier":"/us/usc/t44/s3552/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t44/s3552/b/2/A","parentIdentifier":"/us/usc/t44/s3552/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F2%2FA","sourceRelease":"119-100","text":"actually or imminently jeopardizes, without lawful authority, the integrity, confidentiality, or availability of information or an information system; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t44/s3552/b/2/B","parentIdentifier":"/us/usc/t44/s3552/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F2%2FB","sourceRelease":"119-100","text":"constitutes a violation or imminent threat of violation of law, security policies, security procedures, or acceptable use policies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t44/s3552/b/3","parentIdentifier":"/us/usc/t44/s3552/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t44/s3552/b/3/A","parentIdentifier":"/us/usc/t44/s3552/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F3%2FA","sourceRelease":"119-100","text":"integrity, which means guarding against improper information modification or destruction, and includes ensuring information nonrepudiation and authenticity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t44/s3552/b/3/B","parentIdentifier":"/us/usc/t44/s3552/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F3%2FB","sourceRelease":"119-100","text":"confidentiality, which means preserving authorized restrictions on access and disclosure, including means for protecting personal privacy and proprietary information; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t44/s3552/b/3/C","parentIdentifier":"/us/usc/t44/s3552/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F3%2FC","sourceRelease":"119-100","text":"availability, which means ensuring timely and reliable access to and use of information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t44/s3552/b/4","parentIdentifier":"/us/usc/t44/s3552/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F4","sourceRelease":"119-100","text":"The term “information technology” has the meaning given that term in .section 11101 of title 40","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t44/s3552/b/5","parentIdentifier":"/us/usc/t44/s3552/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F5","sourceRelease":"119-100","text":"The term “intelligence community” has the meaning given that term in section 3(4) of the National Security Act of 1947 ().50 U.S.C. 3003(4)","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t44/s3552/b/6","parentIdentifier":"/us/usc/t44/s3552/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t44/s3552/b/6/A","parentIdentifier":"/us/usc/t44/s3552/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F6%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t44/s3552/b/6/A/i","parentIdentifier":"/us/usc/t44/s3552/b/6/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F6%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t44/s3552/b/6/A/i/I","parentIdentifier":"/us/usc/t44/s3552/b/6/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F6%2FA%2Fi%2FI","sourceRelease":"119-100","text":"involves intelligence activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t44/s3552/b/6/A/i/II","parentIdentifier":"/us/usc/t44/s3552/b/6/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F6%2FA%2Fi%2FII","sourceRelease":"119-100","text":"involves cryptologic activities related to national security;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t44/s3552/b/6/A/i/III","parentIdentifier":"/us/usc/t44/s3552/b/6/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F6%2FA%2Fi%2FIII","sourceRelease":"119-100","text":"involves command and control of military forces;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t44/s3552/b/6/A/i/IV","parentIdentifier":"/us/usc/t44/s3552/b/6/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F6%2FA%2Fi%2FIV","sourceRelease":"119-100","text":"involves equipment that is an integral part of a weapon or weapons system; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t44/s3552/b/6/A/i/V","parentIdentifier":"/us/usc/t44/s3552/b/6/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F6%2FA%2Fi%2FV","sourceRelease":"119-100","text":"subject to subparagraph (B), is critical to the direct fulfillment of military or intelligence missions; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t44/s3552/b/6/A/ii","parentIdentifier":"/us/usc/t44/s3552/b/6/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F6%2FA%2Fii","sourceRelease":"119-100","text":"is protected at all times by procedures established for information that have been specifically authorized under criteria established by an Executive order or an Act of Congress to be kept classified in the interest of national defense or foreign policy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t44/s3552/b/6/B","parentIdentifier":"/us/usc/t44/s3552/b/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F6%2FB","sourceRelease":"119-100","text":"Subparagraph (A)(i)(V) does not include a system that is to be used for routine administrative and business applications (including payroll, finance, logistics, and personnel management applications).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t44/s3552/b/7","parentIdentifier":"/us/usc/t44/s3552/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft44%2Fs3552%2Fb%2F7","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of Homeland Security.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
