{"type":"section","nativeType":"section","number":"17195a","heading":"Geothermal heat pumps and direct use research and development","label":"17195a Geothermal heat pumps and direct use research and development","identifier":"/us/usc/t42/s17195a","parentIdentifier":"/us/usc/t42/ch152/schV/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purposes","label":"a Purposes","identifier":"/us/usc/t42/s17195a/a","parentIdentifier":"/us/usc/t42/s17195a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17195a/a/1","parentIdentifier":"/us/usc/t42/s17195a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fa%2F1","sourceRelease":"119-100","text":"to improve the understanding of related earth sciences, components, processes, and systems used for geothermal heat pumps and the direct use of geothermal energy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17195a/a/2","parentIdentifier":"/us/usc/t42/s17195a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fa%2F2","sourceRelease":"119-100","text":"to increase the energy efficiency, lower the cost, increase the use, and improve and demonstrate the effectiveness of geothermal heat pumps and the direct use of geothermal energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Definitions","label":"b Definitions","identifier":"/us/usc/t42/s17195a/b","parentIdentifier":"/us/usc/t42/s17195a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Direct use of geothermal energy","label":"1 Direct use of geothermal energy","identifier":"/us/usc/t42/s17195a/b/1","parentIdentifier":"/us/usc/t42/s17195a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17195a/b/1/A","parentIdentifier":"/us/usc/t42/s17195a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fb%2F1%2FA","sourceRelease":"119-100","text":"heating and cooling to buildings, commercial districts, residential communities, and large municipal, or industrial projects; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17195a/b/1/B","parentIdentifier":"/us/usc/t42/s17195a/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fb%2F1%2FB","sourceRelease":"119-100","text":"heat required for industrial processes, agriculture, aquaculture, and other facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Economically distressed area","label":"2 Economically distressed area","identifier":"/us/usc/t42/s17195a/b/2","parentIdentifier":"/us/usc/t42/s17195a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fb%2F2","sourceRelease":"119-100","text":"The term “economically distressed area” means an area described in .section 3161(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Geothermal heat pump","label":"3 Geothermal heat pump","identifier":"/us/usc/t42/s17195a/b/3","parentIdentifier":"/us/usc/t42/s17195a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17195a/b/3/A","parentIdentifier":"/us/usc/t42/s17195a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fb%2F3%2FA","sourceRelease":"119-100","text":"a closed loop system, which transfers heat by way of buried or immersed pipes that contain a mix of water and working fluid; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17195a/b/3/B","parentIdentifier":"/us/usc/t42/s17195a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fb%2F3%2FB","sourceRelease":"119-100","text":"an open loop system, which circulates ground or surface water directly into the building and returns the water to the same aquifer or surface water source.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Program","label":"c Program","identifier":"/us/usc/t42/s17195a/c","parentIdentifier":"/us/usc/t42/s17195a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17195a/c/1","parentIdentifier":"/us/usc/t42/s17195a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary shall support within the Geothermal Technologies Office a program of research, development, and demonstration for geothermal heat pumps and the direct use of geothermal energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Areas","label":"2 Areas","identifier":"/us/usc/t42/s17195a/c/2","parentIdentifier":"/us/usc/t42/s17195a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17195a/c/2/A","parentIdentifier":"/us/usc/t42/s17195a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fc%2F2%2FA","sourceRelease":"119-100","text":"geothermal ground loop efficiency improvements, cost reductions, and improved installation and operations methods;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17195a/c/2/B","parentIdentifier":"/us/usc/t42/s17195a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the use of geothermal energy for building-scale energy storage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17195a/c/2/C","parentIdentifier":"/us/usc/t42/s17195a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fc%2F2%2FC","sourceRelease":"119-100","text":"the use of geothermal energy as a grid management resource or seasonal energy storage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17195a/c/2/D","parentIdentifier":"/us/usc/t42/s17195a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fc%2F2%2FD","sourceRelease":"119-100","text":"geothermal heat pump efficiency improvements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17195a/c/2/E","parentIdentifier":"/us/usc/t42/s17195a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fc%2F2%2FE","sourceRelease":"119-100","text":"the use of alternative fluids as a heat exchange medium, such as hot water found in mines and mine shafts, graywater, or other fluids that may improve the economics of geothermal heat pumps;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17195a/c/2/F","parentIdentifier":"/us/usc/t42/s17195a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fc%2F2%2FF","sourceRelease":"119-100","text":"heating of districts, neighborhoods, communities, large commercial or public buildings, and industrial and manufacturing facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s17195a/c/2/G","parentIdentifier":"/us/usc/t42/s17195a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fc%2F2%2FG","sourceRelease":"119-100","text":"the use of low temperature groundwater for direct use; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t42/s17195a/c/2/H","parentIdentifier":"/us/usc/t42/s17195a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fc%2F2%2FH","sourceRelease":"119-100","text":"system integration of direct use with geothermal electricity production.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Environmental impacts","label":"3 Environmental impacts","identifier":"/us/usc/t42/s17195a/c/3","parentIdentifier":"/us/usc/t42/s17195a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fc%2F3","sourceRelease":"119-100","text":"In carrying out the program, the Secretary shall identify and mitigate potential environmental impacts in accordance with .section 17193(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Financial assistance","label":"d Financial assistance","identifier":"/us/usc/t42/s17195a/d","parentIdentifier":"/us/usc/t42/s17195a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17195a/d/1","parentIdentifier":"/us/usc/t42/s17195a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary shall carry out the program established in subsection (c) by making financial assistance available to State, local, and Tribal governments, institutions of higher education, nonprofit entities, National Laboratories, utilities, and for-profit companies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Priority","label":"2 Priority","identifier":"/us/usc/t42/s17195a/d/2","parentIdentifier":"/us/usc/t42/s17195a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17195a%2Fd%2F2","sourceRelease":"119-100","text":"In providing financial assistance under this subsection, the Secretary may give priority to proposals that apply to large buildings, commercial districts, and residential communities that are located in economically distressed areas and areas that the Secretary determines to have high economic potential for geothermal district heating based on the report, “Geovision: Harnessing the Heat Beneath our Feet” published by the Department in 2019, or a successor report.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
