{"type":"section","nativeType":"section","number":"15113","heading":"Reaching up scholarship program","label":"15113 Reaching up scholarship program","identifier":"/us/usc/t42/s15113","parentIdentifier":"/us/usc/t42/ch144/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Program authorization","label":"a Program authorization","identifier":"/us/usc/t42/s15113/a","parentIdentifier":"/us/usc/t42/s15113","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fa","sourceRelease":"119-100","text":"The Secretary may award grants to eligible entities, on a competitive basis, to enable the entities to carry out scholarship programs by providing vouchers for postsecondary education to direct support workers who assist individuals with developmental disabilities residing in diverse settings. The Secretary shall award the grants to pay for the Federal share of the cost of providing the vouchers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Eligible entity","label":"b Eligible entity","identifier":"/us/usc/t42/s15113/b","parentIdentifier":"/us/usc/t42/s15113","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15113/b/1","parentIdentifier":"/us/usc/t42/s15113/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fb%2F1","sourceRelease":"119-100","text":"an institution of higher education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15113/b/2","parentIdentifier":"/us/usc/t42/s15113/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fb%2F2","sourceRelease":"119-100","text":"a State agency; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s15113/b/3","parentIdentifier":"/us/usc/t42/s15113/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fb%2F3","sourceRelease":"119-100","text":"a consortium of such institutions or agencies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Application requirements","label":"c Application requirements","identifier":"/us/usc/t42/s15113/c","parentIdentifier":"/us/usc/t42/s15113","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15113/c/1","parentIdentifier":"/us/usc/t42/s15113/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fc%2F1","sourceRelease":"119-100","text":"the basis for awarding the vouchers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15113/c/2","parentIdentifier":"/us/usc/t42/s15113/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fc%2F2","sourceRelease":"119-100","text":"the number of individuals to receive the vouchers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s15113/c/3","parentIdentifier":"/us/usc/t42/s15113/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fc%2F3","sourceRelease":"119-100","text":"the amount of funds that will be made available by the eligible entity to pay for the non-Federal share of the cost of providing the vouchers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Selection criteria","label":"d Selection criteria","identifier":"/us/usc/t42/s15113/d","parentIdentifier":"/us/usc/t42/s15113","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s15113/d/1","parentIdentifier":"/us/usc/t42/s15113/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s15113/d/1/A","parentIdentifier":"/us/usc/t42/s15113/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fd%2F1%2FA","sourceRelease":"119-100","text":"who are direct support workers who assist individuals with developmental disabilities residing in diverse settings, while pursuing postsecondary education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s15113/d/1/B","parentIdentifier":"/us/usc/t42/s15113/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fd%2F1%2FB","sourceRelease":"119-100","text":"each of whom verifies, prior to receiving the voucher, that the worker has completed 250 hours as a direct support worker in the past 90 days;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s15113/d/2","parentIdentifier":"/us/usc/t42/s15113/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fd%2F2","sourceRelease":"119-100","text":"states that the vouchers that will be provided through the program will be in amounts of not more than $2,000 per year;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s15113/d/3","parentIdentifier":"/us/usc/t42/s15113/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fd%2F3","sourceRelease":"119-100","text":"provides an assurance that the eligible entity (or another specified entity that is not a voucher recipient) will contribute the non-Federal share of the cost of providing the vouchers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s15113/d/4","parentIdentifier":"/us/usc/t42/s15113/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fd%2F4","sourceRelease":"119-100","text":"meets such other conditions as the Secretary may specify.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Federal share","label":"e Federal share","identifier":"/us/usc/t42/s15113/e","parentIdentifier":"/us/usc/t42/s15113","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs15113%2Fe","sourceRelease":"119-100","text":"The Federal share of the cost of providing the vouchers shall be not more than 80 percent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
