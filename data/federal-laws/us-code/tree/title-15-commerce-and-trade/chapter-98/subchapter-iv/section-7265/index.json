{"type":"section","nativeType":"section","number":"7265","heading":"Disclosure of audit committee financial expert","label":"7265 Disclosure of audit committee financial expert","identifier":"/us/usc/t15/s7265","parentIdentifier":"/us/usc/t15/ch98/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7265","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Rules defining “financial expert”","label":"a Rules defining “financial expert”","identifier":"/us/usc/t15/s7265/a","parentIdentifier":"/us/usc/t15/s7265","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7265%2Fa","sourceRelease":"119-100","text":"The Commission shall issue rules, as necessary or appropriate in the public interest and consistent with the protection of investors, to require each issuer, together with periodic reports required pursuant to sections 78m(a) and 78(d) of this title, to disclose whether or not, and if not, the reasons therefor, the audit committee of that issuer is comprised of at least 1 member who is a financial expert, as such term is defined by the Commission.o","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Considerations","label":"b Considerations","identifier":"/us/usc/t15/s7265/b","parentIdentifier":"/us/usc/t15/s7265","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7265%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7265/b/1","parentIdentifier":"/us/usc/t15/s7265/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7265%2Fb%2F1","sourceRelease":"119-100","text":"an understanding of generally accepted accounting principles and financial statements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7265/b/2","parentIdentifier":"/us/usc/t15/s7265/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7265%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7265/b/2/A","parentIdentifier":"/us/usc/t15/s7265/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7265%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the preparation or auditing of financial statements of generally comparable issuers; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7265/b/2/B","parentIdentifier":"/us/usc/t15/s7265/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7265%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the application of such principles in connection with the accounting for estimates, accruals, and reserves;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s7265/b/3","parentIdentifier":"/us/usc/t15/s7265/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7265%2Fb%2F3","sourceRelease":"119-100","text":"experience with internal accounting controls; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s7265/b/4","parentIdentifier":"/us/usc/t15/s7265/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7265%2Fb%2F4","sourceRelease":"119-100","text":"an understanding of audit committee functions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Deadline for rulemaking","label":"c Deadline for rulemaking","identifier":"/us/usc/t15/s7265/c","parentIdentifier":"/us/usc/t15/s7265","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7265%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7265/c/1","parentIdentifier":"/us/usc/t15/s7265/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7265%2Fc%2F1","sourceRelease":"119-100","text":"propose rules to implement this section, not later than 90 days after ; andJuly 30, 2002","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7265/c/2","parentIdentifier":"/us/usc/t15/s7265/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7265%2Fc%2F2","sourceRelease":"119-100","text":"issue final rules to implement this section, not later than 180 days after .July 30, 2002","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
