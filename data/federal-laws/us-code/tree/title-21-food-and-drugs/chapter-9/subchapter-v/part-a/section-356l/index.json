{"type":"section","nativeType":"section","number":"356l","heading":"Advanced manufacturing technologies designation program","label":"356l Advanced manufacturing technologies designation program","identifier":"/us/usc/t21/s356l","parentIdentifier":"/us/usc/t21/ch9/schV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t21/s356l/a","parentIdentifier":"/us/usc/t21/s356l","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fa","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary shall initiate a program under which persons may request designation of an advanced manufacturing technology as described in subsection (b).December 29, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Designation process","label":"b Designation process","identifier":"/us/usc/t21/s356l/b","parentIdentifier":"/us/usc/t21/s356l","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s356l/b/1","parentIdentifier":"/us/usc/t21/s356l/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fb%2F1","sourceRelease":"119-100","text":"reducing development time for a drug using the designated manufacturing method; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s356l/b/2","parentIdentifier":"/us/usc/t21/s356l/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s356l/b/2/A","parentIdentifier":"/us/usc/t21/s356l/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fb%2F2%2FA","sourceRelease":"119-100","text":"a drug that is life-supporting, life-sustaining, or of critical importance to providing health care; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s356l/b/2/B","parentIdentifier":"/us/usc/t21/s356l/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fb%2F2%2FB","sourceRelease":"119-100","text":"a drug that is on the drug shortage list under .section 356e of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Evaluation and designation of an advanced manufacturing technology","label":"c Evaluation and designation of an advanced manufacturing technology","identifier":"/us/usc/t21/s356l/c","parentIdentifier":"/us/usc/t21/s356l","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Submission","label":"1 Submission","identifier":"/us/usc/t21/s356l/c/1","parentIdentifier":"/us/usc/t21/s356l/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s356l/c/1/A","parentIdentifier":"/us/usc/t21/s356l/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fc%2F1%2FA","sourceRelease":"119-100","text":"providing timely advice to, and interactive communication with, such person regarding the development of the method of manufacturing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s356l/c/1/B","parentIdentifier":"/us/usc/t21/s356l/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fc%2F1%2FB","sourceRelease":"119-100","text":"involving senior managers and experienced staff of the Food and Drug Administration, as appropriate, in a collaborative, cross-disciplinary review of the method of manufacturing, as applicable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Evaluation and designation","label":"2 Evaluation and designation","identifier":"/us/usc/t21/s356l/c/2","parentIdentifier":"/us/usc/t21/s356l/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fc%2F2","sourceRelease":"119-100","text":"Not later than 180 calendar days after the receipt of a request under paragraph (1), the Secretary shall determine whether to designate such method of manufacturing as an advanced manufacturing technology, in a particular context of use, based on the data and information submitted under paragraph (1) and the criteria described in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Review of advanced manufacturing technologies","label":"d Review of advanced manufacturing technologies","identifier":"/us/usc/t21/s356l/d","parentIdentifier":"/us/usc/t21/s356l","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s356l/d/1","parentIdentifier":"/us/usc/t21/s356l/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fd%2F1","sourceRelease":"119-100","text":"expedite the development and review of an application submitted under or , including supplemental applications, for drugs that are manufactured using a designated advanced manufacturing technology; andsection 355 of this titlesection 262 of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s356l/d/2","parentIdentifier":"/us/usc/t21/s356l/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fd%2F2","sourceRelease":"119-100","text":"allow the holder of an advanced technology designation, or a person authorized by the advanced manufacturing technology designation holder, to reference or rely upon, in an application submitted under or , including a supplemental application, data and information about the designated advanced manufacturing technology for use in manufacturing drugs in the same context of use for which the designation was granted.section 355 of this titlesection 262 of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Implementation and evaluation of advanced manufacturing technologies program","label":"e Implementation and evaluation of advanced manufacturing technologies program","identifier":"/us/usc/t21/s356l/e","parentIdentifier":"/us/usc/t21/s356l","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Public meeting","label":"1 Public meeting","identifier":"/us/usc/t21/s356l/e/1","parentIdentifier":"/us/usc/t21/s356l/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s356l/e/1/A","parentIdentifier":"/us/usc/t21/s356l/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F1%2FA","sourceRelease":"119-100","text":"the goals and scope of the program under this section, and the framework, procedures, and requirements suitable for such program; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s356l/e/1/B","parentIdentifier":"/us/usc/t21/s356l/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F1%2FB","sourceRelease":"119-100","text":"ways in which the Food and Drug Administration will support the use of advanced manufacturing technologies and other innovative manufacturing approaches for drugs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Program guidance","label":"2 Program guidance","identifier":"/us/usc/t21/s356l/e/2","parentIdentifier":"/us/usc/t21/s356l/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t21/s356l/e/2/A","parentIdentifier":"/us/usc/t21/s356l/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s356l/e/2/A/i","parentIdentifier":"/us/usc/t21/s356l/e/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F2%2FA%2Fi","sourceRelease":"119-100","text":"not later than 180 days after the public meeting under paragraph (1), issue draft guidance regarding the goals and implementation of the program under this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s356l/e/2/A/ii","parentIdentifier":"/us/usc/t21/s356l/e/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F2%2FA%2Fii","sourceRelease":"119-100","text":"not later than 2 years after , issue final guidance regarding the implementation of such program.December 29, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Content","label":"B Content","identifier":"/us/usc/t21/s356l/e/2/B","parentIdentifier":"/us/usc/t21/s356l/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t21/s356l/e/2/B/i","parentIdentifier":"/us/usc/t21/s356l/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the process by which a person may request a designation under subsection (b);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t21/s356l/e/2/B/ii","parentIdentifier":"/us/usc/t21/s356l/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the data and information that a person requesting such a designation is required to submit under subsection (c), and how the Secretary intends to evaluate such submissions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t21/s356l/e/2/B/iii","parentIdentifier":"/us/usc/t21/s356l/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"the process to expedite the development and review of applications under subsection (d); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t21/s356l/e/2/B/iv","parentIdentifier":"/us/usc/t21/s356l/e/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F2%2FB%2Fiv","sourceRelease":"119-100","text":"the criteria described in subsection (b) for eligibility for such a designation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Report","label":"3 Report","identifier":"/us/usc/t21/s356l/e/3","parentIdentifier":"/us/usc/t21/s356l/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t21/s356l/e/3/A","parentIdentifier":"/us/usc/t21/s356l/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F3%2FA","sourceRelease":"119-100","text":"The number of persons that have requested designations and that have been granted designations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t21/s356l/e/3/B","parentIdentifier":"/us/usc/t21/s356l/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F3%2FB","sourceRelease":"119-100","text":"The number of methods of manufacturing that have been the subject of designation requests and that have been granted designations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t21/s356l/e/3/C","parentIdentifier":"/us/usc/t21/s356l/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F3%2FC","sourceRelease":"119-100","text":"The average number of calendar days for completion of evaluations under subsection (c)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t21/s356l/e/3/D","parentIdentifier":"/us/usc/t21/s356l/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F3%2FD","sourceRelease":"119-100","text":"An analysis of the factors in data submissions that result in determinations to designate and not to designate after evaluation under subsection (c)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t21/s356l/e/3/E","parentIdentifier":"/us/usc/t21/s356l/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Fe%2F3%2FE","sourceRelease":"119-100","text":"The number of applications received under or , including supplemental applications, that have included an advanced manufacturing technology designated under this section, and the number of such applications approved.section 355 of this titlesection 262 of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Sunset","label":"f Sunset","identifier":"/us/usc/t21/s356l/f","parentIdentifier":"/us/usc/t21/s356l","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t21/s356l/f/1","parentIdentifier":"/us/usc/t21/s356l/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Ff%2F1","sourceRelease":"119-100","text":"may not consider any requests for designation submitted under subsection (c) after ; andOctober 1, 2032","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t21/s356l/f/2","parentIdentifier":"/us/usc/t21/s356l/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft21%2Fs356l%2Ff%2F2","sourceRelease":"119-100","text":"may continue all activities under this section with respect to advanced manufacturing technologies that were designated pursuant to subsection (b) prior to such date, if the Secretary determines such activities are in the interest of the public health.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
