{"type":"section","nativeType":"section","number":"129d","heading":"Disclosure to litigation support contractors","label":"129d Disclosure to litigation support contractors","identifier":"/us/usc/t10/s129d","parentIdentifier":"/us/usc/t10/stA/ptI/ch3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs129d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Disclosure Authority","label":"a .—Disclosure Authority","identifier":"/us/usc/t10/s129d/a","parentIdentifier":"/us/usc/t10/s129d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs129d%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s129d/a/1","parentIdentifier":"/us/usc/t10/s129d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs129d%2Fa%2F1","sourceRelease":"119-100","text":"the disclosure is for the sole purpose of providing litigation support to the Government in the form of administrative, technical, or professional services during or in anticipation of litigation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s129d/a/2","parentIdentifier":"/us/usc/t10/s129d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs129d%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s129d/a/2/A","parentIdentifier":"/us/usc/t10/s129d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs129d%2Fa%2F2%2FA","sourceRelease":"119-100","text":"that sensitive information furnished will be accessed and used only for the purposes stated in the relevant contract;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s129d/a/2/B","parentIdentifier":"/us/usc/t10/s129d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs129d%2Fa%2F2%2FB","sourceRelease":"119-100","text":"that the contractor will take all precautions necessary to prevent disclosure of the sensitive information provided to the contractor;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s129d/a/2/C","parentIdentifier":"/us/usc/t10/s129d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs129d%2Fa%2F2%2FC","sourceRelease":"119-100","text":"that such sensitive information provided to the contractor under the authority of this section shall not be used by the contractor to compete against a third party for Government or non-Government contracts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s129d/a/2/D","parentIdentifier":"/us/usc/t10/s129d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs129d%2Fa%2F2%2FD","sourceRelease":"119-100","text":"that the violation of subparagraph (A), (B), or (C) is a basis for the Government to terminate the litigation support contract of the contractor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Definitions","label":"b .—Definitions","identifier":"/us/usc/t10/s129d/b","parentIdentifier":"/us/usc/t10/s129d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs129d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s129d/b/1","parentIdentifier":"/us/usc/t10/s129d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs129d%2Fb%2F1","sourceRelease":"119-100","text":"The term “litigation support contractor” means a contractor (including an expert or technical consultant) under contract with the Department of Defense to provide litigation support.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s129d/b/2","parentIdentifier":"/us/usc/t10/s129d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs129d%2Fb%2F2","sourceRelease":"119-100","text":"The term “sensitive information” means confidential commercial, financial, or proprietary information, technical data, or other privileged information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
