{"type":"section","nativeType":"section","number":"15105","heading":"National Boating Safety Advisory Committee","label":"15105 National Boating Safety Advisory Committee","identifier":"/us/usc/t46/s15105","parentIdentifier":"/us/usc/t46/stII/ptK/ch151","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15105","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment","label":"a .—Establishment","identifier":"/us/usc/t46/s15105/a","parentIdentifier":"/us/usc/t46/s15105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15105%2Fa","sourceRelease":"119-100","text":"There is established a National Boating Safety Advisory Committee (in this section referred to as the “Committee”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Function","label":"b .—Function","identifier":"/us/usc/t46/s15105/b","parentIdentifier":"/us/usc/t46/s15105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15105%2Fb","sourceRelease":"119-100","text":"The Committee shall advise the Secretary on matters relating to national boating safety.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Membership.—","label":"c Membership.—","identifier":"/us/usc/t46/s15105/c","parentIdentifier":"/us/usc/t46/s15105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15105%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t46/s15105/c/1","parentIdentifier":"/us/usc/t46/s15105/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15105%2Fc%2F1","sourceRelease":"119-100","text":"The Committee shall consist of 21 members appointed by the Secretary in accordance with this section and section 15109 of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Expertise","label":"2 .—Expertise","identifier":"/us/usc/t46/s15105/c/2","parentIdentifier":"/us/usc/t46/s15105/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15105%2Fc%2F2","sourceRelease":"119-100","text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Representation","label":"3 .—Representation","identifier":"/us/usc/t46/s15105/c/3","parentIdentifier":"/us/usc/t46/s15105/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15105%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s15105/c/3/A","parentIdentifier":"/us/usc/t46/s15105/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15105%2Fc%2F3%2FA","sourceRelease":"119-100","text":"7 members shall represent State officials responsible for State boating safety programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s15105/c/3/B","parentIdentifier":"/us/usc/t46/s15105/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15105%2Fc%2F3%2FB","sourceRelease":"119-100","text":"7 members shall represent recreational vessel and associated equipment manufacturers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t46/s15105/c/3/C","parentIdentifier":"/us/usc/t46/s15105/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs15105%2Fc%2F3%2FC","sourceRelease":"119-100","text":"7 members shall represent the general public or national recreational boating organizations and, of the 7, at least 5 shall represent national recreational boating organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
