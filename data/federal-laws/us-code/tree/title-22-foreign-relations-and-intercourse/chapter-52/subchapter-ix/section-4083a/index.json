{"type":"section","nativeType":"section","number":"4083a","heading":"Rest and recuperation leave","label":"4083a Rest and recuperation leave","identifier":"/us/usc/t22/s4083a","parentIdentifier":"/us/usc/t22/ch52/schIX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t22/s4083a/a","parentIdentifier":"/us/usc/t22/s4083a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4083a/a/1","parentIdentifier":"/us/usc/t22/s4083a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fa%2F1","sourceRelease":"119-100","text":"the term “agency” means an Executive agency (as that term is defined in ), but does not include the Government Accountability Office;section 105 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4083a/a/2","parentIdentifier":"/us/usc/t22/s4083a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fa%2F2","sourceRelease":"119-100","text":"the term “combat zone” means a geographic area designated by an Executive order of the President as an area in which the Armed Forces are engaging or have engaged in combat, an area designated by law to be treated as a combat zone, or a location the Department of Defense has certified for combat zone tax benefits due to its direct support of military operations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s4083a/a/3","parentIdentifier":"/us/usc/t22/s4083a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s4083a/a/3/A","parentIdentifier":"/us/usc/t22/s4083a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fa%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s4083a/a/3/A/i","parentIdentifier":"/us/usc/t22/s4083a/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fa%2F3%2FA%2Fi","sourceRelease":"119-100","text":"The President.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s4083a/a/3/A/ii","parentIdentifier":"/us/usc/t22/s4083a/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fa%2F3%2FA%2Fii","sourceRelease":"119-100","text":"A Member or Members of Congress, or Congress.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t22/s4083a/a/3/A/iii","parentIdentifier":"/us/usc/t22/s4083a/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fa%2F3%2FA%2Fiii","sourceRelease":"119-100","text":"An individual who is an employee under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t22/s4083a/a/3/A/iv","parentIdentifier":"/us/usc/t22/s4083a/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fa%2F3%2FA%2Fiv","sourceRelease":"119-100","text":"The head of a Government-controlled corporation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s4083a/a/3/B","parentIdentifier":"/us/usc/t22/s4083a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fa%2F3%2FB","sourceRelease":"119-100","text":"engaged in the performance of a Federal function under authority of law or an Executive act; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s4083a/a/3/C","parentIdentifier":"/us/usc/t22/s4083a/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fa%2F3%2FC","sourceRelease":"119-100","text":"subject to the supervision of an individual described in subparagraph (A) while engaged in the performance of the duties of his or her position;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s4083a/a/4","parentIdentifier":"/us/usc/t22/s4083a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fa%2F4","sourceRelease":"119-100","text":"the term “high risk, high threat post” has the meaning given that term in ; andsection 4803 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s4083a/a/5","parentIdentifier":"/us/usc/t22/s4083a/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fa%2F5","sourceRelease":"119-100","text":"the term “leave year” means the period beginning on the first day of the first complete pay period in a calendar year and ending on the day immediately before the first day of the first complete pay period in the following calendar year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Leave for rest and recuperation","label":"b Leave for rest and recuperation","identifier":"/us/usc/t22/s4083a/b","parentIdentifier":"/us/usc/t22/s4083a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fb","sourceRelease":"119-100","text":"The Secretary or other head of an agency may prescribe regulations to grant up to 20 days of paid leave, per leave year, for the purposes of rest and recuperation to an employee of the agency serving in a combat zone, any other high risk, high threat post, or any other location presenting significant security or operational challenges.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Discretionary authority of the Secretary or other agency head","label":"c Discretionary authority of the Secretary or other agency head","identifier":"/us/usc/t22/s4083a/c","parentIdentifier":"/us/usc/t22/s4083a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fc","sourceRelease":"119-100","text":"Use of the authority under subsection (b) is at the sole and exclusive discretion of the head of the agency concerned.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Records","label":"d Records","identifier":"/us/usc/t22/s4083a/d","parentIdentifier":"/us/usc/t22/s4083a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4083a%2Fd","sourceRelease":"119-100","text":"An agency shall record leave provided under this section separately from leave authorized under any other provision of law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
