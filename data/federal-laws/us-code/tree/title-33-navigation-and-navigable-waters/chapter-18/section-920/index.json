{"type":"section","nativeType":"section","number":"920","heading":"Presumptions","label":"920 Presumptions","identifier":"/us/usc/t33/s920","parentIdentifier":"/us/usc/t33/ch18","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs920","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t33/s920/a","parentIdentifier":"/us/usc/t33/s920","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs920%2Fa","sourceRelease":"119-100","text":"That the claim comes within the provisions of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t33/s920/b","parentIdentifier":"/us/usc/t33/s920","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs920%2Fb","sourceRelease":"119-100","text":"That sufficient notice of such claim has been given.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t33/s920/c","parentIdentifier":"/us/usc/t33/s920","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs920%2Fc","sourceRelease":"119-100","text":"That the injury was not occasioned solely by the intoxication of the injured employee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t33/s920/d","parentIdentifier":"/us/usc/t33/s920","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs920%2Fd","sourceRelease":"119-100","text":"That the injury was not occasioned by the willful intention of the injured employee to injure or kill himself or another.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
