number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s1015/6/B/i/II","parentIdentifier":"/us/usc/t16/s1015/6/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fi%2FII","sourceRelease":"119-100","text":"livestock grazing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s1015/6/B/i/III","parentIdentifier":"/us/usc/t16/s1015/6/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fi%2FIII","sourceRelease":"119-100","text":"timber production;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t16/s1015/6/B/i/IV","parentIdentifier":"/us/usc/t16/s1015/6/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fi%2FIV","sourceRelease":"119-100","text":"land development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t16/s1015/6/B/i/V","parentIdentifier":"/us/usc/t16/s1015/6/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fi%2FV","sourceRelease":"119-100","text":"recreation or tourism;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VI","heading":null,"label":"VI","identifier":"/us/usc/t16/s1015/6/B/i/VI","parentIdentifier":"/us/usc/t16/s1015/6/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fi%2FVI","sourceRelease":"119-100","text":"irrigated agricultural production;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VII","heading":null,"label":"VII","identifier":"/us/usc/t16/s1015/6/B/i/VII","parentIdentifier":"/us/usc/t16/s1015/6/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fi%2FVII","sourceRelease":"119-100","text":"the environment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"VIII","heading":null,"label":"VIII","identifier":"/us/usc/t16/s1015/6/B/i/VIII","parentIdentifier":"/us/usc/t16/s1015/6/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fi%2FVIII","sourceRelease":"119-100","text":"potable water purveyors and industrial water users;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IX","heading":null,"label":"IX","identifier":"/us/usc/t16/s1015/6/B/i/IX","parentIdentifier":"/us/usc/t16/s1015/6/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fi%2FIX","sourceRelease":"119-100","text":"private property owners within the watershed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"X","heading":null,"label":"X","identifier":"/us/usc/t16/s1015/6/B/i/X","parentIdentifier":"/us/usc/t16/s1015/6/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fi%2FX","sourceRelease":"119-100","text":"disadvantaged communities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s1015/6/B/ii","parentIdentifier":"/us/usc/t16/s1015/6/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fii","sourceRelease":"119-100","text":"any Federal agency that has authority with respect to the watershed;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s1015/6/B/iii","parentIdentifier":"/us/usc/t16/s1015/6/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fiii","sourceRelease":"119-100","text":"any State agency that has authority with respect to the watershed;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s1015/6/B/iv","parentIdentifier":"/us/usc/t16/s1015/6/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fiv","sourceRelease":"119-100","text":"any local agency that has authority with respect to the watershed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t16/s1015/6/B/v","parentIdentifier":"/us/usc/t16/s1015/6/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fv","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s1015/6/B/v/I","parentIdentifier":"/us/usc/t16/s1015/6/B/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fv%2FI","sourceRelease":"119-100","text":"owns land within the watershed; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s1015/6/B/v/II","parentIdentifier":"/us/usc/t16/s1015/6/B/v","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FB%2Fv%2FII","sourceRelease":"119-100","text":"has land in the watershed that is held in trust;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s1015/6/C","parentIdentifier":"/us/usc/t16/s1015/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FC","sourceRelease":"119-100","text":"is a grassroots, nonregulatory entity that addresses water availability and quality issues within the relevant watershed;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s1015/6/D","parentIdentifier":"/us/usc/t16/s1015/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s1015/6/D/i","parentIdentifier":"/us/usc/t16/s1015/6/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FD%2Fi","sourceRelease":"119-100","text":"water conservation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s1015/6/D/ii","parentIdentifier":"/us/usc/t16/s1015/6/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FD%2Fii","sourceRelease":"119-100","text":"improved water quality;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s1015/6/D/iii","parentIdentifier":"/us/usc/t16/s1015/6/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FD%2Fiii","sourceRelease":"119-100","text":"ecological resiliency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t16/s1015/6/D/iv","parentIdentifier":"/us/usc/t16/s1015/6/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FD%2Fiv","sourceRelease":"119-100","text":"the reduction of water conflicts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s1015/6/E","parentIdentifier":"/us/usc/t16/s1015/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F6%2FE","sourceRelease":"119-100","text":"makes decisions on a consensus basis, as defined in the bylaws of the watershed group.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Watershed management project","label":"7 Watershed management project","identifier":"/us/usc/t16/s1015/7","parentIdentifier":"/us/usc/t16/s1015","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s1015/7/A","parentIdentifier":"/us/usc/t16/s1015/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F7%2FA","sourceRelease":"119-100","text":"enhances water conservation, including alternative water uses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s1015/7/B","parentIdentifier":"/us/usc/t16/s1015/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F7%2FB","sourceRelease":"119-100","text":"improves water quality;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s1015/7/C","parentIdentifier":"/us/usc/t16/s1015/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F7%2FC","sourceRelease":"119-100","text":"improves ecological resiliency of a river or stream, including benefits to fisheries, wildlife, or habitat;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s1015/7/D","parentIdentifier":"/us/usc/t16/s1015/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F7%2FD","sourceRelease":"119-100","text":"reduces the potential for water conflicts; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s1015/7/E","parentIdentifier":"/us/usc/t16/s1015/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs1015%2F7%2FE","sourceRelease":"119-100","text":"advances any other goals associated with water quality or quantity that the Secretary determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
