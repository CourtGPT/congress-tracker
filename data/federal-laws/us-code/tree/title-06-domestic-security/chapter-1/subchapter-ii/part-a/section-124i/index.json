{"type":"section","nativeType":"section","number":"124i","heading":"Homeland Security Information Sharing Fellows Program","label":"124i Homeland Security Information Sharing Fellows Program","identifier":"/us/usc/t6/s124i","parentIdentifier":"/us/usc/t6/ch1/schII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t6/s124i/a","parentIdentifier":"/us/usc/t6/s124i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s124i/a/1","parentIdentifier":"/us/usc/t6/s124i/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s124i/a/1/A","parentIdentifier":"/us/usc/t6/s124i/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s124i/a/1/A/i","parentIdentifier":"/us/usc/t6/s124i/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the relevant missions and capabilities of the Department and other Federal agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s124i/a/1/A/ii","parentIdentifier":"/us/usc/t6/s124i/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"the role, programs, products, and personnel of the Office of Intelligence and Analysis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s124i/a/1/B","parentIdentifier":"/us/usc/t6/s124i/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s124i/a/1/B/i","parentIdentifier":"/us/usc/t6/s124i/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"serve as a point of contact in the Department to assist in the representation of State, local, and tribal information requirements;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s124i/a/1/B/ii","parentIdentifier":"/us/usc/t6/s124i/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"identify information within the scope of the information sharing environment, including homeland security information, terrorism information, and weapons of mass destruction information, that is of interest to State, local, and tribal law enforcement officers, intelligence analysts, and other emergency response providers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t6/s124i/a/1/B/iii","parentIdentifier":"/us/usc/t6/s124i/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fa%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"assist Department analysts in preparing and disseminating products derived from information within the scope of the information sharing environment, including homeland security information, terrorism information, and weapons of mass destruction information, that are tailored to State, local, and tribal law enforcement officers and intelligence analysts and designed to prepare for and thwart acts of terrorism; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t6/s124i/a/1/B/iv","parentIdentifier":"/us/usc/t6/s124i/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fa%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"assist Department analysts in preparing products derived from information within the scope of the information sharing environment, including homeland security information, terrorism information, and weapons of mass destruction information, that are tailored to State, local, and tribal emergency response providers and assist in the dissemination of such products through appropriate Department channels.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Program name","label":"2 Program name","identifier":"/us/usc/t6/s124i/a/2","parentIdentifier":"/us/usc/t6/s124i/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fa%2F2","sourceRelease":"119-100","text":"The program under this section shall be known as the “Homeland Security Information Sharing Fellows Program”.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Eligibility","label":"b Eligibility","identifier":"/us/usc/t6/s124i/b","parentIdentifier":"/us/usc/t6/s124i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s124i/b/1","parentIdentifier":"/us/usc/t6/s124i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s124i/b/1/A","parentIdentifier":"/us/usc/t6/s124i/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fb%2F1%2FA","sourceRelease":"119-100","text":"have homeland security-related responsibilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s124i/b/1/B","parentIdentifier":"/us/usc/t6/s124i/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fb%2F1%2FB","sourceRelease":"119-100","text":"be eligible for an appropriate security clearance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s124i/b/1/C","parentIdentifier":"/us/usc/t6/s124i/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fb%2F1%2FC","sourceRelease":"119-100","text":"possess a valid need for access to classified information, as determined by the Under Secretary for Intelligence and Analysis;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s124i/b/1/D","parentIdentifier":"/us/usc/t6/s124i/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fb%2F1%2FD","sourceRelease":"119-100","text":"be an employee of an eligible entity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t6/s124i/b/1/E","parentIdentifier":"/us/usc/t6/s124i/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fb%2F1%2FE","sourceRelease":"119-100","text":"have undergone appropriate privacy and civil liberties training that is developed, supported, or sponsored by the Privacy Officer and the Officer for Civil Rights and Civil Liberties, in consultation with the Privacy and Civil Liberties Oversight Board established under .section 2000ee of title 42","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible entities","label":"2 Eligible entities","identifier":"/us/usc/t6/s124i/b/2","parentIdentifier":"/us/usc/t6/s124i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s124i/b/2/A","parentIdentifier":"/us/usc/t6/s124i/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fb%2F2%2FA","sourceRelease":"119-100","text":"a State, local, or regional fusion center;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s124i/b/2/B","parentIdentifier":"/us/usc/t6/s124i/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fb%2F2%2FB","sourceRelease":"119-100","text":"a State or local law enforcement or other government entity that serves a major metropolitan area, suburban area, or rural area, as determined by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s124i/b/2/C","parentIdentifier":"/us/usc/t6/s124i/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fb%2F2%2FC","sourceRelease":"119-100","text":"a State or local law enforcement or other government entity with port, border, or agricultural responsibilities, as determined by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s124i/b/2/D","parentIdentifier":"/us/usc/t6/s124i/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fb%2F2%2FD","sourceRelease":"119-100","text":"a tribal law enforcement or other authority; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t6/s124i/b/2/E","parentIdentifier":"/us/usc/t6/s124i/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fb%2F2%2FE","sourceRelease":"119-100","text":"such other entity as the Secretary determines is appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Optional participation","label":"c Optional participation","identifier":"/us/usc/t6/s124i/c","parentIdentifier":"/us/usc/t6/s124i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fc","sourceRelease":"119-100","text":"No State, local, or tribal law enforcement or other government entity shall be required to participate in the Homeland Security Information Sharing Fellows Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Procedures for nomination and selection","label":"d Procedures for nomination and selection","identifier":"/us/usc/t6/s124i/d","parentIdentifier":"/us/usc/t6/s124i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s124i/d/1","parentIdentifier":"/us/usc/t6/s124i/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fd%2F1","sourceRelease":"119-100","text":"The Under Secretary for Intelligence and Analysis shall establish procedures to provide for the nomination and selection of individuals to participate in the Homeland Security Information Sharing Fellows Program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Limitations","label":"2 Limitations","identifier":"/us/usc/t6/s124i/d/2","parentIdentifier":"/us/usc/t6/s124i/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s124i/d/2/A","parentIdentifier":"/us/usc/t6/s124i/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fd%2F2%2FA","sourceRelease":"119-100","text":"select law enforcement officers and intelligence analysts representing a broad cross-section of State, local, and tribal agencies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s124i/d/2/B","parentIdentifier":"/us/usc/t6/s124i/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs124i%2Fd%2F2%2FB","sourceRelease":"119-100","text":"ensure that the number of Information Sharing Fellows selected does not impede the activities of the Office of Intelligence and Analysis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
