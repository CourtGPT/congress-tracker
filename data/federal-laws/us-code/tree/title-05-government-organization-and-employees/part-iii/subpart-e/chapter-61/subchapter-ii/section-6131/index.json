{"type":"section","nativeType":"section","number":"6131","heading":"Criteria and review","label":"6131 Criteria and review","identifier":"/us/usc/t5/s6131","parentIdentifier":"/us/usc/t5/ptIII/sptE/ch61/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s6131/a","parentIdentifier":"/us/usc/t5/s6131","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6131/a/1","parentIdentifier":"/us/usc/t5/s6131/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fa%2F1","sourceRelease":"119-100","text":"establish such schedule; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6131/a/2","parentIdentifier":"/us/usc/t5/s6131/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fa%2F2","sourceRelease":"119-100","text":"continue such schedule, if the schedule has already been established.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s6131/b","parentIdentifier":"/us/usc/t5/s6131","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6131/b/1","parentIdentifier":"/us/usc/t5/s6131/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fb%2F1","sourceRelease":"119-100","text":"a reduction of the productivity of the agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6131/b/2","parentIdentifier":"/us/usc/t5/s6131/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fb%2F2","sourceRelease":"119-100","text":"a diminished level of services furnished to the public by the agency; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s6131/b/3","parentIdentifier":"/us/usc/t5/s6131/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fb%2F3","sourceRelease":"119-100","text":"an increase in the cost of agency operations (other than a reasonable administrative cost relating to the process of establishing a flexible or compressed schedule).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":null,"label":"c","identifier":"/us/usc/t5/s6131/c","parentIdentifier":"/us/usc/t5/s6131","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s6131/c/1","parentIdentifier":"/us/usc/t5/s6131/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fc%2F1","sourceRelease":"119-100","text":"This subsection shall apply in the case of any schedule covering employees in a unit represented by an exclusive representative.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s6131/c/2","parentIdentifier":"/us/usc/t5/s6131/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s6131/c/2/A","parentIdentifier":"/us/usc/t5/s6131/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fc%2F2%2FA","sourceRelease":"119-100","text":"If an agency and an exclusive representative reach an impasse in collective bargaining with respect to an agency determination under subsection (a)(1) not to establish a flexible or compressed schedule, the impasse shall be presented to the Federal Service Impasses Panel (hereinafter in this section referred to as the “Panel”).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s6131/c/2/B","parentIdentifier":"/us/usc/t5/s6131/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fc%2F2%2FB","sourceRelease":"119-100","text":"The Panel shall promptly consider any case presented under subparagraph (A), and shall take final action in favor of the agency’s determination if the finding on which it is based is supported by evidence that the schedule is likely to cause an adverse agency impact.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s6131/c/3","parentIdentifier":"/us/usc/t5/s6131/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s6131/c/3/A","parentIdentifier":"/us/usc/t5/s6131/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fc%2F3%2FA","sourceRelease":"119-100","text":"If an agency and an exclusive representative have entered into a collective bargaining agreement providing for use of a flexible or compressed schedule under this subchapter and the head of the agency determines under subsection (a)(2) to terminate a flexible or compressed schedule, the agency may reopen the agreement to seek termination of the schedule involved.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s6131/c/3/B","parentIdentifier":"/us/usc/t5/s6131/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fc%2F3%2FB","sourceRelease":"119-100","text":"If the agency and exclusive representative reach an impasse in collective bargaining with respect to terminating such schedule, the impasse shall be presented to the Panel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s6131/c/3/C","parentIdentifier":"/us/usc/t5/s6131/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fc%2F3%2FC","sourceRelease":"119-100","text":"The Panel shall promptly consider any case presented under subparagraph (B), and shall rule on such impasse not later than 60 days after the date the Panel is presented the impasse. The Panel shall take final action in favor of the agency’s determination to terminate a schedule if the finding on which the determination is based is supported by evidence that the schedule has caused an adverse agency impact.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t5/s6131/c/3/D","parentIdentifier":"/us/usc/t5/s6131/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fc%2F3%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t5/s6131/c/3/D/i","parentIdentifier":"/us/usc/t5/s6131/c/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fc%2F3%2FD%2Fi","sourceRelease":"119-100","text":"the agreement covering such schedule is renegotiated or expires or terminates pursuant to the terms of that agreement; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t5/s6131/c/3/D/ii","parentIdentifier":"/us/usc/t5/s6131/c/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fc%2F3%2FD%2Fii","sourceRelease":"119-100","text":"the date of the Panel’s final decision, if an impasse arose in the reopening of the agreement under subparagraph (A) of this paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":null,"label":"d","identifier":"/us/usc/t5/s6131/d","parentIdentifier":"/us/usc/t5/s6131","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs6131%2Fd","sourceRelease":"119-100","text":"This section shall not apply with respect to flexible schedules that may be established without regard to the authority provided under this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
