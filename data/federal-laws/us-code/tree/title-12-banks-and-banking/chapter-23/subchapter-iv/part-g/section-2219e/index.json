{"type":"section","nativeType":"section","number":"2219e","heading":"Liability for making criminal referrals","label":"2219e Liability for making criminal referrals","identifier":"/us/usc/t12/s2219e","parentIdentifier":"/us/usc/t12/ch23/schIV/ptG","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2219e","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Farm Credit System Reform Act of 1996, and not as part of the Farm Credit Act of 1971 which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t12/s2219e/a","parentIdentifier":"/us/usc/t12/s2219e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2219e%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s2219e/a/1","parentIdentifier":"/us/usc/t12/s2219e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2219e%2Fa%2F1","sourceRelease":"119-100","text":"for the disclosure; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s2219e/a/2","parentIdentifier":"/us/usc/t12/s2219e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2219e%2Fa%2F2","sourceRelease":"119-100","text":"for any failure to notify the person involved in the possible violation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"No prohibition on disclosure","label":"b No prohibition on disclosure","identifier":"/us/usc/t12/s2219e/b","parentIdentifier":"/us/usc/t12/s2219e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs2219e%2Fb","sourceRelease":"119-100","text":"Any institution of the Farm Credit System, or any director, officer, employee, or agent of a Farm Credit System institution, may disclose information to a Government authority that may be relevant to a possible violation of any law or regulation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
