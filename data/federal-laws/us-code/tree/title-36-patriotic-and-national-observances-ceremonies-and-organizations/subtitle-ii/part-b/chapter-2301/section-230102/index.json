{"type":"section","nativeType":"section","number":"230102","heading":"Purposes","label":"230102 Purposes","identifier":"/us/usc/t36/s230102","parentIdentifier":"/us/usc/t36/stII/ptB/ch2301","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230102","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevisedSectionSource (U.S. Code)Source (Statutes at Large)23010236:113., .May 28, 1936, ch. 471, § 349 Stat. 1391","Editorial Notes","Amendments2014—Par. (3). substituted “surviving spouses” for “widows”.Pub. L. 113–1992002— inserted “charitable,” before “and educational,” in introductory provisions.Pub. L. 107–242"],"amendments":["Historical and Revision NotesRevisedSectionSource (U.S. Code)Source (Statutes at Large)23010236:113., .May 28, 1936, ch. 471, § 349 Stat. 1391","Amendments2014—Par. (3). substituted “surviving spouses” for “widows”.Pub. L. 113–1992002— inserted “charitable,” before “and educational,” in introductory provisions.Pub. L. 107–242"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t36/s230102/1","parentIdentifier":"/us/usc/t36/s230102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230102%2F1","sourceRelease":"119-100","text":"to preserve and strengthen comradeship among its members;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t36/s230102/2","parentIdentifier":"/us/usc/t36/s230102","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs230102%2F2","sourceRelease":"119-100","text":"to assist worthy comrades;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t36/s230102/3","parentIdentifier":"/us/usc/t36/s230102","sourceUrl":