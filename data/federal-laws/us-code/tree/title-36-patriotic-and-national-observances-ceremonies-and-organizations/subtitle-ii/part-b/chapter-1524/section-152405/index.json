{"type":"section","nativeType":"section","number":"152405","heading":"Powers","label":"152405 Powers","identifier":"/us/usc/t36/s152405","parentIdentifier":"/us/usc/t36/stII/ptB/ch1524","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2008—Subsec. (b). substituted “jurisdiction in which the principal office of the corporation is located,” for “District of Columbia,” in introductory provisions.Pub. L. 110–336"],"amendments":["Amendments2008—Subsec. (b). substituted “jurisdiction in which the principal office of the corporation is located,” for “District of Columbia,” in introductory provisions.Pub. L. 110–336"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—General","label":"a .—General","identifier":"/us/usc/t36/s152405/a","parentIdentifier":"/us/usc/t36/s152405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t36/s152405/a/1","parentIdentifier":"/us/usc/t36/s152405/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405%2Fa%2F1","sourceRelease":"119-100","text":"adopt a constitution and bylaws;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t36/s152405/a/2","parentIdentifier":"/us/usc/t36/s152405/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405%2Fa%2F2","sourceRelease":"119-100","text":"adopt a seal which shall be judicially noticed; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t36/s152405/a/3","parentIdentifier":"/us/usc/t36/s152405/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405%2Fa%2F3","sourceRelease":"119-100","text":"do any other act necessary to carry out this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Powers as Trustee","label":"b .—Powers as Trustee","identifier":"/us/usc/t36/s152405/b","parentIdentifier":"/us/usc/t36/s152405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t36/s152405/b/1","parentIdentifier":"/us/usc/t36/s152405/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405%2Fb%2F1","sourceRelease":"119-100","text":"to accept, receive, solicit, hold, administer, and use any gift, devise, or bequest, either absolutely or in trust, of property or any income from or other interest in property;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t36/s152405/b/2","parentIdentifier":"/us/usc/t36/s152405/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405%2Fb%2F2","sourceRelease":"119-100","text":"to acquire property or an interest in property by purchase or exchange;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t36/s152405/b/3","parentIdentifier":"/us/usc/t36/s152405/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405%2Fb%2F3","sourceRelease":"119-100","text":"unless otherwise required by an instrument of transfer, to sell, donate, lease, invest, or otherwise dispose of any property or income from property;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t36/s152405/b/4","parentIdentifier":"/us/usc/t36/s152405/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405%2Fb%2F4","sourceRelease":"119-100","text":"to borrow money and issue instruments of indebtedness;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t36/s152405/b/5","parentIdentifier":"/us/usc/t36/s152405/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405%2Fb%2F5","sourceRelease":"119-100","text":"to make contracts and other arrangements with public agencies and private organizations and persons and to make payments necessary to carry out its functions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t36/s152405/b/6","parentIdentifier":"/us/usc/t36/s152405/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405%2Fb%2F6","sourceRelease":"119-100","text":"to sue and be sued; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t36/s152405/b/7","parentIdentifier":"/us/usc/t36/s152405/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405%2Fb%2F7","sourceRelease":"119-100","text":"to do any other act necessary and proper to carry out the purposes of the corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Encumbered or Restricted Gifts","label":"c .—Encumbered or Restricted Gifts","identifier":"/us/usc/t36/s152405/c","parentIdentifier":"/us/usc/t36/s152405","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs152405%2Fc","sourceRelease":"119-100","text":"A gift, devise, or bequest may be accepted by the corporation even though it is encumbered, restricted, or subject to beneficial interests of private persons, if any current or future interest is for the benefit of the corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
