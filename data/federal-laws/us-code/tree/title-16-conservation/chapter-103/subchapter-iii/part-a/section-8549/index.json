{"type":"section","nativeType":"section","number":"8549","heading":"Cost recovery reform","label":"8549 Cost recovery reform","identifier":"/us/usc/t16/s8549","parentIdentifier":"/us/usc/t16/ch103/schIII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8549","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Cost recovery for special recreation permits","label":"a Cost recovery for special recreation permits","identifier":"/us/usc/t16/s8549/a","parentIdentifier":"/us/usc/t16/s8549","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8549%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s8549/a/1","parentIdentifier":"/us/usc/t16/s8549/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8549%2Fa%2F1","sourceRelease":"119-100","text":"processing a proposal or application for the special recreation permit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s8549/a/2","parentIdentifier":"/us/usc/t16/s8549/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8549%2Fa%2F2","sourceRelease":"119-100","text":"issuing the special recreation permit; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s8549/a/3","parentIdentifier":"/us/usc/t16/s8549/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8549%2Fa%2F3","sourceRelease":"119-100","text":"monitoring the special recreation permit to ensure compliance with the terms and conditions of the special recreation permit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"De minimis exemption from cost recovery","label":"b De minimis exemption from cost recovery","identifier":"/us/usc/t16/s8549/b","parentIdentifier":"/us/usc/t16/s8549","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8549%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s8549/b/1","parentIdentifier":"/us/usc/t16/s8549/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8549%2Fb%2F1","sourceRelease":"119-100","text":"establish an hourly de minimis threshold that exempts a specified number of hours from the assessment and collection of administrative costs described in subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s8549/b/2","parentIdentifier":"/us/usc/t16/s8549/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8549%2Fb%2F2","sourceRelease":"119-100","text":"charge an applicant only for any hours that exceed the de minimis threshold.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Multiple applications","label":"c Multiple applications","identifier":"/us/usc/t16/s8549/c","parentIdentifier":"/us/usc/t16/s8549","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8549%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s8549/c/1","parentIdentifier":"/us/usc/t16/s8549/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8549%2Fc%2F1","sourceRelease":"119-100","text":"assess from the applicants the fee described in subsection (a) on a prorated basis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s8549/c/2","parentIdentifier":"/us/usc/t16/s8549/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8549%2Fc%2F2","sourceRelease":"119-100","text":"apply the exemption described in subsection (b) to each applicant on an individual basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Limitation","label":"d Limitation","identifier":"/us/usc/t16/s8549/d","parentIdentifier":"/us/usc/t16/s8549","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8549%2Fd","sourceRelease":"119-100","text":"The Secretary concerned shall not assess or collect administrative costs under this section for a programmatic environmental review.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Cost reduction","label":"e Cost reduction","identifier":"/us/usc/t16/s8549/e","parentIdentifier":"/us/usc/t16/s8549","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8549%2Fe","sourceRelease":"119-100","text":"To the maximum extent practicable, the agency processing an application for a special recreation permit shall use existing studies and analysis to reduce the quantity of work and costs necessary to process the application.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
