n expended or leveraged;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s8304/c/3","parentIdentifier":"/us/usc/t16/s8304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8304%2Fc%2F3","sourceRelease":"119-100","text":"a description of adaptive management practices implemented; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s8304/c/4","parentIdentifier":"/us/usc/t16/s8304/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs8304%2Fc%2F4","sourceRelease":"119-100","text":"a description of emerging challenges or data gaps that hinder the ability of the Coastal Program to achieve the purpose of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
