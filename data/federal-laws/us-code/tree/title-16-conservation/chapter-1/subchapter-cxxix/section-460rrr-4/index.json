{"type":"section","nativeType":"section","number":"460rrr–4","heading":"Management plan","label":"460rrr–4 Management plan","identifier":"/us/usc/t16/s460rrr–4","parentIdentifier":"/us/usc/t16/ch1/schCXXIX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s460rrr–4/a","parentIdentifier":"/us/usc/t16/s460rrr–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fa","sourceRelease":"119-100","text":"Not later than 4 years after , the Secretary and the Commission, in coordination with appropriate agencies in the State of Colorado, political subdivisions of the State, and private landowners in the Natural Area, shall prepare management plans for the Natural Area as provided in subsection (b).October 12, 2006","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Duties of Secretary and Commission","label":"b Duties of Secretary and Commission","identifier":"/us/usc/t16/s460rrr–4/b","parentIdentifier":"/us/usc/t16/s460rrr–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Secretary","label":"1 Secretary","identifier":"/us/usc/t16/s460rrr–4/b/1","parentIdentifier":"/us/usc/t16/s460rrr–4/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary shall prepare a management plan relating to the management of Federal land in the Natural Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Commission","label":"2 Commission","identifier":"/us/usc/t16/s460rrr–4/b/2","parentIdentifier":"/us/usc/t16/s460rrr–4/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s460rrr–4/b/2/A","parentIdentifier":"/us/usc/t16/s460rrr–4/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The Commission shall prepare a management plan relating to the management of the non-Federal land in the Natural Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Approval or disapproval","label":"B Approval or disapproval","identifier":"/us/usc/t16/s460rrr–4/b/2/B","parentIdentifier":"/us/usc/t16/s460rrr–4/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"In general","label":"i In general","identifier":"/us/usc/t16/s460rrr–4/b/2/B/i","parentIdentifier":"/us/usc/t16/s460rrr–4/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"The Commission shall submit to the Secretary the management plan prepared under subparagraph (A) for approval or disapproval.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Action following disapproval","label":"ii Action following disapproval","identifier":"/us/usc/t16/s460rrr–4/b/2/B/ii","parentIdentifier":"/us/usc/t16/s460rrr–4/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s460rrr–4/b/2/B/ii/I","parentIdentifier":"/us/usc/t16/s460rrr–4/b/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fb%2F2%2FB%2Fii%2FI","sourceRelease":"119-100","text":"notify the Commission of the reasons for the disapproval; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s460rrr–4/b/2/B/ii/II","parentIdentifier":"/us/usc/t16/s460rrr–4/b/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fb%2F2%2FB%2Fii%2FII","sourceRelease":"119-100","text":"allow the Commission to submit to the Secretary revisions to the management plan submitted under clause (i).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Cooperation","label":"3 Cooperation","identifier":"/us/usc/t16/s460rrr–4/b/3","parentIdentifier":"/us/usc/t16/s460rrr–4/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fb%2F3","sourceRelease":"119-100","text":"The Secretary and the Commission shall cooperate to ensure that the management plans relating to the management of Federal land and non-Federal land are consistent.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Requirements","label":"c Requirements","identifier":"/us/usc/t16/s460rrr–4/c","parentIdentifier":"/us/usc/t16/s460rrr–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460rrr–4/c/1","parentIdentifier":"/us/usc/t16/s460rrr–4/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fc%2F1","sourceRelease":"119-100","text":"take into consideration Federal, State, and local plans in existence on , to present a unified preservation, restoration, and conservation plan for the Natural Area;October 12, 2006","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460rrr–4/c/2","parentIdentifier":"/us/usc/t16/s460rrr–4/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460rrr–4/c/2/A","parentIdentifier":"/us/usc/t16/s460rrr–4/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fc%2F2%2FA","sourceRelease":"119-100","text":"be developed in accordance with ;section 1712 of title 43","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460rrr–4/c/2/B","parentIdentifier":"/us/usc/t16/s460rrr–4/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fc%2F2%2FB","sourceRelease":"119-100","text":"be consistent, to the maximum extent practicable, with the management plans adopted by the Director of the Bureau of Land Management for land adjacent to the Natural Area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s460rrr–4/c/2/C","parentIdentifier":"/us/usc/t16/s460rrr–4/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fc%2F2%2FC","sourceRelease":"119-100","text":"be considered to be an amendment to the San Luis Resource Management Plan of the Bureau of Land Management; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s460rrr–4/c/3","parentIdentifier":"/us/usc/t16/s460rrr–4/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460rrr–4/c/3/A","parentIdentifier":"/us/usc/t16/s460rrr–4/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fc%2F3%2FA","sourceRelease":"119-100","text":"an inventory of the resources contained in the Natural Area (including a list of property in the Natural Area that should be preserved, restored, managed, developed, maintained, or acquired to further the purposes of the Natural Area); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460rrr–4/c/3/B","parentIdentifier":"/us/usc/t16/s460rrr–4/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fc%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460rrr–4/c/3/B/i","parentIdentifier":"/us/usc/t16/s460rrr–4/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fc%2F3%2FB%2Fi","sourceRelease":"119-100","text":"protect the resources of the Natural Area; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460rrr–4/c/3/B/ii","parentIdentifier":"/us/usc/t16/s460rrr–4/c/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fc%2F3%2FB%2Fii","sourceRelease":"119-100","text":"provide for solitude, quiet use, and pristine natural values of the Natural Area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Publication","label":"d Publication","identifier":"/us/usc/t16/s460rrr–4/d","parentIdentifier":"/us/usc/t16/s460rrr–4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460rrr%E2%80%934%2Fd","sourceRelease":"119-100","text":"The Secretary shall publish notice of the management plans in the Federal Register.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
