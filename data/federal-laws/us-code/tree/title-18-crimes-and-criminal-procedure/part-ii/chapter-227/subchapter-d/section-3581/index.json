,"label":"7","identifier":"/us/usc/t18/s3581/b/7","parentIdentifier":"/us/usc/t18/s3581/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3581%2Fb%2F7","sourceRelease":"119-100","text":"for a Class B misdemeanor, not more than six months;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t18/s3581/b/8","parentIdentifier":"/us/usc/t18/s3581/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3581%2Fb%2F8","sourceRelease":"119-100","text":"for a Class C misdemeanor, not more than thirty days; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t18/s3581/b/9","parentIdentifier":"/us/usc/t18/s3581/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3581%2Fb%2F9","sourceRelease":"119-100","text":"for an infraction, not more than five days.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
