{"type":"section","nativeType":"section","number":"1377a","heading":"Green infrastructure promotion","label":"1377a Green infrastructure promotion","identifier":"/us/usc/t33/s1377a","parentIdentifier":"/us/usc/t33/ch26/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1377a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Prior ProvisionsA prior section 519 of act , was renumbered section 520 and is set out as a note under .June 30, 1948section 1251 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t33/s1377a/a","parentIdentifier":"/us/usc/t33/s1377a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1377a%2Fa","sourceRelease":"119-100","text":"The Administrator shall promote the use of green infrastructure in, and coordinate the integration of green infrastructure into, permitting and enforcement under this chapter, planning efforts, research, technical assistance, and funding guidance of the Environmental Protection Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Coordination of efforts","label":"b Coordination of efforts","identifier":"/us/usc/t33/s1377a/b","parentIdentifier":"/us/usc/t33/s1377a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1377a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s1377a/b/1","parentIdentifier":"/us/usc/t33/s1377a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs1377a%2Fb%2F1","sourceRelease":"119-100","text":"other Federal departments and agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]