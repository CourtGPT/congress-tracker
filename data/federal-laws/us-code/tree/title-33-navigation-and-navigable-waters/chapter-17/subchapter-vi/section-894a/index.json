{"type":"section","nativeType":"section","number":"894a","heading":"Actions to address sexual assault at National Oceanic and Atmospheric Administration","label":"894a Actions to address sexual assault at National Oceanic and Atmospheric Administration","identifier":"/us/usc/t33/s894a","parentIdentifier":"/us/usc/t33/ch17/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2020—Subsec. (b)(5)(B). substituted “can be reported on a restricted or unrestricted basis” for “can be confidentially reported”.Pub. L. 116–259"],"amendments":["Amendments2020—Subsec. (b)(5)(B). substituted “can be reported on a restricted or unrestricted basis” for “can be confidentially reported”.Pub. L. 116–259"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Comprehensive policy on prevention of and response to sexual assaults","label":"a Comprehensive policy on prevention of and response to sexual assaults","identifier":"/us/usc/t33/s894a/a","parentIdentifier":"/us/usc/t33/s894a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fa","sourceRelease":"119-100","text":"Not later than 1 year after , the Secretary of Commerce shall, acting through the Under Secretary for Oceans and Atmosphere, develop a comprehensive policy on the prevention of and response to sexual assaults involving employees of the National Oceanic and Atmospheric Administration, members of the commissioned officer corps of the Administration, and individuals who work with or conduct business on behalf of the Administration.December 23, 2016","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Elements of comprehensive policy","label":"b Elements of comprehensive policy","identifier":"/us/usc/t33/s894a/b","parentIdentifier":"/us/usc/t33/s894a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s894a/b/1","parentIdentifier":"/us/usc/t33/s894a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F1","sourceRelease":"119-100","text":"Prevention measures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s894a/b/2","parentIdentifier":"/us/usc/t33/s894a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F2","sourceRelease":"119-100","text":"Education and training on prevention and response.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s894a/b/3","parentIdentifier":"/us/usc/t33/s894a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s894a/b/3/A","parentIdentifier":"/us/usc/t33/s894a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F3%2FA","sourceRelease":"119-100","text":"options and contact information for after-hours contact; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s894a/b/3/B","parentIdentifier":"/us/usc/t33/s894a/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F3%2FB","sourceRelease":"119-100","text":"a procedure for obtaining assistance and reporting sexual assault while working in a remote scientific field camp, at sea, or in another field status.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t33/s894a/b/4","parentIdentifier":"/us/usc/t33/s894a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F4","sourceRelease":"119-100","text":"Easy and ready availability of information described in paragraph (3).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t33/s894a/b/5","parentIdentifier":"/us/usc/t33/s894a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s894a/b/5/A","parentIdentifier":"/us/usc/t33/s894a/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F5%2FA","sourceRelease":"119-100","text":"questions regarding sexual assault can be confidentially asked and confidentially answered; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s894a/b/5/B","parentIdentifier":"/us/usc/t33/s894a/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F5%2FB","sourceRelease":"119-100","text":"incidents of sexual assault can be reported on a restricted or unrestricted basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t33/s894a/b/6","parentIdentifier":"/us/usc/t33/s894a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F6","sourceRelease":"119-100","text":"Protocols for the investigation of complaints by command and law enforcement personnel.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t33/s894a/b/7","parentIdentifier":"/us/usc/t33/s894a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F7","sourceRelease":"119-100","text":"Prohibiting retaliation and consequences for retaliatory actions against someone who reports a sexual assault.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t33/s894a/b/8","parentIdentifier":"/us/usc/t33/s894a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F8","sourceRelease":"119-100","text":"Oversight by the Under Secretary of administrative and disciplinary actions in response to substantiated incidents of sexual assault.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t33/s894a/b/9","parentIdentifier":"/us/usc/t33/s894a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F9","sourceRelease":"119-100","text":"Victim advocacy, including establishment of and the responsibilities and training requirements for victim advocates as described in subsection (c).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t33/s894a/b/10","parentIdentifier":"/us/usc/t33/s894a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fb%2F10","sourceRelease":"119-100","text":"Availability of resources for victims of sexual assault within other Federal agencies and State, local, and national organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Victim advocacy","label":"c Victim advocacy","identifier":"/us/usc/t33/s894a/c","parentIdentifier":"/us/usc/t33/s894a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t33/s894a/c/1","parentIdentifier":"/us/usc/t33/s894a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary, acting through the Under Secretary, shall establish victim advocates to advocate for victims of sexual assaults involving employees of the Administration, members of the commissioned officer corps of the Administration, and individuals who work with or conduct business on behalf of the Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Victim advocates","label":"2 Victim advocates","identifier":"/us/usc/t33/s894a/c/2","parentIdentifier":"/us/usc/t33/s894a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s894a/c/2/A","parentIdentifier":"/us/usc/t33/s894a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F2%2FA","sourceRelease":"119-100","text":"is trained in matters relating to sexual assault and the comprehensive policy developed under subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s894a/c/2/B","parentIdentifier":"/us/usc/t33/s894a/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F2%2FB","sourceRelease":"119-100","text":"serves as a victim advocate voluntarily and in addition to the employee’s other duties as an employee of the Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Primary duties","label":"3 Primary duties","identifier":"/us/usc/t33/s894a/c/3","parentIdentifier":"/us/usc/t33/s894a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s894a/c/3/A","parentIdentifier":"/us/usc/t33/s894a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F3%2FA","sourceRelease":"119-100","text":"Supporting victims of sexual assault and informing them of their rights and the resources available to them as victims.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s894a/c/3/B","parentIdentifier":"/us/usc/t33/s894a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F3%2FB","sourceRelease":"119-100","text":"Acting as a companion in navigating investigative, medical, mental and emotional health, and recovery processes relating to sexual assault.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s894a/c/3/C","parentIdentifier":"/us/usc/t33/s894a/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F3%2FC","sourceRelease":"119-100","text":"Helping to identify resources to ensure the safety of victims of sexual assault.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Location","label":"4 Location","identifier":"/us/usc/t33/s894a/c/4","parentIdentifier":"/us/usc/t33/s894a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s894a/c/4/A","parentIdentifier":"/us/usc/t33/s894a/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F4%2FA","sourceRelease":"119-100","text":"in each region in which the Administration conducts operations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s894a/c/4/B","parentIdentifier":"/us/usc/t33/s894a/c/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F4%2FB","sourceRelease":"119-100","text":"in each marine and aviation center of the Administration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Hotline","label":"5 Hotline","identifier":"/us/usc/t33/s894a/c/5","parentIdentifier":"/us/usc/t33/s894a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t33/s894a/c/5/A","parentIdentifier":"/us/usc/t33/s894a/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F5%2FA","sourceRelease":"119-100","text":"In carrying out this subsection, the Secretary shall provide a telephone number at which a victim of a sexual assault can contact a victim advocate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"24-hour access","label":"B 24-hour access","identifier":"/us/usc/t33/s894a/c/5/B","parentIdentifier":"/us/usc/t33/s894a/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F5%2FB","sourceRelease":"119-100","text":"The Secretary shall ensure that the telephone number established under subparagraph (A) is monitored at all times.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Partnership","label":"C Partnership","identifier":"/us/usc/t33/s894a/c/5/C","parentIdentifier":"/us/usc/t33/s894a/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F5%2FC","sourceRelease":"119-100","text":"The Secretary shall, where possible, use established hotlines for purposes of this paragraph.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Formal relationships with other entities","label":"6 Formal relationships with other entities","identifier":"/us/usc/t33/s894a/c/6","parentIdentifier":"/us/usc/t33/s894a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fc%2F6","sourceRelease":"119-100","text":"The Secretary may enter into formal relationships with other entities to make available additional victim advocates.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Availability of policy","label":"d Availability of policy","identifier":"/us/usc/t33/s894a/d","parentIdentifier":"/us/usc/t33/s894a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s894a/d/1","parentIdentifier":"/us/usc/t33/s894a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fd%2F1","sourceRelease":"119-100","text":"all employees of the Administration and members of the commissioned officer corps of the Administration, including those employees and members who conduct field work for the Administration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s894a/d/2","parentIdentifier":"/us/usc/t33/s894a/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fd%2F2","sourceRelease":"119-100","text":"the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Consultation and assistance","label":"e Consultation and assistance","identifier":"/us/usc/t33/s894a/e","parentIdentifier":"/us/usc/t33/s894a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs894a%2Fe","sourceRelease":"119-100","text":"In developing the policy required by subsection (a), the Secretary may consult or receive assistance from such State, local, and national organizations and subject matter experts as the Secretary considers appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
