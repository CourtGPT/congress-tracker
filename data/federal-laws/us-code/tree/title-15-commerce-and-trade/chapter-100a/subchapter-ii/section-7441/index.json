Fus%2Fusc%2Ft15%2Fs7441%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7441/e/1","parentIdentifier":"/us/usc/t15/s7441/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7441%2Fe%2F1","sourceRelease":"119-100","text":"shall consult widely both within and outside the Federal Government; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7441/e/2","parentIdentifier":"/us/usc/t15/s7441/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7441%2Fe%2F2","sourceRelease":"119-100","text":"may empanel advisory committees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Internships","label":"f Internships","identifier":"/us/usc/t15/s7441/f","parentIdentifier":"/us/usc/t15/s7441","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7441%2Ff","sourceRelease":"119-100","text":"The Director of the Office of Personnel Management may support, as appropriate, internships or other work experience in the Federal Government to the winners of the competitions and challenges under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
