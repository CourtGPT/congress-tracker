{"type":"section","nativeType":"section","number":"7530","heading":"Application of earned income tax credit to possessions of the United States","label":"7530 Application of earned income tax credit to possessions of the United States","identifier":"/us/usc/t26/s7530","parentIdentifier":"/us/usc/t26/stF/ch77","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Puerto Rico","label":"a Puerto Rico","identifier":"/us/usc/t26/s7530/a","parentIdentifier":"/us/usc/t26/s7530","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t26/s7530/a/1","parentIdentifier":"/us/usc/t26/s7530/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s7530/a/1/A","parentIdentifier":"/us/usc/t26/s7530/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the specified matching amount for such calendar year, plus","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s7530/a/1/B","parentIdentifier":"/us/usc/t26/s7530/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s7530/a/1/B/i","parentIdentifier":"/us/usc/t26/s7530/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the expenditures made by Puerto Rico during such calendar year for education efforts with respect to individual taxpayers and tax return preparers relating to the earned income tax credit, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s7530/a/1/B/ii","parentIdentifier":"/us/usc/t26/s7530/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"$1,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirement to reform earned income tax credit","label":"2 Requirement to reform earned income tax credit","identifier":"/us/usc/t26/s7530/a/2","parentIdentifier":"/us/usc/t26/s7530/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F2","sourceRelease":"119-100","text":"The Secretary shall not make any payments under paragraph (1) with respect to any calendar year unless Puerto Rico has in effect an earned income tax credit for taxable years beginning in or with such calendar year which (relative to the earned income tax credit which was in effect for taxable years beginning in or with calendar year 2019) increases the percentage of earned income which is allowed as a credit for each group of individuals with respect to which such percentage is separately stated or determined in a manner designed to substantially increase workforce participation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Specified matching amount","label":"3 Specified matching amount","identifier":"/us/usc/t26/s7530/a/3","parentIdentifier":"/us/usc/t26/s7530/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t26/s7530/a/3/A","parentIdentifier":"/us/usc/t26/s7530/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s7530/a/3/A/i","parentIdentifier":"/us/usc/t26/s7530/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F3%2FA%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t26/s7530/a/3/A/i/I","parentIdentifier":"/us/usc/t26/s7530/a/3/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F3%2FA%2Fi%2FI","sourceRelease":"119-100","text":"the cost to Puerto Rico of the earned income tax credit for taxable years beginning in or with such calendar year, over","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t26/s7530/a/3/A/i/II","parentIdentifier":"/us/usc/t26/s7530/a/3/A/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F3%2FA%2Fi%2FII","sourceRelease":"119-100","text":"the base amount for such calendar year, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s7530/a/3/A/ii","parentIdentifier":"/us/usc/t26/s7530/a/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F3%2FA%2Fii","sourceRelease":"119-100","text":"the product of 3, multiplied by the base amount for such calendar year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Base amount","label":"B Base amount","identifier":"/us/usc/t26/s7530/a/3/B","parentIdentifier":"/us/usc/t26/s7530/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"Base amount for 2021","label":"i Base amount for 2021","identifier":"/us/usc/t26/s7530/a/3/B/i","parentIdentifier":"/us/usc/t26/s7530/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F3%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t26/s7530/a/3/B/i/I","parentIdentifier":"/us/usc/t26/s7530/a/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F3%2FB%2Fi%2FI","sourceRelease":"119-100","text":"the cost to Puerto Rico of the earned income tax credit for taxable years beginning in or with calendar year 2019 (rounded to the nearest multiple of $1,000,000), or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t26/s7530/a/3/B/i/II","parentIdentifier":"/us/usc/t26/s7530/a/3/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F3%2FB%2Fi%2FII","sourceRelease":"119-100","text":"$200,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Inflation adjustment","label":"ii Inflation adjustment","identifier":"/us/usc/t26/s7530/a/3/B/ii","parentIdentifier":"/us/usc/t26/s7530/a/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F3%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t26/s7530/a/3/B/ii/I","parentIdentifier":"/us/usc/t26/s7530/a/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F3%2FB%2Fii%2FI","sourceRelease":"119-100","text":"such dollar amount, multiplied by—","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t26/s7530/a/3/B/ii/II","parentIdentifier":"/us/usc/t26/s7530/a/3/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F3%2FB%2Fii%2FII","sourceRelease":"119-100","text":"the cost-of-living adjustment determined under section 1(f)(3) for such calendar year, determined by substituting “calendar year 2020” for “calendar year 2016” in subparagraph (A)(ii) thereof.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Rules related to payments","label":"4 Rules related to payments","identifier":"/us/usc/t26/s7530/a/4","parentIdentifier":"/us/usc/t26/s7530/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Timing of payments","label":"A Timing of payments","identifier":"/us/usc/t26/s7530/a/4/A","parentIdentifier":"/us/usc/t26/s7530/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s7530/a/4/A/i","parentIdentifier":"/us/usc/t26/s7530/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F4%2FA%2Fi","sourceRelease":"119-100","text":"after receipt of such information as the Secretary may require to determine such payments, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s7530/a/4/A/ii","parentIdentifier":"/us/usc/t26/s7530/a/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F4%2FA%2Fii","sourceRelease":"119-100","text":"except as provided in clause (i), within a reasonable period of time before the due date for individual income tax returns (as determined under the laws of Puerto Rico) for taxable years which began on the first day of such calendar year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Information","label":"B Information","identifier":"/us/usc/t26/s7530/a/4/B","parentIdentifier":"/us/usc/t26/s7530/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F4%2FB","sourceRelease":"119-100","text":"The Secretary may require the reporting of such information as the Secretary may require to carry out this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Determination of cost of earned income tax credit","label":"C Determination of cost of earned income tax credit","identifier":"/us/usc/t26/s7530/a/4/C","parentIdentifier":"/us/usc/t26/s7530/a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fa%2F4%2FC","sourceRelease":"119-100","text":"For purposes of this subsection, the cost to Puerto Rico of the earned income tax credit shall be determined by the Secretary on the basis of the laws of Puerto Rico and shall include reductions in revenues received by Puerto Rico by reason of such credit and refunds attributable to such credit, but shall not include any administrative costs with respect to such credit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Possessions with mirror code tax systems","label":"b Possessions with mirror code tax systems","identifier":"/us/usc/t26/s7530/b","parentIdentifier":"/us/usc/t26/s7530","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t26/s7530/b/1","parentIdentifier":"/us/usc/t26/s7530/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s7530/b/1/A","parentIdentifier":"/us/usc/t26/s7530/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fb%2F1%2FA","sourceRelease":"119-100","text":"the cost to such possession of the earned income tax credit for taxable years beginning in or with such calendar year, plus","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s7530/b/1/B","parentIdentifier":"/us/usc/t26/s7530/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s7530/b/1/B/i","parentIdentifier":"/us/usc/t26/s7530/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the expenditures made by such possession during such calendar year for education efforts with respect to individual taxpayers and tax return preparers relating to such earned income tax credit, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s7530/b/1/B/ii","parentIdentifier":"/us/usc/t26/s7530/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"$50,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Application of certain rules","label":"2 Application of certain rules","identifier":"/us/usc/t26/s7530/b/2","parentIdentifier":"/us/usc/t26/s7530/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fb%2F2","sourceRelease":"119-100","text":"Rules similar to the rules of subparagraphs (A), (B), and (C) of subsection (a)(4) shall apply for purposes of this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"American Samoa","label":"c American Samoa","identifier":"/us/usc/t26/s7530/c","parentIdentifier":"/us/usc/t26/s7530","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t26/s7530/c/1","parentIdentifier":"/us/usc/t26/s7530/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s7530/c/1/A","parentIdentifier":"/us/usc/t26/s7530/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fc%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s7530/c/1/A/i","parentIdentifier":"/us/usc/t26/s7530/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fc%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the cost to American Samoa of the earned income tax credit for taxable years beginning in or with such calendar year, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s7530/c/1/A/ii","parentIdentifier":"/us/usc/t26/s7530/c/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fc%2F1%2FA%2Fii","sourceRelease":"119-100","text":"$16,000,000, plus","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s7530/c/1/B","parentIdentifier":"/us/usc/t26/s7530/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t26/s7530/c/1/B/i","parentIdentifier":"/us/usc/t26/s7530/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the expenditures made by American Samoa during such calendar year for education efforts with respect to individual taxpayers and tax return preparers relating to such earned income tax credit, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t26/s7530/c/1/B/ii","parentIdentifier":"/us/usc/t26/s7530/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"$50,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirement to enact and maintain an earned income tax credit","label":"2 Requirement to enact and maintain an earned income tax credit","identifier":"/us/usc/t26/s7530/c/2","parentIdentifier":"/us/usc/t26/s7530/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fc%2F2","sourceRelease":"119-100","text":"The Secretary shall not make any payments under paragraph (1) with respect to any calendar year unless American Samoa has in effect an earned income tax credit for taxable years beginning in or with such calendar year which allows a refundable tax credit to individuals on the basis of the taxpayer’s earned income which is designed to substantially increase workforce participation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Inflation adjustment","label":"3 Inflation adjustment","identifier":"/us/usc/t26/s7530/c/3","parentIdentifier":"/us/usc/t26/s7530/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fc%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s7530/c/3/A","parentIdentifier":"/us/usc/t26/s7530/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fc%2F3%2FA","sourceRelease":"119-100","text":"such dollar amount, multiplied by—","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s7530/c/3/B","parentIdentifier":"/us/usc/t26/s7530/c/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fc%2F3%2FB","sourceRelease":"119-100","text":"the cost-of-living adjustment determined under section 1(f)(3) for such calendar year, determined by substituting “calendar year 2020” for “calendar year 2016” in subparagraph (A)(ii) thereof.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Application of certain rules","label":"4 Application of certain rules","identifier":"/us/usc/t26/s7530/c/4","parentIdentifier":"/us/usc/t26/s7530/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fc%2F4","sourceRelease":"119-100","text":"Rules similar to the rules of subparagraphs (A), (B), and (C) of subsection (a)(4) shall apply for purposes of this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Treatment of payments","label":"d Treatment of payments","identifier":"/us/usc/t26/s7530/d","parentIdentifier":"/us/usc/t26/s7530","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs7530%2Fd","sourceRelease":"119-100","text":"For purposes of , United States Code, the payments under this section shall be treated in the same manner as a refund due from a credit provision referred to in subsection (b)(2) of such section.section 1324 of title 31","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
