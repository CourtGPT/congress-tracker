{"type":"section","nativeType":"section","number":"150409","heading":"Restrictions","label":"150409 Restrictions","identifier":"/us/usc/t36/s150409","parentIdentifier":"/us/usc/t36/stII/ptB/ch1504","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150409","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Stock and Dividends","label":"a .—Stock and Dividends","identifier":"/us/usc/t36/s150409/a","parentIdentifier":"/us/usc/t36/s150409","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150409%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t36/s150409/a/1","parentIdentifier":"/us/usc/t36/s150409/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150409%2Fa%2F1","sourceRelease":"119-100","text":"issue any shares of stock; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t36/s150409/a/2","parentIdentifier":"/us/usc/t36/s150409/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150409%2Fa%2F2","sourceRelease":"119-100","text":"declare or pay any dividends.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Distribution of Income or Assets","label":"b .—Distribution of Income or Assets","identifier":"/us/usc/t36/s150409/b","parentIdentifier":"/us/usc/t36/s150409","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150409%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t36/s150409/b/1","parentIdentifier":"/us/usc/t36/s150409/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150409%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t36/s150409/b/1/A","parentIdentifier":"/us/usc/t36/s150409/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150409%2Fb%2F1%2FA","sourceRelease":"119-100","text":"inure to any person who is a member, officer, or director of the corporation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t36/s150409/b/1/B","parentIdentifier":"/us/usc/t36/s150409/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150409%2Fb%2F1%2FB","sourceRelease":"119-100","text":"be distributed to any such person during the life of the charter granted by this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Effect","label":"2 .—Effect","identifier":"/us/usc/t36/s150409/b/2","parentIdentifier":"/us/usc/t36/s150409/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150409%2Fb%2F2","sourceRelease":"119-100","text":"Nothing in this subsection prevents the payment of reasonable compensation to the officers of the corporation, or reimbursement for actual and necessary expenses, in amounts approved by the board of directors.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Loans","label":"c .—Loans","identifier":"/us/usc/t36/s150409/c","parentIdentifier":"/us/usc/t36/s150409","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150409%2Fc","sourceRelease":"119-100","text":"The corporation may not make any loan to any officer, director, member, or employee of the corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—No Federal Endorsement","label":"d .—No Federal Endorsement","identifier":"/us/usc/t36/s150409/d","parentIdentifier":"/us/usc/t36/s150409","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs150409%2Fd","sourceRelease":"119-100","text":"The corporation may not claim congressional approval or Federal Government authority by virtue of the charter granted by this chapter for any of the activities of the corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
