{"type":"section","nativeType":"section","number":"7144d","heading":"Office of Arctic Energy","label":"7144d Office of Arctic Energy","identifier":"/us/usc/t42/s7144d","parentIdentifier":"/us/usc/t42/ch84/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7144d","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","CodificationSection was enacted as part of the Floyd D. Spence National Defense Authorization Act for Fiscal Year 2001, and not as part of the Department of Energy Organization Act which comprises this chapter."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t42/s7144d/a","parentIdentifier":"/us/usc/t42/s7144d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7144d%2Fa","sourceRelease":"119-100","text":"The Secretary of Energy may establish within the Department of Energy an Office of Arctic Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Purposes","label":"b Purposes","identifier":"/us/usc/t42/s7144d/b","parentIdentifier":"/us/usc/t42/s7144d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7144d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s7144d/b/1","parentIdentifier":"/us/usc/t42/s7144d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7144d%2Fb%2F1","sourceRelease":"119-100","text":"To promote research, development, and deployment of electric power technology that is cost-effective and especially well suited to meet the needs of rural and remote regions of the United States, especially where permafrost is present or located nearby.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s7144d/b/2","parentIdentifier":"/us/usc/t42/s7144d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7144d%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7144d/b/2/A","parentIdentifier":"/us/usc/t42/s7144d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7144d%2Fb%2F2%2FA","sourceRelease":"119-100","text":"enhanced oil recovery technology, including heavy oil recovery, reinjection of carbon, and extended reach drilling technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7144d/b/2/B","parentIdentifier":"/us/usc/t42/s7144d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7144d%2Fb%2F2%2FB","sourceRelease":"119-100","text":"gas-to-liquids technology and liquified natural gas (including associated transportation systems);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s7144d/b/2/C","parentIdentifier":"/us/usc/t42/s7144d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7144d%2Fb%2F2%2FC","sourceRelease":"119-100","text":"small hydroelectric facilities, river turbines, and tidal power;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s7144d/b/2/D","parentIdentifier":"/us/usc/t42/s7144d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7144d%2Fb%2F2%2FD","sourceRelease":"119-100","text":"natural gas hydrates, coal bed methane, and shallow bed natural gas; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s7144d/b/2/E","parentIdentifier":"/us/usc/t42/s7144d/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7144d%2Fb%2F2%2FE","sourceRelease":"119-100","text":"alternative energy, including wind, geothermal, and fuel cells.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Location","label":"c Location","identifier":"/us/usc/t42/s7144d/c","parentIdentifier":"/us/usc/t42/s7144d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7144d%2Fc","sourceRelease":"119-100","text":"The Secretary shall locate such office at a university with expertise and experience in the matters specified in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
