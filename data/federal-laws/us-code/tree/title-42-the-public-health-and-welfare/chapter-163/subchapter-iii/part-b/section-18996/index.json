{"type":"section","nativeType":"section","number":"18996","heading":"Cybersecurity workforce data initiative","label":"18996 Cybersecurity workforce data initiative","identifier":"/us/usc/t42/s18996","parentIdentifier":"/us/usc/t42/ch163/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18996","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s18996/1","parentIdentifier":"/us/usc/t42/s18996","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18996%2F1","sourceRelease":"119-100","text":"assesses the feasibility of providing nationally representative estimates and statistical information on the cybersecurity workforce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s18996/2","parentIdentifier":"/us/usc/t42/s18996","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18996%2F2","sourceRelease":"119-100","text":"utilizes the National Initiative for Cybersecurity Education (NICE) Cybersecurity Workforce Framework (NIST Special Publication 800–181), or other frameworks, as appropriate, to enable a consistent measurement of the cybersecurity workforce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s18996/3","parentIdentifier":"/us/usc/t42/s18996","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18996%2F3","sourceRelease":"119-100","text":"utilizes and complements existing data on employer requirements and unfilled positions in the cybersecurity workforce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s18996/4","parentIdentifier":"/us/usc/t42/s18996","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18996%2F4","sourceRelease":"119-100","text":"consults key stakeholders and the broader community of practice in cybersecurity workforce development to determine data requirements needed to strengthen the cybersecurity workforce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s18996/5","parentIdentifier":"/us/usc/t42/s18996","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18996%2F5","sourceRelease":"119-100","text":"evaluates existing Federal survey data for information pertinent to developing national estimates of the cybersecurity workforce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s18996/6","parentIdentifier":"/us/usc/t42/s18996","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18996%2F6","sourceRelease":"119-100","text":"evaluates administrative data and other supplementary data sources, as available, to describe and measure the cybersecurity workforce; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s18996/7","parentIdentifier":"/us/usc/t42/s18996","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18996%2F7","sourceRelease":"119-100","text":"collects statistical data, to the greatest extent practicable, on credential attainment and employment outcomes information for the cybersecurity workforce.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
