{"type":"section","nativeType":"section","number":"4261","heading":"Statement of policy on international cooperation to combat marine debris","label":"4261 Statement of policy on international cooperation to combat marine debris","identifier":"/us/usc/t33/s4261","parentIdentifier":"/us/usc/t33/ch55/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s4261/1","parentIdentifier":"/us/usc/t33/s4261","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s4261/1/A","parentIdentifier":"/us/usc/t33/s4261/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F1%2FA","sourceRelease":"119-100","text":"the linkages between the sources of plastic waste, mismanaged waste and post-consumer materials, and marine debris; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s4261/1/B","parentIdentifier":"/us/usc/t33/s4261/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F1%2FB","sourceRelease":"119-100","text":"the upstream and downstream causes and effects of plastic waste, mismanaged waste and post-consumer materials, and marine debris on marine environments, marine wildlife, human health, and economic development;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s4261/2","parentIdentifier":"/us/usc/t33/s4261","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s4261/2/A","parentIdentifier":"/us/usc/t33/s4261/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s4261/2/A/i","parentIdentifier":"/us/usc/t33/s4261/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F2%2FA%2Fi","sourceRelease":"119-100","text":"to decrease plastic waste at its source; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s4261/2/A/ii","parentIdentifier":"/us/usc/t33/s4261/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F2%2FA%2Fii","sourceRelease":"119-100","text":"to prevent leakage of plastic waste into the environment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s4261/2/B","parentIdentifier":"/us/usc/t33/s4261/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F2%2FB","sourceRelease":"119-100","text":"advancing the utilization and availability of safe and affordable reusable alternatives to disposable plastic products in commerce, to the extent practicable, and with consideration for the potential impacts of such alternatives, and other efforts to prevent marine debris;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s4261/2/C","parentIdentifier":"/us/usc/t33/s4261/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F2%2FC","sourceRelease":"119-100","text":"deployment of and access to advanced technologies to capture value from post-consumer materials and municipal solid waste streams through mechanical and other recycling systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t33/s4261/2/D","parentIdentifier":"/us/usc/t33/s4261/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F2%2FD","sourceRelease":"119-100","text":"access to information on best practices in post-consumer materials management, options for post-consumer materials management systems financing, and options for participating in public-private partnerships; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t33/s4261/2/E","parentIdentifier":"/us/usc/t33/s4261/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F2%2FE","sourceRelease":"119-100","text":"implementation of management measures to reduce derelict fishing gear, the loss of fishing gear, and other sources of pollution generated from marine activities and to increase proper disposal and recycling of fishing gear; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s4261/3","parentIdentifier":"/us/usc/t33/s4261","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t33/s4261/3/A","parentIdentifier":"/us/usc/t33/s4261/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F3%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t33/s4261/3/A/i","parentIdentifier":"/us/usc/t33/s4261/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F3%2FA%2Fi","sourceRelease":"119-100","text":"measurable targets for reducing marine debris, lost fishing gear, and plastic waste from all sources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t33/s4261/3/A/ii","parentIdentifier":"/us/usc/t33/s4261/3/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F3%2FA%2Fii","sourceRelease":"119-100","text":"action plans to achieve those targets with a mechanism to provide regular reporting;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t33/s4261/3/B","parentIdentifier":"/us/usc/t33/s4261/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F3%2FB","sourceRelease":"119-100","text":"to promote consumer education, awareness, and outreach to prevent marine debris;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t33/s4261/3/C","parentIdentifier":"/us/usc/t33/s4261/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F3%2FC","sourceRelease":"119-100","text":"to reduce marine debris by improving advance planning for marine debris events and responses to such events; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t33/s4261/3/D","parentIdentifier":"/us/usc/t33/s4261/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs4261%2F3%2FD","sourceRelease":"119-100","text":"to share best practices in post-consumer materials management systems to prevent the entry of plastic waste into the environment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
