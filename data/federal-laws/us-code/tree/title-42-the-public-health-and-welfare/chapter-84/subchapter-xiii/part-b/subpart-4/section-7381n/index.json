{"type":"section","nativeType":"section","number":"7381n","heading":"Summer institutes","label":"7381n Summer institutes","identifier":"/us/usc/t42/s7381n","parentIdentifier":"/us/usc/t42/ch84/schXIII/ptB/spt4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2011—Subsec. (f)(4). added par. (4).Pub. L. 111–358"],"amendments":["Amendments2011—Subsec. (f)(4). added par. (4).Pub. L. 111–358"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t42/s7381n/a","parentIdentifier":"/us/usc/t42/s7381n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible partner","label":"1 Eligible partner","identifier":"/us/usc/t42/s7381n/a/1","parentIdentifier":"/us/usc/t42/s7381n/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7381n/a/1/A","parentIdentifier":"/us/usc/t42/s7381n/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the science, engineering, or mathematics department at an institution of higher education, acting in coordination with a school, department, or program of education at an institution of higher education that provides training for teachers and principals; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7381n/a/1/B","parentIdentifier":"/us/usc/t42/s7381n/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fa%2F1%2FB","sourceRelease":"119-100","text":"a nonprofit entity with expertise in providing professional development for science, technology, engineering, or mathematics teachers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Summer institute","label":"2 Summer institute","identifier":"/us/usc/t42/s7381n/a/2","parentIdentifier":"/us/usc/t42/s7381n/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7381n/a/2/A","parentIdentifier":"/us/usc/t42/s7381n/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fa%2F2%2FA","sourceRelease":"119-100","text":"is hosted by a National Laboratory or an eligible partner;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7381n/a/2/B","parentIdentifier":"/us/usc/t42/s7381n/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fa%2F2%2FB","sourceRelease":"119-100","text":"is operated for a period of not less than 2 weeks;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s7381n/a/2/C","parentIdentifier":"/us/usc/t42/s7381n/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fa%2F2%2FC","sourceRelease":"119-100","text":"includes, as a component, a program that provides direct interaction between students and faculty, including personnel of 1 or more National Laboratories who have scientific expertise;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s7381n/a/2/D","parentIdentifier":"/us/usc/t42/s7381n/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fa%2F2%2FD","sourceRelease":"119-100","text":"provides for follow-up training, during the academic year, that is conducted in the classroom; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s7381n/a/2/E","parentIdentifier":"/us/usc/t42/s7381n/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fa%2F2%2FE","sourceRelease":"119-100","text":"provides hands-on science, technology, engineering, or mathematics laboratory experience for not less than 2 days.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Summer institute programs authorized","label":"b Summer institute programs authorized","identifier":"/us/usc/t42/s7381n/b","parentIdentifier":"/us/usc/t42/s7381n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Programs at the National Laboratories","label":"1 Programs at the National Laboratories","identifier":"/us/usc/t42/s7381n/b/1","parentIdentifier":"/us/usc/t42/s7381n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F1","sourceRelease":"119-100","text":"The Secretary, acting through the Director, shall establish or expand programs of summer institutes at each of the National Laboratories to provide additional training to strengthen the science, technology, engineering, and mathematics teaching skills of teachers employed at public schools for kindergarten through grade 12, in accordance with the activities authorized under paragraphs (3) and (4).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Programs with eligible partners","label":"2 Programs with eligible partners","identifier":"/us/usc/t42/s7381n/b/2","parentIdentifier":"/us/usc/t42/s7381n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t42/s7381n/b/2/A","parentIdentifier":"/us/usc/t42/s7381n/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F2%2FA","sourceRelease":"119-100","text":"The Secretary, acting through the Director, shall identify and provide assistance as described in subparagraph (C) to eligible partners to establish or expand programs of summer institutes that provide additional training to strengthen the science, technology, engineering, and mathematics teaching skills of teachers employed at public schools for kindergarten through grade 12, in accordance with paragraphs (3) and (4).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Selection criteria","label":"B Selection criteria","identifier":"/us/usc/t42/s7381n/b/2/B","parentIdentifier":"/us/usc/t42/s7381n/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s7381n/b/2/B/i","parentIdentifier":"/us/usc/t42/s7381n/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"how the partner institution has the capability to administer the program in accordance with this section, which may include a description of any existing programs at the institution of the applicant that are targeted at education of science and mathematics teachers and the number of teachers graduated annually from the programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s7381n/b/2/B/ii","parentIdentifier":"/us/usc/t42/s7381n/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"how the partner institution will assist the National Laboratory in carrying out the activities described in paragraphs (3) and (4).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Assistance","label":"C Assistance","identifier":"/us/usc/t42/s7381n/b/2/C","parentIdentifier":"/us/usc/t42/s7381n/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s7381n/b/2/C/i","parentIdentifier":"/us/usc/t42/s7381n/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F2%2FC%2Fi","sourceRelease":"119-100","text":"assists in providing training to teachers at summer institutes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s7381n/b/2/C/ii","parentIdentifier":"/us/usc/t42/s7381n/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F2%2FC%2Fii","sourceRelease":"119-100","text":"uses National Laboratory scientific equipment in the training.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Required activities","label":"3 Required activities","identifier":"/us/usc/t42/s7381n/b/3","parentIdentifier":"/us/usc/t42/s7381n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7381n/b/3/A","parentIdentifier":"/us/usc/t42/s7381n/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F3%2FA","sourceRelease":"119-100","text":"creating opportunities for enhanced and ongoing professional development for teachers that improves the science, technology, engineering, and mathematics content knowledge of the teachers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7381n/b/3/B","parentIdentifier":"/us/usc/t42/s7381n/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s7381n/b/3/B/i","parentIdentifier":"/us/usc/t42/s7381n/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"based on scientific research; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s7381n/b/3/B/ii","parentIdentifier":"/us/usc/t42/s7381n/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"aligned with challenging State academic content standards;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s7381n/b/3/C","parentIdentifier":"/us/usc/t42/s7381n/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F3%2FC","sourceRelease":"119-100","text":"training on the use and integration of technology in the classrooms; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s7381n/b/3/D","parentIdentifier":"/us/usc/t42/s7381n/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F3%2FD","sourceRelease":"119-100","text":"supplemental and follow-up professional development activities as described in subsection (a)(2)(D).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Additional uses of funds","label":"4 Additional uses of funds","identifier":"/us/usc/t42/s7381n/b/4","parentIdentifier":"/us/usc/t42/s7381n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7381n/b/4/A","parentIdentifier":"/us/usc/t42/s7381n/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F4%2FA","sourceRelease":"119-100","text":"training and classroom materials to assist in carrying out paragraph (3);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7381n/b/4/B","parentIdentifier":"/us/usc/t42/s7381n/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F4%2FB","sourceRelease":"119-100","text":"expenses associated with scientific and engineering staff at the National Laboratories assisting in providing training to teachers at summer institutes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s7381n/b/4/C","parentIdentifier":"/us/usc/t42/s7381n/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F4%2FC","sourceRelease":"119-100","text":"instruction in the use and integration of data and assessments to inform and instruct classroom practice; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s7381n/b/4/D","parentIdentifier":"/us/usc/t42/s7381n/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fb%2F4%2FD","sourceRelease":"119-100","text":"stipends and travel expenses for teachers participating in the program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Priority","label":"c Priority","identifier":"/us/usc/t42/s7381n/c","parentIdentifier":"/us/usc/t42/s7381n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s7381n/c/1","parentIdentifier":"/us/usc/t42/s7381n/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fc%2F1","sourceRelease":"119-100","text":"teachers from a wide range of school districts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s7381n/c/2","parentIdentifier":"/us/usc/t42/s7381n/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fc%2F2","sourceRelease":"119-100","text":"teachers from high-need school districts; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s7381n/c/3","parentIdentifier":"/us/usc/t42/s7381n/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fc%2F3","sourceRelease":"119-100","text":"teachers from groups underrepresented in the fields of science, technology, engineering, and mathematics teaching, including women and members of minority groups.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Coordination and consultation","label":"d Coordination and consultation","identifier":"/us/usc/t42/s7381n/d","parentIdentifier":"/us/usc/t42/s7381n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fd","sourceRelease":"119-100","text":"The Director shall consult and coordinate with the Secretary of Education and the Director of the National Science Foundation regarding the implementation of the programs authorized under subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Evaluation and accountability plan","label":"e Evaluation and accountability plan","identifier":"/us/usc/t42/s7381n/e","parentIdentifier":"/us/usc/t42/s7381n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s7381n/e/1","parentIdentifier":"/us/usc/t42/s7381n/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fe%2F1","sourceRelease":"119-100","text":"The Director shall develop an evaluation and accountability plan for the activities funded under this section that measures the impact of the activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t42/s7381n/e/2","parentIdentifier":"/us/usc/t42/s7381n/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s7381n/e/2/A","parentIdentifier":"/us/usc/t42/s7381n/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fe%2F2%2FA","sourceRelease":"119-100","text":"measurable objectives to increase the number of science, technology, and mathematics teachers who participate in the summer institutes involved; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s7381n/e/2/B","parentIdentifier":"/us/usc/t42/s7381n/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fe%2F2%2FB","sourceRelease":"119-100","text":"measurable objectives for improved student academic achievement on State science, mathematics, and to the maximum extent applicable, technology and engineering assessments.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Report to Congress","label":"3 Report to Congress","identifier":"/us/usc/t42/s7381n/e/3","parentIdentifier":"/us/usc/t42/s7381n/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Fe%2F3","sourceRelease":"119-100","text":"The Secretary shall submit to Congress with the annual budget submission of the Secretary a report on how the activities assisted under this section improve the science, technology, engineering, and mathematics teaching skills of participating teachers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorization of appropriations","label":"f Authorization of appropriations","identifier":"/us/usc/t42/s7381n/f","parentIdentifier":"/us/usc/t42/s7381n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s7381n/f/1","parentIdentifier":"/us/usc/t42/s7381n/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Ff%2F1","sourceRelease":"119-100","text":"$15,000,000 for fiscal year 2008;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s7381n/f/2","parentIdentifier":"/us/usc/t42/s7381n/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Ff%2F2","sourceRelease":"119-100","text":"$20,000,000 for fiscal year 2009;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s7381n/f/3","parentIdentifier":"/us/usc/t42/s7381n/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Ff%2F3","sourceRelease":"119-100","text":"$25,000,000 for fiscal year 2010; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s7381n/f/4","parentIdentifier":"/us/usc/t42/s7381n/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7381n%2Ff%2F4","sourceRelease":"119-100","text":"$25,000,000 for each of fiscal years 2011 through 2013.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
