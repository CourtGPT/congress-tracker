{"type":"section","nativeType":"section","number":"16024","heading":"Nuclear Regulatory Commission","label":"16024 Nuclear Regulatory Commission","identifier":"/us/usc/t42/s16024","parentIdentifier":"/us/usc/t42/ch149/schVI/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16024","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s16024/a","parentIdentifier":"/us/usc/t42/s16024","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16024%2Fa","sourceRelease":"119-100","text":"In accordance with , the Nuclear Regulatory Commission shall have licensing and regulatory authority for any reactor authorized under this part.section 5842 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Licensing strategy","label":"b Licensing strategy","identifier":"/us/usc/t42/s16024/b","parentIdentifier":"/us/usc/t42/s16024","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16024%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16024/b/1","parentIdentifier":"/us/usc/t42/s16024/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16024%2Fb%2F1","sourceRelease":"119-100","text":"a description of ways in which current licensing requirements relating to light-water reactors need to be adapted for the types of prototype nuclear reactor being considered by the Project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16024/b/2","parentIdentifier":"/us/usc/t42/s16024/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16024%2Fb%2F2","sourceRelease":"119-100","text":"a description of analytical tools that the Nuclear Regulatory Commission will have to develop to independently verify designs and performance characteristics of components, equipment, systems, or structures associated with the prototype nuclear reactor;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16024/b/3","parentIdentifier":"/us/usc/t42/s16024/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16024%2Fb%2F3","sourceRelease":"119-100","text":"other research or development activities that may be required on the part of the Nuclear Regulatory Commission in order to review a license application for the prototype nuclear reactor; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16024/b/4","parentIdentifier":"/us/usc/t42/s16024/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16024%2Fb%2F4","sourceRelease":"119-100","text":"an estimate of the budgetary requirements associated with the licensing strategy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Ongoing interaction","label":"c Ongoing interaction","identifier":"/us/usc/t42/s16024/c","parentIdentifier":"/us/usc/t42/s16024","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16024%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16024/c/1","parentIdentifier":"/us/usc/t42/s16024/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16024%2Fc%2F1","sourceRelease":"119-100","text":"avoid design decisions that will compromise adequate safety margins in the design of the reactor or impair the accessibility of nuclear safety-related components of the prototype reactor for inspection and maintenance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16024/c/2","parentIdentifier":"/us/usc/t42/s16024/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16024%2Fc%2F2","sourceRelease":"119-100","text":"develop tools to facilitate inspection and maintenance needed for safety purposes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16024/c/3","parentIdentifier":"/us/usc/t42/s16024/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16024%2Fc%2F3","sourceRelease":"119-100","text":"develop risk-based criteria for any future commercial development of a similar reactor architectures.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
