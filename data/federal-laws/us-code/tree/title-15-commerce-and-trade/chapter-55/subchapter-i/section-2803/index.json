{"type":"section","nativeType":"section","number":"2803","heading":"Trial and interim franchises","label":"2803 Trial and interim franchises","identifier":"/us/usc/t15/s2803","parentIdentifier":"/us/usc/t15/ch55/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Nonapplicability of statutory nonrenewal provisions","label":"a Nonapplicability of statutory nonrenewal provisions","identifier":"/us/usc/t15/s2803/a","parentIdentifier":"/us/usc/t15/s2803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2803/a/1","parentIdentifier":"/us/usc/t15/s2803/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fa%2F1","sourceRelease":"119-100","text":"under a trial franchise; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2803/a/2","parentIdentifier":"/us/usc/t15/s2803/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fa%2F2","sourceRelease":"119-100","text":"under an interim franchise.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Definitions","label":"b Definitions","identifier":"/us/usc/t15/s2803/b","parentIdentifier":"/us/usc/t15/s2803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2803/b/1","parentIdentifier":"/us/usc/t15/s2803/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s2803/b/1/A","parentIdentifier":"/us/usc/t15/s2803/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F1%2FA","sourceRelease":"119-100","text":"which is entered into on or after ;June 19, 1978","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s2803/b/1/B","parentIdentifier":"/us/usc/t15/s2803/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F1%2FB","sourceRelease":"119-100","text":"the franchisee of which has not previously been a party to a franchise with the franchisor;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s2803/b/1/C","parentIdentifier":"/us/usc/t15/s2803/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F1%2FC","sourceRelease":"119-100","text":"the initial term of which is for a period of not more than 1 year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s2803/b/1/D","parentIdentifier":"/us/usc/t15/s2803/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F1%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s2803/b/1/D/i","parentIdentifier":"/us/usc/t15/s2803/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F1%2FD%2Fi","sourceRelease":"119-100","text":"that the franchise is a trial franchise;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s2803/b/1/D/ii","parentIdentifier":"/us/usc/t15/s2803/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F1%2FD%2Fii","sourceRelease":"119-100","text":"the duration of the initial term of the franchise;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s2803/b/1/D/iii","parentIdentifier":"/us/usc/t15/s2803/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F1%2FD%2Fiii","sourceRelease":"119-100","text":"that the franchisor may fail to renew the franchise relationship at the conclusion of the initial term stated in the franchise by notifying the franchisee, in accordance with the provisions of , of the franchisor’s intention not to renew the franchise relationship; andsection 2804 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t15/s2803/b/1/D/iv","parentIdentifier":"/us/usc/t15/s2803/b/1/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F1%2FD%2Fiv","sourceRelease":"119-100","text":"that the provisions of , limiting the right of a franchisor to fail to renew a franchise relationship, are not applicable to such trial franchise.section 2802 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2803/b/2","parentIdentifier":"/us/usc/t15/s2803/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F2","sourceRelease":"119-100","text":"The term “trial franchise” does not include any unexpired period of any term of any franchise (other than a trial franchise, as defined by paragraph (1)) which was transferred or assigned by a franchisee to the extent authorized by the provisions of the franchise or any applicable provision of State law which permits such transfer or assignment, without regard to any provision of the franchise.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s2803/b/3","parentIdentifier":"/us/usc/t15/s2803/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s2803/b/3/A","parentIdentifier":"/us/usc/t15/s2803/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F3%2FA","sourceRelease":"119-100","text":"which is entered into on or after ;June 19, 1978","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s2803/b/3/B","parentIdentifier":"/us/usc/t15/s2803/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F3%2FB","sourceRelease":"119-100","text":"the term of which, when combined with the terms of all prior interim franchises between the franchisor and the franchisee, does not exceed 3 years;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s2803/b/3/C","parentIdentifier":"/us/usc/t15/s2803/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s2803/b/3/C/i","parentIdentifier":"/us/usc/t15/s2803/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F3%2FC%2Fi","sourceRelease":"119-100","text":"was based upon a determination described in , andsection 2802(b)(2)(E) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s2803/b/3/C/ii","parentIdentifier":"/us/usc/t15/s2803/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F3%2FC%2Fii","sourceRelease":"119-100","text":"the requirements of were satisfied; andsection 2802(b)(2)(E) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s2803/b/3/D","parentIdentifier":"/us/usc/t15/s2803/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F3%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t15/s2803/b/3/D/i","parentIdentifier":"/us/usc/t15/s2803/b/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F3%2FD%2Fi","sourceRelease":"119-100","text":"that the franchise is an interim franchise;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t15/s2803/b/3/D/ii","parentIdentifier":"/us/usc/t15/s2803/b/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F3%2FD%2Fii","sourceRelease":"119-100","text":"the duration of the franchise; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t15/s2803/b/3/D/iii","parentIdentifier":"/us/usc/t15/s2803/b/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fb%2F3%2FD%2Fiii","sourceRelease":"119-100","text":"that the franchisor may fail to renew the franchise at the conclusion of the term stated in the franchise based upon a determination made by the franchisor in good faith and in the normal course of business to withdraw from the marketing of motor fuel through retail outlets in the relevant geographic market area in which the marketing premises are located if the requirements of section 2802(b)(2)(E)(ii) and (iii) of this title are satisfied.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Nonrenewal upon meeting statutory notification requirements","label":"c Nonrenewal upon meeting statutory notification requirements","identifier":"/us/usc/t15/s2803/c","parentIdentifier":"/us/usc/t15/s2803","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2803/c/1","parentIdentifier":"/us/usc/t15/s2803/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fc%2F1","sourceRelease":"119-100","text":"under any trial franchise, at the conclusion of the initial term of such trial franchise; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2803/c/2","parentIdentifier":"/us/usc/t15/s2803/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s2803/c/2/A","parentIdentifier":"/us/usc/t15/s2803/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fc%2F2%2FA","sourceRelease":"119-100","text":"such nonrenewal is based upon a determination described in ; andsection 2802(b)(2)(E) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s2803/c/2/B","parentIdentifier":"/us/usc/t15/s2803/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2803%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the requirements of section 2802(b)(2)(E)(ii) and (iii) of this title are satisfied.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
