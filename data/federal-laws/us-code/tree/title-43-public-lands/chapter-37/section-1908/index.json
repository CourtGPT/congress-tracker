{"type":"section","nativeType":"section","number":"1908","heading":"Experimental stewardship program","label":"1908 Experimental stewardship program","identifier":"/us/usc/t43/s1908","parentIdentifier":"/us/usc/t43/ch37","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1908","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Scope of program","label":"a Scope of program","identifier":"/us/usc/t43/s1908/a","parentIdentifier":"/us/usc/t43/s1908","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1908%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s1908/a/1","parentIdentifier":"/us/usc/t43/s1908/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1908%2Fa%2F1","sourceRelease":"119-100","text":"cooperative range management projects designed to foster a greater degree of cooperation and coordination between the Federal and State agencies charged with the management of the rangelands and with local private range users,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s1908/a/2","parentIdentifier":"/us/usc/t43/s1908/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1908%2Fa%2F2","sourceRelease":"119-100","text":"the payment of up to 50 per centum of the amount due the Federal Government from grazing permittees in the form of range improvement work,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s1908/a/3","parentIdentifier":"/us/usc/t43/s1908/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1908%2Fa%2F3","sourceRelease":"119-100","text":"such other incentives as he may deem appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report to Congress","label":"b Report to Congress","identifier":"/us/usc/t43/s1908/b","parentIdentifier":"/us/usc/t43/s1908","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs1908%2Fb","sourceRelease":"119-100","text":"No later than , the Secretaries shall report to the Congress the results of such experimental program, their evaluation of the fee established in and other grazing fee options, and their recommendations to implement a grazing fee schedule for the 1986 and subsequent grazing years.December 31, 1985section 1905 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
