ourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s6991i/c/2/A","parentIdentifier":"/us/usc/t42/s6991i/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fc%2F2%2FA","sourceRelease":"119-100","text":"a requirement or standard promulgated by the Administrator under ; orsection 6991b of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s6991i/c/2/B","parentIdentifier":"/us/usc/t42/s6991i/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs6991i%2Fc%2F2%2FB","sourceRelease":"119-100","text":"a requirement or standard of a State program approved under .section 6991c of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
