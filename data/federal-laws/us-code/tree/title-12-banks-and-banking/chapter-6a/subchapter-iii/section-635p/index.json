{"type":"section","nativeType":"section","number":"635p","heading":"Presidential mandate to negotiate; objectives","label":"635p Presidential mandate to negotiate; objectives","identifier":"/us/usc/t12/s635p","parentIdentifier":"/us/usc/t12/ch6A/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs635p","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s635p/1","parentIdentifier":"/us/usc/t12/s635p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs635p%2F1","sourceRelease":"119-100","text":"to define the various forms of tied aid credit, particularly mixed credits under the Arrangement on Guidelines for Officially Supported Export Credits established through the Organization for Economic Cooperation and Development (hereinafter in this subchapter referred to as the “Arrangement”);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s635p/2","parentIdentifier":"/us/usc/t12/s635p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs635p%2F2","sourceRelease":"119-100","text":"to phase out the use of government-mixed credits by a date certain;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t12/s635p/3","parentIdentifier":"/us/usc/t12/s635p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs635p%2F3","sourceRelease":"119-100","text":"to set rules governing the use of public-private cofinancing, or other forms of mixed financing, which may have the same result as government-mixed credits of drawing on concessional development assistance to produce subsidized export financing;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t12/s635p/4","parentIdentifier":"/us/usc/t12/s635p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs635p%2F4","sourceRelease":"119-100","text":"to raise the threshold for notification of the use of tied aid credit to a 50 per centum level of concessionality;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t12/s635p/5","parentIdentifier":"/us/usc/t12/s635p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs635p%2F5","sourceRelease":"119-100","text":"to improve notification procedures so that advance notification must be given on all uses of tied aid credit; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t12/s635p/6","parentIdentifier":"/us/usc/t12/s635p","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs635p%2F6","sourceRelease":"119-100","text":"to prohibit the use of tied aid credit for production facilities for goods which are in structural oversupply in the world.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
