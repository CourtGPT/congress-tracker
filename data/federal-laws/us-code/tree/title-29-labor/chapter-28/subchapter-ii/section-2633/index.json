{"type":"section","nativeType":"section","number":"2633","heading":"Membership","label":"2633 Membership","identifier":"/us/usc/t29/s2633","parentIdentifier":"/us/usc/t29/ch28/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Composition","label":"a Composition","identifier":"/us/usc/t29/s2633/a","parentIdentifier":"/us/usc/t29/s2633","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Appointments","label":"1 Appointments","identifier":"/us/usc/t29/s2633/a/1","parentIdentifier":"/us/usc/t29/s2633/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Senators","label":"A Senators","identifier":"/us/usc/t29/s2633/a/1/A","parentIdentifier":"/us/usc/t29/s2633/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fa%2F1%2FA","sourceRelease":"119-100","text":"One Senator shall be appointed by the Majority Leader of the Senate, and one Senator shall be appointed by the Minority Leader of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Members of House of Representatives","label":"B Members of House of Representatives","identifier":"/us/usc/t29/s2633/a/1/B","parentIdentifier":"/us/usc/t29/s2633/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fa%2F1%2FB","sourceRelease":"119-100","text":"One Member of the House of Representatives shall be appointed by the Speaker of the House of Representatives, and one Member of the House of Representatives shall be appointed by the Minority Leader of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Additional members","label":"C Additional members","identifier":"/us/usc/t29/s2633/a/1/C","parentIdentifier":"/us/usc/t29/s2633/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fa%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":"Appointment","label":"i Appointment","identifier":"/us/usc/t29/s2633/a/1/C/i","parentIdentifier":"/us/usc/t29/s2633/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fa%2F1%2FC%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t29/s2633/a/1/C/i/I","parentIdentifier":"/us/usc/t29/s2633/a/1/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fa%2F1%2FC%2Fi%2FI","sourceRelease":"119-100","text":"the Speaker of the House of Representatives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t29/s2633/a/1/C/i/II","parentIdentifier":"/us/usc/t29/s2633/a/1/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fa%2F1%2FC%2Fi%2FII","sourceRelease":"119-100","text":"the Majority Leader of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t29/s2633/a/1/C/i/III","parentIdentifier":"/us/usc/t29/s2633/a/1/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fa%2F1%2FC%2Fi%2FIII","sourceRelease":"119-100","text":"the Minority Leader of the House of Representatives; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t29/s2633/a/1/C/i/IV","parentIdentifier":"/us/usc/t29/s2633/a/1/C/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fa%2F1%2FC%2Fi%2FIV","sourceRelease":"119-100","text":"the Minority Leader of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":"Expertise","label":"ii Expertise","identifier":"/us/usc/t29/s2633/a/1/C/ii","parentIdentifier":"/us/usc/t29/s2633/a/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fa%2F1%2FC%2Fii","sourceRelease":"119-100","text":"Such members shall be appointed by virtue of demonstrated expertise in relevant family, temporary disability, and labor management issues. Such members shall include representatives of employers, including employers from large businesses and from small businesses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Ex officio members","label":"2 Ex officio members","identifier":"/us/usc/t29/s2633/a/2","parentIdentifier":"/us/usc/t29/s2633/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fa%2F2","sourceRelease":"119-100","text":"The Secretary of Health and Human Services, the Secretary of Labor, the Secretary of Commerce, and the Administrator of the Small Business Administration shall serve on the Commission as nonvoting ex officio members.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Vacancies","label":"b Vacancies","identifier":"/us/usc/t29/s2633/b","parentIdentifier":"/us/usc/t29/s2633","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fb","sourceRelease":"119-100","text":"Any vacancy on the Commission shall be filled in the manner in which the original appointment was made. The vacancy shall not affect the power of the remaining members to execute the duties of the Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Chairperson and vice chairperson","label":"c Chairperson and vice chairperson","identifier":"/us/usc/t29/s2633/c","parentIdentifier":"/us/usc/t29/s2633","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fc","sourceRelease":"119-100","text":"The Commission shall elect a chairperson and a vice chairperson from among the members of the Commission.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Quorum","label":"d Quorum","identifier":"/us/usc/t29/s2633/d","parentIdentifier":"/us/usc/t29/s2633","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2633%2Fd","sourceRelease":"119-100","text":"Eight members of the Commission shall constitute a quorum for all purposes, except that a lesser number may constitute a quorum for the purpose of holding hearings.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
