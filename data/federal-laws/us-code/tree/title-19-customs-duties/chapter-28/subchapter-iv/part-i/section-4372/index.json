{"type":"section","nativeType":"section","number":"4372","heading":"Collection of information on evasion of trade remedy laws","label":"4372 Collection of information on evasion of trade remedy laws","identifier":"/us/usc/t19/s4372","parentIdentifier":"/us/usc/t19/ch28/schIV/ptI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authority to collect information","label":"a Authority to collect information","identifier":"/us/usc/t19/s4372/a","parentIdentifier":"/us/usc/t19/s4372","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4372/a/1","parentIdentifier":"/us/usc/t19/s4372/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fa%2F1","sourceRelease":"119-100","text":"shall exercise all existing authorities to collect information needed to make the determination; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4372/a/2","parentIdentifier":"/us/usc/t19/s4372/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s4372/a/2/A","parentIdentifier":"/us/usc/t19/s4372/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fa%2F2%2FA","sourceRelease":"119-100","text":"a person who filed an allegation with respect to the covered merchandise;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s4372/a/2/B","parentIdentifier":"/us/usc/t19/s4372/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fa%2F2%2FB","sourceRelease":"119-100","text":"a person who is alleged to have entered the covered merchandise into the customs territory of the United States through evasion; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t19/s4372/a/2/C","parentIdentifier":"/us/usc/t19/s4372/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fa%2F2%2FC","sourceRelease":"119-100","text":"any other person who is determined to have information relevant to the allegation of entry of covered merchandise into the customs territory of the United States through evasion.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Adverse inference","label":"b Adverse inference","identifier":"/us/usc/t19/s4372/b","parentIdentifier":"/us/usc/t19/s4372","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Use of adverse inference","label":"1 Use of adverse inference","identifier":"/us/usc/t19/s4372/b/1","parentIdentifier":"/us/usc/t19/s4372/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t19/s4372/b/1/A","parentIdentifier":"/us/usc/t19/s4372/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fb%2F1%2FA","sourceRelease":"119-100","text":"If the Secretary finds that a person described in subparagraph (B) has failed to cooperate by not acting to the best of the person’s ability to comply with a request for information under subsection (a), the Secretary may, in making a determination whether an entry or entries of covered merchandise may constitute merchandise that is entered into the customs territory of the United States through evasion, use an inference that is adverse to the interests of that person in selecting from among the facts otherwise available to determine whether evasion has occurred.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Person described","label":"B Person described","identifier":"/us/usc/t19/s4372/b/1/B","parentIdentifier":"/us/usc/t19/s4372/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s4372/b/1/B/i","parentIdentifier":"/us/usc/t19/s4372/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"a person who filed an allegation with respect to covered merchandise;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s4372/b/1/B/ii","parentIdentifier":"/us/usc/t19/s4372/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"a person alleged to have entered covered merchandise into the customs territory of the United States through evasion; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t19/s4372/b/1/B/iii","parentIdentifier":"/us/usc/t19/s4372/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fb%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"a foreign producer or exporter of covered merchandise that is alleged to have entered into the customs territory of the United States through evasion.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Application","label":"C Application","identifier":"/us/usc/t19/s4372/b/1/C","parentIdentifier":"/us/usc/t19/s4372/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fb%2F1%2FC","sourceRelease":"119-100","text":"An inference described in subparagraph (A) may be used under that subparagraph with respect to a person described in clause (ii) or (iii) of subparagraph (B) without regard to whether another person involved in the same transaction or transactions under examination has provided the information sought by the Secretary, such as import or export documentation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Adverse inference described","label":"2 Adverse inference described","identifier":"/us/usc/t19/s4372/b/2","parentIdentifier":"/us/usc/t19/s4372/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s4372/b/2/A","parentIdentifier":"/us/usc/t19/s4372/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the allegation of evasion of the trade remedy laws, if any, submitted to U.S. Customs and Border Protection;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s4372/b/2/B","parentIdentifier":"/us/usc/t19/s4372/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fb%2F2%2FB","sourceRelease":"119-100","text":"a determination by the Commissioner in another investigation, proceeding, or other action regarding evasion of the unfair trade laws; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t19/s4372/b/2/C","parentIdentifier":"/us/usc/t19/s4372/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4372%2Fb%2F2%2FC","sourceRelease":"119-100","text":"any other available information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
