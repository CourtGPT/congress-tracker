{"type":"section","nativeType":"section","number":"9859e","heading":"Use of funds","label":"9859e Use of funds","identifier":"/us/usc/t42/s9859e","parentIdentifier":"/us/usc/t42/ch105/schII–C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9859e","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s9859e/a","parentIdentifier":"/us/usc/t42/s9859e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9859e%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s9859e/a/1","parentIdentifier":"/us/usc/t42/s9859e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9859e%2Fa%2F1","sourceRelease":"119-100","text":"providing training and education to eligible child care providers on preventing injuries and illnesses in children, and promoting health-related practices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s9859e/a/2","parentIdentifier":"/us/usc/t42/s9859e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9859e%2Fa%2F2","sourceRelease":"119-100","text":"strengthening licensing, regulation, or registration standards for eligible child care providers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s9859e/a/3","parentIdentifier":"/us/usc/t42/s9859e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9859e%2Fa%2F3","sourceRelease":"119-100","text":"assisting eligible child care providers in meeting licensing, regulation, or registration standards, including rehabilitating the facilities of the providers, in order to bring the facilities into compliance with the standards;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s9859e/a/4","parentIdentifier":"/us/usc/t42/s9859e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9859e%2Fa%2F4","sourceRelease":"119-100","text":"enforcing licensing, regulation, or registration standards for eligible child care providers, including holding increased unannounced inspections of the facilities of those providers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s9859e/a/5","parentIdentifier":"/us/usc/t42/s9859e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9859e%2Fa%2F5","sourceRelease":"119-100","text":"providing health consultants to provide advice to eligible child care providers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s9859e/a/6","parentIdentifier":"/us/usc/t42/s9859e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9859e%2Fa%2F6","sourceRelease":"119-100","text":"assisting eligible child care providers in enhancing the ability of the providers to serve children with disabilities and infants and toddlers with disabilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s9859e/a/7","parentIdentifier":"/us/usc/t42/s9859e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9859e%2Fa%2F7","sourceRelease":"119-100","text":"conducting criminal background checks for eligible child care providers and other individuals who have contact with children in the facilities of the providers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s9859e/a/8","parentIdentifier":"/us/usc/t42/s9859e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9859e%2Fa%2F8","sourceRelease":"119-100","text":"providing information to parents on what factors to consider in choosing a safe and healthy child care setting; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t42/s9859e/a/9","parentIdentifier":"/us/usc/t42/s9859e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9859e%2Fa%2F9","sourceRelease":"119-100","text":"assisting in improving the safety of transportation practices for children enrolled in child care programs with eligible child care providers.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Supplement, not supplant","label":"b Supplement, not supplant","identifier":"/us/usc/t42/s9859e/b","parentIdentifier":"/us/usc/t42/s9859e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9859e%2Fb","sourceRelease":"119-100","text":"Funds appropriated pursuant to the authority of this subchapter shall be used to supplement and not supplant other Federal, State, and local public funds expended to provide services for eligible individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
