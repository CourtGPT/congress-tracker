{"type":"section","nativeType":"section","number":"2009aa–5","heading":"Distressed counties and areas and nondistressed counties","label":"2009aa–5 Distressed counties and areas and nondistressed counties","identifier":"/us/usc/t7/s2009aa–5","parentIdentifier":"/us/usc/t7/ch50/schVI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Designations","label":"a Designations","identifier":"/us/usc/t7/s2009aa–5/a","parentIdentifier":"/us/usc/t7/s2009aa–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s2009aa–5/a/1","parentIdentifier":"/us/usc/t7/s2009aa–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fa%2F1","sourceRelease":"119-100","text":"as distressed counties, counties in the region that are the most severely and persistently distressed and underdeveloped and have high rates of poverty or unemployment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s2009aa–5/a/2","parentIdentifier":"/us/usc/t7/s2009aa–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fa%2F2","sourceRelease":"119-100","text":"as nondistressed counties, counties in the region that are not designated as distressed counties under paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s2009aa–5/a/3","parentIdentifier":"/us/usc/t7/s2009aa–5/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fa%2F3","sourceRelease":"119-100","text":"as isolated areas of distress, areas located in nondistressed counties (as designated under paragraph (2)) that have high rates of poverty or unemployment.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Distressed counties","label":"b Distressed counties","identifier":"/us/usc/t7/s2009aa–5/b","parentIdentifier":"/us/usc/t7/s2009aa–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s2009aa–5/b/1","parentIdentifier":"/us/usc/t7/s2009aa–5/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fb%2F1","sourceRelease":"119-100","text":"The Authority shall allocate at least 75 percent of the appropriations made available under for programs and projects designed to serve the needs of distressed counties and isolated areas of distress in the region.section 2009aa–12 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Funding limitations","label":"2 Funding limitations","identifier":"/us/usc/t7/s2009aa–5/b/2","parentIdentifier":"/us/usc/t7/s2009aa–5/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fb%2F2","sourceRelease":"119-100","text":"The funding limitations under shall not apply to a project providing transportation or basic public services to residents of one or more distressed counties or isolated areas of distress in the region.section 2009aa–3(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Nondistressed counties","label":"c Nondistressed counties","identifier":"/us/usc/t7/s2009aa–5/c","parentIdentifier":"/us/usc/t7/s2009aa–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s2009aa–5/c/1","parentIdentifier":"/us/usc/t7/s2009aa–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fc%2F1","sourceRelease":"119-100","text":"Except as provided in this subsection, no funds shall be provided under this subchapter for a project located in a county designated as a nondistressed county under subsection (a)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Exceptions","label":"2 Exceptions","identifier":"/us/usc/t7/s2009aa–5/c/2","parentIdentifier":"/us/usc/t7/s2009aa–5/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t7/s2009aa–5/c/2/A","parentIdentifier":"/us/usc/t7/s2009aa–5/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fc%2F2%2FA","sourceRelease":"119-100","text":"The funding prohibition under paragraph (1) shall not apply to grants to fund the administrative expenses of local development districts under .section 2009aa–4(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Multicounty projects","label":"B Multicounty projects","identifier":"/us/usc/t7/s2009aa–5/c/2/B","parentIdentifier":"/us/usc/t7/s2009aa–5/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s2009aa–5/c/2/B/i","parentIdentifier":"/us/usc/t7/s2009aa–5/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"a multicounty project that includes participation by a nondistressed county; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s2009aa–5/c/2/B/ii","parentIdentifier":"/us/usc/t7/s2009aa–5/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"any other type of project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Isolated areas of distress","label":"C Isolated areas of distress","identifier":"/us/usc/t7/s2009aa–5/c/2/C","parentIdentifier":"/us/usc/t7/s2009aa–5/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fc%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s2009aa–5/c/2/C/i","parentIdentifier":"/us/usc/t7/s2009aa–5/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fc%2F2%2FC%2Fi","sourceRelease":"119-100","text":"by the most recent Federal data available; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s2009aa–5/c/2/C/ii","parentIdentifier":"/us/usc/t7/s2009aa–5/c/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fc%2F2%2FC%2Fii","sourceRelease":"119-100","text":"if no recent Federal data are available, by the most recent data available through the government of the State in which the isolated area of distress is located.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Transportation and basic public infrastructure","label":"d Transportation and basic public infrastructure","identifier":"/us/usc/t7/s2009aa–5/d","parentIdentifier":"/us/usc/t7/s2009aa–5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs2009aa%E2%80%935%2Fd","sourceRelease":"119-100","text":"The Authority shall allocate at least 50 percent of any funds made available under for transportation and basic public infrastructure projects authorized under paragraphs (1) and (3) of .section 2009aa–12 of this titlesection 2009aa–2(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
