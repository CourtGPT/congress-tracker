{"type":"section","nativeType":"section","number":"16532","heading":"Nuclear science talent expansion program for institutions of higher education","label":"16532 Nuclear science talent expansion program for institutions of higher education","identifier":"/us/usc/t42/s16532","parentIdentifier":"/us/usc/t42/ch149/schXVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2011—Subsec. (f)(1)(D) to (F). , added subpars. (D) to (F).Pub. L. 111–358, § 902(a)(1)Subsec. (f)(2)(D) to (F). , added subpars. (D) to (F).Pub. L. 111–358, § 902(a)(2)"],"amendments":["Amendments2011—Subsec. (f)(1)(D) to (F). , added subpars. (D) to (F).Pub. L. 111–358, § 902(a)(1)Subsec. (f)(2)(D) to (F). , added subpars. (D) to (F).Pub. L. 111–358, § 902(a)(2)"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Purposes","label":"a Purposes","identifier":"/us/usc/t42/s16532/a","parentIdentifier":"/us/usc/t42/s16532","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16532/a/1","parentIdentifier":"/us/usc/t42/s16532/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fa%2F1","sourceRelease":"119-100","text":"to address the decline in the number of and resources available to nuclear science programs at institutions of higher education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16532/a/2","parentIdentifier":"/us/usc/t42/s16532/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fa%2F2","sourceRelease":"119-100","text":"to increase the number of graduates with degrees in nuclear science, an area of strategic importance to the economic competitiveness and energy security of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Definition of nuclear science","label":"b Definition of nuclear science","identifier":"/us/usc/t42/s16532/b","parentIdentifier":"/us/usc/t42/s16532","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16532/b/1","parentIdentifier":"/us/usc/t42/s16532/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fb%2F1","sourceRelease":"119-100","text":"nuclear science;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16532/b/2","parentIdentifier":"/us/usc/t42/s16532/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fb%2F2","sourceRelease":"119-100","text":"nuclear engineering;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s16532/b/3","parentIdentifier":"/us/usc/t42/s16532/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fb%2F3","sourceRelease":"119-100","text":"nuclear chemistry;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s16532/b/4","parentIdentifier":"/us/usc/t42/s16532/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fb%2F4","sourceRelease":"119-100","text":"radio chemistry; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s16532/b/5","parentIdentifier":"/us/usc/t42/s16532/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fb%2F5","sourceRelease":"119-100","text":"health physics.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Establishment","label":"c Establishment","identifier":"/us/usc/t42/s16532/c","parentIdentifier":"/us/usc/t42/s16532","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fc","sourceRelease":"119-100","text":"The Secretary shall establish, in accordance with this section, a program to expand and enhance institution of higher education nuclear science educational capabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Nuclear science program expansion grants for institutions of higher education","label":"d Nuclear science program expansion grants for institutions of higher education","identifier":"/us/usc/t42/s16532/d","parentIdentifier":"/us/usc/t42/s16532","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16532/d/1","parentIdentifier":"/us/usc/t42/s16532/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F1","sourceRelease":"119-100","text":"The Secretary shall award up to 3 competitive grants for each fiscal year to institutions of higher education that establish new academic degree programs in nuclear science.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Priority","label":"2 Priority","identifier":"/us/usc/t42/s16532/d/2","parentIdentifier":"/us/usc/t42/s16532/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F2","sourceRelease":"119-100","text":"In evaluating grants under this subsection, the Secretary shall give priority to proposals that involve partnerships with a National Laboratory or other eligible nuclear-related entity, as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Criteria","label":"3 Criteria","identifier":"/us/usc/t42/s16532/d/3","parentIdentifier":"/us/usc/t42/s16532/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16532/d/3/A","parentIdentifier":"/us/usc/t42/s16532/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F3%2FA","sourceRelease":"119-100","text":"the potential to attract new students to the program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16532/d/3/B","parentIdentifier":"/us/usc/t42/s16532/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F3%2FB","sourceRelease":"119-100","text":"academic rigor; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16532/d/3/C","parentIdentifier":"/us/usc/t42/s16532/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F3%2FC","sourceRelease":"119-100","text":"the ability to offer hands-on learning opportunities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Duration and amount","label":"4 Duration and amount","identifier":"/us/usc/t42/s16532/d/4","parentIdentifier":"/us/usc/t42/s16532/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Duration","label":"A Duration","identifier":"/us/usc/t42/s16532/d/4/A","parentIdentifier":"/us/usc/t42/s16532/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F4%2FA","sourceRelease":"119-100","text":"A grant under this subsection may be up to 5 years in duration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Amount","label":"B Amount","identifier":"/us/usc/t42/s16532/d/4/B","parentIdentifier":"/us/usc/t42/s16532/d/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F4%2FB","sourceRelease":"119-100","text":"An institution of higher education that receives a grant under this subsection shall be eligible for up to $1,000,000 for each year of the grant period.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Use of funds","label":"5 Use of funds","identifier":"/us/usc/t42/s16532/d/5","parentIdentifier":"/us/usc/t42/s16532/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16532/d/5/A","parentIdentifier":"/us/usc/t42/s16532/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F5%2FA","sourceRelease":"119-100","text":"recruit and retain new faculty;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16532/d/5/B","parentIdentifier":"/us/usc/t42/s16532/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F5%2FB","sourceRelease":"119-100","text":"develop core and specialized course content;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16532/d/5/C","parentIdentifier":"/us/usc/t42/s16532/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F5%2FC","sourceRelease":"119-100","text":"encourage collaboration between faculty and researchers in the nuclear science field; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16532/d/5/D","parentIdentifier":"/us/usc/t42/s16532/d/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fd%2F5%2FD","sourceRelease":"119-100","text":"support outreach efforts to recruit students.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Nuclear science competitiveness grants for institutions of higher education","label":"e Nuclear science competitiveness grants for institutions of higher education","identifier":"/us/usc/t42/s16532/e","parentIdentifier":"/us/usc/t42/s16532","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16532/e/1","parentIdentifier":"/us/usc/t42/s16532/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fe%2F1","sourceRelease":"119-100","text":"The Secretary shall award up to 5 competitive grants for each fiscal year to institutions of higher education with existing academic degree programs that produce graduates in nuclear science.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Criteria","label":"2 Criteria","identifier":"/us/usc/t42/s16532/e/2","parentIdentifier":"/us/usc/t42/s16532/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fe%2F2","sourceRelease":"119-100","text":"Criteria for a grant awarded under this subsection shall be based on the potential for increasing the number and academic quality of graduates in the nuclear sciences who enter into careers in nuclear-related fields.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Duration and amount","label":"3 Duration and amount","identifier":"/us/usc/t42/s16532/e/3","parentIdentifier":"/us/usc/t42/s16532/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fe%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Duration","label":"A Duration","identifier":"/us/usc/t42/s16532/e/3/A","parentIdentifier":"/us/usc/t42/s16532/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fe%2F3%2FA","sourceRelease":"119-100","text":"A grant under this subsection may be up to 5 years in duration.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Amount","label":"B Amount","identifier":"/us/usc/t42/s16532/e/3/B","parentIdentifier":"/us/usc/t42/s16532/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fe%2F3%2FB","sourceRelease":"119-100","text":"An institution of higher education that receives a grant under this subsection shall be eligible for up to $500,000 for each year of the grant period.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Use of funds","label":"4 Use of funds","identifier":"/us/usc/t42/s16532/e/4","parentIdentifier":"/us/usc/t42/s16532/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fe%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16532/e/4/A","parentIdentifier":"/us/usc/t42/s16532/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fe%2F4%2FA","sourceRelease":"119-100","text":"increase the number of graduates in nuclear science that enter into careers in the nuclear science field;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16532/e/4/B","parentIdentifier":"/us/usc/t42/s16532/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fe%2F4%2FB","sourceRelease":"119-100","text":"enhance the teaching of advanced nuclear technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16532/e/4/C","parentIdentifier":"/us/usc/t42/s16532/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fe%2F4%2FC","sourceRelease":"119-100","text":"aggressively pursue collaboration opportunities with industry and National Laboratories;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16532/e/4/D","parentIdentifier":"/us/usc/t42/s16532/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fe%2F4%2FD","sourceRelease":"119-100","text":"bolster or sustain nuclear infrastructure and research facilities of the institution of higher education, such as research and training reactors or laboratories; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16532/e/4/E","parentIdentifier":"/us/usc/t42/s16532/e/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Fe%2F4%2FE","sourceRelease":"119-100","text":"provide tuition assistance and stipends to undergraduate and graduate students.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Authorization of appropriations","label":"f Authorization of appropriations","identifier":"/us/usc/t42/s16532/f","parentIdentifier":"/us/usc/t42/s16532","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16532%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Nuclear science program expansion grants for institutions of higher education","label":"1 Nuclear science prog