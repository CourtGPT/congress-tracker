{"type":"section","nativeType":"section","number":"385","heading":"Department of Defense support for other departments and agencies of the United States Government that advance Department of Defense security cooperation objectives","label":"385 Department of Defense support for other departments and agencies of the United States Government that advance Department of Defense security cooperation objectives","identifier":"/us/usc/t10/s385","parentIdentifier":"/us/usc/t10/stA/ptI/ch16/schVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2018—Subsec. (d)(1)(B). substituted “including” for “include”.Pub. L. 115–232"],"amendments":["Amendments2018—Subsec. (d)(1)(B). substituted “including” for “include”.Pub. L. 115–232"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Support Authorized","label":"a .—Support Authorized","identifier":"/us/usc/t10/s385/a","parentIdentifier":"/us/usc/t10/s385","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fa","sourceRelease":"119-100","text":"Subject to subsection (c), the Secretary of Defense is authorized to support other departments and agencies of the United States Government for the purpose of implementing or supporting foreign assistance programs and activities described in subsection (b) that advance security cooperation objectives of the Department of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Foreign Assistance Programs and Activities","label":"b .—Foreign Assistance Programs and Activities","identifier":"/us/usc/t10/s385/b","parentIdentifier":"/us/usc/t10/s385","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s385/b/1","parentIdentifier":"/us/usc/t10/s385/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fb%2F1","sourceRelease":"119-100","text":"are necessary for the effectiveness of one or more programs of the Department of Defense relating to security cooperation conducted pursuant to an authority in this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s385/b/2","parentIdentifier":"/us/usc/t10/s385/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fb%2F2","sourceRelease":"119-100","text":"cannot be carried out by the Department.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Annual Limitation on Amount of Support","label":"c .—Annual Limitation on Amount of Support","identifier":"/us/usc/t10/s385/c","parentIdentifier":"/us/usc/t10/s385","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fc","sourceRelease":"119-100","text":"The amount of support provided pursuant to subsection (a) in any fiscal year may not exceed $75,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Notice and Wait","label":"d .—Notice and Wait","identifier":"/us/usc/t10/s385/d","parentIdentifier":"/us/usc/t10/s385","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s385/d/1","parentIdentifier":"/us/usc/t10/s385/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s385/d/1/A","parentIdentifier":"/us/usc/t10/s385/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fd%2F1%2FA","sourceRelease":"119-100","text":"a detailed description of the purpose and estimated cost of such program or activity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s385/d/1/B","parentIdentifier":"/us/usc/t10/s385/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fd%2F1%2FB","sourceRelease":"119-100","text":"a detailed description of the security cooperation objectives of the Department, including the theater campaign plan of the combatant command concerned, that will be advanced;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t10/s385/d/1/C","parentIdentifier":"/us/usc/t10/s385/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fd%2F1%2FC","sourceRelease":"119-100","text":"a justification why such program or activity will advance such objectives;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t10/s385/d/1/D","parentIdentifier":"/us/usc/t10/s385/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fd%2F1%2FD","sourceRelease":"119-100","text":"a justification why such program or activity cannot be carried out by the Department;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t10/s385/d/1/E","parentIdentifier":"/us/usc/t10/s385/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fd%2F1%2FE","sourceRelease":"119-100","text":"an identification of any funds programmed or obligated by the department or agency other than the Department on such program or activity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t10/s385/d/1/F","parentIdentifier":"/us/usc/t10/s385/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fd%2F1%2FF","sourceRelease":"119-100","text":"a timeline for the provision of such support; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s385/d/2","parentIdentifier":"/us/usc/t10/s385/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs385%2Fd%2F2","sourceRelease":"119-100","text":"a period of 30 days elapses after the date of the submittal of the notice pursuant to paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
