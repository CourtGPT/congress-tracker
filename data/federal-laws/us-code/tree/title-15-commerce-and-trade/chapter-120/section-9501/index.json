,"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Institution of higher education","label":"6 Institution of higher education","identifier":"/us/usc/t15/s9501/6","parentIdentifier":"/us/usc/t15/s9501","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F6","sourceRelease":"119-100","text":"The term “institution of higher education” has the meaning given the term in .section 1001 of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"MBDA Business Center","label":"7 MBDA Business Center","identifier":"/us/usc/t15/s9501/7","parentIdentifier":"/us/usc/t15/s9501","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9501/7/A","parentIdentifier":"/us/usc/t15/s9501/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F7%2FA","sourceRelease":"119-100","text":"is established by the Agency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9501/7/B","parentIdentifier":"/us/usc/t15/s9501/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F7%2FB","sourceRelease":"119-100","text":"provides technical business assistance to minority business enterprises consistent with the requirements of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"MBDA Business Center agreement","label":"8 MBDA Business Center agreement","identifier":"/us/usc/t15/s9501/8","parentIdentifier":"/us/usc/t15/s9501","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s9501/8/A","parentIdentifier":"/us/usc/t15/s9501/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F8%2FA","sourceRelease":"119-100","text":"reflecting a relationship between the Agency and the recipient of a Federal assistance award that is the subject of the instrument; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s9501/8/B","parentIdentifier":"/us/usc/t15/s9501/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F8%2FB","sourceRelease":"119-100","text":"that establishes the terms by which the recipient described in subparagraph (A) shall operate an MBDA Business Center.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":"Minority business enterprise","label":"9 Minority business enterprise","identifier":"/us/usc/t15/s9501/9","parentIdentifier":"/us/usc/t15/s9501","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F9","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t15/s9501/9/A","parentIdentifier":"/us/usc/t15/s9501/9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs9501%2F9%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"lab