{"type":"section","nativeType":"section","number":"460zzz–3","heading":"Maps and legal descriptions","label":"460zzz–3 Maps and legal descriptions","identifier":"/us/usc/t16/s460zzz–3","parentIdentifier":"/us/usc/t16/ch1/schCXXXVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%933","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s460zzz–3/a","parentIdentifier":"/us/usc/t16/s460zzz–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%933%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s460zzz–3/a/1","parentIdentifier":"/us/usc/t16/s460zzz–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%933%2Fa%2F1","sourceRelease":"119-100","text":"the Committee on Energy and Natural Resources of the Senate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s460zzz–3/a/2","parentIdentifier":"/us/usc/t16/s460zzz–3/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%933%2Fa%2F2","sourceRelease":"119-100","text":"the Committee on Natural Resources of the House of Representatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Force and effect","label":"b Force and effect","identifier":"/us/usc/t16/s460zzz–3/b","parentIdentifier":"/us/usc/t16/s460zzz–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%933%2Fb","sourceRelease":"119-100","text":"The Map and legal descriptions filed under subsection (a) shall have the same force and effect as if included in this subchapter, except that the Secretary may correct clerical and typographical errors in the Map and legal descriptions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Public availability","label":"c Public availability","identifier":"/us/usc/t16/s460zzz–3/c","parentIdentifier":"/us/usc/t16/s460zzz–3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%933%2Fc","sourceRelease":"119-100","text":"The Map and legal descriptions filed under subsection (a) shall be available for public inspection in the appropriate offices of the Bureau of Land Management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
