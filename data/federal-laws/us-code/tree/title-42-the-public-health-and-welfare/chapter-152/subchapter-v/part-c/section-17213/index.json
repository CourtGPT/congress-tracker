nt existing facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17213/2","parentIdentifier":"/us/usc/t42/s17213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17213/2/A","parentIdentifier":"/us/usc/t42/s17213/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F2%2FA","sourceRelease":"119-100","text":"extend the operational lifetime of hydropower systems and their physical structures, while improving environmental impact, including potential cumulative environmental impacts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17213/2/B","parentIdentifier":"/us/usc/t42/s17213/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F2%2FB","sourceRelease":"119-100","text":"assist in device and system design, installation, operation, and maintenance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17213/2/C","parentIdentifier":"/us/usc/t42/s17213/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F2%2FC","sourceRelease":"119-100","text":"reduce costs, limit outages, and increase unit and plant efficiencies, including by examining the impact of changing water and electricity demand on hydropower generation, flexibility, and provision of grid services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17213/3","parentIdentifier":"/us/usc/t42/s17213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F3","sourceRelease":"119-100","text":"study, in conjunction with other relevant Federal agencies as appropriate, methods to improve the hydropower licensing process, including by compiling current and accepted best practices, public comments, and methodologies to assess the full range of potential environmental and economic impacts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17213/4","parentIdentifier":"/us/usc/t42/s17213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17213/4/A","parentIdentifier":"/us/usc/t42/s17213/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F4%2FA","sourceRelease":"119-100","text":"pumped storage systems and other renewable energy systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17213/4/B","parentIdentifier":"/us/usc/t42/s17213/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F4%2FB","sourceRelease":"119-100","text":"small hydro facilities and other energy storage systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17213/4/C","parentIdentifier":"/us/usc/t42/s17213/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F4%2FC","sourceRelease":"119-100","text":"other hybrid energy systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17213/4/D","parentIdentifier":"/us/usc/t42/s17213/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F4%2FD","sourceRelease":"119-100","text":"small hydro facilities and critical infrastructure, including water infrastructure; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17213/4/E","parentIdentifier":"/us/usc/t42/s17213/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F4%2FE","sourceRelease":"119-100","text":"hydro facilities and responsive load technologies, which may include smart buildings and city systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s17213/5","parentIdentifier":"/us/usc/t42/s17213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F5","sourceRelease":"119-100","text":"improve the reliability of hydropower technologies, including during extreme weather events;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s17213/6","parentIdentifier":"/us/usc/t42/s17213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17213/6/A","parentIdentifier":"/us/usc/t42/s17213/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F6%2FA","sourceRelease":"119-100","text":"fisheries;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17213/6/B","parentIdentifier":"/us/usc/t42/s17213/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F6%2FB","sourceRelease":"119-100","text":"aquatic life and resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17213/6/C","parentIdentifier":"/us/usc/t42/s17213/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F6%2FC","sourceRelease":"119-100","text":"navigation of waterways; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17213/6/D","parentIdentifier":"/us/usc/t42/s17213/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F6%2FD","sourceRelease":"119-100","text":"upstream and downstream environmental conditions, including sediment movement, water quality, and flow volumes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s17213/7","parentIdentifier":"/us/usc/t42/s17213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17213/7/A","parentIdentifier":"/us/usc/t42/s17213/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F7%2FA","sourceRelease":"119-100","text":"diversifying plant configuration options;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17213/7/B","parentIdentifier":"/us/usc/t42/s17213/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F7%2FB","sourceRelease":"119-100","text":"improving pump-back efficiencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17213/7/C","parentIdentifier":"/us/usc/t42/s17213/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F7%2FC","sourceRelease":"119-100","text":"investigating multi-phase systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17213/7/D","parentIdentifier":"/us/usc/t42/s17213/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F7%2FD","sourceRelease":"119-100","text":"developing, testing, and monitoring advanced generators with faster cycling times, variable speeds, and improved efficiencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s17213/7/E","parentIdentifier":"/us/usc/t42/s17213/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F7%2FE","sourceRelease":"119-100","text":"developing, testing, and monitoring advanced turbines capable of improving environmental impact, including potential cumulative environmental impacts, including small turbine designs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s17213/7/F","parentIdentifier":"/us/usc/t42/s17213/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F7%2FF","sourceRelease":"119-100","text":"developing standardized powertrain components;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t42/s17213/7/G","parentIdentifier":"/us/usc/t42/s17213/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F7%2FG","sourceRelease":"119-100","text":"developing components with advanced materials and manufacturing processes, including additive manufacturing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t42/s17213/7/H","parentIdentifier":"/us/usc/t42/s17213/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F7%2FH","sourceRelease":"119-100","text":"developing analytical tools that enable hydropower to provide grid services that, amongst other services, improve grid integration of other energy sources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s17213/8","parentIdentifier":"/us/usc/t42/s17213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17213/8/A","parentIdentifier":"/us/usc/t42/s17213/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F8%2FA","sourceRelease":"119-100","text":"systems with adjustable speed and other new pumping and generating equipment designs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17213/8/B","parentIdentifier":"/us/usc/t42/s17213/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F8%2FB","sourceRelease":"119-100","text":"modular systems;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17213/8/C","parentIdentifier":"/us/usc/t42/s17213/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F8%2FC","sourceRelease":"119-100","text":"alternative closed-loop systems, including mines and quarries; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s17213/8/D","parentIdentifier":"/us/usc/t42/s17213/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F8%2FD","sourceRelease":"119-100","text":"other innovative equipment and materials as determined by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t42/s17213/9","parentIdentifier":"/us/usc/t42/s17213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F9","sourceRelease":"119-100","text":"reduce civil works costs and construction times for hydropower and pumped storage systems, including comprehensive data and systems analysis of hydropower and pumped storage construction technologies and processes in order to identify areas for whole-system efficiency gains;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t42/s17213/10","parentIdentifier":"/us/usc/t42/s17213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F10","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17213/10/A","parentIdentifier":"/us/usc/t42/s17213/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F10%2FA","sourceRelease":"119-100","text":"improving methods for operational forecasting of renewable energy systems to identify opportunities for hydropower applications in pumped storage and hybrid energy systems, including forecasting of seasonal and annual energy storage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17213/10/B","parentIdentifier":"/us/usc/t42/s17213/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F10%2FB","sourceRelease":"119-100","text":"considering aggregating small distributed hydropower assets; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s17213/10/C","parentIdentifier":"/us/usc/t42/s17213/10","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F10%2FC","sourceRelease":"119-100","text":"identifying barriers to grid scale implementation of hydropower and pumped storage technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t42/s17213/11","parentIdentifier":"/us/usc/t42/s17213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F11","sourceRelease":"119-100","text":"improve computational fluid dynamic modeling methods;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t42/s17213/12","parentIdentifier":"/us/usc/t42/s17213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F12","sourceRelease":"119-100","text":"improve flow measurement methods, including maintenance of continuous flow measurement equipment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"13","heading":null,"label":"13","identifier":"/us/usc/t42/s17213/13","parentIdentifier":"/us/usc/t42/s17213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F13","sourceRelease":"119-100","text":"identify best methods for compiling data on all hydropower resources and assets, including identifying potential for increased capacity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"14","heading":null,"label":"14","identifier":"/us/usc/t42/s17213/14","parentIdentifier":"/us/usc/t42/s17213","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17213%2F14","sourceRelease":"119-100","text":"identify mechanisms to test and validate performance of hydropower and pumped storage technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
