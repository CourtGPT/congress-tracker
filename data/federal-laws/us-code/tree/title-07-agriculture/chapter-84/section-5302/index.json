{"type":"section","nativeType":"section","number":"5302","heading":"Definitions","label":"5302 Definitions","identifier":"/us/usc/t7/s5302","parentIdentifier":"/us/usc/t7/ch84","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5302","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s5302/1","parentIdentifier":"/us/usc/t7/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5302%2F1","sourceRelease":"119-100","text":"the term “comprehensive plan” means the comprehensive plan prepared under ;section 5313 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s5302/2","parentIdentifier":"/us/usc/t7/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5302%2F2","sourceRelease":"119-100","text":"the term “coordinated program” means the National Nutrition Monitoring and Related Research Program established by ;section 5311(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s5302/3","parentIdentifier":"/us/usc/t7/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5302%2F3","sourceRelease":"119-100","text":"the terms “Interagency Board for Nutrition Monitoring and Related Research” and “Board” mean the Federal coordinating body established by ;section 5311(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s5302/4","parentIdentifier":"/us/usc/t7/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5302%2F4","sourceRelease":"119-100","text":"the term “Joint Implementation Plan for a Comprehensive National Nutrition Monitoring System” means the plan of that title dated and submitted by the Department of Agriculture and the Department of Health and Human Services under ;August 18, 1981section 3178 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s5302/5","parentIdentifier":"/us/usc/t7/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5302%2F5","sourceRelease":"119-100","text":"the term “local government” means a local general unit of government or local educational unit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s5302/6","parentIdentifier":"/us/usc/t7/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5302%2F6","sourceRelease":"119-100","text":"the terms “National Nutrition Monitoring Advisory Council” and “Council” mean the advisory body established under ;section 5331 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t7/s5302/7","parentIdentifier":"/us/usc/t7/s5302","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5302%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s5302/7/A","parentIdentifier":"/us/usc/t7/s5302/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5302%2F7%2FA","sourceRelease":"119-100","text":"dietary, nutritional, and health status measurements;","notes":[