{"type":"section","nativeType":"section","number":"9304","heading":"Surety corporations","label":"9304 Surety corporations","identifier":"/us/usc/t31/s9304","parentIdentifier":"/us/usc/t31/stVI/ch93","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs9304","sourceRelease":"119-100","text":null,"notes":["Historical and Revision NotesRevised SectionSource (U.S. Code)Source (Statutes at Large)93046:6.Subsection (a) is substituted for 6:6(1st sentence) to eliminate unnecessary words and for clarity and consistency. Clause (3) is added for clarity.In subsection (b), the words “Each surety bond” are substituted for “Such recognizance, stipulation, bond, or undertaking”, the words “official of the Government” are substituted for “head of department, court, judge, officer, board, or body executive, legislative, or judicial”, and the word “official” is substituted for “officer or person having the approval of any bond”, to eliminate unnecessary words and for clarity and consistency."],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t31/s9304/a","parentIdentifier":"/us/usc/t31/s9304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs9304%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t31/s9304/a/1","parentIdentifier":"/us/usc/t31/s9304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs9304%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t31/s9304/a/1/A","parentIdentifier":"/us/usc/t31/s9304/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs9304%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t31/s9304/a/1/B","parentIdentifier":"/us/usc/t31/s9304/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs9304%2Fa%2F1%2FB","sourceRelease":"119-100","text":"a State, the District of Columbia, or a territory or possession of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t31/s9304/a/2","parentIdentifier":"/us/usc/t31/s9304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs9304%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t31/s9304/a/2/A","parentIdentifier":"/us/usc/t31/s9304/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs9304%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the fidelity of persons holding positions of trust; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t31/s9304/a/2/B","parentIdentifier":"/us/usc/t31/s9304/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs9304%2Fa%2F2%2FB","sourceRelease":"119-100","text":"bonds and undertakings in judicial proceedings; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t31/s9304/a/3","parentIdentifier":"/us/usc/t31/s9304/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs9304%2Fa%2F3","sourceRelease":"119-100","text":"complying with sections 9305 and 9306 of this title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t31/s9304/b","parentIdentifier":"/us/usc/t31/s9304","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs9304%2Fb","sourceRelease":"119-100","text":"Each surety bond shall be approved by the official of the Government required to approve or accept the bond. The official may not require that the surety bond be given through a guaranty corporation or through any particular guaranty corporation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
