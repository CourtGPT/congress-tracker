ype":"paragraph","nativeType":"paragraph","number":"2","heading":"Requirement","label":"2 Requirement","identifier":"/us/usc/t16/s6591e/f/2","parentIdentifier":"/us/usc/t16/s6591e/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6591e/f/2/A","parentIdentifier":"/us/usc/t16/s6591e/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Ff%2F2%2FA","sourceRelease":"119-100","text":"as soon as practicable; but","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6591e/f/2/B","parentIdentifier":"/us/usc/t16/s6591e/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Ff%2F2%2FB","sourceRelease":"119-100","text":"not later than 10 years after the date of completion of the applicable covered vegetation management activity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Limitations","label":"g Limitations","identifier":"/us/usc/t16/s6591e/g","parentIdentifier":"/us/usc/t16/s6591e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fg","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Project size","label":"1 Project size","identifier":"/us/usc/t16/s6591e/g/1","parentIdentifier":"/us/usc/t16/s6591e/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fg%2F1","sourceRelease":"119-100","text":"A covered vegetation management activity that is covered by the categorical exclusion under subsection (b) may not exceed 4,500 acres.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Location","label":"2 Location","identifier":"/us/usc/t16/s6591e/g/2","parentIdentifier":"/us/usc/t16/s6591e/g","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6591e%2Fg%2F2","sourceRelease":"119-100","text":"A covered vegetation management activity carried out on National Forest System land that is covered by the categorical exclusion under subsection (b) shall be limited to areas designated under , as of .section 6591a(b) of this titleDecember 20, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
