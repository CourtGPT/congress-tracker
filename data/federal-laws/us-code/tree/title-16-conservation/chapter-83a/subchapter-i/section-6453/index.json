{"type":"section","nativeType":"section","number":"6453","heading":"Membership","label":"6453 Membership","identifier":"/us/usc/t16/s6453","parentIdentifier":"/us/usc/t16/ch83A/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Voting membership","label":"a Voting membership","identifier":"/us/usc/t16/s6453/a","parentIdentifier":"/us/usc/t16/s6453","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s6453/a/1","parentIdentifier":"/us/usc/t16/s6453/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fa%2F1","sourceRelease":"119-100","text":"the Under Secretary of Commerce for Oceans and Atmosphere and the Secretary of Interior, who shall be co-chairpersons of the Task Force;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6453/a/2","parentIdentifier":"/us/usc/t16/s6453/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fa%2F2","sourceRelease":"119-100","text":"such representatives from other Federal agencies as the President, in consultation with the Under Secretary, determines appropriate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s6453/a/3","parentIdentifier":"/us/usc/t16/s6453/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fa%2F3","sourceRelease":"119-100","text":"the Governor, or a representative of the Governor, of each covered State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Nonvoting members","label":"b Nonvoting members","identifier":"/us/usc/t16/s6453/b","parentIdentifier":"/us/usc/t16/s6453","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s6453/b/1","parentIdentifier":"/us/usc/t16/s6453/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fb%2F1","sourceRelease":"119-100","text":"A member of the South Atlantic Fishery Management Council who is designated by the Governor of Florida under .section 1852(b)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6453/b/2","parentIdentifier":"/us/usc/t16/s6453/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fb%2F2","sourceRelease":"119-100","text":"A member of the Gulf of Mexico Fishery Management Council who is designated by the Governor of Florida under such section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s6453/b/3","parentIdentifier":"/us/usc/t16/s6453/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6453/b/3/A","parentIdentifier":"/us/usc/t16/s6453/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fb%2F3%2FA","sourceRelease":"119-100","text":"For the period beginning on , and ending on December 31 of the calendar year during which such date occurs, the member shall be selected jointly by the Governors of Hawaii, American Samoa, Guam, and the Commonwealth of the Northern Mariana Islands.December 23, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6453/b/3/B","parentIdentifier":"/us/usc/t16/s6453/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fb%2F3%2FB","sourceRelease":"119-100","text":"For each calendar year thereafter, the Governors of Hawaii, American Samoa, Guam, and the Commonwealth of the Northern Mariana Islands shall, on a rotating basis, take turns selecting the member.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t16/s6453/b/4","parentIdentifier":"/us/usc/t16/s6453/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6453/b/4/A","parentIdentifier":"/us/usc/t16/s6453/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fb%2F4%2FA","sourceRelease":"119-100","text":"For the period beginning on , and ending on December 31 of the calendar year during which such date occurs, the member shall be selected jointly by the Governors of Puerto Rico and the United States Virgin Islands.December 23, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6453/b/4/B","parentIdentifier":"/us/usc/t16/s6453/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fb%2F4%2FB","sourceRelease":"119-100","text":"For each calendar year thereafter, the Governors of Puerto Rico and the United States Virgin Islands shall, on an alternating basis, take turns selecting the member.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t16/s6453/b/5","parentIdentifier":"/us/usc/t16/s6453/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fb%2F5","sourceRelease":"119-100","text":"A member appointed by the President of the Federated States of Micronesia.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t16/s6453/b/6","parentIdentifier":"/us/usc/t16/s6453/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fb%2F6","sourceRelease":"119-100","text":"A member appointed by the President of the Republic of the Marshall Islands.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t16/s6453/b/7","parentIdentifier":"/us/usc/t16/s6453/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6453%2Fb%2F7","sourceRelease":"119-100","text":"A member appointed by the President of the Republic of Palau.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
