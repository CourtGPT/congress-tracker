{"type":"section","nativeType":"section","number":"280h–1","heading":"Applied research program","label":"280h–1 Applied research program","identifier":"/us/usc/t42/s280h–1","parentIdentifier":"/us/usc/t42/ch6A/schII/ptQ","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280h%E2%80%931","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s280h–1/a","parentIdentifier":"/us/usc/t42/s280h–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280h%E2%80%931%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s280h–1/a/1","parentIdentifier":"/us/usc/t42/s280h–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280h%E2%80%931%2Fa%2F1","sourceRelease":"119-100","text":"conduct research to better understand the relationship between physical activity, diet, and health and factors that influence health-related behaviors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s280h–1/a/2","parentIdentifier":"/us/usc/t42/s280h–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280h%E2%80%931%2Fa%2F2","sourceRelease":"119-100","text":"develop and evaluate strategies for the prevention and treatment of obesity to be used in community-based interventions and by health professionals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s280h–1/a/3","parentIdentifier":"/us/usc/t42/s280h–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280h%E2%80%931%2Fa%2F3","sourceRelease":"119-100","text":"develop and evaluate strategies for the prevention and treatment of eating disorders, such as anorexia and bulimia;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s280h–1/a/4","parentIdentifier":"/us/usc/t42/s280h–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280h%E2%80%931%2Fa%2F4","sourceRelease":"119-100","text":"conduct research to establish the prevalence, consequences, and costs of childhood obesity and its effects in adulthood;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s280h–1/a/5","parentIdentifier":"/us/usc/t42/s280h–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280h%E2%80%931%2Fa%2F5","sourceRelease":"119-100","text":"identify behaviors and risk factors that contribute to obesity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s280h–1/a/6","parentIdentifier":"/us/usc/t42/s280h–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280h%E2%80%931%2Fa%2F6","sourceRelease":"119-100","text":"evaluate materials and programs to provide nutrition education to parents and teachers of children in child care or pre-school and the food service staff of such child care and pre-school entities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s280h–1/a/7","parentIdentifier":"/us/usc/t42/s280h–1/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280h%E2%80%931%2Fa%2F7","sourceRelease":"119-100","text":"evaluate materials and programs that are designed to educate and encourage physical activity in child care and pre-school facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Authorization of appropriations","label":"b Authorization of appropriations","identifier":"/us/usc/t42/s280h–1/b","parentIdentifier":"/us/usc/t42/s280h–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs280h%E2%80%931%2Fb","sourceRelease":"119-100","text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for each of the fiscal years 2001 through 2005.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
