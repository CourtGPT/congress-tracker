{"type":"section","nativeType":"section","number":"12140","heading":"Investigations by Secretary","label":"12140 Investigations by Secretary","identifier":"/us/usc/t46/s12140","parentIdentifier":"/us/usc/t46/stII/ptH/ch121/schIII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs12140","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—In General","label":"a .—In General","identifier":"/us/usc/t46/s12140/a","parentIdentifier":"/us/usc/t46/s12140","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs12140%2Fa","sourceRelease":"119-100","text":"The Secretary may conduct investigations and inspections regarding compliance with this chapter and regulations prescribed under this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Authority To Obtain Evidence.—","label":"b Authority To Obtain Evidence.—","identifier":"/us/usc/t46/s12140/b","parentIdentifier":"/us/usc/t46/s12140","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs12140%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t46/s12140/b/1","parentIdentifier":"/us/usc/t46/s12140/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs12140%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t46/s12140/b/1/A","parentIdentifier":"/us/usc/t46/s12140/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs12140%2Fb%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t46/s12140/b/1/A/i","parentIdentifier":"/us/usc/t46/s12140/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs12140%2Fb%2F1%2FA%2Fi","sourceRelease":"119-100","text":"is reasonable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t46/s12140/b/1/A/ii","parentIdentifier":"/us/usc/t46/s12140/b/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs12140%2Fb%2F1%2FA%2Fii","sourceRelease":"119-100","text":"will interfere with a criminal investigation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t46/s12140/b/1/B","parentIdentifier":"/us/usc/t46/s12140/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs12140%2Fb%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t46/s12140/b/1/B/i","parentIdentifier":"/us/usc/t46/s12140/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs12140%2Fb%2F1%2FB%2Fi","sourceRelease":"119-100","text":"determines that the subpoena is reasonable and will not interfere with a criminal investigation; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t46/s12140/b/1/B/ii","parentIdentifier":"/us/usc/t46/s12140/b/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs12140%2Fb%2F1%2FB%2Fii","sourceRelease":"119-100","text":"fails to make a determination with respect to the subpoena before the date that is 30 days after the date on which the Secretary makes a request under subparagraph (A) with respect to the subpoena.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Enforcement","label":"2 .—Enforcement","identifier":"/us/usc/t46/s12140/b/2","parentIdentifier":"/us/usc/t46/s12140/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft46%2Fs12140%2Fb%2F2","sourceRelease":"119-100","text":"In the case of a refusal to obey a subpoena issued to any person under this section, the Secretary may invoke the aid of the appropriate district court of the United States to compel compliance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
