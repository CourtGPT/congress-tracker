{"type":"section","nativeType":"section","number":"3712","heading":"Disposition of sale proceeds","label":"3712 Disposition of sale proceeds","identifier":"/us/usc/t12/s3712","parentIdentifier":"/us/usc/t12/ch38","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3712","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t12/s3712/1","parentIdentifier":"/us/usc/t12/s3712","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3712%2F1","sourceRelease":"119-100","text":"first to cover the costs of foreclosure provided for in ;section 3711 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t12/s3712/2","parentIdentifier":"/us/usc/t12/s3712","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3712%2F2","sourceRelease":"119-100","text":"then to pay valid tax liens or assessments prior to the mortgage;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t12/s3712/3","parentIdentifier":"/us/usc/t12/s3712","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3712%2F3","sourceRelease":"119-100","text":"then to pay any liens recorded prior to the recording of the mortgage which are required to be paid in conformity with the terms of sale in the notice of default and foreclosure sale;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t12/s3712/4","parentIdentifier":"/us/usc/t12/s3712","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3712%2F4","sourceRelease":"119-100","text":"then to service charges and advancements for taxes, assessments, and property insurance premiums;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t12/s3712/5","parentIdentifier":"/us/usc/t12/s3712","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3712%2F5","sourceRelease":"119-100","text":"then to the interest;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t12/s3712/6","parentIdentifier":"/us/usc/t12/s3712","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3712%2F6","sourceRelease":"119-100","text":"then to the principal balance secured by the mortgage (including expenditures for the necessary protection, preservation, and repair of the security property as authorized under the mortgage agreement and interest thereon if provided for in the mortgage agreement); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t12/s3712/7","parentIdentifier":"/us/usc/t12/s3712","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft12%2Fs3712%2F7","sourceRelease":"119-100","text":"then to late charges.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
