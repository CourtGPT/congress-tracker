{"type":"section","nativeType":"section","number":"7384f","heading":"Legislative proposal","label":"7384f Legislative proposal","identifier":"/us/usc/t42/s7384f","parentIdentifier":"/us/usc/t42/ch84/schXVI/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7384f","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Legislative proposal required","label":"a Legislative proposal required","identifier":"/us/usc/t42/s7384f/a","parentIdentifier":"/us/usc/t42/s7384f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7384f%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s7384f/a/1","parentIdentifier":"/us/usc/t42/s7384f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7384f%2Fa%2F1","sourceRelease":"119-100","text":"The types of compensation and benefits, including lost wages, medical benefits, and any lump-sum settlement payments, to be provided under the compensation program.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s7384f/a/2","parentIdentifier":"/us/usc/t42/s7384f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7384f%2Fa%2F2","sourceRelease":"119-100","text":"Any adjustments or modifications necessary to appropriately administer the compensation program under part B.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s7384f/a/3","parentIdentifier":"/us/usc/t42/s7384f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7384f%2Fa%2F3","sourceRelease":"119-100","text":"Whether to expand the compensation program to include other illnesses associated with exposure to toxic substances.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s7384f/a/4","parentIdentifier":"/us/usc/t42/s7384f/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7384f%2Fa%2F4","sourceRelease":"119-100","text":"Whether to expand the class of individuals who are members of the Special Exposure Cohort (as defined in section 7384(14) of this title).l","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Assessment of potential covered employees and required amounts","label":"b Assessment of potential covered employees and required amounts","identifier":"/us/usc/t42/s7384f/b","parentIdentifier":"/us/usc/t42/s7384f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7384f%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s7384f/b/1","parentIdentifier":"/us/usc/t42/s7384f/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7384f%2Fb%2F1","sourceRelease":"119-100","text":"An estimate of the number of covered employees that the President determines were exposed in the performance of duty.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s7384f/b/2","parentIdentifier":"/us/usc/t42/s7384f/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs7384f%2Fb%2F2","sourceRelease":"119-100","text":"An estimate, for each fiscal year of the