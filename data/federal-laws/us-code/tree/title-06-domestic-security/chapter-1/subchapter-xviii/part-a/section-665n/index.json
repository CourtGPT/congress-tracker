{"type":"section","nativeType":"section","number":"665n","heading":"Industrial Control Systems Cybersecurity Training Initiative","label":"665n Industrial Control Systems Cybersecurity Training Initiative","identifier":"/us/usc/t6/s665n","parentIdentifier":"/us/usc/t6/ch1/schXVIII/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t6/s665n/a","parentIdentifier":"/us/usc/t6/s665n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s665n/a/1","parentIdentifier":"/us/usc/t6/s665n/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fa%2F1","sourceRelease":"119-100","text":"The Industrial Control Systems Cybersecurity Training Initiative (in this section referred to as the “Initiative”) is established within the Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Purpose","label":"2 Purpose","identifier":"/us/usc/t6/s665n/a/2","parentIdentifier":"/us/usc/t6/s665n/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fa%2F2","sourceRelease":"119-100","text":"The purpose of the Initiative is to develop and strengthen the skills of the cybersecurity workforce related to securing industrial control systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirements","label":"b Requirements","identifier":"/us/usc/t6/s665n/b","parentIdentifier":"/us/usc/t6/s665n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s665n/b/1","parentIdentifier":"/us/usc/t6/s665n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s665n/b/1/A","parentIdentifier":"/us/usc/t6/s665n/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fb%2F1%2FA","sourceRelease":"119-100","text":"virtual and in-person trainings and courses provided at no cost to participants;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s665n/b/1/B","parentIdentifier":"/us/usc/t6/s665n/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fb%2F1%2FB","sourceRelease":"119-100","text":"trainings and courses available at different skill levels, including introductory level courses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s665n/b/1/C","parentIdentifier":"/us/usc/t6/s665n/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fb%2F1%2FC","sourceRelease":"119-100","text":"trainings and courses that cover cyber defense strategies for industrial control systems, including an understanding of the unique cyber threats facing industrial control systems and the mitigation of security vulnerabilities in industrial control systems technology; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s665n/b/1/D","parentIdentifier":"/us/usc/t6/s665n/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fb%2F1%2FD","sourceRelease":"119-100","text":"appropriate consideration regarding the availability of trainings and courses in different regions of the United States; and1So in original. The word “and” probably should not appear.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s665n/b/2","parentIdentifier":"/us/usc/t6/s665n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s665n/b/2/A","parentIdentifier":"/us/usc/t6/s665n/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fb%2F2%2FA","sourceRelease":"119-100","text":"collaboration with the National Laboratories of the Department of Energy in accordance with ;section 189 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s665n/b/2/B","parentIdentifier":"/us/usc/t6/s665n/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fb%2F2%2FB","sourceRelease":"119-100","text":"consultation with Sector Risk Management Agencies;2So in original. Probably should be followed by “and”.2","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s665n/b/2/C","parentIdentifier":"/us/usc/t6/s665n/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fb%2F2%2FC","sourceRelease":"119-100","text":"as appropriate, consultation with private sector entities with relevant expertise, such as vendors of industrial control systems technologies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s665n/b/3","parentIdentifier":"/us/usc/t6/s665n/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fb%2F3","sourceRelease":"119-100","text":"consult, to the maximum extent practicable, with commercial training providers and academia to minimize the potential for duplication of other training opportunities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Reports","label":"c Reports","identifier":"/us/usc/t6/s665n/c","parentIdentifier":"/us/usc/t6/s665n","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s665n/c/1","parentIdentifier":"/us/usc/t6/s665n/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fc%2F1","sourceRelease":"119-100","text":"Not later than one year after , and annually thereafter, the Director shall submit to the Committee on Homeland Security of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate a report on the Initiative.December 23, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t6/s665n/c/2","parentIdentifier":"/us/usc/t6/s665n/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s665n/c/2/A","parentIdentifier":"/us/usc/t6/s665n/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fc%2F2%2FA","sourceRelease":"119-100","text":"A description of the courses provided under the Initiative.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s665n/c/2/B","parentIdentifier":"/us/usc/t6/s665n/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fc%2F2%2FB","sourceRelease":"119-100","text":"A description of outreach efforts to raise awareness of the availability of such courses.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s665n/c/2/C","parentIdentifier":"/us/usc/t6/s665n/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fc%2F2%2FC","sourceRelease":"119-100","text":"The number of participants in each course.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s665n/c/2/D","parentIdentifier":"/us/usc/t6/s665n/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fc%2F2%2FD","sourceRelease":"119-100","text":"Voluntarily provided information on the demographics of participants in such courses, including by sex, race, and place of residence.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t6/s665n/c/2/E","parentIdentifier":"/us/usc/t6/s665n/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fc%2F2%2FE","sourceRelease":"119-100","text":"Information on the participation in such courses of workers from each critical infrastructure sector.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t6/s665n/c/2/F","parentIdentifier":"/us/usc/t6/s665n/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fc%2F2%2FF","sourceRelease":"119-100","text":"Plans for expanding access to industrial control systems education and training, including expanding access to women and underrepresented populations, and expanding access to different regions of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t6/s665n/c/2/G","parentIdentifier":"/us/usc/t6/s665n/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs665n%2Fc%2F2%2FG","sourceRelease":"119-100","text":"Recommendations regarding how to strengthen the state of industrial control systems cybersecurity education and training.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
