{"type":"section","nativeType":"section","number":"709","heading":"Emergency leave of absence","label":"709 Emergency leave of absence","identifier":"/us/usc/t10/s709","parentIdentifier":"/us/usc/t10/stA/ptII/ch40","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Emergency Leave of Absence","label":"a .—Emergency Leave of Absence","identifier":"/us/usc/t10/s709/a","parentIdentifier":"/us/usc/t10/s709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fa","sourceRelease":"119-100","text":"The Secretary concerned may grant a member of the armed forces emergency leave of absence for a qualifying emergency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Limitations","label":"b .—Limitations","identifier":"/us/usc/t10/s709/b","parentIdentifier":"/us/usc/t10/s709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s709/b/1","parentIdentifier":"/us/usc/t10/s709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fb%2F1","sourceRelease":"119-100","text":"may be granted only once for any member;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s709/b/2","parentIdentifier":"/us/usc/t10/s709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fb%2F2","sourceRelease":"119-100","text":"may be granted only to prevent the member from entering unearned leave status or excess leave status; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s709/b/3","parentIdentifier":"/us/usc/t10/s709/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fb%2F3","sourceRelease":"119-100","text":"may not extend for a period of more than 14 days.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Qualifying Emergency","label":"c .—Qualifying Emergency","identifier":"/us/usc/t10/s709/c","parentIdentifier":"/us/usc/t10/s709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s709/c/1","parentIdentifier":"/us/usc/t10/s709/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t10/s709/c/1/A","parentIdentifier":"/us/usc/t10/s709/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fc%2F1%2FA","sourceRelease":"119-100","text":"a medical condition of a member of the immediate family of the member; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t10/s709/c/1/B","parentIdentifier":"/us/usc/t10/s709/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fc%2F1%2FB","sourceRelease":"119-100","text":"any other hardship that the Secretary concerned determines appropriate for purposes of this section; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s709/c/2","parentIdentifier":"/us/usc/t10/s709/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fc%2F2","sourceRelease":"119-100","text":"is verified to the Secretary’s satisfaction based upon information or opinion from a source in addition to the member that the Secretary considers to be objective and reliable.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Military Department Regulations","label":"d .—Military Department Regulations","identifier":"/us/usc/t10/s709/d","parentIdentifier":"/us/usc/t10/s709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fd","sourceRelease":"119-100","text":"Regulations prescribed under this section by the Secretaries of the military department shall be as uniform as practicable and shall be subject to approval by the Secretary of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Definitions","label":"e .—Definitions","identifier":"/us/usc/t10/s709/e","parentIdentifier":"/us/usc/t10/s709","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s709/e/1","parentIdentifier":"/us/usc/t10/s709/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fe%2F1","sourceRelease":"119-100","text":"The term “unearned leave status” means leave approved to be used by a member of the armed forces that exceeds the amount of leave credit that has been accrued as a result of the member’s active service and that has not been previously used by the member.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s709/e/2","parentIdentifier":"/us/usc/t10/s709/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs709%2Fe%2F2","sourceRelease":"119-100","text":"The term “excess leave status” means leave approved to be used by a member of the armed forces that is unearned leave for which a member is unable to accrue leave credit during the member’s current term of service before the member’s separation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
